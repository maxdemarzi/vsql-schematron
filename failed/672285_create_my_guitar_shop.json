        "product_name": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "VALUES": [
            "Fender Stratocaster",
            "<PERSON>",
            "Gibson SG",
            "Yamaha FG700S",
            "Washburn D10S",
            "Rodriguez Caballero 11",
            "Fender Precision",
