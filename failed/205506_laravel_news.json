            "GRYApLPpJBe3AB0kZ1ay70Yk3sRoB0_clb-ha-noi-112419-1555078338212.jpg",
            "GW8nhzSYohIA6EyLjc6Wx45OZSa3sO_tphcm-112419-1555072231540.jpg",
