        "summary": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "VALUES": [
            "B\u00ean c\u1ea1nh nh\u1eefng cu\u1ed9c \u0111ua c\u1ee7a c\u00e1c \u0111\u1ed9i b\u00f3ng t\u1ea1i Premier League, kh\u00f4ng th\u1ec3 qu\u00ean c\u00e1c cu\u1ed9c \u0111ua c\u1ee7a c\u00e1c c\u00e1 nh\u00e2n, n\u1ed5i b\u1eadt l\u00e0 cu\u1ed9c chi\u1ebfn gi\u00e0nh \u201cChi\u1ebfc gi\u00e0y v\u00e0ng\u201d.",
            "Hai l\u1ea7n trong tr\u1eadn \u0111\u1ea5u n\u00e0y, ngo\u1ea1i binh Oliveira b\u00ean ph\u00eda Kh\u00e1nh Ho\u00e0 \u0111\u01b0a b\u00f3ng v\u00e0o l\u01b0\u1edbi CLB H\u00e0 N\u1ed9i,",
            "<PERSON>",
            "Ngay tr\u01b0\u1edbc th\u1ec1m c\u00e1c gi\u1ea3i \u0111\u1ea5u quan tr\u1ecdng c\u1ee7a c\u00e1c \u0111\u1ed9i tuy\u1ec3n Vi\u1ec7t Nam trong n\u0103m nay",
            "<PERSON>",
            "C\u00f3 th\u1ef1c t\u1ebf kh\u00f3 tin l\u00e0 MU thi \u0111\u1ea5u tr\u00ean s\u00e2n nh\u00e0 t\u1ec7 h\u01a1n s\u00e2n kh\u00e1ch trong th\u1eddi gian qua.",
            "Blackpink"
          ],
          "COMMENT": null
        },
