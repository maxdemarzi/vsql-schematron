          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "VALUES": [
            " \u0633\u0647 \u0633\u0637\u062d\u06cc \u0632\u06cc\u0633\u062a \u0634\u0646\u0627\u0633\u06cc \u06cc\u0627\u0632\u062f\u0647\u0645 \u0642\u0644\u0645 \u0686\u06cc",
            "\u0645\u063a\u0632 \u0633\u062e\u0646 \u0686\u06cc\u0646",
            "\u0645\u0631\u062c\u0639 \u062c\u0627\u0645\u0639 \u0648 \u06a9\u0627\u0631\u0628\u0631\u062f\u06cc ARCHICAD 16",
            "\u0645\u062f\u06cc\u0631\u06cc\u062a \u0634\u0628\u06a9\u0647 \u0647\u0627\u06cc \u0645\u062d\u0644\u06cc",
            "AutoCAD Electical \u0627\u062a\u0648\u06a9\u062f \u0627\u0644\u06a9\u062a\u0631\u06cc\u06a9\u0627\u0644",
            "\u0645\u0647\u0646\u062f\u0633\u06cc \u06a9\u0646\u062a\u0631\u0644\u060c(\u0648\u06cc\u0631\u0627\u0633\u062a \u067e\u0646\u062c\u0645 )",
            "\u0627\u0646\u0633\u0627\u0646 \u0648 \u0627\u062f\u06cc\u0627\u0646- \u0646\u0642\u0634 \u062f\u06cc\u0646 \u062f\u0631 \u0632\u0646\u062f\u06af\u06cc \u0641\u0631\u062f\u06cc \u0648 \u0627\u062c\u062a\u0645\u0627\u0639\u06cc"
          ],
          "COMMENT": null
        },
        "description": {
          "TYPE": "Text",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "VALUES": [
            " \u0633\u0647 \u0633\u0637\u062d\u06cc \u0632\u06cc\u0633\u062a \u0634\u0646\u0627\u0633\u06cc \u06cc\u0627\u0632\u062f\u0647\u0645 \u0642\u0644\u0645 \u0686\u06cc",
            "<PERSON>",
            "\u0645\u0631\u062c\u0639 \u062c\u0627\u0645\u0639 \u0648 \u06a9\u0627\u0631\u0628\u0631\u062f\u06cc ARCHICAD 16\r\n\r\n\u0646\u0648\u06cc\u0633\u0646\u062f\u0647: \u0645\u0633\u0639\u0648\u062f \u0628\u0627\u0642\u0631\u06cc-\u0645\u0635\u0637\u0641\u06cc \u0639\u0644\u06cc \u0646\u0698\u0627\u062f\u06cc\u0627\u0646\r\n\r\n\u0627\u0646\u062a\u0634\u0627\u0631\u0627\u062a : \u062f\u0627\u06cc\u0631\u0647 \u062f\u0627\u0646\u0634\r\n\r\n\u0633\u0631\u0641\u0635\u0644 \u0647\u0627:\r\n\r\n\u0641\u0635\u06441: \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0627\u0648\u0644\u06cc\u0647\r\n\r\n\u0641\u0635\u06442: \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u067e\u0627\u06cc\u0647\r\n\r\n\u0641\u0635\u06443: \u0627\u0628\u0632\u0627\u0631 \u062e\u0637 \u0648 \u0641\u0631\u0645\u0627\u0646\u0647\u0627\u06cc \u067e\u0627\u06cc\u0647\r\n\r\n\u0641\u0635\u06444: \u0631\u0648\u0634\u0647\u0627\u06cc \u0627\u0646\u062a\u062e\u0627\u0628 \u0627\u0644\u0645\u0627\u0646\u0647\u0627\r\n\r\n\u0641\u0635\u06445: \u0645\u0628\u0627\u062d\u062b \u0627\u0646\u062f\u0627\u0632\u0647 \u06af\u06cc\u0631\u06cc \u0648 \u0627\u0646\u062f\u0627\u0632\u0647 \u06cc\u0627\u0628\u06cc\r\n\r\n\u0641\u0635\u0644 6:\u0627\u0628\u0632\u0627\u0631 \u0647\u0627\u06cc \u0645\u062f\u06cc\u0631\u06cc\u062a \u062a\u0635\u0627\u0648\u06cc\u0631\u060c \u0645\u062d\u0627\u0633\u0628\u0627\u062a \u0633\u0637\u062d\u060c \u062d\u062c\u0645 \u0648 \u0647\u0627\u0634\u0648\u0631\u0632\u0646\u06cc\r\n\r\n\u0641\u0635\u0644 7:\u0645\u0628\u0627\u062d\u062b \u062c\u0646\u0633 \u0645\u0648\u0627\u062f \u0648 \u062a\u0646\u0638\u06cc\u0645\u0627\u062a \u0646\u0645\u0627\u06cc\u0634\u06cc\r\n\r\n\u0641\u0635\u06448: \u0627\u0628\u0632\u0627\u0631 \u0647\u0627\u06cc \u0627\u06cc\u062c\u0627\u062f \u0628\u0631\u0634 \u0648 \u0646\u0645\u0627 \u0648 \u0645\u0628\u0627\u062d\u062b \u0645\u0631\u0628\u0648\u0637\u0647\r\n\r\n\u0641\u0635\u06449: \u0627\u0645\u06a9\u0627\u0646\u0627\u062a \u0645\u062f\u06cc\u0631\u06cc\u062a \u062a\u0631\u0633\u06cc\u0645 \u0647\u0627\r\n\r\n\u0641\u0635\u064410: \u0631\u0648\u0634 \u0627\u06cc\u062c\u0627\u062f \u0637\u0628\u0642\u0627\u062a\r\n\r\n\u0641\u0635\u064411: \u0627\u0644\u0645\u0627\u0646\u0647\u0627\u06cc \u067e\u0631 \u06a9\u0627\u0631\u0628\u0631\u062f \u0645\u062f\u0644 \u0633\u0627\u0632\u06cc\r\n\r\n\u0648...",
            "\u0645\u062f\u06cc\u0631\u06cc\u062a \u0634\u0628\u06a9\u0647 \u0647\u0627\u06cc \u0645\u062d\u0644\u06cc( \u0628\u0631\u0627\u06cc  \u062a\u062f\u0631\u06cc\u0633 \u062f\u0631 \u062f\u0627\u0646\u0634\u06af\u0627\u0647)\r\n\r\n\u0646\u0648\u06cc\u0633\u0646\u062f\u0647: \u0642\u0631\u062a \u0627\u0644\u0647 \u0637\u0644\u0627\u06cc\u06cc \u060c  \u0633\u0627\u0628\u06cc\u0646\u0627 \u0646\u0648\u0631\u06cc\r\n\r\n\u0627\u0646\u062a\u0634\u0627\u0631\u0627\u062a: \u062f\u0627\u06cc\u0631\u0647 \u062f\u0627\u0646\u0634\r\n\r\n\u0633\u0631\u0641\u0635\u0644 \u0647\u0627:\r\n\r\n\u0641\u0635\u06441: \u0645\u0641\u0627\u0647\u06cc\u0645 \u0627\u0648\u0644\u06cc\u0647 \u0634\u0628\u06a9\u0647 network\r\n\r\n\u0641\u0635\u06442: \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc \u0639\u0627\u0645\u0644 \u062a\u06a9 \u06a9\u0627\u0631\u0628\u0631\u062f single user operating system\r\n\r\n\u0641\u0635\u06443: \u062a\u062c\u0647\u06cc\u0632\u0627\u062a \u0627\u0635\u0644\u06cc \u0634\u0628\u06a9\u0647\r\n\r\n\u0641\u0635\u06444:\u0642\u0631\u0627\u0631 \u062f\u0627\u062f\u0647\u0627\u06cc \u0634\u0628\u06a9\u0647 protocol\r\n\r\n\u0641\u0635\u06445: \u0627\u0633\u062a\u0627\u0646\u062f\u0627\u0631\u062f \u0647\u0627\u06cc \u0634\u0628\u06a9\u0647 \u0645\u062d\u0644\u06cc \u0628\u06cc \u0633\u06cc\u0645\r\n\r\n\u0641\u0635\u06446: \u0627\u0646\u0648\u0627\u0639 \u0634\u0628\u06a9\u0647\r\n\r\n\u0641\u0635\u06447: \u0631\u06cc\u062e\u062a \u0634\u0646\u0627\u0633\u06cc \u0634\u0628\u06a9\u0647 network topology\r\n\r\n\u0641\u0635\u06448: \u0622\u0634\u0646\u0627\u06cc\u06cc \u0628\u0627 \u0627\u0635\u0637\u0644\u0627\u062d\u0627\u062a \u062e\u0637\u0648\u0637 \u0645\u062e\u0627\u0628\u0631\u0627\u062a\u06cc\r\n\r\n\u0641\u0635\u06449: \u0631\u0627\u0647\u0646\u0645\u0627\u06cc \u0645\u062f\u06cc\u0631\u06cc\u062a \u0641\u0646\u0627\u0648\u0631\u06cc \u0627\u0637\u0644\u0627\u0639\u0627\u062a (IT)\r\n\r\n\u0641\u0635\u064410: \u062a\u062c\u0627\u0631\u062a \u0627\u0644\u06a9\u062a\u0631\u0648\u0646\u06cc\u06a9\r\n\r\n\u0641\u0635\u064411: \u0637\u0631\u0627\u062d\u06cc \u0645\u062f\u06cc\u0631\u06cc\u062a \u0634\u0628\u06a9\u0647\r\n\r\n\u0641\u0635\u064412: \u062d\u0641\u0627\u0638\u062a \u0627\u0632 \u0634\u0628\u06a9\u0647 \u0628\u0627 \u0628\u0647\u0631\u0647 \u06af\u06cc\u0631\u06cc \u0627\u0632 \u0641\u0627\u06cc\u0631\u0648\u0627\u0644 (\u062f\u06cc\u0648\u0627\u0631 \u062d\u0641\u0627\u0638\u062a\u06cc)\r\n\r\n \r\n\r\n ",
            "<PERSON>",
            "\u0646\u0627\u0645 \u06a9\u0627\u0644\u0627: \u0645\u0647\u0646\u062f\u0633\u06cc \u06a9\u0646\u062a\u0631\u0644\u060c(\u0648\u06cc\u0631\u0627\u0633\u062a \u067e\u0646\u062c\u0645 )\r\n\r\n\u0646\u0648\u06cc\u0633\u0646\u062f\u0647: \u06a9\u0627\u062a\u0633\u0648 \u0647\u06cc\u0644\u0648\u0648\u06af\u0627\u062a\u0627\r\n\r\n\u0645\u062a\u0631\u062c\u0645 : \u0645\u062d\u0645\u0648\u062f \u062f\u06cc\u0627\u0646\u06cc      \r\n\r\n\u0627\u0646\u062a\u0634\u0627\u0631\u0627\u062a: \u0646\u0635\r\n\r\n\u0645\u0648\u0636\u0648\u0639: \u0645\u0647\u0646\u062f\u0633\u06cc \u0628\u0631\u0642\r\n\r\n\u0633\u0631\u0641\u0635\u0644 \u0647\u0627:\r\n\r\n1. \u0645\u0639\u0631\u0641\u06cc \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc \u06a9\u0646\u062a\u0631\u0644\r\n\r\n2.\u0645\u062f\u0644 \u0633\u0627\u0632\u06cc \u0631\u06cc\u0627\u0636\u06cc \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc \u062f\u06cc\u0646\u0627\u0645\u06cc\u06a9\u06cc\r\n\r\n3.\u0645\u062f\u0644 \u0633\u0627\u0632\u06cc \u0631\u06cc\u0627\u0636\u06cc \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc \u0645\u06a9\u0627\u0646\u06cc\u06a9\u06cc \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc \u0627\u0644\u062a\u0631\u06cc\u06a9\u06cc\r\n\r\n4.\u0645\u062f\u0644 \u0633\u0627\u0632\u06cc \u0631\u06cc\u0627\u0636\u06cc \u0633\u06cc\u0633\u062a\u0645 \u0647\u0627\u06cc\u0633\u06cc\u0627\u0644\u0627\u062a\u06cc \u0648  \u06af\u0631\u0645\u0627\u06cc\u06cc\r\n\r\n5.\u062a\u062d\u0644\u06cc\u0644 \u067e\u0627\u0633\u062e \u06af\u0630\u0627\u0631 \u0648 \u067e\u0627\u0633\u062e \u062d\u0627\u0644\u0627\u062a \u0645\u0627\u0646\u062f\u06af\u0627\u0631\r\n\r\n6.\u062a\u062d\u0644\u06cc\u0644 \u0648 \u0637\u0631\u0627\u062d\u06cc \u0633\u06cc\u0633\u062a\u0645\u0647\u0627\u06cc \u06a9\u0646\u062a\u0631\u0644 \u0628\u0647 \u0631\u0648\u0634 \u0645\u06a9\u0627\u0646 \u0647\u0646\u062f\u0633\u0647 \u0631\u06cc\u0634\u0647 \u0647\u0627       ",
            "<PERSON>"
          ],
          "COMMENT": null
