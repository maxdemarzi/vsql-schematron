USE `db_217018_up`;
CREATE TABLE `rbac_resources` (
`id` VARCHAR(50) NOT NULL,
`realm_id` VARCHAR(50),
`resource_name` VARCHAR(50),
`description` TEXT,
`allowable_actions` TEXT,
`created_by` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_by` VARCHAR(50),
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_resource_instances` (
`id` VARCHAR(50) NOT NULL,
`resource_id` VARCHAR(50),
`license_policy_id` VARCHAR(50),
`scope` VARCHAR(50),
`ref_id` VARCHAR(50),
`status` VARCHAR(50),
`description` TEXT,
`created_by` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_by` VARCHAR(50),
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_resource_quotas` (
`id` VARCHAR(50) NOT NULL,
`resource_id` VARCHAR(50),
`license_policy_id` VARCHAR(50),
`scope` VARCHAR(50),
`max_value` INT,
`effective_at` TIMESTAMP NULL,
`expired_at` TIMESTAMP NULL,
`created_by` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_by` VARCHAR(50),
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
