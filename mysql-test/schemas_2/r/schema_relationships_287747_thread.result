[Implied]  deletions.thread_id -> threads.thread_id
[Implied]  deletions.user_zid -> thread_keys.user_zid
[Implied]  messages.msg_zid -> chunks.msg_zid
[Implied]  messages.msg_zid -> deletions.msg_zid
[Implied]  messages.thread_id -> threads.thread_id
[Implied]  thread_keys.thread_id -> threads.thread_id
[Implied]  thread_keys.user_zid -> deletions.user_zid

DROP DATABASE `db_287747_thread`;
UNINSTALL EXTENSION vsql_schematron;
