CREATE DATABASE `db_237660_scripts`;
USE `db_237660_scripts`;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`date_of_joining` TIMESTAMP NULL,
`designation` VARCHAR(50),
`gender` VARCHAR(50),
`email` VARCHAR(50),
`bio` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_assignment` (
`id` INT NOT NULL,
`employee_id` INT,
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_237660_scripts') AS relationships;
