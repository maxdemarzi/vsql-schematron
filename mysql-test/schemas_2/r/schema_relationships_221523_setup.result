INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 221523_setup
#
CREATE DATABASE `db_221523_setup`;
USE `db_221523_setup`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogs` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`image_url` TEXT,
`body` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`comment_text` VARCHAR(50),
`blog_id` INT,
`user_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_221523_setup') AS relationships;
relationships
Database: db_221523_setup

Table Connections:
