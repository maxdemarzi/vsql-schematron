CREATE DATABASE `db_286868_database`;
USE `db_286868_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password_hash` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_sessions` (
`id` INT NOT NULL,
`user_id` INT,
`device_uuid` INT,
`is_logged_in` INT,
`last_updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genre` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
