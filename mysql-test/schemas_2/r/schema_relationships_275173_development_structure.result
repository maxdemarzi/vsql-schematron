INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 275173_development_structure
#
CREATE DATABASE `db_275173_development_structure`;
USE `db_275173_development_structure`;
CREATE TABLE `authorizations` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` INT,
`client_id` INT,
`code_expires_at` DATETIME,
`redirect_url` VARCHAR(64),
`code` VARCHAR(64),
`scopes` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`store_id` INT,
`title` VARCHAR(64),
`secret` VARCHAR(64),
`api_key` VARCHAR(64),
`oauth_redirect_uri` VARCHAR(64),
`skips_authorization_dialog` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nonces` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`store_id` INT,
`key` VARCHAR(64),
`value` VARCHAR(64),
`url` VARCHAR(64),
`expires_at` DATETIME,
`user_id` INT,
`endpoint` VARCHAR(64),
`context` VARCHAR(64),
`delivery_status_key` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schema_migrations` (
`version` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `stores` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(64),
`default_url` VARCHAR(64),
`template_url` VARCHAR(64),
`scopes` VARCHAR(64),
`secret` VARCHAR(64),
`user_name_pattern` VARCHAR(64),
`minimum_user_name_length` INT,
`maximum_user_name_length` INT,
`default_sender_email_address` VARCHAR(64),
`login_methods` VARCHAR(64),
`hermes_session` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` INT,
`client_id` INT,
`authorization_code` VARCHAR(64),
`access_token` VARCHAR(64),
`refresh_token` VARCHAR(64),
`scopes` VARCHAR(64),
`expires_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`store_id` INT,
`name` VARCHAR(64),
`password_hash` VARCHAR(64),
`mobile_number` VARCHAR(64),
`mobile_verified` BOOL,
`email_address` VARCHAR(64),
`email_verified` BOOL,
`birth_date` DATETIME,
`gender` VARCHAR(64),
`deleted` BOOL,
`deleted_at` DATETIME,
`activated` BOOL,
`activated_at` DATETIME,
`logged_in` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_275173_development_structure') AS relationships;
relationships
Database: db_275173_development_structure

Table Connections:
