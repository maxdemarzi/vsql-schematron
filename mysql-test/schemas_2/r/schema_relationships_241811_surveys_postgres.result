INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 241811_surveys.postgres
#
CREATE DATABASE `db_241811_surveys_postgres`;
USE `db_241811_surveys_postgres`;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`password_digest` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `surveys` (
`id` INT,
`author_id` INT,
`title` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_choices` (
`id` INT,
`survey_id` INT,
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_responses` (
`id` INT,
`survey_id` INT,
`respondent_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_response_choices` (
`id` INT,
`survey_choice_id` INT,
`survey_response_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_241811_surveys_postgres') AS relationships;
relationships
