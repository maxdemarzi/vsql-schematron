CREATE DATABASE `db_203045_creatiing_a_database`;
USE `db_203045_creatiing_a_database`;
CREATE TABLE `Manager` (
`Mg_Name` VARCHAR(50),
`Mg_Number` VARCHAR(50) NOT NULL,
`Mg_Department` VARCHAR(50),
PRIMARY KEY (`Mg_Number`)
) CHARACTER SET latin1;
CREATE TABLE `product_cost` (
`pc_desc` VARCHAR(50),
`pc_code` VARCHAR(50) NOT NULL,
`pc_type` VARCHAR(50),
`pc_amount` INT,
PRIMARY KEY (`pc_code`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
`P_Name` VARCHAR(50),
`P_Number` VARCHAR(50) NOT NULL,
`P_Manager` VARCHAR(50),
`P_Act_Cost` INT,
`P_Exp_Cost` INT,
PRIMARY KEY (`P_Number`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_203045_creatiing_a_database') AS relationships;
