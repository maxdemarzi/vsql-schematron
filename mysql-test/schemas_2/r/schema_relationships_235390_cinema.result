INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 235390_cinema
#
CREATE DATABASE `db_235390_cinema`;
USE `db_235390_cinema`;
CREATE TABLE `movielist` (
`movienum` INT NOT NULL,
`name` VARCHAR(50),
`price` INT,
PRIMARY KEY (`movienum`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`name` VARCHAR(50),
`phone` VARCHAR(50) NOT NULL,
`age` INT,
PRIMARY KEY (`phone`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`ordernum` INT NOT NULL,
`phone` VARCHAR(50),
`movienum` INT,
`time` INT,
`seat` INT,
PRIMARY KEY (`ordernum`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_235390_cinema') AS relationships;
relationships
Database: db_235390_cinema

Table Connections:
