CREATE DATABASE `db_230193_db`;
USE `db_230193_db`;
CREATE TABLE `actor` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`birth_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`synopsis` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_actor` (
`movieid` INT,
`actorid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230193_db') AS relationships;
