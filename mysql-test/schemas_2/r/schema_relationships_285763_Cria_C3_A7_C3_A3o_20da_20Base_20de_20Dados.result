USE `db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados`;
CREATE TABLE `Fornecedor` (
`cod_fornecedor` INT NOT NULL,
`nome` VARCHAR(50),
`morada` VARCHAR(50),
`nif` DECIMAL(10,2),
`telefone` DECIMAL(10,2),
PRIMARY KEY (`cod_fornecedor`)
) CHARACTER SET latin1;
CREATE TABLE `Armazem` (
`cod_armazem` INT NOT NULL,
`nome` VARCHAR(50),
`morada` VARCHAR(50),
`cidade` VARCHAR(50),
PRIMARY KEY (`cod_armazem`)
) CHARACTER SET latin1;
CREATE TABLE `ArmazemProduto` (
`cod_armazem` INT,
`cod_produto` INT,
`stock` INT,
`stock_minimo` INT,
`corredor` VARCHAR(50),
`prateleira` VARCHAR(50)
) CHARACTER SET latin1;
