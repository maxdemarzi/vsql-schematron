INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 294114_schema-oracle
#
CREATE DATABASE `db_294114_schema_oracle`;
USE `db_294114_schema_oracle`;
CREATE TABLE `SPRING_SESSION` (
`PRIMARY_ID` VARCHAR(50) NOT NULL,
`SESSION_ID` CHAR(50),
`CREATION_TIME` DECIMAL(10,2),
`LAST_ACCESS_TIME` DECIMAL(10,2),
`MAX_INACTIVE_INTERVAL` DECIMAL(10,2),
`EXPIRY_TIME` DECIMAL(10,2),
`PRINCIPAL_NAME` VARCHAR(50),
PRIMARY KEY (`PRIMARY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SPRING_SESSION_ATTRIBUTES` (
`SESSION_PRIMARY_ID` VARCHAR(50) NOT NULL,
`ATTRIBUTE_NAME` VARCHAR(50) NOT NULL,
`ATTRIBUTE_BYTES` BLOB,
PRIMARY KEY (`SESSION_PRIMARY_ID`, `ATTRIBUTE_NAME`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_294114_schema_oracle') AS relationships;
