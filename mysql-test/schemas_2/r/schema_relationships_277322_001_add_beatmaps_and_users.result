CREATE DATABASE `db_277322_001_add_beatmaps_and_users`;
USE `db_277322_001_add_beatmaps_and_users`;
CREATE TABLE `users` (
`id` INT,
`api_fetched_at` DATETIME,
`avatar_url` VARCHAR(64),
`banned` VARCHAR(64),
`country` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `beatmapsets` (
`id` INT,
`api_fetched_at` DATETIME,
`artist` VARCHAR(64),
`created_at` DATETIME,
`creator_id` INT,
`creator_name` VARCHAR(64),
`favorite_count` INT,
`play_count` INT,
`ranked_status` INT,
`submitted_at` DATETIME,
`title` VARCHAR(64),
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `beatmaps` (
`id` INT,
`beatmapset_id` INT,
`bpm` DECIMAL(10,2),
`game_mode` INT,
`key_count` INT,
`play_count` INT,
`star_rating` DECIMAL(10,2),
`version` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `beatmapset_creators` (
`beatmapset_id` INT,
`creator_id` INT,
`game_mode` INT,
PRIMARY KEY (`beatmapset_id`, `creator_id`, `game_mode`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_277322_001_add_beatmaps_and_users') AS relationships;
