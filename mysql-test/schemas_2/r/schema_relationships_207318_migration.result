INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 207318_migration
#
CREATE DATABASE `db_207318_migration`;
USE `db_207318_migration`;
CREATE TABLE `users` (
`id` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lists` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`checked` VARCHAR(64),
`note` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`list_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_lists` (
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` VARCHAR(64),
`list_id` VARCHAR(64),
PRIMARY KEY (`user_id`, `list_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_207318_migration') AS relationships;
