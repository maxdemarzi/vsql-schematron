INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 218501_blog_with_tags.postgres
#
CREATE DATABASE `db_218501_blog_with_tags_postgres`;
USE `db_218501_blog_with_tags_postgres`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`password_digest` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT NOT NULL,
`author_id` INT,
`title` TEXT,
`body` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT NOT NULL,
`name` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `taggings` (
`id` INT NOT NULL,
`article_id` INT,
`tag_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_218501_blog_with_tags_postgres') AS relationships;
relationships
Database: db_218501_blog_with_tags_postgres

Table Connections:
