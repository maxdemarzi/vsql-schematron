) CHARACTER SET latin1;
CREATE TABLE `Images` (
`Id` INT,
`Title` VARCHAR(64),
`Comment` VARCHAR(64),
`Url` VARCHAR(64),
`Path` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `CollectionItems` (
`Collection` INT,
`Item` INT
) CHARACTER SET latin1;
