INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 255016_migration
#
CREATE DATABASE `db_255016_migration`;
USE `db_255016_migration`;
CREATE TABLE `tweets` (
`id` INT,
`body` VARCHAR(64),
`userId` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT,
`compound_id` VARCHAR(64),
`user_id` INT,
`provider_type` VARCHAR(64),
`provider_id` VARCHAR(64),
`provider_account_id` VARCHAR(64),
`refresh_token` VARCHAR(64),
`access_token` VARCHAR(64),
`access_token_expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`id` INT,
`user_id` INT,
`expires` DATETIME,
`session_token` VARCHAR(64),
`access_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified` DATETIME,
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `verification_requests` (
`id` INT,
`identifier` VARCHAR(64),
`token` VARCHAR(64),
`expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_255016_migration') AS relationships;
