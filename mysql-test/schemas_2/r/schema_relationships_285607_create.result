`pid` INT NOT NULL,
`corcern` INT,
`content` VARCHAR(50),
`thetime` DATE,
`truth` VARCHAR(50),
`uid` VARCHAR(50),
`pic` VARCHAR(50),
`title` VARCHAR(50),
`subtitle` VARCHAR(50),
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `norumor.problem` (
`questionContent` VARCHAR(50),
`qid` INT NOT NULL,
`thetime` DATE,
`uid` VARCHAR(50),
PRIMARY KEY (`qid`)
) CHARACTER SET latin1;
CREATE TABLE `norumor.answer` (
`replyContent` VARCHAR(50),
`pid` INT NOT NULL,
`qid` INT,
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
