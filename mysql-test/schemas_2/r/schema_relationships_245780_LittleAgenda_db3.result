`ContactType` INT,
PRIMARY KEY (`TelephoneId`)
) CHARACTER SET latin1;
CREATE TABLE `Email` (
`EmailId` VARCHAR(50) NOT NULL,
`ContactId` TEXT,
`EmailContent` TEXT,
`ContactType` INT,
PRIMARY KEY (`EmailId`)
) CHARACTER SET latin1;
CREATE TABLE `Contact` (
`ContactId` VARCHAR(50) NOT NULL,
`Name` TEXT,
`Observation` TEXT,
`FavoriteTag` INT,
PRIMARY KEY (`ContactId`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
`AddressId` VARCHAR(50) NOT NULL,
`ContactId` TEXT,
`AddressContent` TEXT,
`ContactType` INT,
PRIMARY KEY (`AddressId`)
) CHARACTER SET latin1;
