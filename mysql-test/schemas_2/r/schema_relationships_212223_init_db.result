CREATE DATABASE `db_212223_init_db`;
USE `db_212223_init_db`;
CREATE TABLE `Session` (
`Id` INT,
`SessionStart` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
`Id` INT,
`SessionId` INT,
`TimeStamp` INT,
`Key` VARCHAR(64),
`Type` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ValueBool` (
`Id` INT,
`Value` BOOL,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ValueString` (
`Id` INT,
`Value` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ValueNumber` (
`Id` INT,
`Value` DECIMAL(10,2),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_212223_init_db') AS relationships;
