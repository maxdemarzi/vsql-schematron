INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 266035_schema
#
CREATE DATABASE `db_266035_schema`;
USE `db_266035_schema`;
CREATE TABLE `department` (
`id` INT,
`dept_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_266035_schema') AS relationships;
relationships
Database: db_266035_schema

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> department.id

DROP DATABASE `db_266035_schema`;
UNINSTALL EXTENSION vsql_schematron;
