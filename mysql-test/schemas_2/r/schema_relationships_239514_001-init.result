INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 239514_001-init
#
CREATE DATABASE `db_239514_001_init`;
USE `db_239514_001_init`;
CREATE TABLE `settings` (
`setting` TEXT,
`value` TEXT
) CHARACTER SET latin1;
CREATE TABLE `libraries` (
`id` INT NOT NULL,
`path` TEXT,
`searchByDefault` INT,
`stillExists` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT NOT NULL,
`libraryId` INT,
`path` VARCHAR(50),
`lastModified` INT,
`size` INT,
`stillExists` INT,
`indexed` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tracks` (
`id` INT NOT NULL,
`fileId` INT,
`trackNumber` INT,
`type` VARCHAR(50),
`language` VARCHAR(50),
`title` VARCHAR(50),
`subtitlePreambleJson` VARCHAR(50),
`subtitleNondialogueEventsJson` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations` (
`id` INT NOT NULL,
`trackId` INT,
`indexedText` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lines` (
`id` INT NOT NULL,
`conversationId` INT,
`startMs` INT,
`endMs` INT,
`subtitleEventJson` TEXT,
`displayText` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_239514_001_init') AS relationships;
relationships
Database: db_239514_001_init

Table Connections:
------------------
[Implied]  conversations.trackId -> tracks.id
[Implied]  files.libraryId -> libraries.id
[Implied]  lines.conversationId -> conversations.id
[Implied]  tracks.fileId -> files.id

DROP DATABASE `db_239514_001_init`;
UNINSTALL EXTENSION vsql_schematron;
