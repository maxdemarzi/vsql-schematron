) CHARACTER SET latin1;
CREATE TABLE `ratings` (
`id` INT NOT NULL,
`movie_id` INT,
`number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publishyear` (
`id` INT NOT NULL,
`movie_id` INT,
`releasedate` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
