`id` INT NOT NULL,
`director_id` INT,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` TEXT,
