CREATE DATABASE `db_276194_migration`;
USE `db_276194_migration`;
CREATE TABLE `players` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`birth_date` DATETIME,
`weight` INT,
`height` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `divisions` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`id` INT,
`name` VARCHAR(255),
`division` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roster` (
`team_id` INT,
`player_id` INT,
PRIMARY KEY (`team_id`, `player_id`)
) CHARACTER SET latin1;
