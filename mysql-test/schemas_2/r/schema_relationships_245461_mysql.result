INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 245461_mysql
#
CREATE DATABASE `db_245461_mysql`;
USE `db_245461_mysql`;
CREATE TABLE `AM_GW_PUBLISHED_API_DETAILS` (
`API_ID` VARCHAR(64),
`TENANT_DOMAIN` VARCHAR(64),
`API_PROVIDER` VARCHAR(64),
`API_NAME` VARCHAR(64),
`API_VERSION` VARCHAR(64),
`API_TYPE` VARCHAR(64),
PRIMARY KEY (`API_ID`)
) CHARACTER SET latin1;
CREATE TABLE `AM_GW_API_ARTIFACTS` (
`API_ID` VARCHAR(64),
`REVISION_ID` VARCHAR(64),
`ARTIFACT` VARCHAR(64),
`TIME_STAMP` DATETIME,
PRIMARY KEY (`REVISION_ID`, `API_ID`)
) CHARACTER SET latin1;
CREATE TABLE `AM_GW_API_DEPLOYMENTS` (
`API_ID` VARCHAR(64),
`REVISION_ID` VARCHAR(64),
`LABEL` VARCHAR(64),
`VHOST` VARCHAR(64),
PRIMARY KEY (`REVISION_ID`, `API_ID`, `LABEL`)
) CHARACTER SET latin1;
CREATE TABLE `AM_SERVICE_CATALOG` (
`UUID` VARCHAR(64),
`SERVICE_KEY` VARCHAR(64),
`MD5` VARCHAR(64),
`SERVICE_NAME` VARCHAR(64),
`DISPLAY_NAME` VARCHAR(64),
`SERVICE_VERSION` VARCHAR(64),
`TENANT_ID` INT,
`SERVICE_URL` VARCHAR(64),
`DEFINITION_TYPE` VARCHAR(64),
`DEFINITION_URL` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`SECURITY_TYPE` VARCHAR(64),
`MUTUAL_SSL_ENABLED` VARCHAR(64),
`CREATED_TIME` DATETIME,
`LAST_UPDATED_TIME` DATETIME,
`CREATED_BY` VARCHAR(64),
`UPDATED_BY` VARCHAR(64),
`SERVICE_DEFINITION` VARCHAR(64),
`METADATA` VARCHAR(64),
PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;
CREATE TABLE `AM_API_SERVICE_MAPPING` (
`API_ID` INT,
`SERVICE_KEY` VARCHAR(64),
`MD5` VARCHAR(64),
`TENANT_ID` INT,
PRIMARY KEY (`API_ID`, `SERVICE_KEY`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_245461_mysql') AS relationships;
