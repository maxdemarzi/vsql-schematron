INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 249066_fakebook
#
CREATE DATABASE `db_249066_fakebook`;
USE `db_249066_fakebook`;
CREATE TABLE `comments` (
`comment_id` INT,
`comment_content` VARCHAR(64),
`post_id` INT,
`comment_owner` INT,
`commented_on` DATETIME,
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `comment_liked_by_users` (
`comment_id` INT,
`comment_liked_by` INT,
`comment_liked_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `friend_requests` (
`request_id` INT,
`request_from` INT,
`request_to` INT,
`request_on` DATETIME,
`request_status` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`msg_id` INT,
`msg_content` VARCHAR(64),
`msg_from` INT,
`msg_to` INT,
`msgd_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`post_id` INT,
`post_content` VARCHAR(64),
`original_post` INT,
`post_owner` INT,
`posted_on` DATETIME,
`is_shared_post` INT,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `post_liked_by_users` (
`post_id` INT,
`post_liked_by` INT,
`post_liked_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`user_id` INT,
`token` VARCHAR(64),
`logged_in` DATETIME,
PRIMARY KEY (`user_id`, `token`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`email` VARCHAR(64),
`psword` VARCHAR(64),
`registered_on` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_249066_fakebook') AS relationships;
