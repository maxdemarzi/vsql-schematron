INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 257055_kmo_20last
#
CREATE DATABASE `db_257055_kmo_20last`;
USE `db_257055_kmo_20last`;
CREATE TABLE `city` (
`id` INT,
`name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `exam` (
`id` INT,
`examtitle` VARCHAR(255),
`filepath` VARCHAR(255),
`examdate` DATETIME,
`starttime` DATETIME,
`endtime` DATETIME,
`description` VARCHAR(255),
`examstatus` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `examresult` (
`id` INT,
`userid` INT,
`examid` INT,
`filepath` VARCHAR(255),
`score` INT,
`collecttime` DATETIME,
`resultstatus` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`id` INT,
`userid` INT,
`accountname` VARCHAR(255),
`bank` VARCHAR(255),
`paymentslip` VARCHAR(255),
`paymentstatus` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`nisn` VARCHAR(255),
`fullname` VARCHAR(255),
`email` VARCHAR(255),
`gender` VARCHAR(255),
`school` VARCHAR(255),
`address` VARCHAR(255),
`phoneNumber` VARCHAR(255),
`dateOfBirth` DATETIME,
`photo` VARCHAR(255),
`password` VARCHAR(255),
`salt` VARCHAR(255),
`privilege` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_257055_kmo_20last') AS relationships;
relationships
Database: db_257055_kmo_20last

