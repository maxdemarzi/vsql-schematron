) CHARACTER SET latin1;
CREATE TABLE `resource` (
`id` VARCHAR(64),
`de_title` VARCHAR(64),
`en_title` VARCHAR(64),
`en_description` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `resource_layer` (
`id` INT,
`resource_id` VARCHAR(64),
`layer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
