CREATE DATABASE `db_221683_create_tables`;
USE `db_221683_create_tables`;
CREATE TABLE `sales_rep` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `leads` (
`id` INT,
`company_name` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`phone_number` VARCHAR(64),
`rep_lead_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
`id` INT,
`city` VARCHAR(64),
`country` VARCHAR(64),
`employee_count` INT,
`industry` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact` (
`id` INT,
`company_name` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`phone_number` VARCHAR(64),
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `opportunity` (
`id` INT,
`product` VARCHAR(64),
`quantity` INT,
`status` VARCHAR(64),
`account_id` INT,
`decision_maker_id` INT,
`rep_opportunity_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
