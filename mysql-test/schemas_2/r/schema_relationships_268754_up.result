CREATE DATABASE `db_268754_up`;
USE `db_268754_up`;
CREATE TABLE `vendors` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`phone` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`ucid` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `points` (
`id` INT,
`user_id` INT,
`vendor_id` INT,
`amount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_268754_up') AS relationships;
