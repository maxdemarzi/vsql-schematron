INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 262783_db_init
#
CREATE DATABASE `db_262783_db_init`;
USE `db_262783_db_init`;
CREATE TABLE `companies` (
`company_id` INT,
`company_name` VARCHAR(64),
`company_address` VARCHAR(64),
`company_tax_number` VARCHAR(64),
PRIMARY KEY (`company_id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations` (
`conversation_id` INT,
`conversation_subject` VARCHAR(64),
PRIMARY KEY (`conversation_id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations_members` (
`id` INT,
`conversation_id` INT,
`user_id` INT,
`conversation_last_viewed` INT,
`conversation_deleted` INT
) CHARACTER SET latin1;
CREATE TABLE `conversations_messages` (
`message_id` INT,
`conversation_id` INT,
`user_id` INT,
`date_sent` INT,
`message_body` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `shipments` (
`shipment_id` INT,
`sent` INT,
`recipient` VARCHAR(64),
`recipient_address` VARCHAR(64),
`body_sent_correspondence` VARCHAR(64),
`received` INT,
`shipment_type_id` INT,
`registered_by_id` INT,
`date_received` DATETIME,
`date_sent` DATETIME,
`updated_by_id` INT,
`date_updated` DATETIME,
`deleted` INT
) CHARACTER SET latin1;
CREATE TABLE `shipments_types` (
`shipment_type_id` INT,
`shipment_type_name` VARCHAR(64),
PRIMARY KEY (`shipment_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`login` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`job_title` VARCHAR(64),
`cellphone` VARCHAR(64),
`landline_phone` VARCHAR(64),
`email` VARCHAR(64),
`company_id` INT,
`allow_email` INT,
`permissions` INT,
`last_logged_in` DATETIME,
`picture` VARCHAR(64),
`type` VARCHAR(64),
`active` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_262783_db_init') AS relationships;
