INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 257551_electrodes
#
CREATE DATABASE `db_257551_electrodes`;
USE `db_257551_electrodes`;
CREATE TABLE `electrode_groups` (
`id` INT NOT NULL,
`name` TEXT,
`CoordinateSystem` TEXT,
`CoordinateUnits` TEXT,
`IntendedFor` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `electrodes` (
`electrode_group_id` INT,
`name` TEXT,
`x` DOUBLE,
`y` DOUBLE,
`z` DOUBLE,
`size` DOUBLE,
`material` TEXT,
`manufacturer` TEXT,
`groups` TEXT,
`hemisphere` TEXT,
`type` TEXT,
`impedance` DOUBLE,
`dimension` TEXT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_257551_electrodes') AS relationships;
relationships
Database: db_257551_electrodes

