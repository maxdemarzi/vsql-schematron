`ID_PATIENT` INT,
PRIMARY KEY (`ID_CARER`, `ID_PATIENT`)
) CHARACTER SET latin1;
CREATE TABLE `symptomsformpatient` (
`ID_PATIENT` INT,
`Q1` VARCHAR(64),
`Q2` VARCHAR(64),
`formdate` DATETIME,
`pathvideo` VARCHAR(64),
`discrepancy` INT,
PRIMARY KEY (`ID_PATIENT`, `formdate`)
) CHARACTER SET latin1;
CREATE TABLE `patientxsymptomsform` (
`ID_PATIENT` INT,
`DATE_FORM` DATETIME,
PRIMARY KEY (`DATE_FORM`, `ID_PATIENT`)
) CHARACTER SET latin1;
