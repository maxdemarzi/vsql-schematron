PRIMARY KEY (`ID_DOCTOR`, `ID_PATIENT`)
) CHARACTER SET latin1;
CREATE TABLE `patientxdoctor` (
`ID_DOCTOR` INT,
`ID_PATIENT` INT,
PRIMARY KEY (`ID_DOCTOR`, `ID_PATIENT`)
) CHARACTER SET latin1;
CREATE TABLE `patientxcarer` (
