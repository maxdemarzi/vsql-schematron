CREATE DATABASE `db_249522_script`;
USE `db_249522_script`;
CREATE TABLE `users` (
`ID` INT,
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`TYPE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `doctors` (
`ID_USER` INT,
`NAME` VARCHAR(64),
`PHOTOPATH` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
`ID_USER` INT,
`NAME` VARCHAR(64),
`PHOTOPATH` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `carers` (
`ID_USER` INT,
`NAME` VARCHAR(64),
