CREATE TABLE `emotionalformxpatient` (
`ID_PATIENT` INT,
`Q1` INT,
`Q2` INT,
`date` DATETIME,
PRIMARY KEY (`ID_PATIENT`, `date`)
) CHARACTER SET latin1;
CREATE TABLE `medicinealarmpatient` (
`ID_PATIENT` INT,
`id` VARCHAR(64),
`title` VARCHAR(64),
`alarmDateTime` DATETIME,
`alarmTime` DATETIME,
`isPending` BOOL,
PRIMARY KEY (`ID_PATIENT`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `medicine` (
`ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `alarmandmedicinepatient` (
`ID_PATIENT` INT,
`periodicityQuantity` INT,
`title` VARCHAR(64),
`alarmTime` DATETIME,
`idMedicine` INT,
`dose` VARCHAR(64),
`periodicityType` VARCHAR(64),
PRIMARY KEY (`ID_PATIENT`, `idMedicine`, `alarmTime`)
) CHARACTER SET latin1;
CREATE TABLE `toolboxitems` (
`ID` INT,
`Title` VARCHAR(64),
`Description` VARCHAR(64),
`URL` VARCHAR(64),
`Type` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `stepsxpatient` (
`ID_PATIENT` INT,
`stepDate` DATETIME,
`quantitySteps` INT,
PRIMARY KEY (`ID_PATIENT`, `stepDate`)
) CHARACTER SET latin1;
CREATE TABLE `touchgamexpatient` (
`ID_PATIENT` INT,
`gameDate` DATETIME,
`score` INT,
PRIMARY KEY (`ID_PATIENT`, `gameDate`)
) CHARACTER SET latin1;
