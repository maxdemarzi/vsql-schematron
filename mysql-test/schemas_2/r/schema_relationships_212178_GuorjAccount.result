CREATE TABLE `roles` (
`RoleID` VARCHAR(50) NOT NULL,
`Name` VARCHAR(50),
PRIMARY KEY (`RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `userroles` (
`UserID` VARCHAR(50) NOT NULL,
`RoleID` VARCHAR(50) NOT NULL,
PRIMARY KEY (`UserID`, `RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`ID` VARCHAR(50) NOT NULL,
`NickName` VARCHAR(50),
`Birthday` DATE,
`Gender` TINYINT,
`CreateAt` DATETIME,
`UpdateAt` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
