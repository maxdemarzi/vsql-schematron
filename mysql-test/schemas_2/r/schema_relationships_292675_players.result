CREATE DATABASE `db_292675_players`;
USE `db_292675_players`;
CREATE TABLE `team_details` (
`id` BIGINT NOT NULL,
`created_at` BIGINT,
`updated_at` BIGINT,
`team_code` INT,
`team_name` VARCHAR(50),
`ranking_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ranking_details` (
`id` BIGINT NOT NULL,
`created_at` BIGINT,
`updated_at` BIGINT,
`team_id` INT,
`test_ranking` INT,
`odi_ranking` INT,
`t20_ranking` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
