CREATE DATABASE `db_257207_tic_tac_toe_postgres`;
USE `db_257207_tic_tac_toe_postgres`;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`password_digest` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
`id` INT,
`winner_id` INT,
`completed_at` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games_players` (
`id` INT,
`game_id` INT,
`player_id` INT,
`token` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
