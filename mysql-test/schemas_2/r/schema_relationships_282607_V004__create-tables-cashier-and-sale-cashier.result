CREATE DATABASE `db_282607_V004__create_tables_cashier_and_sale_cashier`;
USE `db_282607_V004__create_tables_cashier_and_sale_cashier`;
CREATE TABLE `cashier` (
`id` VARCHAR(50) NOT NULL,
`closing_date` DATETIME,
`opening_date` DATETIME,
`status` TINYINT,
`total_value` DECIMAL(10,2),
`value_reported` DECIMAL(10,2),
`cards_value` DECIMAL(10,2),
`money_value` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sale_cashier` (
`cashier_id` VARCHAR(50),
`sale_id` VARCHAR(50)
) CHARACTER SET latin1;
