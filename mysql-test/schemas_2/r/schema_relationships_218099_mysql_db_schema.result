CREATE DATABASE `db_218099_mysql_db_schema`;
USE `db_218099_mysql_db_schema`;
CREATE TABLE `permissions` (
`user_id` VARCHAR(50),
`permission_bit` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `permissions_schema` (
`bit` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`bit`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_218099_mysql_db_schema') AS relationships;
