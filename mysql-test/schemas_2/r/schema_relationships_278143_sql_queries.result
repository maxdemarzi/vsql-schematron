INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 278143_sql_queries
#
CREATE DATABASE `db_278143_sql_queries`;
USE `db_278143_sql_queries`;
CREATE TABLE `city` (
`CityID` INT NOT NULL,
`City` VARCHAR(50),
PRIMARY KEY (`CityID`)
) CHARACTER SET latin1;
CREATE TABLE `postal_codes` (
`PostalCodeID` INT NOT NULL,
`PostalCode` VARCHAR(50),
`CityId` INT,
PRIMARY KEY (`PostalCodeID`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`CategoryID` INT NOT NULL,
`Category` VARCHAR(50),
PRIMARY KEY (`CategoryID`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants_info` (
`id` VARCHAR(50) NOT NULL,
`RestaurantName` VARCHAR(50),
`Reviews` INT,
`Rating` DECIMAL(10,2),
`Price` VARCHAR(50),
`RestaurantPhone` VARCHAR(50),
`RestaurantAddress` VARCHAR(50),
`RestaurantLatitude` DECIMAL(10,2),
`RestaurantLongitude` DECIMAL(10,2),
`RestaurantDistance` DECIMAL(10,2),
`PostalCodeID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants_with_categories` (
`RestaurantID` VARCHAR(50),
`CategoryID` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_278143_sql_queries') AS relationships;
relationships
Database: db_278143_sql_queries

Table Connections:
------------------
[Implied]  postal_codes.CityId -> city.CityID
[Implied]  restaurants_info.PostalCodeID -> postal_codes.PostalCodeID
[Implied]  restaurants_with_categories.CategoryID -> categories.CategoryID
[Implied]  restaurants_with_categories.RestaurantID -> restaurants_info.id

DROP DATABASE `db_278143_sql_queries`;
UNINSTALL EXTENSION vsql_schematron;
