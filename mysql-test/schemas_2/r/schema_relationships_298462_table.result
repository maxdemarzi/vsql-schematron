PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `discography` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `song` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
