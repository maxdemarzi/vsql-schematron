CREATE TABLE `userTBL` (
`아이디` VARCHAR(50) NOT NULL,
`이름` VARCHAR(50),
`생년` INT,
`지역` CHAR(50),
`국번` CHAR(50),
`전화번호` CHAR(50),
`키` INT,
`가입일` DATE,
PRIMARY KEY (`아이디`)
) CHARACTER SET latin1;
CREATE TABLE `buyTBL` (
`순번` INT NOT NULL,
`아이디` VARCHAR(50),
`물품` VARCHAR(50),
`분류` VARCHAR(50),
`단가` INT,
`수량` INT,
PRIMARY KEY (`순번`)
) CHARACTER SET latin1;
