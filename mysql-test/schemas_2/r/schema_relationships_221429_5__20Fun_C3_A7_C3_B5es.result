) CHARACTER SET latin1;
CREATE TABLE `FILME` (
`IDFILME` INT NOT NULL,
`NOME` VARCHAR(50),
`ANO` INT,
`ID_GENERO` INT,
PRIMARY KEY (`IDFILME`)
) CHARACTER SET latin1;
CREATE TABLE `LOCACAO` (
`IDLOCACAO` INT NOT NULL,
`DATA` DATE,
`MIDIA` INT,
`DIAS` INT,
`ID_FILME` INT,
PRIMARY KEY (`IDLOCACAO`)
) CHARACTER SET latin1;
