) CHARACTER SET latin1;
CREATE TABLE `estudiante_x_grupo` (
`id` INT NOT NULL,
`idEstudiante` INT,
`idGrupo` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
