[Implied]  ticket_customer.customerID -> customers.customerID
[Implied]  ticket_customer.ticketNO -> ticket.ticketNO
[Implied]  ticket_event.eventID -> events.eventID
[Implied]  ticket_event.ticketNO -> ticket.ticketNO

DROP DATABASE `db_269949_schema`;
UNINSTALL EXTENSION vsql_schematron;
