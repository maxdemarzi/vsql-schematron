`question_text` VARCHAR(64),
`question_type` VARCHAR(64),
`question_correct_answer` VARCHAR(64),
`kc_question_id` INT,
PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT,
`user_login` VARCHAR(64),
`user_email` VARCHAR(64),
`user_password` VARCHAR(64),
`user_role` VARCHAR(64),
`user_name` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_answers` (
`user_answer_id` INT,
`user_answer` VARCHAR(64),
`user_answer_iscorrect` INT,
`user_id` INT,
`question_id` INT,
`question_kc_id` INT,
PRIMARY KEY (`user_answer_id`)
) CHARACTER SET latin1;
