INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 231469_trms
#
CREATE DATABASE `db_231469_trms`;
USE `db_231469_trms`;
CREATE TABLE `employees` (
`empId` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`address` VARCHAR(255),
`email` VARCHAR(255),
`phone` VARCHAR(255),
PRIMARY KEY (`empId`)
) CHARACTER SET latin1;
CREATE TABLE `event_form` (
`form_id` INT,
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`empId` INT,
`curr_date` DATETIME,
`event_date` DATETIME,
`event_time` VARCHAR(255),
`event_location` VARCHAR(255),
`event_cost` DECIMAL(10,2),
`event_type` VARCHAR(255),
`description` VARCHAR(255),
`grading_format` VARCHAR(255),
`wrjust` VARCHAR(255),
`event_attachments` VARCHAR(255),
`work_time_missed` VARCHAR(255),
`estim_reimbursement` DECIMAL(10,2),
PRIMARY KEY (`form_id`)
) CHARACTER SET latin1;
CREATE TABLE `approvers` (
`aid` INT,
`a_role` INT,
`a_username` VARCHAR(255),
`a_password` VARCHAR(255),
PRIMARY KEY (`aid`)
) CHARACTER SET latin1;
CREATE TABLE `communication_table` (
`form_id` INT,
`employee_id` INT,
`estim_reimbursement` DECIMAL(10,2),
`requestor_need_additional_info_from` VARCHAR(255),
`requestee_response` VARCHAR(255),
`alter_reimbursment_amount` DECIMAL(10,2),
`reason_for_larger_amount` VARCHAR(255),
`exceeding_available_funds` VARCHAR(255),
`pending_amount_val` DECIMAL(10,2),
`notify_employee` VARCHAR(255),
`employee_option_to_cancel` VARCHAR(255),
`approval_status` VARCHAR(255),
`event_grade` VARCHAR(255),
`event_presentation` VARCHAR(255),
`mgmt_view_present` VARCHAR(255),
`dir_mgr_appr_present` VARCHAR(255),
`grade_status_direct_sup` VARCHAR(255),
`direct_sup_appr` VARCHAR(255),
`dept_head_appr` VARCHAR(255),
`benco_final_appr` VARCHAR(255),
`final_reimburse_val_benco` DECIMAL(10,2),
`escalation_email_direct_sup` VARCHAR(255),
`automatic_approv_direct_sup` VARCHAR(255),
`automatic_approv_dept_head` VARCHAR(255),
`marked_urgent` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `balanceinfo` (
`empId` INT,
`initalBal` DECIMAL(10,2),
`availBal` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_231469_trms') AS relationships;
