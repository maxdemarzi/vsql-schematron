`destination` VARCHAR(64),
`source` VARCHAR(64),
`source_destination` VARCHAR(64),
`snap_id` INT,
PRIMARY KEY (`add_id`)
) CHARACTER SET latin1;
CREATE TABLE `df_arg` (
`arg_id` INT,
