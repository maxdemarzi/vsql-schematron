PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `election_officials` (
`id` INT,
`results_id` INT,
`name` VARCHAR(64),
`title` VARCHAR(64),
`phone` VARCHAR(64),
`fax` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `elections` (
`id` INT,
`results_id` INT,
`absentee_ballot_info` VARCHAR(64),
`absentee_request_deadline` DATETIME,
`date` DATETIME,
