INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 274281_database-setup
#
CREATE DATABASE `db_274281_database_setup`;
USE `db_274281_database_setup`;
CREATE TABLE `ballot_candidates` (
`results_id` INT,
`ballot_id` INT,
`candidate_id` INT
) CHARACTER SET latin1;
CREATE TABLE `ballot_line_results` (
`id` INT,
`results_id` INT,
`contest_id` INT,
`jurisdiction_id` INT,
`entire_district` BOOL,
`candidate_id` INT,
`ballot_response_id` INT,
`votes` INT,
`overvotes` INT,
`victorious` BOOL,
`certification` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ballot_responses` (
`id` INT,
`results_id` INT,
`text` VARCHAR(64),
`sort_order` INT,
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `ballots` (
`id` INT,
`results_id` INT,
`referendum_id` INT,
`custom_ballot_id` INT,
`write_in` BOOL,
`image_url` VARCHAR(64),
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `candidates` (
`id` INT,
`results_id` INT,
`name` VARCHAR(64),
`party` VARCHAR(64),
`candidate_url` VARCHAR(64),
`biography` VARCHAR(64),
`phone` VARCHAR(64),
`photo_url` VARCHAR(64),
`filed_mailing_address_location_name` VARCHAR(64),
`filed_mailing_address_line1` VARCHAR(64),
`filed_mailing_address_line2` VARCHAR(64),
`filed_mailing_address_line3` VARCHAR(64),
`filed_mailing_address_city` VARCHAR(64),
`filed_mailing_address_state` VARCHAR(64),
`filed_mailing_address_zip` VARCHAR(64),
`email` VARCHAR(64),
`sort_order` INT,
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `contest_results` (
`id` INT,
`results_id` INT,
`contest_id` INT,
`jurisdiction_id` INT,
`entire_district` BOOL,
`total_votes` INT,
`total_valid_votes` INT,
`overvotes` INT,
`blank_votes` INT,
`accepted_provisional_votes` INT,
`rejected_votes` INT,
`certification` VARCHAR(64),
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `contests` (
`id` INT,
`results_id` INT,
`election_id` INT,
`electoral_district_id` INT,
`type` VARCHAR(64),
`partisan` BOOL,
`primary_party` VARCHAR(64),
`electorate_specifications` VARCHAR(64),
`special` BOOL,
`office` VARCHAR(64),
`filing_closed_date` DATETIME,
`number_elected` INT,
`number_voting_for` INT,
`ballot_id` INT,
`ballot_placement` INT,
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `custom_ballot_ballot_responses` (
`results_id` INT,
`custom_ballot_id` INT,
`ballot_response_id` INT,
`sort_order` INT
) CHARACTER SET latin1;
CREATE TABLE `custom_ballots` (
`id` INT,
`results_id` INT,
`heading` VARCHAR(64),
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `early_vote_sites` (
`id` INT,
`results_id` INT,
`name` VARCHAR(64),
`address_location_name` VARCHAR(64),
`address_line1` VARCHAR(64),
`address_line2` VARCHAR(64),
`address_line3` VARCHAR(64),
`address_city` VARCHAR(64),
`address_state` VARCHAR(64),
`address_zip` VARCHAR(64),
`directions` VARCHAR(64),
`voter_services` VARCHAR(64),
`start_date` VARCHAR(64),
`end_date` VARCHAR(64),
`days_times_open` VARCHAR(64),
PRIMARY KEY (`results_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `election_administrations` (
`id` INT,
`results_id` INT,
`name` VARCHAR(64),
`eo_id` INT,
`ovc_id` INT,
