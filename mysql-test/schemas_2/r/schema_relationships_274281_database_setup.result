`mailing_address_line1` VARCHAR(64),
`mailing_address_line2` VARCHAR(64),
`mailing_address_line3` VARCHAR(64),
`mailing_address_city` VARCHAR(64),
`mailing_address_state` VARCHAR(64),
`mailing_address_zip` VARCHAR(64),
`elections_url` VARCHAR(64),
`registration_url` VARCHAR(64),
`am_i_registered_url` VARCHAR(64),
`absentee_url` VARCHAR(64),
`where_do_i_vote_url` VARCHAR(64),
`what_is_on_my_ballot_url` VARCHAR(64),
`rules_url` VARCHAR(64),
`voter_services` VARCHAR(64),
