INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 280519_Attendance_Mgmt_System
#
CREATE DATABASE `db_280519_Attendance_Mgmt_System`;
USE `db_280519_Attendance_Mgmt_System`;
CREATE TABLE `Class` (
`Semester` INT,
`Section` VARCHAR(64),
`Department` VARCHAR(64),
`CTID` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `MessageImages` (
`MsgID` INT,
`Images` VARCHAR(64),
PRIMARY KEY (`MsgID`)
) CHARACTER SET latin1;
CREATE TABLE `Messages` (
`MsgID` INT,
`ToID` VARCHAR(64),
`FromID` VARCHAR(64),
`Content` VARCHAR(64),
PRIMARY KEY (`MsgID`)
) CHARACTER SET latin1;
CREATE TABLE `Student Attendance` (
`USN` VARCHAR(64),
`Subject Code` VARCHAR(64),
`Attendance` INT,
`Absent Days` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Subjects` (
`Subject` VARCHAR(64),
`Subject Code` VARCHAR(64),
`Dep` VARCHAR(64),
`Sem` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_280519_Attendance_Mgmt_System') AS relationships;
relationships
Database: db_280519_Attendance_Mgmt_System

