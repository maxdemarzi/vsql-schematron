CREATE DATABASE `db_279518_ilepm`;
USE `db_279518_ilepm`;
CREATE TABLE `consumable` (
`id` INT,
`part_number` VARCHAR(64),
`description` VARCHAR(64),
`category` INT,
`flag` INT
) CHARACTER SET latin1;
CREATE TABLE `consumable_category` (
`id` INT,
`category_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `equipment` (
`id` INT,
`ctrl_no` INT,
`product_name` VARCHAR(64),
`serial_no` VARCHAR(64),
`procedures` VARCHAR(64),
`standard_criteria` VARCHAR(64),
`category` INT,
`flag` INT
) CHARACTER SET latin1;
CREATE TABLE `equipment_category` (
`id` INT,
`category_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `problemandsolution` (
`id` INT,
`idConsumableUnit` INT,
`date_problem` VARCHAR(64),
`problem` VARCHAR(64),
`date_solution` VARCHAR(64),
`solution` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quantityperconsumableunit` (
`id` INT,
`idConsumableUnit` INT,
`first` VARCHAR(64),
`second` VARCHAR(64),
`summer` VARCHAR(64),
`year` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `remarkperequipmentunit` (
`id` INT,
`idEquipmentUnit` INT,
`firstremark` VARCHAR(64),
`secondremark` VARCHAR(64),
`summerremark` VARCHAR(64),
`year` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`department` VARCHAR(64),
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`contactnumber` VARCHAR(64),
`image` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
