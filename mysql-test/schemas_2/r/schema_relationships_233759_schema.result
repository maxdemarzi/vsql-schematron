CREATE DATABASE `db_233759_schema`;
USE `db_233759_schema`;
CREATE TABLE `CUSTOMER_ORDER` (
`id` VARCHAR(255),
`creation_time` DATETIME,
`address` VARCHAR(255),
`city` VARCHAR(255),
`country` VARCHAR(255),
`email` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`phone` VARCHAR(255),
`zipcode` VARCHAR(255),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ORDER_ITEM` (
`id` VARCHAR(255),
`quantity` INT,
`article_id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER_ORDER_ITEMS` (
`customer_order_id` VARCHAR(255),
`items_id` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_233759_schema') AS relationships;
