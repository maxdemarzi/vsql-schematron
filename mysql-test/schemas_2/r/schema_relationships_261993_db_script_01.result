CREATE DATABASE `db_261993_db_script_01`;
USE `db_261993_db_script_01`;
CREATE TABLE `Students` (
`student_id` INT,
`roll_number` VARCHAR(64),
`student_name` VARCHAR(64),
`date_of_birth` DATETIME,
`dept_code` VARCHAR(64),
`govt_id_number` VARCHAR(64),
`home_address` VARCHAR(64),
`hostel_address` VARCHAR(64),
`phone_number` VARCHAR(64),
`parent_name` VARCHAR(64),
`par_contact_num` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `Departments` (
`dept_id` INT,
`dept_name` VARCHAR(64),
`dept_code` VARCHAR(64),
`programs_offered` VARCHAR(64),
`time_of_foundation` DATETIME,
`research_areas` VARCHAR(64),
`num_of_students` INT,
`num_of_teaching_staffs` INT,
`num_of_non_teaching_stf` INT,
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
`user_id` INT,
`user_name` VARCHAR(64),
`user_role` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Courses` (
`course_id` INT,
`course_code` VARCHAR(64),
`course_name` VARCHAR(64),
`course_credit` INT,
`course_details` VARCHAR(64),
`dept_code` VARCHAR(64),
`semester_name` VARCHAR(64),
`faculty_name` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `ResearchAreas` (
`research_id` INT,
`res_code` VARCHAR(64),
`research_field` VARCHAR(64),
`dept_associated` VARCHAR(64),
`pub_this_year` INT,
`pub_last_year` INT,
PRIMARY KEY (`research_id`)
) CHARACTER SET latin1;
CREATE TABLE `Publications` (
`publication_id` INT,
`pub_type` VARCHAR(64),
`journal_name` VARCHAR(64),
`pub_year` INT,
`authors` VARCHAR(64),
`pub_extract` VARCHAR(64),
`web_link` VARCHAR(64),
`res_code` VARCHAR(64),
PRIMARY KEY (`publication_id`)
) CHARACTER SET latin1;
