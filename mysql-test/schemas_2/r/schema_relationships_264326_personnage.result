CREATE DATABASE `db_264326_personnage`;
USE `db_264326_personnage`;
CREATE TABLE `personnage` (
`id_personnage` INT,
`id_utilisateur` INT,
`id_carriere` INT,
`deleted` INT,
PRIMARY KEY (`id_personnage`)
) CHARACTER SET latin1;
CREATE TABLE `personnage_profil` (
`id_personnage_profil` INT,
`id_personnage` INT,
`capacite_combat` INT,
`capacite_tir` INT,
`force` INT,
`endurance` INT,
`agilite` INT,
`intelligence` INT,
`force_mentale` INT,
`sociabilite` INT,
`attaques` INT,
`blessures` INT,
`mouvement` INT,
`magie` INT,
`fortune` INT,
`destin` INT,
`deleted` INT,
PRIMARY KEY (`id_personnage_profil`)
) CHARACTER SET latin1;
CREATE TABLE `personnage_information` (
`id_personnage_information` INT,
`id_personnage` INT,
`nom` VARCHAR(64),
`prenom` VARCHAR(64),
`id_pays` INT,
`age` INT,
`sexe` VARCHAR(64),
`couleur_yeux` VARCHAR(64),
`couleur_pilosite` VARCHAR(64),
`masse` INT,
`membre_famille` INT,
`statut_marital` VARCHAR(64),
`id_signe_astral` INT,
`id_lieu_naissance` INT,
`id_religion` INT,
`id_carriere` INT,
`id_race` INT,
`id_race_2` INT,
PRIMARY KEY (`id_personnage_information`)
) CHARACTER SET latin1;
CREATE TABLE `personnage_equipement` (
`id_personnage_equipement` INT,
`id_personnage` INT,
PRIMARY KEY (`id_personnage_equipement`)
) CHARACTER SET latin1;
