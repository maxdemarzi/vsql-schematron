[Implied]  received_docs.voucher_id -> vouchers.id
[Implied]  returnable_list_docs.voucher_id -> vouchers.id
[Implied]  site_completion_docs.voucher_id -> vouchers.id
[Implied]  submitted_docs.voucher_id -> vouchers.id
[Implied]  voucher_job.job_id -> jobs.id
[Implied]  voucher_job.voucher_id -> vouchers.id
[Implied]  vouchers.employee_id -> employees.id

DROP DATABASE `db_230349_db`;
UNINSTALL EXTENSION vsql_schematron;
