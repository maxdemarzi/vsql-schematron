INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 230349_db
#
CREATE DATABASE `db_230349_db`;
USE `db_230349_db`;
CREATE TABLE `bills` (
`id` INT,
`file_name` VARCHAR(255),
`expense_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`name` VARCHAR(255),
`code` VARCHAR(255),
`number` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
`photo` VARCHAR(255),
`aadhar_photo` VARCHAR(255),
`wallet_balance` DECIMAL(10,2),
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `expense_categories` (
`id` INT,
`name` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `expenses` (
`id` INT,
`date` DATETIME,
`category_id` INT,
`description` VARCHAR(255),
`bill` VARCHAR(255),
`amount` DECIMAL(10,2),
`approved_amount` DECIMAL(10,2),
`voucher_id` INT,
`remark` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
`id` INT,
`name` VARCHAR(255),
`number` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(255),
`token` VARCHAR(255),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`id` INT,
`date` DATETIME,
`payment_mode` INT,
`amount` DECIMAL(10,2),
`remark` VARCHAR(255),
`employee_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `received_docs` (
`id` INT,
`file_name` VARCHAR(255),
`voucher_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `returnable_list_docs` (
`id` INT,
`file_name` VARCHAR(255),
`voucher_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `site_completion_docs` (
`id` INT,
`file_name` VARCHAR(255),
`voucher_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submitted_docs` (
`id` INT,
`file_name` VARCHAR(255),
`voucher_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voucher_job` (
`id` INT,
`job_id` INT,
`voucher_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vouchers` (
`id` INT,
`date` DATETIME,
`special_remark` VARCHAR(255),
`number` VARCHAR(255),
`approval_date` DATETIME,
`approved_amount` DECIMAL(10,2),
`status` INT,
`employee_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230349_db') AS relationships;
relationships
Database: db_230349_db

Table Connections:
