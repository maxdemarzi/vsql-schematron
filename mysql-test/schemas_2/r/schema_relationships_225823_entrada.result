CREATE DATABASE `db_225823_entrada`;
USE `db_225823_entrada`;
CREATE TABLE `tbUSUARIO` (
`id_ususario` INT NOT NULL,
`usuario` VARCHAR(50),
`password` VARCHAR(50),
`telefono` VARCHAR(50),
`direccion` VARCHAR(50),
`edad` INT,
PRIMARY KEY (`id_ususario`)
) CHARACTER SET latin1;
CREATE TABLE `tbCURSO` (
`id_curso` INT NOT NULL,
`descripcion` VARCHAR(50),
PRIMARY KEY (`id_curso`)
) CHARACTER SET latin1;
CREATE TABLE `tbASIGNACION` (
`id_asignacion` INT NOT NULL,
`id_ususario` INT,
`id_curso` INT,
PRIMARY KEY (`id_asignacion`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_225823_entrada') AS relationships;
