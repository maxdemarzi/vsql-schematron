CREATE DATABASE `db_224222_schema`;
USE `db_224222_schema`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` TEXT,
`password` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `moods` (
`id` INT NOT NULL,
`author_id` INT,
`created` TIMESTAMP NULL,
`mood` INT,
`title` TEXT,
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_224222_schema') AS relationships;
