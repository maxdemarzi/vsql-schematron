INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 256900_tablas
#
CREATE DATABASE `db_256900_tablas`;
USE `db_256900_tablas`;
CREATE TABLE `empleado` (
`curp` VARCHAR(50) NOT NULL,
`paterno` VARCHAR(50),
`materno` VARCHAR(50),
`nombre` VARCHAR(50),
`f_nac` VARCHAR(50),
`calle` VARCHAR(50),
`numero` INT,
`ciudad` VARCHAR(50),
`cp` VARCHAR(50),
PRIMARY KEY (`curp`)
) CHARACTER SET latin1;
CREATE TABLE `empresa` (
`rfc` VARCHAR(50) NOT NULL,
`razon_social` VARCHAR(50),
`calle` VARCHAR(50),
`numero` INT,
`ciudad` VARCHAR(50),
`cp` VARCHAR(50),
PRIMARY KEY (`rfc`)
) CHARACTER SET latin1;
CREATE TABLE `trabajar` (
`curp` VARCHAR(50),
`rfc` VARCHAR(50),
`f_ingreso` VARCHAR(50),
`salario` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `proyecto` (
`num_prov` INT NOT NULL,
`nombre` VARCHAR(50),
`f_inicio` VARCHAR(50),
`f_fin` VARCHAR(50),
PRIMARY KEY (`num_prov`)
) CHARACTER SET latin1;
CREATE TABLE `controlar` (
`rfc` VARCHAR(50),
`num_prov` INT
) CHARACTER SET latin1;
CREATE TABLE `colaborar` (
`curp` VARCHAR(50),
`rfc` VARCHAR(50),
`num_horas` INT,
`f_fin` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `supervisar` (
`curp` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_256900_tablas') AS relationships;
relationships
