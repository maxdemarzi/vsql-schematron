INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 278344_schema
#
CREATE DATABASE `db_278344_schema`;
USE `db_278344_schema`;
CREATE TABLE `Departments` (
`DepartmentID` INT NOT NULL,
`DeptName` VARCHAR(50),
PRIMARY KEY (`DepartmentID`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
`RoleID` INT NOT NULL,
`Title` VARCHAR(50),
`Salary` DECIMAL(10,2),
`DepartmentID` INT,
PRIMARY KEY (`RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
`EmployeeID` INT NOT NULL,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`RoleID` INT,
`ManagerID` INT,
PRIMARY KEY (`EmployeeID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_278344_schema') AS relationships;
relationships
Database: db_278344_schema

Table Connections:
------------------
[Implied]  Employees.ManagerID -> Employees.EmployeeID
[Implied]  Employees.RoleID -> Roles.RoleID
[Implied]  Roles.DepartmentID -> Departments.DepartmentID

DROP DATABASE `db_278344_schema`;
UNINSTALL EXTENSION vsql_schematron;
