CREATE DATABASE `db_207744_db`;
USE `db_207744_db`;
CREATE TABLE `Users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`email` TEXT,
`password` TEXT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `web_sites` (
`id` VARCHAR(50) NOT NULL,
`id_user` TEXT,
`name` TEXT,
`url` TEXT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_207744_db') AS relationships;
