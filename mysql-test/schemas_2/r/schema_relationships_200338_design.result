INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 200338_design
#
CREATE DATABASE `db_200338_design`;
USE `db_200338_design`;
CREATE TABLE `user` (
`userId` VARCHAR(255),
`userActivationToken` VARCHAR(255),
`userAvatarUrl` VARCHAR(255),
`userEmail` VARCHAR(255),
`userHash` VARCHAR(255),
`userName` VARCHAR(255),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `truck` (
`truckId` VARCHAR(255),
`truckUserId` VARCHAR(255),
`truckAvatarUrl` VARCHAR(255),
`truckEmail` VARCHAR(255),
`truckFoodType` VARCHAR(255),
`truckMenuUrl` VARCHAR(255),
`truckName` VARCHAR(255),
`truckPhoneNumber` VARCHAR(255),
`truckVerifyImage` VARCHAR(255),
PRIMARY KEY (`truckId`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`postId` VARCHAR(255),
`postTruckId` VARCHAR(255),
`postUserId` VARCHAR(255),
`postContent` VARCHAR(255),
`postDatetime` DATETIME,
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_200338_design') AS relationships;
relationships
Database: db_200338_design

Table Connections:
------------------
[Implied]  post.postTruckId -> truck.truckId
[Implied]  post.postUserId -> user.userId
[Implied]  truck.truckUserId -> user.userId

DROP DATABASE `db_200338_design`;
UNINSTALL EXTENSION vsql_schematron;
