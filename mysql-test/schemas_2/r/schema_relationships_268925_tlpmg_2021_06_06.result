INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 268925_tlpmg-2021-06-06
#
CREATE DATABASE `db_268925_tlpmg_2021_06_06`;
USE `db_268925_tlpmg_2021_06_06`;
CREATE TABLE `accounts` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory` (
`id` INT,
`barcode` VARCHAR(64),
`item_code` VARCHAR(64),
`item_name` VARCHAR(64),
`qty` INT,
`item_description` VARCHAR(64),
`item_price` DECIMAL(10,2),
`market_original_price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory_cost` (
`id` INT,
`item_id` INT,
`total_cost` INT,
`date_added` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`id` INT,
`full_name` VARCHAR(64),
`transaction_date` DATETIME,
`address` VARCHAR(64),
`phone_num` VARCHAR(64),
`total_amount` DECIMAL(10,2),
`amount_paid` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction_lists` (
`id` INT,
`transaction_id` INT,
`item_id` INT,
`qty` INT,
`adjusted_price` DECIMAL(10,2),
`transaction_date` DATETIME,
`subtotal` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_268925_tlpmg_2021_06_06') AS relationships;
relationships
Database: db_268925_tlpmg_2021_06_06

Table Connections:
