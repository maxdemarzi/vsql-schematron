`price` INT,
`id_category` INT,
`description` VARCHAR(64),
`image` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`usernmae` VARCHAR(64),
`name` VARCHAR(64),
`lastname` VARCHAR(64),
`contact` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
