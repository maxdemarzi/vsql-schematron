INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 224010_Tables_Airbnb
#
CREATE DATABASE `db_224010_Tables_Airbnb`;
USE `db_224010_Tables_Airbnb`;
CREATE TABLE `usuario` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`email` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `state` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`state_id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `amenity` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `place` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`user_id` VARCHAR(64),
`name` VARCHAR(64),
`city_id` VARCHAR(64),
`description` VARCHAR(64),
`number_rooms` DECIMAL(10,2),
`number_bathrooms` DECIMAL(10,2),
`max_guest` DECIMAL(10,2),
`price_by_night` DECIMAL(10,2),
`latitud` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `review` (
`id` VARCHAR(64),
`updated_at` DATETIME,
`created_at` DATETIME,
`user_id` VARCHAR(64),
`place_id` VARCHAR(64),
`text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `placeamenity` (
`amenity_id` VARCHAR(64),
`place_id` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_224010_Tables_Airbnb') AS relationships;
relationships
Database: db_224010_Tables_Airbnb

Table Connections:
------------------
[Implied]  city.state_id -> state.id
[Implied]  place.city_id -> city.id
[Implied]  place.user_id -> usuario.id
[Implied]  placeamenity.amenity_id -> amenity.id
[Implied]  placeamenity.place_id -> place.id
[Implied]  review.place_id -> place.id
[Implied]  review.user_id -> usuario.id

DROP DATABASE `db_224010_Tables_Airbnb`;
UNINSTALL EXTENSION vsql_schematron;
