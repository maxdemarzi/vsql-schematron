INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 205559_dump
#
CREATE DATABASE `db_205559_dump`;
USE `db_205559_dump`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` INT,
PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64),
PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_205559_dump') AS relationships;
relationships
