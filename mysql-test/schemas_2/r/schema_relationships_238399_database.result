INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 238399_database
#
CREATE DATABASE `db_238399_database`;
USE `db_238399_database`;
CREATE TABLE `articles` (
`id` INT,
`title` VARCHAR(64),
`body` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`name` VARCHAR(64),
`desc` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `failed_jobs` (
`id` INT,
`connection` VARCHAR(64),
`queue` VARCHAR(64),
`payload` VARCHAR(64),
`exception` VARCHAR(64),
`failed_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` INT,
`migration` VARCHAR(64),
`batch` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`category_id` INT,
`title` VARCHAR(64),
`author` VARCHAR(64),
`image` VARCHAR(64),
`short_desc` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified_at` DATETIME,
`password` VARCHAR(64),
`remember_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`is_email_verified` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_verify` (
`user_id` INT,
`token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_238399_database') AS relationships;
relationships
Database: db_238399_database

Table Connections:
------------------
[Implied]  posts.category_id -> categories.id
[Implied]  users_verify.user_id -> users.id

DROP DATABASE `db_238399_database`;
UNINSTALL EXTENSION vsql_schematron;
