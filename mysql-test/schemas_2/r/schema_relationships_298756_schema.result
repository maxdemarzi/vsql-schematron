INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 298756_schema
#
CREATE DATABASE `db_298756_schema`;
USE `db_298756_schema`;
CREATE TABLE `dogmabrowser.repository` (
`id` INT,
`full_name` VARCHAR(64),
`commit_hash` VARCHAR(64),
`is_stale` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dogmabrowser.type` (
`id` INT,
`package` VARCHAR(64),
`name` VARCHAR(64),
`needs_removal` VARCHAR(64),
`repository_id` INT,
`url` VARCHAR(64),
`docs` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dogmabrowser.application` (
`key` VARCHAR(64),
`name` VARCHAR(64),
`type_id` INT,
`is_pointer` VARCHAR(64),
`repository_id` INT,
`needs_removal` VARCHAR(64),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `dogmabrowser.handler` (
`key` VARCHAR(64),
`name` VARCHAR(64),
`application_key` VARCHAR(64),
`handler_type` VARCHAR(64),
`type_id` INT,
`is_pointer` VARCHAR(64),
`needs_removal` VARCHAR(64),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `dogmabrowser.handler_message` (
`handler_key` VARCHAR(64),
`type_id` INT,
`is_pointer` VARCHAR(64),
`role` VARCHAR(64),
`is_produced` VARCHAR(64),
`is_consumed` VARCHAR(64),
`needs_removal` VARCHAR(64),
PRIMARY KEY (`handler_key`, `type_id`, `is_pointer`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_298756_schema') AS relationships;
