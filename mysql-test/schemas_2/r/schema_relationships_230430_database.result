[Implied]  comment.student_id -> student.student_id
[Implied]  curTeach.courseName -> course.courseName
[Implied]  curTeach.student_id -> student.student_id
[Implied]  graduate.student_id -> student.student_id
[Implied]  interStudent.student_id -> student.student_id
[Implied]  likeTeach.courseName -> course.courseName
[Implied]  likeTeach.student_id -> student.student_id
[Implied]  preTeach.courseName -> course.courseName
[Implied]  preTeach.student_id -> student.student_id
[Implied]  undergraduate.student_id -> student.student_id

DROP DATABASE `db_230430_database`;
UNINSTALL EXTENSION vsql_schematron;
