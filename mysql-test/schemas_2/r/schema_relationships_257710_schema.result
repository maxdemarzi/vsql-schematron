[Implied]  employee_table.manager_id -> employee_table.id
[Implied]  employee_table.role_id -> role_table.id
[Implied]  role_table.department_id -> department_table.id

DROP DATABASE `db_257710_schema`;
UNINSTALL EXTENSION vsql_schematron;
