INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 257710_schema
#
CREATE DATABASE `db_257710_schema`;
USE `db_257710_schema`;
CREATE TABLE `department_table` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_table` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_table` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_257710_schema') AS relationships;
relationships
Database: db_257710_schema

Table Connections:
