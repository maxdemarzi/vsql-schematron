[Implied]  mention.internal_message_id -> message.internal_id
[Implied]  message.message_id -> message.internal_id
[Implied]  message.reply_to_message_id -> message.internal_id

DROP DATABASE `db_276104_schema`;
UNINSTALL EXTENSION vsql_schematron;
