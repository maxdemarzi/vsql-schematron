CREATE DATABASE `db_299468_Script_NPT`;
USE `db_299468_Script_NPT`;
CREATE TABLE `usuarios` (
`idUsuario` INT,
`nick` VARCHAR(64),
`nombre` VARCHAR(64),
`correo` VARCHAR(64),
`password` VARCHAR(64),
`edad` VARCHAR(64),
`perfil` VARCHAR(64),
`diaRegistro` DATETIME,
PRIMARY KEY (`idUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `jugadores` (
`idUsuarioJugador` INT,
`organizador` BOOL,
PRIMARY KEY (`idUsuarioJugador`)
) CHARACTER SET latin1;
CREATE TABLE `torneos` (
`idTorneo` INT,
`nombre` VARCHAR(64),
`precioInscripcion` DECIMAL(10,2),
`premio` DECIMAL(10,2),
`maxJugadores` INT,
`numMaxJugadoresEquipo` INT,
`inscritos` INT,
`fechaInicio` DATETIME,
`fechaFin` DATETIME,
`numRondas` VARCHAR(64),
`idOrganizador` INT,
PRIMARY KEY (`idTorneo`)
) CHARACTER SET latin1;
CREATE TABLE `equipos` (
`idEquipo` INT,
`nombre` VARCHAR(64),
`maxJugadores` INT,
`numJugadores` INT,
`idCreadorEquipo` INT,
PRIMARY KEY (`idEquipo`)
) CHARACTER SET latin1;
CREATE TABLE `juegos` (
`idJuego` INT,
`nombre` VARCHAR(64),
`edadMinima` VARCHAR(64),
`tipo` VARCHAR(64),
`descripcion` VARCHAR(64),
`imagenJuego` VARCHAR(64),
`idAdministrador` INT,
PRIMARY KEY (`idJuego`)
) CHARACTER SET latin1;
CREATE TABLE `plataformas` (
`idPlataforma` INT,
`nombre` VARCHAR(64),
`imagenPlataforma` VARCHAR(64),
`idAdministrador` INT,
PRIMARY KEY (`idPlataforma`)
) CHARACTER SET latin1;
CREATE TABLE `inscripcionJugadores` (
`idTorneo` INT,
`idUsuarioJugador` INT,
PRIMARY KEY (`idTorneo`, `idUsuarioJugador`)
) CHARACTER SET latin1;
CREATE TABLE `equipoJugador` (
`idEquipo` INT,
`idUsuarioJugador` INT,
PRIMARY KEY (`idEquipo`, `idUsuarioJugador`)
) CHARACTER SET latin1;
CREATE TABLE `inscripcionEquipo` (
`idTorneo` INT,
`idEquipo` INT,
PRIMARY KEY (`idTorneo`, `idEquipo`)
) CHARACTER SET latin1;
CREATE TABLE `juegoTorneo` (
`idTorneo` INT,
`idJuego` INT,
`idPlataforma` INT,
PRIMARY KEY (`idTorneo`, `idJuego`, `idPlataforma`)
) CHARACTER SET latin1;
CREATE TABLE `partidas` (
`idPartida` INT,
`idTorneo` INT,
`Ganador` INT,
`Resultado` VARCHAR(64),
`Ronda` VARCHAR(64),
PRIMARY KEY (`idPartida`)
) CHARACTER SET latin1;
CREATE TABLE `partidasEquipos` (
`idPartida` INT,
`idEquipo1` INT,
`idEquipo2` INT,
PRIMARY KEY (`idPartida`, `idEquipo1`, `idEquipo2`)
) CHARACTER SET latin1;
CREATE TABLE `partidasIndividuales` (
`idPartida` INT,
`idJugador` INT,
PRIMARY KEY (`idPartida`, `idJugador`)
) CHARACTER SET latin1;
