INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 244122_first
#
CREATE DATABASE `db_244122_first`;
USE `db_244122_first`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`student_id` VARCHAR(50),
`hashed_password` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `problems` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
`testcases` VARCHAR(50),
`author` VARCHAR(50),
`timelimit` BIGINT,
`memorylimit` BIGINT,
`difficulty_level` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submissions` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`problem_id` BIGINT,
`language` VARCHAR(50),
`score` BIGINT,
`result` VARCHAR(50),
`code` TEXT,
`created_at` TIMESTAMP NULL,
`time` BIGINT,
`memory` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`problem_id` BIGINT,
`author` VARCHAR(50),
`content` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_244122_first') AS relationships;
relationships
Database: db_244122_first

Table Connections:
------------------
[Implied]  categories.problem_id -> problems.id
[Implied]  categories.user_id -> users.id
[Implied]  submissions.problem_id -> problems.id
[Implied]  submissions.user_id -> users.id

DROP DATABASE `db_244122_first`;
UNINSTALL EXTENSION vsql_schematron;
