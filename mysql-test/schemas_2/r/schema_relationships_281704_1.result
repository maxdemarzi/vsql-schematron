INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 281704_1
#
CREATE DATABASE `db_281704_1`;
USE `db_281704_1`;
CREATE TABLE `app_user` (
`app_user_id` VARCHAR(64),
`username` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
`salary` DECIMAL(10,2),
`is_manager` BOOL,
`timestamp_created` DATETIME,
`timestamp_edited` DATETIME,
PRIMARY KEY (`app_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`project_id` VARCHAR(64),
`name` VARCHAR(64),
`description` VARCHAR(64),
`timestamp_created` DATETIME,
`timestamp_edited` DATETIME,
`billable` BOOL,
`owned_by` VARCHAR(64),
`created_by` VARCHAR(64),
`last_edited_by` VARCHAR(64),
`client_id` VARCHAR(64),
PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_app_user` (
`project_id` VARCHAR(64),
`app_user_id` VARCHAR(64),
PRIMARY KEY (`project_id`, `app_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`client_id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`timestamp_created` DATETIME,
`timestamp_edited` DATETIME,
PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281704_1') AS relationships;
relationships
Database: db_281704_1

Table Connections:
