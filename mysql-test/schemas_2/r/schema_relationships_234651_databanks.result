INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 234651_databanks
#
CREATE DATABASE `db_234651_databanks`;
USE `db_234651_databanks`;
CREATE TABLE `User` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`passwordhash` CHAR(50),
`total_books` INT,
`total_pages` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
`id` INT NOT NULL,
`user_id` INT,
`title` TEXT,
`author` TEXT,
`pages` INT,
`rating` INT,
`month` INT,
`year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_234651_databanks') AS relationships;
relationships
