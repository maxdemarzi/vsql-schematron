CREATE TABLE `users` (
`id` INT,
`organization_id` INT,
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`password_hash` VARCHAR(64),
`phone` INT,
`email` VARCHAR(64),
`photo` VARCHAR(64),
`department` VARCHAR(64),
`title` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organizations` (
`id` INT,
`admin_id` INT,
`default_id` INT,
`name` VARCHAR(64),
`logo` VARCHAR(64),
`welcome_message` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
