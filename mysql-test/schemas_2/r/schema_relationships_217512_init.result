INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 217512_init
#
CREATE DATABASE `db_217512_init`;
USE `db_217512_init`;
CREATE TABLE `users` (
`registration_no` VARCHAR(64),
`phone_no` VARCHAR(64),
`email` VARCHAR(64),
`first_and_last_name` VARCHAR(64),
`user_type` VARCHAR(64),
`pwd` VARCHAR(64),
PRIMARY KEY (`registration_no`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`course_id` INT,
`course_title` VARCHAR(64),
`course_desc` VARCHAR(64),
`difficulty` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`student_id` INT,
`user_id` VARCHAR(64),
`course_id` INT,
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `instructor` (
`faculty_id` INT,
`approval` BOOL,
`user_id` VARCHAR(64),
`course_id` INT,
PRIMARY KEY (`faculty_id`)
) CHARACTER SET latin1;
CREATE TABLE `feedback` (
`feedback_id` INT,
`date_and_time` DATETIME,
`content` VARCHAR(64),
`user_id` VARCHAR(64),
`course_id` INT,
PRIMARY KEY (`feedback_id`)
) CHARACTER SET latin1;
CREATE TABLE `course_content` (
`content_id` INT,
`date_and_time` DATETIME,
`content` VARCHAR(64),
`user_id` VARCHAR(64),
`course_id` INT,
`content_type` VARCHAR(64),
`title` VARCHAR(64),
`file_path` VARCHAR(64),
PRIMARY KEY (`content_id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`question_id` INT,
`course_id` INT,
`content_id` INT,
`question` VARCHAR(64),
`choices` VARCHAR(64),
PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_217512_init') AS relationships;
relationships
Database: db_217512_init

Table Connections:
------------------
[Implied]  course_content.course_id -> courses.course_id
[Implied]  course_content.user_id -> users.registration_no
[Implied]  feedback.course_id -> courses.course_id
[Implied]  feedback.user_id -> users.registration_no
[Implied]  instructor.course_id -> courses.course_id
[Implied]  instructor.user_id -> users.registration_no
[Implied]  questions.content_id -> course_content.content_id
[Implied]  questions.course_id -> courses.course_id
[Implied]  student.course_id -> courses.course_id
[Implied]  student.user_id -> users.registration_no

DROP DATABASE `db_217512_init`;
UNINSTALL EXTENSION vsql_schematron;
