CREATE DATABASE `db_298824_db_version_one`;
USE `db_298824_db_version_one`;
CREATE TABLE `transport.accessibility` (
`id` INT,
`theme` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.address` (
`address_id` INT,
`city` VARCHAR(64),
`street` VARCHAR(64),
`house_number` INT,
`postcode` VARCHAR(64),
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.user_type` (
`user_type_id` INT,
`type` VARCHAR(64),
PRIMARY KEY (`user_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.user` (
`user_id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`forename` VARCHAR(64),
`surname` VARCHAR(64),
`phone_number` VARCHAR(64),
`date_created` DATETIME,
`fk_accessibility_id` INT,
`fk_address_id` INT,
`fk_user_type_id` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.coordinate` (
`coordinate_id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`coordinate_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.journey` (
`journey_id` INT,
`start_time` DATETIME,
`end_time` DATETIME,
PRIMARY KEY (`journey_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.ticket` (
`ticket_id` INT,
`accessibility_required` INT,
`used` INT,
`expired` INT,
`date_created` DATETIME,
PRIMARY KEY (`ticket_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.user_journey` (
`fk_journey_id` INT,
`fk_user_id` INT,
`fk_ticket_id` INT,
`paid` INT,
PRIMARY KEY (`fk_journey_id`, `fk_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.coordinate_type` (
`id` INT,
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.journey_coordinate` (
`fk_journey_id` INT,
`fk_coordinate_id` INT,
`fk_coordinate_type_id` INT
) CHARACTER SET latin1;
CREATE TABLE `transport.vehicle_type` (
`vehicle_type_id` INT,
`type` VARCHAR(64),
PRIMARY KEY (`vehicle_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.vehicle` (
`vehicle_id` INT,
`registration` VARCHAR(64),
`make` VARCHAR(64),
`model` VARCHAR(64),
`year` INT,
`passanger_seats` INT,
`wheelchair_access` INT,
`currently_driven` INT,
`fk_vehicle_type_id` INT,
PRIMARY KEY (`vehicle_id`, `fk_vehicle_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.user_vehicle` (
`fk_user_id` INT,
`fk_vehicle_id` INT,
PRIMARY KEY (`fk_user_id`, `fk_vehicle_id`)
) CHARACTER SET latin1;
