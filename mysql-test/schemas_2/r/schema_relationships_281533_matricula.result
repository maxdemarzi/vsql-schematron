INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 281533_matricula
#
CREATE DATABASE `db_281533_matricula`;
USE `db_281533_matricula`;
CREATE TABLE `rol` (
`id` INT NOT NULL,
`desc` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellidos` VARCHAR(50),
`email` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`creado` TIMESTAMP NULL,
`modificado` TIMESTAMP NULL,
`rol` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comentario` (
`id` INT NOT NULL,
`creado` TIMESTAMP NULL,
`usuario` INT,
`texto` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281533_matricula') AS relationships;
