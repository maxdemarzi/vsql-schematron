INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 263126_schema
#
CREATE DATABASE `db_263126_schema`;
USE `db_263126_schema`;
CREATE TABLE `employees` (
`emp_no` INT,
`emp_title_id` VARCHAR(64),
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`sex` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(64),
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` INT,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_263126_schema') AS relationships;
relationships
Database: db_263126_schema

Table Connections:
------------------
[Implied]  dept_emp.dept_no -> departments.dept_no
[Implied]  dept_emp.emp_no -> employees.emp_no
[Implied]  dept_manager.dept_no -> departments.dept_no
[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  salaries.emp_no -> employees.emp_no

DROP DATABASE `db_263126_schema`;
UNINSTALL EXTENSION vsql_schematron;
