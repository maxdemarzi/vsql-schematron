CREATE DATABASE `db_295428_on_delete_cascade_demo_using_XAMPP`;
USE `db_295428_on_delete_cascade_demo_using_XAMPP`;
CREATE TABLE `Emp` (
`eid` INT,
`ename` VARCHAR(64),
`age` INT,
`salary` DECIMAL(10,2),
PRIMARY KEY (`eid`)
) CHARACTER SET latin1;
CREATE TABLE `Dept` (
`did` INT,
`budget` DECIMAL(10,2),
`managerid` INT,
PRIMARY KEY (`did`)
) CHARACTER SET latin1;
CREATE TABLE `Works` (
`eid` INT,
`did` INT,
`pcttime` INT,
PRIMARY KEY (`eid`, `did`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_295428_on_delete_cascade_demo_using_XAMPP') AS relationships;
