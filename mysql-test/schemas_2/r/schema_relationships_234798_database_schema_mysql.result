INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 234798_database_schema_mysql
#
CREATE DATABASE `db_234798_database_schema_mysql`;
USE `db_234798_database_schema_mysql`;
CREATE TABLE `experiments` (
`id` INT NOT NULL,
`experiment_date` DATE,
`experiment_time` TIME,
`sampling_rate` DOUBLE,
`input_file` VARCHAR(50),
`configurations` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `metrics` (
`id` INT NOT NULL,
`experiment_id` INT,
`model` VARCHAR(50),
`sampler` VARCHAR(50),
`mean_square_error` DOUBLE,
`mean_average_error` DOUBLE,
`deviation` DOUBLE,
`coefficient_of_determination` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `samples` (
`id` INT NOT NULL,
`experiment_id` INT,
`sampler` VARCHAR(50),
`list` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `model_predictions` (
`id` INT NOT NULL,
`experiment_id` INT,
`sampler` VARCHAR(50),
`model` VARCHAR(50),
`list` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_234798_database_schema_mysql') AS relationships;
relationships
