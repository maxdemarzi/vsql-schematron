INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 227634_criarPedidos
#
CREATE DATABASE `db_227634_criarPedidos`;
USE `db_227634_criarPedidos`;
CREATE TABLE `Cliente` (
`CodCLI` INT NOT NULL,
`Nome` VARCHAR(50),
`Endereco` VARCHAR(50),
`Telefone` VARCHAR(50),
`InscE` VARCHAR(50),
`CNPJ` VARCHAR(50),
`Cidade` VARCHAR(50),
`UF` VARCHAR(50),
PRIMARY KEY (`CodCLI`)
) CHARACTER SET latin1;
CREATE TABLE `Produto` (
`CodPROD` INT NOT NULL,
`Descricao` VARCHAR(50),
`Valor` DECIMAL(10,2),
`Unidade` CHAR(50),
PRIMARY KEY (`CodPROD`)
) CHARACTER SET latin1;
CREATE TABLE `Pedido` (
`NumPED` INT NOT NULL,
`PrazoEntrega` INT,
`Data` DATE,
`CodCLI` INT,
`CodVEND` INT,
PRIMARY KEY (`NumPED`)
) CHARACTER SET latin1;
CREATE TABLE `Vendedor` (
`CodVEND` INT NOT NULL,
`Nome` VARCHAR(50),
`DataNasc` DATE,
`SalarioFixo` DECIMAL(10,2),
`FaixaComissao` CHAR(50),
PRIMARY KEY (`CodVEND`)
) CHARACTER SET latin1;
CREATE TABLE `ItensPedido` (
`NumPED` INT NOT NULL,
`CodPROD` INT NOT NULL,
`Quantidade` INT,
PRIMARY KEY (`CodPROD`, `NumPED`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_227634_criarPedidos') AS relationships;
relationships
Database: db_227634_criarPedidos

