CREATE DATABASE `db_245180_table_creation`;
USE `db_245180_table_creation`;
CREATE TABLE `teacher` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `class` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `section` (
`id` INT,
`name` VARCHAR(64),
`teacher_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`id` INT,
`name` VARCHAR(64),
`gender` VARCHAR(64),
`class_id` INT,
`section_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_245180_table_creation') AS relationships;
