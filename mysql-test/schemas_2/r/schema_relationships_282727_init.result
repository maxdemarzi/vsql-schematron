INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 282727_init
#
CREATE DATABASE `db_282727_init`;
USE `db_282727_init`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`year` VARCHAR(50),
`poster` VARCHAR(50),
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_282727_init') AS relationships;
relationships
