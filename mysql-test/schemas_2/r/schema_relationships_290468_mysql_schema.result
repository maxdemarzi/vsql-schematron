INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 290468_mysql_schema
#
CREATE DATABASE `db_290468_mysql_schema`;
USE `db_290468_mysql_schema`;
CREATE TABLE `CART_ITEMS` (
`ITEM_ID` INT,
`CART_ID` INT,
`QUANTITY` INT,
PRIMARY KEY (`ITEM_ID`, `CART_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORY` (
`CATEGORY_ID` INT,
`CATEGORY_NAME` VARCHAR(64),
PRIMARY KEY (`CATEGORY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
`ITEM_ID` INT,
`UNIT_PRICE` DECIMAL(10,2),
`STOCK` INT,
`BRAND_NAME` VARCHAR(64),
`VENDOR_NAME` VARCHAR(64),
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`MAIN_CATEGORY` INT,
PRIMARY KEY (`ITEM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM_CATEGORY` (
`ITEM_ID` INT,
`CATEGORY_ID` INT,
PRIMARY KEY (`ITEM_ID`, `CATEGORY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
`ORDER_ID` INT,
`USER_ID` INT,
`CART_ID` INT,
`FINAL_ORDER_TOTAL` DECIMAL(10,2),
`SHIP_DATE` DATETIME,
`TAX` DECIMAL(10,2),
`PAYMENT_INTENT` VARCHAR(64),
PRIMARY KEY (`ORDER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SHOPPING_CART` (
`CART_ID` INT,
`USER_ID` INT,
`DATE_COMPLETED` DATETIME,
`CURR_ORDER_TOTAL` DECIMAL(10,2),
`DATE_CREATED` DATETIME,
PRIMARY KEY (`CART_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STORE_USER` (
`USER_ID` INT,
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`STREET_ADDR1` VARCHAR(64),
`STREET_ADDR2` VARCHAR(64),
`CITY` VARCHAR(64),
`STATE` VARCHAR(64),
`ZIPCODE` VARCHAR(64),
`USER_ROLE` VARCHAR(64),
`FIRSTNAME` VARCHAR(64),
`LASTNAME` VARCHAR(64),
PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_290468_mysql_schema') AS relationships;
relationships
Database: db_290468_mysql_schema

Table Connections:
------------------
[Implied]  CART_ITEMS.CART_ID -> SHOPPING_CART.CART_ID
[Implied]  CART_ITEMS.ITEM_ID -> ITEM.ITEM_ID
[Implied]  ITEM.MAIN_CATEGORY -> CATEGORY.CATEGORY_ID
[Implied]  ITEM_CATEGORY.CATEGORY_ID -> CATEGORY.CATEGORY_ID
[Implied]  ITEM_CATEGORY.ITEM_ID -> ITEM.ITEM_ID
[Implied]  ORDERS.CART_ID -> SHOPPING_CART.CART_ID
[Implied]  ORDERS.USER_ID -> STORE_USER.USER_ID
[Implied]  SHOPPING_CART.USER_ID -> STORE_USER.USER_ID

DROP DATABASE `db_290468_mysql_schema`;
UNINSTALL EXTENSION vsql_schematron;
