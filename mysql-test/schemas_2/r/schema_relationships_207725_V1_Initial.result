INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 207725_V1__Initial
#
CREATE DATABASE `db_207725_V1_Initial`;
USE `db_207725_V1_Initial`;
CREATE TABLE `BUCKET` (
`ID` VARCHAR(64),
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`CREATED` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BUCKET_ITEM` (
`ID` VARCHAR(64),
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`CREATED` DATETIME,
`MODIFIED` DATETIME,
`ITEM_TYPE` VARCHAR(64),
`BUCKET_ID` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FLOW` (
`ID` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FLOW_SNAPSHOT` (
`FLOW_ID` VARCHAR(64),
`VERSION` INT,
`CREATED` DATETIME,
`CREATED_BY` VARCHAR(64),
`COMMENTS` VARCHAR(64),
PRIMARY KEY (`FLOW_ID`, `VERSION`)
) CHARACTER SET latin1;
CREATE TABLE `SIGNING_KEY` (
`ID` VARCHAR(64),
`TENANT_IDENTITY` VARCHAR(64),
`KEY_VALUE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_207725_V1_Initial') AS relationships;
relationships
Database: db_207725_V1_Initial

