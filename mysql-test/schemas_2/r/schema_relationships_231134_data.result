CREATE DATABASE `db_231134_data`;
USE `db_231134_data`;
CREATE TABLE `USER` (
`id` INT,
`name` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ROLE` (
`id` INT,
`role_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLE` (
`user_id` INT,
`role_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_231134_data') AS relationships;
