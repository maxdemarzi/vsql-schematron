INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 240904_ddl
#
CREATE DATABASE `db_240904_ddl`;
USE `db_240904_ddl`;
CREATE TABLE `professor` (
`ssn` INT NOT NULL,
`name` VARCHAR(50),
`address` VARCHAR(50),
`telephone` INT,
`sex` VARCHAR(50),
`teacher_title` VARCHAR(50),
`college_degrees` VARCHAR(50),
`salary` INT,
PRIMARY KEY (`ssn`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`dept_id` INT NOT NULL,
`professor_ssn` INT,
`dept_name` VARCHAR(50),
`telephone` INT,
`office_location` VARCHAR(50),
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`course_id` INT NOT NULL,
`department_id` INT,
`title` VARCHAR(50),
`textbook` VARCHAR(50),
`unit` INT,
`prereq_course` VARCHAR(50),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `section` (
`section_id` INT NOT NULL,
`course_id` INT,
`professor_ssn` INT,
`classroom_num` INT,
`num_of_seats` INT,
`meet_days` VARCHAR(50),
`begin_time` INT,
`end_time` INT,
PRIMARY KEY (`section_id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`cwid` INT NOT NULL,
`department_id` INT,
`name` VARCHAR(50),
`address` VARCHAR(50),
`telephone` INT,
PRIMARY KEY (`cwid`)
) CHARACTER SET latin1;
CREATE TABLE `enrollment` (
`cwid` INT,
`section_id` INT,
`grade` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_240904_ddl') AS relationships;
relationships
Database: db_240904_ddl

Table Connections:
------------------
[Implied]  course.department_id -> department.dept_id
[Implied]  department.professor_ssn -> professor.ssn
[Implied]  enrollment.cwid -> student.cwid
[Implied]  enrollment.section_id -> section.section_id
[Implied]  section.course_id -> course.course_id
[Implied]  section.professor_ssn -> professor.ssn
[Implied]  student.department_id -> department.dept_id

DROP DATABASE `db_240904_ddl`;
UNINSTALL EXTENSION vsql_schematron;
