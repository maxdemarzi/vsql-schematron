CREATE DATABASE `db_281978_security_tables`;
USE `db_281978_security_tables`;
CREATE TABLE `Authority` (
`Id` INT NOT NULL,
`Name` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`Id` INT NOT NULL,
`Username` VARCHAR(50),
`Password` VARCHAR(50),
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`Email` VARCHAR(50),
`Enabled` VARCHAR(50),
`LastPasswordResetDate` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `UserAuthority` (
`UserId` INT,
`AuthorityId` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281978_security_tables') AS relationships;
relationships
