INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 252315_BD2021_data
#
CREATE DATABASE `db_252315_BD2021_data`;
USE `db_252315_BD2021_data`;
CREATE TABLE `emp` (
`nemp` DECIMAL(10,2),
`nome` VARCHAR(64),
`funcao` VARCHAR(64),
`encar` DECIMAL(10,2),
`data_entrada` DATETIME,
`sal` DECIMAL(10,2),
`premios` DECIMAL(10,2),
`ndep` DECIMAL(10,2),
PRIMARY KEY (`nemp`)
) CHARACTER SET latin1;
CREATE TABLE `dep` (
`ndep` DECIMAL(10,2),
`nome` VARCHAR(64),
`local` VARCHAR(64),
PRIMARY KEY (`ndep`)
) CHARACTER SET latin1;
CREATE TABLE `descontos` (
`escalao` DECIMAL(10,2),
`salinf` DECIMAL(10,2),
`salsup` DECIMAL(10,2),
PRIMARY KEY (`escalao`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_252315_BD2021_data') AS relationships;
relationships
Database: db_252315_BD2021_data

