INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 237966_DB
#
CREATE DATABASE `db_237966_DB`;
USE `db_237966_DB`;
CREATE TABLE `articles` (
`title` VARCHAR(64),
`image` VARCHAR(64),
`description` VARCHAR(64),
`create_date` DATETIME,
`article_id` INT,
`user_id` INT,
PRIMARY KEY (`article_id`)
) CHARACTER SET latin1;
CREATE TABLE `chats` (
`name` VARCHAR(64),
`short_description` VARCHAR(64),
`chat_id` INT,
PRIMARY KEY (`chat_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`chat_id` INT,
`user_id` INT,
`m_text` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`login` VARCHAR(64),
`password` VARCHAR(64),
`salt` VARCHAR(64),
`img` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_to_users` (
`article_id` INT,
`user_id` INT,
PRIMARY KEY (`user_id`, `article_id`)
) CHARACTER SET latin1;
CREATE TABLE `chats_to_users` (
`chat_id` INT,
`user_id` INT,
PRIMARY KEY (`user_id`, `chat_id`)
) CHARACTER SET latin1;
CREATE TABLE `tags_to_articles` (
`article_id` INT,
`tag` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_237966_DB') AS relationships;
relationships
Database: db_237966_DB

