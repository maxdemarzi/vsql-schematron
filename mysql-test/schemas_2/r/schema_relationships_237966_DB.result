[Implied]  chats_to_users.chat_id -> chats.chat_id
[Implied]  chats_to_users.user_id -> users.user_id
[Implied]  messages.chat_id -> chats.chat_id
[Implied]  messages.user_id -> users.user_id
[Implied]  tags_to_articles.article_id -> articles.article_id

DROP DATABASE `db_237966_DB`;
UNINSTALL EXTENSION vsql_schematron;
