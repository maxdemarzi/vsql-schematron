CREATE DATABASE `db_284102_02_base_tables_up`;
USE `db_284102_02_base_tables_up`;
CREATE TABLE `ra_nodes` (
`id` INT,
`name` VARCHAR(64),
`code` VARCHAR(64),
`detail` VARCHAR(64),
`type` VARCHAR(64),
`inserted_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ra_users` (
`id` INT,
`node_id` INT,
`username` VARCHAR(64),
`password_digest` VARCHAR(64),
`email` VARCHAR(64),
`is_active` BOOL,
`inserted_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ra_jobs` (
`id` INT,
`node_id` INT,
`source_user_id` INT,
`inserted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ra_job_details` (
`id` INT,
`node_id` INT,
`job_id` INT,
`source_user_id` INT,
`code` VARCHAR(64),
`name` VARCHAR(64),
`type` VARCHAR(64),
`detail` VARCHAR(64),
`before` BOOL,
`before_jobs` VARCHAR(64),
`after` BOOL,
`after_jobs` VARCHAR(64),
`script_file` VARCHAR(64),
`script` VARCHAR(64),
`inserted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ra_job_logs` (
`id` INT,
`node_id` INT,
`job_id` INT,
`data` VARCHAR(64),
`state` BOOL,
`inserted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_284102_02_base_tables_up') AS relationships;
