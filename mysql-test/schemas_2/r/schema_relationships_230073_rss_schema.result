INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 230073_rss_schema
#
CREATE DATABASE `db_230073_rss_schema`;
USE `db_230073_rss_schema`;
CREATE TABLE `channel` (
`id` INT,
`name` VARCHAR(255),
`url` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`id` INT,
`channel_id` INT,
`channel` INT,
`title` VARCHAR(255),
`link` VARCHAR(255),
`description` VARCHAR(255),
`language` VARCHAR(255),
`copyright` VARCHAR(255),
`managing_editor` VARCHAR(255),
`web_master` VARCHAR(255),
`pub_date` DATETIME,
`last_build_date` DATETIME,
`generator` VARCHAR(255),
`docs` VARCHAR(255),
`cloud_id` INT,
`ttl` INT,
`image_id` INT,
`skip_hours` VARCHAR(255),
`skip_days` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` INT,
`category` VARCHAR(255),
`domain` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item_category` (
`id` INT,
`category_id` INT,
`item_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`id` INT,
`url` VARCHAR(255),
`title` VARCHAR(255),
`link` VARCHAR(255),
`width` INT,
`height` INT,
`description` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cloud` (
`id` INT,
`domain` VARCHAR(255),
`port` VARCHAR(255),
`path` VARCHAR(255),
`register_procedure` VARCHAR(255),
`protocol` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230073_rss_schema') AS relationships;
relationships
Database: db_230073_rss_schema

Table Connections:
------------------
[Implied]  item.channel -> channel.id
[Implied]  item.channel_id -> channel.id
[Implied]  item.cloud_id -> cloud.id
[Implied]  item.image_id -> image.id
[Implied]  item_category.category_id -> category.id
[Implied]  item_category.item_id -> item.id

DROP DATABASE `db_230073_rss_schema`;
UNINSTALL EXTENSION vsql_schematron;
