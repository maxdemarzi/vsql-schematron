CREATE DATABASE `db_200185_005_core_lookups_mysql`;
USE `db_200185_005_core_lookups_mysql`;
CREATE TABLE `aa_uom_types` (
`uom_type` INT,
`uom_type_description` VARCHAR(255),
PRIMARY KEY (`uom_type`)
) CHARACTER SET latin1;
CREATE TABLE `aa_uom` (
`uom_code` VARCHAR(255),
`uom_type` INT,
`uom_description` VARCHAR(255),
PRIMARY KEY (`uom_code`)
) CHARACTER SET latin1;
CREATE TABLE `aa_uom_conversions` (
`uom_type` INT,
`from_uom` VARCHAR(255),
`to_uom` VARCHAR(255),
`multiply_by` INT,
`divide_by` INT
) CHARACTER SET latin1;
CREATE TABLE `aa_terms` (
`terms_id` INT,
`terms_code` VARCHAR(255),
`terms_name` VARCHAR(255),
`terms_type` INT,
`terms_basis` INT,
`discount_percent_1` DECIMAL(10,2),
`discount_days_1` INT,
`discount_percent_2` DECIMAL(10,2),
`discount_days_2` INT,
`discount_percent_3` DECIMAL(10,2),
`discount_days_3` INT,
`tier1_type` VARCHAR(255),
`tier2_type` VARCHAR(255),
`tier3_type` VARCHAR(255),
`status` VARCHAR(255),
PRIMARY KEY (`terms_id`)
) CHARACTER SET latin1;
CREATE TABLE `aa_note_types` (
`note_type_id` INT,
`note_type_code` VARCHAR(255),
`note_type_description` VARCHAR(255),
PRIMARY KEY (`note_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `aa_attachment_types` (
`attachment_type_id` INT,
`attachment_type_code` VARCHAR(255),
`attachment_type_description` VARCHAR(255),
PRIMARY KEY (`attachment_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `aa_attachments` (
`attachment_id` INT,
`attachment_type_id` INT,
`file_name` VARCHAR(255),
`uri` VARCHAR(255),
`description` VARCHAR(255),
`hash_code` VARCHAR(255),
`data` VARCHAR(255),
PRIMARY KEY (`attachment_id`)
) CHARACTER SET latin1;
CREATE TABLE `aa_options` (
`option_id` INT,
`option_code` VARCHAR(255),
`option_group` VARCHAR(255),
`description` VARCHAR(255),
`option_value` VARCHAR(255),
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`option_id`)
) CHARACTER SET latin1;
