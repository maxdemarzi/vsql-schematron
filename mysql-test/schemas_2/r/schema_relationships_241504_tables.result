INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 241504_tables
#
CREATE DATABASE `db_241504_tables`;
USE `db_241504_tables`;
CREATE TABLE `bugs` (
`libname` VARCHAR(64),
`numberofbugs` INT,
`status` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
CREATE TABLE `releasefreq` (
`libname` VARCHAR(64),
`numreleases` INT,
`averagedays` INT,
`status` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
CREATE TABLE `lastdiscussed` (
`libname` VARCHAR(64),
`lastdate` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
CREATE TABLE `pullrequests` (
`libname` VARCHAR(64),
`percent` VARCHAR(64),
`mergedcount` INT,
`contributorprcount` INT,
`numPRs` INT,
`saveddate` VARCHAR(64),
`status` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`libname` VARCHAR(64),
`userclassification` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
CREATE TABLE `issueresponse` (
`libname` VARCHAR(64),
`averagedays` VARCHAR(64),
`totalWithComments` INT,
`totalIssues` INT,
`status` VARCHAR(64),
PRIMARY KEY (`libname`)
) CHARACTER SET latin1;
