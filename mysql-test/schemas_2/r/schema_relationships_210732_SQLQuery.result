INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 210732_SQLQuery
#
CREATE DATABASE `db_210732_SQLQuery`;
USE `db_210732_SQLQuery`;
CREATE TABLE `Bloc` (
`nom` VARCHAR(50) NOT NULL,
PRIMARY KEY (`nom`)
) CHARACTER SET latin1;
CREATE TABLE `Cassier` (
`nom` VARCHAR(50) NOT NULL,
`nomBloc` VARCHAR(50),
PRIMARY KEY (`nom`)
) CHARACTER SET latin1;
CREATE TABLE `Materiel` (
`ref` VARCHAR(50) NOT NULL,
`description` VARCHAR(50),
`prix` DOUBLE,
`quantite` DOUBLE,
`lien` VARCHAR(50),
`nomFab` VARCHAR(50),
PRIMARY KEY (`ref`)
) CHARACTER SET latin1;
CREATE TABLE `Fabricant` (
`nom` VARCHAR(50) NOT NULL,
PRIMARY KEY (`nom`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_210732_SQLQuery') AS relationships;
relationships
