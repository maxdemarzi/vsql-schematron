`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `product_pictures` (
`id` INT,
`product_id` INT,
`path` VARCHAR(64),
`default` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_points` (
`id` INT,
`user_id` INT,
`action_type_id` INT,
`source_id` INT,
`points` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
