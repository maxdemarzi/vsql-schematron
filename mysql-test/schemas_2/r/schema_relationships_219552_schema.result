INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 219552_schema
#
CREATE DATABASE `db_219552_schema`;
USE `db_219552_schema`;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`title` VARCHAR(255),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`manager_id` VARCHAR(255),
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_219552_schema') AS relationships;
relationships
Database: db_219552_schema

Table Connections:
