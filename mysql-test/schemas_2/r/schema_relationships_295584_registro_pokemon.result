`correo` VARCHAR(64),
`contrasena` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon` (
`id` INT,
`mote` VARCHAR(64),
`nivel` INT,
`entrenador` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
