INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 260275_code_calc
#
CREATE DATABASE `db_260275_code_calc`;
USE `db_260275_code_calc`;
CREATE TABLE `code_calc_subject` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_calc_model` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_calc_progs` (
`id` VARCHAR(50) NOT NULL,
`url` VARCHAR(50),
`name` VARCHAR(50),
`released` INT,
`subject` VARCHAR(50),
`model` VARCHAR(50),
`ticalc` VARCHAR(50),
`descmd` TEXT,
`deschtml` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_260275_code_calc') AS relationships;
