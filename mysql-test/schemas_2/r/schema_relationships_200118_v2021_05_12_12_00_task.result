CREATE TABLE `CATGENOME.TASK` (
`TASK_ID` INT,
`TITLE` VARCHAR(64),
`CREATED_DATE` DATETIME,
`STATUS` INT,
`END_DATE` DATETIME,
`STATUS_REASON` VARCHAR(64),
`QUERY` VARCHAR(64),
`DATABASE` VARCHAR(64),
`EXECUTABLE` VARCHAR(64),
`ALGORITHM` VARCHAR(64),
`OPTIONS` VARCHAR(64),
`OWNER` VARCHAR(64),
PRIMARY KEY (`TASK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_PARAMETER` (
`PARAMETER_ID` INT,
`TASK_ID` INT,
`PARAMETER` VARCHAR(64),
`VALUE` VARCHAR(64),
PRIMARY KEY (`PARAMETER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_ORGANISM` (
`ORGANISM_ID` INT,
`TASK_ID` INT,
`ORGANISM` INT,
PRIMARY KEY (`ORGANISM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_EXCL_ORGANISM` (
`ORGANISM_ID` INT,
`TASK_ID` INT,
`ORGANISM` INT,
PRIMARY KEY (`ORGANISM_ID`)
) CHARACTER SET latin1;
