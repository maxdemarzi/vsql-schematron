`session_id` INT,
`account` VARCHAR(64),
`computer_name` VARCHAR(64),
`record_number` INT,
`recovered` BOOL,
`alias` VARCHAR(64),
`record_hash` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `source_files` (
`file_name` VARCHAR(64),
`hash` VARCHAR(64),
`import_timestamp` DATETIME,
`alias` VARCHAR(64),
`computer_name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `raw_xml_data` (
`record_hash` VARCHAR(64),
`raw_xml` VARCHAR(64)
) CHARACTER SET latin1;
