INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 218458_init
#
CREATE DATABASE `db_218458_init`;
USE `db_218458_init`;
CREATE TABLE `TOWN` (
`ID` VARCHAR(64),
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CAR` (
`ID` VARCHAR(64),
`LABEL` VARCHAR(64),
`CLEAN` BOOL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON_ADDRESS` (
`ID` VARCHAR(64),
`STREET` VARCHAR(64),
`ID_TOWN` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON` (
`ID` VARCHAR(64),
`FIRSTNAME` VARCHAR(64),
`AGE` INT,
`BIRTHDAY` BOOL,
`ID_PERSON_ADDRESS` VARCHAR(64),
`ID_CAR` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PET` (
`ID` VARCHAR(64),
`NAME` VARCHAR(64),
`ID_PERSON` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_218458_init') AS relationships;
relationships
Database: db_218458_init

Table Connections:
------------------
[Implied]  PERSON.ID_CAR -> CAR.ID
[Implied]  PERSON.ID_PERSON_ADDRESS -> PERSON_ADDRESS.ID
[Implied]  PERSON_ADDRESS.ID_TOWN -> TOWN.ID
[Implied]  PET.ID_PERSON -> PERSON.ID
[Implied]  PET.ID_PERSON -> PERSON_ADDRESS.ID

DROP DATABASE `db_218458_init`;
UNINSTALL EXTENSION vsql_schematron;
