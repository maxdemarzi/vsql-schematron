INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 281036_Exo1
#
CREATE DATABASE `db_281036_Exo1`;
USE `db_281036_Exo1`;
CREATE TABLE `HOTEL` (
`NOMS_HOTEL` VARCHAR(50) NOT NULL,
`ADRESS` VARCHAR(50),
PRIMARY KEY (`NOMS_HOTEL`)
) CHARACTER SET latin1;
CREATE TABLE `CHAMBRE` (
`NUMERO_CH` INT NOT NULL,
`PRIX` INT,
`NOMS_HOTEL` VARCHAR(50) NOT NULL,
PRIMARY KEY (`NUMERO_CH`, `NOMS_HOTEL`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENT` (
`NUMERO_CLI` INT NOT NULL,
`NOMS_CLI` VARCHAR(50),
`PRENOMS_CLI` VARCHAR(50),
PRIMARY KEY (`NUMERO_CLI`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVATION` (
`NUMERO_RES` INT NOT NULL,
`DATE_RSA` VARCHAR(50),
`NUMERO_CLI` INT,
`NUMERO_CH` INT,
PRIMARY KEY (`NUMERO_RES`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281036_Exo1') AS relationships;
