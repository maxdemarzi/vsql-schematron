CREATE DATABASE `db_273724_001_initial`;
USE `db_273724_001_initial`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`surname` TEXT,
`email` TEXT,
`password` TEXT,
`role` INT,
`blocked` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `timers` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`start_time` TIMESTAMP NULL,
`end_time` TIMESTAMP NULL,
`pending` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `proofs` (
`id` VARCHAR(50) NOT NULL,
`timer_id` VARCHAR(50),
`time` TIMESTAMP NULL,
`percentage` DOUBLE,
`confirmed` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_273724_001_initial') AS relationships;
