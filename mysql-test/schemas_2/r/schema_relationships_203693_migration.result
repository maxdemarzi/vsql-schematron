`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Registry` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`author_id` INT,
`uid` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`registry_id` INT,
`date` DATETIME,
`degree` VARCHAR(64),
`accommodation` VARCHAR(64),
`image_key` VARCHAR(64),
`university` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Wishlist` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`registry_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Donation` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`summary` VARCHAR(64),
`image_key` VARCHAR(64),
`uid` VARCHAR(64),
`author_id` INT,
`registry_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`uid` VARCHAR(64),
`summary` VARCHAR(64),
`url` VARCHAR(64),
`wishlist_id` INT,
`donation_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`summary` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `_CategoryToWishlist` (
`A` INT,
