CREATE DATABASE `db_291640_V1_0__Initial_IGX_Database`;
USE `db_291640_V1_0__Initial_IGX_Database`;
CREATE TABLE `Users` (
`UserID` INT NOT NULL,
`Username` VARCHAR(50),
`Password` VARCHAR(50),
PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `Rank` (
`RankID` INT NOT NULL,
`UserID` INT,
`GamesPlayed` INT,
`GamesWon` INT,
`GamesPlayedHumans` INT,
`GamesWonHumans` INT,
`Rank` INT,
PRIMARY KEY (`RankID`)
) CHARACTER SET latin1;
CREATE TABLE `IGXConfig` (
`key` VARCHAR(50) NOT NULL,
`value` VARCHAR(50),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
