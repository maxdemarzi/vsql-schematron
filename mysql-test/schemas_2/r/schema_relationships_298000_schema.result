INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 298000_schema
#
CREATE DATABASE `db_298000_schema`;
USE `db_298000_schema`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_298000_schema') AS relationships;
relationships
Database: db_298000_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_298000_schema`;
UNINSTALL EXTENSION vsql_schematron;
