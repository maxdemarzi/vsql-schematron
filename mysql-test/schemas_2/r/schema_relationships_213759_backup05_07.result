CREATE DATABASE `db_213759_backup05_07`;
USE `db_213759_backup05_07`;
CREATE TABLE `chats` (
`chatid` INT,
`chatname` VARCHAR(64),
`participant` VARCHAR(64),
`time` DATETIME,
`isgroup` INT,
PRIMARY KEY (`chatid`, `participant`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
`id` VARCHAR(64),
`friendid` VARCHAR(64),
`installed` INT,
PRIMARY KEY (`id`, `friendid`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`chatid` INT,
`sender` VARCHAR(64),
`content` VARCHAR(64),
`ismedia` INT,
`time` DATETIME,
PRIMARY KEY (`chatid`, `sender`, `time`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`fbid` VARCHAR(64),
`token` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`fbid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_213759_backup05_07') AS relationships;
