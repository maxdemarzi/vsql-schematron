INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 243426_schema
#
CREATE DATABASE `db_243426_schema`;
USE `db_243426_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_243426_schema') AS relationships;
relationships
Database: db_243426_schema

