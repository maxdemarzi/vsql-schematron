INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 256995_schema
#
CREATE DATABASE `db_256995_schema`;
USE `db_256995_schema`;
CREATE TABLE `locations` (
`id` INT NOT NULL,
`search_query` VARCHAR(50),
`formatted_query` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
`id` INT NOT NULL,
`forecast` VARCHAR(50),
`time` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`overview` VARCHAR(50),
`average_votes` DOUBLE,
`total_votes` INT,
`image_url` VARCHAR(50),
`popularity` DECIMAL(10,2),
`released_on` CHAR(50),
`created_at` BIGINT,
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `yelp` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`url` VARCHAR(50),
`price` CHAR(50),
`rating` DECIMAL(10,2),
`image_url` VARCHAR(50),
`created_at` BIGINT,
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_256995_schema') AS relationships;
relationships
Database: db_256995_schema

Table Connections:
------------------
[Implied]  movies.location_id -> locations.id
[Implied]  weather.location_id -> locations.id
[Implied]  yelp.location_id -> locations.id

DROP DATABASE `db_256995_schema`;
UNINSTALL EXTENSION vsql_schematron;
