INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 204215_Estacion
#
CREATE DATABASE `db_204215_Estacion`;
USE `db_204215_Estacion`;
CREATE TABLE `ALERT` (
`ID` INT,
`DESCRIPTION` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ALERT_EVENTS` (
`ALERT_ID` INT,
`STATION_ID` INT,
`SENSORTYPE_ID` INT,
`ACTIVE` INT,
PRIMARY KEY (`ALERT_ID`, `STATION_ID`, `SENSORTYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STATION_SENSORTYPE` (
`STATION_ID` INT,
`SENSORTYPE_ID` INT,
PRIMARY KEY (`STATION_ID`, `SENSORTYPE_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_204215_Estacion') AS relationships;
relationships
