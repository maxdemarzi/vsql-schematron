INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 205111_script-mysql
#
CREATE DATABASE `db_205111_script_mysql`;
USE `db_205111_script_mysql`;
CREATE TABLE `usuarios` (
`idusr` INT NOT NULL,
`codigo` VARCHAR(50),
`nombre` VARCHAR(50),
`clave` VARCHAR(50),
PRIMARY KEY (`idusr`)
) CHARACTER SET latin1;
CREATE TABLE `opciones_menu` (
`idopc` INT NOT NULL,
`etiqueta` VARCHAR(50),
`comando` VARCHAR(50),
`estado` VARCHAR(50),
PRIMARY KEY (`idopc`)
) CHARACTER SET latin1;
CREATE TABLE `accesos_usuario` (
`idacc` INT NOT NULL,
`idopc` INT,
`idusr` INT,
PRIMARY KEY (`idacc`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_205111_script_mysql') AS relationships;
relationships
