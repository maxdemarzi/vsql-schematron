CREATE DATABASE `db_230872_OKKY`;
USE `db_230872_OKKY`;
CREATE TABLE `article` (
`id` INT,
`category_id` VARCHAR(64),
`version` INT,
`a_nick_name` VARCHAR(64),
`anonymity` BOOL,
`author_id` INT,
`choice` BOOL,
`content_id` INT,
`create_ip` VARCHAR(64),
`date_created` DATETIME,
`enabled` BOOL,
`is_recruit` BOOL,
`last_editor_id` INT,
`last_updated` DATETIME,
`note_count` INT,
`scrap_count` INT,
`selected_note_id` INT,
`tag_string` VARCHAR(64),
`title` VARCHAR(64),
`view_count` INT,
`vote_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
