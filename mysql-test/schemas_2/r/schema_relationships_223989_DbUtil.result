) CHARACTER SET latin1;
CREATE TABLE `phone` (
`id` BIGINT NOT NULL,
`ddd` INT,
`number` VARCHAR(50),
`type` VARCHAR(50),
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
