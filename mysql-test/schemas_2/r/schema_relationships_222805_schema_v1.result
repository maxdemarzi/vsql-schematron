INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 222805_schema_v1
#
CREATE DATABASE `db_222805_schema_v1`;
USE `db_222805_schema_v1`;
CREATE TABLE `studies` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `assays` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`study_id` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `search_configuration` (
`id` INT NOT NULL,
`equate_il` INT,
`filter_duplicates` INT,
`missing_cleavage_handling` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pept2data` (
`assay_id` VARCHAR(50) NOT NULL,
`index_buffer` BLOB,
`data_buffer` BLOB,
PRIMARY KEY (`assay_id`)
) CHARACTER SET latin1;
CREATE TABLE `peptide_trust` (
`assay_id` VARCHAR(50) NOT NULL,
`missed_peptides` TEXT,
`matched_peptides` INT,
`searched_peptides` INT,
PRIMARY KEY (`assay_id`)
) CHARACTER SET latin1;
CREATE TABLE `storage_metadata` (
`assay_id` VARCHAR(50) NOT NULL,
`configuration_id` INT,
`endpoint` TEXT,
`db_version` TEXT,
`analysis_date` TEXT,
PRIMARY KEY (`assay_id`)
) CHARACTER SET latin1;
CREATE TABLE `database_metadata` (
`application_version` TEXT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_222805_schema_v1') AS relationships;
relationships
Database: db_222805_schema_v1

Table Connections:
------------------
[Implied]  assays.study_id -> studies.id
[Implied]  storage_metadata.configuration_id -> search_configuration.id

DROP DATABASE `db_222805_schema_v1`;
UNINSTALL EXTENSION vsql_schematron;
