CREATE DATABASE `db_298873_egresados_database`;
USE `db_298873_egresados_database`;
CREATE TABLE `achievements_users` (
`id` INT NOT NULL,
`achievement_id` INT,
`users_id` VARCHAR(50),
`level` VARCHAR(50),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `companies` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`phone` VARCHAR(50),
`location` VARCHAR(50),
`created` DATETIME,
`modified` DATETIME,
`sector_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `companies_users` (
`companies_id` INT,
`id` INT NOT NULL,
`users_id` VARCHAR(50),
`position` VARCHAR(50),
`start_date` DATE,
`end_date` DATE,
`current_job` TINYINT,
`description` VARCHAR(50),
`created` DATETIME,
`modified` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sectors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created` DATETIME,
`modified` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `settings` (
`id` INT NOT NULL,
`profile` VARCHAR(50),
`sms_user` VARCHAR(50),
`sms_pass` VARCHAR(50),
`sms_from` VARCHAR(50),
`sms_apikey` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skills_users` (
`id` INT NOT NULL,
`skills_id` INT,
`users_id` VARCHAR(50),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_298873_egresados_database') AS relationships;
