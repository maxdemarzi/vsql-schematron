CREATE DATABASE `db_217495_recipeapp_ddl`;
USE `db_217495_recipeapp_ddl`;
CREATE TABLE `RECIPE` (
`RECIPE_ID` INT,
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`DIFFICULTY` VARCHAR(64),
`SERVINGS` INT,
`SOURCE` VARCHAR(64),
`URL` VARCHAR(64),
`IMAGE` VARCHAR(64),
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`RECIPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORY` (
`CATEGORY_ID` INT,
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`CATEGORY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STEP` (
`STEP_ID` INT,
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`PREPARATION_TIME` INT,
`COOKING_TIME` INT,
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`STEP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `INGREDIENT` (
`INGREDIENT_ID` INT,
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`INGREDIENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `UOM` (
`UOM_ID` INT,
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
`NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
PRIMARY KEY (`UOM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RECIPE_CATEGORY` (
`RECIPE_ID` INT,
`CATEGORY_ID` INT
) CHARACTER SET latin1;
CREATE TABLE `RECIPE_STEP` (
`RECIPE_STEP_ID` INT,
`RECIPE_ID` INT,
`STEP_ID` INT,
`ORDINAL` INT,
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`RECIPE_STEP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STEP_INGREDIENT` (
`STEP_INGREDIENT_ID` INT,
`STEP_ID` INT,
`INGREDIENT_ID` INT,
`UOM_ID` INT,
`UOM_COUNT` DECIMAL(10,2),
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`STEP_INGREDIENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `NOTE` (
`NOTE_ID` INT,
`RECIPE_ID` INT,
`NOTE_TEXT` VARCHAR(64),
`CREATED_TIMESTAMP` DATETIME,
`MODIFIED_TIMESTAMP` DATETIME,
PRIMARY KEY (`NOTE_ID`)
) CHARACTER SET latin1;
