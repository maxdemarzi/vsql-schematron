[Implied]  job.user_id -> user.id
[Implied]  laststate.host_id -> host.id
[Implied]  notification.user_id -> user.id
[Implied]  ou.optionset_id -> optionset.id
[Implied]  ou.parent_id -> ou.id
[Implied]  statelog.host_id -> host.id
[Implied]  user.ou_id -> ou.id

DROP DATABASE `db_275337_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
