CREATE TABLE `Movies` (
`titleid` VARCHAR(64),
`title` VARCHAR(64),
`releaseyear` INT,
`runtimemin` INT,
`summary` VARCHAR(64),
PRIMARY KEY (`titleid`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`userid` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `Casts` (
`castid` VARCHAR(64),
`castname` VARCHAR(64),
PRIMARY KEY (`castid`)
) CHARACTER SET latin1;
CREATE TABLE `Cast_Movie` (
`castid` VARCHAR(64),
`titleid` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`castid`, `titleid`, `role`)
) CHARACTER SET latin1;
CREATE TABLE `Lists` (
`listid` VARCHAR(64),
`userid` VARCHAR(64),
`listname` VARCHAR(64),
PRIMARY KEY (`listid`)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
`commentid` VARCHAR(64),
`titleid` VARCHAR(64),
`userid` VARCHAR(64),
`comment` VARCHAR(64),
`publishtime` DATETIME,
PRIMARY KEY (`commentid`)
) CHARACTER SET latin1;
CREATE TABLE `List_Movie` (
`listid` VARCHAR(64),
`titleid` VARCHAR(64),
PRIMARY KEY (`listid`, `titleid`)
) CHARACTER SET latin1;
CREATE TABLE `Genre_Movie` (
`titleid` VARCHAR(64),
`genre` VARCHAR(64),
PRIMARY KEY (`titleid`, `genre`)
) CHARACTER SET latin1;
CREATE TABLE `Subscription` (
`subscriber` VARCHAR(64),
`subscribeto` VARCHAR(64),
PRIMARY KEY (`subscriber`, `subscribeto`)
) CHARACTER SET latin1;
