CREATE DATABASE `db_296682_initdbtableschema`;
USE `db_296682_initdbtableschema`;
CREATE TABLE `routes` (
`routeid` INT,
`fromPort` VARCHAR(255),
`toPort` VARCHAR(255),
`routeStr` VARCHAR(255),
PRIMARY KEY (`routeid`)
) CHARACTER SET latin1;
CREATE TABLE `flightPrices` (
`_id` INT,
`routeid` INT,
`carrier` VARCHAR(255),
`depTime` INT,
`arrTime` INT,
`price` DECIMAL(10,2),
`layovers` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `flightlegs` (
`_id` INT,
`priceID` INT,
`airline` VARCHAR(255),
`flightno` VARCHAR(255),
`routeid` INT,
`fromPort` VARCHAR(255),
`toPort` VARCHAR(255),
`depTime` INT,
`arrTime` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_296682_initdbtableschema') AS relationships;
