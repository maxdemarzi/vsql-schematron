CREATE DATABASE `db_276821_000001_init_schema_up`;
USE `db_276821_000001_init_schema_up`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`answers` VARCHAR(50),
`correct` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`group_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tests` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_questions` (
`id` BIGINT NOT NULL,
`question_id` BIGINT,
`test_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_276821_000001_init_schema_up') AS relationships;
