INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 286495_sql-schema
#
CREATE DATABASE `db_286495_sql_schema`;
USE `db_286495_sql_schema`;
CREATE TABLE `customers` (
`c_id` INT NOT NULL,
`firstname` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`c_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT NOT NULL,
`name` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT NOT NULL,
`c_id` INT,
`total_cost` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_items_id` INT NOT NULL,
`order_id` INT,
`item_id` INT,
`quantity` INT,
PRIMARY KEY (`order_items_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_286495_sql_schema') AS relationships;
relationships
Database: db_286495_sql_schema

Table Connections:
------------------
[Implied]  order_items.item_id -> items.item_id
[Implied]  order_items.order_id -> orders.order_id
[Implied]  orders.c_id -> customers.c_id

DROP DATABASE `db_286495_sql_schema`;
UNINSTALL EXTENSION vsql_schematron;
