CREATE DATABASE `db_224373_create_tables`;
USE `db_224373_create_tables`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`email` TEXT,
`hashed_password` TEXT,
`auth_token` TEXT,
`is_admin` BOOLEAN,
`is_service` BOOLEAN,
`date_created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `twitter_accounts` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`username` TEXT,
`date_created` TIMESTAMP NULL,
`consumer_key` TEXT,
`consumer_secret` TEXT,
`access_token` TEXT,
`access_token_secret` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets` (
`id` VARCHAR(50) NOT NULL,
`twitter_account_id` VARCHAR(50),
`tweet` TEXT,
`post_on` TIMESTAMP NULL,
`is_posted` BOOLEAN,
`date_created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
