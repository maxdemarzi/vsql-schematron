INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 200989_ZenQuery_postgres
#
CREATE DATABASE `db_200989_ZenQuery_postgres`;
USE `db_200989_ZenQuery_postgres`;
CREATE TABLE `database_connections` (
`id` INT NOT NULL,
`name` CHAR(50),
`url` CHAR(50),
`username` CHAR(50),
`password` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queries` (
`id` INT NOT NULL,
`key` CHAR(50),
`database_connection_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `query_versions` (
`id` INT NOT NULL,
`content` CHAR(50),
`version` INT,
`is_current_version` BOOLEAN,
`query_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_200989_ZenQuery_postgres') AS relationships;
relationships
