CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `condos` (
`id` INT,
`name` VARCHAR(64),
`location` VARCHAR(64),
`owner_id` INT,
`price` INT,
`pets` BOOL,
`guests` INT,
`description` VARCHAR(64),
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pictures` (
`id` INT,
`name` VARCHAR(64),
`property_id` INT,
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `calendars` (
`id` INT,
`name` VARCHAR(64),
`property_id` INT,
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
