CREATE DATABASE `db_270965_cmritdb`;
USE `db_270965_cmritdb`;
CREATE TABLE `clubchange` (
`id` INT,
`club_id` VARCHAR(64),
`action` VARCHAR(64),
`cdate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clubs` (
`club_id` VARCHAR(64),
`club_name` VARCHAR(64),
`branch` VARCHAR(64),
PRIMARY KEY (`club_id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`e_id` VARCHAR(64),
`e_name` VARCHAR(64),
`o_name` VARCHAR(64),
`club_id` VARCHAR(64),
`start_date` DATETIME,
`end_date` DATETIME,
`status` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`m_id` VARCHAR(64),
`name` VARCHAR(64),
`branch` VARCHAR(64),
`sex` VARCHAR(64),
`email` VARCHAR(64),
`ph_no` VARCHAR(64),
`club_id` VARCHAR(64),
`desg` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `organiser` (
`m_id` VARCHAR(64),
`e_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `resourceperson` (
`r_name` VARCHAR(64),
`email_id` VARCHAR(64),
`company` VARCHAR(64),
`desg` VARCHAR(64),
`ph_no` VARCHAR(64),
`e_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`s_id` VARCHAR(64),
`s_name` VARCHAR(64),
`branch` VARCHAR(64),
`sex` VARCHAR(64),
`email` VARCHAR(64),
`sem` INT,
`ph_no` VARCHAR(64),
`e_id` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_270965_cmritdb') AS relationships;
