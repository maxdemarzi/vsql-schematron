CREATE TABLE `actions` (
`id` INT NOT NULL,
`types` VARCHAR(50),
`chrono` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `but` (
`id` INT NOT NULL,
`equipe` INT,
`joueur` VARCHAR(50),
`idActions` INT,
`valeur` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `faute` (
`id` INT NOT NULL,
`equipe` INT,
`typeCarton` INT,
`idActions` INT,
`valeur` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `possession` (
`id` INT NOT NULL,
`equipe` INT,
`valeur` DOUBLE,
`idActions` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tir` (
`id` INT NOT NULL,
`equipe` INT,
`typeTir` INT,
`idActions` INT,
`valeur` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `touche` (
`id` INT NOT NULL,
`equipe` INT,
`idActions` INT,
`valeurs` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
