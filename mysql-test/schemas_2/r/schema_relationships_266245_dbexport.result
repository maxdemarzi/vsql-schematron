INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 266245_dbexport
#
CREATE DATABASE `db_266245_dbexport`;
USE `db_266245_dbexport`;
CREATE TABLE `component` (
`cp_uuid` VARCHAR(64),
`dsb_uuid` VARCHAR(64),
`cp_route` VARCHAR(64),
PRIMARY KEY (`cp_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `dashboard` (
`dsb_uuid` VARCHAR(64),
`usr_email` VARCHAR(64),
`dsb_name` VARCHAR(64),
PRIMARY KEY (`dsb_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `dashboard_x_label` (
`dsb_uuid` VARCHAR(64),
`lbl_id` INT,
PRIMARY KEY (`dsb_uuid`, `lbl_id`)
) CHARACTER SET latin1;
CREATE TABLE `followers` (
`follower_email` VARCHAR(64),
`usr_email` VARCHAR(64),
PRIMARY KEY (`follower_email`, `usr_email`)
) CHARACTER SET latin1;
CREATE TABLE `label` (
`lbl_id` INT,
`lbl_name` VARCHAR(64),
PRIMARY KEY (`lbl_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_266245_dbexport') AS relationships;
relationships
Database: db_266245_dbexport

