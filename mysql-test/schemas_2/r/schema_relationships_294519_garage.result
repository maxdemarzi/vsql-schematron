INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 294519_garage
#
CREATE DATABASE `db_294519_garage`;
USE `db_294519_garage`;
CREATE TABLE `appointments` (
`id` INT,
`name` VARCHAR(64),
`comment` VARCHAR(64),
`datetime` DATETIME,
`status` VARCHAR(64),
`car_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT,
`plate` VARCHAR(64),
`brand` VARCHAR(64),
`type` VARCHAR(64),
`customer_id` INT
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`zipcode` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parts` (
`id` INT,
`name` VARCHAR(64),
`brand` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `repairs` (
`id` INT,
`appointment_id` INT,
`part_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_294519_garage') AS relationships;
relationships
Database: db_294519_garage

Table Connections:
------------------
[Implied]  appointments.car_id -> cars.id
[Implied]  cars.customer_id -> customers.id
[Implied]  repairs.appointment_id -> appointments.id
[Implied]  repairs.part_id -> parts.id

DROP DATABASE `db_294519_garage`;
UNINSTALL EXTENSION vsql_schematron;
