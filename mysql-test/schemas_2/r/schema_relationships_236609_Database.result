[Implied]  Employee.roleId -> Role.id
[Implied]  Notification.vacationId -> Vacation.id
[Implied]  Project.statusId -> Status.id
[Implied]  Project_Employee.employeeId -> Employee.username
[Implied]  Project_Employee.projectId -> Project.id
[Implied]  Vacation.employeeId -> Employee.username
[Implied]  Vacation.vacationStatusId -> Vacation_Status.id

DROP DATABASE `db_236609_Database`;
UNINSTALL EXTENSION vsql_schematron;
