INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 260187_db
#
CREATE DATABASE `db_260187_db`;
USE `db_260187_db`;
CREATE TABLE `roles` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`image` VARCHAR(50),
`route` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`email` VARCHAR(50),
`name` VARCHAR(50),
`lastname` VARCHAR(50),
`phone` VARCHAR(50),
`password` VARCHAR(50),
`salt` VARCHAR(50),
`image` VARCHAR(50),
`is_available` BOOLEAN,
`session_token` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_has_roles` (
`id_user` BIGINT NOT NULL,
`id_role` BIGINT NOT NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id_user`, `id_role`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_260187_db') AS relationships;
relationships
Database: db_260187_db

