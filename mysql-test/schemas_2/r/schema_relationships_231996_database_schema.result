INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 231996_database_schema
#
CREATE DATABASE `db_231996_database_schema`;
USE `db_231996_database_schema`;
CREATE TABLE `User` (
`email` VARCHAR(50) NOT NULL,
`telegramId` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
`password` VARCHAR(50),
`phone_number` VARCHAR(50),
`statements` BOOLEAN,
PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `Fire` (
`id` INT NOT NULL,
`actual_location` VARCHAR(50),
`fire_location` VARCHAR(50),
`photo` VARCHAR(50),
`industrial_area` BOOLEAN,
`waste_dump` BOOLEAN,
`city_center` BOOLEAN,
`trusses` BOOLEAN,
`gas_pipeline` BOOLEAN,
`bell_tower` BOOLEAN,
`more_info` VARCHAR(50),
`dateAndTime` VARCHAR(50),
`user_email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_231996_database_schema') AS relationships;
relationships
