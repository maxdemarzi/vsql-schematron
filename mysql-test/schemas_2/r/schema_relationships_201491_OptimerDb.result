CREATE DATABASE `db_201491_OptimerDb`;
USE `db_201491_OptimerDb`;
CREATE TABLE `Usuarios` (
`id_usuario` INT,
`usuario` VARCHAR(64),
`senha` VARCHAR(64),
`nome` VARCHAR(64),
`email` VARCHAR(64),
`telefone` VARCHAR(64),
`cargo` VARCHAR(64),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `Clientes` (
`id_cliente` INT,
`identidade` VARCHAR(64),
`cpfcnpj` VARCHAR(64),
`nome` VARCHAR(64),
`email` VARCHAR(64),
`inscEst` VARCHAR(64),
`telefone` VARCHAR(64),
`genero` VARCHAR(64),
`data_nasc` DATETIME,
`data_cadastro` DATETIME,
`observacoes` VARCHAR(64),
PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `Enderecos` (
`id_endereco` INT,
