INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 267461_database
#
CREATE DATABASE `db_267461_database`;
USE `db_267461_database`;
CREATE TABLE `users` (
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants` (
`rid` VARCHAR(64),
`name` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`zip` VARCHAR(64),
`phone` VARCHAR(64),
`url` VARCHAR(64),
`twitter` VARCHAR(64),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`rid`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`uid` VARCHAR(64),
`rid` VARCHAR(64),
`vote` INT,
`creation` DATETIME,
PRIMARY KEY (`uid`, `rid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_267461_database') AS relationships;
