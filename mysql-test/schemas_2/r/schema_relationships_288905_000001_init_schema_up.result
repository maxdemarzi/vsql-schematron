INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 288905_000001_init_schema_up
#
CREATE DATABASE `db_288905_000001_init_schema_up`;
USE `db_288905_000001_init_schema_up`;
CREATE TABLE `accounts` (
`id` INT,
`owner` VARCHAR(64),
`citizenship` VARCHAR(64),
`balance` INT,
`currency` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
`id` INT,
`account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transfers` (
`id` INT,
`from_account_id` INT,
`to_account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transfers_psp` (
`id` INT,
`account_id` INT,
`psp_account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_288905_000001_init_schema_up') AS relationships;
