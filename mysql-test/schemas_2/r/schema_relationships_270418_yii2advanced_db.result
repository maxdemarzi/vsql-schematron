INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 270418_yii2advanced_db
#
CREATE DATABASE `db_270418_yii2advanced_db`;
USE `db_270418_yii2advanced_db`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `menu` (
`id` INT,
`name` VARCHAR(64),
`parent` INT,
`route` VARCHAR(64),
`order` INT,
`data` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `url_status` (
`hash_string` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
`url` VARCHAR(64),
`status_code` INT,
`query_count` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`auth_key` VARCHAR(64),
`password_hash` VARCHAR(64),
`password_reset_token` VARCHAR(64),
`email` VARCHAR(64),
`status` INT,
`created_at` INT,
`updated_at` INT,
`verification_token` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_270418_yii2advanced_db') AS relationships;
relationships
Database: db_270418_yii2advanced_db

