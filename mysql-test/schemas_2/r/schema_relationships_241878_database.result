CREATE DATABASE `db_241878_database`;
USE `db_241878_database`;
CREATE TABLE `TIPO_USUARIO` (
`IDTIPO` INT,
`NOMBRE` VARCHAR(64),
`DESCRIPCION` VARCHAR(64),
PRIMARY KEY (`IDTIPO`)
) CHARACTER SET latin1;
CREATE TABLE `ESTADO_USUARIO` (
`IDESTADO` INT,
`NOMBRE` VARCHAR(64),
`DESCRIPCION` VARCHAR(64),
PRIMARY KEY (`IDESTADO`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO` (
`IDUSUARIO` INT,
`NOMBREUSUARIO` VARCHAR(64),
`CEDULA` VARCHAR(64),
`TELEFONO` VARCHAR(64),
`CORREO` VARCHAR(64),
`NOMBRE` VARCHAR(64),
`APELLIDO` VARCHAR(64),
`CONTRASENA` VARCHAR(64),
`GENERO` VARCHAR(64),
`TIPO` INT,
`ESTADO` INT,
PRIMARY KEY (`IDUSUARIO`)
) CHARACTER SET latin1;
CREATE TABLE `MONEDA` (
`IDMONEDA` INT,
`NOMBRE` VARCHAR(64),
`ABREVIATURA` VARCHAR(64),
PRIMARY KEY (`IDMONEDA`)
) CHARACTER SET latin1;
CREATE TABLE `ESTADO_CUENTA` (
`IDESTADO` INT,
`NOMBRE` VARCHAR(64),
`DESCRIPCION` VARCHAR(64),
PRIMARY KEY (`IDESTADO`)
) CHARACTER SET latin1;
CREATE TABLE `CUENTA_AHORRO` (
`IDCUENTA` INT,
`BALANCE` DECIMAL(10,2),
`FECHA_APERTURA` DATETIME,
`USUARIO` INT,
`MONEDA` INT,
`ESTADO` INT,
PRIMARY KEY (`IDCUENTA`)
) CHARACTER SET latin1;
CREATE TABLE `ESTADO_TARJETA` (
`IDESTADO` INT,
`NOMBRE` VARCHAR(64),
`DESCRIPCION` VARCHAR(64),
PRIMARY KEY (`IDESTADO`)
) CHARACTER SET latin1;
CREATE TABLE `TARJETA_DEBITO` (
`IDTARJETA` INT,
`FECHA_CREACION` DATETIME,
`FECHA_EXPIRACION` DATETIME,
`CUENTA` INT,
PRIMARY KEY (`IDTARJETA`)
) CHARACTER SET latin1;
CREATE TABLE `ESTADO_TRANSACCION` (
`IDESTADO` INT,
`NOMBRE` VARCHAR(64),
`DESCRIPCION` VARCHAR(64),
PRIMARY KEY (`IDESTADO`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSACCION` (
`IDTRANSACCION` INT,
`FECHA` DATETIME,
`LATITUD` VARCHAR(64),
`LONGITUD` VARCHAR(64),
`CUENTA_ORIGEN` INT,
`CUENTA_DESTINO` INT,
`MONTO` DECIMAL(10,2),
`ESTADO` INT,
PRIMARY KEY (`IDTRANSACCION`)
) CHARACTER SET latin1;
CREATE TABLE `TASA_CAMBIO` (
`IDTASA` INT,
`MONEDA_ORIGEN` INT,
`MONEDA_DESTINO` INT,
`TASA` DECIMAL(10,2),
PRIMARY KEY (`IDTASA`)
) CHARACTER SET latin1;
CREATE TABLE `BILLETE` (
`IDBILLETE` INT,
`MONEDA` INT,
`VALOR` INT,
PRIMARY KEY (`IDBILLETE`)
) CHARACTER SET latin1;
