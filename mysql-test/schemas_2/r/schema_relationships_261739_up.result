PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AtlasEdge` (
`id` INT,
`atlas_id` INT,
`polygon_point_id` INT,
`source_id` INT,
`sink_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
