`raw_data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `email_content` (
`id` BIGINT,
`email` BIGINT,
`content_type` VARCHAR(50),
`data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `email_attachment` (
`id` BIGINT,
`email` BIGINT,
`filename` VARCHAR(50),
`data` VARCHAR(50)
) CHARACTER SET latin1;
