[Implied]  rs_chatroom_grants.grant_user -> rs_users.user_id
[Implied]  rs_comments.comment_post -> rs_posts.post_id
[Implied]  rs_comments.comment_user -> rs_users.user_id
[Implied]  rs_files.file_post -> rs_posts.post_id
[Implied]  rs_posts.post_user -> rs_users.user_id
[Implied]  rs_private_messages.mp_user -> rs_users.user_id
[Implied]  rs_relations.relation_user1 -> rs_users.user_id
[Implied]  rs_relations.relation_user2 -> rs_users.user_id
[Implied]  rs_reports.report_comment -> rs_comments.comment_id
[Implied]  rs_reports.report_post -> rs_posts.post_id
[Implied]  rs_reports.report_user -> rs_users.user_id
[Implied]  rs_votes.vote_post -> rs_posts.post_id
[Implied]  rs_votes.vote_user -> rs_users.user_id

DROP DATABASE `db_255375_db`;
UNINSTALL EXTENSION vsql_schematron;
