INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 289361_schema
#
CREATE DATABASE `db_289361_schema`;
USE `db_289361_schema`;
CREATE TABLE `users` (
`username` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`surname` VARCHAR(64),
`biografy` VARCHAR(64),
`imageprofile` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `advertiser` (
`advertiserid` VARCHAR(64),
PRIMARY KEY (`advertiserid`)
) CHARACTER SET latin1;
CREATE TABLE `reader` (
`readerid` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`articlesid` INT,
`advertiserid` VARCHAR(64),
`categoryid` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`markdown` VARCHAR(64),
`imagearticle` VARCHAR(64),
PRIMARY KEY (`articlesid`)
) CHARACTER SET latin1;
CREATE TABLE `material` (
`materialid` INT,
`articlesid` INT,
`filepath` VARCHAR(64),
`virustotalurl` VARCHAR(64),
PRIMARY KEY (`materialid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_289361_schema') AS relationships;
relationships
Database: db_289361_schema

Table Connections:
