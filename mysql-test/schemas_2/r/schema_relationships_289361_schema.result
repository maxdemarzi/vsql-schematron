[Implied]  articles.advertiserid -> advertiser.advertiserid
[Implied]  articles.categoryid -> category.name
[Implied]  material.articlesid -> articles.articlesid

DROP DATABASE `db_289361_schema`;
UNINSTALL EXTENSION vsql_schematron;
