) CHARACTER SET latin1;
CREATE TABLE `mydb.Notas` (
`idNota` INT,
`idAlumno` INT,
`nota` DECIMAL(10,2),
`idProfesor` INT,
`idAsignatura` INT,
`IdSemestre` INT,
`fecNota` DATETIME,
`idCarrera` INT,
PRIMARY KEY (`idNota`)
) CHARACTER SET latin1;
