INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 293666_creation
#
CREATE DATABASE `db_293666_creation`;
USE `db_293666_creation`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`date_of_birth` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT,
`name` VARCHAR(64),
`genre` VARCHAR(64),
`release_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`user_id` INT,
`movie_id` INT,
`rating` DECIMAL(10,2),
`comment` VARCHAR(64),
PRIMARY KEY (`user_id`, `movie_id`)
) CHARACTER SET latin1;
CREATE TABLE `actors` (
`id` INT,
`name` VARCHAR(64),
`gender` VARCHAR(64),
`date_of_birth` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lead` (
`actor_id` INT,
`movie_id` INT,
PRIMARY KEY (`actor_id`, `movie_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_293666_creation') AS relationships;
relationships
Database: db_293666_creation

Table Connections:
