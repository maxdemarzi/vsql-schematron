INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 201322_base_dades
#
CREATE DATABASE `db_201322_base_dades`;
USE `db_201322_base_dades`;
CREATE TABLE `Login` (
`user` VARCHAR(64),
`mail` VARCHAR(64),
`password` VARCHAR(64),
`connected` BOOL,
`register_date` VARCHAR(64),
`last_login` VARCHAR(64),
`number_games` INT,
`total_points` INT,
`gaming` BOOL,
`startingGameTime` VARCHAR(64),
PRIMARY KEY (`user`, `mail`)
) CHARACTER SET latin1;
CREATE TABLE `Replay` (
`user` VARCHAR(64),
`ID` INT,
`Order_` INT,
`move` VARCHAR(64),
`path` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Partida` (
`user` VARCHAR(64),
`score` INT,
`time` VARCHAR(64),
`game_date` VARCHAR(64),
`max_espectators` INT,
`replay_path` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `DefaultKeys` (
`user` VARCHAR(64),
`derecha` INT,
`izquierda` INT,
`abajo` INT,
`rderecha` INT,
`rizquierda` INT,
`pause` INT,
PRIMARY KEY (`user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_201322_base_dades') AS relationships;
relationships
Database: db_201322_base_dades

