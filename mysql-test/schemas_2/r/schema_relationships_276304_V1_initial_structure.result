CREATE DATABASE `db_276304_V1_initial_structure`;
USE `db_276304_V1_initial_structure`;
CREATE TABLE `actor` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`active` INT,
`name` VARCHAR(64),
`created_by` INT,
`updated_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `director` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`active` INT,
`name` VARCHAR(64),
`created_by` INT,
`updated_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`active` INT,
`amount_votes` INT,
`average_score` DECIMAL(10,2),
`genre` VARCHAR(64),
`name` VARCHAR(64),
`total_score` INT,
`created_by` INT,
`updated_by` INT,
`director_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_actors` (
`movie_id` INT,
`actors_id` INT
) CHARACTER SET latin1;
CREATE TABLE `movie_votes` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`active` INT,
`score` INT,
`created_by` INT,
`updated_by` INT,
`movie_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
