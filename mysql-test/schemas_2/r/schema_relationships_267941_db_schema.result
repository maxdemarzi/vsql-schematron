[Implied]  Point.trip_id -> Trip.id
[Implied]  Subscription.from_user -> User.uid
[Implied]  Subscription.to_user -> User.uid
[Implied]  Trip.user_id -> User.uid

DROP DATABASE `db_267941_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
