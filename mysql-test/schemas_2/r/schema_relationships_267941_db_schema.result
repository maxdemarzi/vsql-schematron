INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 267941_db_schema
#
CREATE DATABASE `db_267941_db_schema`;
USE `db_267941_db_schema`;
CREATE TABLE `Point` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`description` VARCHAR(255),
`photos` VARCHAR(255),
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
`address` VARCHAR(255),
`address_components` VARCHAR(255),
`trip_id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Trip` (
`id` VARCHAR(255),
`tripname` VARCHAR(255),
`is_completed` VARCHAR(255),
`first_point_name` VARCHAR(255),
`last_point_name` VARCHAR(255),
`photo` VARCHAR(255),
`user_id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`uid` VARCHAR(255),
`email` VARCHAR(255),
`nickname` VARCHAR(255),
`password` VARCHAR(255),
`photo` VARCHAR(255),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `Subscription` (
`from_user` VARCHAR(255),
`to_user` VARCHAR(255),
PRIMARY KEY (`from_user`, `to_user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_267941_db_schema') AS relationships;
relationships
Database: db_267941_db_schema

Table Connections:
