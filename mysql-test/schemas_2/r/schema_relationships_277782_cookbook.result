INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 277782_cookbook
#
CREATE DATABASE `db_277782_cookbook`;
USE `db_277782_cookbook`;
CREATE TABLE `dishes` (
`id` INT,
`title` VARCHAR(255),
`big_img` VARCHAR(255),
`small_img` VARCHAR(255),
`description` VARCHAR(255),
`user_id` INT,
`category_id` INT,
`views` INT,
`rating` DECIMAL(10,2),
`complexity` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dish_steps` (
`id` INT,
`step_number` INT,
`img` VARCHAR(255),
`text` VARCHAR(255),
`dish_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`id` INT,
`ingredients_name` VARCHAR(255),
`quantity` VARCHAR(255),
`measure_id` INT,
`dish_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_277782_cookbook') AS relationships;
relationships
Database: db_277782_cookbook

Table Connections:
------------------
[Implied]  dish_steps.dish_id -> dishes.id
[Implied]  ingredients.dish_id -> dishes.id

DROP DATABASE `db_277782_cookbook`;
