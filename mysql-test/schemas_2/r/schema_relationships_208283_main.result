INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 208283_main
#
CREATE DATABASE `db_208283_main`;
USE `db_208283_main`;
CREATE TABLE `student` (
`student_id` INT,
`name` VARCHAR(64),
`major` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`emp_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birth_day` DATETIME,
`sex` VARCHAR(64),
`salary` INT,
`super_id` INT,
`branch_id` INT,
PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
CREATE TABLE `branch` (
`branch_id` INT,
`branch_name` VARCHAR(64),
`mgr_id` INT,
`mgr_start_date` DATETIME,
PRIMARY KEY (`branch_id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`client_id` INT,
`client_name` VARCHAR(64),
`branch_id` INT,
PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `works_with` (
`emp_id` INT,
`client_id` INT,
`total_sales` INT,
PRIMARY KEY (`emp_id`, `client_id`)
) CHARACTER SET latin1;
CREATE TABLE `branch_supplier` (
`branch_id` INT,
`supplier_name` VARCHAR(64),
`supply_type` VARCHAR(64),
PRIMARY KEY (`branch_id`, `supplier_name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_208283_main') AS relationships;
relationships
Database: db_208283_main

Table Connections:
------------------
[Implied]  branch.mgr_id -> branch.branch_id
[Implied]  branch_supplier.branch_id -> branch.branch_id
[Implied]  client.branch_id -> branch.branch_id
[Implied]  employee.branch_id -> branch.branch_id
[Implied]  works_with.client_id -> client.client_id
[Implied]  works_with.emp_id -> employee.emp_id

DROP DATABASE `db_208283_main`;
UNINSTALL EXTENSION vsql_schematron;
