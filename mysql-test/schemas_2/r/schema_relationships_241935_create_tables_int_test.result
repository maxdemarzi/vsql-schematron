CREATE TABLE `int_test_coin_basic_data` (
`id` INT,
`name` VARCHAR(64),
`symbol` VARCHAR(64),
`slug` VARCHAR(64),
`image_url` VARCHAR(64),
`circulating_supply` INT,
`total_supply` INT,
`max_supply` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `int_test_coin_quote` (
`id` INT,
`coin_id` INT,
`quote` DECIMAL(10,2),
`quoted_at` DATETIME,
`volume_24h` DECIMAL(10,2),
`market_cap` DECIMAL(10,2),
`percent_change_1h` DECIMAL(10,2),
`percent_change_24h` DECIMAL(10,2),
`percent_change_7d` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
