CREATE DATABASE `db_265827_DB`;
USE `db_265827_DB`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`first-name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `block` (
`id` INT NOT NULL,
`block_code` INT,
`nonce` INT,
`hash_code` VARCHAR(50),
`previous_hash_code` VARCHAR(50),
`timestamp` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pages` (
`id` INT NOT NULL,
`pages_code` VARCHAR(50),
`hash_code` VARCHAR(50),
`previous_hash_code` VARCHAR(50),
`block_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chaine` (
`block_id` INT,
`user_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_265827_DB') AS relationships;
