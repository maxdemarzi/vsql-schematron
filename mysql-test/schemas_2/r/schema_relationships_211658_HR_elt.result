INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 211658_HR_elt
#
CREATE DATABASE `db_211658_HR_elt`;
USE `db_211658_HR_elt`;
CREATE TABLE `REGIONS` (
`REGION_ID` VARCHAR(50) NOT NULL,
`REGION_NAME` VARCHAR(50),
PRIMARY KEY (`REGION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `COUNTRIES` (
`COUNTRY_ID` VARCHAR(50) NOT NULL,
`COUNTRY_NAME` VARCHAR(50),
`REGION_ID` VARCHAR(50),
PRIMARY KEY (`COUNTRY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOCATIONS` (
`LOCATION_ID` VARCHAR(50) NOT NULL,
`STREET_ADDRESS` VARCHAR(50),
`POSTAL_CODE` VARCHAR(50),
`CITY` VARCHAR(50),
`STATE_PROVINCE` VARCHAR(50),
`COUNTRY_ID` VARCHAR(50),
PRIMARY KEY (`LOCATION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEPARTMENTS` (
`DEPARTMENT_ID` VARCHAR(50) NOT NULL,
`DEPARTMENT_NAME` VARCHAR(50),
`LOCATION_ID` VARCHAR(50),
PRIMARY KEY (`DEPARTMENT_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_211658_HR_elt') AS relationships;
relationships
Database: db_211658_HR_elt

Table Connections:
