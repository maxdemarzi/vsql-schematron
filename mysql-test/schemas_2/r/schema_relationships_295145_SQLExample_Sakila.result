INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 295145_SQLExample_Sakila
#
CREATE DATABASE `db_295145_SQLExample_Sakila`;
USE `db_295145_SQLExample_Sakila`;
CREATE TABLE `Actor` (
`actor_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;
CREATE TABLE `Language` (
`language_id` VARCHAR(64),
`name` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`language_id`)
) CHARACTER SET latin1;
CREATE TABLE `Film` (
`film_id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`release_year` DATETIME,
`language_id` VARCHAR(64),
`original_language_id` VARCHAR(64),
`rental_duration` VARCHAR(64),
`rental_rate` DECIMAL(10,2),
`length` INT,
`replacement_cost` DECIMAL(10,2),
`rating` VARCHAR(64),
`special_features` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;
CREATE TABLE `Film_actor` (
`actor_id` INT,
`film_id` INT,
`last_update` DATETIME,
PRIMARY KEY (`actor_id`, `film_id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`category_id` VARCHAR(64),
`name` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `Film_category` (
`film_id` INT,
`category_id` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`film_id`, `category_id`)
) CHARACTER SET latin1;
CREATE TABLE `Film_text` (
`film_id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;
CREATE TABLE `Inventory` (
`inventory_id` INT,
`film_id` INT,
`store_id` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`inventory_id`)
) CHARACTER SET latin1;
CREATE TABLE `Staff` (
`staff_id` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`address_id` INT,
`picture` VARCHAR(64),
`email` VARCHAR(64),
`store_id` VARCHAR(64),
`active` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`staff_id`)
) CHARACTER SET latin1;
CREATE TABLE `Customer` (
`customer_id` INT,
`store_id` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`address_id` INT,
`active` VARCHAR(64),
`create_date` DATETIME,
`last_update` DATETIME,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `Payment` (
`payment_id` INT,
`customer_id` INT,
`staff_id` VARCHAR(64),
`rental_id` INT,
`amount` DECIMAL(10,2),
`payment_date` DATETIME,
`last_update` DATETIME,
PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
`address_id` INT,
`address` VARCHAR(64),
`address2` VARCHAR(64),
`district` VARCHAR(64),
`city_id` INT,
`postal_code` VARCHAR(64),
`phone` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `City` (
`city_id` INT,
`city` VARCHAR(64),
`country_id` INT,
`last_update` DATETIME,
PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `Country` (
`country_id` INT,
`country` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_295145_SQLExample_Sakila') AS relationships;
relationships
