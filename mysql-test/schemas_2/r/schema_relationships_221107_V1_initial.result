INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 221107_V1__initial
#
CREATE DATABASE `db_221107_V1_initial`;
USE `db_221107_V1_initial`;
CREATE TABLE `guild` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`logo` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`uuid` VARCHAR(64),
`name` VARCHAR(64),
`team_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`is_banned` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feed_item` (
`id` INT,
`uuid` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` INT,
`image` VARCHAR(64),
`text` VARCHAR(64),
`type` VARCHAR(64),
`action_id` INT,
`is_banned` BOOL,
`is_sticky` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action_type` (
`id` INT,
`code` VARCHAR(64),
`name` VARCHAR(64),
`value` INT,
`cooldown` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`is_user_action` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
`id` INT,
`user_id` INT,
`action_type_id` INT,
`image_path` VARCHAR(64),
`text` VARCHAR(64),
`aggregated` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
`is_banned` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT,
`user_id` INT,
`feed_item_id` INT,
`text` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_221107_V1_initial') AS relationships;
relationships
Database: db_221107_V1_initial

