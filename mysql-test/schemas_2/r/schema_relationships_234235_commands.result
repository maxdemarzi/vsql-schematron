INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 234235_commands
#
CREATE DATABASE `db_234235_commands`;
USE `db_234235_commands`;
CREATE TABLE `staff` (
`emp_id` INT,
`current_version` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`last_updated` DATETIME,
`updated_by` VARCHAR(64),
PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
CREATE TABLE `staff_data` (
`record_id` INT,
`emp_id` INT,
`VERSION` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`birth_date` DATETIME,
`salary` DECIMAL(10,2),
`address` VARCHAR(64),
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `cohort` (
`student_id` INT,
`current_version` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`last_updated` DATETIME,
`updated_by` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `cohort_data` (
`record_id` INT,
`student_id` INT,
`VERSION` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`birth_date` DATETIME,
`city_id` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`course_id` VARCHAR(64),
`current_version` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`last_updated` DATETIME,
`updated_by` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses_data` (
`record_id` INT,
`course_id` VARCHAR(64),
`department_id` VARCHAR(64),
`VERSION` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `worker` (
`worker_id` INT,
`current_version` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`last_updated` DATETIME,
`updated_by` VARCHAR(64),
PRIMARY KEY (`worker_id`)
) CHARACTER SET latin1;
CREATE TABLE `worker_data` (
`record_id` INT,
`worker_id` INT,
`VERSION` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`birth_date` DATETIME,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `faculty` (
`instructor_id` INT,
`current_version` INT,
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`last_updated` DATETIME,
`updated_by` VARCHAR(64),
PRIMARY KEY (`instructor_id`)
) CHARACTER SET latin1;
CREATE TABLE `faculty_data` (
`record_id` INT,
`instructor_id` INT,
`department_id` VARCHAR(64),
`VERSION` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`POSITION` VARCHAR(64),
`address` VARCHAR(64),
`is_deleted` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_234235_commands') AS relationships;
