[Implied]  BD_D_CONFIGURACION.idconfiguraciontipo -> BD_D_CONFIGURACIONTIPO.idconfiguraciontipo
[Implied]  BD_D_REPO.idbusqueda -> BD_D_BUSQUEDA.idbusqueda

DROP DATABASE `db_200273_init`;
UNINSTALL EXTENSION vsql_schematron;
