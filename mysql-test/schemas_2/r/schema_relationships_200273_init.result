INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 200273_init
#
CREATE DATABASE `db_200273_init`;
USE `db_200273_init`;
CREATE TABLE `BD_D_BUSQUEDA` (
`idbusqueda` INT NOT NULL,
`lenguaje` VARCHAR(50),
`stars` VARCHAR(50),
`forks` VARCHAR(50),
`created` VARCHAR(50),
`pushed` VARCHAR(50),
`archived` INT,
`public` INT,
`research` VARCHAR(50),
`contadores` BLOB,
`tstbd` VARCHAR(50),
PRIMARY KEY (`idbusqueda`)
) CHARACTER SET latin1;
CREATE TABLE `BD_D_REPO` (
`idrepo` INT NOT NULL,
`nombre` VARCHAR(50),
`organizacion` VARCHAR(50),
`lenguaje` VARCHAR(50),
`url` VARCHAR(50),
`commitid` VARCHAR(50),
`size` INT,
`boe2e` INT,
`idbusqueda` INT,
`tstbd` VARCHAR(50),
PRIMARY KEY (`idrepo`)
) CHARACTER SET latin1;
CREATE TABLE `BD_D_CONFIGURACIONTIPO` (
`idconfiguraciontipo` INT NOT NULL,
`codigo` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`idconfiguraciontipo`)
) CHARACTER SET latin1;
CREATE TABLE `BD_D_CONFIGURACION` (
`idconfiguracion` INT NOT NULL,
`campo` VARCHAR(50),
`valor` VARCHAR(50),
`descripcion` VARCHAR(50),
`idconfiguraciontipo` INT,
PRIMARY KEY (`idconfiguracion`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_200273_init') AS relationships;
relationships
Database: db_200273_init

Table Connections:
