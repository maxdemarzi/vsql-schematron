INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 232108_schema
#
CREATE DATABASE `db_232108_schema`;
USE `db_232108_schema`;
CREATE TABLE `symbolids` (
`id` INT,
`symbol` VARCHAR(64),
`exchange` VARCHAR(64),
`name` VARCHAR(64),
`industry` VARCHAR(64),
`subindustry` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candlestick` (
`id` INT,
`starttime` DATETIME,
`endtime` DATETIME,
`open` DECIMAL(10,2),
`close` DECIMAL(10,2),
`high` DECIMAL(10,2),
`low` DECIMAL(10,2),
`volume` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_232108_schema') AS relationships;
relationships
Database: db_232108_schema

Table Connections:
