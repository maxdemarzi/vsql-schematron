`payment_type` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `paypal_payments` (
`id` INT,
`fee` DECIMAL(10,2),
`token` VARCHAR(64),
`transaction_id` VARCHAR(64)
) CHARACTER SET latin1;
