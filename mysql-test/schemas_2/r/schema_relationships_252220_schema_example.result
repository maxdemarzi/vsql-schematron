INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 252220_schema.example
#
CREATE DATABASE `db_252220_schema_example`;
USE `db_252220_schema_example`;
CREATE TABLE `sess` (
`session_id` INT NOT NULL,
`session_name` VARCHAR(50),
PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
`id` INT NOT NULL,
`session_id` INT,
`product_id` INT,
`active` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
`id` INT NOT NULL,
`productId` INT,
`name` VARCHAR(50),
`photos` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT NOT NULL,
`styleId` INT,
`photoObj` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_252220_schema_example') AS relationships;
relationships
Database: db_252220_schema_example

Table Connections:
------------------
[Implied]  cart.session_id -> sess.session_id
[Implied]  photos.styleId -> styles.id

DROP DATABASE `db_252220_schema_example`;
UNINSTALL EXTENSION vsql_schematron;
