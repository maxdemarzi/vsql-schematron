INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 293524_novel_re
#
CREATE DATABASE `db_293524_novel_re`;
USE `db_293524_novel_re`;
CREATE TABLE `bookmarks` (
`bookmark_id` INT,
`user_id` INT,
`novel_id` INT,
`type` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`comment_id` INT,
`user_id` INT,
`novel_id` INT,
`content` VARCHAR(255),
`state` INT,
`delete_marker` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`genre_id` INT,
`genre` VARCHAR(255),
PRIMARY KEY (`genre_id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`image_id` INT,
`foreign_id` INT,
`usage` VARCHAR(255),
`path_to_image` VARCHAR(255),
`name` VARCHAR(255),
`type` VARCHAR(255),
`size` INT,
`extension` VARCHAR(255),
`affiliation` VARCHAR(255),
`created_at` DATETIME,
`update_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `novels` (
`novel_id` INT,
`user_id` INT,
`title` VARCHAR(255),
`original_title` VARCHAR(255),
`alternative_title` VARCHAR(255),
`year_release` INT,
`description` VARCHAR(255),
`developer` VARCHAR(255),
`type` VARCHAR(255),
`duration` VARCHAR(255),
`platforms` VARCHAR(255),
`age_rating` VARCHAR(255),
`country` VARCHAR(255),
`language` VARCHAR(255),
`views` INT,
`state` INT,
`delete_marker` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`novel_id`)
) CHARACTER SET latin1;
CREATE TABLE `novels-genres` (
`relation_id` INT,
`novel_id` INT,
`genre_id` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`username` VARCHAR(255),
`email` VARCHAR(255),
`login` VARCHAR(255),
`password` VARCHAR(255),
`remember_token` VARCHAR(255),
`role` VARCHAR(255),
`online` INT,
`state` INT,
`delete_marker` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_293524_novel_re') AS relationships;
relationships
Database: db_293524_novel_re

Table Connections:
