[Implied]  novels.user_id -> users.user_id
[Implied]  novels-genres.genre_id -> genres.genre_id
[Implied]  novels-genres.novel_id -> novels.novel_id

DROP DATABASE `db_293524_novel_re`;
UNINSTALL EXTENSION vsql_schematron;
