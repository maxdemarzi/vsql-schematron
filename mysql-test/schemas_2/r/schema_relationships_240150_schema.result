INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 240150_schema
#
CREATE DATABASE `db_240150_schema`;
USE `db_240150_schema`;
CREATE TABLE `public.animals` (
`id` INT,
`name` VARCHAR(64),
`date_of_birth` DATETIME,
`escape_attempts` INT,
`neutered` VARCHAR(64),
`weight_kg` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.owners` (
`id` INT,
`full_name` VARCHAR(64),
`age` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.vets` (
`id` INT,
`name` VARCHAR(64),
`age` INT,
`date_of_graduation` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.specializations` (
`vet_id` INT,
`species_id` INT,
PRIMARY KEY (`vet_id`, `species_id`)
) CHARACTER SET latin1;
CREATE TABLE `public.visits` (
`date` DATETIME,
`vet_id` INT,
`animal_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_240150_schema') AS relationships;
relationships
