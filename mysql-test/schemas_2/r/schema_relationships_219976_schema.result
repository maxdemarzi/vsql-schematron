CREATE DATABASE `db_219976_schema`;
USE `db_219976_schema`;
CREATE TABLE `departments` (
`id` VARCHAR(50) NOT NULL,
`dpt_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` VARCHAR(50),
`mgr_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_219976_schema') AS relationships;
