INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 217658_collection
#
CREATE DATABASE `db_217658_collection`;
USE `db_217658_collection`;
CREATE TABLE `PUBLISHER` (
`PUBLISHER_NAME` VARCHAR(64),
`ADDRESS` VARCHAR(64),
`PHONE` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ONLINE_USER` (
`USER_NAME` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`EMAIL_ADDRESS` VARCHAR(64),
`FNAME` VARCHAR(64),
`LNAME` VARCHAR(64),
`PHONE_NO` VARCHAR(64),
`SHIPPING_ADDRESS` VARCHAR(64),
`MANAGER` BOOL,
PRIMARY KEY (`USER_NAME`, `EMAIL_ADDRESS`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR` (
`AUTHOR_NAME` VARCHAR(64),
`AUTHOR_ID` VARCHAR(64),
PRIMARY KEY (`AUTHOR_NAME`, `AUTHOR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`ISBN` VARCHAR(64),
`AUTHOR` VARCHAR(64),
`TITLE` VARCHAR(64),
`PUBLISHER_NAME` VARCHAR(64),
`PUBLICATION_YEAR` VARCHAR(64),
`CATEGORY` VARCHAR(64),
`SELLING_PRICE` DECIMAL(10,2),
`THRESHOLD` INT,
`COPIES` INT,
PRIMARY KEY (`ISBN`, `TITLE`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK_ORDER` (
`ISBN` VARCHAR(64),
`TITLE` VARCHAR(64),
`DATE_ORDERED` DATETIME,
`USER_NAME` VARCHAR(64),
`COPIES` INT
) CHARACTER SET latin1;
CREATE TABLE `SALES` (
`ISBN` VARCHAR(64),
`TITLE` VARCHAR(64),
`DATE_ORDERED` DATETIME,
`USER_NAME` VARCHAR(64),
`COPIES` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_217658_collection') AS relationships;
relationships
Database: db_217658_collection

Table Connections:
