[Implied]  BOOK.PUBLISHER_NAME -> PUBLISHER.PUBLISHER_NAME
[Implied]  BOOK_ORDER.ISBN -> BOOK.ISBN
[Implied]  BOOK_ORDER.TITLE -> BOOK.TITLE
[Implied]  BOOK_ORDER.USER_NAME -> ONLINE_USER.USER_NAME
[Implied]  SALES.ISBN -> BOOK.ISBN
[Implied]  SALES.TITLE -> BOOK.TITLE
[Implied]  SALES.USER_NAME -> ONLINE_USER.USER_NAME

DROP DATABASE `db_217658_collection`;
UNINSTALL EXTENSION vsql_schematron;
