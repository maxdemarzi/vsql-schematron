CREATE TABLE `Product` (
`manufacturer` VARCHAR(64),
`model` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`model`)
) CHARACTER SET latin1;
CREATE TABLE `PC` (
`model` VARCHAR(64),
`speed` INT,
`ram` INT,
`hd` INT,
`rd` VARCHAR(64),
`price` INT,
PRIMARY KEY (`model`)
) CHARACTER SET latin1;
CREATE TABLE `Laptop` (
`model` VARCHAR(64),
`speed` INT,
`ram` INT,
`hd` INT,
`screen` DECIMAL(10,2),
`price` INT,
PRIMARY KEY (`model`)
) CHARACTER SET latin1;
