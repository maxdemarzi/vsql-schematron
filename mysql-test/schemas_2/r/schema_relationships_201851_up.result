INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 201851_up
#
CREATE DATABASE `db_201851_up`;
USE `db_201851_up`;
CREATE TABLE `domains` (
`id` INT NOT NULL,
`rank` INT,
`title` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `components` (
`id` INT NOT NULL,
`domain_id` INT,
`rank` INT,
`title` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `competencies` (
`id` INT NOT NULL,
`component_id` INT,
`rank` INT,
`title` TEXT,
`c1` TEXT,
`c2` TEXT,
`c3` TEXT,
`c4` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_201851_up') AS relationships;
relationships
