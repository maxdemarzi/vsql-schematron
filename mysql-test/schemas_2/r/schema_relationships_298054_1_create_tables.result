CREATE DATABASE `db_298054_1_create_tables`;
USE `db_298054_1_create_tables`;
CREATE TABLE `educational_degree` (
`id` INT,
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `educational_field` (
`id` INT,
`value` VARCHAR(64),
