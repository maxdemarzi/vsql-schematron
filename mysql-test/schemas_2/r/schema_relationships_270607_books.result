INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 270607_books
#
CREATE DATABASE `db_270607_books`;
USE `db_270607_books`;
CREATE TABLE `作家` (
`id` INT,
`name` VARCHAR(64),
`sex` VARCHAR(64),
`remark` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `出版社` (
`id` INT,
`pname` VARCHAR(64),
`address` VARCHAR(64),
`tel` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `图书` (
`id` INT,
`bname` VARCHAR(64),
`price` DECIMAL(10,2),
`aid` INT,
`pid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `author_press` (
`id` INT,
`签约时间` DATETIME,
`a_id` INT,
`p_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_270607_books') AS relationships;
