INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 204649_schema
#
CREATE DATABASE `db_204649_schema`;
USE `db_204649_schema`;
CREATE TABLE `cache` (
`cache_id` VARCHAR(255),
`cache_time` INT,
`cache_queries` INT,
`cache_process_time` DECIMAL(10,2),
`cache_possible_miss` INT,
PRIMARY KEY (`cache_id`)
) CHARACTER SET latin1;
CREATE TABLE `cache_data` (
`cdata_id` VARCHAR(255),
`cdata_cache_id` VARCHAR(255),
`cdata_url` VARCHAR(255),
`cdata_confidence` DECIMAL(10,2),
`cdata_skipped` INT,
`cdata_excluded` INT,
PRIMARY KEY (`cdata_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_204649_schema') AS relationships;
