INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 230662_createDatabase
#
CREATE DATABASE `db_230662_createDatabase`;
USE `db_230662_createDatabase`;
CREATE TABLE `AUTHOR` (
`ID` BIGINT NOT NULL,
`FIRSTNAME` VARCHAR(50),
`LASTNAME` VARCHAR(50),
`VITA` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`ID` BIGINT NOT NULL,
`DESCRIPTION` VARCHAR(50),
`ISBN` VARCHAR(50),
`TITLE` VARCHAR(50),
`PUBLISHER_ID` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER` (
`ID` BIGINT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR_BOOK` (
`AUTHOR_ID` BIGINT NOT NULL,
`BOOK_ID` BIGINT NOT NULL,
PRIMARY KEY (`AUTHOR_ID`, `BOOK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SEQUENCE` (
`SEQ_NAME` VARCHAR(50) NOT NULL,
`SEQ_COUNT` DECIMAL(10,2),
PRIMARY KEY (`SEQ_NAME`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230662_createDatabase') AS relationships;
relationships
Database: db_230662_createDatabase

