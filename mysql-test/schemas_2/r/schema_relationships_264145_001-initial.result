`key` VARCHAR(50) NOT NULL,
`title` TEXT,
`description` TEXT,
`link` TEXT,
`last_build_date` TEXT,
`copyright` TEXT,
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `episode` (
`id` INT NOT NULL,
`feed_key` TEXT,
`title` TEXT,
`description` TEXT,
`link` TEXT,
`pubdate` TEXT,
`copyright` TEXT,
`enclosure` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
