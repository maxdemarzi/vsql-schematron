INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 219767_init_tables
#
CREATE DATABASE `db_219767_init_tables`;
USE `db_219767_init_tables`;
CREATE TABLE `Customers` (
`id` INT,
`name` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`username` VARCHAR(64),
`address_line_1` VARCHAR(64),
`address_line_2` VARCHAR(64),
`city` VARCHAR(64),
`country` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`order_id` VARCHAR(64),
`customer_id` INT,
`order_date` DATETIME,
`status` VARCHAR(64),
`total_price` DECIMAL(10,2),
`comment` VARCHAR(64),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `RewardCard` (
`customer_id` INT,
`money_earned` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `OrderItems` (
`item_id` INT,
`order_id` VARCHAR(64),
`beer_id` INT,
`quantity` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `Passwords` (
`customer_id` INT,
`password` VARCHAR(64),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_219767_init_tables') AS relationships;
relationships
Database: db_219767_init_tables

Table Connections:
------------------
[Implied]  OrderItems.order_id -> Orders.order_id
[Implied]  Orders.customer_id -> Customers.id
[Implied]  Passwords.customer_id -> Customers.id
[Implied]  RewardCard.customer_id -> Customers.id

DROP DATABASE `db_219767_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
