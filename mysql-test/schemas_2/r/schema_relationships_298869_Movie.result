INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 298869_Movie
#
CREATE DATABASE `db_298869_Movie`;
USE `db_298869_Movie`;
CREATE TABLE `ACTOR` (
`ACT_ID` INT,
`ACT_NAME` VARCHAR(64),
`ACT_GENDER` VARCHAR(64),
PRIMARY KEY (`ACT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DIRECTOR` (
`DIR_ID` INT,
`DIR_NAME` VARCHAR(64),
`DIR_PHONE` INT,
PRIMARY KEY (`DIR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIES` (
`MOV_ID` INT,
`MOV_TITLE` VARCHAR(64),
`MOV_YEAR` INT,
`MOV_LANG` VARCHAR(64),
`DIR_ID` INT,
PRIMARY KEY (`MOV_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIE_CAST` (
`ACT_ID` INT,
`MOV_ID` INT,
`ROLE` VARCHAR(64),
PRIMARY KEY (`ACT_ID`, `MOV_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RATING` (
`MOV_ID` INT,
`REV_STARS` VARCHAR(64),
PRIMARY KEY (`MOV_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_298869_Movie') AS relationships;
relationships
Database: db_298869_Movie

Table Connections:
------------------
[Implied]  MOVIES.DIR_ID -> DIRECTOR.DIR_ID
[Implied]  MOVIE_CAST.ACT_ID -> ACTOR.ACT_ID
[Implied]  MOVIE_CAST.MOV_ID -> MOVIES.MOV_ID
[Implied]  MOVIE_CAST.MOV_ID -> RATING.MOV_ID

DROP DATABASE `db_298869_Movie`;
UNINSTALL EXTENSION vsql_schematron;
