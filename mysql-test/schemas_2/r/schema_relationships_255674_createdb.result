CREATE DATABASE `db_255674_createdb`;
USE `db_255674_createdb`;
CREATE TABLE `specialization` (
`code` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`specode` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test` (
`id` INT NOT NULL,
`theme` VARCHAR(50),
`courseid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
`id` INT NOT NULL,
`qtext` TEXT,
`testid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
`id` INT NOT NULL,
`atext` TEXT,
`correct` TINYINT,
`questid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_255674_createdb') AS relationships;
