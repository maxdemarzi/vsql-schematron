`quantidade_produto` INT,
`preco_produto` DECIMAL(10,2),
PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
CREATE TABLE `vendas` (
`id_venda` INT,
`total_venda` DECIMAL(10,2),
`cliente_venda` INT,
PRIMARY KEY (`id_venda`)
) CHARACTER SET latin1;
