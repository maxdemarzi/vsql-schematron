CREATE TABLE `boards` (
`id` INT NOT NULL,
`key` VARCHAR(50),
`create_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
`id` INT NOT NULL,
`board_id` INT,
`title` VARCHAR(50),
`description` TEXT,
`status` INT,
`create_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `statuses` (
`id` INT NOT NULL,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
