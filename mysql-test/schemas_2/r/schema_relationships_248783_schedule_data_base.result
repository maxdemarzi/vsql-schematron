CREATE DATABASE `db_248783_schedule_data_base`;
USE `db_248783_schedule_data_base`;
CREATE TABLE `admin_data` (
`value` INT,
`user_id` INT,
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `exercise` (
`value` INT,
`exercise_id` INT,
`training_id` INT,
`approach` INT,
`repetition` INT,
`weigth` INT,
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `exercise_data` (
`value` INT,
`name` VARCHAR(64),
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`value` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birthday` DATETIME,
`sex_id` INT,
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `sex` (
`value` INT,
`sex` VARCHAR(64),
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `state` (
`value` INT,
`state` VARCHAR(64),
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `training` (
`value` INT,
`user_id` INT,
`create_date` DATETIME,
`training_date` DATETIME,
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
CREATE TABLE `user_data` (
`value` INT,
`person_id` INT,
`user_login` VARCHAR(64),
`user_password` VARCHAR(64),
`state_id` INT,
`date_reg` DATETIME,
PRIMARY KEY (`value`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_248783_schedule_data_base') AS relationships;
