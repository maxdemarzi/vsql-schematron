CREATE DATABASE `db_241772_data`;
USE `db_241772_data`;
CREATE TABLE `USER` (
`ID` INT,
`USER_EMAIL` VARCHAR(64),
`USER_NAME` VARCHAR(64),
`HASHED_PASSWORD` VARCHAR(64),
`SALT` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SLOT` (
`SLOT_OWNER_ID` INT,
`SLOT_START` DATETIME,
`SLOT_BOOKED_BY` INT,
PRIMARY KEY (`SLOT_OWNER_ID`, `SLOT_START`)
) CHARACTER SET latin1;
