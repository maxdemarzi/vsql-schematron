CREATE DATABASE `db_277409_1499261826`;
USE `db_277409_1499261826`;
CREATE TABLE `organization` (
`id` INT,
`organization_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organization_email_domain` (
`organization_id` INT,
`domain` VARCHAR(64),
PRIMARY KEY (`organization_id`, `domain`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
`id` INT,
`replay_name` VARCHAR(64),
`map_width` INT,
`map_height` INT,
`map_seed` VARCHAR(64),
`map_generator` VARCHAR(64),
`time_played` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_participant` (
`game_id` INT,
`user_id` INT,
`bot_id` INT,
`version_number` INT,
`log_name` VARCHAR(64),
`rank` INT,
`player_index` INT,
`timed_out` VARCHAR(64),
PRIMARY KEY (`game_id`, `user_id`, `bot_id`)
) CHARACTER SET latin1;
CREATE TABLE `bot_history` (
`user_id` INT,
`bot_id` INT,
`version_number` INT,
`last_rank` INT,
`last_score` INT,
`last_num_players` INT,
`last_games_played` INT,
`language` VARCHAR(64),
`when_retired` DATETIME,
PRIMARY KEY (`user_id`, `bot_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_277409_1499261826') AS relationships;
