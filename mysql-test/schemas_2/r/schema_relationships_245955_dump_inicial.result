CREATE DATABASE `db_245955_dump_inicial`;
USE `db_245955_dump_inicial`;
CREATE TABLE `photo` (
`id` INT NOT NULL,
`photo_name` VARCHAR(50),
`photo_length` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contato` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`birthday` DATE,
`photo_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
`id` INT NOT NULL,
`contato_id` INT,
`number` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_245955_dump_inicial') AS relationships;
