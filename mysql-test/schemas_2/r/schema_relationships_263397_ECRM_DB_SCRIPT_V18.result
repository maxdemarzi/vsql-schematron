CREATE TABLE `tblmessage` (
`Id` INT,
`Body` VARCHAR(64),
`IsRead` VARCHAR(64),
`Phone` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `tblreportdetail` (
`EquipmentId` INT,
`ReportId` INT,
`DamagedLevel` VARCHAR(64),
`Position` VARCHAR(64),
`Description` VARCHAR(64),
`Solution` VARCHAR(64),
`ResolveTime` DATETIME,
`Status` INT,
PRIMARY KEY (`EquipmentId`, `ReportId`)
) CHARACTER SET latin1;
CREATE TABLE `tbluser` (
`Username` VARCHAR(64),
`RoleId` INT,
`Password` VARCHAR(64),
`Status` INT,
PRIMARY KEY (`Username`)
) CHARACTER SET latin1;
CREATE TABLE `tbluserinfo` (
`Username` VARCHAR(64),
`FullName` VARCHAR(64),
`Phone` VARCHAR(64),
`LastLogin` DATETIME,
`DeviceId` VARCHAR(64),
`DownloadTime` INT,
PRIMARY KEY (`Username`)
) CHARACTER SET latin1;
