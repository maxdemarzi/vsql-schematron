CREATE DATABASE `db_264177_V1__tabelas`;
USE `db_264177_V1__tabelas`;
CREATE TABLE `empresa` (
`id` BIGINT NOT NULL,
`cnpj` VARCHAR(50),
`data_atualizacao` DATETIME,
`data_criacao` DATETIME,
`razao_social` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
`id` BIGINT,
`cpf` VARCHAR(50),
`data_atualizacao` DATETIME,
`data_criacao` DATETIME,
`email` VARCHAR(50),
`nome` VARCHAR(50),
`perfil` VARCHAR(50),
`qtd_horas_almoco` DOUBLE,
`qtd_horas_trabalho_dia` DOUBLE,
`senha` VARCHAR(50),
`valor_hora` DECIMAL(10,2),
`empresa_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `lancamento` (
`id` BIGINT,
`data` DATETIME,
`data_atualizacao` DATETIME,
`data_criacao` DATETIME,
`descricao` VARCHAR(50),
`localizacao` VARCHAR(50),
`tipo` VARCHAR(50),
`funcionario_id` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_264177_V1__tabelas') AS relationships;
