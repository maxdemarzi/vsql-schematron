[Implied]  image.newsId -> news.newsId
[Implied]  news.userId -> user.userId
[Implied]  payment_method.userId -> user.userId
[Implied]  purchased_article.newsId -> news.newsId
[Implied]  purchased_article.userId -> user.userId

DROP DATABASE `db_280332_taketec_pdo_version_1`;
