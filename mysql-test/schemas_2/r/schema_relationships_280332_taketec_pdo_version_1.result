INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 280332_taketec_pdo_version_1
#
CREATE DATABASE `db_280332_taketec_pdo_version_1`;
USE `db_280332_taketec_pdo_version_1`;
CREATE TABLE `category` (
`catId` INT,
`description` VARCHAR(64),
PRIMARY KEY (`catId`)
) CHARACTER SET latin1;
CREATE TABLE `category_has_news` (
`catId` INT,
`newsId` INT
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`commentId` INT,
`content` VARCHAR(64),
`newsId` INT,
`userId` INT
) CHARACTER SET latin1;
CREATE TABLE `image` (
`imageId` INT,
`imagePath` VARCHAR(64),
`copyright` VARCHAR(64),
`newsId` INT
) CHARACTER SET latin1;
CREATE TABLE `news` (
`newsId` INT,
`creation` DATETIME,
`updated` DATETIME,
`userId` INT,
`content` VARCHAR(64),
`copyright` VARCHAR(64),
`paidNew` INT,
`price` DECIMAL(10,2),
`newsTitle` VARCHAR(64),
`newsShortDescription` VARCHAR(64),
`likes` INT,
PRIMARY KEY (`newsId`)
) CHARACTER SET latin1;
CREATE TABLE `payment_method` (
`paymentMethodId` INT,
`userId` INT,
`cardType` INT,
`cardNumber` VARCHAR(64),
`CVV` VARCHAR(64),
`nameOnCard` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `purchased_article` (
`newsId` INT,
`userId` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`userId` INT,
`firstName` VARCHAR(64),
`surname` VARCHAR(64),
`password` VARCHAR(64),
`gender` VARCHAR(64),
`DOB` DATETIME,
`country` VARCHAR(64),
`phone` VARCHAR(64),
`eMail` VARCHAR(64),
`permission` INT,
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_280332_taketec_pdo_version_1') AS relationships;
relationships
Database: db_280332_taketec_pdo_version_1

Table Connections:
