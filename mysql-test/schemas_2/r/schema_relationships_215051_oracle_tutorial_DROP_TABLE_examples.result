PRIMARY KEY (`brand_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`car_id` DECIMAL(10,2) NOT NULL,
`make` VARCHAR(50),
`model` VARCHAR(50),
`year` DECIMAL(10,2),
`plate_number` VARCHAR(50),
`brand_id` DECIMAL(10,2),
PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;
