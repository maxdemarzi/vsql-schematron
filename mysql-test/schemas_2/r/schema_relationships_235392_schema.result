INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 235392_schema
#
CREATE DATABASE `db_235392_schema`;
USE `db_235392_schema`;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`emp_no` INT,
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`gender` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `salarys` (
`emp_no` INT,
`salary` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_235392_schema') AS relationships;
relationships
Database: db_235392_schema

Table Connections:
------------------
[Implied]  dept_manager.dept_no -> departments.dept_no
[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  salarys.emp_no -> employees.emp_no

DROP DATABASE `db_235392_schema`;
UNINSTALL EXTENSION vsql_schematron;
