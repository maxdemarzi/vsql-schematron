[Implied]  Employee.Dep_ID -> Department.Dep_ID
[Implied]  Employee.Mine_ID -> Mine.Mine_ID
[Implied]  Employee.Shift_ID -> Shift.Shift_ID
[Implied]  Export.Dest_ID -> Destination.Dest_ID
[Implied]  Export.Mine_ID -> Mine.Mine_ID
[Implied]  Manager.Emp_ID -> Employee.Emp_ID
[Implied]  Qualification.Emp_ID -> Employee.Emp_ID
[Implied]  Qualification.Qual_ID -> Qualification_Detail.Qual_ID
[Implied]  Salary_History.Emp_ID -> Employee.Emp_ID

DROP DATABASE `db_264351_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
