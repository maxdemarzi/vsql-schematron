INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 278091_V1__init_tables
#
CREATE DATABASE `db_278091_V1_init_tables`;
USE `db_278091_V1_init_tables`;
CREATE TABLE `schema_type` (
`schema_type_name` VARCHAR(64),
PRIMARY KEY (`schema_type_name`)
) CHARACTER SET latin1;
CREATE TABLE `compatibility_type` (
`compatibility_type_name` VARCHAR(64),
PRIMARY KEY (`compatibility_type_name`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
`subject_name` VARCHAR(64),
`compatibility_type_name` VARCHAR(64),
`is_locked` VARCHAR(64),
`creation_ts` DATETIME,
PRIMARY KEY (`subject_name`)
) CHARACTER SET latin1;
CREATE TABLE `schema_info` (
`schema_id` INT,
`schema_type_name` VARCHAR(64),
`schema_text` VARCHAR(64),
`schema_hash` VARCHAR(64),
`creation_ts` DATETIME,
PRIMARY KEY (`schema_id`)
) CHARACTER SET latin1;
CREATE TABLE `subject_schema` (
`subject_name` VARCHAR(64),
`schema_id` INT,
`version` INT,
`creation_ts` DATETIME,
PRIMARY KEY (`subject_name`, `schema_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_278091_V1_init_tables') AS relationships;
relationships
Database: db_278091_V1_init_tables

Table Connections:
