INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 269292_init_tourist
#
CREATE DATABASE `db_269292_init_tourist`;
USE `db_269292_init_tourist`;
CREATE TABLE `sight` (
`id` INT,
`sight_name` VARCHAR(255),
`sight_descr` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tourtype` (
`id` INT,
`tour_type_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedule` (
`id` INT,
`tour_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instructor` (
`id` INT,
`surname` VARCHAR(255),
`forename` VARCHAR(255),
`patronymic` VARCHAR(255),
`id_schedule` INT,
`id_tour_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tour` (
`id` INT,
`tour_name` VARCHAR(255),
`tour_descr` VARCHAR(255),
`id_sight` INT,
`id_schedule` INT,
`id_tour_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_269292_init_tourist') AS relationships;
relationships
Database: db_269292_init_tourist

Table Connections:
------------------
[Implied]  instructor.id_schedule -> schedule.id
[Implied]  instructor.id_tour_type -> tourtype.id
[Implied]  tour.id_schedule -> schedule.id
[Implied]  tour.id_sight -> sight.id
[Implied]  tour.id_tour_type -> tourtype.id

DROP DATABASE `db_269292_init_tourist`;
UNINSTALL EXTENSION vsql_schematron;
