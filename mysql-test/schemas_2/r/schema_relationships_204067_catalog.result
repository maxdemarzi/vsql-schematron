[Implied]  procs.archive_id -> archive.id
[Implied]  retention_rules.id -> retention.id
[Implied]  stream.archive_id -> archive.id

DROP DATABASE `db_204067_catalog`;
UNINSTALL EXTENSION vsql_schematron;
