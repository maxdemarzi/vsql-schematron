CREATE DATABASE `db_273346_V1_CreateTables`;
USE `db_273346_V1_CreateTables`;
CREATE TABLE `games` (
`id` INT,
`name` VARCHAR(64),
`image` VARCHAR(64),
`genre` VARCHAR(64),
`rating` INT,
`price` INT,
`operating_system` VARCHAR(64),
`summary` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
`user_1_id` INT,
`user_2_id` INT
) CHARACTER SET latin1;
CREATE TABLE `library` (
`game_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authority` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_authority` (
`authority_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `points` (
`user_id` INT,
`points` INT
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT,
`game_id` INT,
`user_id` INT,
`rating` INT,
`review` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stats` (
`game_id` INT,
`players_online` INT
) CHARACTER SET latin1;
CREATE TABLE `wishlist` (
`game_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart` (
`id` INT,
`game_id` INT,
`price` INT,
`quantity` INT,
`image` VARCHAR(64),
`name` VARCHAR(64)
) CHARACTER SET latin1;
