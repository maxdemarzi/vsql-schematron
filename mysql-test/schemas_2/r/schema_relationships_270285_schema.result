) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`is_done` BOOLEAN,
`list_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_270285_schema') AS relationships;
