INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 272914_schema
#
CREATE DATABASE `db_272914_schema`;
USE `db_272914_schema`;
CREATE TABLE `authors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`dob` DATE,
`sex` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_authors` (
`book_id` SMALLINT NOT NULL,
`author_id` SMALLINT NOT NULL,
PRIMARY KEY (`author_id`, `book_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_272914_schema') AS relationships;
relationships
