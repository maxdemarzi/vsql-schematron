CREATE DATABASE `db_256426_posm_paths`;
USE `db_256426_posm_paths`;
CREATE TABLE `Users` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sequences` (
`id` VARCHAR(64),
`userId` INT,
`images` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Images` (
`id` VARCHAR(64),
`path` VARCHAR(64),
`time` INT,
`seqId` INT,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_256426_posm_paths') AS relationships;
