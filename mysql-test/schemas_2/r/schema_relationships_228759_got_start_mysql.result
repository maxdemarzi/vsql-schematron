) CHARACTER SET latin1;
CREATE TABLE `printers` (
`id` INT,
`organization_id` INT,
`printer_model_id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`rent` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `toner_models` (
`id` INT,
`vendor_id` INT,
`name` VARCHAR(64),
`compatible` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `toners` (
`id` INT,
`organization_id` INT,
`toner_model_id` INT,
`number` INT,
`gift` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`upn` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`surname` VARCHAR(64),
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vendors` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
