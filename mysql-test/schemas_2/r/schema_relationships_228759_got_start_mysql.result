CREATE DATABASE `db_228759_got_start_mysql`;
USE `db_228759_got_start_mysql`;
CREATE TABLE `admins` (
`id` INT,
`user_id` INT,
`organization_id` INT,
`authlevel` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organizations` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `printer_models` (
`id` INT,
`vendor_id` INT,
`name` VARCHAR(64),
`laser` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `printer_models_toner_models` (
