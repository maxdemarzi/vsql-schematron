INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 266765_V2_10_0_Initial
#
CREATE DATABASE `db_266765_V2_10_0_Initial`;
USE `db_266765_V2_10_0_Initial`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(255),
`cpa` VARCHAR(255),
`url` VARCHAR(255),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`time_stamp` DATETIME,
`cpa_id` VARCHAR(255),
`conversation_id` VARCHAR(255),
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`ref_to_message_id` VARCHAR(255),
`time_to_live` DATETIME,
`from_party_id` VARCHAR(255),
`from_role` VARCHAR(255),
`to_party_id` VARCHAR(255),
`to_role` VARCHAR(255),
`service` VARCHAR(255),
`action` VARCHAR(255),
`content` VARCHAR(255),
`status` DECIMAL(10,2),
`status_time` DATETIME,
PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`order_nr` DECIMAL(10,2),
`name` VARCHAR(255),
`content_id` VARCHAR(255),
`content_type` VARCHAR(255),
`content` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event` (
`cpa_id` VARCHAR(255),
`channel_id` VARCHAR(255),
`message_id` VARCHAR(255),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`retries` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event_log` (
`message_id` VARCHAR(255),
`time_stamp` DATETIME,
`uri` VARCHAR(255),
`status` DECIMAL(10,2),
`error_message` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_266765_V2_10_0_Initial') AS relationships;
relationships
Database: db_266765_V2_10_0_Initial

Table Connections:
------------------
[Implied]  ebms_event.cpa_id -> cpa.cpa_id
[Implied]  ebms_message.cpa_id -> cpa.cpa_id

DROP DATABASE `db_266765_V2_10_0_Initial`;
UNINSTALL EXTENSION vsql_schematron;
