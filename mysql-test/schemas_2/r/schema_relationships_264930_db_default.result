`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
`id` INT,
`subject` VARCHAR(64),
`html_text` VARCHAR(64),
`created_date` DATETIME,
`category_id` INT,
`user_id` INT,
`approved` INT,
`comment` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question_attachment` (
`id` INT,
`location` VARCHAR(64),
`question_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question_vote` (
`id` INT,
`vote` INT,
`question_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
