INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 215298_schema
#
CREATE DATABASE `db_215298_schema`;
USE `db_215298_schema`;
CREATE TABLE `Product` (
`id` INT NOT NULL,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProductTopic` (
`id` INT NOT NULL,
`productId` INT NOT NULL,
`description` VARCHAR(50),
PRIMARY KEY (`id`, `productId`)
) CHARACTER SET latin1;
CREATE TABLE `Agent` (
`id` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`agentProfileAssignId` INT,
`locationId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AgentSlot` (
`id` INT NOT NULL,
`agentId` INT NOT NULL,
`slotFrom` DATETIME,
`slotTo` DATETIME,
`status` VARCHAR(50),
PRIMARY KEY (`id`, `agentId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_215298_schema') AS relationships;
relationships
Database: db_215298_schema

