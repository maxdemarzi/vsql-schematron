INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 258248_schema
#
CREATE DATABASE `db_258248_schema`;
USE `db_258248_schema`;
CREATE TABLE `department` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `duty` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_258248_schema') AS relationships;
relationships
