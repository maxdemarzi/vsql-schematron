`PARAMETER` VARCHAR(50),
`VALUE` VARCHAR(50),
PRIMARY KEY (`PARAMETER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_ORGANISM` (
`ORGANISM_ID` BIGINT NOT NULL,
`TASK_ID` BIGINT,
`ORGANISM` VARCHAR(50),
PRIMARY KEY (`ORGANISM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_EXCL_ORGANISM` (
