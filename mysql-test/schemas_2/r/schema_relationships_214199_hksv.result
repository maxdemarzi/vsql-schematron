[Implied]  articles.KonselorNIP -> dosen.NIP
[Implied]  chats.KonselorNIP -> dosen.NIP
[Implied]  events.KonselorNIP -> dosen.NIP
[Implied]  role.NIP -> dosen.NIP

DROP DATABASE `db_214199_hksv`;
UNINSTALL EXTENSION vsql_schematron;
