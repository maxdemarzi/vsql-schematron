INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 209208_schema
#
CREATE DATABASE `db_209208_schema`;
USE `db_209208_schema`;
CREATE TABLE `student` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `enrolment` (
`id` INT NOT NULL,
`student_id` INT,
`course_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_209208_schema') AS relationships;
relationships
Database: db_209208_schema

Table Connections:
------------------
[Implied]  enrolment.course_id -> course.id
[Implied]  enrolment.student_id -> student.id

DROP DATABASE `db_209208_schema`;
UNINSTALL EXTENSION vsql_schematron;
