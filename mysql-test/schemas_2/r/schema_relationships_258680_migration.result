CREATE TABLE `User` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`name` TEXT,
`email` TEXT,
`hashedPassword` TEXT,
`role` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`expiresAt` TIMESTAMP NULL,
`handle` TEXT,
`userId` INT,
`hashedSessionToken` TEXT,
`antiCSRFToken` TEXT,
`publicData` TEXT,
`privateData` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
