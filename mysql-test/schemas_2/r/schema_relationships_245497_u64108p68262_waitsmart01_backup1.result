CREATE TABLE `address` (
`street` VARCHAR(255),
`streetnumber` INT,
`city` VARCHAR(255),
`state` VARCHAR(255),
`postalcode` INT,
`country` VARCHAR(255),
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shop` (
`name` VARCHAR(255),
`space` INT,
`typebussiness` VARCHAR(255),
`id` INT,
`address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`firstname` VARCHAR(255),
`lastname` VARCHAR(255),
`age` INT,
`email` VARCHAR(255),
`password` VARCHAR(255),
`timestamp` DATETIME,
`address_id` INT
) CHARACTER SET latin1;
CREATE TABLE `usershop` (
`user_email` VARCHAR(255),
`shop_id` INT
) CHARACTER SET latin1;
