CREATE DATABASE `db_241918_vehicle_init`;
USE `db_241918_vehicle_init`;
CREATE TABLE `vehicle_info` (
`id` INT,
`id_device` INT,
`vin` VARCHAR(64),
`type_vehicle` VARCHAR(64),
`fellow` VARCHAR(64),
`licence_plate` VARCHAR(64),
`miles_orignal` INT,
`miles_current` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicle_status` (
`id` INT,
`id_device` INT,
`datetime_` DATETIME,
`speed` INT,
`engine_rpm` INT,
`engine_load_cal` INT,
`engine_load_abs` INT,
`trim_long` VARCHAR(64),
`trim_short` VARCHAR(64),
`timing_advance` INT,
`tmp_engine` INT,
`tmp_water` INT,
`tmp_air_intake` INT,
`tmp_catalyst_B1S1` INT,
`tmp_catalyst_B1S2` INT,
`oxygen_sensor` VARCHAR(64),
`air_flow_rate_MAF` INT,
`pos_throttle` INT,
`time_since_enginee` INT,
`time_since_cleared` INT,
`time_with_MIL` INT,
`pressure_barometric_abs` INT,
`cmd_evaporative_purge` INT,
`cmd_fuel_air_equ_ratio` INT,
`cmd_throttle_actuator` INT,
`warm_ups_since_cleared` INT,
`miles_since_cleared` INT,
`miles_with_MIL` INT,
`voltage` INT,
`fule_status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicle_history` (
`id` INT,
`id_device` INT,
`datetime_start` DATETIME,
`datetime_stop` DATETIME,
`speed_avg` INT,
`speed_min` INT,
`speed_max` INT,
`engine_rpm_avg` INT,
`engine_rpm_min` INT,
`engine_rpm_max` INT,
`engine_load_avg` INT,
`engine_load_min` INT,
`engine_load_max` INT,
`tmp_engine_avg` INT,
`tmp_engine_min` INT,
`tmp_engine_max` INT,
`tmp_water_avg` INT,
`tmp_water_min` INT,
`tmp_water_max` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
