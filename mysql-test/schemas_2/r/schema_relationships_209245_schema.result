INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 209245_schema
#
CREATE DATABASE `db_209245_schema`;
USE `db_209245_schema`;
CREATE TABLE `group_variant` (
`group_variant_id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`group_variant_id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`product_id` BIGINT,
`name` VARCHAR(50),
`created` DATE,
`description` VARCHAR(50),
`product_group` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `product_group` (
`product_group_id` BIGINT,
`name` VARCHAR(50),
`group_variant` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_209245_schema') AS relationships;
relationships
Database: db_209245_schema

Table Connections:
