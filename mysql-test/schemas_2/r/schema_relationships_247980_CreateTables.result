CREATE DATABASE `db_247980_CreateTables`;
USE `db_247980_CreateTables`;
CREATE TABLE `Person` (
`SSN` DECIMAL(10,2),
`FName` VARCHAR(64),
`LName` VARCHAR(64),
`HomeAddress` VARCHAR(64),
`CampusAddress` VARCHAR(64),
`CardNo` DECIMAL(10,2),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `Librarian` (
`SSN` DECIMAL(10,2),
`Position` VARCHAR(64),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `Member` (
`SSN` DECIMAL(10,2),
`Personification` VARCHAR(64),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `PhoneNo` (
`SSN` DECIMAL(10,2),
`Number` INT,
PRIMARY KEY (`SSN`, `Number`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`ISBN` DECIMAL(10,2),
`Title` VARCHAR(64),
`Author` VARCHAR(64),
`ItemDescription` VARCHAR(64),
`Publisher` VARCHAR(64),
`YearPublishing` INT,
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `Map` (
`ISBN` DECIMAL(10,2),
`NoCopies` INT,
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `Book` (
`ISBN` DECIMAL(10,2),
`BookType` VARCHAR(64),
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `BookCopy` (
`ISBN` DECIMAL(10,2),
`Barcode` DECIMAL(10,2),
PRIMARY KEY (`ISBN`, `Barcode`)
) CHARACTER SET latin1;
CREATE TABLE `BookSubject` (
`ISBN` DECIMAL(10,2),
`BookSubject` VARCHAR(64),
PRIMARY KEY (`ISBN`, `BookSubject`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_247980_CreateTables') AS relationships;
