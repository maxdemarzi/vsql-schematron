INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 294919_companydb
#
CREATE DATABASE `db_294919_companydb`;
USE `db_294919_companydb`;
CREATE TABLE `department` (
`department_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`role_id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_294919_companydb') AS relationships;
