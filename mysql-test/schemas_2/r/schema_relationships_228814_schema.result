) CHARACTER SET latin1;
CREATE TABLE `source` (
`source` VARCHAR(64),
`source_name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`tag` VARCHAR(64),
`tag_name` VARCHAR(64),
`datatype` VARCHAR(64),
PRIMARY KEY (`tag`)
) CHARACTER SET latin1;
CREATE TABLE `dataset` (
`dataset` VARCHAR(64),
