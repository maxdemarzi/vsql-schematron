PRIMARY KEY (`col`)
) CHARACTER SET latin1;
CREATE TABLE `row` (
`row` INT,
PRIMARY KEY (`row`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_228814_schema') AS relationships;
