`category` VARCHAR(64),
`is_primary` VARCHAR(64),
`c_id` VARCHAR(64),
`cre_dt` DATETIME,
`upd_dt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
