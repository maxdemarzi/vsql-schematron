`admin_password` VARCHAR(64),
`admin_nickname` VARCHAR(64),
`admin_email` VARCHAR(64),
PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;
CREATE TABLE `moerogUser` (
`user_id` VARCHAR(64),
`user_password` VARCHAR(64),
`user_nickname` VARCHAR(64),
`user_email` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `moerogPost` (
`post_id` DECIMAL(10,2),
`post_category` DECIMAL(10,2),
`post_title` VARCHAR(64),
`post_datetime` DATETIME,
`post_content` VARCHAR(64),
`admin_nickname` VARCHAR(64),
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `moerogComment` (
`comment_id` DECIMAL(10,2),
`comment_datetime` DATETIME,
`comment_content` VARCHAR(64),
`admin_nickname` VARCHAR(64),
`user_nickname` VARCHAR(64),
`post_id` DECIMAL(10,2),
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
