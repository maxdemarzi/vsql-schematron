INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 252641_postgres
#
CREATE DATABASE `db_252641_postgres`;
USE `db_252641_postgres`;
CREATE TABLE `classes` (
`id` INT NOT NULL,
`mask` INT,
`powertype` TEXT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `class_colors` (
`id` INT NOT NULL,
`class_id` INT,
`color` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `races` (
`id` INT NOT NULL,
`mask` INT,
`side` TEXT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `toon` (
`id` INT NOT NULL,
`name` TEXT,
`race_id` INT,
`class_id` INT,
`gender` INT,
`realm` TEXT,
`region` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stats` (
`id` INT NOT NULL,
`toon_id` INT,
`last_modified` BIGINT,
`create_date` DATE,
`achievement_points` INT,
`number_exalted` INT,
`mounts_owned` INT,
`quests_completed` INT,
`fish_caught` INT,
`pets_owned` INT,
`pet_battles_won` INT,
`pet_battles_pvp_won` INT,
`level` INT,
`item_level` INT,
`honorable_kills` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_252641_postgres') AS relationships;
relationships
Database: db_252641_postgres

Table Connections:
------------------
[Implied]  class_colors.class_id -> classes.id
[Implied]  stats.toon_id -> toon.id
[Implied]  toon.class_id -> classes.id
[Implied]  toon.race_id -> races.id

DROP DATABASE `db_252641_postgres`;
UNINSTALL EXTENSION vsql_schematron;
