INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 297711_Creation
#
CREATE DATABASE `db_297711_Creation`;
USE `db_297711_Creation`;
CREATE TABLE `Adherent` (
`numA` DECIMAL(10,2),
`nom` VARCHAR(64),
`prenom` VARCHAR(64),
`adresse` VARCHAR(64),
PRIMARY KEY (`numA`)
) CHARACTER SET latin1;
CREATE TABLE `Emprunt` (
`numA` DECIMAL(10,2),
`dateE` DATETIME,
`dateR` DATETIME,
PRIMARY KEY (`numA`, `dateE`)
) CHARACTER SET latin1;
CREATE TABLE `Livre` (
`ISBN` DECIMAL(10,2),
`titre` VARCHAR(64),
`editeur` VARCHAR(64),
`anneeParution` DECIMAL(10,2),
`auteurs` VARCHAR(64),
`nbE` DECIMAL(10,2),
`dateDE` DATETIME,
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `Exemplaire` (
`numInv` DECIMAL(10,2),
`ISBN` DECIMAL(10,2),
PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;
CREATE TABLE `ExemplaireEmprunte` (
`numInv` DECIMAL(10,2),
`numA` DECIMAL(10,2),
`dateE` DATETIME,
PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_297711_Creation') AS relationships;
relationships
Database: db_297711_Creation

Table Connections:
------------------
[Implied]  Emprunt.numA -> Adherent.numA
[Implied]  Exemplaire.ISBN -> Livre.ISBN
[Implied]  ExemplaireEmprunte.numInv -> Exemplaire.numInv

DROP DATABASE `db_297711_Creation`;
UNINSTALL EXTENSION vsql_schematron;
