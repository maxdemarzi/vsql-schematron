CREATE DATABASE `db_221963_db_links`;
USE `db_221963_db_links`;
CREATE TABLE `links` (
`link_id` INT,
`title` VARCHAR(50),
`url` VARCHAR(50),
`description` TEXT,
`user_id` INT,
`createdby` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`fullname` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_221963_db_links') AS relationships;
