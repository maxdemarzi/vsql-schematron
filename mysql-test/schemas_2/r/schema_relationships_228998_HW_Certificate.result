INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 228998_HW_Certificate
#
CREATE DATABASE `db_228998_HW_Certificate`;
USE `db_228998_HW_Certificate`;
CREATE TABLE `ORGANIZATION` (
`SN` VARCHAR(64),
`CN` VARCHAR(64),
PRIMARY KEY (`SN`)
) CHARACTER SET latin1;
CREATE TABLE `CA` (
`SN` VARCHAR(64),
`CN` VARCHAR(64),
`Trusted` BOOL,
PRIMARY KEY (`SN`)
) CHARACTER SET latin1;
CREATE TABLE `CERTIFICATE` (
`SN` VARCHAR(64),
`CN` VARCHAR(64),
`Org` VARCHAR(64),
`Issuer` VARCHAR(64),
`Valid_Since` DATETIME,
`Valid_Until` DATETIME,
PRIMARY KEY (`SN`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_228998_HW_Certificate') AS relationships;
relationships
