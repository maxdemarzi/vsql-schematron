CREATE DATABASE `db_282545_security`;
USE `db_282545_security`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`active_code` VARCHAR(50),
`active_status` INT,
`roles` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` INT NOT NULL,
`group_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_authorities` (
`group_id` INT,
`authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`group_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_282545_security') AS relationships;
