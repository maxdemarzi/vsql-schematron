CREATE DATABASE `db_266137_schema`;
USE `db_266137_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`pass_hash` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lists` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`list_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_266137_schema') AS relationships;
