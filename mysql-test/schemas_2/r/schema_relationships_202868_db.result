INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 202868_db
#
CREATE DATABASE `db_202868_db`;
USE `db_202868_db`;
CREATE TABLE `users` (
`id` VARCHAR(64),
`username` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `passwords` (
`user_id` VARCHAR(64),
`salt` VARCHAR(64),
`hash` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `auth_attempts` (
`user_id` VARCHAR(64),
`successful` BOOL,
`at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `password_changes` (
`user_id` VARCHAR(64),
`at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `permission_assignments` (
`user_id` VARCHAR(64),
`permission` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
`id` INT,
`owner` VARCHAR(64),
`name` VARCHAR(64),
`seats` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_messages` (
`id` INT,
`table_id` INT,
`sender` VARCHAR(64),
`msg` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_202868_db') AS relationships;
relationships
Database: db_202868_db

Table Connections:
------------------
[Implied]  auth_attempts.user_id -> users.id
[Implied]  chat_messages.sender -> users.id
[Implied]  chat_messages.table_id -> tables.id
[Implied]  password_changes.user_id -> users.id
[Implied]  passwords.user_id -> users.id
[Implied]  permission_assignments.permission -> permissions.name
[Implied]  permission_assignments.user_id -> users.id
[Implied]  tables.owner -> users.id

DROP DATABASE `db_202868_db`;
UNINSTALL EXTENSION vsql_schematron;
