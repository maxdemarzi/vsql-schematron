CREATE DATABASE `db_255215_myth_auth`;
USE `db_255215_myth_auth`;
CREATE TABLE `auth_activation_attempts` (
`id` INT,
`ip_address` VARCHAR(64),
`user_agent` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_groups` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_groups_permissions` (
`group_id` INT,
`permission_id` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_groups_users` (
`group_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_logins` (
`id` INT,
`ip_address` VARCHAR(64),
`email` VARCHAR(64),
`user_id` INT,
`date` DATETIME,
`success` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_permissions` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_reset_attempts` (
`id` INT,
`email` VARCHAR(64),
`ip_address` VARCHAR(64),
`user_agent` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_tokens` (
`id` INT,
`selector` VARCHAR(64),
`hashedValidator` VARCHAR(64),
`user_id` INT,
`expires` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `auth_users_permissions` (
`user_id` INT,
`permission_id` INT
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` INT,
`version` VARCHAR(64),
`class` VARCHAR(64),
`group` VARCHAR(64),
`namespace` VARCHAR(64),
`time` INT,
`batch` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`avatar` VARCHAR(64),
`provider_id` VARCHAR(64),
`username` VARCHAR(64),
`password_hash` VARCHAR(64),
`reset_hash` VARCHAR(64),
`reset_at` DATETIME,
`reset_expires` DATETIME,
`activate_hash` VARCHAR(64),
`status` VARCHAR(64),
`status_message` VARCHAR(64),
`active` INT,
`force_pass_reset` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME
) CHARACTER SET latin1;
