INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 230646_officeSchema
#
CREATE DATABASE `db_230646_officeSchema`;
USE `db_230646_officeSchema`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230646_officeSchema') AS relationships;
relationships
Database: db_230646_officeSchema

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_230646_officeSchema`;
UNINSTALL EXTENSION vsql_schematron;
