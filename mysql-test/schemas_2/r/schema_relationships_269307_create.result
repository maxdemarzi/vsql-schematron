CREATE DATABASE `db_269307_create`;
USE `db_269307_create`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `repositories` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `repositories_contributors` (
`repository_id` INT,
`contributor_id` INT
) CHARACTER SET latin1;
CREATE TABLE `issues` (
`id` INT,
`title` VARCHAR(64),
`issue_status` VARCHAR(64),
`repository_id` INT,
`assignee_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `commits` (
`id` INT,
`message` VARCHAR(64),
`issue_id` INT,
`repository_id` INT,
`contributor_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT,
`name` VARCHAR(64),
`size` DECIMAL(10,2),
`parent_id` INT,
`commit_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_269307_create') AS relationships;
