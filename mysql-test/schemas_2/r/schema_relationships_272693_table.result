INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 272693_table
#
CREATE DATABASE `db_272693_table`;
USE `db_272693_table`;
CREATE TABLE `students` (
`Sno` VARCHAR(64),
`Sname` VARCHAR(64),
`Ssex` VARCHAR(64),
`Sage` INT,
`Sdept` VARCHAR(64),
PRIMARY KEY (`Sno`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`Cno` VARCHAR(64),
`Cname` VARCHAR(64),
`Cpno` VARCHAR(64),
`Ccredit` INT,
PRIMARY KEY (`Cno`)
) CHARACTER SET latin1;
CREATE TABLE `StoC` (
`Sno` VARCHAR(64),
`Cno` VARCHAR(64),
`Grade` INT,
PRIMARY KEY (`Sno`, `Cno`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_272693_table') AS relationships;
relationships
