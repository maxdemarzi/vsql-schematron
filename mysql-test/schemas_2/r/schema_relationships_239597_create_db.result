CREATE TABLE `users` (
`uid` INT,
`timeCreated` DATETIME,
`realName` VARCHAR(255),
`name` VARCHAR(255),
`email` VARCHAR(255),
`bio` VARCHAR(255),
`isAdmin` INT,
`score` INT,
`userRank` INT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `patterns` (
`uid` INT,
`timeCreated` DATETIME,
`name` VARCHAR(255),
`description` VARCHAR(255),
`numObjects` INT,
`GIF` VARCHAR(255),
`difficulty` DECIMAL(10,2),
`avgHighScoreCatch` DECIMAL(10,2),
`avgHighScoreTime` DECIMAL(10,2),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `records` (
`uid` INT,
`userUID` INT,
`patternUID` INT,
`isPersonalBest` INT,
`score` DECIMAL(10,2),
`recordRank` INT,
`catches` INT,
`duration` DATETIME,
`timeRecorded` DATETIME,
`video` VARCHAR(255),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
