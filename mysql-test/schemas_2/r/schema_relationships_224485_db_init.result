INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 224485_db_init
#
CREATE DATABASE `db_224485_db_init`;
USE `db_224485_db_init`;
CREATE TABLE `User` (
`UserID` INT,
`Email` VARCHAR(255),
`PasswordHash` VARCHAR(255),
`DateJoined` DATETIME,
`FirstName` VARCHAR(255),
`LastName` VARCHAR(255),
`PhoneNumber` INT,
PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `ApartmentAdvert` (
`AdvertID` INT,
`AuthorID` INT,
`DateCreated` DATETIME,
`DealType` INT,
`LocationData` VARCHAR(255),
`Price` DECIMAL(10,2),
`Title` VARCHAR(255),
`RoomCount` INT,
`Space` INT,
`LivingSpace` INT,
`Height` INT,
`Floor` INT,
`TotalFloors` INT,
`YearBuilt` INT,
`Condition` VARCHAR(255),
`Heating` VARCHAR(255),
`Walls` VARCHAR(255),
PRIMARY KEY (`AdvertID`)
) CHARACTER SET latin1;
CREATE TABLE `DealType` (
`DealTypeID` INT,
`DealName` VARCHAR(255),
PRIMARY KEY (`DealTypeID`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
`AdminID` INT,
`Login` VARCHAR(255),
`PasswordHash` VARCHAR(255),
`DateGranted` DATETIME,
PRIMARY KEY (`AdminID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_224485_db_init') AS relationships;
relationships
