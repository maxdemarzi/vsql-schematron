INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 281625_code_web
#
CREATE DATABASE `db_281625_code_web`;
USE `db_281625_code_web`;
CREATE TABLE `code_web_usetype` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_web_reqinfo` (
`id` INT,
`name` VARCHAR(64),
`url` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_web_scripts` (
`id` INT,
`url` VARCHAR(64),
`name` VARCHAR(64),
`released` INT,
`usetype` INT,
`download` VARCHAR(64),
`github` VARCHAR(64),
`wiki` VARCHAR(64),
`descmd` VARCHAR(64),
`deschtml` VARCHAR(64),
`instmd` VARCHAR(64),
`insthtml` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_web_requirements` (
`script` INT,
`req` INT,
PRIMARY KEY (`script`, `req`)
) CHARACTER SET latin1;
CREATE TABLE `code_web_comments` (
`id` INT,
`script` INT,
`posted` INT,
`user` INT,
`name` VARCHAR(64),
`contacturl` VARCHAR(64),
`html` VARCHAR(64),
`markdown` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281625_code_web') AS relationships;
relationships
Database: db_281625_code_web

Table Connections:
------------------
[Implied]  code_web_comments.script -> code_web_scripts.id
[Implied]  code_web_requirements.req -> code_web_reqinfo.id
[Implied]  code_web_requirements.script -> code_web_scripts.id
[Implied]  code_web_scripts.usetype -> code_web_usetype.id

DROP DATABASE `db_281625_code_web`;
UNINSTALL EXTENSION vsql_schematron;
