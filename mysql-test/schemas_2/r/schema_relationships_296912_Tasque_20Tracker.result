PRIMARY KEY (`ClientId`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
`ProjectId` INT,
`DomainType` VARCHAR(64),
`ProjectName` VARCHAR(64),
`ProjectDeadline` DATETIME,
`Status` VARCHAR(64),
`ProjectDesc` VARCHAR(64),
`ProjectSubmissionDate` DATETIME,
`cost` INT,
PRIMARY KEY (`ProjectId`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
`EmpId` INT,
`DomainType` VARCHAR(64),
`Status` VARCHAR(64),
`JoiningDate` DATETIME,
`LeavingDate` DATETIME,
`Position` VARCHAR(64),
`DateOfBirth` DATETIME,
PRIMARY KEY (`EmpId`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
`TaskId` INT,
