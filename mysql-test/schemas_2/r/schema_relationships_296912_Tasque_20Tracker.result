CREATE TABLE `Person` (
`PersonId` INT,
`FirstName` VARCHAR(64),
`MiddleName` VARCHAR(64),
`LastName` VARCHAR(64),
`EmailId` VARCHAR(64),
`StreetName` VARCHAR(64),
`CityName` VARCHAR(64),
`State` VARCHAR(64),
