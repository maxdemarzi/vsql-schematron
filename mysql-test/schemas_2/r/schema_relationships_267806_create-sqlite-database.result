INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 267806_create-sqlite-database
#
CREATE DATABASE `db_267806_create_sqlite_database`;
USE `db_267806_create_sqlite_database`;
CREATE TABLE `PhysicalDimension` (
`Id` INT NOT NULL,
`Name` TEXT,
`Scale` TEXT,
`Created` DATETIME,
`CreatedBy` TEXT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Sensor` (
`Id` INT NOT NULL,
`Name` TEXT,
`Make` TEXT,
`Model` TEXT,
`SerialNumber` TEXT,
`PhysicalDimensionId` INT,
`Created` DATETIME,
`CreatedBy` TEXT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Measure` (
`Id` INT NOT NULL,
`SensorId` INT,
`Value` DOUBLE,
`Created` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_267806_create_sqlite_database') AS relationships;
relationships
