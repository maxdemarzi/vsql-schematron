CREATE DATABASE `db_294026_00_clear_database`;
USE `db_294026_00_clear_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`salt` VARCHAR(50),
`reset_token` CHAR(50),
`reset_token_expire` DATETIME,
`created_date` DATETIME,
`last_login_date` DATETIME,
`is_active` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`role_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles_users` (
`user_id` INT NOT NULL,
`role_id` INT NOT NULL,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
