INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 214767_EntireDatabase
#
CREATE DATABASE `db_214767_EntireDatabase`;
USE `db_214767_EntireDatabase`;
CREATE TABLE `Categories` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
`id` INT NOT NULL,
`orderId` INT NOT NULL,
`quantity` INT,
`price` DECIMAL(10,2),
`productId` INT,
PRIMARY KEY (`id`, `orderId`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`id` INT NOT NULL,
`clientId` INT,
`totalPrice` DECIMAL(10,2),
`createdAt` DATETIME,
`delivered` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`quantity` INT,
`price` DECIMAL(10,2),
`categoryId` INT,
`imageFileName` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProductsXSpecifications` (
`id` INT NOT NULL,
`value` VARCHAR(50),
`productId` INT,
`specificationId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Specifications` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`isNumeric` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_214767_EntireDatabase') AS relationships;
relationships
Database: db_214767_EntireDatabase

Table Connections:
