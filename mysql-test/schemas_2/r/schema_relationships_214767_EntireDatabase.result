[Implied]  OrderDetails.orderId -> Orders.id
[Implied]  OrderDetails.productId -> Products.id
[Implied]  Products.categoryId -> Categories.id
[Implied]  ProductsXSpecifications.productId -> Products.id
[Implied]  ProductsXSpecifications.specificationId -> Specifications.id

DROP DATABASE `db_214767_EntireDatabase`;
UNINSTALL EXTENSION vsql_schematron;
