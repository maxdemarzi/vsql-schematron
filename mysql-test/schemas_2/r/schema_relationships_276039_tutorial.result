INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 276039_tutorial
#
CREATE DATABASE `db_276039_tutorial`;
USE `db_276039_tutorial`;
CREATE TABLE `cities` (
`abbr` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`LOCATION` VARCHAR(50),
`create_dt` TIMESTAMP NULL,
`update_dt` TIMESTAMP NULL,
PRIMARY KEY (`abbr`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
`id` INT NOT NULL,
`city` CHAR(50),
`date` DATE,
`temp_lo` INT,
`temp_hi` INT,
`prcp` DOUBLE,
`create_dt` TIMESTAMP NULL,
`update_dt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_276039_tutorial') AS relationships;
