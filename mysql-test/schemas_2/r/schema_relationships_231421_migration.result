PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
`id` VARCHAR(50) NOT NULL,
`bio` TEXT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`user_id` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`email` TEXT,
`password` TEXT,
`role` VARCHAR(50),
`username` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
