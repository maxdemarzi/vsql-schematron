INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212571_database
--echo #
CREATE DATABASE `db_212571_database`;
USE `db_212571_database`;

CREATE TABLE `customers` (
  `id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `cpf` INT,
  `rg` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `agencies` (
  `id` INT,
  `name` VARCHAR(64),
  `manager` VARCHAR(64),
  `services` VARCHAR(64),
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` INT,
  `street` VARCHAR(64),
  `neighborhood` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `id` INT,
  `color` VARCHAR(64),
  `chassi` VARCHAR(64),
  `door` INT,
  `models_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `models` (
  `id` INT,
  `brand` VARCHAR(64),
  `model` VARCHAR(64),
  `manufacturer` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `date` DATETIME,
  `customer_id` INT,
  `agency_id` INT,
  `days` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cars_orders` (
  `cars_id` INT,
  `orders_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212571_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212571_database') AS relationships;
DROP DATABASE `db_212571_database`;
UNINSTALL EXTENSION vsql_schematron;
