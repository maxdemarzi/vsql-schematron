INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 225255_init
--echo #
CREATE DATABASE `db_225255_init`;
USE `db_225255_init`;

CREATE TABLE `MAIN` (
  `SourceCellLine` VARCHAR(64),
  `TargetCellLine` VARCHAR(64),
  `Species` VARCHAR(64),
  PRIMARY KEY (`SourceCellLine`, `TargetCellLine`)
) CHARACTER SET latin1;

CREATE TABLE `method_of_differentiation` (
  `SourceCellLine` VARCHAR(64),
  `TargetCellLine` VARCHAR(64),
  `MethodID` INT,
  PRIMARY KEY (`SourceCellLine`, `TargetCellLine`, `MethodID`)
) CHARACTER SET latin1;

CREATE TABLE `PROTOCOLS` (
  `ProtocolID` INT,
  `Steps` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`ProtocolID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_225255_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_225255_init') AS relationships;
DROP DATABASE `db_225255_init`;
UNINSTALL EXTENSION vsql_schematron;
