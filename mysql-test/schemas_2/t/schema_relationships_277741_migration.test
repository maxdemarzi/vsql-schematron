INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277741_migration
--echo #
CREATE DATABASE `db_277741_migration`;
USE `db_277741_migration`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `templates` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` VARCHAR(64),
  `subject` VARCHAR(64),
  `body` VARCHAR(64),
  `template_id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` VARCHAR(64),
  `type` VARCHAR(64),
  `meta` VARCHAR(64),
  `recipient_id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipients` (
  `id` VARCHAR(64),
  `message_id` VARCHAR(64),
  `contact_id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_MessageToTag` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277741_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277741_migration') AS relationships;
DROP DATABASE `db_277741_migration`;
UNINSTALL EXTENSION vsql_schematron;
