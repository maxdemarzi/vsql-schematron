INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 272134_IphoneStore
--echo #
CREATE DATABASE `db_272134_IphoneStore`;
USE `db_272134_IphoneStore`;

CREATE TABLE `colors` (
  `color_id` INT,
  `color_name` VARCHAR(64),
  `color_quantity` INT,
  PRIMARY KEY (`color_id`)
) CHARACTER SET latin1;

CREATE TABLE `Staffs` (
  `staff_id` INT,
  `staff_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_pass` VARCHAR(64),
  `telephone` VARCHAR(64),
  `email` VARCHAR(64),
  `role` INT,
  PRIMARY KEY (`staff_id`)
) CHARACTER SET latin1;

CREATE TABLE `iphones` (
  `iphone_id` INT,
  `iphone_name` VARCHAR(64),
  `iphone_process` VARCHAR(64),
  `iphone_memory` VARCHAR(64),
  `color_id` INT,
  `iphone_storage` VARCHAR(64),
  `iphone_camera` VARCHAR(64),
  `iphone_battery` VARCHAR(64),
  `iphone_screen` VARCHAR(64),
  `iphone_wireless_network` VARCHAR(64),
  `iphone_waterproof` VARCHAR(64),
  `iphone_support` VARCHAR(64),
  `iphone_price` DECIMAL(10,2),
  PRIMARY KEY (`iphone_id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `customer_id` INT,
  `customer_name` VARCHAR(64),
  `customer_address` VARCHAR(64),
  `customer_email` VARCHAR(64),
  `customer_phone` VARCHAR(64),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `invoices` (
  `invoice_no` INT,
  `invoice_data` DATETIME,
  `invoice_status` VARCHAR(64),
  `customer_id` INT,
  `staff_id` INT,
  PRIMARY KEY (`invoice_no`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_272134_IphoneStore') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_272134_IphoneStore') AS relationships;
DROP DATABASE `db_272134_IphoneStore`;
UNINSTALL EXTENSION vsql_schematron;
