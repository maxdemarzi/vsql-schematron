INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224235_2_permissions
--echo #
CREATE DATABASE `db_224235_2_permissions`;
USE `db_224235_2_permissions`;

CREATE TABLE `groups` (
  `GID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`GID`)
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `PID` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`PID`)
) CHARACTER SET latin1;

CREATE TABLE `group_permissions` (
  `GID` INT,
  `PID` INT,
  PRIMARY KEY (`GID`, `PID`)
) CHARACTER SET latin1;

CREATE TABLE `user_groups` (
  `UID` INT,
  `GID` INT,
  PRIMARY KEY (`UID`, `GID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224235_2_permissions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224235_2_permissions') AS relationships;
DROP DATABASE `db_224235_2_permissions`;
UNINSTALL EXTENSION vsql_schematron;
