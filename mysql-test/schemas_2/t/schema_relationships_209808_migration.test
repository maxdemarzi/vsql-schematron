INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 209808_migration
--echo #
CREATE DATABASE `db_209808_migration`;
USE `db_209808_migration`;

CREATE TABLE `Client` (
  `id` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  `birthday` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Address` (
  `id` VARCHAR(64),
  `addressLine` VARCHAR(64),
  `zip` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `isBillingAddress` BOOL,
  `isShippingAddress` BOOL,
  `clientId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Product` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `price` DECIMAL(10,2),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `id` VARCHAR(64),
  `clientId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_OrderToProduct` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_209808_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_209808_migration') AS relationships;
DROP DATABASE `db_209808_migration`;
UNINSTALL EXTENSION vsql_schematron;
