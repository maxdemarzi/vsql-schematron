INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 287741_mysql_sample
--echo #
CREATE DATABASE `db_287741_mysql_sample`;
USE `db_287741_mysql_sample`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_keys` (
  `id` INT NOT NULL,
  `token_type` VARCHAR(50),
  `token` VARCHAR(50),
  `refresh_token` VARCHAR(50),
  `user_id` INT,
  `expires_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signature_keys` (
  `id` INT NOT NULL,
  `signature_key` VARCHAR(50),
  `user_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `infos` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `category` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_287741_mysql_sample') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_287741_mysql_sample') AS relationships;
DROP DATABASE `db_287741_mysql_sample`;
UNINSTALL EXTENSION vsql_schematron;
