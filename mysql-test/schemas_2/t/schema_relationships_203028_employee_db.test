INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 203028_employee_db
--echo #
CREATE DATABASE `db_203028_employee_db`;
USE `db_203028_employee_db`;

CREATE TABLE `employee` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `role_id` INT,
  `manager_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `title` VARCHAR(64),
  `salary` VARCHAR(64),
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_203028_employee_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_203028_employee_db') AS relationships;
DROP DATABASE `db_203028_employee_db`;
UNINSTALL EXTENSION vsql_schematron;
