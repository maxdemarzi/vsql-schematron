INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213828_weblog
--echo #
CREATE DATABASE `db_213828_weblog`;
USE `db_213828_weblog`;
CREATE TABLE `Hosts` (
  `id` INT NOT NULL,
  `ipaddr` VARCHAR(50),
  `hostname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
  `id` INT NOT NULL,
  `host` INT,
  `complete` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Accesses` (
  `session` INT NOT NULL,
  `seq` INT NOT NULL,
  `course` INT,
  `page` VARCHAR(50),
  `params` VARCHAR(50),
  `accTime` TIMESTAMP NULL,
  `nbytes` INT,
  PRIMARY KEY (`session`, `seq`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213828_weblog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213828_weblog') AS relationships;
DROP DATABASE `db_213828_weblog`;
UNINSTALL EXTENSION vsql_schematron;
