INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283454_join
--echo #
CREATE DATABASE `db_283454_join`;
USE `db_283454_join`;

CREATE TABLE `empresas` (
  `id` INT,
  `nome` VARCHAR(64),
  `endereco` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `historicos` (
  `id` INT,
  `fkempresa` INT,
  `historico` VARCHAR(64),
  `credito` DECIMAL(10,2),
  `debito` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `funcionarios` (
  `id` INT,
  `fkempresa` INT,
  `nome` VARCHAR(64),
  `cargo` VARCHAR(64),
  `salario` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283454_join') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283454_join') AS relationships;
DROP DATABASE `db_283454_join`;
UNINSTALL EXTENSION vsql_schematron;
