INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 236316_sbase2_20210512_12_43
--echo #
CREATE DATABASE `db_236316_sbase2_20210512_12_43`;
USE `db_236316_sbase2_20210512_12_43`;

CREATE TABLE `acceso` (
  `id` INT,
  `accion_id` INT,
  `perfil_id` INT,
  `permitido` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `accion` (
  `id` INT,
  `accion` VARCHAR(64),
  `controlador_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `controlador` (
  `id` INT,
  `controlador` VARCHAR(64),
  `perfil_id` INT
) CHARACTER SET latin1;

CREATE TABLE `generacomp` (
  `id` INT,
  `generacomp_at` DATETIME,
  `usuario_id` INT,
  `periodo_mes` VARCHAR(64),
  `periodo_anio` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `id` INT,
  `texto` VARCHAR(64),
  `icono` VARCHAR(64),
  `color` VARCHAR(64),
  `perfil_id` INT,
  `posicion` INT,
  `accion_id` INT
) CHARACTER SET latin1;

CREATE TABLE `modulo` (
  `id` INT,
  `modulo` VARCHAR(64),
  `descripcion` VARCHAR(64),
  `logo` VARCHAR(64),
  `privado` VARCHAR(64),
  `modulo_at` DATETIME,
  `link` VARCHAR(64),
  `inicial` VARCHAR(64),
  `publicado` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `persona` (
  `id` INT,
  `ape` VARCHAR(64),
  `nom` VARCHAR(64),
  `dni` INT,
  `cuil` VARCHAR(64),
  `cel` VARCHAR(64),
  `fijo` VARCHAR(64),
  `pais` VARCHAR(64),
  `nac` DATETIME,
  `usuario_id` INT,
  `mail` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `rol` (
  `id` INT,
  `usuario_id` INT,
  `perfil_id` INT,
  `activo` VARCHAR(64),
  `contrata_at` DATETIME,
  `finaliza` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id` INT,
  `usu` VARCHAR(64),
  `cla` VARCHAR(64),
  `usuario_at` DATETIME,
  `foto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_236316_sbase2_20210512_12_43') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_236316_sbase2_20210512_12_43') AS relationships;
DROP DATABASE `db_236316_sbase2_20210512_12_43`;
UNINSTALL EXTENSION vsql_schematron;
