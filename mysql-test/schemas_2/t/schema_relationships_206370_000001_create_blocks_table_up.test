INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 206370_000001_create_blocks_table.up
--echo #
CREATE DATABASE `db_206370_000001_create_blocks_table_up`;
USE `db_206370_000001_create_blocks_table_up`;

CREATE TABLE `blocks` (
  `id` INT,
  `block_hash` VARCHAR(64),
  `accepting_block_id` INT,
  `version` INT,
  `hash_merkle_root` VARCHAR(64),
  `accepted_id_merkle_root` VARCHAR(64),
  `utxo_commitment` VARCHAR(64),
  `timestamp` DATETIME,
  `bits` INT,
  `nonce` VARCHAR(64),
  `blue_score` INT,
  `is_chain_block` BOOL,
  `mass` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_206370_000001_create_blocks_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_206370_000001_create_blocks_table_up') AS relationships;
DROP DATABASE `db_206370_000001_create_blocks_table_up`;
UNINSTALL EXTENSION vsql_schematron;
