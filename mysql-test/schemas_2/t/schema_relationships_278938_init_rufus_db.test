INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278938_init_rufus_db
--echo #
CREATE DATABASE `db_278938_init_rufus_db`;
USE `db_278938_init_rufus_db`;

CREATE TABLE `rufususer` (
  `userid` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

CREATE TABLE `articles` (
  `userid` INT,
  `title` VARCHAR(64),
  `date` DATETIME,
  `description` VARCHAR(64),
  `url` VARCHAR(64),
  `channeltitle` VARCHAR(64),
  `channelurl` VARCHAR(64),
  `authors` VARCHAR(64),
  PRIMARY KEY (`userid`, `url`)
) CHARACTER SET latin1;

CREATE TABLE `sources` (
  `userid` INT,
  `source` VARCHAR(64),
  `frontpage` VARCHAR(64),
  `tags` VARCHAR(64),
  PRIMARY KEY (`userid`, `source`)
) CHARACTER SET latin1;

CREATE TABLE `publicsources` (
  `source` VARCHAR(64),
  `frontpage` VARCHAR(64),
  `tags` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278938_init_rufus_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278938_init_rufus_db') AS relationships;
DROP DATABASE `db_278938_init_rufus_db`;
UNINSTALL EXTENSION vsql_schematron;
