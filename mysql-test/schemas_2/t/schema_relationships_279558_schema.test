INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279558_schema
--echo #
CREATE DATABASE `db_279558_schema`;
USE `db_279558_schema`;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `username` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `active` BOOLEAN,
  `favorite_products` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279558_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279558_schema') AS relationships;
DROP DATABASE `db_279558_schema`;
UNINSTALL EXTENSION vsql_schematron;
