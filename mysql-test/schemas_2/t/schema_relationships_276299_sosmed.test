INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276299_sosmed
--echo #
CREATE DATABASE `db_276299_sosmed`;
USE `db_276299_sosmed`;

CREATE TABLE `komentar` (
  `id_komentar` INT,
  `nama` VARCHAR(64),
  `email` VARCHAR(64),
  `komentar` VARCHAR(64),
  PRIMARY KEY (`id_komentar`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `id` INT,
  `username` VARCHAR(64),
  `content` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `photo` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276299_sosmed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276299_sosmed') AS relationships;
DROP DATABASE `db_276299_sosmed`;
UNINSTALL EXTENSION vsql_schematron;
