INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 255873_ConstraintFK_UsingAlterWithoutName_00.Source
--echo #
CREATE DATABASE `db_255873_ConstraintFK_UsingAlterWithoutName_00_Source`;
USE `db_255873_ConstraintFK_UsingAlterWithoutName_00_Source`;

CREATE TABLE `t_master` (
  `i` INT,
  PRIMARY KEY (`i`)
) CHARACTER SET latin1;

CREATE TABLE `t_detail` (
  `i` INT,
  PRIMARY KEY (`i`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_255873_ConstraintFK_UsingAlterWithoutName_00_Source') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_255873_ConstraintFK_UsingAlterWithoutName_00_Source') AS relationships;
DROP DATABASE `db_255873_ConstraintFK_UsingAlterWithoutName_00_Source`;
UNINSTALL EXTENSION vsql_schematron;
