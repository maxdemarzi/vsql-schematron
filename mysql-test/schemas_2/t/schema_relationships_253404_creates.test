INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 253404_creates
--echo #
CREATE DATABASE `db_253404_creates`;
USE `db_253404_creates`;

CREATE TABLE `department` (
  `dcode` VARCHAR(64),
  `building` VARCHAR(64),
  `room` INT,
  PRIMARY KEY (`dcode`)
) CHARACTER SET latin1;

CREATE TABLE `major` (
  `mid` INT,
  `mname` VARCHAR(64),
  `dcode` VARCHAR(64),
  PRIMARY KEY (`mid`)
) CHARACTER SET latin1;

CREATE TABLE `faculty` (
  `fid` INT,
  `fname` VARCHAR(64),
  `dcode` VARCHAR(64),
  PRIMARY KEY (`fid`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `sid` INT,
  `sname` VARCHAR(64),
  `mid` INT,
  `fid` INT,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `cnum` VARCHAR(64),
  `cname` VARCHAR(64),
  `semester` VARCHAR(64),
  `year` INT,
  `credits` INT,
  `fid` INT,
  PRIMARY KEY (`cnum`, `semester`, `year`)
) CHARACTER SET latin1;

CREATE TABLE `enroll` (
  `cnum` VARCHAR(64),
  `semester` VARCHAR(64),
  `year` INT,
  `sid` INT,
  `grade` VARCHAR(64),
  PRIMARY KEY (`cnum`, `semester`, `year`, `sid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_253404_creates') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_253404_creates') AS relationships;
DROP DATABASE `db_253404_creates`;
UNINSTALL EXTENSION vsql_schematron;
