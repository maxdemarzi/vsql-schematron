INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289930_DB_proxima_estacao_8
--echo #
CREATE DATABASE `db_289930_DB_proxima_estacao_8`;
USE `db_289930_DB_proxima_estacao_8`;

CREATE TABLE `status` (
  `id_status` VARCHAR(64),
  `descricao_status` VARCHAR(64),
  PRIMARY KEY (`id_status`)
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id_usuario` INT,
  `foto_perfil` VARCHAR(64),
  `nome` VARCHAR(64),
  `sobrenome` VARCHAR(64),
  `apelido` VARCHAR(64),
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  `numero` VARCHAR(64),
  `id_status` VARCHAR(64),
  `data_nascimento` DATETIME,
  `cpf` VARCHAR(64),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;

CREATE TABLE `tipo_categoria` (
  `id_tipo_categoria` INT,
  `nome_tipo` VARCHAR(64),
  PRIMARY KEY (`id_tipo_categoria`)
) CHARACTER SET latin1;

CREATE TABLE `categoria` (
  `id_categoria` INT,
  `nome_categoria` VARCHAR(64),
  `id_tipo_categoria` INT,
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;

CREATE TABLE `artista` (
  `id_artista` INT,
  `descricao` VARCHAR(64),
  `id_usuario` INT,
  `rede_social` VARCHAR(64),
  PRIMARY KEY (`id_artista`)
) CHARACTER SET latin1;

CREATE TABLE `grupo` (
  `id_grupo` INT,
  `nome_grupo` VARCHAR(64),
  `tag_grupo` VARCHAR(64),
  `descricao_grupo` VARCHAR(64),
  PRIMARY KEY (`id_grupo`)
) CHARACTER SET latin1;

CREATE TABLE `forma_pagamento` (
  `id_forma_Pag` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`id_forma_Pag`)
) CHARACTER SET latin1;

CREATE TABLE `doacao` (
  `id_doacao` INT,
  `valor` DECIMAL(10,2),
  `id_artista` INT,
  `id_usuario` INT,
  `id_forma_pag` INT,
  PRIMARY KEY (`id_doacao`)
) CHARACTER SET latin1;

CREATE TABLE `publicacao` (
  `id_publicacao` INT,
  `thumb` VARCHAR(64),
  `conteudo` VARCHAR(64),
  `conteudo_sensi` VARCHAR(64),
  `descricao` VARCHAR(64),
  `visualizacao` INT,
  `id_artista` INT,
  PRIMARY KEY (`id_publicacao`)
) CHARACTER SET latin1;

CREATE TABLE `feedback` (
  `id_feedback` INT,
  `titulo` VARCHAR(64),
  `comentario` VARCHAR(64),
  `curtida` VARCHAR(64),
  `id_usuario` INT,
  `id_publicacao` INT,
  PRIMARY KEY (`id_feedback`)
) CHARACTER SET latin1;

CREATE TABLE `recompensa` (
  `id_recompensa` INT,
  `nome` VARCHAR(64),
  `descricao` VARCHAR(64),
  `emblema` VARCHAR(64),
  PRIMARY KEY (`id_recompensa`)
) CHARACTER SET latin1;

CREATE TABLE `grupo_artista` (
  `id_grupo` INT,
  `id_artista` INT,
  PRIMARY KEY (`id_grupo`, `id_artista`)
) CHARACTER SET latin1;

CREATE TABLE `artista_Categoria` (
  `id_artista` INT,
  `id_categoria` INT,
  PRIMARY KEY (`id_artista`, `id_categoria`)
) CHARACTER SET latin1;

CREATE TABLE `publicacao_categoria` (
  `id_publicacao` INT,
  `id_categoria` INT,
  PRIMARY KEY (`id_publicacao`, `id_categoria`)
) CHARACTER SET latin1;

CREATE TABLE `usuario_recompensa` (
  `id_recompensa` INT,
  `id_usuario` INT,
  PRIMARY KEY (`id_recompensa`, `id_usuario`)
) CHARACTER SET latin1;

CREATE TABLE `formaPag_artista` (
  `id_forma_Pag` INT,
  `id_artista` INT,
  PRIMARY KEY (`id_forma_Pag`, `id_artista`)
) CHARACTER SET latin1;

CREATE TABLE `seguidores` (
  `id_artista` INT,
  `id_usuario` INT,
  PRIMARY KEY (`id_artista`, `id_usuario`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289930_DB_proxima_estacao_8') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289930_DB_proxima_estacao_8') AS relationships;
DROP DATABASE `db_289930_DB_proxima_estacao_8`;
UNINSTALL EXTENSION vsql_schematron;
