INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 200428_modelagem
--echo #
CREATE DATABASE `db_200428_modelagem`;
USE `db_200428_modelagem`;

CREATE TABLE `clientes` (
  `id_cliente` INT,
  `cpf_cliente` VARCHAR(64),
  `nome_cliente` VARCHAR(64),
  PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;

CREATE TABLE `produtos` (
  `id_produto` INT,
  `descricao_produto` VARCHAR(64),
  `quantidade_produto` INT,
  `preco_produto` DECIMAL(10,2),
  PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;

CREATE TABLE `vendas` (
  `id_venda` INT,
  `total_venda` DECIMAL(10,2),
  `cliente_venda` INT,
  PRIMARY KEY (`id_venda`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_200428_modelagem') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_200428_modelagem') AS relationships;
DROP DATABASE `db_200428_modelagem`;
UNINSTALL EXTENSION vsql_schematron;
