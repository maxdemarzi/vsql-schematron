INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 263497_test
--echo #
CREATE DATABASE `db_263497_test`;
USE `db_263497_test`;

CREATE TABLE `USER` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MODERATOR` (
  `ID` INT,
  `MODERATED_THREAD` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MESSAGE` (
  `ID` INT,
  `BODY` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `AUTHOR` INT,
  `THREAD` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `THREAD` (
  `ID` INT,
  `TITLE` VARCHAR(64),
  `ORIGINAL_MESSAGE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_263497_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_263497_test') AS relationships;
DROP DATABASE `db_263497_test`;
UNINSTALL EXTENSION vsql_schematron;
