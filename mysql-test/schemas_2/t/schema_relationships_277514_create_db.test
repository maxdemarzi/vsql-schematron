INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277514_create_db
--echo #
CREATE DATABASE `db_277514_create_db`;
USE `db_277514_create_db`;

CREATE TABLE `stripe_payees` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `apple_payees` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `google_payees` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_tiers` (
  `id` INT,
  `bytes_cap` INT,
  `valid_until` DATETIME,
  `payee_stripe` INT,
  `payee_apple` INT,
  `payee_google` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts` (
  `name` VARCHAR(64),
  `public_key` VARCHAR(64),
  `account_tier` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` VARCHAR(64),
  `parent` VARCHAR(64),
  `parent_access_key` VARCHAR(64),
  `is_folder` BOOL,
  `name_encrypted` VARCHAR(64),
  `name_hmac` VARCHAR(64),
  `owner` VARCHAR(64),
  `deleted` BOOL,
  `metadata_version` INT,
  `content_version` INT,
  `document_size` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_access_keys` (
  `file_id` VARCHAR(64),
  `sharee_id` VARCHAR(64),
  `encrypted_key` VARCHAR(64),
  PRIMARY KEY (`file_id`, `sharee_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277514_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277514_create_db') AS relationships;
DROP DATABASE `db_277514_create_db`;
UNINSTALL EXTENSION vsql_schematron;
