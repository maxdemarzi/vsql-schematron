INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295584_registro-pokemon
--echo #
CREATE DATABASE `db_295584_registro_pokemon`;
USE `db_295584_registro_pokemon`;

CREATE TABLE `usuarios` (
  `id` INT,
  `nombre` VARCHAR(64),
  `region` VARCHAR(64),
  `correo` VARCHAR(64),
  `contrasena` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pokemon` (
  `id` INT,
  `mote` VARCHAR(64),
  `nivel` INT,
  `entrenador` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295584_registro_pokemon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295584_registro_pokemon') AS relationships;
DROP DATABASE `db_295584_registro_pokemon`;
UNINSTALL EXTENSION vsql_schematron;
