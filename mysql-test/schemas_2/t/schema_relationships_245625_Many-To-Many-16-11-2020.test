INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 245625_Many-To-Many-16-11-2020
--echo #
CREATE DATABASE `db_245625_Many_To_Many_16_11_2020`;
USE `db_245625_Many_To_Many_16_11_2020`;
CREATE TABLE `students` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students_exams` (
  `student_id` INT NOT NULL,
  `exam_id` INT NOT NULL,
  PRIMARY KEY (`student_id`, `exam_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_245625_Many_To_Many_16_11_2020') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_245625_Many_To_Many_16_11_2020') AS relationships;
DROP DATABASE `db_245625_Many_To_Many_16_11_2020`;
UNINSTALL EXTENSION vsql_schematron;
