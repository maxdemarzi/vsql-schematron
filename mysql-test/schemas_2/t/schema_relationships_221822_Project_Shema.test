INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221822_Project_Shema
--echo #
CREATE DATABASE `db_221822_Project_Shema`;
USE `db_221822_Project_Shema`;

CREATE TABLE `FootballClub` (
  `id` INT,
  `c_name` VARCHAR(64),
  `homwCourt_advantage` INT,
  `league` VARCHAR(64),
  `teamInfo` INT,
  `logo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Player` (
  `id` INT,
  `p_name` VARCHAR(64),
  `age` INT,
  `numberOnBack` INT,
  `attack` INT,
  `defence` INT,
  `stamina` INT,
  `overall` INT,
  `injuryResistance` INT,
  `foot` VARCHAR(64),
  `position` VARCHAR(64),
  `partOf` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Injury` (
  `id` INT,
  `name` VARCHAR(64),
  `rcoveryTime` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LineUp` (
  `id` INT,
  `attack` INT,
  `defence` INT,
  `overall` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TeamInformation` (
  `id` INT,
  `formation` VARCHAR(64),
  `lineup` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `GetInjured` (
  `startTime` INT,
  `has` INT,
  `belongsTo` INT,
  PRIMARY KEY (`has`, `belongsTo`)
) CHARACTER SET latin1;

CREATE TABLE `PosOnField` (
  `positionNum` INT,
  `has` INT,
  `isIn` INT,
  PRIMARY KEY (`has`, `isIn`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221822_Project_Shema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221822_Project_Shema') AS relationships;
DROP DATABASE `db_221822_Project_Shema`;
UNINSTALL EXTENSION vsql_schematron;
