INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 253226_schema.ddl
--echo #
CREATE DATABASE `db_253226_schema_ddl`;
USE `db_253226_schema_ddl`;
CREATE TABLE `player_login` (
  `id` CHAR(50),
  `name` VARCHAR(50),
  `ip_address` VARCHAR(50),
  `time` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `player_ip_ban` (
  `id` INT NOT NULL,
  `ip_address` VARCHAR(50),
  `sender_id` CHAR(50),
  `reason` VARCHAR(50),
  `creation_date` TIMESTAMP NULL,
  `expiry_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player_ip_unban` (
  `ban_id` INT,
  `ip_address` VARCHAR(50),
  `sender_id` CHAR(50),
  `creation_date` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `player_punish` (
  `id` INT NOT NULL,
  `banned_id` CHAR(50),
  `sender_id` CHAR(50),
  `reason` VARCHAR(50),
  `creation_date` TIMESTAMP NULL,
  `expiry_date` TIMESTAMP NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player_punish_reverse` (
  `punish_id` INT,
  `banned_id` CHAR(50),
  `sender_id` CHAR(50),
  `reason` VARCHAR(50),
  `creation_date` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_253226_schema_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_253226_schema_ddl') AS relationships;
DROP DATABASE `db_253226_schema_ddl`;
UNINSTALL EXTENSION vsql_schematron;
