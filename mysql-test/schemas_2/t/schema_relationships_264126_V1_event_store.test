INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264126_V1_event_store
--echo #
CREATE DATABASE `db_264126_V1_event_store`;
USE `db_264126_V1_event_store`;

CREATE TABLE `stream` (
  `stream_id` VARCHAR(64),
  `version` INT,
  PRIMARY KEY (`stream_id`)
) CHARACTER SET latin1;

CREATE TABLE `event` (
  `stream_id` VARCHAR(64),
  `version` INT,
  `data` VARCHAR(64),
  `metadata` VARCHAR(64),
  PRIMARY KEY (`stream_id`, `version`)
) CHARACTER SET latin1;

CREATE TABLE `event_sequence` (
  `position` INT,
  `stream_id` VARCHAR(64),
  `version` INT,
  PRIMARY KEY (`position`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264126_V1_event_store') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264126_V1_event_store') AS relationships;
DROP DATABASE `db_264126_V1_event_store`;
UNINSTALL EXTENSION vsql_schematron;
