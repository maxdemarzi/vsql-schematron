INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246296_mysql-init
--echo #
CREATE DATABASE `db_246296_mysql_init`;
USE `db_246296_mysql_init`;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `eans` (
  `id` INT NOT NULL,
  `code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_x_tags` (
  `book_id` INT NOT NULL,
  `tag_id` INT NOT NULL,
  PRIMARY KEY (`book_id`, `tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `table_with_defaults` (
  `name` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246296_mysql_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246296_mysql_init') AS relationships;
DROP DATABASE `db_246296_mysql_init`;
UNINSTALL EXTENSION vsql_schematron;
