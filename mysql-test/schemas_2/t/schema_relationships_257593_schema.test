INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257593_schema
--echo #
CREATE DATABASE `db_257593_schema`;
USE `db_257593_schema`;

CREATE TABLE `Actions` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Subjects` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TimeTable` (
  `action` INT,
  `subject` INT,
  `duration` INT,
  PRIMARY KEY (`action`, `subject`)
) CHARACTER SET latin1;

CREATE TABLE `History` (
  `started` VARCHAR(64),
  `ended` VARCHAR(64),
  `action` INT,
  `subject` INT,
  PRIMARY KEY (`started`)
) CHARACTER SET latin1;

CREATE TABLE `Meta` (
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257593_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257593_schema') AS relationships;
DROP DATABASE `db_257593_schema`;
UNINSTALL EXTENSION vsql_schematron;
