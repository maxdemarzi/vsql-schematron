INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258280_createDB
--echo #
CREATE DATABASE `db_258280_createDB`;
USE `db_258280_createDB`;

CREATE TABLE `classes` (
  `class_id` INT,
  `title` VARCHAR(255),
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;

CREATE TABLE `decks` (
  `deck_id` INT,
  `class_id` INT,
  `title` VARCHAR(255),
  `topic1` VARCHAR(255),
  `topic2` VARCHAR(255),
  PRIMARY KEY (`deck_id`)
) CHARACTER SET latin1;

CREATE TABLE `cards` (
  `card_id` INT,
  `deck_id` INT,
  `data` VARCHAR(255),
  PRIMARY KEY (`card_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258280_createDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258280_createDB') AS relationships;
DROP DATABASE `db_258280_createDB`;
UNINSTALL EXTENSION vsql_schematron;
