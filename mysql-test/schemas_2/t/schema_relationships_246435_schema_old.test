INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246435_schema-old
--echo #
CREATE DATABASE `db_246435_schema_old`;
USE `db_246435_schema_old`;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `credit_card` (
  `id` INT,
  `name` VARCHAR(64),
  `number` INT,
  `expiration` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_credit_card` (
  `customer_id` INT,
  `credit_card_id` INT
) CHARACTER SET latin1;

CREATE TABLE `customer_order` (
  `id` INT,
  `customer_id` INT,
  `credit_card_id` INT,
  `total_price` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_order_preference` (
  `customer_id` INT,
  `customer_order_id` INT
) CHARACTER SET latin1;

CREATE TABLE `drinks` (
  `name` VARCHAR(64),
  `price` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `pizzas` (
  `id` INT,
  `size` VARCHAR(64),
  `topping_1` VARCHAR(64),
  `topping_2` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_pizzas` (
  `customer_order_id` INT,
  `pizza_id` INT
) CHARACTER SET latin1;

CREATE TABLE `toppings` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `customer_drinks` (
  `customer_order_id` INT,
  `drink` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sizes` (
  `name` VARCHAR(64),
  `price` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246435_schema_old') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246435_schema_old') AS relationships;
DROP DATABASE `db_246435_schema_old`;
UNINSTALL EXTENSION vsql_schematron;
