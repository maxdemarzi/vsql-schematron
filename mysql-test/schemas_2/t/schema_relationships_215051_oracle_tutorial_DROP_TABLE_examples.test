INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215051_oracle_tutorial_DROP_TABLE_examples
--echo #
CREATE DATABASE `db_215051_oracle_tutorial_DROP_TABLE_examples`;
USE `db_215051_oracle_tutorial_DROP_TABLE_examples`;
CREATE TABLE `brands` (
  `brand_id` DECIMAL(10,2) NOT NULL,
  `brand_name` VARCHAR(50),
  PRIMARY KEY (`brand_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `car_id` DECIMAL(10,2) NOT NULL,
  `make` VARCHAR(50),
  `model` VARCHAR(50),
  `year` DECIMAL(10,2),
  `plate_number` VARCHAR(50),
  `brand_id` DECIMAL(10,2),
  PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215051_oracle_tutorial_DROP_TABLE_examples') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215051_oracle_tutorial_DROP_TABLE_examples') AS relationships;
DROP DATABASE `db_215051_oracle_tutorial_DROP_TABLE_examples`;
UNINSTALL EXTENSION vsql_schematron;
