INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233772_postgresql_create_tables
--echo #
CREATE DATABASE `db_233772_postgresql_create_tables`;
USE `db_233772_postgresql_create_tables`;

CREATE TABLE `lookup.preference_type` (
  `preference_type_id` INT,
  `preference_type` VARCHAR(64),
  PRIMARY KEY (`preference_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `lookup.preference_value` (
  `preference_value_id` INT,
  `preference_value` VARCHAR(64),
  PRIMARY KEY (`preference_value_id`)
) CHARACTER SET latin1;

CREATE TABLE `patient.preferences` (
  `patient_id` VARCHAR(64),
  `preference_type_id` INT,
  `preference_value_id` INT,
  `preference_priority` INT,
  `created` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`patient_id`, `preference_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `receipt.documents` (
  `patient_id` VARCHAR(64),
  `guid` VARCHAR(64),
  `ts` DATETIME,
  PRIMARY KEY (`patient_id`, `guid`)
) CHARACTER SET latin1;

CREATE TABLE `register.documents` (
  `GUID` VARCHAR(64),
  `fhir_id` VARCHAR(64),
  `Title` VARCHAR(64),
  `Clinic` VARCHAR(64),
  `Document_Type` VARCHAR(64),
  `Filesname` VARCHAR(64),
  `URL` VARCHAR(64),
  `Patient_Visible` INT,
  `CreatedDate` DATETIME,
  `Modified` DATETIME,
  `Specialty` VARCHAR(64),
  `FullPath` VARCHAR(64),
  `BaseURL` VARCHAR(64),
  `BaseSite` VARCHAR(64),
  PRIMARY KEY (`GUID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233772_postgresql_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233772_postgresql_create_tables') AS relationships;
DROP DATABASE `db_233772_postgresql_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
