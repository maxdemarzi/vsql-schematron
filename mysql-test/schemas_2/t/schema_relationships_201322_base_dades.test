INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 201322_base_dades
--echo #
CREATE DATABASE `db_201322_base_dades`;
USE `db_201322_base_dades`;

CREATE TABLE `Login` (
  `user` VARCHAR(64),
  `mail` VARCHAR(64),
  `password` VARCHAR(64),
  `connected` BOOL,
  `register_date` VARCHAR(64),
  `last_login` VARCHAR(64),
  `number_games` INT,
  `total_points` INT,
  `gaming` BOOL,
  `startingGameTime` VARCHAR(64),
  PRIMARY KEY (`user`, `mail`)
) CHARACTER SET latin1;

CREATE TABLE `Replay` (
  `user` VARCHAR(64),
  `ID` INT,
  `Order_` INT,
  `move` VARCHAR(64),
  `path` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Partida` (
  `user` VARCHAR(64),
  `score` INT,
  `time` VARCHAR(64),
  `game_date` VARCHAR(64),
  `max_espectators` INT,
  `replay_path` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `DefaultKeys` (
  `user` VARCHAR(64),
  `derecha` INT,
  `izquierda` INT,
  `abajo` INT,
  `rderecha` INT,
  `rizquierda` INT,
  `pause` INT,
  PRIMARY KEY (`user`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_201322_base_dades') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_201322_base_dades') AS relationships;
DROP DATABASE `db_201322_base_dades`;
UNINSTALL EXTENSION vsql_schematron;
