INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 241276_V1__init
--echo #
CREATE DATABASE `db_241276_V1__init`;
USE `db_241276_V1__init`;
CREATE TABLE `players` (
  `id` BIGINT NOT NULL,
  `nickname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
  `id` BIGINT NOT NULL,
  `level` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stats` (
  `id` BIGINT NOT NULL,
  `player_id` BIGINT,
  `game_id` BIGINT,
  `score` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_241276_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_241276_V1__init') AS relationships;
DROP DATABASE `db_241276_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
