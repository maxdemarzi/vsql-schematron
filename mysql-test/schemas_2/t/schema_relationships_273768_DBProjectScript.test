INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273768_DBProjectScript
--echo #
CREATE DATABASE `db_273768_DBProjectScript`;
USE `db_273768_DBProjectScript`;

CREATE TABLE `Cardholder` (
  `cardNumber` INT,
  `lastName` VARCHAR(64),
  `firstName` VARCHAR(64),
  `address` VARCHAR(64),
  `phoneNumber` DECIMAL(10,2),
  `email` VARCHAR(64),
  PRIMARY KEY (`cardNumber`)
) CHARACTER SET latin1;

CREATE TABLE `Publisher` (
  `publisherID` INT,
  `publisherName` VARCHAR(64),
  PRIMARY KEY (`publisherID`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `floorNumber` INT,
  `studyrooms` INT,
  `computers` INT,
  PRIMARY KEY (`floorNumber`)
) CHARACTER SET latin1;

CREATE TABLE `Employee` (
  `employeeID` INT,
  `lastName` VARCHAR(64),
  `firstName` VARCHAR(64),
  `extension` INT,
  `floorNumber` INT,
  `salary` INT,
  PRIMARY KEY (`employeeID`)
) CHARACTER SET latin1;

CREATE TABLE `Book` (
  `bookID` INT,
  `publisherID` INT,
  `floorLocation` INT,
  `ISBN` VARCHAR(64),
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `copies` INT,
  `publicationYear` INT,
  `bookInfo` VARCHAR(64),
  PRIMARY KEY (`bookID`)
) CHARACTER SET latin1;

CREATE TABLE `Borrows` (
  `borrowerID` INT,
  `bookID` INT,
  `borrowDate` DATETIME,
  `dueDate` DATETIME,
  `returnDate` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `Reserves` (
  `memberID` INT,
  `floorLocation` INT,
  `computer` BOOL,
  `studyroom` BOOL
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273768_DBProjectScript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273768_DBProjectScript') AS relationships;
DROP DATABASE `db_273768_DBProjectScript`;
UNINSTALL EXTENSION vsql_schematron;
