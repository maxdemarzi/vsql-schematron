INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276104_schema
--echo #
CREATE DATABASE `db_276104_schema`;
USE `db_276104_schema`;

CREATE TABLE `hashtag` (
  `id` INT,
  `internal_message_id` INT,
  `tag` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `link` (
  `id` INT,
  `internal_message_id` INT,
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mention` (
  `id` INT,
  `chat_name` VARCHAR(64),
  `internal_message_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `internal_id` INT,
  `chat_id` INT,
  `message_id` INT,
  `reply_to_message_id` INT,
  `forwarded_from_chat_id` INT,
  `forwarded_from_message_id` INT,
  `type` INT,
  `text_content` VARCHAR(64),
  `publish_date` DATETIME,
  `load_date` DATETIME,
  `views` INT,
  PRIMARY KEY (`internal_id`)
) CHARACTER SET latin1;

CREATE TABLE `chat` (
  `name` VARCHAR(64),
  `id` INT,
  `description` VARCHAR(64),
  `members` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276104_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276104_schema') AS relationships;
DROP DATABASE `db_276104_schema`;
UNINSTALL EXTENSION vsql_schematron;
