INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289974_assignmetn4
--echo #
CREATE DATABASE `db_289974_assignmetn4`;
USE `db_289974_assignmetn4`;

CREATE TABLE `Branch` (
  `branchNo` VARCHAR(64),
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  PRIMARY KEY (`branchNo`)
) CHARACTER SET latin1;

CREATE TABLE `BranchTel` (
  `branchNo` VARCHAR(64),
  `telNo` VARCHAR(64),
  PRIMARY KEY (`branchNo`, `telNo`)
) CHARACTER SET latin1;

CREATE TABLE `Manager` (
  `staffNo` VARCHAR(64),
  `cellPhone` VARCHAR(64),
  `eMail` VARCHAR(64),
  PRIMARY KEY (`staffNo`)
) CHARACTER SET latin1;

CREATE TABLE `ActorDirector` (
  `stageName` VARCHAR(64),
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  PRIMARY KEY (`stageName`)
) CHARACTER SET latin1;

CREATE TABLE `DVD` (
  `catalogNo` VARCHAR(64),
  `title` VARCHAR(64),
  `category` VARCHAR(64),
  `dailyRent` DECIMAL(10,2),
  PRIMARY KEY (`catalogNo`)
) CHARACTER SET latin1;

CREATE TABLE `ChildrenDVD` (
  `catalogNo` VARCHAR(64),
  `ageGroup` VARCHAR(64),
  PRIMARY KEY (`catalogNo`)
) CHARACTER SET latin1;

CREATE TABLE `ForeignDVD` (
  `catalogNo` VARCHAR(64),
  `spokenLanguage` VARCHAR(64),
  `subtitleLanguage` VARCHAR(64),
  PRIMARY KEY (`catalogNo`)
) CHARACTER SET latin1;

CREATE TABLE `Makes` (
  `stageName` VARCHAR(64),
  `catalogNo` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`stageName`, `catalogNo`)
) CHARACTER SET latin1;

CREATE TABLE `DVDCopy` (
  `catalogNo` VARCHAR(64),
  `copyNo` INT,
  `condition` INT,
  `branchNo` VARCHAR(64),
  PRIMARY KEY (`catalogNo`, `copyNo`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289974_assignmetn4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289974_assignmetn4') AS relationships;
DROP DATABASE `db_289974_assignmetn4`;
UNINSTALL EXTENSION vsql_schematron;
