INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276304_V1__initial_structure
--echo #
CREATE DATABASE `db_276304_V1_initial_structure`;
USE `db_276304_V1_initial_structure`;

CREATE TABLE `actor` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `active` INT,
  `name` VARCHAR(64),
  `created_by` INT,
  `updated_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `director` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `active` INT,
  `name` VARCHAR(64),
  `created_by` INT,
  `updated_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `active` INT,
  `amount_votes` INT,
  `average_score` DECIMAL(10,2),
  `genre` VARCHAR(64),
  `name` VARCHAR(64),
  `total_score` INT,
  `created_by` INT,
  `updated_by` INT,
  `director_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_actors` (
  `movie_id` INT,
  `actors_id` INT
) CHARACTER SET latin1;

CREATE TABLE `movie_votes` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `active` INT,
  `score` INT,
  `created_by` INT,
  `updated_by` INT,
  `movie_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276304_V1_initial_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276304_V1_initial_structure') AS relationships;
DROP DATABASE `db_276304_V1_initial_structure`;
UNINSTALL EXTENSION vsql_schematron;
