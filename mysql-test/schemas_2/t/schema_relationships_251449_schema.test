INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 251449_schema
--echo #
CREATE DATABASE `db_251449_schema`;
USE `db_251449_schema`;
CREATE TABLE `Article` (
  `id` INT,
  `title` VARCHAR(50),
  `status` INT,
  `type` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
  `id` INT,
  `title` VARCHAR(50),
  `priority` INT
) CHARACTER SET latin1;
CREATE TABLE `Event` (
  `id` INT,
  `title` VARCHAR(50),
  `category` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `Activity` (
  `id` INT,
  `user_id` INT,
  `detail` VARCHAR(50),
  `happened_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_251449_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_251449_schema') AS relationships;
DROP DATABASE `db_251449_schema`;
UNINSTALL EXTENSION vsql_schematron;
