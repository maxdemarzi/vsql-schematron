INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278792_schema
--echo #
CREATE DATABASE `db_278792_schema`;
USE `db_278792_schema`;

CREATE TABLE `boards` (
  `id` INT,
  `board_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_boards` (
  `user_id` INT,
  `board_id` INT
) CHARACTER SET latin1;

CREATE TABLE `orgs` (
  `id` INT,
  `org_name` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `org_boards` (
  `org_id` INT,
  `board_id` INT
) CHARACTER SET latin1;

CREATE TABLE `org_users` (
  `org_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `columns_in_board` (
  `id` INT,
  `title` VARCHAR(64),
  `board_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cards_in_column` (
  `id` INT,
  `content` VARCHAR(64),
  `author` INT,
  `column_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278792_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278792_schema') AS relationships;
DROP DATABASE `db_278792_schema`;
UNINSTALL EXTENSION vsql_schematron;
