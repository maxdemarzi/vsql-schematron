INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228838_20200827063158_maki
--echo #
CREATE DATABASE `db_228838_20200827063158_maki`;
USE `db_228838_20200827063158_maki`;

CREATE TABLE `users` (
  `id` INT,
  `pronouns` VARCHAR(64),
  `lastfm` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `muted` (
  `id` INT,
  `guild_id` INT,
  `mute_length` INT,
  `muted_time` DATETIME,
  `unmute_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `guilds` (
  `id` INT,
  `muted_role` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228838_20200827063158_maki') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228838_20200827063158_maki') AS relationships;
DROP DATABASE `db_228838_20200827063158_maki`;
UNINSTALL EXTENSION vsql_schematron;
