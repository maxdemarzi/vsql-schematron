INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215162_schema
--echo #
CREATE DATABASE `db_215162_schema`;
USE `db_215162_schema`;
CREATE TABLE `region` (
  `index` INT,
  `region_id` INT NOT NULL,
  `country` TEXT,
  `province` TEXT,
  `Region` TEXT,
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
  `index` INT,
  `region_id` INT,
  `Lat` DECIMAL(10,2),
  `Lng` DECIMAL(10,2),
  `max_temp` DECIMAL(10,2),
  `min_temp` DECIMAL(10,2),
  `Temp` DECIMAL(10,2),
  `Humidity` DECIMAL(10,2),
  `diurnal_range` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `wine` (
  `index` INT,
  `region_id` INT,
  `variety` TEXT,
  `points` INT,
  `price` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215162_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215162_schema') AS relationships;
DROP DATABASE `db_215162_schema`;
UNINSTALL EXTENSION vsql_schematron;
