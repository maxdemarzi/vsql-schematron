INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297968_database
--echo #
CREATE DATABASE `db_297968_database`;
USE `db_297968_database`;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stocks` (
  `id` INT,
  `name` VARCHAR(64),
  `quantity` INT,
  `category` INT,
  `unit_price` INT,
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `admin` INT,
  `phone_number` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `shipping_address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `items` VARCHAR(64),
  `total_price` INT,
  `status` INT,
  `shipping_address` VARCHAR(64),
  `additional_message` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297968_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297968_database') AS relationships;
DROP DATABASE `db_297968_database`;
UNINSTALL EXTENSION vsql_schematron;
