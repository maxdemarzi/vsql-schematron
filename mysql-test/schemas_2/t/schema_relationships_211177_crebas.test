INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 211177_crebas
--echo #
CREATE DATABASE `db_211177_crebas`;
USE `db_211177_crebas`;

CREATE TABLE `Bar` (
  `chainName` VARCHAR(64),
  `chainID` INT,
  `beer_brand_name` VARCHAR(64),
  `beer_produce_factory_name` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `form` VARCHAR(64),
  `capacity` INT,
  `cardID` INT,
  `Dri_cardID` INT,
  `countyName` VARCHAR(64),
  `streetName` VARCHAR(64),
  `apartmentNumber` INT,
  `price` INT,
  PRIMARY KEY (`chainName`, `chainID`)
) CHARACTER SET latin1;

CREATE TABLE `Beer` (
  `beer_brand_name` VARCHAR(64),
  `beer_produce_factory_name` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `form` VARCHAR(64),
  `capacity` INT,
  `cardID` INT,
  `Dri_cardID` INT,
  PRIMARY KEY (`beer_brand_name`, `beer_produce_factory_name`, `name`, `type`, `form`, `capacity`)
) CHARACTER SET latin1;

CREATE TABLE `Drinker` (
  `cardID` INT,
  `group_id` INT,
  `beer_brand_name` VARCHAR(64),
  `beer_produce_factory_name` VARCHAR(64),
  `Bee_name` VARCHAR(64),
  `type` VARCHAR(64),
  `form` VARCHAR(64),
  `capacity` INT,
  `chainName` VARCHAR(64),
  `chainID` INT,
  `name` VARCHAR(64),
  `age` INT,
  `sex` INT,
  PRIMARY KEY (`cardID`)
) CHARACTER SET latin1;

CREATE TABLE `Group` (
  `group_id` INT,
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `zip` INT,
  `street_number` INT,
  `apt_number` INT,
  `chainName` VARCHAR(64),
  `chainID` INT,
  `cardID` INT,
  `state` VARCHAR(64),
  `city` VARCHAR(64),
  `street_name` VARCHAR(64),
  `apt_name` VARCHAR(64),
  PRIMARY KEY (`zip`, `street_number`, `apt_number`)
) CHARACTER SET latin1;

CREATE TABLE `Manufacturer` (
  `beer_brand_name` VARCHAR(64),
  `beer_produce_factory_name` VARCHAR(64),
  PRIMARY KEY (`beer_brand_name`, `beer_produce_factory_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_211177_crebas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_211177_crebas') AS relationships;
DROP DATABASE `db_211177_crebas`;
UNINSTALL EXTENSION vsql_schematron;
