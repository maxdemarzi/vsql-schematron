INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 284102_02.base_tables.up
--echo #
CREATE DATABASE `db_284102_02_base_tables_up`;
USE `db_284102_02_base_tables_up`;

CREATE TABLE `ra_nodes` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `detail` VARCHAR(64),
  `type` VARCHAR(64),
  `inserted_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ra_users` (
  `id` INT,
  `node_id` INT,
  `username` VARCHAR(64),
  `password_digest` VARCHAR(64),
  `email` VARCHAR(64),
  `is_active` BOOL,
  `inserted_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ra_jobs` (
  `id` INT,
  `node_id` INT,
  `source_user_id` INT,
  `inserted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ra_job_details` (
  `id` INT,
  `node_id` INT,
  `job_id` INT,
  `source_user_id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `detail` VARCHAR(64),
  `before` BOOL,
  `before_jobs` VARCHAR(64),
  `after` BOOL,
  `after_jobs` VARCHAR(64),
  `script_file` VARCHAR(64),
  `script` VARCHAR(64),
  `inserted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ra_job_logs` (
  `id` INT,
  `node_id` INT,
  `job_id` INT,
  `data` VARCHAR(64),
  `state` BOOL,
  `inserted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_284102_02_base_tables_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_284102_02_base_tables_up') AS relationships;
DROP DATABASE `db_284102_02_base_tables_up`;
UNINSTALL EXTENSION vsql_schematron;
