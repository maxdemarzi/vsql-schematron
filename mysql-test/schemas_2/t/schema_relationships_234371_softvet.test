INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 234371_softvet
--echo #
CREATE DATABASE `db_234371_softvet`;
USE `db_234371_softvet`;

CREATE TABLE `cliente` (
  `cli_id` INT,
  `cli_nome` VARCHAR(64),
  `cli_nacional` VARCHAR(64),
  `cli_sexo` VARCHAR(64),
  `cli_fantasia` VARCHAR(64),
  `cli_tipo_FJ` VARCHAR(64),
  `cli_cpf_cnpj` VARCHAR(64),
  `cli_rg_ie` VARCHAR(64),
  `cli_aniversario` VARCHAR(64),
  `status_financeiro` VARCHAR(64),
  `cli_conheceu` VARCHAR(64),
  `cli_profissao` VARCHAR(64),
  `cli_ativo` INT,
  `cli_aceita_email` INT,
  `cli_aceita_sms` INT,
  `cli_obs` VARCHAR(64),
  `data_criacao` DATETIME,
  `data_update` DATETIME,
  `data_exclusao` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `contato` (
  `contato_id` INT,
  `fk_id_cliente` INT,
  `fk_id_funcionario` INT,
  `contato_tipo` VARCHAR(64),
  `contato_numero` VARCHAR(64),
  `contato_email` VARCHAR(64),
  `contato_obs` VARCHAR(64),
  `contato_favorito` INT,
  `contato_ativo` INT,
  `data_criacao` DATETIME,
  `data_update` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `endereco` (
  `end_id` INT,
  `fk_id_cliente` INT,
  `fk_id_fornecedor` INT,
  `fk_id_funcionario` INT,
  `end_rua` VARCHAR(64),
  `end_numero` VARCHAR(64),
  `end_bairro` VARCHAR(64),
  `end_complemento` VARCHAR(64),
  `end_estado` VARCHAR(64),
  `end_cep` VARCHAR(64),
  `end_cidade` VARCHAR(64),
  `end_tipo` VARCHAR(64),
  `end_ref` VARCHAR(64),
  `end_ativo` INT,
  `data_criacao` DATETIME,
  `data_update` DATETIME,
  `data_exclusao` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `version` VARCHAR(64),
  `class` VARCHAR(64),
  `group` VARCHAR(64),
  `namespace` VARCHAR(64),
  `time` INT,
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_234371_softvet') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_234371_softvet') AS relationships;
DROP DATABASE `db_234371_softvet`;
UNINSTALL EXTENSION vsql_schematron;
