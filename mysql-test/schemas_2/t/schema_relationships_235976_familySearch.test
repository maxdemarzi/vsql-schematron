INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235976_familySearch
--echo #
CREATE DATABASE `db_235976_familySearch`;
USE `db_235976_familySearch`;

CREATE TABLE `abap_testing.familyBonds` (
  `people_id` INT,
  `gender` VARCHAR(64),
  `full_name` VARCHAR(64),
  `age` INT,
  `father` INT,
  `mother` INT,
  `spouse` INT,
  PRIMARY KEY (`people_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235976_familySearch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235976_familySearch') AS relationships;
DROP DATABASE `db_235976_familySearch`;
UNINSTALL EXTENSION vsql_schematron;
