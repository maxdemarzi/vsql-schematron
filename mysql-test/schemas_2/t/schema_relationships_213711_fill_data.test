INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213711_fill_data
--echo #
CREATE DATABASE `db_213711_fill_data`;
USE `db_213711_fill_data`;
CREATE TABLE `users` (
  `id` INT,
  `last_name` TEXT,
  `first_name` TEXT,
  `middle_name` TEXT,
  `phone` TEXT,
  `email` TEXT,
  `city_id` INT,
  `deleted` INT
) CHARACTER SET latin1;
CREATE TABLE `regions` (
  `id` INT,
  `name` TEXT,
  `deleted` INT
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT,
  `text` TEXT,
  `user_id` INT,
  `deleted` INT,
  `timestamp` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
  `id` INT,
  `name` TEXT,
  `region_id` INT,
  `deleted` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213711_fill_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213711_fill_data') AS relationships;
DROP DATABASE `db_213711_fill_data`;
UNINSTALL EXTENSION vsql_schematron;
