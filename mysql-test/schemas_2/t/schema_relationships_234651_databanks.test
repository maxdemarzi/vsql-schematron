INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 234651_databanks
--echo #
CREATE DATABASE `db_234651_databanks`;
USE `db_234651_databanks`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `passwordhash` CHAR(50),
  `total_books` INT,
  `total_pages` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` TEXT,
  `author` TEXT,
  `pages` INT,
  `rating` INT,
  `month` INT,
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_234651_databanks') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_234651_databanks') AS relationships;
DROP DATABASE `db_234651_databanks`;
UNINSTALL EXTENSION vsql_schematron;
