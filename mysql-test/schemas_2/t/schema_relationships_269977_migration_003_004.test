INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269977_migration-003-004
--echo #
CREATE DATABASE `db_269977_migration_003_004`;
USE `db_269977_migration_003_004`;

CREATE TABLE `MZ_MS_RUNS` (
  `ID` INT,
  `EXPE_ID` VARCHAR(64),
  `SAMP_ID` VARCHAR(64),
  `DS_ID` VARCHAR(64),
  `INSTRUMENT_TYPE` VARCHAR(64),
  `INSTRUMENT_MANUFACTURER` VARCHAR(64),
  `INSTRUMENT_MODEL` VARCHAR(64),
  `METHOD_IONISATION` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MZ_SCANS` (
  `ID` INT,
  `MZ_MS_RUN_ID` VARCHAR(64),
  `NUMBER` INT,
  `LEVEL` INT,
  `PEAKS_COUNT` INT,
  `POLARITY` VARCHAR(64),
  `SCAN_TYPE` VARCHAR(64),
  `COLLISION_ENERGY` DECIMAL(10,2),
  `LOW_MZ` DECIMAL(10,2),
  `HIGH_MZ` DECIMAL(10,2),
  `RETENTION_TIME` DECIMAL(10,2),
  `PRECURSOR1_MZ` DECIMAL(10,2),
  `PRECURSOR1_INTENSITY` DECIMAL(10,2),
  `PRECURSOR1_CHARGE` INT,
  `PRECURSOR2_MZ` DECIMAL(10,2),
  `PRECURSOR2_INTENSITY` DECIMAL(10,2),
  `PRECURSOR2_CHARGE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MZ_PEAKS` (
  `MZ_SCAN_ID` VARCHAR(64),
  `MZ` DECIMAL(10,2),
  `INTENSITY` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269977_migration_003_004') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269977_migration_003_004') AS relationships;
DROP DATABASE `db_269977_migration_003_004`;
UNINSTALL EXTENSION vsql_schematron;
