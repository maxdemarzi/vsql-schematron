INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 225899_dbSchema
--echo #
CREATE DATABASE `db_225899_dbSchema`;
USE `db_225899_dbSchema`;

CREATE TABLE `users` (
  `id` INT,
  `organization_id` INT,
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `phone` INT,
  `email` VARCHAR(64),
  `photo` VARCHAR(64),
  `department` VARCHAR(64),
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `organizations` (
  `id` INT,
  `admin_id` INT,
  `default_id` INT,
  `name` VARCHAR(64),
  `logo` VARCHAR(64),
  `welcome_message` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_225899_dbSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_225899_dbSchema') AS relationships;
DROP DATABASE `db_225899_dbSchema`;
UNINSTALL EXTENSION vsql_schematron;
