INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 248679_202101221100_initialize_schema.up
--echo #
CREATE DATABASE `db_248679_202101221100_initialize_schema_up`;
USE `db_248679_202101221100_initialize_schema_up`;
CREATE TABLE `addresses` (
  `id` INT NOT NULL,
  `street_address` TEXT,
  `building_name` TEXT,
  `locality` TEXT,
  `town` TEXT,
  `postcode` TEXT,
  `creation_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
  `id` VARCHAR(50) NOT NULL,
  `address_id` INT,
  `creation_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_248679_202101221100_initialize_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_248679_202101221100_initialize_schema_up') AS relationships;
DROP DATABASE `db_248679_202101221100_initialize_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
