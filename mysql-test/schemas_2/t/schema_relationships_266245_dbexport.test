INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266245_dbexport
--echo #
CREATE DATABASE `db_266245_dbexport`;
USE `db_266245_dbexport`;

CREATE TABLE `component` (
  `cp_uuid` VARCHAR(64),
  `dsb_uuid` VARCHAR(64),
  `cp_route` VARCHAR(64),
  PRIMARY KEY (`cp_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `dashboard` (
  `dsb_uuid` VARCHAR(64),
  `usr_email` VARCHAR(64),
  `dsb_name` VARCHAR(64),
  PRIMARY KEY (`dsb_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `dashboard_x_label` (
  `dsb_uuid` VARCHAR(64),
  `lbl_id` INT,
  PRIMARY KEY (`dsb_uuid`, `lbl_id`)
) CHARACTER SET latin1;

CREATE TABLE `followers` (
  `follower_email` VARCHAR(64),
  `usr_email` VARCHAR(64),
  PRIMARY KEY (`follower_email`, `usr_email`)
) CHARACTER SET latin1;

CREATE TABLE `label` (
  `lbl_id` INT,
  `lbl_name` VARCHAR(64),
  PRIMARY KEY (`lbl_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266245_dbexport') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266245_dbexport') AS relationships;
DROP DATABASE `db_266245_dbexport`;
UNINSTALL EXTENSION vsql_schematron;
