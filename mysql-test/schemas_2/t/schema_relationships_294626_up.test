INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294626_up
--echo #
CREATE DATABASE `db_294626_up`;
USE `db_294626_up`;

CREATE TABLE `workshops` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `end` DATETIME,
  `anonymous` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `criterion` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `weight` DECIMAL(10,2),
  `kind` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `criteria` (
  `workshop` INT,
  `criterion` INT,
  PRIMARY KEY (`workshop`, `criterion`)
) CHARACTER SET latin1;

CREATE TABLE `workshoplist` (
  `workshop` INT,
  `user` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`workshop`, `user`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294626_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294626_up') AS relationships;
DROP DATABASE `db_294626_up`;
UNINSTALL EXTENSION vsql_schematron;
