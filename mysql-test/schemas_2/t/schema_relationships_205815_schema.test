INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 205815_schema
--echo #
CREATE DATABASE `db_205815_schema`;
USE `db_205815_schema`;

CREATE TABLE `changed_files` (
  `changedfile_id` INT,
  `changetype` VARCHAR(64),
  `commit` VARCHAR(64),
  `deletions` INT,
  `file_name` VARCHAR(64),
  `path` VARCHAR(64),
  `file_type` VARCHAR(64),
  `full_file_name` VARCHAR(64),
  `insertions` INT,
  `mode` INT,
  `range_index` INT,
  `range_size` INT,
  `reponame` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`changedfile_id`)
) CHARACTER SET latin1;

CREATE TABLE `cmd_params` (
  `run_id` INT,
  `cmd_params` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `df_add` (
  `add_id` INT,
  `current` BOOL,
  `destination` VARCHAR(64),
  `source` VARCHAR(64),
  `source_destination` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`add_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_arg` (
  `arg_id` INT,
  `arg` VARCHAR(64),
  `current` BOOL,
  `snap_id` INT,
  PRIMARY KEY (`arg_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_cmd` (
  `snap_id` INT,
  `run_params` VARCHAR(64),
  `current` BOOL,
  `executable` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_comment` (
  `comment_id` INT,
  `comment` VARCHAR(64),
  `current` BOOL,
  `instruction` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_copy` (
  `copy_id` INT,
  `current` BOOL,
  `destination` VARCHAR(64),
  `source` VARCHAR(64),
  `source_destination` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`copy_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_entrypoint` (
  `snap_id` INT,
  `run_params` VARCHAR(64),
  `current` BOOL,
  `executable` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_env` (
  `env_id` INT,
  `current` BOOL,
  `key` VARCHAR(64),
  `key_value` VARCHAR(64),
  `value` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`env_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_expose` (
  `expose_id` INT,
  `current` BOOL,
  `port` INT,
  `snap_id` INT,
  PRIMARY KEY (`expose_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_from` (
  `snap_id` INT,
  `current` BOOL,
  `digest` VARCHAR(64),
  `full_name` VARCHAR(64),
  `imageversionnumber` DECIMAL(10,2),
  `imageversionstring` VARCHAR(64),
  `imagename` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_healthcheck` (
  `snap_id` INT,
  `instruction_params` VARCHAR(64),
  `current` BOOL,
  `instruction` VARCHAR(64),
  `options_params` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_label` (
  `label_id` INT,
  `current` BOOL,
  `key` VARCHAR(64),
  `key_value` VARCHAR(64),
  `value` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`label_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_maintainer` (
  `snap_id` INT,
  `current` BOOL,
  `maintainername` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_onbuild` (
  `onbuild_id` INT,
  `instruction_params` VARCHAR(64),
  `current` BOOL,
  `instruction` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`onbuild_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_run` (
  `run_id` INT,
  `run_params` VARCHAR(64),
  `current` BOOL,
  `executable` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`run_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_stopsignal` (
  `snap_id` INT,
  `current` BOOL,
  `signal` VARCHAR(64),
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_user` (
  `user_id` INT,
  `current` BOOL,
  `username` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_volume` (
  `volume_id` INT,
  `current` BOOL,
  `value` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`volume_id`)
) CHARACTER SET latin1;

CREATE TABLE `df_workdir` (
  `workdir_id` INT,
  `current` BOOL,
  `path` VARCHAR(64),
  `snap_id` INT,
  PRIMARY KEY (`workdir_id`)
) CHARACTER SET latin1;

CREATE TABLE `diff` (
  `diff_id` INT,
  `commit_date` INT,
  `del` INT,
  `diff_state` VARCHAR(64),
  `ins` INT,
  `mod` INT,
  PRIMARY KEY (`diff_id`)
) CHARACTER SET latin1;

CREATE TABLE `diff_type` (
  `diff_type_id` INT,
  `after` VARCHAR(64),
  `before` VARCHAR(64),
  `change_type` VARCHAR(64),
  `executable` VARCHAR(64),
  `instruction` VARCHAR(64),
  `diff_id` INT,
  PRIMARY KEY (`diff_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `dockerfile` (
  `dock_id` INT,
  `commits` INT,
  `docker_path` VARCHAR(64),
  `created_at` INT,
  `first_docker_commit` INT,
  `repo_id` INT,
  `i_size` INT,
  `project_project_id` INT,
  PRIMARY KEY (`dock_id`)
) CHARACTER SET latin1;

CREATE TABLE `entrypoints_params` (
  `entrypoint_id` INT,
  `entrypoints_params` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `project_id` INT,
  `git_url` VARCHAR(64),
  `created_at` INT,
  `i_forks` INT,
  `giturl` VARCHAR(64),
  `i_network_count` INT,
  `i_open_issues` INT,
  `i_owner_type` VARCHAR(64),
  `repo_id` INT,
  `repo_path` VARCHAR(64),
  `i_size` INT,
  `i_stargazers` INT,
  `i_subscribers` INT,
  `i_watchers` INT,
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;

CREATE TABLE `run_params` (
  `run_id` INT,
  `run_params` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `snap_diff` (
  `snap_id` INT,
  `diff_id` INT
) CHARACTER SET latin1;

CREATE TABLE `snapshot` (
  `snap_id` INT,
  `change_type` VARCHAR(64),
  `commit_date` INT,
  `del` INT,
  `from_date` INT,
  `image_is_automated` BOOL,
  `image_is_offical` BOOL,
  `commit_index` INT,
  `ins` INT,
  `instructions` INT,
  `current` BOOL,
  `repo_id` INT,
  `star_count` INT,
  `to_date` INT,
  `dock_id` INT,
  PRIMARY KEY (`snap_id`)
) CHARACTER SET latin1;

CREATE TABLE `violated_rules` (
  `dock_id` INT,
  `violated_rules` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_205815_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_205815_schema') AS relationships;
DROP DATABASE `db_205815_schema`;
UNINSTALL EXTENSION vsql_schematron;
