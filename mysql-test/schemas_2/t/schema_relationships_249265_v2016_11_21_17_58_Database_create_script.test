CREATE TABLE `CATGENOME.BUCKET` (
  `BUCKET_ID` INT,
  `BUCKET_NAME` VARCHAR(64),
  `ACCESS_KEY_ID` VARCHAR(64),
  `SECRET_ACCESS_KEY` VARCHAR(64),
  PRIMARY KEY (`BUCKET_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CATGENOME.BIOLOGICAL_DATA_ITEM` (
  `BIO_DATA_ITEM_ID` INT,
