INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 299938_1
--echo #
CREATE DATABASE `db_299938_1`;
USE `db_299938_1`;

CREATE TABLE `difficult` (
  `id` INT,
  `value` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ingredient` (
  `id` INT,
  `recipe_id` INT,
  `name` VARCHAR(64),
  `type_id` INT,
  `calories` DECIMAL(10,2),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ingredient_type` (
  `id` INT,
  `value` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipe` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `duration_in_hours` DECIMAL(10,2),
  `difficult_id` INT,
  `category_id` INT,
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subcategory` (
  `id` INT,
  `recipe_id` INT,
  `value` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_299938_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_299938_1') AS relationships;
DROP DATABASE `db_299938_1`;
UNINSTALL EXTENSION vsql_schematron;
