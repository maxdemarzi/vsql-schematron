INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228337_prod_mplv
--echo #
CREATE DATABASE `db_228337_prod_mplv`;
USE `db_228337_prod_mplv`;

CREATE TABLE `action_types` (
  `id` INT,
  `source_type` VARCHAR(255),
  `action` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email_change_petitions` (
  `id` INT,
  `user_id` INT,
  `old_email` VARCHAR(255),
  `new_email` VARCHAR(255),
  `token` VARCHAR(255),
  `confirmed` VARCHAR(255),
  `expires_at` DATETIME,
  `confirmed_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(255),
  `token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `product_pictures` (
  `id` INT,
  `product_id` INT,
  `path` VARCHAR(255),
  `default` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_points` (
  `id` INT,
  `user_id` INT,
  `action_type_id` INT,
  `source_id` INT,
  `points` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228337_prod_mplv') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228337_prod_mplv') AS relationships;
DROP DATABASE `db_228337_prod_mplv`;
UNINSTALL EXTENSION vsql_schematron;
