INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283942_inventory070
--echo #
CREATE DATABASE `db_283942_inventory070`;
USE `db_283942_inventory070`;

CREATE TABLE `categories` (
  `id` INT,
  `category_name` VARCHAR(64),
  `brand_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clients` (
  `id` INT,
  `client_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `description` VARCHAR(64),
  `rc` VARCHAR(64),
  `article` INT,
  `nif` INT,
  `nis` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `general_settings` (
  `id` INT,
  `store_name` VARCHAR(64),
  `activity` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `start_day` DATETIME,
  `image` VARCHAR(64),
  `investment_capital` DECIMAL(10,2),
  `rc` VARCHAR(64),
  `article` INT,
  `nif` INT,
  `nis` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission_user` (
  `permission_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `product_purchase` (
  `product_id` INT,
  `quantity` VARCHAR(64),
  `purchase_id` INT
) CHARACTER SET latin1;

CREATE TABLE `product_sale` (
  `product_id` INT,
  `quantity` VARCHAR(64),
  `sale_id` INT
) CHARACTER SET latin1;

CREATE TABLE `providers` (
  `id` INT,
  `provider_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `description` VARCHAR(64),
  `rc` VARCHAR(64),
  `article` INT,
  `nif` INT,
  `nis` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `purchases` (
  `id` INT,
  `number_purchase` VARCHAR(64),
  `total` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `total_amount` DECIMAL(10,2),
  `status` VARCHAR(64),
  `paid` DECIMAL(10,2),
  `due` DECIMAL(10,2),
  `provider_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `role_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `number_sale` VARCHAR(64),
  `total` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `total_amount` DECIMAL(10,2),
  `status` VARCHAR(64),
  `paid` DECIMAL(10,2),
  `due` DECIMAL(10,2),
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `spendings` (
  `id` INT,
  `spending_name` VARCHAR(64),
  `spending_description` VARCHAR(64),
  `spending_price` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `image` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283942_inventory070') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283942_inventory070') AS relationships;
DROP DATABASE `db_283942_inventory070`;
UNINSTALL EXTENSION vsql_schematron;
