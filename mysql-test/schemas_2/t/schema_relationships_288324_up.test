INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 288324_up
--echo #
CREATE DATABASE `db_288324_up`;
USE `db_288324_up`;
CREATE TABLE `manufacturers` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parts` (
  `id` INT NOT NULL,
  `manufacturer_id` INT,
  `name` TEXT,
  `description` TEXT,
  `amount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tagnames` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `tagname_id` INT,
  `value` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `part_tag` (
  `id` INT NOT NULL,
  `part_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_288324_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_288324_up') AS relationships;
DROP DATABASE `db_288324_up`;
UNINSTALL EXTENSION vsql_schematron;
