INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221314_data
--echo #
CREATE DATABASE `db_221314_data`;
USE `db_221314_data`;

CREATE TABLE `teacher` (
  `tid` INT,
  `tname` VARCHAR(64),
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `sid` INT,
  `sname` VARCHAR(64),
  `gender` VARCHAR(64),
  `class_id` INT,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `cid` INT,
  `cname` VARCHAR(64),
  `teacher_id` INT,
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;

CREATE TABLE `score` (
  `sid` INT,
  `student_id` INT,
  `course_id` INT,
  `number` INT,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221314_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221314_data') AS relationships;
DROP DATABASE `db_221314_data`;
UNINSTALL EXTENSION vsql_schematron;
