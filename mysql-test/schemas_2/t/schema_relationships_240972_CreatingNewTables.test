INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 240972_CreatingNewTables
--echo #
CREATE DATABASE `db_240972_CreatingNewTables`;
USE `db_240972_CreatingNewTables`;
CREATE TABLE `Employee2` (
  `EmployeeId` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `SSN` INT,
  `DeptId` INT,
  PRIMARY KEY (`EmployeeId`)
) CHARACTER SET latin1;
CREATE TABLE `Department` (
  `DeptId` INT NOT NULL,
  `Name` VARCHAR(50),
  `Location` VARCHAR(50),
  PRIMARY KEY (`DeptId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_240972_CreatingNewTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_240972_CreatingNewTables') AS relationships;
DROP DATABASE `db_240972_CreatingNewTables`;
UNINSTALL EXTENSION vsql_schematron;
