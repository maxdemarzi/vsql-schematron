INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277055_schema
--echo #
CREATE DATABASE `db_277055_schema`;
USE `db_277055_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` TEXT,
  `role` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
  `id` INT NOT NULL,
  `subject_name` TEXT,
  `password` TEXT,
  `content` TEXT,
  `require_permission` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `id` INT NOT NULL,
  `room_name` TEXT,
  `user_id` INT,
  `subject_id` INT,
  `visible` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `user_id` INT,
  `room_id` INT,
  `content` TEXT,
  `created_at` TIMESTAMP NULL,
  `visible` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subject_rights` (
  `id` INT NOT NULL,
  `user_id` INT,
  `subject_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277055_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277055_schema') AS relationships;
DROP DATABASE `db_277055_schema`;
UNINSTALL EXTENSION vsql_schematron;
