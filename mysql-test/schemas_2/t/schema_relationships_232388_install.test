INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232388_install
--echo #
CREATE DATABASE `db_232388_install`;
USE `db_232388_install`;

CREATE TABLE `classes` (
  `class_id` INT,
  `name` VARCHAR(255),
  `teacher_id` INT,
  `prefect_id` INT,
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `subject_id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `teacher_id` INT,
  `hash` VARCHAR(255),
  `name` VARCHAR(255),
  `birthday` VARCHAR(255),
  `sex` VARCHAR(255),
  `religion` VARCHAR(255),
  `profileUrl` VARCHAR(255),
  `blood_group` VARCHAR(255),
  `role` VARCHAR(255),
  `address` VARCHAR(255),
  `phone` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `country` VARCHAR(255),
  `county` VARCHAR(255),
  `subjects` VARCHAR(255),
  `authentication_key` VARCHAR(255),
  PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjectteacher` (
  `subject_id` INT,
  `teacher_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232388_install') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232388_install') AS relationships;
DROP DATABASE `db_232388_install`;
UNINSTALL EXTENSION vsql_schematron;
