INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289230_0_121518155437861
--echo #
CREATE DATABASE `db_289230_0_121518155437861`;
USE `db_289230_0_121518155437861`;

CREATE TABLE `actor` (
  `actor_id` INT,
  `actor_name` VARCHAR(255),
  PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;

CREATE TABLE `film` (
  `film_id` INT,
  `film_title` VARCHAR(255),
  PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;

CREATE TABLE `film_actor` (
  `actor_id` INT,
  `film_id` INT,
  PRIMARY KEY (`actor_id`, `film_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289230_0_121518155437861') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289230_0_121518155437861') AS relationships;
DROP DATABASE `db_289230_0_121518155437861`;
UNINSTALL EXTENSION vsql_schematron;
