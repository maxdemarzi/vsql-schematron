INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294519_garage
--echo #
CREATE DATABASE `db_294519_garage`;
USE `db_294519_garage`;

CREATE TABLE `appointments` (
  `id` INT,
  `name` VARCHAR(64),
  `comment` VARCHAR(64),
  `datetime` DATETIME,
  `status` VARCHAR(64),
  `car_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `id` INT,
  `plate` VARCHAR(64),
  `brand` VARCHAR(64),
  `type` VARCHAR(64),
  `customer_id` INT
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `zipcode` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `parts` (
  `id` INT,
  `name` VARCHAR(64),
  `brand` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `repairs` (
  `id` INT,
  `appointment_id` INT,
  `part_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294519_garage') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294519_garage') AS relationships;
DROP DATABASE `db_294519_garage`;
UNINSTALL EXTENSION vsql_schematron;
