INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 218033_V1.0.0__default_tables_schemas
--echo #
CREATE DATABASE `db_218033_V1_0_0__default_tables_schemas`;
USE `db_218033_V1_0_0__default_tables_schemas`;
CREATE TABLE `dog` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `rg` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vaccine` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `vaccine_date` DATE,
  `dog_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_218033_V1_0_0__default_tables_schemas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_218033_V1_0_0__default_tables_schemas') AS relationships;
DROP DATABASE `db_218033_V1_0_0__default_tables_schemas`;
UNINSTALL EXTENSION vsql_schematron;
