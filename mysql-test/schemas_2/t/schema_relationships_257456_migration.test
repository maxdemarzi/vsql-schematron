INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257456_migration
--echo #
CREATE DATABASE `db_257456_migration`;
USE `db_257456_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `bio` VARCHAR(64),
  `image` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Follower` (
  `userId` VARCHAR(64),
  `followingId` VARCHAR(64),
  PRIMARY KEY (`userId`, `followingId`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Article` (
  `id` VARCHAR(64),
  `authorId` VARCHAR(64),
  `slug` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `body` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ArticleToTag` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257456_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257456_migration') AS relationships;
DROP DATABASE `db_257456_migration`;
UNINSTALL EXTENSION vsql_schematron;
