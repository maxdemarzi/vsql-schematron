INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293666_creation
--echo #
CREATE DATABASE `db_293666_creation`;
USE `db_293666_creation`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `date_of_birth` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` INT,
  `name` VARCHAR(64),
  `genre` VARCHAR(64),
  `release_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `user_id` INT,
  `movie_id` INT,
  `rating` DECIMAL(10,2),
  `comment` VARCHAR(64),
  PRIMARY KEY (`user_id`, `movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `actors` (
  `id` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `date_of_birth` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lead` (
  `actor_id` INT,
  `movie_id` INT,
  PRIMARY KEY (`actor_id`, `movie_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293666_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293666_creation') AS relationships;
DROP DATABASE `db_293666_creation`;
UNINSTALL EXTENSION vsql_schematron;
