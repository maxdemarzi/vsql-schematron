INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 285763_Cria%C3%A7%C3%A3o%20da%20Base%20de%20Dados
--echo #
CREATE DATABASE `db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados`;
USE `db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados`;
CREATE TABLE `Fornecedor` (
  `cod_fornecedor` INT NOT NULL,
  `nome` VARCHAR(50),
  `morada` VARCHAR(50),
  `nif` DECIMAL(10,2),
  `telefone` DECIMAL(10,2),
  PRIMARY KEY (`cod_fornecedor`)
) CHARACTER SET latin1;
CREATE TABLE `Armazem` (
  `cod_armazem` INT NOT NULL,
  `nome` VARCHAR(50),
  `morada` VARCHAR(50),
  `cidade` VARCHAR(50),
  PRIMARY KEY (`cod_armazem`)
) CHARACTER SET latin1;
CREATE TABLE `ArmazemProduto` (
  `cod_armazem` INT,
  `cod_produto` INT,
  `stock` INT,
  `stock_minimo` INT,
  `corredor` VARCHAR(50),
  `prateleira` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados') AS relationships;
DROP DATABASE `db_285763_Cria_C3_A7_C3_A3o_20da_20Base_20de_20Dados`;
UNINSTALL EXTENSION vsql_schematron;
