INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281978_security_tables
--echo #
CREATE DATABASE `db_281978_security_tables`;
USE `db_281978_security_tables`;
CREATE TABLE `Authority` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `Id` INT NOT NULL,
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Email` VARCHAR(50),
  `Enabled` VARCHAR(50),
  `LastPasswordResetDate` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `UserAuthority` (
  `UserId` INT,
  `AuthorityId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281978_security_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281978_security_tables') AS relationships;
DROP DATABASE `db_281978_security_tables`;
UNINSTALL EXTENSION vsql_schematron;
