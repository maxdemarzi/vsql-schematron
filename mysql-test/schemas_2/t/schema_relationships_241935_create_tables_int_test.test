INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 241935_create-tables-int-test
--echo #
CREATE DATABASE `db_241935_create_tables_int_test`;
USE `db_241935_create_tables_int_test`;

CREATE TABLE `int_test_coin_basic_data` (
  `id` INT,
  `name` VARCHAR(64),
  `symbol` VARCHAR(64),
  `slug` VARCHAR(64),
  `image_url` VARCHAR(64),
  `circulating_supply` INT,
  `total_supply` INT,
  `max_supply` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `int_test_coin_quote` (
  `id` INT,
  `coin_id` INT,
  `quote` DECIMAL(10,2),
  `quoted_at` DATETIME,
  `volume_24h` DECIMAL(10,2),
  `market_cap` DECIMAL(10,2),
  `percent_change_1h` DECIMAL(10,2),
  `percent_change_24h` DECIMAL(10,2),
  `percent_change_7d` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_241935_create_tables_int_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_241935_create_tables_int_test') AS relationships;
DROP DATABASE `db_241935_create_tables_int_test`;
UNINSTALL EXTENSION vsql_schematron;
