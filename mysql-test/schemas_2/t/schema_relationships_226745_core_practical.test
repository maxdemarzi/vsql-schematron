INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226745_core_practical
--echo #
CREATE DATABASE `db_226745_core_practical`;
USE `db_226745_core_practical`;
CREATE TABLE `candidate` (
  `id` INT,
  `userid` INT,
  `firstname` VARCHAR(50),
  `middlename` VARCHAR(50),
  `lastname` VARCHAR(50),
  `education` VARCHAR(50),
  `language` VARCHAR(50),
  `expirience` VARCHAR(50),
  `currentctc` VARCHAR(50),
  `expectedctc` VARCHAR(50),
  `noticeperiod` VARCHAR(50),
  `interviewdate` DATE,
  `reasonleavejob` VARCHAR(50),
  `currentstatus` VARCHAR(50),
  `rejectedreason` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `profile_image` VARCHAR(50),
  `role` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226745_core_practical') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226745_core_practical') AS relationships;
DROP DATABASE `db_226745_core_practical`;
UNINSTALL EXTENSION vsql_schematron;
