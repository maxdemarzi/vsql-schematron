INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 222975_pbrowsedb
--echo #
CREATE DATABASE `db_222975_pbrowsedb`;
USE `db_222975_pbrowsedb`;

CREATE TABLE `users` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `nick` VARCHAR(64),
  `sessionkey` VARCHAR(64),
  `saved_config` VARCHAR(64),
  `activated` BOOL,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `id` INT,
  `username` VARCHAR(64),
  `token` VARCHAR(64),
  `funct` INT,
  `params` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `groups` (
  `name` VARCHAR(64),
  `owner` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `data` (
  `id` INT,
  `owner` VARCHAR(64),
  `trackname` VARCHAR(64),
  `description` VARCHAR(64),
  `path` VARCHAR(64),
  `format` VARCHAR(64),
  `ispublic` INT,
  `indexedby` INT,
  `isindex` BOOL,
  `remote` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `trackref` INT,
  `ctext` VARCHAR(64),
  `chromosome` VARCHAR(64),
  `startpos` INT,
  `endpos` INT,
  `creator` VARCHAR(64),
  `ispublic` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_222975_pbrowsedb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_222975_pbrowsedb') AS relationships;
DROP DATABASE `db_222975_pbrowsedb`;
UNINSTALL EXTENSION vsql_schematron;
