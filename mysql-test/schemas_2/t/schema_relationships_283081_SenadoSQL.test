INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283081_SenadoSQL
--echo #
CREATE DATABASE `db_283081_SenadoSQL`;
USE `db_283081_SenadoSQL`;
CREATE TABLE `escritorio` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `estado` VARCHAR(50),
  `setor` VARCHAR(50),
  `endereco` VARCHAR(50),
  `telefone` VARCHAR(50),
  `fax` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `imovel` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `auxilio_moradia` VARCHAR(50),
  `imovel_funcional` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `despesa` (
  `id` INT NOT NULL,
  `ano` INT,
  `mes` TINYINT,
  `senador` VARCHAR(50),
  `tipo_despesa` VARCHAR(50),
  `cnpj_cpf` VARCHAR(50),
  `fornecedor` VARCHAR(50),
  `documento` VARCHAR(50),
  `data_` VARCHAR(50),
  `detalhamento` VARCHAR(50),
  `valor_reembolsado` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aposentadoria` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `tipo` VARCHAR(50),
  `data_ini` VARCHAR(50),
  `data_fim` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contratos` (
  `numerocontratos` VARCHAR(50) NOT NULL,
  `unidadegestoria` VARCHAR(50),
  `contratada` VARCHAR(50),
  `cnpj` VARCHAR(50),
  `objeto` VARCHAR(50),
  `dataassinatura` VARCHAR(50),
  `datapublicacao` VARCHAR(50),
  `iniciovigencia` VARCHAR(50),
  `fimvigencia` VARCHAR(50),
  `modalidade` VARCHAR(50),
  `numerolicitacao` VARCHAR(50),
  `processo` VARCHAR(50),
  PRIMARY KEY (`numerocontratos`)
) CHARACTER SET latin1;
CREATE TABLE `comentario` (
  `id` INT NOT NULL,
  `idUsuario` INT,
  `url` VARCHAR(50),
  `commentUser` VARCHAR(50),
  `commentData` DATETIME,
  `commentText` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `createTime` DATETIME,
  `tentativas` INT,
  `bloqueado` BOOLEAN,
  PRIMARY KEY (`id`, `email`)
) CHARACTER SET latin1;
CREATE TABLE `log` (
  `id` INT NOT NULL,
  `createTime` DATETIME,
  `msg` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283081_SenadoSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283081_SenadoSQL') AS relationships;
DROP DATABASE `db_283081_SenadoSQL`;
UNINSTALL EXTENSION vsql_schematron;
