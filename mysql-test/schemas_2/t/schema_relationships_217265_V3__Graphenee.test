INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217265_V3__Graphenee
--echo #
CREATE DATABASE `db_217265_V3__Graphenee`;
USE `db_217265_V3__Graphenee`;
CREATE TABLE `gx_country` (
  `oid` INT NOT NULL,
  `is_active` BOOLEAN,
  `country_name` VARCHAR(50),
  `alpha3_code` VARCHAR(50),
  `numeric_code` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_state` (
  `oid` INT NOT NULL,
  `is_active` BOOLEAN,
  `state_name` VARCHAR(50),
  `state_code` VARCHAR(50),
  `oid_gx_country` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_city` (
  `oid` INT NOT NULL,
  `is_active` BOOLEAN,
  `city_name` VARCHAR(50),
  `oid_gx_country` INT,
  `oid_gx_state` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217265_V3__Graphenee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217265_V3__Graphenee') AS relationships;
DROP DATABASE `db_217265_V3__Graphenee`;
UNINSTALL EXTENSION vsql_schematron;
