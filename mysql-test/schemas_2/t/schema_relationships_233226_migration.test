INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233226_migration
--echo #
CREATE DATABASE `db_233226_migration`;
USE `db_233226_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `name` TEXT,
  `email` TEXT,
  `hashedPassword` TEXT,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `expiresAt` TIMESTAMP NULL,
  `handle` TEXT,
  `hashedSessionToken` TEXT,
  `antiCSRFToken` TEXT,
  `publicData` TEXT,
  `privateData` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Token` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `hashedToken` TEXT,
  `type` VARCHAR(50),
  `expiresAt` TIMESTAMP NULL,
  `sentTo` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Listing` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `category` TEXT,
  `tagline` TEXT,
  `img` TEXT,
  `logo` TEXT,
  `name` TEXT,
  `likes` INT,
  `tags` TEXT,
  `website` TEXT,
  `social` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233226_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233226_migration') AS relationships;
DROP DATABASE `db_233226_migration`;
UNINSTALL EXTENSION vsql_schematron;
