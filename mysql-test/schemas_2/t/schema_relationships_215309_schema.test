INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215309_schema
--echo #
CREATE DATABASE `db_215309_schema`;
USE `db_215309_schema`;

CREATE TABLE `clients` (
  `id` INT,
  `name` VARCHAR(255),
  `surname` VARCHAR(255),
  `tel` VARCHAR(255),
  `email` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `devices` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `devices_owners` (
  `deviceID` INT,
  `ownerIDi` INT,
  PRIMARY KEY (`deviceID`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `deviceID` INT,
  `clientID` INT,
  `inDate` INT,
  `outDate` INT,
  `state` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ordered_services` (
  `orderID` INT,
  `serviceID` INT,
  `price` DECIMAL(10,2),
  `startDate` INT,
  `endDate` INT,
  `description` VARCHAR(255),
  PRIMARY KEY (`orderID`, `serviceID`)
) CHARACTER SET latin1;

CREATE TABLE `services` (
  `id` INT,
  `name` VARCHAR(255),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `parts` (
  `id` INT,
  `name` VARCHAR(255),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tools` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accessories` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tools_accessories` (
  `toolID` INT,
  `accessoryID` INT,
  PRIMARY KEY (`toolID`, `accessoryID`)
) CHARACTER SET latin1;

CREATE TABLE `substances` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `quantity` INT,
  `unit` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215309_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215309_schema') AS relationships;
DROP DATABASE `db_215309_schema`;
UNINSTALL EXTENSION vsql_schematron;
