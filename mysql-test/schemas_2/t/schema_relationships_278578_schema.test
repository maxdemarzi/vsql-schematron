INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278578_schema
--echo #
CREATE DATABASE `db_278578_schema`;
USE `db_278578_schema`;

CREATE TABLE `student` (
  `id` INT,
  `jmbag` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `date_of_birth` DATETIME,
  `number_of_ects` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `id` INT,
  `name` VARCHAR(64),
  `number_of_ects` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student_course` (
  `course_id` INT,
  `student_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authority` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_authority` (
  `user_id` INT,
  `authority_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278578_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278578_schema') AS relationships;
DROP DATABASE `db_278578_schema`;
UNINSTALL EXTENSION vsql_schematron;
