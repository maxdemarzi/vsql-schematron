INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226083_test
--echo #
CREATE DATABASE `db_226083_test`;
USE `db_226083_test`;
CREATE TABLE `s_dept` (
  `dept_id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_emp` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `dept_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226083_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226083_test') AS relationships;
DROP DATABASE `db_226083_test`;
UNINSTALL EXTENSION vsql_schematron;
