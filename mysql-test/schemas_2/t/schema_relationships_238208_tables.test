INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 238208_tables
--echo #
CREATE DATABASE `db_238208_tables`;
USE `db_238208_tables`;

CREATE TABLE `pharmacies` (
  `id` INT,
  `title` VARCHAR(64),
  `phones` VARCHAR(64),
  `address` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drugs` (
  `id` INT,
  `title` VARCHAR(64),
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drugs_to_ph` (
  `id` INT,
  `ph_id` INT,
  `drug_id` INT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drugs_analogs` (
  `id` INT,
  `drug_id` INT,
  `analog_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_238208_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_238208_tables') AS relationships;
DROP DATABASE `db_238208_tables`;
UNINSTALL EXTENSION vsql_schematron;
