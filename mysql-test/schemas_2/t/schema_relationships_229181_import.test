INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 229181_import
--echo #
CREATE DATABASE `db_229181_import`;
USE `db_229181_import`;

CREATE TABLE `persistent_logins` (
  `username` VARCHAR(255),
  `series` VARCHAR(255),
  `token` VARCHAR(255),
  `last_used` DATETIME,
  PRIMARY KEY (`series`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `role_name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `role_id` INT,
  `user_id` INT,
  PRIMARY KEY (`role_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_229181_import') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_229181_import') AS relationships;
DROP DATABASE `db_229181_import`;
UNINSTALL EXTENSION vsql_schematron;
