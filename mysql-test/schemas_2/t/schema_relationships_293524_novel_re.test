INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293524_novel_re
--echo #
CREATE DATABASE `db_293524_novel_re`;
USE `db_293524_novel_re`;

CREATE TABLE `bookmarks` (
  `bookmark_id` INT,
  `user_id` INT,
  `novel_id` INT,
  `type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `comment_id` INT,
  `user_id` INT,
  `novel_id` INT,
  `content` VARCHAR(64),
  `state` INT,
  `delete_marker` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `genre_id` INT,
  `genre` VARCHAR(64),
  PRIMARY KEY (`genre_id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `image_id` INT,
  `foreign_id` INT,
  `usage` VARCHAR(64),
  `path_to_image` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `size` INT,
  `extension` VARCHAR(64),
  `affiliation` VARCHAR(64),
  `created_at` DATETIME,
  `update_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `novels` (
  `novel_id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `original_title` VARCHAR(64),
  `alternative_title` VARCHAR(64),
  `year_release` INT,
  `description` VARCHAR(64),
  `developer` VARCHAR(64),
  `type` VARCHAR(64),
  `duration` VARCHAR(64),
  `platforms` VARCHAR(64),
  `age_rating` VARCHAR(64),
  `country` VARCHAR(64),
  `language` VARCHAR(64),
  `views` INT,
  `state` INT,
  `delete_marker` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`novel_id`)
) CHARACTER SET latin1;

CREATE TABLE `novels-genres` (
  `relation_id` INT,
  `novel_id` INT,
  `genre_id` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `role` VARCHAR(64),
  `online` INT,
  `state` INT,
  `delete_marker` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293524_novel_re') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293524_novel_re') AS relationships;
DROP DATABASE `db_293524_novel_re`;
UNINSTALL EXTENSION vsql_schematron;
