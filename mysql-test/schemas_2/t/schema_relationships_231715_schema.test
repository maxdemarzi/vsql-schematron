INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231715_schema
--echo #
CREATE DATABASE `db_231715_schema`;
USE `db_231715_schema`;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `username` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `temperature_humidity` (
  `id` BIGINT NOT NULL,
  `humidity` VARCHAR(50),
  `temp` VARCHAR(50),
  `read_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231715_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231715_schema') AS relationships;
DROP DATABASE `db_231715_schema`;
UNINSTALL EXTENSION vsql_schematron;
