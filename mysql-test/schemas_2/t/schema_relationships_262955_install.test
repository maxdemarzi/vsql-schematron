INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 262955_install
--echo #
CREATE DATABASE `db_262955_install`;
USE `db_262955_install`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `password` VARCHAR(50),
  `created_on` DATETIME,
  `updated_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emloyees` (
  `id` INT NOT NULL,
  `user_id` INT,
  `organization_name` VARCHAR(50),
  `state_id` INT,
  `created_on` DATETIME,
  `updated_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_262955_install') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_262955_install') AS relationships;
DROP DATABASE `db_262955_install`;
UNINSTALL EXTENSION vsql_schematron;
