INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 261739_up
--echo #
CREATE DATABASE `db_261739_up`;
USE `db_261739_up`;

CREATE TABLE `Atlas` (
  `id` INT,
  `tiling_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `AtlasVertex` (
  `id` INT,
  `atlas_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `AtlasEdge` (
  `id` INT,
  `atlas_id` INT,
  `polygon_point_id` INT,
  `source_id` INT,
  `sink_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_261739_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_261739_up') AS relationships;
DROP DATABASE `db_261739_up`;
UNINSTALL EXTENSION vsql_schematron;
