INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 209135_schema
--echo #
CREATE DATABASE `db_209135_schema`;
USE `db_209135_schema`;

CREATE TABLE `Beers` (
  `name` VARCHAR(64),
  `manf` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Bars` (
  `name` VARCHAR(64),
  `addr` VARCHAR(64),
  `license` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Drinkers` (
  `name` VARCHAR(64),
  `addr` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Sells` (
  `bar` VARCHAR(64),
  `beer` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`bar`, `beer`)
) CHARACTER SET latin1;

CREATE TABLE `Likes` (
  `drinker` VARCHAR(64),
  `beer` VARCHAR(64),
  PRIMARY KEY (`drinker`, `beer`)
) CHARACTER SET latin1;

CREATE TABLE `Frequents` (
  `drinker` VARCHAR(64),
  `bar` VARCHAR(64),
  PRIMARY KEY (`drinker`, `bar`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_209135_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_209135_schema') AS relationships;
DROP DATABASE `db_209135_schema`;
UNINSTALL EXTENSION vsql_schematron;
