INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294012_upgrade.base.v1
--echo #
CREATE DATABASE `db_294012_upgrade_base_v1`;
USE `db_294012_upgrade_base_v1`;

CREATE TABLE `ArticleBlog` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `title` VARCHAR(64),
  `subtitle` VARCHAR(64),
  `content` VARCHAR(64),
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articleblog_tag` (
  `articleblog_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`articleblog_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag_articleblog` (
  `tag_id` INT,
  `articleblog_id` INT,
  PRIMARY KEY (`tag_id`, `articleblog_id`)
) CHARACTER SET latin1;

CREATE TABLE `ArticleBlog_tags` (
  `articleblog_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`articleblog_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294012_upgrade_base_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294012_upgrade_base_v1') AS relationships;
DROP DATABASE `db_294012_upgrade_base_v1`;
UNINSTALL EXTENSION vsql_schematron;
