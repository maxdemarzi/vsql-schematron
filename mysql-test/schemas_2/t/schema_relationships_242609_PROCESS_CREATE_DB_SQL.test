CREATE DATABASE `db_242609_PROCESS_CREATE_DB_SQL`;
USE `db_242609_PROCESS_CREATE_DB_SQL`;

CREATE TABLE `personnel_table` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `tc` VARCHAR(64),
  `workStartDate` DATETIME,
  `birthDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

