INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 218227_script
--echo #
CREATE DATABASE `db_218227_script`;
USE `db_218227_script`;
CREATE TABLE `EVENTS` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `ACTIVITY` VARCHAR(50),
  `TYPE` INT,
  `MAXPPL` INT,
  `MINPPL` INT,
  `ATMPPL` INT,
  `OWNER` VARCHAR(50),
  `APP` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PARTICIPANTS` (
  `PARTICIPANT_ID` VARCHAR(50) NOT NULL,
  `EVENTS_ID` INT NOT NULL,
  `APP` VARCHAR(50),
  PRIMARY KEY (`PARTICIPANT_ID`, `EVENTS_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_218227_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_218227_script') AS relationships;
DROP DATABASE `db_218227_script`;
UNINSTALL EXTENSION vsql_schematron;
