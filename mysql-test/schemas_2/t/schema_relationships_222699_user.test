INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 222699_user
--echo #
CREATE DATABASE `db_222699_user`;
USE `db_222699_user`;

CREATE TABLE `user` (
  `id` VARCHAR(64),
  `local_id` VARCHAR(64),
  `display_name` VARCHAR(64),
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `location_user_assignment` (
  `location_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  PRIMARY KEY (`location_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `group` (
  `id` VARCHAR(64),
  `local_id` VARCHAR(64),
  `display_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_user_assignment` (
  `group_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  PRIMARY KEY (`group_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `location_group_assignment` (
  `location_id` VARCHAR(64),
  `group_id` VARCHAR(64),
  PRIMARY KEY (`location_id`, `group_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_222699_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_222699_user') AS relationships;
DROP DATABASE `db_222699_user`;
UNINSTALL EXTENSION vsql_schematron;
