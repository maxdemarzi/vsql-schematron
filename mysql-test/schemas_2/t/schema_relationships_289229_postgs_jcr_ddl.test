INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289229_postgs_jcr_ddl
--echo #
CREATE DATABASE `db_289229_postgs_jcr_ddl`;
USE `db_289229_postgs_jcr_ddl`;
CREATE TABLE `cloud_provider_config` (
  `id` BIGINT NOT NULL,
  `provider` VARCHAR(50),
  `access_key` VARCHAR(50),
  `secrate_key` VARCHAR(50),
  `bucket` VARCHAR(50),
  `end_point` VARCHAR(50),
  `permission_mode` VARCHAR(50),
  `permission_mode_value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cloud_context_path` (
  `id` BIGINT NOT NULL,
  `provider` VARCHAR(50),
  `plugin` VARCHAR(50),
  `path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
  `id` BIGINT NOT NULL,
  `file_name` VARCHAR(50),
  `local_file_path` VARCHAR(50),
  `cloud_file_path` VARCHAR(50),
  `client_type` VARCHAR(50),
  `client_id` BIGINT,
  `cloud_context_path_id` BIGINT,
  `cdn` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289229_postgs_jcr_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289229_postgs_jcr_ddl') AS relationships;
DROP DATABASE `db_289229_postgs_jcr_ddl`;
UNINSTALL EXTENSION vsql_schematron;
