INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232932__000_dev4
--echo #
CREATE DATABASE `db_232932__000_dev4`;
USE `db_232932__000_dev4`;
CREATE TABLE `a_parent` (
  `id` INT NOT NULL,
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232932__000_dev4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232932__000_dev4') AS relationships;
DROP DATABASE `db_232932__000_dev4`;
UNINSTALL EXTENSION vsql_schematron;
