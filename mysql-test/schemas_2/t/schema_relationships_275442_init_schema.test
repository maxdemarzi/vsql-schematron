INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 275442_init-schema
--echo #
CREATE DATABASE `db_275442_init_schema`;
USE `db_275442_init_schema`;

CREATE TABLE `tbl_member` (
  `id` VARCHAR(64),
  `full_name` VARCHAR(64),
  `email_addr` VARCHAR(64),
  `city` VARCHAR(64),
  `state_prov` VARCHAR(64),
  `zip_code` VARCHAR(64),
  `date_created` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_account` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `access_code` VARCHAR(64),
  `member_id` VARCHAR(64),
  `date_created` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_club` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `activity` VARCHAR(64),
  `date_created` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_membership` (
  `member_id` VARCHAR(64),
  `club_id` VARCHAR(64),
  `member_alias` VARCHAR(64),
  `member_status` VARCHAR(64),
  `date_created` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`member_id`, `club_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_275442_init_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_275442_init_schema') AS relationships;
DROP DATABASE `db_275442_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
