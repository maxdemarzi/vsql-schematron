INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297459_V003__create_poll_submission
--echo #
CREATE DATABASE `db_297459_V003__create_poll_submission`;
USE `db_297459_V003__create_poll_submission`;
CREATE TABLE `poll_submission` (
  `id` BIGINT NOT NULL,
  `cfg` BIGINT,
  `user` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `poll_submission_time` (
  `submission` BIGINT NOT NULL,
  `cfg` BIGINT,
  `time` TIME NOT NULL,
  `value` SMALLINT,
  PRIMARY KEY (`submission`, `time`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297459_V003__create_poll_submission') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297459_V003__create_poll_submission') AS relationships;
DROP DATABASE `db_297459_V003__create_poll_submission`;
UNINSTALL EXTENSION vsql_schematron;
