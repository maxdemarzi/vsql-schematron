INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204183_V1__Create_Initial_Schema
--echo #
CREATE DATABASE `db_204183_V1__Create_Initial_Schema`;
USE `db_204183_V1__Create_Initial_Schema`;
CREATE TABLE `public.department` (
  `department_id` INT NOT NULL,
  `department_name` VARCHAR(50),
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `public.employee` (
  `employee_id` INT NOT NULL,
  `employee_firstname` VARCHAR(50),
  `employee_lastname` VARCHAR(50),
  `department_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204183_V1__Create_Initial_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204183_V1__Create_Initial_Schema') AS relationships;
DROP DATABASE `db_204183_V1__Create_Initial_Schema`;
UNINSTALL EXTENSION vsql_schematron;
