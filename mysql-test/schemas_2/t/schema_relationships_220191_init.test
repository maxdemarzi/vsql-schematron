INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220191_init
--echo #
CREATE DATABASE `db_220191_init`;
USE `db_220191_init`;

CREATE TABLE `country` (
  `id` INT,
  `code` VARCHAR(64),
  `phone_code` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `phone` (
  `id` INT,
  `phone_number` VARCHAR(64),
  `is_active` INT,
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `id` INT,
  `phone_id` INT,
  `date` DATETIME,
  `special_id` INT,
  `message_text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220191_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220191_init') AS relationships;
DROP DATABASE `db_220191_init`;
UNINSTALL EXTENSION vsql_schematron;
