INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 282434_TP3
--echo #
CREATE DATABASE `db_282434_TP3`;
USE `db_282434_TP3`;

CREATE TABLE `Equipe` (
  `numEquipe` DECIMAL(10,2),
  `nom` VARCHAR(64),
  `capaciteStade` DECIMAL(10,2),
  `budget` DECIMAL(10,2),
  PRIMARY KEY (`numEquipe`)
) CHARACTER SET latin1;

CREATE TABLE `Joueur` (
  `numJoueur` DECIMAL(10,2),
  `nom` VARCHAR(64),
  `prenom` VARCHAR(64),
  `nationalite` VARCHAR(64),
  `nbSelection` DECIMAL(10,2),
  `numEquipe` DECIMAL(10,2),
  PRIMARY KEY (`numJoueur`)
) CHARACTER SET latin1;

CREATE TABLE `Competition` (
  `numComp` DECIMAL(10,2),
  `nom` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`numComp`)
) CHARACTER SET latin1;

CREATE TABLE `Participer` (
  `numComp` DECIMAL(10,2),
  `numEquipe` DECIMAL(10,2),
  `resultat` DECIMAL(10,2),
  PRIMARY KEY (`numComp`, `numEquipe`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_282434_TP3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_282434_TP3') AS relationships;
DROP DATABASE `db_282434_TP3`;
UNINSTALL EXTENSION vsql_schematron;
