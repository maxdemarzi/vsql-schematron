INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 243878_V1_initial_schema
--echo #
CREATE DATABASE `db_243878_V1_initial_schema`;
USE `db_243878_V1_initial_schema`;

CREATE TABLE `FEATURE_TOGGLES` (
  `technical_name` VARCHAR(255),
  `display_name` VARCHAR(255),
  `expires_on` DATETIME,
  `description` VARCHAR(255),
  `inverted` DECIMAL(10,2),
  PRIMARY KEY (`technical_name`)
) CHARACTER SET latin1;

CREATE TABLE `TOGGLE_CUSTOMERS` (
  `customer_id` VARCHAR(255),
  `toggle_technical_name` VARCHAR(255),
  PRIMARY KEY (`customer_id`, `toggle_technical_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_243878_V1_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_243878_V1_initial_schema') AS relationships;
DROP DATABASE `db_243878_V1_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
