INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239597_create_db
--echo #
CREATE DATABASE `db_239597_create_db`;
USE `db_239597_create_db`;

CREATE TABLE `users` (
  `uid` INT,
  `timeCreated` DATETIME,
  `realName` VARCHAR(255),
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `bio` VARCHAR(255),
  `isAdmin` INT,
  `score` INT,
  `userRank` INT,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `patterns` (
  `uid` INT,
  `timeCreated` DATETIME,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `numObjects` INT,
  `GIF` VARCHAR(255),
  `difficulty` DECIMAL(10,2),
  `avgHighScoreCatch` DECIMAL(10,2),
  `avgHighScoreTime` DECIMAL(10,2),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `records` (
  `uid` INT,
  `userUID` INT,
  `patternUID` INT,
  `isPersonalBest` INT,
  `score` DECIMAL(10,2),
  `recordRank` INT,
  `catches` INT,
  `duration` DATETIME,
  `timeRecorded` DATETIME,
  `video` VARCHAR(255),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239597_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239597_create_db') AS relationships;
DROP DATABASE `db_239597_create_db`;
UNINSTALL EXTENSION vsql_schematron;
