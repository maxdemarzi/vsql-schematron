INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 201193_0_instances_users_up
--echo #
CREATE DATABASE `db_201193_0_instances_users_up`;
USE `db_201193_0_instances_users_up`;

CREATE TABLE `instances` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `activated_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profiles` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `instance_id` VARCHAR(64),
  `role` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `id` INT,
  `user_id` VARCHAR(64),
  `profile_id` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME,
  `expires_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_201193_0_instances_users_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_201193_0_instances_users_up') AS relationships;
DROP DATABASE `db_201193_0_instances_users_up`;
UNINSTALL EXTENSION vsql_schematron;
