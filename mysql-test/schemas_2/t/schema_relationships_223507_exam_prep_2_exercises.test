INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 223507_exam_prep_2_exercises
--echo #
CREATE DATABASE `db_223507_exam_prep_2_exercises`;
USE `db_223507_exam_prep_2_exercises`;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `best_before` DATETIME,
  `price` DECIMAL(10,2),
  `description` VARCHAR(64),
  `category_id` INT,
  `picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `towns` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` INT,
  `name` VARCHAR(64),
  `town_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stores` (
  `id` INT,
  `name` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `has_parking` VARCHAR(64),
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products_stores` (
  `product_id` INT,
  `store_id` INT,
  PRIMARY KEY (`product_id`, `store_id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `hire_date` DATETIME,
  `manager_id` INT,
  `store_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_223507_exam_prep_2_exercises') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_223507_exam_prep_2_exercises') AS relationships;
DROP DATABASE `db_223507_exam_prep_2_exercises`;
UNINSTALL EXTENSION vsql_schematron;
