INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 282607_V004__create-tables-cashier-and-sale-cashier
--echo #
CREATE DATABASE `db_282607_V004__create_tables_cashier_and_sale_cashier`;
USE `db_282607_V004__create_tables_cashier_and_sale_cashier`;
CREATE TABLE `cashier` (
  `id` VARCHAR(50) NOT NULL,
  `closing_date` DATETIME,
  `opening_date` DATETIME,
  `status` TINYINT,
  `total_value` DECIMAL(10,2),
  `value_reported` DECIMAL(10,2),
  `cards_value` DECIMAL(10,2),
  `money_value` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sale_cashier` (
  `cashier_id` VARCHAR(50),
  `sale_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_282607_V004__create_tables_cashier_and_sale_cashier') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_282607_V004__create_tables_cashier_and_sale_cashier') AS relationships;
DROP DATABASE `db_282607_V004__create_tables_cashier_and_sale_cashier`;
UNINSTALL EXTENSION vsql_schematron;
