INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273847_schema
--echo #
CREATE DATABASE `db_273847_schema`;
USE `db_273847_schema`;

CREATE TABLE `comp_department` (
  `id` INT,
  `comp_department` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comp_position` (
  `id` INT,
  `title` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `department_desc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `manager` (
  `id` INT,
  `manager_name` VARCHAR(64),
  `department_desc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `comp_pos_name` VARCHAR(64),
  `manager_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273847_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273847_schema') AS relationships;
DROP DATABASE `db_273847_schema`;
UNINSTALL EXTENSION vsql_schematron;
