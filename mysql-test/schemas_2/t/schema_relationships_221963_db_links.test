INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221963_db_links
--echo #
CREATE DATABASE `db_221963_db_links`;
USE `db_221963_db_links`;
CREATE TABLE `links` (
  `link_id` INT,
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `description` TEXT,
  `user_id` INT,
  `createdby` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `fullname` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221963_db_links') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221963_db_links') AS relationships;
DROP DATABASE `db_221963_db_links`;
UNINSTALL EXTENSION vsql_schematron;
