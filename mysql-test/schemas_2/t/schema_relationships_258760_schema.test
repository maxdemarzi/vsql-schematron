INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258760_schema
--echo #
CREATE DATABASE `db_258760_schema`;
USE `db_258760_schema`;

CREATE TABLE `pubs` (
  `id` INT,
  `abstract` VARCHAR(64),
  `arxiv` VARCHAR(64),
  `bibcode` VARCHAR(64),
  `doi` VARCHAR(64),
  `keep` INT,
  `nfas` VARCHAR(64),
  `refdata` VARCHAR(64),
  `title` VARCHAR(64),
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `author_names` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `authors` (
  `type` INT,
  `pubid` INT,
  `idx` INT,
  `authid` INT
) CHARACTER SET latin1;

CREATE TABLE `history` (
  `date` INT,
  `pubid` INT,
  `action` INT,
  PRIMARY KEY (`date`)
) CHARACTER SET latin1;

CREATE TABLE `nicknames` (
  `nickname` VARCHAR(64),
  `pubid` INT,
  PRIMARY KEY (`nickname`)
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `pubid` INT,
  `note` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `pdfs` (
  `sha1` VARCHAR(64),
  `pubid` INT,
  PRIMARY KEY (`sha1`)
) CHARACTER SET latin1;

CREATE TABLE `publists` (
  `name` VARCHAR(64),
  `idx` INT,
  `pubid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258760_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258760_schema') AS relationships;
DROP DATABASE `db_258760_schema`;
UNINSTALL EXTENSION vsql_schematron;
