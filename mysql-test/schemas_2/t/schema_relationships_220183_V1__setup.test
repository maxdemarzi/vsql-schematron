INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220183_V1__setup
--echo #
CREATE DATABASE `db_220183_V1__setup`;
USE `db_220183_V1__setup`;
CREATE TABLE `groups` (
  `id` VARCHAR(50) NOT NULL,
  `code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `group_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `droplets` (
  `id` VARCHAR(50) NOT NULL,
  `created` TIMESTAMP NULL,
  `url` VARCHAR(50),
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `image_url` VARCHAR(50),
  `is_read` BOOLEAN,
  `user_id` VARCHAR(50),
  `group_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220183_V1__setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220183_V1__setup') AS relationships;
DROP DATABASE `db_220183_V1__setup`;
UNINSTALL EXTENSION vsql_schematron;
