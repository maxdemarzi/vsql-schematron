INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257778_database
--echo #
CREATE DATABASE `db_257778_database`;
USE `db_257778_database`;
CREATE TABLE `entries` (
  `eid` INT NOT NULL,
  `summary` VARCHAR(50),
  `body` TEXT,
  `imagepath` TEXT,
  PRIMARY KEY (`eid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `tid` SMALLINT NOT NULL,
  `tag` TEXT,
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
CREATE TABLE `tag_group` (
  `eid` INT NOT NULL,
  `tid` INT NOT NULL,
  PRIMARY KEY (`eid`, `tid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257778_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257778_database') AS relationships;
DROP DATABASE `db_257778_database`;
UNINSTALL EXTENSION vsql_schematron;
