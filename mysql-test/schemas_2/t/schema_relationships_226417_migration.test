INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226417_migration
--echo #
CREATE DATABASE `db_226417_migration`;
USE `db_226417_migration`;

CREATE TABLE `PostalCode` (
  `code` VARCHAR(64),
  `province` VARCHAR(64),
  `type` VARCHAR(64),
  `hotspot` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `Riding` (
  `province` VARCHAR(64),
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `population` INT,
  `area` INT,
  `url` VARCHAR(64),
  `mppName` VARCHAR(64),
  `mppDesignation` VARCHAR(64),
  `mppFirstName` VARCHAR(64),
  `mppLastName` VARCHAR(64),
  `mppEmail` VARCHAR(64),
  `mppPhone` VARCHAR(64),
  `mppParty` VARCHAR(64),
  `mppUrl` VARCHAR(64),
  PRIMARY KEY (`province`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `PostalCodeToRiding` (
  `postal` VARCHAR(64),
  `province` VARCHAR(64),
  `ridingId` VARCHAR(64),
  `weight` DECIMAL(10,2),
  PRIMARY KEY (`postal`, `province`, `ridingId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226417_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226417_migration') AS relationships;
DROP DATABASE `db_226417_migration`;
UNINSTALL EXTENSION vsql_schematron;
