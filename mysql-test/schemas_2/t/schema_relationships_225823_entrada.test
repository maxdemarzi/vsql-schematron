INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 225823_entrada
--echo #
CREATE DATABASE `db_225823_entrada`;
USE `db_225823_entrada`;
CREATE TABLE `tbUSUARIO` (
  `id_ususario` INT NOT NULL,
  `usuario` VARCHAR(50),
  `password` VARCHAR(50),
  `telefono` VARCHAR(50),
  `direccion` VARCHAR(50),
  `edad` INT,
  PRIMARY KEY (`id_ususario`)
) CHARACTER SET latin1;
CREATE TABLE `tbCURSO` (
  `id_curso` INT NOT NULL,
  `descripcion` VARCHAR(50),
  PRIMARY KEY (`id_curso`)
) CHARACTER SET latin1;
CREATE TABLE `tbASIGNACION` (
  `id_asignacion` INT NOT NULL,
  `id_ususario` INT,
  `id_curso` INT,
  PRIMARY KEY (`id_asignacion`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_225823_entrada') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_225823_entrada') AS relationships;
DROP DATABASE `db_225823_entrada`;
UNINSTALL EXTENSION vsql_schematron;
