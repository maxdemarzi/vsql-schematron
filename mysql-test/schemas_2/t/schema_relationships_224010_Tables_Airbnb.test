INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224010_Tables_Airbnb
--echo #
CREATE DATABASE `db_224010_Tables_Airbnb`;
USE `db_224010_Tables_Airbnb`;

CREATE TABLE `usuario` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `state` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `city` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `state_id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `amenity` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `place` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `user_id` VARCHAR(64),
  `name` VARCHAR(64),
  `city_id` VARCHAR(64),
  `description` VARCHAR(64),
  `number_rooms` DECIMAL(10,2),
  `number_bathrooms` DECIMAL(10,2),
  `max_guest` DECIMAL(10,2),
  `price_by_night` DECIMAL(10,2),
  `latitud` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `review` (
  `id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `user_id` VARCHAR(64),
  `place_id` VARCHAR(64),
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `placeamenity` (
  `amenity_id` VARCHAR(64),
  `place_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224010_Tables_Airbnb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224010_Tables_Airbnb') AS relationships;
DROP DATABASE `db_224010_Tables_Airbnb`;
UNINSTALL EXTENSION vsql_schematron;
