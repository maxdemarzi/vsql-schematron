INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 211685_structure
--echo #
CREATE DATABASE `db_211685_structure`;
USE `db_211685_structure`;
CREATE TABLE `project` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `color` VARCHAR(50),
  `assignees` VARCHAR(50),
  `status` INT,
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `phone` VARCHAR(50),
  `auth_key` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `password_reset_token` VARCHAR(50),
  `role` INT,
  `status` INT,
  `created_at` INT,
  `updated_at` INT,
  `theme` VARCHAR(50),
  `api_key` VARCHAR(50),
  `pin_hash` VARCHAR(50),
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clock` (
  `id` INT NOT NULL,
  `user_id` INT,
  `clock_in` INT,
  `clock_out` INT,
  `note` VARCHAR(50),
  `created_at` INT,
  `updated_at` INT,
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `holiday` (
  `year` INT NOT NULL,
  `month` INT NOT NULL,
  `day` INT NOT NULL,
  PRIMARY KEY (`year`, `month`, `day`)
) CHARACTER SET latin1;
CREATE TABLE `off` (
  `id` INT NOT NULL,
  `user_id` INT,
  `start_at` DATE,
  `end_at` DATE,
  `note` VARCHAR(50),
  `type` INT,
  `approved` INT,
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_211685_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_211685_structure') AS relationships;
DROP DATABASE `db_211685_structure`;
UNINSTALL EXTENSION vsql_schematron;
