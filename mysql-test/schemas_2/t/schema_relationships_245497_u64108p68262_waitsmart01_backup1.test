INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 245497_u64108p68262_waitsmart01_backup1
--echo #
CREATE DATABASE `db_245497_u64108p68262_waitsmart01_backup1`;
USE `db_245497_u64108p68262_waitsmart01_backup1`;

CREATE TABLE `address` (
  `street` VARCHAR(255),
  `streetnumber` INT,
  `city` VARCHAR(255),
  `state` VARCHAR(255),
  `postalcode` INT,
  `country` VARCHAR(255),
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shop` (
  `name` VARCHAR(255),
  `space` INT,
  `typebussiness` VARCHAR(255),
  `id` INT,
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `firstname` VARCHAR(255),
  `lastname` VARCHAR(255),
  `age` INT,
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `timestamp` DATETIME,
  `address_id` INT
) CHARACTER SET latin1;

CREATE TABLE `usershop` (
  `user_email` VARCHAR(255),
  `shop_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_245497_u64108p68262_waitsmart01_backup1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_245497_u64108p68262_waitsmart01_backup1') AS relationships;
DROP DATABASE `db_245497_u64108p68262_waitsmart01_backup1`;
UNINSTALL EXTENSION vsql_schematron;
