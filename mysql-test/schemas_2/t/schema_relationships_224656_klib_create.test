INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224656_klib_create
--echo #
CREATE DATABASE `db_224656_klib_create`;
USE `db_224656_klib_create`;
CREATE TABLE `authors` (
  `id` INT NOT NULL,
  `nick` VARCHAR(50),
  `firstname` CHAR(50),
  `lastname` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `id` INT NOT NULL,
  `author_id` INT,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `article_id` INT,
  `author_id` INT,
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224656_klib_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224656_klib_create') AS relationships;
DROP DATABASE `db_224656_klib_create`;
UNINSTALL EXTENSION vsql_schematron;
