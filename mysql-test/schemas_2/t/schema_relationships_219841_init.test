INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 219841_init
--echo #
CREATE DATABASE `db_219841_init`;
USE `db_219841_init`;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `contact_number` VARCHAR(50),
  `media` VARCHAR(50),
  `conversation_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations` (
  `id` INT NOT NULL,
  `started_at` DATETIME,
  `finished_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_219841_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_219841_init') AS relationships;
DROP DATABASE `db_219841_init`;
UNINSTALL EXTENSION vsql_schematron;
