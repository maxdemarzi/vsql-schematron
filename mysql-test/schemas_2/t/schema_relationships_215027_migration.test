INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215027_migration
--echo #
CREATE DATABASE `db_215027_migration`;
USE `db_215027_migration`;
CREATE TABLE `Project` (
  `id` INT NOT NULL,
  `projectName` TEXT,
  `accountId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Schema` (
  `id` INT NOT NULL,
  `schemaName` TEXT,
  `projectId` INT,
  `accountId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SchemaField` (
  `id` INT NOT NULL,
  `fieldName` TEXT,
  `fieldType` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `schemaId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Content` (
  `id` INT NOT NULL,
  `accountId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Assets` (
  `id` INT NOT NULL,
  `accountId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
  `id` INT NOT NULL,
  `uuid` TEXT,
  `identifier` TEXT,
  `authProvider` TEXT,
  `password` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `bio` TEXT,
  `accountId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Config` (
  `id` INT NOT NULL,
  `key` TEXT,
  `value` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215027_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215027_migration') AS relationships;
DROP DATABASE `db_215027_migration`;
UNINSTALL EXTENSION vsql_schematron;
