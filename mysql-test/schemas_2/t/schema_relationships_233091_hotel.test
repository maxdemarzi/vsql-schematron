INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233091_hotel
--echo #
CREATE DATABASE `db_233091_hotel`;
USE `db_233091_hotel`;
CREATE TABLE `booking` (
  `id_boking` INT,
  `id_kamar` INT,
  `nama_customer` VARCHAR(50),
  `no_telp` VARCHAR(50),
  `tgl_in` DATETIME,
  `tgl_out` DATETIME,
  `pembayaran` VARCHAR(50),
  `status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `fasilitas` (
  `id_fasilitas` INT NOT NULL,
  `fasilitas` VARCHAR(50),
  PRIMARY KEY (`id_fasilitas`)
) CHARACTER SET latin1;
CREATE TABLE `kamar` (
  `id_kamar` INT,
  `id_fasilitas` INT,
  `stok` INT,
  `jenis_kamar` VARCHAR(50),
  `harga` INT
) CHARACTER SET latin1;
CREATE TABLE `login` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233091_hotel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233091_hotel') AS relationships;
DROP DATABASE `db_233091_hotel`;
UNINSTALL EXTENSION vsql_schematron;
