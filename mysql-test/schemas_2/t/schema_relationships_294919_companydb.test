INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294919_companydb
--echo #
CREATE DATABASE `db_294919_companydb`;
USE `db_294919_companydb`;

CREATE TABLE `department` (
  `department_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `role_id` INT,
  `title` VARCHAR(64),
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `employee_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `manager_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294919_companydb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294919_companydb') AS relationships;
DROP DATABASE `db_294919_companydb`;
UNINSTALL EXTENSION vsql_schematron;
