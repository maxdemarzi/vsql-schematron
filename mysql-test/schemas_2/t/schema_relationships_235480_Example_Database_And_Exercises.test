INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235480_Example_Database_And_Exercises
--echo #
CREATE DATABASE `db_235480_Example_Database_And_Exercises`;
USE `db_235480_Example_Database_And_Exercises`;

CREATE TABLE `Courses` (
  `CourseID` INT,
  `CourseName` VARCHAR(64),
  `TeacherID` INT,
  PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;

CREATE TABLE `Teachers` (
  `TeacherID` INT,
  `TeacherName` VARCHAR(64),
  PRIMARY KEY (`TeacherID`)
) CHARACTER SET latin1;

CREATE TABLE `Students` (
  `StudentID` INT,
  `StudentName` VARCHAR(64),
  PRIMARY KEY (`StudentID`)
) CHARACTER SET latin1;

CREATE TABLE `StudentCourses` (
  `CourseID` INT,
  `StudentID` INT,
  PRIMARY KEY (`CourseID`, `StudentID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235480_Example_Database_And_Exercises') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235480_Example_Database_And_Exercises') AS relationships;
DROP DATABASE `db_235480_Example_Database_And_Exercises`;
UNINSTALL EXTENSION vsql_schematron;
