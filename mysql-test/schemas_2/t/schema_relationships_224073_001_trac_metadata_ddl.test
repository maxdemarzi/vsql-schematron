INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224073_001__trac_metadata.ddl
--echo #
CREATE DATABASE `db_224073_001_trac_metadata_ddl`;
USE `db_224073_001_trac_metadata_ddl`;

CREATE TABLE `tenant` (
  `tenant_id` INT,
  `tenant_code` VARCHAR(64),
  PRIMARY KEY (`tenant_id`)
) CHARACTER SET latin1;

CREATE TABLE `object_id` (
  `tenant_id` INT,
  `object_pk` INT,
  `object_type` VARCHAR(64),
  `object_id_hi` INT,
  `object_id_lo` INT,
  PRIMARY KEY (`object_pk`)
) CHARACTER SET latin1;

CREATE TABLE `object_definition` (
  `tenant_id` INT,
  `definition_pk` INT,
  `object_fk` INT,
  `object_version` INT,
  `object_timestamp` DATETIME,
  `object_superseded` DATETIME,
  `object_is_latest` BOOL,
  `definition` VARCHAR(64),
  PRIMARY KEY (`definition_pk`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `tenant_id` INT,
  `tag_pk` INT,
  `definition_fk` INT,
  `tag_version` INT,
  `tag_timestamp` DATETIME,
  `tag_superseded` DATETIME,
  `tag_is_latest` BOOL,
  `object_type` VARCHAR(64),
  PRIMARY KEY (`tag_pk`)
) CHARACTER SET latin1;

CREATE TABLE `tag_attr` (
  `tenant_id` INT,
  `tag_fk` INT,
  `attr_name` VARCHAR(64),
  `attr_index` INT,
  `attr_type` VARCHAR(64),
  `attr_value_boolean` BOOL,
  `attr_value_integer` INT,
  `attr_value_float` DECIMAL(10,2),
  `attr_value_string` VARCHAR(64),
  `attr_value_decimal` DECIMAL(10,2),
  `attr_value_date` DATETIME,
  `attr_value_datetime` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224073_001_trac_metadata_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224073_001_trac_metadata_ddl') AS relationships;
DROP DATABASE `db_224073_001_trac_metadata_ddl`;
UNINSTALL EXTENSION vsql_schematron;
