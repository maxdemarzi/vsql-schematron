INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 229598_ods_weather
--echo #
CREATE DATABASE `db_229598_ods_weather`;
USE `db_229598_ods_weather`;

CREATE TABLE `weather_temperature` (
  `date` DATETIME,
  `min` DECIMAL(10,2),
  `max` DECIMAL(10,2),
  `normal_min` DECIMAL(10,2),
  `normal_max` DECIMAL(10,2),
  PRIMARY KEY (`date`)
) CHARACTER SET latin1;

CREATE TABLE `weather_precipitation` (
  `date` DATETIME,
  `precipitation` VARCHAR(64),
  `precipitation_normal` DECIMAL(10,2),
  PRIMARY KEY (`date`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_229598_ods_weather') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_229598_ods_weather') AS relationships;
DROP DATABASE `db_229598_ods_weather`;
UNINSTALL EXTENSION vsql_schematron;
