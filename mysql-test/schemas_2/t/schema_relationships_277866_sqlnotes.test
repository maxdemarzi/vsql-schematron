INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277866_sqlnotes
--echo #
CREATE DATABASE `db_277866_sqlnotes`;
USE `db_277866_sqlnotes`;

CREATE TABLE `cart` (
  `id` INT,
  `userId` INT,
  `sessionId` VARCHAR(64),
  `token` VARCHAR(64),
  `status` INT,
  `firstName` VARCHAR(64),
  `middleName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `mobile` VARCHAR(64),
  `email` VARCHAR(64),
  `line1` VARCHAR(64),
  `line2` VARCHAR(64),
  `city` VARCHAR(64),
  `province` VARCHAR(64),
  `country` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart_item` (
  `id` INT,
  `productId` INT,
  `cartId` INT,
  `sku` VARCHAR(64),
  `price` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `quantity` INT,
  `active` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `parentId` INT,
  `title` VARCHAR(64),
  `metaTitle` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `userId` INT,
  `sessionId` VARCHAR(64),
  `token` VARCHAR(64),
  `status` INT,
  `subTotal` DECIMAL(10,2),
  `itemDiscount` DECIMAL(10,2),
  `tax` DECIMAL(10,2),
  `shipping` DECIMAL(10,2),
  `total` DECIMAL(10,2),
  `promo` VARCHAR(64),
  `discount` DECIMAL(10,2),
  `grandTotal` DECIMAL(10,2),
  `firstName` VARCHAR(64),
  `middleName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `mobile` VARCHAR(64),
  `email` VARCHAR(64),
  `line1` VARCHAR(64),
  `line2` VARCHAR(64),
  `city` VARCHAR(64),
  `province` VARCHAR(64),
  `country` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_item` (
  `id` INT,
  `productId` INT,
  `orderId` INT,
  `sku` VARCHAR(64),
  `price` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `quantity` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_category` (
  `productId` INT,
  `categoryId` INT,
  PRIMARY KEY (`productId`, `categoryId`)
) CHARACTER SET latin1;

CREATE TABLE `product_review` (
  `id` INT,
  `productId` INT,
  `parentId` INT,
  `title` VARCHAR(64),
  `rating` INT,
  `published` INT,
  `createdAt` DATETIME,
  `publishedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_tag` (
  `productId` INT,
  `tagId` INT,
  PRIMARY KEY (`productId`, `tagId`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `title` VARCHAR(64),
  `metaTitle` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `userId` INT,
  `orderId` INT,
  `code` VARCHAR(64),
  `type` INT,
  `mode` INT,
  `status` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277866_sqlnotes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277866_sqlnotes') AS relationships;
DROP DATABASE `db_277866_sqlnotes`;
UNINSTALL EXTENSION vsql_schematron;
