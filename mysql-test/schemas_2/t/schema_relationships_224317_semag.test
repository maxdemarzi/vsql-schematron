INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224317_semag
--echo #
CREATE DATABASE `db_224317_semag`;
USE `db_224317_semag`;

CREATE TABLE `semag` (
  `_id` INT,
  `mitzvahId` INT,
  `mitzvahNumber` INT,
  `category` INT,
  `semagTitle` VARCHAR(64),
  `source` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `semagNotes` (
  `_id` INT,
  `hebrewNote` VARCHAR(64),
  `enNote` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224317_semag') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224317_semag') AS relationships;
DROP DATABASE `db_224317_semag`;
UNINSTALL EXTENSION vsql_schematron;
