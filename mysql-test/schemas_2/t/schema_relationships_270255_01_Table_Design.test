INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 270255_01.Table_Design
--echo #
CREATE DATABASE `db_270255_01_Table_Design`;
USE `db_270255_01_Table_Design`;
CREATE TABLE `coaches` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `coach_level` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skills_data` (
  `id` INT NOT NULL,
  `dribbling` INT,
  `pace` INT,
  `passing` INT,
  `shooting` INT,
  `speed` INT,
  `strength` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `towns` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stadiums` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `capacity` INT,
  `town_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `established` DATE,
  `fan_base` BIGINT,
  `stadium_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `players` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `age` INT,
  `position` CHAR(50),
  `salary` DECIMAL(10,2),
  `hire_date` DATETIME,
  `skills_data_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `players_coaches` (
  `player_id` INT NOT NULL,
  `coach_id` INT NOT NULL,
  PRIMARY KEY (`player_id`, `coach_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_270255_01_Table_Design') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_270255_01_Table_Design') AS relationships;
DROP DATABASE `db_270255_01_Table_Design`;
UNINSTALL EXTENSION vsql_schematron;
