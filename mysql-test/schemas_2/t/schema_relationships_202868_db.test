INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202868_db
--echo #
CREATE DATABASE `db_202868_db`;
USE `db_202868_db`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passwords` (
  `user_id` VARCHAR(64),
  `salt` VARCHAR(64),
  `hash` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_attempts` (
  `user_id` VARCHAR(64),
  `successful` BOOL,
  `at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_changes` (
  `user_id` VARCHAR(64),
  `at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `permission_assignments` (
  `user_id` VARCHAR(64),
  `permission` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tables` (
  `id` INT,
  `owner` VARCHAR(64),
  `name` VARCHAR(64),
  `seats` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chat_messages` (
  `id` INT,
  `table_id` INT,
  `sender` VARCHAR(64),
  `msg` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202868_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202868_db') AS relationships;
DROP DATABASE `db_202868_db`;
UNINSTALL EXTENSION vsql_schematron;
