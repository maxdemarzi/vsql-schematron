INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 256884_menagjimiibursave
--echo #
CREATE DATABASE `db_256884_menagjimiibursave`;
USE `db_256884_menagjimiibursave`;
CREATE TABLE `Selected` (
  `idStudentit` INT NOT NULL,
  `emri` VARCHAR(50),
  `mbiemri` VARCHAR(50),
  `ditelindja` DATE,
  `mesatarja` DOUBLE,
  `email` VARCHAR(50),
  `numri` VARCHAR(50),
  `qyteti` VARCHAR(50),
  `adresa` VARCHAR(50),
  `VitiiStudimeve` INT,
  `NiveliiStudimeve` VARCHAR(50),
  `fakulteti` VARCHAR(50),
  `drejtimi` VARCHAR(50),
  `bursa` VARCHAR(50),
  PRIMARY KEY (`idStudentit`)
) CHARACTER SET latin1;
CREATE TABLE `login` (
  `username` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `aplikuesit` (
  `id` INT NOT NULL,
  `idStudentit` INT,
  `emri` VARCHAR(50),
  `mbiemri` VARCHAR(50),
  `ditelindja` DATE,
  `mesatarja` DOUBLE,
  `email` VARCHAR(50),
  `numri` VARCHAR(50),
  `qyteti` VARCHAR(50),
  `adresa` VARCHAR(50),
  `VitiiStudimeve` INT,
  `NiveliiStudimeve` VARCHAR(50),
  `fakulteti` VARCHAR(50),
  `drejtimi` VARCHAR(50),
  `bursa` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_256884_menagjimiibursave') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_256884_menagjimiibursave') AS relationships;
DROP DATABASE `db_256884_menagjimiibursave`;
UNINSTALL EXTENSION vsql_schematron;
