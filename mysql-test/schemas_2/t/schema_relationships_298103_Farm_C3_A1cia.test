INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 298103_Farm%C3%A1cia
--echo #
CREATE DATABASE `db_298103_Farm_C3_A1cia`;
USE `db_298103_Farm_C3_A1cia`;

CREATE TABLE `tb_categoria` (
  `id` INT,
  `categoria` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_produtos` (
  `id` INT,
  `nome` VARCHAR(64),
  `preço` DECIMAL(10,2),
  `quantidade` INT,
  `id_produto` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_298103_Farm_C3_A1cia') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_298103_Farm_C3_A1cia') AS relationships;
DROP DATABASE `db_298103_Farm_C3_A1cia`;
UNINSTALL EXTENSION vsql_schematron;
