INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277782_cookbook
--echo #
CREATE DATABASE `db_277782_cookbook`;
USE `db_277782_cookbook`;

CREATE TABLE `dishes` (
  `id` INT,
  `title` VARCHAR(64),
  `big_img` VARCHAR(64),
  `small_img` VARCHAR(64),
  `description` VARCHAR(64),
  `user_id` INT,
  `category_id` INT,
  `views` INT,
  `rating` DECIMAL(10,2),
  `complexity` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dish_steps` (
  `id` INT,
  `step_number` INT,
  `img` VARCHAR(64),
  `text` VARCHAR(64),
  `dish_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `ingredients` (
  `id` INT,
  `ingredients_name` VARCHAR(64),
  `quantity` VARCHAR(64),
  `measure_id` INT,
  `dish_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277782_cookbook') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277782_cookbook') AS relationships;
DROP DATABASE `db_277782_cookbook`;
UNINSTALL EXTENSION vsql_schematron;
