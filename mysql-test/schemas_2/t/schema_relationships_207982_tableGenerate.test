INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 207982_tableGenerate
--echo #
CREATE DATABASE `db_207982_tableGenerate`;
USE `db_207982_tableGenerate`;

CREATE TABLE `mydb.Movie` (
  `idMovie` VARCHAR(64),
  `title` VARCHAR(64),
  `isAdult` INT,
  `releaseYear` INT,
  `runtimeMinutes` INT,
  `rating` DECIMAL(10,2),
  `numVotes` INT,
  `imgUrl` VARCHAR(64),
  PRIMARY KEY (`idMovie`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.WritersAndDirectors` (
  `idWritersAndDirectors` VARCHAR(64),
  `name` VARCHAR(64),
  `birthYear` INT,
  `deathYear` INT,
  PRIMARY KEY (`idWritersAndDirectors`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.GenresByMovie` (
  `idGenre` INT,
  `idMovie` VARCHAR(64),
  PRIMARY KEY (`idGenre`, `idMovie`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.Opinion` (
  `idUser` INT,
  `idMovie` VARCHAR(64),
  `ocena` DECIMAL(10,2),
  `opinion` VARCHAR(64),
  PRIMARY KEY (`idUser`, `idMovie`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.Team` (
  `idWritersAndDirectors` VARCHAR(64),
  `idMovie` VARCHAR(64),
  `director` INT,
  `writer` INT,
  PRIMARY KEY (`idWritersAndDirectors`, `idMovie`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_207982_tableGenerate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_207982_tableGenerate') AS relationships;
DROP DATABASE `db_207982_tableGenerate`;
UNINSTALL EXTENSION vsql_schematron;
