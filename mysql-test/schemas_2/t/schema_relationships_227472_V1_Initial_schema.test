INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227472_V1__Initial_schema
--echo #
CREATE DATABASE `db_227472_V1_Initial_schema`;
USE `db_227472_V1_Initial_schema`;

CREATE TABLE `collection` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cdx` (
  `id` INT,
  `collection_id` INT,
  `path` VARCHAR(64),
  `total_docs` INT,
  `total_bytes` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `crawl_series` (
  `id` INT,
  `name` VARCHAR(64),
  `path` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `crawl` (
  `id` INT,
  `name` VARCHAR(64),
  `total_docs` INT,
  `total_bytes` INT,
  `crawl_series_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cdx_crawl` (
  `cdx_id` INT,
  `crawl_id` INT,
  PRIMARY KEY (`cdx_id`, `crawl_id`)
) CHARACTER SET latin1;

CREATE TABLE `import_task` (
  `id` INT,
  `job_path` VARCHAR(64),
  `crawl_series_id` INT,
  `state` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227472_V1_Initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227472_V1_Initial_schema') AS relationships;
DROP DATABASE `db_227472_V1_Initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
