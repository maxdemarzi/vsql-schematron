INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235772_V1_5__Epost_tabell
--echo #
CREATE DATABASE `db_235772_V1_5__Epost_tabell`;
USE `db_235772_V1_5__Epost_tabell`;
CREATE TABLE `EPOST` (
  `epost_id` DECIMAL(10,2) NOT NULL,
  `mottaker` VARCHAR(50),
  `emne` VARCHAR(50),
  `innhold` VARCHAR(50),
  `sendt` DECIMAL(10,2),
  PRIMARY KEY (`epost_id`)
) CHARACTER SET latin1;
CREATE TABLE `EPOST_VEDLEGG` (
  `epost_vedlegg_id` DECIMAL(10,2) NOT NULL,
  `epost_id` DECIMAL(10,2),
  `innhold` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`epost_vedlegg_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235772_V1_5__Epost_tabell') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235772_V1_5__Epost_tabell') AS relationships;
DROP DATABASE `db_235772_V1_5__Epost_tabell`;
UNINSTALL EXTENSION vsql_schematron;
