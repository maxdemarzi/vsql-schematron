INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 254258_createdb
--echo #
CREATE DATABASE `db_254258_createdb`;
USE `db_254258_createdb`;

CREATE TABLE `Yelp_User` (
  `user_id` VARCHAR(64),
  `name` VARCHAR(64),
  `yelping_since` DATETIME,
  `review_count` INT,
  `friend_count` INT,
  `avg_stars` DECIMAL(10,2),
  `vote_count` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `Business` (
  `bid` VARCHAR(64),
  `if_open` DECIMAL(10,2),
  `city` VARCHAR(64),
  `b_state` VARCHAR(64),
  `review_count` INT,
  `bname` VARCHAR(64),
  `stars` DECIMAL(10,2),
  PRIMARY KEY (`bid`)
) CHARACTER SET latin1;

CREATE TABLE `Category` (
  `bid` VARCHAR(64),
  `catg` VARCHAR(64),
  PRIMARY KEY (`bid`, `catg`)
) CHARACTER SET latin1;

CREATE TABLE `Subcategory` (
  `bid` VARCHAR(64),
  `subcatg` VARCHAR(64),
  PRIMARY KEY (`bid`, `subcatg`)
) CHARACTER SET latin1;

CREATE TABLE `Attribute` (
  `bid` VARCHAR(64),
  `attribute` VARCHAR(64),
  PRIMARY KEY (`bid`, `attribute`)
) CHARACTER SET latin1;

CREATE TABLE `Review` (
  `rid` VARCHAR(64),
  `user_id` VARCHAR(64),
  `bid` VARCHAR(64),
  `useful_vote_count` INT,
  `stars` DECIMAL(10,2),
  `rdate` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`rid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_254258_createdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_254258_createdb') AS relationships;
DROP DATABASE `db_254258_createdb`;
UNINSTALL EXTENSION vsql_schematron;
