INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 255038_roomie.ddl
--echo #
CREATE DATABASE `db_255038_roomie_ddl`;
USE `db_255038_roomie_ddl`;

CREATE TABLE `Tenant` (
  `ID` INT,
  `AvatarID` INT,
  `Name` VARCHAR(64),
  `Email` VARCHAR(64),
  `Username` VARCHAR(64),
  `Phone` VARCHAR(64),
  `BirthDate` DATETIME,
  `Sex` VARCHAR(64),
  `Nif` VARCHAR(64),
  `Nationality` VARCHAR(64),
  `Occupation` VARCHAR(64),
  `Password` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `House` (
  `ID` INT,
  `LandlordID` INT,
  `Address` VARCHAR(64),
  `Title` VARCHAR(64),
  `Rooms` INT,
  `AvailableRooms` INT,
  `BathRooms` INT,
  `MinPrice` DECIMAL(10,2),
  `MaxPrice` DECIMAL(10,2),
  `Description` VARCHAR(64),
  `Features` VARCHAR(64),
  `LandlordIndex` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Photo` (
  `ID` INT,
  `HouseID` INT,
  `Path` VARCHAR(64),
  `HouseIndex` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Landlord` (
  `ID` INT,
  `AvatarID` INT,
  `Name` VARCHAR(64),
  `Email` VARCHAR(64),
  `Username` VARCHAR(64),
  `BirthDate` DATETIME,
  `Sex` VARCHAR(64),
  `Nif` VARCHAR(64),
  `Address` VARCHAR(64),
  `Password` VARCHAR(64),
  `Phone` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `RentHistory` (
  `HouseID` INT,
  `TenantID` INT,
  `BDate` DATETIME,
  `EDate` DATETIME,
  PRIMARY KEY (`HouseID`, `TenantID`)
) CHARACTER SET latin1;

CREATE TABLE `Application` (
  `TenantID` INT,
  `HouseID` INT,
  `ToBeAssessed` BOOL,
  `Accepted` BOOL,
  PRIMARY KEY (`TenantID`, `HouseID`)
) CHARACTER SET latin1;

CREATE TABLE `LandlordEvaluation` (
  `LandlordID` INT,
  `TenantID` INT,
  `Cleanliness` DECIMAL(10,2),
  `Payment` DECIMAL(10,2),
  `Care` DECIMAL(10,2),
  PRIMARY KEY (`LandlordID`, `TenantID`)
) CHARACTER SET latin1;

CREATE TABLE `TenantEvaluation` (
  `EvaluatorID` INT,
  `EvaluatedID` INT,
  `Tidiness` DECIMAL(10,2),
  `Cleanliness` DECIMAL(10,2),
  `Privacy` DECIMAL(10,2),
  `Friendliness` DECIMAL(10,2),
  PRIMARY KEY (`EvaluatorID`, `EvaluatedID`)
) CHARACTER SET latin1;

CREATE TABLE `Avatar` (
  `ID` INT,
  `Path` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_255038_roomie_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_255038_roomie_ddl') AS relationships;
DROP DATABASE `db_255038_roomie_ddl`;
UNINSTALL EXTENSION vsql_schematron;
