INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295111_schema
--echo #
CREATE DATABASE `db_295111_schema`;
USE `db_295111_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `password_salt` VARCHAR(50),
  `cookie_token` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pub` (
  `id` INT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `status_update` (
  `user_id` INT,
  `pub_id` INT,
  `timestamp` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295111_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295111_schema') AS relationships;
DROP DATABASE `db_295111_schema`;
UNINSTALL EXTENSION vsql_schematron;
