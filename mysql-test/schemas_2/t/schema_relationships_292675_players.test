INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 292675_players
--echo #
CREATE DATABASE `db_292675_players`;
USE `db_292675_players`;
CREATE TABLE `team_details` (
  `id` BIGINT NOT NULL,
  `created_at` BIGINT,
  `updated_at` BIGINT,
  `team_code` INT,
  `team_name` VARCHAR(50),
  `ranking_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ranking_details` (
  `id` BIGINT NOT NULL,
  `created_at` BIGINT,
  `updated_at` BIGINT,
  `team_id` INT,
  `test_ranking` INT,
  `odi_ranking` INT,
  `t20_ranking` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_292675_players') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_292675_players') AS relationships;
DROP DATABASE `db_292675_players`;
UNINSTALL EXTENSION vsql_schematron;
