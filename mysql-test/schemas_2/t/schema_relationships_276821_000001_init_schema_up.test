INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276821_000001_init_schema.up
--echo #
CREATE DATABASE `db_276821_000001_init_schema_up`;
USE `db_276821_000001_init_schema_up`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `answers` VARCHAR(50),
  `correct` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `group_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tests` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_questions` (
  `id` BIGINT NOT NULL,
  `question_id` BIGINT,
  `test_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276821_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276821_000001_init_schema_up') AS relationships;
DROP DATABASE `db_276821_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
