INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 286278_sql%20penambahan
--echo #
CREATE DATABASE `db_286278_sql_20penambahan`;
USE `db_286278_sql_20penambahan`;

CREATE TABLE `m_produk` (
  `id` INT,
  `kodeproduk` VARCHAR(64),
  `namaproduk` VARCHAR(64),
  `id_bag` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m_harga` (
  `id` INT,
  `hargaproduk` DECIMAL(10,2),
  `hargapcsrate` DECIMAL(10,2),
  `potongan1` DECIMAL(10,2),
  `potongan2` DECIMAL(10,2),
  `potongan3` DECIMAL(10,2),
  `idproduk` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_286278_sql_20penambahan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_286278_sql_20penambahan') AS relationships;
DROP DATABASE `db_286278_sql_20penambahan`;
UNINSTALL EXTENSION vsql_schematron;
