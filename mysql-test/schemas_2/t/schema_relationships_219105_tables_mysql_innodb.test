INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 219105_tables_mysql_innodb
--echo #
CREATE DATABASE `db_219105_tables_mysql_innodb`;
USE `db_219105_tables_mysql_innodb`;

CREATE TABLE `QRTZ_JOB_DETAILS` (
  `SCHED_NAME` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `JOB_CLASS_NAME` VARCHAR(64),
  `IS_DURABLE` VARCHAR(64),
  `IS_NONCONCURRENT` VARCHAR(64),
  `IS_UPDATE_DATA` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `NEXT_FIRE_TIME` INT,
  `PREV_FIRE_TIME` INT,
  `PRIORITY` INT,
  `TRIGGER_STATE` VARCHAR(64),
  `TRIGGER_TYPE` VARCHAR(64),
  `START_TIME` INT,
  `END_TIME` INT,
  `CALENDAR_NAME` VARCHAR(64),
  `MISFIRE_INSTR` INT,
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SIMPLE_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `REPEAT_COUNT` INT,
  `REPEAT_INTERVAL` INT,
  `TIMES_TRIGGERED` INT,
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CRON_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `CRON_EXPRESSION` VARCHAR(64),
  `TIME_ZONE_ID` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SIMPROP_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `STR_PROP_1` VARCHAR(64),
  `STR_PROP_2` VARCHAR(64),
  `STR_PROP_3` VARCHAR(64),
  `INT_PROP_1` INT,
  `INT_PROP_2` INT,
  `LONG_PROP_1` INT,
  `LONG_PROP_2` INT,
  `DEC_PROP_1` DECIMAL(10,2),
  `DEC_PROP_2` DECIMAL(10,2),
  `BOOL_PROP_1` VARCHAR(64),
  `BOOL_PROP_2` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_BLOB_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `BLOB_DATA` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CALENDARS` (
  `SCHED_NAME` VARCHAR(64),
  `CALENDAR_NAME` VARCHAR(64),
  `CALENDAR` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `CALENDAR_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_PAUSED_TRIGGER_GRPS` (
  `SCHED_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_FIRED_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `ENTRY_ID` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `INSTANCE_NAME` VARCHAR(64),
  `FIRED_TIME` INT,
  `SCHED_TIME` INT,
  `PRIORITY` INT,
  `STATE` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `IS_NONCONCURRENT` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `ENTRY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SCHEDULER_STATE` (
  `SCHED_NAME` VARCHAR(64),
  `INSTANCE_NAME` VARCHAR(64),
  `LAST_CHECKIN_TIME` INT,
  `CHECKIN_INTERVAL` INT,
  PRIMARY KEY (`SCHED_NAME`, `INSTANCE_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_LOCKS` (
  `SCHED_NAME` VARCHAR(64),
  `LOCK_NAME` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `LOCK_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `CRNX_PREVIOUS_TO_AFTER_TRIGGERS` (
  `SCHED_NAME` VARCHAR(64),
  `PREVIOUS_TRIGGER_NAME` VARCHAR(64),
  `PREVIOUS_TRIGGER_GROUP` VARCHAR(64),
  `AFTER_TRIGGER_NAME` VARCHAR(64),
  `AFTER_TRIGGER_GROUP` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `PREVIOUS_TRIGGER_NAME`, `PREVIOUS_TRIGGER_GROUP`, `AFTER_TRIGGER_NAME`, `AFTER_TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `CRNX_TRIGGER_HISTORY` (
  `SCHED_NAME` VARCHAR(64),
  `SCHED_INSTANCE_ID` VARCHAR(64),
  `CONTEXT_KEY` VARCHAR(64),
  `FIRE_KEY` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `START_TIME` DATETIME,
  `END_TIME` DATETIME,
  `INPUT` VARCHAR(64),
  `OUTPUT` VARCHAR(64),
  `RUN_STATUS` VARCHAR(64),
  `EXCEPTION` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `CONTEXT_KEY`, `FIRE_KEY`, `START_TIME`)
) CHARACTER SET latin1;

CREATE TABLE `CRNX_PREV_FIRE_KEYS` (
  `SCHED_NAME` VARCHAR(64),
  `CONTEXT_KEY` VARCHAR(64),
  `FIRE_KEY` VARCHAR(64),
  `PREV_FIRE_KEY` VARCHAR(64),
  PRIMARY KEY (`SCHED_NAME`, `CONTEXT_KEY`, `FIRE_KEY`, `PREV_FIRE_KEY`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_219105_tables_mysql_innodb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_219105_tables_mysql_innodb') AS relationships;
DROP DATABASE `db_219105_tables_mysql_innodb`;
UNINSTALL EXTENSION vsql_schematron;
