INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283486_pizzeria-db
--echo #
CREATE DATABASE `db_283486_pizzeria_db`;
USE `db_283486_pizzeria_db`;
CREATE TABLE `pizzas` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pizza_ingredient` (
  `id` INT NOT NULL,
  `pizza_id` INT,
  `ingredient_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `order_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
  `id` INT NOT NULL,
  `pizza_id` INT,
  `order_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283486_pizzeria_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283486_pizzeria_db') AS relationships;
DROP DATABASE `db_283486_pizzeria_db`;
UNINSTALL EXTENSION vsql_schematron;
