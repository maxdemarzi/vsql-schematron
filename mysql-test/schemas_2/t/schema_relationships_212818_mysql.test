INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212818_mysql
--echo #
CREATE DATABASE `db_212818_mysql`;
USE `db_212818_mysql`;

CREATE TABLE `Students` (
  `id` INT,
  `name` VARCHAR(64),
  `nick` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `emp_no` INT,
  `birth_date` DATETIME,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `hire_date` DATETIME,
  PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;

CREATE TABLE `dept_emp` (
  `emp_no` INT,
  `dept_no` VARCHAR(64),
  `from_date` DATETIME,
  `to_date` DATETIME,
  PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212818_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212818_mysql') AS relationships;
DROP DATABASE `db_212818_mysql`;
UNINSTALL EXTENSION vsql_schematron;
