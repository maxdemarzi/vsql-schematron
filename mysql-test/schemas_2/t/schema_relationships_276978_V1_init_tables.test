INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276978_V1_init_tables
--echo #
CREATE DATABASE `db_276978_V1_init_tables`;
USE `db_276978_V1_init_tables`;

CREATE TABLE `${schemakeeper_schema}.schema_type` (
  `schema_type_name` VARCHAR(64),
  PRIMARY KEY (`schema_type_name`)
) CHARACTER SET latin1;

CREATE TABLE `${schemakeeper_schema}.compatibility_type` (
  `compatibility_type_name` VARCHAR(64),
  PRIMARY KEY (`compatibility_type_name`)
) CHARACTER SET latin1;

CREATE TABLE `${schemakeeper_schema}.subject` (
  `subject_name` VARCHAR(64),
  `compatibility_type_name` VARCHAR(64),
  `is_locked` VARCHAR(64),
  `creation_ts` DATETIME,
  PRIMARY KEY (`subject_name`)
) CHARACTER SET latin1;

CREATE TABLE `${schemakeeper_schema}.schema_info` (
  `schema_id` INT,
  `schema_type_name` VARCHAR(64),
  `schema_text` VARCHAR(64),
  `schema_hash` VARCHAR(64),
  `creation_ts` DATETIME,
  PRIMARY KEY (`schema_id`)
) CHARACTER SET latin1;

CREATE TABLE `${schemakeeper_schema}.subject_schema` (
  `subject_name` VARCHAR(64),
  `schema_id` INT,
  `version` INT,
  `creation_ts` DATETIME,
  PRIMARY KEY (`subject_name`, `schema_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276978_V1_init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276978_V1_init_tables') AS relationships;
DROP DATABASE `db_276978_V1_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
