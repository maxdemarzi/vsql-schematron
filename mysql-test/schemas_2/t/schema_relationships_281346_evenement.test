INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281346_evenement
--echo #
CREATE DATABASE `db_281346_evenement`;
USE `db_281346_evenement`;

CREATE TABLE `typeEvenement` (
  `id` INT,
  `intitule` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `evenement` (
  `id` INT,
  `idTypeEvenement` INT,
  `idUniversite` INT,
  `dateDebut` DATETIME,
  `dateFin` DATETIME,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281346_evenement') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281346_evenement') AS relationships;
DROP DATABASE `db_281346_evenement`;
UNINSTALL EXTENSION vsql_schematron;
