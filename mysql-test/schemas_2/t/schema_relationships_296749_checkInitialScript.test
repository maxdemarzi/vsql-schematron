INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 296749_checkInitialScript
--echo #
CREATE DATABASE `db_296749_checkInitialScript`;
USE `db_296749_checkInitialScript`;
CREATE TABLE `trade.customers` (
  `cid` INT NOT NULL,
  `cust_name` VARCHAR(50),
  `addr` VARCHAR(50),
  `tid` INT,
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `trade.portfolio` (
  `cid` INT NOT NULL,
  `sid` INT NOT NULL,
  `qty` INT,
  `availQty` INT,
  `tid` INT,
  PRIMARY KEY (`cid`, `sid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_296749_checkInitialScript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_296749_checkInitialScript') AS relationships;
DROP DATABASE `db_296749_checkInitialScript`;
UNINSTALL EXTENSION vsql_schematron;
