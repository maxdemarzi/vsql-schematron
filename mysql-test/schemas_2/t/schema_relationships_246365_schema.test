INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246365_schema
--echo #
CREATE DATABASE `db_246365_schema`;
USE `db_246365_schema`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `condos` (
  `id` INT,
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `owner_id` INT,
  `price` INT,
  `pets` BOOL,
  `guests` INT,
  `description` VARCHAR(64),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pictures` (
  `id` INT,
  `name` VARCHAR(64),
  `property_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `calendars` (
  `id` INT,
  `name` VARCHAR(64),
  `property_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246365_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246365_schema') AS relationships;
DROP DATABASE `db_246365_schema`;
UNINSTALL EXTENSION vsql_schematron;
