INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280507_melonbookkeeping
--echo #
CREATE DATABASE `db_280507_melonbookkeeping`;
USE `db_280507_melonbookkeeping`;

CREATE TABLE `admin` (
  `admin_id` INT,
  `user_name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;

CREATE TABLE `app` (
  `app_id` INT,
  `is_available` INT,
  `version` INT,
  `info` VARCHAR(64),
  `update_time` DATETIME,
  PRIMARY KEY (`app_id`)
) CHARACTER SET latin1;

CREATE TABLE `bookkeeping` (
  `bookkeeping_id` INT,
  `user_id` INT,
  `time` DATETIME,
  `count` DECIMAL(10,2),
  `out_intype` INT,
  `detail_type` VARCHAR(64),
  `pic_res` INT,
  `note` VARCHAR(64),
  `remark` VARCHAR(64),
  `location` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `config` (
  `config_kind` INT,
  `config_key` VARCHAR(64),
  `config_value` VARCHAR(64),
  PRIMARY KEY (`config_key`)
) CHARACTER SET latin1;

CREATE TABLE `feedback` (
  `feedback_id` INT,
  `user_id` INT,
  `content` VARCHAR(64),
  `create_time` DATETIME,
  `is_read` INT,
  PRIMARY KEY (`feedback_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `user_name` VARCHAR(64),
  `password` VARCHAR(64),
  `nick_name` VARCHAR(64),
  `avatar` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `status` INT,
  `register_time` DATETIME,
  `last_login_time` DATETIME,
  `access_token` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280507_melonbookkeeping') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280507_melonbookkeeping') AS relationships;
DROP DATABASE `db_280507_melonbookkeeping`;
UNINSTALL EXTENSION vsql_schematron;
