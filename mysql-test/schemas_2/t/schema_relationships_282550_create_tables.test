INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 282550_create_tables
--echo #
CREATE DATABASE `db_282550_create_tables`;
USE `db_282550_create_tables`;
CREATE TABLE `meals` (
  `meal_id` INT NOT NULL,
  `meal_name` TEXT,
  PRIMARY KEY (`meal_id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `ingredient_id` INT NOT NULL,
  `ingredient_name` TEXT,
  PRIMARY KEY (`ingredient_id`)
) CHARACTER SET latin1;
CREATE TABLE `measures` (
  `measure_id` INT NOT NULL,
  `measure_name` TEXT,
  PRIMARY KEY (`measure_id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
  `recipe_id` INT NOT NULL,
  `recipe_name` TEXT,
  `recipe_description` TEXT,
  PRIMARY KEY (`recipe_id`)
) CHARACTER SET latin1;
CREATE TABLE `serve` (
  `serve_id` INT NOT NULL,
  `recipe_id` INT,
  `meal_id` INT,
  PRIMARY KEY (`serve_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_282550_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_282550_create_tables') AS relationships;
DROP DATABASE `db_282550_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
