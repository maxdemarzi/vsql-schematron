INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 240659_V1.0__Initial_Schema
--echo #
CREATE DATABASE `db_240659_V1_0__Initial_Schema`;
USE `db_240659_V1_0__Initial_Schema`;
CREATE TABLE `secure` (
  `id` BIGINT,
  `key` VARCHAR(50),
  `encrypted_data` VARCHAR(50),
  `iv` VARCHAR(50),
  `algo` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `certificate_uses` (
  `certificate_use` VARCHAR(50) NOT NULL,
  `config` VARCHAR(50),
  PRIMARY KEY (`certificate_use`)
) CHARACTER SET latin1;
CREATE TABLE `certificates` (
  `id` BIGINT,
  `serial_number` DECIMAL(10,2),
  `not_valid_before` TIMESTAMP NULL,
  `not_valid_after` TIMESTAMP NULL,
  `subject` VARCHAR(50),
  `status` VARCHAR(50),
  `revocation_reason` VARCHAR(50),
  `revocation_time` TIMESTAMP NULL,
  `user_id` VARCHAR(50),
  `x509_cert_pem` VARCHAR(50),
  `certificate_use` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `crl` (
  `id` BIGINT,
  `this_update` TIMESTAMP NULL,
  `next_update` TIMESTAMP NULL,
  `x509_crl_pem` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_240659_V1_0__Initial_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_240659_V1_0__Initial_Schema') AS relationships;
DROP DATABASE `db_240659_V1_0__Initial_Schema`;
UNINSTALL EXTENSION vsql_schematron;
