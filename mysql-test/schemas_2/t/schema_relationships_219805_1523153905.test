INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 219805_1523153905
--echo #
CREATE DATABASE `db_219805_1523153905`;
USE `db_219805_1523153905`;

CREATE TABLE `action` (
  `id` INT,
  `strategy_id` INT,
  `type` INT,
  `kind` INT,
  `alarm_subject` VARCHAR(255),
  `alarm_template` VARCHAR(255),
  `restore_subject` VARCHAR(255),
  `restore_template` VARCHAR(255),
  `script_id` INT,
  `begin_time` DATETIME,
  `end_time` DATETIME,
  `time_period` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `action_result` (
  `strategy_event_id` INT,
  `count` INT,
  `action_id` INT,
  `action_type` INT,
  `action_kind` INT,
  `script_id` INT,
  `user_id` INT,
  `username` VARCHAR(255),
  `phone` VARCHAR(255),
  `mail` VARCHAR(255),
  `weixin` VARCHAR(255),
  `subject` VARCHAR(255),
  `content` VARCHAR(255),
  `success` INT,
  `response` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `chart` (
  `id` INT,
  `title` VARCHAR(255),
  `creator` VARCHAR(255),
  `span` INT,
  `height` INT,
  `create_at` DATETIME,
  `type` VARCHAR(255),
  `panel_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chart_element` (
  `metric` VARCHAR(255),
  `tags` VARCHAR(255),
  `chart_id` INT
) CHARACTER SET latin1;

CREATE TABLE `host_group_plugin` (
  `id` INT,
  `group_id` INT,
  `plugin_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `operations` (
  `ip` VARCHAR(255),
  `operator` VARCHAR(255),
  `method` VARCHAR(255),
  `api` VARCHAR(255),
  `body` VARCHAR(255),
  `result` INT,
  `time` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `panel` (
  `id` INT,
  `product_id` INT,
  `name` VARCHAR(255),
  `creator` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `strategy_event` (
  `id` INT,
  `product_id` INT,
  `strategy_id` INT,
  `strategy_name` VARCHAR(255),
  `priority` INT,
  `cycle` INT,
  `alarm_count` INT,
  `expression` VARCHAR(255),
  `create_time` DATETIME,
  `update_time` DATETIME,
  `aware_end_time` DATETIME,
  `count` INT,
  `status` INT,
  `host_id` VARCHAR(255),
  `host_name` VARCHAR(255),
  `ip` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `strategy_event_process` (
  `strategy_event_id` INT,
  `process_status` INT,
  `process_user` VARCHAR(255),
  `process_comments` VARCHAR(255),
  `process_time` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_219805_1523153905') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_219805_1523153905') AS relationships;
DROP DATABASE `db_219805_1523153905`;
UNINSTALL EXTENSION vsql_schematron;
