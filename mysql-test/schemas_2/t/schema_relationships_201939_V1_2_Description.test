INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 201939_V1_2_Description
--echo #
CREATE DATABASE `db_201939_V1_2_Description`;
USE `db_201939_V1_2_Description`;

CREATE TABLE `permission` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `deleted` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `deleted` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_permission` (
  `id_role` INT,
  `id_permission` INT,
  PRIMARY KEY (`id_role`, `id_permission`)
) CHARACTER SET latin1;

CREATE TABLE `public.user` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `phone` VARCHAR(255),
  `cpf` VARCHAR(255),
  `deleted` VARCHAR(255),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_201939_V1_2_Description') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_201939_V1_2_Description') AS relationships;
DROP DATABASE `db_201939_V1_2_Description`;
UNINSTALL EXTENSION vsql_schematron;
