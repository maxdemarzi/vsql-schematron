INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233675_Entrega3-Estrutura_Tabelas_ORACLE
--echo #
CREATE DATABASE `db_233675_Entrega3_Estrutura_Tabelas_ORACLE`;
USE `db_233675_Entrega3_Estrutura_Tabelas_ORACLE`;
CREATE TABLE `ATX2.setor` (
  `idSetor` DECIMAL(10,2) NOT NULL,
  `nomeSetor` VARCHAR(50),
  PRIMARY KEY (`idSetor`)
) CHARACTER SET latin1;
CREATE TABLE `ATX2.cargo` (
  `idCargo` DECIMAL(10,2) NOT NULL,
  `fkidSetor` DECIMAL(10,2),
  `nomeCargo` VARCHAR(50),
  PRIMARY KEY (`idCargo`)
) CHARACTER SET latin1;
CREATE TABLE `ATX2.pessoa` (
  `idPessoa` DECIMAL(10,2) NOT NULL,
  `nome` VARCHAR(50),
  `cPF` DECIMAL(10,2),
  `dataAtualizacao` TIMESTAMP NULL,
  `dataCadastro` TIMESTAMP NULL,
  `fkidCargo` DECIMAL(10,2),
  `observacoes` VARCHAR(50),
  `systemUser` VARCHAR(50),
  `senha` VARCHAR(50),
  `userAdmin` DECIMAL(10,2),
  PRIMARY KEY (`idPessoa`)
) CHARACTER SET latin1;
CREATE TABLE `ATX2.turno` (
  `idTurno` DECIMAL(10,2) NOT NULL,
  `nomeTurno` VARCHAR(50),
  `horaInicio` TIMESTAMP NULL,
  `horaIntervalo` TIMESTAMP NULL,
  `tempoIntervalo` TIMESTAMP NULL,
  `horaTermino` TIMESTAMP NULL,
  `horasFolga` TIMESTAMP NULL,
  PRIMARY KEY (`idTurno`)
) CHARACTER SET latin1;
CREATE TABLE `ATX2.plantao` (
  `idPlantao` DECIMAL(10,2) NOT NULL,
  `fkidPessoa` DECIMAL(10,2),
  `fkidTurno` DECIMAL(10,2),
  `dataInicio` TIMESTAMP NULL,
  `codPlantao` DECIMAL(10,2),
  PRIMARY KEY (`idPlantao`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233675_Entrega3_Estrutura_Tabelas_ORACLE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233675_Entrega3_Estrutura_Tabelas_ORACLE') AS relationships;
DROP DATABASE `db_233675_Entrega3_Estrutura_Tabelas_ORACLE`;
UNINSTALL EXTENSION vsql_schematron;
