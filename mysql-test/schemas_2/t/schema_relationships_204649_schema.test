INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204649_schema
--echo #
CREATE DATABASE `db_204649_schema`;
USE `db_204649_schema`;

CREATE TABLE `cache` (
  `cache_id` VARCHAR(255),
  `cache_time` INT,
  `cache_queries` INT,
  `cache_process_time` DECIMAL(10,2),
  `cache_possible_miss` INT,
  PRIMARY KEY (`cache_id`)
) CHARACTER SET latin1;

CREATE TABLE `cache_data` (
  `cdata_id` VARCHAR(255),
  `cdata_cache_id` VARCHAR(255),
  `cdata_url` VARCHAR(255),
  `cdata_confidence` DECIMAL(10,2),
  `cdata_skipped` INT,
  `cdata_excluded` INT,
  PRIMARY KEY (`cdata_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204649_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204649_schema') AS relationships;
DROP DATABASE `db_204649_schema`;
UNINSTALL EXTENSION vsql_schematron;
