INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224397_V1__flashback
--echo #
CREATE DATABASE `db_224397_V1__flashback`;
USE `db_224397_V1__flashback`;
CREATE TABLE `test` (
  `id` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `table1` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(50),
  `test_id` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224397_V1__flashback') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224397_V1__flashback') AS relationships;
DROP DATABASE `db_224397_V1__flashback`;
UNINSTALL EXTENSION vsql_schematron;
