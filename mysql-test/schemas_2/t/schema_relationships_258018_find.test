INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258018_find
--echo #
CREATE DATABASE `db_258018_find`;
USE `db_258018_find`;

CREATE TABLE `record` (
  `id` INT,
  `find_id` INT,
  `lost_id` INT,
  `time` DATETIME,
  `status` INT,
  `way` INT,
  `token` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `yyid` INT,
  `number` VARCHAR(64),
  `school` INT,
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `type` INT,
  `blocked` INT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258018_find') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258018_find') AS relationships;
DROP DATABASE `db_258018_find`;
UNINSTALL EXTENSION vsql_schematron;
