INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279220_fashion_valley_schema_and_data
--echo #
CREATE DATABASE `db_279220_fashion_valley_schema_and_data`;
USE `db_279220_fashion_valley_schema_and_data`;
CREATE TABLE `order_products` (
  `id` VARCHAR(50) NOT NULL,
  `order_id` INT,
  `product_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `created_at` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279220_fashion_valley_schema_and_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279220_fashion_valley_schema_and_data') AS relationships;
DROP DATABASE `db_279220_fashion_valley_schema_and_data`;
UNINSTALL EXTENSION vsql_schematron;
