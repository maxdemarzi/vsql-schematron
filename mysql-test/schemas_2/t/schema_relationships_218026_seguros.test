INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 218026_seguros
--echo #
CREATE DATABASE `db_218026_seguros`;
USE `db_218026_seguros`;

CREATE TABLE `acidente` (
  `numero_ocorrencia` INT,
  `data` DATETIME,
  `local` VARCHAR(64),
  PRIMARY KEY (`numero_ocorrencia`)
) CHARACTER SET latin1;

CREATE TABLE `carro` (
  `modelo` VARCHAR(64),
  `ano` INT,
  `placa` VARCHAR(64),
  PRIMARY KEY (`placa`)
) CHARACTER SET latin1;

CREATE TABLE `participou` (
  `id_motorista` INT,
  `placa` VARCHAR(64),
  `numero_ocorrencia` INT,
  `valor_dano` DECIMAL(10,2),
  PRIMARY KEY (`id_motorista`, `placa`, `numero_ocorrencia`)
) CHARACTER SET latin1;

CREATE TABLE `pertence` (
  `id_motorista` INT,
  `placa` VARCHAR(64),
  PRIMARY KEY (`id_motorista`, `placa`)
) CHARACTER SET latin1;

CREATE TABLE `pessoa` (
  `id_motorista` INT,
  `nome` VARCHAR(64),
  `endereco` VARCHAR(64),
  PRIMARY KEY (`id_motorista`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_218026_seguros') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_218026_seguros') AS relationships;
DROP DATABASE `db_218026_seguros`;
UNINSTALL EXTENSION vsql_schematron;
