INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 265587_schema
--echo #
CREATE DATABASE `db_265587_schema`;
USE `db_265587_schema`;

CREATE TABLE `CONTACTS` (
  `id` VARCHAR(64),
  `full_name` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `cre_dt` DATETIME,
  `upd_dt` DATETIME,
  `deleted` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `C_NUMS` (
  `id` VARCHAR(64),
  `c_number` VARCHAR(64),
  `category` VARCHAR(64),
  `is_primary` VARCHAR(64),
  `c_id` VARCHAR(64),
  `cre_dt` DATETIME,
  `upd_dt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `EMAILS` (
  `id` VARCHAR(64),
  `email_id` VARCHAR(64),
  `category` VARCHAR(64),
  `is_primary` VARCHAR(64),
  `c_id` VARCHAR(64),
  `cre_dt` DATETIME,
  `upd_dt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_265587_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_265587_schema') AS relationships;
DROP DATABASE `db_265587_schema`;
UNINSTALL EXTENSION vsql_schematron;
