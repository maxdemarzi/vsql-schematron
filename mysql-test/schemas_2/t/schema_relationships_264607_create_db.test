INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264607_create_db
--echo #
CREATE DATABASE `db_264607_create_db`;
USE `db_264607_create_db`;

CREATE TABLE `pilots` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `jets` (
  `id` INT,
  `pilot_id` INT,
  `age` INT,
  `name` VARCHAR(255),
  `color` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `languages` (
  `id` INT,
  `language` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pilot_languages` (
  `pilot_id` INT,
  `language_id` INT,
  PRIMARY KEY (`pilot_id`, `language_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264607_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264607_create_db') AS relationships;
DROP DATABASE `db_264607_create_db`;
UNINSTALL EXTENSION vsql_schematron;
