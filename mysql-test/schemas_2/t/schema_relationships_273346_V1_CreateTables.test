INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273346_V1_CreateTables
--echo #
CREATE DATABASE `db_273346_V1_CreateTables`;
USE `db_273346_V1_CreateTables`;

CREATE TABLE `games` (
  `id` INT,
  `name` VARCHAR(255),
  `image` VARCHAR(255),
  `genre` VARCHAR(255),
  `rating` INT,
  `price` INT,
  `operating_system` VARCHAR(255),
  `summary` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `friends` (
  `user_1_id` INT,
  `user_2_id` INT
) CHARACTER SET latin1;

CREATE TABLE `library` (
  `game_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authority` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_authority` (
  `authority_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `points` (
  `user_id` INT,
  `points` INT
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `game_id` INT,
  `user_id` INT,
  `rating` INT,
  `review` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stats` (
  `game_id` INT,
  `players_online` INT
) CHARACTER SET latin1;

CREATE TABLE `wishlist` (
  `game_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `shopping_cart` (
  `id` INT,
  `game_id` INT,
  `price` INT,
  `quantity` INT,
  `image` VARCHAR(255),
  `name` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273346_V1_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273346_V1_CreateTables') AS relationships;
DROP DATABASE `db_273346_V1_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
