INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269292_init_tourist
--echo #
CREATE DATABASE `db_269292_init_tourist`;
USE `db_269292_init_tourist`;

CREATE TABLE `sight` (
  `id` INT,
  `sight_name` VARCHAR(255),
  `sight_descr` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tourtype` (
  `id` INT,
  `tour_type_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schedule` (
  `id` INT,
  `tour_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `instructor` (
  `id` INT,
  `surname` VARCHAR(255),
  `forename` VARCHAR(255),
  `patronymic` VARCHAR(255),
  `id_schedule` INT,
  `id_tour_type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tour` (
  `id` INT,
  `tour_name` VARCHAR(255),
  `tour_descr` VARCHAR(255),
  `id_sight` INT,
  `id_schedule` INT,
  `id_tour_type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269292_init_tourist') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269292_init_tourist') AS relationships;
DROP DATABASE `db_269292_init_tourist`;
UNINSTALL EXTENSION vsql_schematron;
