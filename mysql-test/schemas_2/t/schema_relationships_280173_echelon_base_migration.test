INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280173_echelon_base_migration
--echo #
CREATE DATABASE `db_280173_echelon_base_migration`;
USE `db_280173_echelon_base_migration`;
CREATE TABLE `app_academicprogram` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `credits` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_course` (
  `name` VARCHAR(50),
  `department` VARCHAR(50),
  `number` INT,
  `deptnum` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  `credits` DOUBLE,
  `yearSpan` VARCHAR(50),
  PRIMARY KEY (`deptnum`)
) CHARACTER SET latin1;
CREATE TABLE `app_event` (
  `id` INT NOT NULL,
  `days` VARCHAR(50),
  `starttime` TIME,
  `endtime` TIME,
  `building` VARCHAR(50),
  `room` INT,
  `location` VARCHAR(50),
  `semester` VARCHAR(50),
  `yearSpan` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_option` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `option` INT,
  `type` INT,
  `academicprogram_id` INT,
  `course_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_schedule` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_studentrecord` (
  `id` INT NOT NULL,
  `GPA` DOUBLE,
  `currentStanding` VARCHAR(50),
  `currentCredits` DOUBLE,
  `remainingCredits` DOUBLE,
  `academicProgram_id` INT,
  `mainSchedule_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `django_admin_log` (
  `id` INT NOT NULL,
  `action_time` DATETIME,
  `object_id` VARCHAR(50),
  `object_repr` VARCHAR(50),
  `action_flag` VARCHAR(50),
  `change_message` VARCHAR(50),
  `content_type_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `django_session` (
  `session_key` VARCHAR(50) NOT NULL,
  `session_data` VARCHAR(50),
  `expire_date` DATETIME,
  PRIMARY KEY (`session_key`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280173_echelon_base_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280173_echelon_base_migration') AS relationships;
DROP DATABASE `db_280173_echelon_base_migration`;
UNINSTALL EXTENSION vsql_schematron;
