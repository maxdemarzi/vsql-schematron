INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 275085_V1.0__base
--echo #
CREATE DATABASE `db_275085_V1_0__base`;
USE `db_275085_V1_0__base`;
CREATE TABLE `urls` (
  `id` VARCHAR(50) NOT NULL,
  `url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
  `id` VARCHAR(50) NOT NULL,
  `link` TEXT,
  `urlID` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_275085_V1_0__base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_275085_V1_0__base') AS relationships;
DROP DATABASE `db_275085_V1_0__base`;
UNINSTALL EXTENSION vsql_schematron;
