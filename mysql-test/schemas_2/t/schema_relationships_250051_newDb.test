INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 250051_newDb
--echo #
CREATE DATABASE `db_250051_newDb`;
USE `db_250051_newDb`;
CREATE TABLE `function` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `group_id` VARCHAR(50),
  `weight` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `function_group` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `weight` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_250051_newDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_250051_newDb') AS relationships;
DROP DATABASE `db_250051_newDb`;
UNINSTALL EXTENSION vsql_schematron;
