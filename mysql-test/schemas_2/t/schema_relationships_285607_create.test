INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 285607_create
--echo #
CREATE DATABASE `db_285607_create`;
USE `db_285607_create`;
CREATE TABLE `norumor.user` (
  `id` INT NOT NULL,
  `uid` INT,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `norumor.information` (
  `pid` INT NOT NULL,
  `corcern` INT,
  `content` VARCHAR(50),
  `thetime` DATE,
  `truth` VARCHAR(50),
  `uid` VARCHAR(50),
  `pic` VARCHAR(50),
  `title` VARCHAR(50),
  `subtitle` VARCHAR(50),
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `norumor.problem` (
  `questionContent` VARCHAR(50),
  `qid` INT NOT NULL,
  `thetime` DATE,
  `uid` VARCHAR(50),
  PRIMARY KEY (`qid`)
) CHARACTER SET latin1;
CREATE TABLE `norumor.answer` (
  `replyContent` VARCHAR(50),
  `pid` INT NOT NULL,
  `qid` INT,
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_285607_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_285607_create') AS relationships;
DROP DATABASE `db_285607_create`;
UNINSTALL EXTENSION vsql_schematron;
