INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231421_migration
--echo #
CREATE DATABASE `db_231421_migration`;
USE `db_231421_migration`;
CREATE TABLE `Post` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `type` VARCHAR(50),
  `published` BOOLEAN,
  `author_id` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
  `id` VARCHAR(50) NOT NULL,
  `bio` TEXT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `user_id` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `role` VARCHAR(50),
  `username` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231421_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231421_migration') AS relationships;
DROP DATABASE `db_231421_migration`;
UNINSTALL EXTENSION vsql_schematron;
