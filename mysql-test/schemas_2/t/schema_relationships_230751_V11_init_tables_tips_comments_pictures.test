INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 230751_V11__init_tables_tips_comments_pictures
--echo #
CREATE DATABASE `db_230751_V11_init_tables_tips_comments_pictures`;
USE `db_230751_V11_init_tables_tips_comments_pictures`;

CREATE TABLE `tips` (
  `id` INT,
  `body` VARCHAR(64),
  `pic_id` INT,
  `url` VARCHAR(64),
  `when_created` DATETIME,
  `usuniety` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tip_pictures` (
  `id` INT,
  `picture` VARCHAR(64),
  `when_created` DATETIME,
  `usuniety` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tip_comments` (
  `id` INT,
  `author` INT,
  `body` VARCHAR(64),
  `tip_id` INT,
  `when_created` DATETIME,
  `usuniety` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_230751_V11_init_tables_tips_comments_pictures') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_230751_V11_init_tables_tips_comments_pictures') AS relationships;
DROP DATABASE `db_230751_V11_init_tables_tips_comments_pictures`;
UNINSTALL EXTENSION vsql_schematron;
