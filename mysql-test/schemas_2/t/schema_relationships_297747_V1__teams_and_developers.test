INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297747_V1__teams_and_developers
--echo #
CREATE DATABASE `db_297747_V1__teams_and_developers`;
USE `db_297747_V1__teams_and_developers`;
CREATE TABLE `TEAM` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEVELOPER` (
  `ID` BIGINT NOT NULL,
  `USERNAME` VARCHAR(50),
  `TEAM_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297747_V1__teams_and_developers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297747_V1__teams_and_developers') AS relationships;
DROP DATABASE `db_297747_V1__teams_and_developers`;
UNINSTALL EXTENSION vsql_schematron;
