INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 245180_table_creation
--echo #
CREATE DATABASE `db_245180_table_creation`;
USE `db_245180_table_creation`;

CREATE TABLE `teacher` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `class` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `section` (
  `id` INT,
  `name` VARCHAR(64),
  `teacher_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `id` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `class_id` INT,
  `section_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_245180_table_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_245180_table_creation') AS relationships;
DROP DATABASE `db_245180_table_creation`;
UNINSTALL EXTENSION vsql_schematron;
