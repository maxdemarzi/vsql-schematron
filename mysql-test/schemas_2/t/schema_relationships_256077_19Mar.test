INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 256077_19Mar
--echo #
CREATE DATABASE `db_256077_19Mar`;
USE `db_256077_19Mar`;
CREATE TABLE `cust` (
  `c_id` INT NOT NULL,
  `name` CHAR(50),
  PRIMARY KEY (`c_id`)
) CHARACTER SET latin1;
CREATE TABLE `ord` (
  `o_id` INT NOT NULL,
  `o_name` CHAR(50),
  `c_id` INT,
  PRIMARY KEY (`o_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_256077_19Mar') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_256077_19Mar') AS relationships;
DROP DATABASE `db_256077_19Mar`;
UNINSTALL EXTENSION vsql_schematron;
