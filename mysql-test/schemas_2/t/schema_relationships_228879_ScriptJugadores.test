INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228879_ScriptJugadores
--echo #
CREATE DATABASE `db_228879_ScriptJugadores`;
USE `db_228879_ScriptJugadores`;

CREATE TABLE `equipo` (
  `codigo_eq` DECIMAL(10,2),
  `nombre_eq` VARCHAR(64),
  `ciudad` VARCHAR(64),
  `division` VARCHAR(64),
  `conferencia` VARCHAR(64),
  `codigo_ent_eq` DECIMAL(10,2),
  PRIMARY KEY (`codigo_eq`)
) CHARACTER SET latin1;

CREATE TABLE `jugador` (
  `codigo_jug` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  `posicion` DECIMAL(10,2),
  `peso` DECIMAL(10,2),
  `fecha_nac` DATETIME,
  `codigo_eq_jug` DECIMAL(10,2),
  PRIMARY KEY (`codigo_jug`)
) CHARACTER SET latin1;

CREATE TABLE `lesion` (
  `codigo_les` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  `tiempo_rec` DECIMAL(10,2),
  PRIMARY KEY (`codigo_les`)
) CHARACTER SET latin1;

CREATE TABLE `entrenador` (
  `codigo_ent` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  `edad` DECIMAL(10,2),
  PRIMARY KEY (`codigo_ent`)
) CHARACTER SET latin1;

CREATE TABLE `jugador_lesion` (
  `codigo_jug_jl` DECIMAL(10,2),
  `codigo_les_jl` DECIMAL(10,2),
  PRIMARY KEY (`codigo_jug_jl`, `codigo_les_jl`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228879_ScriptJugadores') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228879_ScriptJugadores') AS relationships;
DROP DATABASE `db_228879_ScriptJugadores`;
UNINSTALL EXTENSION vsql_schematron;
