INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 219534_db_users_and_groups
--echo #
CREATE DATABASE `db_219534_db_users_and_groups`;
USE `db_219534_db_users_and_groups`;
CREATE TABLE `Groups` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `id` INT NOT NULL,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `date_added` DATETIME,
  `fk_group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_219534_db_users_and_groups') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_219534_db_users_and_groups') AS relationships;
DROP DATABASE `db_219534_db_users_and_groups`;
UNINSTALL EXTENSION vsql_schematron;
