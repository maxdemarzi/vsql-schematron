INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281625_code_web
--echo #
CREATE DATABASE `db_281625_code_web`;
USE `db_281625_code_web`;

CREATE TABLE `code_web_usetype` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `code_web_reqinfo` (
  `id` INT,
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `code_web_scripts` (
  `id` INT,
  `url` VARCHAR(64),
  `name` VARCHAR(64),
  `released` INT,
  `usetype` INT,
  `download` VARCHAR(64),
  `github` VARCHAR(64),
  `wiki` VARCHAR(64),
  `descmd` VARCHAR(64),
  `deschtml` VARCHAR(64),
  `instmd` VARCHAR(64),
  `insthtml` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `code_web_requirements` (
  `script` INT,
  `req` INT,
  PRIMARY KEY (`script`, `req`)
) CHARACTER SET latin1;

CREATE TABLE `code_web_comments` (
  `id` INT,
  `script` INT,
  `posted` INT,
  `user` INT,
  `name` VARCHAR(64),
  `contacturl` VARCHAR(64),
  `html` VARCHAR(64),
  `markdown` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281625_code_web') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281625_code_web') AS relationships;
DROP DATABASE `db_281625_code_web`;
UNINSTALL EXTENSION vsql_schematron;
