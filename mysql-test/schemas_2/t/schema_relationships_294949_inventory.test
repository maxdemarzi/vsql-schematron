INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294949_inventory
--echo #
CREATE DATABASE `db_294949_inventory`;
USE `db_294949_inventory`;

CREATE TABLE `customers` (
  `id` INT,
  `cu_name` VARCHAR(64),
  `cu_phone` VARCHAR(64),
  `cu_email` VARCHAR(64),
  `cu_address` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gen_settings` (
  `id` INT,
  `inven_name` VARCHAR(64),
  `currency` VARCHAR(64),
  `copy` VARCHAR(64),
  `logo` VARCHAR(64),
  `year` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `it_name` VARCHAR(64),
  `it_barcode` VARCHAR(64),
  `itpc_id` INT,
  `itsub_id` INT,
  `it_descrip` VARCHAR(64),
  `it_image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_has_permissions` (
  `permission_id` INT,
  `model_id` INT,
  `model_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `model_has_roles` (
  `role_id` INT,
  `model_id` INT,
  `model_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `id` INT,
  `pay_name` VARCHAR(64),
  `pay_status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_has_permissions` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `self_levels` (
  `id` INT,
  `number` VARCHAR(64),
  `shelf_id` INT,
  `sl_status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `warehouses` (
  `id` INT,
  `w_name` VARCHAR(64),
  `w_location` VARCHAR(64),
  `w_status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294949_inventory') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294949_inventory') AS relationships;
DROP DATABASE `db_294949_inventory`;
UNINSTALL EXTENSION vsql_schematron;
