INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280779_storedb
--echo #
CREATE DATABASE `db_280779_storedb`;
USE `db_280779_storedb`;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `price` DECIMAL(10,2),
  `percentageOFF` DECIMAL(10,2),
  `imageURL` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `salesItem` (
  `id` INT,
  `sales_id` INT,
  `item_id` INT,
  `qte` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `itemsincategory` (
  `id` INT,
  `itemID` INT,
  `categoryID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `store` (
  `id` INT,
  `name` VARCHAR(255),
  `hours` VARCHAR(255),
  `areOpen` VARCHAR(255),
  `address` VARCHAR(255),
  `phoneNumber` VARCHAR(255),
  `email` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280779_storedb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280779_storedb') AS relationships;
DROP DATABASE `db_280779_storedb`;
UNINSTALL EXTENSION vsql_schematron;
