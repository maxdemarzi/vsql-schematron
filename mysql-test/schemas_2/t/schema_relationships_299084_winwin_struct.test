INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 299084_winwin_struct
--echo #
CREATE DATABASE `db_299084_winwin_struct`;
USE `db_299084_winwin_struct`;

CREATE TABLE `def_pins` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `inf_carrier_pins` (
  `id` INT,
  `carrier_id` INT,
  `pin_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `jobs` (
  `id` INT,
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `attempts` INT,
  `reserved_at` INT,
  `available_at` INT,
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` VARCHAR(64),
  `type` VARCHAR(64),
  `notifiable_id` INT,
  `notifiable_type` VARCHAR(64),
  `data` VARCHAR(64),
  `read_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT,
  PRIMARY KEY (`permission_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `user_id` INT,
  `role_id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_299084_winwin_struct') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_299084_winwin_struct') AS relationships;
DROP DATABASE `db_299084_winwin_struct`;
UNINSTALL EXTENSION vsql_schematron;
