INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264181_V001__setup
--echo #
CREATE DATABASE `db_264181_V001_setup`;
USE `db_264181_V001_setup`;

CREATE TABLE `owner_account` (
  `id` INT,
  `birth` DATETIME,
  `cpf` VARCHAR(64),
  `created_at` DATETIME,
  `email` VARCHAR(64),
  `full_name` VARCHAR(64),
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `id` INT,
  `agency` VARCHAR(64),
  `bank_code` VARCHAR(64),
  `created_at` DATETIME,
  `external_id` VARCHAR(64),
  `account_number` VARCHAR(64),
  `security_code` VARCHAR(64),
  `account_type` VARCHAR(64),
  `updated_at` DATETIME,
  `expiration_date` DATETIME,
  `owner_account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264181_V001_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264181_V001_setup') AS relationships;
DROP DATABASE `db_264181_V001_setup`;
UNINSTALL EXTENSION vsql_schematron;
