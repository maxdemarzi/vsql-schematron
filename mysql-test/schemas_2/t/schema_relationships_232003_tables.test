INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232003_tables
--echo #
CREATE DATABASE `db_232003_tables`;
USE `db_232003_tables`;

CREATE TABLE `FLIGHT` (
  `FLIGHT_ID` INT,
  `AIRLINE_NAME` VARCHAR(64),
  `FLIGHT_DAYS` DATETIME,
  PRIMARY KEY (`FLIGHT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AIRPORT` (
  `AIRPORT_CODE` INT,
  `AIRPORT_NAME` VARCHAR(64),
  `AIRPORT_CITY` VARCHAR(64),
  `AIRPORT_PROVINCE` VARCHAR(64),
  PRIMARY KEY (`AIRPORT_CODE`)
) CHARACTER SET latin1;

CREATE TABLE `FLIGHT_LEG` (
  `LEG_ID` INT,
  `FLIGHT_ID` INT,
  `DEPARTURE_AIRPORT_CODE` INT,
  `SHEDULED_DEPARTURE_TIME` DATETIME,
  `ARRIVAL_AIRPORT_CODE` INT,
  `SHEDULED_ARRIVAL_TIME` DATETIME,
  PRIMARY KEY (`LEG_ID`, `FLIGHT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AIRPLANE_TYPE` (
  `Airplane_TYPE` VARCHAR(64),
  `MAX_SEATS` INT,
  `COMPANY` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `AIRPLANE` (
  `AIRPLANE_ID` INT,
  `AVAILABLE_SEATS` INT,
  `Airplane_TYPE` VARCHAR(64),
  PRIMARY KEY (`AIRPLANE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `LEG_INSTANCE` (
  `LEG_ID` INT,
  `FLIGHT_ID` INT,
  `LEGDATE` DATETIME,
  `AVAILABLE_SEATS` INT,
  `DEPARTURE_TIME` DATETIME,
  `ARRIVAL_TIME` DATETIME,
  `AIRPLANE_ID` INT,
  PRIMARY KEY (`LEG_ID`, `FLIGHT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CUSTOMER` (
  `CUSTOMER_ID` INT,
  `CUSTOMER_NAME` VARCHAR(64),
  `PHONE` INT,
  `ACCUMULATED_KM` INT,
  `CLASSIFICATION` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `RESERVATION` (
  `RESERVATION_NUMBER` INT,
  `CUSTOMER_ID` INT,
  `FLIGHT_ID` INT,
  `SEAT_NUMBER` INT,
  `AIRPLANE_ID` INT,
  PRIMARY KEY (`RESERVATION_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `CAN_LAND` (
  `Airplane_TYPE` VARCHAR(64),
  `AIRPORT_CODE` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232003_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232003_tables') AS relationships;
DROP DATABASE `db_232003_tables`;
UNINSTALL EXTENSION vsql_schematron;
