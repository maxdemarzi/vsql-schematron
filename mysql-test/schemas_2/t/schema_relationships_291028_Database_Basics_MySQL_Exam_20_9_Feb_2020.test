INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 291028_Database_Basics_MySQL_Exam_20_9_Feb_2020
--echo #
CREATE DATABASE `db_291028_Database_Basics_MySQL_Exam_20_9_Feb_2020`;
USE `db_291028_Database_Basics_MySQL_Exam_20_9_Feb_2020`;

CREATE TABLE `players` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `age` INT,
  `position` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `hire_date` DATETIME,
  `skills_data_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `players_coaches` (
  `player_id` INT,
  `coach_id` INT,
  PRIMARY KEY (`player_id`, `coach_id`)
) CHARACTER SET latin1;

CREATE TABLE `coaches` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `coach_level` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `skills_data` (
  `id` INT,
  `dribbling` INT,
  `pace` INT,
  `passing` INT,
  `shooting` INT,
  `speed` INT,
  `strength` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `countries` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `towns` (
  `id` INT,
  `name` VARCHAR(64),
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stadiums` (
  `id` INT,
  `name` VARCHAR(64),
  `capacity` INT,
  `town_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(64),
  `established` DATETIME,
  `fan_base` INT,
  `stadium_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_291028_Database_Basics_MySQL_Exam_20_9_Feb_2020') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_291028_Database_Basics_MySQL_Exam_20_9_Feb_2020') AS relationships;
DROP DATABASE `db_291028_Database_Basics_MySQL_Exam_20_9_Feb_2020`;
UNINSTALL EXTENSION vsql_schematron;
