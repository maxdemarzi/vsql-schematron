INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257207_tic_tac_toe.postgres
--echo #
CREATE DATABASE `db_257207_tic_tac_toe_postgres`;
USE `db_257207_tic_tac_toe_postgres`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password_digest` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `games` (
  `id` INT,
  `winner_id` INT,
  `completed_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `games_players` (
  `id` INT,
  `game_id` INT,
  `player_id` INT,
  `token` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257207_tic_tac_toe_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257207_tic_tac_toe_postgres') AS relationships;
DROP DATABASE `db_257207_tic_tac_toe_postgres`;
UNINSTALL EXTENSION vsql_schematron;
