INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269112_db_challenge_eldorado
--echo #
CREATE DATABASE `db_269112_db_challenge_eldorado`;
USE `db_269112_db_challenge_eldorado`;

CREATE TABLE `Types` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Devices` (
  `Id` INT,
  `Category` INT,
  `Color` VARCHAR(64),
  `partNumber` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269112_db_challenge_eldorado') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269112_db_challenge_eldorado') AS relationships;
DROP DATABASE `db_269112_db_challenge_eldorado`;
UNINSTALL EXTENSION vsql_schematron;
