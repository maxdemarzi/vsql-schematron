INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 234854_V03__criar_proposta_documento
--echo #
CREATE DATABASE `db_234854_V03__criar_proposta_documento`;
USE `db_234854_V03__criar_proposta_documento`;
CREATE TABLE `proposta` (
  `id` BIGINT NOT NULL,
  `tipo_proposta` VARCHAR(50),
  `status_proposta` VARCHAR(50),
  `data` DATE,
  `id_cliente` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documento` (
  `id` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  `arquivo_base64` TEXT,
  `formato` VARCHAR(50),
  `data` DATE,
  `id_proposta` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_234854_V03__criar_proposta_documento') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_234854_V03__criar_proposta_documento') AS relationships;
DROP DATABASE `db_234854_V03__criar_proposta_documento`;
UNINSTALL EXTENSION vsql_schematron;
