INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283298_create_tables_column_drop_patch
--echo #
CREATE DATABASE `db_283298_create_tables_column_drop_patch`;
USE `db_283298_create_tables_column_drop_patch`;
CREATE TABLE `actionexporter.exportjob` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `actionexporter.exportfile` (
  `id` VARCHAR(50) NOT NULL,
  `filename` CHAR(50),
  `exportjobid` VARCHAR(50),
  `datesuccessfullysent` TIMESTAMP NULL,
  `status` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283298_create_tables_column_drop_patch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283298_create_tables_column_drop_patch') AS relationships;
DROP DATABASE `db_283298_create_tables_column_drop_patch`;
UNINSTALL EXTENSION vsql_schematron;
