INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 265366_index
--echo #
CREATE DATABASE `db_265366_index`;
USE `db_265366_index`;

CREATE TABLE `employee` (
  `employee_id` INT,
  `supervisor_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `bus_station` (
  `id` INT,
  `name` VARCHAR(255),
  `location` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_265366_index') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_265366_index') AS relationships;
DROP DATABASE `db_265366_index`;
UNINSTALL EXTENSION vsql_schematron;
