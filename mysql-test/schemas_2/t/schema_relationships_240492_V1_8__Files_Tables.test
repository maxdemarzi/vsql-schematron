INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 240492_V1.8__Files_Tables
--echo #
CREATE DATABASE `db_240492_V1_8__Files_Tables`;
USE `db_240492_V1_8__Files_Tables`;
CREATE TABLE `file` (
  `id` INT NOT NULL,
  `student_id` INT,
  `file_name` VARCHAR(50),
  `file_external_id` VARCHAR(50),
  `access_type` VARCHAR(50),
  `group_owner` VARCHAR(50),
  `file_type` VARCHAR(50),
  `mime_type` VARCHAR(50),
  `link` VARCHAR(50),
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_240492_V1_8__Files_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_240492_V1_8__Files_Tables') AS relationships;
DROP DATABASE `db_240492_V1_8__Files_Tables`;
UNINSTALL EXTENSION vsql_schematron;
