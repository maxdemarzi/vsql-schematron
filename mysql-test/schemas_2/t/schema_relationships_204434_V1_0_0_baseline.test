INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204434_V1_0_0__baseline
--echo #
CREATE DATABASE `db_204434_V1_0_0_baseline`;
USE `db_204434_V1_0_0_baseline`;

CREATE TABLE `World_Type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `World` (
  `id` INT,
  `name` VARCHAR(64),
  `namespace` VARCHAR(64),
  `type` INT,
  `endpoint` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Service_Type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Service` (
  `id` INT,
  `service_type` INT,
  `world_id` INT,
  `endpoint` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204434_V1_0_0_baseline') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204434_V1_0_0_baseline') AS relationships;
DROP DATABASE `db_204434_V1_0_0_baseline`;
UNINSTALL EXTENSION vsql_schematron;
