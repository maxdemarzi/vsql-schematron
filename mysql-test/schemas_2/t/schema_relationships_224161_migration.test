INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224161_migration
--echo #
CREATE DATABASE `db_224161_migration`;
USE `db_224161_migration`;
CREATE TABLE `OAuth` (
  `id` VARCHAR(50) NOT NULL,
  `accessToken` TEXT,
  `refreshToken` TEXT,
  `expiration` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `new_User` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `oAuthId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224161_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224161_migration') AS relationships;
DROP DATABASE `db_224161_migration`;
UNINSTALL EXTENSION vsql_schematron;
