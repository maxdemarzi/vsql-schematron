INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226300_database
--echo #
CREATE DATABASE `db_226300_database`;
USE `db_226300_database`;

CREATE TABLE `orders` (
  `id` INT,
  `customer_name` VARCHAR(64),
  `price` DECIMAL(10,2),
  `currency_code` VARCHAR(64),
  `status` VARCHAR(64),
  `payment_type` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `paypal_payments` (
  `id` INT,
  `fee` DECIMAL(10,2),
  `token` VARCHAR(64),
  `transaction_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226300_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226300_database') AS relationships;
DROP DATABASE `db_226300_database`;
UNINSTALL EXTENSION vsql_schematron;
