INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 216742_script
--echo #
CREATE DATABASE `db_216742_script`;
USE `db_216742_script`;
CREATE TABLE `CLASS` (
  `CLASSID` VARCHAR(50) NOT NULL,
  `CLASSNAME` VARCHAR(50),
  `REGTIME` DATETIME,
  `SPECIALTY` VARCHAR(50),
  `REMARK` VARCHAR(50),
  PRIMARY KEY (`CLASSID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
  `USERID` VARCHAR(50) NOT NULL,
  `USERNAME` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `SEX` VARCHAR(50),
  `BIRTHDAY` DATE,
  `REGTIME` DATETIME,
  `SPECIALTY` VARCHAR(50),
  `REMARK` VARCHAR(50),
  PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT_CLASS` (
  `USERID` VARCHAR(50) NOT NULL,
  `CLASSID` VARCHAR(50) NOT NULL,
  `REGTIME` DATETIME,
  `GRADE` DOUBLE,
  PRIMARY KEY (`USERID`, `CLASSID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_216742_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_216742_script') AS relationships;
DROP DATABASE `db_216742_script`;
UNINSTALL EXTENSION vsql_schematron;
