INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258886_createDb
--echo #
CREATE DATABASE `db_258886_createDb`;
USE `db_258886_createDb`;
CREATE TABLE `CORE` (
  `coreid` INT NOT NULL,
  `core` TEXT,
  `coredef` TEXT,
  PRIMARY KEY (`coreid`)
) CHARACTER SET latin1;
CREATE TABLE `PLATFORM` (
  `platformid` INT NOT NULL,
  `platform` TEXT,
  PRIMARY KEY (`platformid`)
) CHARACTER SET latin1;
CREATE TABLE `COMPILERKIND` (
  `compilerkindid` INT NOT NULL,
  `compiler` TEXT,
  PRIMARY KEY (`compilerkindid`)
) CHARACTER SET latin1;
CREATE TABLE `COMPILER` (
  `compilerid` INT NOT NULL,
  `compilerkindid` INT,
  `version` TEXT,
  `testdateid` INT,
  PRIMARY KEY (`compilerid`)
) CHARACTER SET latin1;
CREATE TABLE `RUN` (
  `runid` INT NOT NULL,
  `date` TEXT,
  PRIMARY KEY (`runid`)
) CHARACTER SET latin1;
CREATE TABLE `TYPE` (
  `typeid` INT NOT NULL,
  `type` TEXT,
  PRIMARY KEY (`typeid`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORY` (
  `categoryid` INT NOT NULL,
  `category` TEXT,
  PRIMARY KEY (`categoryid`)
) CHARACTER SET latin1;
CREATE TABLE `TESTNAME` (
  `testnameid` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`testnameid`)
) CHARACTER SET latin1;
CREATE TABLE `TESTDATE` (
  `testdateid` INT NOT NULL,
  `date` TEXT,
  PRIMARY KEY (`testdateid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258886_createDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258886_createDb') AS relationships;
DROP DATABASE `db_258886_createDb`;
UNINSTALL EXTENSION vsql_schematron;
