INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276194_migration
--echo #
CREATE DATABASE `db_276194_migration`;
USE `db_276194_migration`;

CREATE TABLE `players` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `birth_date` DATETIME,
  `weight` INT,
  `height` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `divisions` (
  `name` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(255),
  `division` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roster` (
  `team_id` INT,
  `player_id` INT,
  PRIMARY KEY (`team_id`, `player_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276194_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276194_migration') AS relationships;
DROP DATABASE `db_276194_migration`;
UNINSTALL EXTENSION vsql_schematron;
