INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226639_pokemon_db_seed
--echo #
CREATE DATABASE `db_226639_pokemon_db_seed`;
USE `db_226639_pokemon_db_seed`;

CREATE TABLE `Location` (
  `location_id` INT,
  `location_name` VARCHAR(64),
  `location_description` VARCHAR(64),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;

CREATE TABLE `IsFoundIn` (
  `pokemon` INT,
  `location` INT,
  PRIMARY KEY (`pokemon`, `location`)
) CHARACTER SET latin1;

CREATE TABLE `CanLearn` (
  `pokemon` INT,
  `move` INT,
  PRIMARY KEY (`pokemon`, `move`)
) CHARACTER SET latin1;

CREATE TABLE `EvolvesInto` (
  `evolvesFrom` INT,
  `evolvesInto` INT,
  PRIMARY KEY (`evolvesFrom`, `evolvesInto`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226639_pokemon_db_seed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226639_pokemon_db_seed') AS relationships;
DROP DATABASE `db_226639_pokemon_db_seed`;
UNINSTALL EXTENSION vsql_schematron;
