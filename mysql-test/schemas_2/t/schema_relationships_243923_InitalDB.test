INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 243923_InitalDB
--echo #
CREATE DATABASE `db_243923_InitalDB`;
USE `db_243923_InitalDB`;

CREATE TABLE `Member` (
  `Id` INT,
  `LoginId` VARCHAR(255),
  `Password` VARCHAR(255),
  `Email` VARCHAR(255),
  `Name` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Post` (
  `Id` INT,
  `MemberId` INT,
  `BoardName` VARCHAR(255),
  `Title` VARCHAR(255),
  `Content` VARCHAR(255),
  `Suggestion` INT,
  `View` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Board` (
  `Name` VARCHAR(255),
  `NickName` VARCHAR(255),
  `Activation` VARCHAR(255),
  `Describe` VARCHAR(255),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `Id` INT,
  `MemberId` INT,
  `PostId` INT,
  `Content` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Authority` (
  `MemberId` INT,
  `BoardName` VARCHAR(255),
  `Role` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_243923_InitalDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_243923_InitalDB') AS relationships;
DROP DATABASE `db_243923_InitalDB`;
UNINSTALL EXTENSION vsql_schematron;
