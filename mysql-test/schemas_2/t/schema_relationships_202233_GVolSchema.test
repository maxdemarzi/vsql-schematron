INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202233_GVolSchema
--echo #
CREATE DATABASE `db_202233_GVolSchema`;
USE `db_202233_GVolSchema`;
CREATE TABLE `VolCommand` (
  `ID` INT NOT NULL,
  `Cmd` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROFILE` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Desc` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Plugin` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Desc` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Option` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Desc` VARCHAR(50),
  `Type` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PluginOption` (
  `ID` INT NOT NULL,
  `PluginID` INT,
  `OptionID` INT,
  `Required` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BatchFile` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BatchFilePlugin` (
  `ID` INT NOT NULL,
  `BatchFileID` INT,
  `PluginID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202233_GVolSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202233_GVolSchema') AS relationships;
DROP DATABASE `db_202233_GVolSchema`;
UNINSTALL EXTENSION vsql_schematron;
