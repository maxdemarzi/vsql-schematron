INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213759_backup05_07
--echo #
CREATE DATABASE `db_213759_backup05_07`;
USE `db_213759_backup05_07`;

CREATE TABLE `chats` (
  `chatid` INT,
  `chatname` VARCHAR(64),
  `participant` VARCHAR(64),
  `time` DATETIME,
  `isgroup` INT,
  PRIMARY KEY (`chatid`, `participant`)
) CHARACTER SET latin1;

CREATE TABLE `friends` (
  `id` VARCHAR(64),
  `friendid` VARCHAR(64),
  `installed` INT,
  PRIMARY KEY (`id`, `friendid`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `chatid` INT,
  `sender` VARCHAR(64),
  `content` VARCHAR(64),
  `ismedia` INT,
  `time` DATETIME,
  PRIMARY KEY (`chatid`, `sender`, `time`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `fbid` VARCHAR(64),
  `token` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`fbid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213759_backup05_07') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213759_backup05_07') AS relationships;
DROP DATABASE `db_213759_backup05_07`;
UNINSTALL EXTENSION vsql_schematron;
