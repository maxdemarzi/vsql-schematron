INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212310_mysql_script
--echo #
CREATE DATABASE `db_212310_mysql_script`;
USE `db_212310_mysql_script`;

CREATE TABLE `patient` (
  `patient_id` INT,
  `bu_number` INT,
  `contact_number` VARCHAR(255),
  `icmr_number` VARCHAR(255),
  `srf_number` VARCHAR(255),
  `zone` VARCHAR(255),
  PRIMARY KEY (`patient_id`)
) CHARACTER SET latin1;

CREATE TABLE `queue` (
  `id` INT,
  `type` VARCHAR(255),
  `patient_id` INT,
  `enqueue_timestamp` DATETIME,
  `updated_timestamp` DATETIME,
  `zone` VARCHAR(255),
  `is_active` INT,
  `push_front` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `allotment` (
  `id` INT,
  `queue_id` INT,
  `patient_id` INT,
  `hospital_id` VARCHAR(255),
  `bed_type` VARCHAR(255),
  `request_time` DATETIME,
  `allocation_time` DATETIME,
  `zone` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212310_mysql_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212310_mysql_script') AS relationships;
DROP DATABASE `db_212310_mysql_script`;
UNINSTALL EXTENSION vsql_schematron;
