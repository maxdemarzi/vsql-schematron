INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 262286_migration
--echo #
CREATE DATABASE `db_262286_migration`;
USE `db_262286_migration`;

CREATE TABLE `Post` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `author` VARCHAR(64),
  `body` VARCHAR(64),
  `image` VARCHAR(64),
  `postedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `isAdmin` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_PostToTag` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_262286_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_262286_migration') AS relationships;
DROP DATABASE `db_262286_migration`;
UNINSTALL EXTENSION vsql_schematron;
