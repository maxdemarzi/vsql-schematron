INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 214802_REFERENTIAL_INTEGRITY_Relationships
--echo #
CREATE DATABASE `db_214802_REFERENTIAL_INTEGRITY_Relationships`;
USE `db_214802_REFERENTIAL_INTEGRITY_Relationships`;
CREATE TABLE `Students` (
  `Student_id` INT NOT NULL,
  `Student_Name` VARCHAR(50),
  PRIMARY KEY (`Student_id`)
) CHARACTER SET latin1;
CREATE TABLE `Subjects` (
  `Subject_id` INT NOT NULL,
  `Subject_Name` VARCHAR(50),
  PRIMARY KEY (`Subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `Students_Subjects_Join` (
  `Student_id` INT NOT NULL,
  `Subject_id` INT NOT NULL,
  PRIMARY KEY (`Student_id`, `Subject_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_214802_REFERENTIAL_INTEGRITY_Relationships') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_214802_REFERENTIAL_INTEGRITY_Relationships') AS relationships;
DROP DATABASE `db_214802_REFERENTIAL_INTEGRITY_Relationships`;
UNINSTALL EXTENSION vsql_schematron;
