INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227634_criarPedidos
--echo #
CREATE DATABASE `db_227634_criarPedidos`;
USE `db_227634_criarPedidos`;
CREATE TABLE `Cliente` (
  `CodCLI` INT NOT NULL,
  `Nome` VARCHAR(50),
  `Endereco` VARCHAR(50),
  `Telefone` VARCHAR(50),
  `InscE` VARCHAR(50),
  `CNPJ` VARCHAR(50),
  `Cidade` VARCHAR(50),
  `UF` VARCHAR(50),
  PRIMARY KEY (`CodCLI`)
) CHARACTER SET latin1;
CREATE TABLE `Produto` (
  `CodPROD` INT NOT NULL,
  `Descricao` VARCHAR(50),
  `Valor` DECIMAL(10,2),
  `Unidade` CHAR(50),
  PRIMARY KEY (`CodPROD`)
) CHARACTER SET latin1;
CREATE TABLE `Pedido` (
  `NumPED` INT NOT NULL,
  `PrazoEntrega` INT,
  `Data` DATE,
  `CodCLI` INT,
  `CodVEND` INT,
  PRIMARY KEY (`NumPED`)
) CHARACTER SET latin1;
CREATE TABLE `Vendedor` (
  `CodVEND` INT NOT NULL,
  `Nome` VARCHAR(50),
  `DataNasc` DATE,
  `SalarioFixo` DECIMAL(10,2),
  `FaixaComissao` CHAR(50),
  PRIMARY KEY (`CodVEND`)
) CHARACTER SET latin1;
CREATE TABLE `ItensPedido` (
  `NumPED` INT NOT NULL,
  `CodPROD` INT NOT NULL,
  `Quantidade` INT,
  PRIMARY KEY (`CodPROD`, `NumPED`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227634_criarPedidos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227634_criarPedidos') AS relationships;
DROP DATABASE `db_227634_criarPedidos`;
UNINSTALL EXTENSION vsql_schematron;
