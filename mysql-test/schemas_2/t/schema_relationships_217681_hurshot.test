INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217681_hurshot
--echo #
CREATE DATABASE `db_217681_hurshot`;
USE `db_217681_hurshot`;
CREATE TABLE `markers` (
  `id` INT NOT NULL,
  `secret` VARCHAR(50),
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  `descr` TEXT,
  `pic` VARCHAR(50),
  `points` INT,
  `is_enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `marklog` (
  `id` INT NOT NULL,
  `marker_id` INT,
  `auth` VARCHAR(50),
  `ts` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217681_hurshot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217681_hurshot') AS relationships;
DROP DATABASE `db_217681_hurshot`;
UNINSTALL EXTENSION vsql_schematron;
