INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 299165_V1_0_0__Initial
--echo #
CREATE DATABASE `db_299165_V1_0_0__Initial`;
USE `db_299165_V1_0_0__Initial`;
CREATE TABLE `rooms` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `INFO` TEXT,
  `MAX_CAPACITY` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `patient` (
  `ID` INT NOT NULL,
  `HASHED_PASSWORD` VARCHAR(50),
  `PERSONAL_ID` VARCHAR(50),
  `NAME` VARCHAR(50),
  `PHONE` VARCHAR(50),
  `ROOM_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `health_records` (
  `ID` INT NOT NULL,
  `CREATED_ON` TIMESTAMP NULL,
  `PATIENT_ID` INT,
  `TEMPERATURE` DECIMAL(10,2),
  `COUGH` BOOLEAN,
  `HEADACHE` BOOLEAN,
  `THROAT_ACHE` BOOLEAN,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_299165_V1_0_0__Initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_299165_V1_0_0__Initial') AS relationships;
DROP DATABASE `db_299165_V1_0_0__Initial`;
UNINSTALL EXTENSION vsql_schematron;
