INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269910_tables
--echo #
CREATE DATABASE `db_269910_tables`;
USE `db_269910_tables`;
CREATE TABLE `Destination` (
  `dID` INT NOT NULL,
  `Country` VARCHAR(50),
  PRIMARY KEY (`dID`)
) CHARACTER SET latin1;
CREATE TABLE `Passport` (
  `pID` INT NOT NULL,
  `Country` VARCHAR(50),
  PRIMARY KEY (`pID`)
) CHARACTER SET latin1;
CREATE TABLE `RequireDocs` (
  `ID` INT NOT NULL,
  `DestId` INT,
  `PassId` INT,
  `Cost` INT,
  `Requred_Doc` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269910_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269910_tables') AS relationships;
DROP DATABASE `db_269910_tables`;
UNINSTALL EXTENSION vsql_schematron;
