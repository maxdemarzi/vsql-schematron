INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 249241_schema
--echo #
CREATE DATABASE `db_249241_schema`;
USE `db_249241_schema`;
CREATE TABLE `game` (
  `id` INT NOT NULL,
  `channel_id` BIGINT,
  `server_id` BIGINT,
  `admin_id` BIGINT,
  `status` VARCHAR(50),
  `created` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_player` (
  `game_id` INT,
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_249241_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_249241_schema') AS relationships;
DROP DATABASE `db_249241_schema`;
UNINSTALL EXTENSION vsql_schematron;
