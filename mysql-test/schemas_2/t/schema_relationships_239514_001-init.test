INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239514_001-init
--echo #
CREATE DATABASE `db_239514_001_init`;
USE `db_239514_001_init`;
CREATE TABLE `settings` (
  `setting` TEXT,
  `value` TEXT
) CHARACTER SET latin1;
CREATE TABLE `libraries` (
  `id` INT NOT NULL,
  `path` TEXT,
  `searchByDefault` INT,
  `stillExists` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `libraryId` INT,
  `path` VARCHAR(50),
  `lastModified` INT,
  `size` INT,
  `stillExists` INT,
  `indexed` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tracks` (
  `id` INT NOT NULL,
  `fileId` INT,
  `trackNumber` INT,
  `type` VARCHAR(50),
  `language` VARCHAR(50),
  `title` VARCHAR(50),
  `subtitlePreambleJson` VARCHAR(50),
  `subtitleNondialogueEventsJson` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations` (
  `id` INT NOT NULL,
  `trackId` INT,
  `indexedText` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lines` (
  `id` INT NOT NULL,
  `conversationId` INT,
  `startMs` INT,
  `endMs` INT,
  `subtitleEventJson` TEXT,
  `displayText` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239514_001_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239514_001_init') AS relationships;
DROP DATABASE `db_239514_001_init`;
UNINSTALL EXTENSION vsql_schematron;
