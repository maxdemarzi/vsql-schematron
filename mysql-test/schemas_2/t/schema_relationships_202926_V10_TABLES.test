INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202926_V10_TABLES
--echo #
CREATE DATABASE `db_202926_V10_TABLES`;
USE `db_202926_V10_TABLES`;

CREATE TABLE `blogpost` (
  `id` VARCHAR(255),
  `auditing_created_at` DATETIME,
  `auditing_updated_at` DATETIME,
  `blogpost_author` VARCHAR(255),
  `title` VARCHAR(255),
  `content` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blogpost_comment` (
  `id` VARCHAR(255),
  `auditing_created_at` DATETIME,
  `auditing_updated_at` DATETIME,
  `blogpost_comment_author` VARCHAR(255),
  `blogpost_id` VARCHAR(255),
  `content` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blogpost_comments` (
  `blogpost_id` VARCHAR(255),
  `comment_id` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202926_V10_TABLES') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202926_V10_TABLES') AS relationships;
DROP DATABASE `db_202926_V10_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
