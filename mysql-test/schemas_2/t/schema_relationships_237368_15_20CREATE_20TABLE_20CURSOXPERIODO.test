  `ID` DECIMAL(10,2),
  `ID_CURSO` DECIMAL(10,2),
  `ID_PERIODO` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `IMPARTE` (
  `ID` DECIMAL(10,2),
  `ID_EMPLEADO` DECIMAL(10,2),
  `ID_CURSOXPERIODO` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `MATRICULA` (
  `ID` DECIMAL(10,2),
  `ID_CURSOXPERIODO` DECIMAL(10,2),
  `ID_ALUMNO` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `DESERCIONES` (
  `ID` DECIMAL(10,2),
  `ID_CURSOXPERIODO` DECIMAL(10,2),
  `ID_ALUMNO` DECIMAL(10,2),
  `MOTIVO` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
