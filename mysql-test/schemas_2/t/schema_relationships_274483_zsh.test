INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 274483_zsh
--echo #
CREATE DATABASE `db_274483_zsh`;
USE `db_274483_zsh`;

CREATE TABLE `address` (
  `address_areaId` VARCHAR(64),
  `address_name` VARCHAR(64),
  `address_regionId` VARCHAR(64),
  PRIMARY KEY (`address_areaId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_274483_zsh') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_274483_zsh') AS relationships;
DROP DATABASE `db_274483_zsh`;
UNINSTALL EXTENSION vsql_schematron;
