INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228683_table%20-%20foreign%20key
--echo #
CREATE DATABASE `db_228683_table_20__20foreign_20key`;
USE `db_228683_table_20__20foreign_20key`;
CREATE TABLE `parent` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT,
  `user_id` INT,
  `text` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228683_table_20__20foreign_20key') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228683_table_20__20foreign_20key') AS relationships;
DROP DATABASE `db_228683_table_20__20foreign_20key`;
UNINSTALL EXTENSION vsql_schematron;
