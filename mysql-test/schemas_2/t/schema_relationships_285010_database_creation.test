INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 285010_database_creation
--echo #
CREATE DATABASE `db_285010_database_creation`;
USE `db_285010_database_creation`;

CREATE TABLE `Users` (
  `Id` INT,
  `Login` VARCHAR(64),
  `Email` VARCHAR(64),
  `Password` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Collections` (
  `Id` INT,
  `Title` VARCHAR(64),
  `User` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Images` (
  `Id` INT,
  `Title` VARCHAR(64),
  `Comment` VARCHAR(64),
  `Url` VARCHAR(64),
  `Path` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `CollectionItems` (
  `Collection` INT,
  `Item` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_285010_database_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_285010_database_creation') AS relationships;
DROP DATABASE `db_285010_database_creation`;
UNINSTALL EXTENSION vsql_schematron;
