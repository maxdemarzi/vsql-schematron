INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221429_5.%20Fun%C3%A7%C3%B5es
--echo #
CREATE DATABASE `db_221429_5__20Fun_C3_A7_C3_B5es`;
USE `db_221429_5__20Fun_C3_A7_C3_B5es`;
CREATE TABLE `GENERO` (
  `IDGENERO` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`IDGENERO`)
) CHARACTER SET latin1;
CREATE TABLE `FILME` (
  `IDFILME` INT NOT NULL,
  `NOME` VARCHAR(50),
  `ANO` INT,
  `ID_GENERO` INT,
  PRIMARY KEY (`IDFILME`)
) CHARACTER SET latin1;
CREATE TABLE `LOCACAO` (
  `IDLOCACAO` INT NOT NULL,
  `DATA` DATE,
  `MIDIA` INT,
  `DIAS` INT,
  `ID_FILME` INT,
  PRIMARY KEY (`IDLOCACAO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221429_5__20Fun_C3_A7_C3_B5es') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221429_5__20Fun_C3_A7_C3_B5es') AS relationships;
DROP DATABASE `db_221429_5__20Fun_C3_A7_C3_B5es`;
UNINSTALL EXTENSION vsql_schematron;
