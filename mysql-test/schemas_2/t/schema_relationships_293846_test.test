INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293846_test
--echo #
CREATE DATABASE `db_293846_test`;
USE `db_293846_test`;
CREATE TABLE `Hotel` (
  `hotelNo` INT NOT NULL,
  `hotelName` VARCHAR(50),
  `city` VARCHAR(50),
  PRIMARY KEY (`hotelNo`)
) CHARACTER SET latin1;
CREATE TABLE `Room` (
  `roomNo` INT NOT NULL,
  `hotelNo` INT NOT NULL,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`roomNo`, `hotelNo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293846_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293846_test') AS relationships;
DROP DATABASE `db_293846_test`;
UNINSTALL EXTENSION vsql_schematron;
