INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293680_create
--echo #
CREATE DATABASE `db_293680_create`;
USE `db_293680_create`;

CREATE TABLE `SPC_GEN_ROLE` (
  `id` DECIMAL(10,2),
  `authority` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SPC_GEN_TRZ` (
  `id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SPC_GEN_USER` (
  `id` DECIMAL(10,2),
  `account_non_expired` DECIMAL(10,2),
  `account_non_locked` DECIMAL(10,2),
  `credentials_non_expired` DECIMAL(10,2),
  `enabled` DECIMAL(10,2),
  `password` VARCHAR(255),
  `username` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SPC_GEN_USER_ROLE` (
  `user_id` DECIMAL(10,2),
  `role_id` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293680_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293680_create') AS relationships;
DROP DATABASE `db_293680_create`;
UNINSTALL EXTENSION vsql_schematron;
