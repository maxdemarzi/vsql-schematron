INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258531_Projektowanieoprogramowania.ddl
--echo #
CREATE DATABASE `db_258531_Projektowanieoprogramowania_ddl`;
USE `db_258531_Projektowanieoprogramowania_ddl`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Series` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `releaseYear` INT,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rate` (
  `rate` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`rate`)
) CHARACTER SET latin1;
CREATE TABLE `FollowedSeries` (
  `id` VARCHAR(50) NOT NULL,
  `rate` VARCHAR(50),
  `comment` VARCHAR(50),
  `userId` VARCHAR(50),
  `seriesId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Season` (
  `id` VARCHAR(50) NOT NULL,
  `number` INT,
  `description` VARCHAR(50),
  `releaseYear` INT,
  `seriesId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Episode` (
  `id` VARCHAR(50) NOT NULL,
  `number` INT,
  `title` VARCHAR(50),
  `releaseDate` VARCHAR(50),
  `duration` INT,
  `seasonId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WatchedEpisode` (
  `id` VARCHAR(50) NOT NULL,
  `rate` VARCHAR(50),
  `comment` VARCHAR(50),
  `userId` VARCHAR(50),
  `episodeId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258531_Projektowanieoprogramowania_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258531_Projektowanieoprogramowania_ddl') AS relationships;
DROP DATABASE `db_258531_Projektowanieoprogramowania_ddl`;
UNINSTALL EXTENSION vsql_schematron;
