INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 207318_migration
--echo #
CREATE DATABASE `db_207318_migration`;
USE `db_207318_migration`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lists` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `checked` VARCHAR(64),
  `note` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `list_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_lists` (
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` VARCHAR(64),
  `list_id` VARCHAR(64),
  PRIMARY KEY (`user_id`, `list_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_207318_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_207318_migration') AS relationships;
DROP DATABASE `db_207318_migration`;
UNINSTALL EXTENSION vsql_schematron;
