INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 265577_26.08.2021DUMP
--echo #
CREATE DATABASE `db_265577_26_08_2021DUMP`;
USE `db_265577_26_08_2021DUMP`;
CREATE TABLE `Ware` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `benutzer` (
  `idrfid` INT NOT NULL,
  `name` VARCHAR(50),
  `vorname` VARCHAR(50),
  `guthaben` DOUBLE,
  `isAdmin` INT,
  `chipid` BIGINT,
  PRIMARY KEY (`idrfid`)
) CHARACTER SET latin1;
CREATE TABLE `kauefe` (
  `id` INT NOT NULL,
  `Datum` DATE,
  `benutzer_idrfid` INT,
  `Ware_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_265577_26_08_2021DUMP') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_265577_26_08_2021DUMP') AS relationships;
DROP DATABASE `db_265577_26_08_2021DUMP`;
UNINSTALL EXTENSION vsql_schematron;
