INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226217_val_geo_init
--echo #
CREATE DATABASE `db_226217_val_geo_init`;
USE `db_226217_val_geo_init`;

CREATE TABLE `val_geo_ent` (
  `ent_id` INT,
  `ent_type` VARCHAR(64),
  `ent_name` VARCHAR(64),
  PRIMARY KEY (`ent_id`)
) CHARACTER SET latin1;

CREATE TABLE `val_geo` (
  `geo_id` INT,
  `geo_polygon` VARCHAR(64),
  PRIMARY KEY (`geo_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226217_val_geo_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226217_val_geo_init') AS relationships;
DROP DATABASE `db_226217_val_geo_init`;
UNINSTALL EXTENSION vsql_schematron;
