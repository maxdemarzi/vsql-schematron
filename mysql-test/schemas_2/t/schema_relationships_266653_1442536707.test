INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266653_1442536707
--echo #
CREATE DATABASE `db_266653_1442536707`;
USE `db_266653_1442536707`;

CREATE TABLE `mydb.field` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `value` VARCHAR(64),
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.option` (
  `id` INT,
  `option` VARCHAR(64),
  `field_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.collection` (
  `id` INT,
  `name` VARCHAR(64),
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.collectionfield` (
  `collection_id` INT,
  `field_id` INT,
  `id` INT,
  PRIMARY KEY (`id`, `collection_id`, `field_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266653_1442536707') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266653_1442536707') AS relationships;
DROP DATABASE `db_266653_1442536707`;
UNINSTALL EXTENSION vsql_schematron;
