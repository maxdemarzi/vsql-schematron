INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235004_V4_18_create_parse_workout_table
--echo #
CREATE DATABASE `db_235004_V4_18_create_parse_workout_table`;
USE `db_235004_V4_18_create_parse_workout_table`;

CREATE TABLE `ptcore.parse_workout` (
  `id` INT,
  `parse_user_id` INT,
  `created` DATETIME,
  `name` VARCHAR(255),
  `column_index` INT,
  `row_index` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ptcore.parse_warmup_workout_item` (
  `id` INT,
  `parse_workout_id` INT,
  `created` DATETIME,
  `name` VARCHAR(255),
  `speed` INT,
  `incline` INT,
  `time_in_min` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ptcore.parse_workout_item` (
  `id` INT,
  `parse_workout_id` INT,
  `created` DATETIME,
  `name` VARCHAR(255),
  `sets` INT,
  `repetitions` INT,
  `weight` INT,
  `bodyweight` VARCHAR(255),
  `time_in_min` INT,
  `speed` INT,
  `resistance` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235004_V4_18_create_parse_workout_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235004_V4_18_create_parse_workout_table') AS relationships;
DROP DATABASE `db_235004_V4_18_create_parse_workout_table`;
UNINSTALL EXTENSION vsql_schematron;
