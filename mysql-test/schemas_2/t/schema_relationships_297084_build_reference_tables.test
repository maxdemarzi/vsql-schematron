INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297084_build_reference_tables
--echo #
CREATE DATABASE `db_297084_build_reference_tables`;
USE `db_297084_build_reference_tables`;
CREATE TABLE `Attack` (
  `Id` INT NOT NULL,
  `DerivationID` INT,
  `Attack` TEXT,
  `StatUsed` TEXT,
  `AttackType` TEXT,
  `ItemRequired` TEXT,
  `GutsUsed` INT,
  `Damage` INT,
  `GutsDown` INT,
  `Critical` INT,
  `Hit` INT,
  `MaxLevel` INT,
  `AttackRange` TEXT,
  `Growth` TEXT,
  `Effect` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Characteristic` (
  `Id` INT NOT NULL,
  `Characteristic` TEXT,
  `Description` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Derivation` (
  `Id` INT NOT NULL,
  `Derivation` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Region` (
  `Id` INT NOT NULL,
  `Region` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297084_build_reference_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297084_build_reference_tables') AS relationships;
DROP DATABASE `db_297084_build_reference_tables`;
UNINSTALL EXTENSION vsql_schematron;
