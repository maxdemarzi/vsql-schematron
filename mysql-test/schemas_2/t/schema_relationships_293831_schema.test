INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293831_schema
--echo #
CREATE DATABASE `db_293831_schema`;
USE `db_293831_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `author_id` INT,
  `created` TIMESTAMP NULL,
  `title` TEXT,
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publication` (
  `id` INT NOT NULL,
  `type` TEXT,
  `author_block` TEXT,
  `title` TEXT,
  `journal` TEXT,
  `year` TEXT,
  `doi` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293831_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293831_schema') AS relationships;
DROP DATABASE `db_293831_schema`;
UNINSTALL EXTENSION vsql_schematron;
