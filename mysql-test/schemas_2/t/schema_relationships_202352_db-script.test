INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202352_db-script
--echo #
CREATE DATABASE `db_202352_db_script`;
USE `db_202352_db_script`;
CREATE TABLE `user` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `todo_item` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `priority` VARCHAR(50),
  `status` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202352_db_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202352_db_script') AS relationships;
DROP DATABASE `db_202352_db_script`;
UNINSTALL EXTENSION vsql_schematron;
