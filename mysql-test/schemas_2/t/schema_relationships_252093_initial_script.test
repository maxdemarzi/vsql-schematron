INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 252093_initial_script
--echo #
CREATE DATABASE `db_252093_initial_script`;
USE `db_252093_initial_script`;

CREATE TABLE `countries` (
  `id` INT,
  `capital_id` INT,
  `name_ru` VARCHAR(64),
  `name_en` VARCHAR(64),
  `name_de` VARCHAR(64),
  `name_es` VARCHAR(64),
  `name_fr` VARCHAR(64),
  `name_ja` VARCHAR(64),
  `native_name` VARCHAR(64),
  `alpha2_code` VARCHAR(64),
  `alpha3_code` VARCHAR(64),
  `flag` VARCHAR(64),
  `region` VARCHAR(64),
  `subregion` VARCHAR(64),
  `phone_code_prefix` VARCHAR(64),
  `nationality` VARCHAR(64),
  `currency` VARCHAR(64),
  `creditsafe_country` VARCHAR(64),
  `numeric_code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `regions` (
  `id` INT,
  `country_id` INT,
  `name_ru` VARCHAR(64),
  `name_en` VARCHAR(64),
  `name_ro` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cities` (
  `id` INT,
  `country_id` INT,
  `region_id` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `timezone` VARCHAR(64),
  `name_ru` VARCHAR(64),
  `name_en` VARCHAR(64),
  `name_ro` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `industries` (
  `id` INT,
  `name_ru` VARCHAR(64),
  `name_en` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_252093_initial_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_252093_initial_script') AS relationships;
DROP DATABASE `db_252093_initial_script`;
UNINSTALL EXTENSION vsql_schematron;
