INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273334_data
--echo #
CREATE DATABASE `db_273334_data`;
USE `db_273334_data`;

CREATE TABLE `privileges` (
  `id` INT,
  `name` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_at` DATETIME,
  `updated_by` VARCHAR(64),
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_at` DATETIME,
  `updated_by` VARCHAR(64),
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles_privileges` (
  `role_id` INT,
  `privilege_id` INT,
  PRIMARY KEY (`role_id`, `privilege_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `login_id` VARCHAR(64),
  `password` VARCHAR(64),
  `locked` VARCHAR(64),
  `enabled` VARCHAR(64),
  `expire` VARCHAR(64),
  `expire_at` DATETIME,
  `created_by` VARCHAR(64),
  `created_at` DATETIME,
  `updated_by` VARCHAR(64),
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `audit_logs` (
  `id` INT,
  `action` VARCHAR(64),
  `created_by` VARCHAR(64),
  `entity` VARCHAR(64),
  `timestamp` DATETIME,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273334_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273334_data') AS relationships;
DROP DATABASE `db_273334_data`;
UNINSTALL EXTENSION vsql_schematron;
