INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 252046_create-db
--echo #
CREATE DATABASE `db_252046_create_db`;
USE `db_252046_create_db`;

CREATE TABLE `Posts` (
  `ID` VARCHAR(64),
  `Title` VARCHAR(64),
  `Content` VARCHAR(64),
  `Created` DATETIME,
  `Updated` DATETIME,
  `Deleted` DATETIME,
  `Author` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Email` VARCHAR(64),
  `Password` VARCHAR(64),
  PRIMARY KEY (`Email`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_252046_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_252046_create_db') AS relationships;
DROP DATABASE `db_252046_create_db`;
UNINSTALL EXTENSION vsql_schematron;
