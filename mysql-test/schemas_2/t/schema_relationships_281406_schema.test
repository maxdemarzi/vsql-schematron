INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281406_schema
--echo #
CREATE DATABASE `db_281406_schema`;
USE `db_281406_schema`;

CREATE TABLE `tournament` (
  `id` INT,
  `title` VARCHAR(64),
  `t_date` VARCHAR(64),
  `current_rnd` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `player` (
  `id` INT,
  `tid` INT,
  `p_name` VARCHAR(64),
  `corp_id` VARCHAR(64),
  `runner_id` VARCHAR(64),
  `score` INT,
  `sos` DECIMAL(10,2),
  `esos` DECIMAL(10,2),
  `bias` INT,
  `games_played` INT,
  `received_bye` INT,
  `is_bye` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `match` (
  `id` INT,
  `match_num` INT,
  `tid` INT,
  `corp_id` INT,
  `runner_id` INT,
  `rnd` INT,
  `corp_score` INT,
  `runner_score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281406_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281406_schema') AS relationships;
DROP DATABASE `db_281406_schema`;
UNINSTALL EXTENSION vsql_schematron;
