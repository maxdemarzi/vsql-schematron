INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293504_schema
--echo #
CREATE DATABASE `db_293504_schema`;
USE `db_293504_schema`;

CREATE TABLE `api_user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role` INT
) CHARACTER SET latin1;

CREATE TABLE `chat` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `icon` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_management` (
  `id` INT,
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `language` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  `userid` INT,
  `iconid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `name` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `ispositive` VARCHAR(64),
  `note` VARCHAR(64),
  `categoryid` INT,
  `userid` INT,
  `chatid` INT,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293504_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293504_schema') AS relationships;
DROP DATABASE `db_293504_schema`;
UNINSTALL EXTENSION vsql_schematron;
