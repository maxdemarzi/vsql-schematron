INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 222611_db
--echo #
CREATE DATABASE `db_222611_db`;
USE `db_222611_db`;

CREATE TABLE `example_devs` (
  `id` INT,
  `uid` VARCHAR(64),
  `serial_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `example_dev_test_results` (
  `id` INT,
  `example_dev_id` INT,
  `group_entry_id` INT,
  `pass_fail` INT,
  `output_file_id` INT,
  `log_file_id` INT,
  `group_result_id` INT,
  `duration` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `example_dev_test_results_values` (
  `id` INT,
  `test_result_id` INT,
  `value_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_222611_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_222611_db') AS relationships;
DROP DATABASE `db_222611_db`;
UNINSTALL EXTENSION vsql_schematron;
