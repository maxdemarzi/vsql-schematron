INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217524_kontaktor_db
--echo #
CREATE DATABASE `db_217524_kontaktor_db`;
USE `db_217524_kontaktor_db`;

CREATE TABLE `tb_bahan` (
  `id_bahan` INT,
  `nama_bahan` VARCHAR(64),
  `jumlah` INT,
  `satuan` VARCHAR(64),
  `harga_satuan` INT,
  `harga_total` INT,
  `id_projek` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_jmlbiaya` (
  `id_jmlbiaya` INT,
  `id_projek` INT,
  `uraian` VARCHAR(64),
  `volume` INT,
  `luas` INT,
  `harga_satuan` INT,
  `harga_total` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_login` (
  `id_login` INT,
  `username` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `level` VARCHAR(64),
  PRIMARY KEY (`id_login`)
) CHARACTER SET latin1;

CREATE TABLE `tb_proses` (
  `id_proses` INT,
  `nama_mandor` VARCHAR(64),
  `foto` VARCHAR(64),
  `waktu` DATETIME,
  `ket` VARCHAR(64),
  `id_proyek` INT,
  `id_mandor` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_proyek` (
  `id_projek` INT,
  `nama_proyek` VARCHAR(64),
  `nama_mandor` VARCHAR(64),
  `lokasi` VARCHAR(64),
  `luas` INT,
  `tanggal` DATETIME,
  `id_login` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217524_kontaktor_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217524_kontaktor_db') AS relationships;
DROP DATABASE `db_217524_kontaktor_db`;
UNINSTALL EXTENSION vsql_schematron;
