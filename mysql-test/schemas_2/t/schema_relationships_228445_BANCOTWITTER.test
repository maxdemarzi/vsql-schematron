INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228445_BANCOTWITTER
--echo #
CREATE DATABASE `db_228445_BANCOTWITTER`;
USE `db_228445_BANCOTWITTER`;

CREATE TABLE `usuario` (
  `id` INT,
  `nome` VARCHAR(64),
  `login` VARCHAR(64),
  `senha` VARCHAR(64),
  `arroba` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `twits` (
  `id` INT,
  `nome_tw` VARCHAR(64),
  `arroba_tw` VARCHAR(64),
  `mensagem` VARCHAR(64),
  `data` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228445_BANCOTWITTER') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228445_BANCOTWITTER') AS relationships;
DROP DATABASE `db_228445_BANCOTWITTER`;
UNINSTALL EXTENSION vsql_schematron;
