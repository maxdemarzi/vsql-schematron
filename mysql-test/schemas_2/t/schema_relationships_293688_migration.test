INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293688_migration
--echo #
CREATE DATABASE `db_293688_migration`;
USE `db_293688_migration`;
CREATE TABLE `Role` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `canManageProducts` BOOLEAN,
  `canSeeOtherUsers` BOOLEAN,
  `canManageUsers` BOOLEAN,
  `canManageRoles` BOOLEAN,
  `canManageCart` BOOLEAN,
  `canManageOrgs` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `subjectId` TEXT,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293688_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293688_migration') AS relationships;
DROP DATABASE `db_293688_migration`;
UNINSTALL EXTENSION vsql_schematron;
