INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 260187_db
--echo #
CREATE DATABASE `db_260187_db`;
USE `db_260187_db`;
CREATE TABLE `roles` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `image` VARCHAR(50),
  `route` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `lastname` VARCHAR(50),
  `phone` VARCHAR(50),
  `password` VARCHAR(50),
  `salt` VARCHAR(50),
  `image` VARCHAR(50),
  `is_available` BOOLEAN,
  `session_token` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_has_roles` (
  `id_user` BIGINT NOT NULL,
  `id_role` BIGINT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_user`, `id_role`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_260187_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_260187_db') AS relationships;
DROP DATABASE `db_260187_db`;
UNINSTALL EXTENSION vsql_schematron;
