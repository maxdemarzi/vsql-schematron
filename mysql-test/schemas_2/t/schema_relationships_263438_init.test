INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 263438_init
--echo #
CREATE DATABASE `db_263438_init`;
USE `db_263438_init`;
CREATE TABLE `image_index` (
  `img_id` VARCHAR(50) NOT NULL,
  `filename` VARCHAR(50),
  `width` INT,
  `height` INT,
  PRIMARY KEY (`img_id`)
) CHARACTER SET latin1;
CREATE TABLE `image_data` (
  `img_data_id` VARCHAR(50) NOT NULL,
  `img_id` VARCHAR(50),
  `order_x` INT,
  `order_y` INT,
  `actual_width` INT,
  `actual_height` INT,
  `width` INT,
  `height` INT,
  `img_data` BLOB,
  PRIMARY KEY (`img_data_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_263438_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_263438_init') AS relationships;
DROP DATABASE `db_263438_init`;
UNINSTALL EXTENSION vsql_schematron;
