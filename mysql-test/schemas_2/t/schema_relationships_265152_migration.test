INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 265152_migration
--echo #
CREATE DATABASE `db_265152_migration`;
USE `db_265152_migration`;
CREATE TABLE `Idea` (
  `id` INT NOT NULL,
  `opportunity` BOOLEAN,
  `product` TEXT,
  `system` TEXT,
  `partNum` TEXT,
  `vendor` TEXT,
  `title` TEXT,
  `body` TEXT,
  `value` INT,
  `author` TEXT,
  `active` BOOLEAN,
  `finish` BOOLEAN,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Plan` (
  `id` INT NOT NULL,
  `ideaId` INT,
  `owner` TEXT,
  `plannedStart` DATETIME,
  `plannedEnd` DATETIME,
  `progress` INT,
  `finish` BOOLEAN,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
  `id` INT NOT NULL,
  `planId` INT,
  `type` TEXT,
  `owner` TEXT,
  `Requiredby` DATETIME,
  `status` TEXT,
  `Start` DATETIME,
  `Finish` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_265152_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_265152_migration') AS relationships;
DROP DATABASE `db_265152_migration`;
UNINSTALL EXTENSION vsql_schematron;
