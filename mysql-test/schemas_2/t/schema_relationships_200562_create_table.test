INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 200562_create_table
--echo #
CREATE DATABASE `db_200562_create_table`;
USE `db_200562_create_table`;
CREATE TABLE `CAYXANH` (
  `MaCay` INT NOT NULL,
  `GiongCay` VARCHAR(50),
  `LoaiCay` VARCHAR(50),
  `ToaDoX` DOUBLE,
  `ToaDoY` DOUBLE,
  `DiaChiCay` VARCHAR(50),
  `ChieuCao` INT,
  `SoTuoi` INT,
  `TrangThai` VARCHAR(50),
  PRIMARY KEY (`MaCay`)
) CHARACTER SET latin1;
CREATE TABLE `NGUOIDUNG` (
  `MaNguoiDung` VARCHAR(50) NOT NULL,
  `MatKhau` VARCHAR(50),
  `HoVaTen` VARCHAR(50),
  `Tuoi` TINYINT,
  `DiaChi` VARCHAR(50),
  `SDT` VARCHAR(50),
  PRIMARY KEY (`MaNguoiDung`)
) CHARACTER SET latin1;
CREATE TABLE `CHUCVU` (
  `MaChucVu` INT NOT NULL,
  `ChucVu` VARCHAR(50),
  PRIMARY KEY (`MaChucVu`)
) CHARACTER SET latin1;
CREATE TABLE `CONGVIEC` (
  `MaCongViec` VARCHAR(50) NOT NULL,
  `MaNguoiDung` VARCHAR(50),
  `TenCongViec` VARCHAR(50),
  `LoaiCongViec` VARCHAR(50),
  `ThoiGianBatDau` TIMESTAMP NULL,
  `ThoiGianKetThuc` TIMESTAMP NULL,
  PRIMARY KEY (`MaCongViec`)
) CHARACTER SET latin1;
CREATE TABLE `LIENKET_CHUCVU` (
  `MaLienKet` INT NOT NULL,
  `MaChucVu` INT,
  `MaNguoiDung` VARCHAR(50),
  `ChoPhep` BOOLEAN,
  PRIMARY KEY (`MaLienKet`)
) CHARACTER SET latin1;
CREATE TABLE `CHAMSOC_CAYXANH` (
  `MaCay` INT,
  `MaCongViec` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_200562_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_200562_create_table') AS relationships;
DROP DATABASE `db_200562_create_table`;
UNINSTALL EXTENSION vsql_schematron;
