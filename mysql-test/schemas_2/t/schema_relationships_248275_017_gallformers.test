INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 248275_017-gallformers
--echo #
CREATE DATABASE `db_248275_017_gallformers`;
USE `db_248275_017_gallformers`;

CREATE TABLE `place` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `placeplace` (
  `place_id` INT,
  `parent_id` INT,
  PRIMARY KEY (`place_id`, `parent_id`)
) CHARACTER SET latin1;

CREATE TABLE `speciesplace` (
  `species_id` INT,
  `place_id` INT,
  PRIMARY KEY (`species_id`, `place_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_248275_017_gallformers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_248275_017_gallformers') AS relationships;
DROP DATABASE `db_248275_017_gallformers`;
UNINSTALL EXTENSION vsql_schematron;
