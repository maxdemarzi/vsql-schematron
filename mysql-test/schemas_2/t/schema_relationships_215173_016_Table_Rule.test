INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215173_016_Table_Rule
--echo #
CREATE DATABASE `db_215173_016_Table_Rule`;
USE `db_215173_016_Table_Rule`;

CREATE TABLE `Rule` (
  `Id` INT,
  `ActionId` INT,
  `Name` VARCHAR(64),
  `IsRoot` BOOL,
  `MemberName` VARCHAR(64),
  `Operation` VARCHAR(64),
  `Value` VARCHAR(64),
  `RuleForPass` INT,
  `RuleForFail` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215173_016_Table_Rule') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215173_016_Table_Rule') AS relationships;
DROP DATABASE `db_215173_016_Table_Rule`;
UNINSTALL EXTENSION vsql_schematron;
