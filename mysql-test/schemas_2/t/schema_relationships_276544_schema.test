INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276544_schema
--echo #
CREATE DATABASE `db_276544_schema`;
USE `db_276544_schema`;
CREATE TABLE `TEAM` (
  `TEAM_ID` BIGINT NOT NULL,
  `TEAM_NAME` VARCHAR(50),
  `TEAM_NUMBER` BIGINT,
  `TEAM_DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`TEAM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MEMBERS` (
  `MEMBER_ID` BIGINT NOT NULL,
  `MEMBER_NAME` VARCHAR(50),
  `NICK_NAME` VARCHAR(50),
  `LOCATION` VARCHAR(50),
  `COUNTRY` VARCHAR(50),
  PRIMARY KEY (`MEMBER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TEAM_ALLOCATIONS` (
  `ALLOCATION_ID` BIGINT NOT NULL,
  `TEAM_ID` BIGINT,
  `MEMBER_ID` BIGINT,
  `ALLOCATION_START_DATE` DATE,
  `ALLOCATION_END_DATE` DATE,
  PRIMARY KEY (`ALLOCATION_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276544_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276544_schema') AS relationships;
DROP DATABASE `db_276544_schema`;
UNINSTALL EXTENSION vsql_schematron;
