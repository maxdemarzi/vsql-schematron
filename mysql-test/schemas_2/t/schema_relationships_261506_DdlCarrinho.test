INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 261506_DdlCarrinho
--echo #
CREATE DATABASE `db_261506_DdlCarrinho`;
USE `db_261506_DdlCarrinho`;
CREATE TABLE `TB_CARRINHO` (
  `COD` INT NOT NULL,
  PRIMARY KEY (`COD`)
) CHARACTER SET latin1;
CREATE TABLE `TB_PRODUTO` (
  `COD` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`COD`)
) CHARACTER SET latin1;
CREATE TABLE `RL_CARRINHO_PRODUTO` (
  `COD_CARRINHO` INT,
  `COD_PRODUTO` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_261506_DdlCarrinho') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_261506_DdlCarrinho') AS relationships;
DROP DATABASE `db_261506_DdlCarrinho`;
UNINSTALL EXTENSION vsql_schematron;
