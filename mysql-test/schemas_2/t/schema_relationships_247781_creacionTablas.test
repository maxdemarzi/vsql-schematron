INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 247781_creacionTablas
--echo #
CREATE DATABASE `db_247781_creacionTablas`;
USE `db_247781_creacionTablas`;
CREATE TABLE `estudiante` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `activo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `grupo` (
  `id` INT NOT NULL,
  `capacidad` INT,
  `nombreCurso` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estudiante_x_grupo` (
  `id` INT NOT NULL,
  `idEstudiante` INT,
  `idGrupo` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_247781_creacionTablas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_247781_creacionTablas') AS relationships;
DROP DATABASE `db_247781_creacionTablas`;
UNINSTALL EXTENSION vsql_schematron;
