INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 250773_schema
--echo #
CREATE DATABASE `db_250773_schema`;
USE `db_250773_schema`;

CREATE TABLE `logs` (
  `timestamp_utc` DATETIME,
  `event_id` INT,
  `description` VARCHAR(64),
  `details` VARCHAR(64),
  `event_source` VARCHAR(64),
  `event_log` VARCHAR(64),
  `session_id` INT,
  `account` VARCHAR(64),
  `computer_name` VARCHAR(64),
  `record_number` INT,
  `recovered` BOOL,
  `alias` VARCHAR(64),
  `record_hash` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `source_files` (
  `file_name` VARCHAR(64),
  `hash` VARCHAR(64),
  `import_timestamp` DATETIME,
  `alias` VARCHAR(64),
  `computer_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `raw_xml_data` (
  `record_hash` VARCHAR(64),
  `raw_xml` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_250773_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_250773_schema') AS relationships;
DROP DATABASE `db_250773_schema`;
UNINSTALL EXTENSION vsql_schematron;
