INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246751_struct
--echo #
CREATE DATABASE `db_246751_struct`;
USE `db_246751_struct`;
CREATE TABLE `occurrence` (
  `id_occurrence` INT NOT NULL,
  `id_resource` INT,
  `name_solicitant` VARCHAR(50),
  `phone` VARCHAR(50),
  `city` VARCHAR(50),
  `address` VARCHAR(50),
  `number_address` VARCHAR(50),
  `complement` VARCHAR(50),
  `neighborhood` VARCHAR(50),
  `reference_address` VARCHAR(50),
  `comments` TEXT,
  `emergency` VARCHAR(50),
  `status` VARCHAR(50),
  `location` VARCHAR(50),
  PRIMARY KEY (`id_occurrence`)
) CHARACTER SET latin1;
CREATE TABLE `patient` (
  `id_patient` INT NOT NULL,
  `name_patient` VARCHAR(50),
  `bith_year` INT,
  `blood_type` VARCHAR(50),
  `gender` VARCHAR(50),
  `allergy` VARCHAR(50),
  PRIMARY KEY (`id_patient`)
) CHARACTER SET latin1;
CREATE TABLE `occurrence_patient` (
  `id_occurrence_patient` INT NOT NULL,
  `id_patient` INT,
  `id_occurrence` INT,
  `complaint_patient` TEXT,
  `informations_patient` TEXT,
  `multimedia_communication` VARCHAR(50),
  PRIMARY KEY (`id_occurrence_patient`)
) CHARACTER SET latin1;
CREATE TABLE `resource` (
  `id_resource` INT NOT NULL,
  `board_resource` VARCHAR(50),
  `number_resource` VARCHAR(50),
  `status_resource` INT,
  `location` VARCHAR(50),
  `player_id` VARCHAR(50),
  `password_resource` VARCHAR(50),
  PRIMARY KEY (`id_resource`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246751_struct') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246751_struct') AS relationships;
DROP DATABASE `db_246751_struct`;
UNINSTALL EXTENSION vsql_schematron;
