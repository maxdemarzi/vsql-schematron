INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232911_migration
--echo #
CREATE DATABASE `db_232911_migration`;
USE `db_232911_migration`;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `username` TEXT,
  `firstName` TEXT,
  `lastName` TEXT,
  `updatedAt` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_channels` (
  `id` VARCHAR(50) NOT NULL,
  `userId` TEXT,
  `channelId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `channel` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `creatorId` TEXT,
  `updatedAt` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `isPrivate` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` VARCHAR(50) NOT NULL,
  `content` TEXT,
  `senderId` TEXT,
  `receiverId` TEXT,
  `updatedAt` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `channelId` TEXT,
  `seen` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232911_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232911_migration') AS relationships;
DROP DATABASE `db_232911_migration`;
UNINSTALL EXTENSION vsql_schematron;
