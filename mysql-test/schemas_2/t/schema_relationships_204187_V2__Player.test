INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204187_V2__Player
--echo #
CREATE DATABASE `db_204187_V2__Player`;
USE `db_204187_V2__Player`;
CREATE TABLE `auth_player` (
  `id` VARCHAR(50) NOT NULL,
  `provider` VARCHAR(50),
  `provider_user_id` VARCHAR(50),
  `locked` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_player_roles` (
  `players_id` VARCHAR(50) NOT NULL,
  `roles_name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`players_id`, `roles_name`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204187_V2__Player') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204187_V2__Player') AS relationships;
DROP DATABASE `db_204187_V2__Player`;
UNINSTALL EXTENSION vsql_schematron;
