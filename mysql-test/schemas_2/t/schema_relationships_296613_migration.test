INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 296613_migration
--echo #
CREATE DATABASE `db_296613_migration`;
USE `db_296613_migration`;

CREATE TABLE `Group` (
  `id` INT,
  `code` VARCHAR(64),
  `label` VARCHAR(64),
  `projectId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project` (
  `id` INT,
  `code` VARCHAR(64),
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Domain` (
  `id` INT,
  `projectId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Topic` (
  `id` INT,
  `domainId` INT,
  `projectId` INT,
  `parentId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_GroupToUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_ProjectToUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_296613_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_296613_migration') AS relationships;
DROP DATABASE `db_296613_migration`;
UNINSTALL EXTENSION vsql_schematron;
