INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280453_leaa-api-seed
--echo #
CREATE DATABASE `db_280453_leaa_api_seed`;
USE `db_280453_leaa_api_seed`;

CREATE TABLE `actions` (
  `id` INT,
  `ip` VARCHAR(64),
  `module` VARCHAR(64),
  `action` VARCHAR(64),
  `account` VARCHAR(64),
  `token` VARCHAR(64),
  `user_id` VARCHAR(64),
  `diff` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `address` VARCHAR(64),
  `province` VARCHAR(64),
  `city` VARCHAR(64),
  `area` VARCHAR(64),
  `consignee` VARCHAR(64),
  `zip` INT,
  `phone` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articles_categories_categories` (
  `articlesId` VARCHAR(64),
  `categoriesId` VARCHAR(64),
  PRIMARY KEY (`articlesId`, `categoriesId`)
) CHARACTER SET latin1;

CREATE TABLE `articles_tags_tags` (
  `articlesId` VARCHAR(64),
  `tagsId` VARCHAR(64),
  PRIMARY KEY (`articlesId`, `tagsId`)
) CHARACTER SET latin1;

CREATE TABLE `attachments` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `title` VARCHAR(64),
  `alt` VARCHAR(64),
  `type` VARCHAR(64),
  `filename` VARCHAR(64),
  `description` VARCHAR(64),
  `link` VARCHAR(64),
  `module_id` VARCHAR(64),
  `module_name` VARCHAR(64),
  `type_name` VARCHAR(64),
  `type_platform` VARCHAR(64),
  `ext` VARCHAR(64),
  `width` INT,
  `height` INT,
  `size` INT,
  `path` VARCHAR(64),
  `external_url` VARCHAR(64),
  `at2x` INT,
  `in_local` INT,
  `in_oss` INT,
  `user_id` VARCHAR(64),
  `sort` INT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles_permissions_permissions` (
  `rolesId` VARCHAR(64),
  `permissionsId` VARCHAR(64),
  PRIMARY KEY (`rolesId`, `permissionsId`)
) CHARACTER SET latin1;

CREATE TABLE `users_addresses_addresses` (
  `usersId` VARCHAR(64),
  `addressesId` VARCHAR(64),
  PRIMARY KEY (`usersId`, `addressesId`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles_roles` (
  `usersId` VARCHAR(64),
  `rolesId` VARCHAR(64),
  PRIMARY KEY (`usersId`, `rolesId`)
) CHARACTER SET latin1;

CREATE TABLE `verifications` (
  `id` INT,
  `token` VARCHAR(64),
  `code` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280453_leaa_api_seed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280453_leaa_api_seed') AS relationships;
DROP DATABASE `db_280453_leaa_api_seed`;
UNINSTALL EXTENSION vsql_schematron;
