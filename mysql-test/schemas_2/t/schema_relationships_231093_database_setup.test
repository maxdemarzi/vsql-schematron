INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231093_database_setup
--echo #
CREATE DATABASE `db_231093_database_setup`;
USE `db_231093_database_setup`;
CREATE TABLE `smallproject.Users` (
  `UserID` INT NOT NULL,
  `DateCreated` DATETIME,
  `DateLastLoggedIn` DATETIME,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `smallproject.ContactList` (
  `ContactID` INT NOT NULL,
  `UserID` INT,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `PhoneNumber` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`ContactID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231093_database_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231093_database_setup') AS relationships;
DROP DATABASE `db_231093_database_setup`;
UNINSTALL EXTENSION vsql_schematron;
