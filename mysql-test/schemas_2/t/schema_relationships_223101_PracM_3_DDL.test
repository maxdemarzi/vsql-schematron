INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 223101_PracM_3_DDL
--echo #
CREATE DATABASE `db_223101_PracM_3_DDL`;
USE `db_223101_PracM_3_DDL`;
CREATE TABLE `userTBL` (
  `아이디` VARCHAR(50) NOT NULL,
  `이름` VARCHAR(50),
  `생년` INT,
  `지역` CHAR(50),
  `국번` CHAR(50),
  `전화번호` CHAR(50),
  `키` INT,
  `가입일` DATE,
  PRIMARY KEY (`아이디`)
) CHARACTER SET latin1;
CREATE TABLE `buyTBL` (
  `순번` INT NOT NULL,
  `아이디` VARCHAR(50),
  `물품` VARCHAR(50),
  `분류` VARCHAR(50),
  `단가` INT,
  `수량` INT,
  PRIMARY KEY (`순번`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_223101_PracM_3_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_223101_PracM_3_DDL') AS relationships;
DROP DATABASE `db_223101_PracM_3_DDL`;
UNINSTALL EXTENSION vsql_schematron;
