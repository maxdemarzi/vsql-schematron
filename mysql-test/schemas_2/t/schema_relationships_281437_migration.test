INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281437_migration
--echo #
CREATE DATABASE `db_281437_migration`;
USE `db_281437_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  `email` TEXT,
  `hashedPassword` TEXT,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `expiresAt` DATETIME,
  `handle` TEXT,
  `hashedSessionToken` TEXT,
  `antiCSRFToken` TEXT,
  `publicData` TEXT,
  `privateData` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Token` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `hashedToken` TEXT,
  `type` TEXT,
  `expiresAt` DATETIME,
  `sentTo` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  `basePath` TEXT,
  `createdBy` TEXT,
  `updatedBy` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Stub` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `createdBy` TEXT,
  `updatedBy` TEXT,
  `path` TEXT,
  `method` TEXT,
  `contentType` TEXT,
  `statusCode` TEXT,
  `response` TEXT,
  `sleep` INT,
  `logs` TEXT,
  `projectId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281437_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281437_migration') AS relationships;
DROP DATABASE `db_281437_migration`;
UNINSTALL EXTENSION vsql_schematron;
