INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 223989_DbUtil
--echo #
CREATE DATABASE `db_223989_DbUtil`;
USE `db_223989_DbUtil`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `category` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
  `id` BIGINT NOT NULL,
  `ddd` INT,
  `number` VARCHAR(50),
  `type` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_223989_DbUtil') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_223989_DbUtil') AS relationships;
DROP DATABASE `db_223989_DbUtil`;
UNINSTALL EXTENSION vsql_schematron;
