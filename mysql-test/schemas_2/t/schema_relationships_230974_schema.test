INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 230974_schema
--echo #
CREATE DATABASE `db_230974_schema`;
USE `db_230974_schema`;

CREATE TABLE `TB_CLIENTE` (
  `id` INT,
  `nome` VARCHAR(64),
  `usuario` VARCHAR(64),
  `cpf` VARCHAR(64),
  `saldo` DECIMAL(10,2),
  `agencia` INT,
  `conta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TB_TP_OPERACAO` (
  `id` INT,
  `nome` VARCHAR(64),
  `ativo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TB_OPERACAO` (
  `id_cliente` INT,
  `id_operacao` INT,
  `data` DATETIME,
  `valor` DECIMAL(10,2),
  `descricao` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_230974_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_230974_schema') AS relationships;
DROP DATABASE `db_230974_schema`;
UNINSTALL EXTENSION vsql_schematron;
