INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273724_001_initial
--echo #
CREATE DATABASE `db_273724_001_initial`;
USE `db_273724_001_initial`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `surname` TEXT,
  `email` TEXT,
  `password` TEXT,
  `role` INT,
  `blocked` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `timers` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `start_time` TIMESTAMP NULL,
  `end_time` TIMESTAMP NULL,
  `pending` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `proofs` (
  `id` VARCHAR(50) NOT NULL,
  `timer_id` VARCHAR(50),
  `time` TIMESTAMP NULL,
  `percentage` DOUBLE,
  `confirmed` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273724_001_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273724_001_initial') AS relationships;
DROP DATABASE `db_273724_001_initial`;
UNINSTALL EXTENSION vsql_schematron;
