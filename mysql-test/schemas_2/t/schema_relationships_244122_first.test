INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 244122_first
--echo #
CREATE DATABASE `db_244122_first`;
USE `db_244122_first`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `student_id` VARCHAR(50),
  `hashed_password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `problems` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `testcases` VARCHAR(50),
  `author` VARCHAR(50),
  `timelimit` BIGINT,
  `memorylimit` BIGINT,
  `difficulty_level` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submissions` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `problem_id` BIGINT,
  `language` VARCHAR(50),
  `score` BIGINT,
  `result` VARCHAR(50),
  `code` TEXT,
  `created_at` TIMESTAMP NULL,
  `time` BIGINT,
  `memory` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `problem_id` BIGINT,
  `author` VARCHAR(50),
  `content` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_244122_first') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_244122_first') AS relationships;
DROP DATABASE `db_244122_first`;
UNINSTALL EXTENSION vsql_schematron;
