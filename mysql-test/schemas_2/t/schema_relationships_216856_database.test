INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 216856_database
--echo #
CREATE DATABASE `db_216856_database`;
USE `db_216856_database`;

CREATE TABLE `CATEGORIA` (
  `id` INT,
  `categoria` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `producto` (
  `id` INT,
  `title` VARCHAR(64),
  `price` INT,
  `id_category` INT,
  `description` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `usernmae` VARCHAR(64),
  `name` VARCHAR(64),
  `lastname` VARCHAR(64),
  `contact` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_216856_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_216856_database') AS relationships;
DROP DATABASE `db_216856_database`;
UNINSTALL EXTENSION vsql_schematron;
