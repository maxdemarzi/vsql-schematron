INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 242412_create-tables
--echo #
CREATE DATABASE `db_242412_create_tables`;
USE `db_242412_create_tables`;

CREATE TABLE `drs_object` (
  `id` VARCHAR(64),
  `description` VARCHAR(64),
  `created_time` DATETIME,
  `mime_type` VARCHAR(64),
  `name` VARCHAR(64),
  `size` INT,
  `updated_time` DATETIME,
  `version` VARCHAR(64),
  `is_bundle` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `file_access_object` (
  `id` INT,
  `drs_object_id` VARCHAR(64),
  `path` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `aws_s3_access_object` (
  `id` INT,
  `drs_object_id` VARCHAR(64),
  `region` VARCHAR(64),
  `bucket` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drs_object_alias` (
  `drs_object_id` VARCHAR(64),
  `alias` VARCHAR(64),
  PRIMARY KEY (`drs_object_id`, `alias`)
) CHARACTER SET latin1;

CREATE TABLE `drs_object_checksum` (
  `id` INT,
  `drs_object_id` VARCHAR(64),
  `checksum` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drs_object_bundle` (
  `parent_id` VARCHAR(64),
  `child_id` VARCHAR(64),
  PRIMARY KEY (`parent_id`, `child_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_242412_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_242412_create_tables') AS relationships;
DROP DATABASE `db_242412_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
