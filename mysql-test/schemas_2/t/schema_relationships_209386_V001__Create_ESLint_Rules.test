INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 209386_V001__Create_ESLint_Rules
--echo #
CREATE DATABASE `db_209386_V001__Create_ESLint_Rules`;
USE `db_209386_V001__Create_ESLint_Rules`;
CREATE TABLE `eslint_rules` (
  `rule_id` BIGINT NOT NULL,
  `core` BOOLEAN,
  `create_function` BLOB,
  `rule_type` VARCHAR(50),
  `category` VARCHAR(50),
  `recommended` BOOLEAN,
  `suggestion` BOOLEAN,
  `fixable` VARCHAR(50),
  `rule_schema` BLOB,
  `deprecated` BOOLEAN,
  `replaced_by` BLOB,
  PRIMARY KEY (`rule_id`)
) CHARACTER SET latin1;
CREATE TABLE `eslint_messages` (
  `message_id` BIGINT NOT NULL,
  `rule_id` BIGINT,
  `message_key` VARCHAR(50),
  `message_value` VARCHAR(50),
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_209386_V001__Create_ESLint_Rules') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_209386_V001__Create_ESLint_Rules') AS relationships;
DROP DATABASE `db_209386_V001__Create_ESLint_Rules`;
UNINSTALL EXTENSION vsql_schematron;
