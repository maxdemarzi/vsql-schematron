INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264681_script%20banco%20cinema
--echo #
CREATE DATABASE `db_264681_script_20banco_20cinema`;
USE `db_264681_script_20banco_20cinema`;

CREATE TABLE `filmes` (
  `id` INT,
  `titulo_obra` VARCHAR(64),
  `id_genero` VARCHAR(64),
  `nacionalidade` VARCHAR(64),
  `pais` VARCHAR(64),
  `lancamento` DATETIME,
  `distribuidora` VARCHAR(64),
  `origem_distribuidora` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sala` (
  `id` INT,
  `ano_exibicao` INT,
  `semana_exibicao` VARCHAR(64),
  `salas_na_semana` INT,
  `publico_na_semana` INT,
  `renda` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `genero` (
  `id_genero` VARCHAR(64),
  `genero` VARCHAR(64),
  PRIMARY KEY (`id_genero`)
) CHARACTER SET latin1;

CREATE TABLE `pais` (
  `pais` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264681_script_20banco_20cinema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264681_script_20banco_20cinema') AS relationships;
DROP DATABASE `db_264681_script_20banco_20cinema`;
UNINSTALL EXTENSION vsql_schematron;
