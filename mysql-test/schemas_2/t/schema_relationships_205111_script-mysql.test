INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 205111_script-mysql
--echo #
CREATE DATABASE `db_205111_script_mysql`;
USE `db_205111_script_mysql`;
CREATE TABLE `usuarios` (
  `idusr` INT NOT NULL,
  `codigo` VARCHAR(50),
  `nombre` VARCHAR(50),
  `clave` VARCHAR(50),
  PRIMARY KEY (`idusr`)
) CHARACTER SET latin1;
CREATE TABLE `opciones_menu` (
  `idopc` INT NOT NULL,
  `etiqueta` VARCHAR(50),
  `comando` VARCHAR(50),
  `estado` VARCHAR(50),
  PRIMARY KEY (`idopc`)
) CHARACTER SET latin1;
CREATE TABLE `accesos_usuario` (
  `idacc` INT NOT NULL,
  `idopc` INT,
  `idusr` INT,
  PRIMARY KEY (`idacc`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_205111_script_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_205111_script_mysql') AS relationships;
DROP DATABASE `db_205111_script_mysql`;
UNINSTALL EXTENSION vsql_schematron;
