INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 225671_create_db_tables
--echo #
CREATE DATABASE `db_225671_create_db_tables`;
USE `db_225671_create_db_tables`;

CREATE TABLE `Players` (
  `Id` INT,
  `Name` VARCHAR(64),
  `IsActive` INT
) CHARACTER SET latin1;

CREATE TABLE `Games` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Developer` VARCHAR(64),
  `Platform` VARCHAR(64),
  `ReleaseYear` INT,
  `IsActive` INT
) CHARACTER SET latin1;

CREATE TABLE `MatchRecords` (
  `Id` INT,
  `GameId` INT,
  `Player1Id` INT,
  `Player2Id` INT,
  `WinnerId` INT,
  `Date` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_225671_create_db_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_225671_create_db_tables') AS relationships;
DROP DATABASE `db_225671_create_db_tables`;
UNINSTALL EXTENSION vsql_schematron;
