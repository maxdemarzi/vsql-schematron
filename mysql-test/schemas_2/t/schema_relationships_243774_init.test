INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 243774_init
--echo #
CREATE DATABASE `db_243774_init`;
USE `db_243774_init`;

CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(64),
  `ProductVersion` VARCHAR(64),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;

CREATE TABLE `Address` (
  `Id` VARCHAR(64),
  `City` VARCHAR(64),
  `Country` VARCHAR(64),
  `Number` VARCHAR(64),
  `Street` VARCHAR(64),
  `ZipCode` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `Id` VARCHAR(64),
  `BillingAddressId` VARCHAR(64),
  `Birthday` DATETIME,
  `DeliveryAddressId` VARCHAR(64),
  `Email` VARCHAR(64),
  `FirstName` VARCHAR(64),
  `Name` VARCHAR(64),
  `Number` VARCHAR(64),
  `Title` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Bill` (
  `Id` VARCHAR(64),
  `AddressId` VARCHAR(64),
  `Customerid` VARCHAR(64),
  `DocumentDate` DATETIME,
  `Number` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Position` (
  `Id` VARCHAR(64),
  `Article` VARCHAR(64),
  `BillId` VARCHAR(64),
  `Comment` VARCHAR(64),
  `GrossAmmount` DECIMAL(10,2),
  `NetAmount` DECIMAL(10,2),
  `Number` INT,
  `TaxAmmount` DECIMAL(10,2),
  `ValidFrom` DATETIME,
  `ValidTo` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Reversal` (
  `Id` VARCHAR(64),
  `DocumentDate` DATETIME,
  `Number` VARCHAR(64),
  `ReferenceBillId` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_243774_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_243774_init') AS relationships;
DROP DATABASE `db_243774_init`;
UNINSTALL EXTENSION vsql_schematron;
