INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 205860_zwallet
--echo #
CREATE DATABASE `db_205860_zwallet`;
USE `db_205860_zwallet`;

CREATE TABLE `profile` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `photo` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `balance` VARCHAR(64),
  `pin` INT,
  `verified` VARCHAR(64),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_role` (
  `id` INT,
  `role_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tes` (
  `id` INT,
  `name` VARCHAR(64),
  `pass` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `top_up` (
  `id` INT,
  `step` INT,
  `article` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transfer` (
  `transfer_id` INT,
  `profile_id` INT,
  `receiver_id` INT,
  `amount` DECIMAL(10,2),
  `trans_name` VARCHAR(64),
  `trans_type` VARCHAR(64),
  `date` DATETIME,
  `note` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `wallet` (
  `wallet_id` INT,
  `user_id` INT,
  `pin` INT,
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`wallet_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_205860_zwallet') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_205860_zwallet') AS relationships;
DROP DATABASE `db_205860_zwallet`;
UNINSTALL EXTENSION vsql_schematron;
