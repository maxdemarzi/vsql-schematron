INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 230193_db
--echo #
CREATE DATABASE `db_230193_db`;
USE `db_230193_db`;
CREATE TABLE `actor` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `birth_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `synopsis` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_actor` (
  `movieid` INT,
  `actorid` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_230193_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_230193_db') AS relationships;
DROP DATABASE `db_230193_db`;
UNINSTALL EXTENSION vsql_schematron;
