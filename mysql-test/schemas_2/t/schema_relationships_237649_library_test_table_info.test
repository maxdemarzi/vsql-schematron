INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 237649_library_test_table_info
--echo #
CREATE DATABASE `db_237649_library_test_table_info`;
USE `db_237649_library_test_table_info`;
CREATE TABLE `librarian` (
  `lib_id` VARCHAR(50) NOT NULL,
  `f_name` VARCHAR(50),
  `l_name` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`lib_id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `uid` DECIMAL(10,2) NOT NULL,
  `f_name` VARCHAR(50),
  `l_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `yr` VARCHAR(50),
  `division` VARCHAR(50),
  `roll_no` DECIMAL(10,2),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `isbn` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `author` VARCHAR(50),
  `publisher` VARCHAR(50),
  `issued` VARCHAR(50),
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `issue_book` (
  `i_id` VARCHAR(50) NOT NULL,
  `lib_id` VARCHAR(50),
  `st_uid` DECIMAL(10,2),
  `isbn` DECIMAL(10,2),
  `issue_date` DATE,
  PRIMARY KEY (`i_id`)
) CHARACTER SET latin1;
CREATE TABLE `return_book` (
  `i_id` VARCHAR(50),
  `due_date` DATE,
  `fine` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_237649_library_test_table_info') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_237649_library_test_table_info') AS relationships;
DROP DATABASE `db_237649_library_test_table_info`;
UNINSTALL EXTENSION vsql_schematron;
