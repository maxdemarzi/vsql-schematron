INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 261982_myfirstsql
--echo #
CREATE DATABASE `db_261982_myfirstsql`;
USE `db_261982_myfirstsql`;

CREATE TABLE `customers` (
  `customerID` VARCHAR(64),
  `companyName` VARCHAR(64),
  `contactName` VARCHAR(64),
  `contactTitle` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `region` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `country` VARCHAR(64),
  `phone` VARCHAR(64),
  `fax` VARCHAR(64),
  PRIMARY KEY (`customerID`)
) CHARACTER SET latin1;

CREATE TABLE `territories` (
  `territoryID` VARCHAR(64),
  `territoryDescription` VARCHAR(64),
  `regionID` INT,
  PRIMARY KEY (`territoryID`)
) CHARACTER SET latin1;

CREATE TABLE `regions` (
  `regionid` INT,
  `regionDescription` VARCHAR(64),
  PRIMARY KEY (`regionid`)
) CHARACTER SET latin1;

CREATE TABLE `employee_territories` (
  `employeeID` INT,
  `territoryID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `shippers` (
  `shipperID` INT,
  `companyName` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`shipperID`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `orderID` INT,
  `customerID` VARCHAR(64),
  `employeeID` INT,
  `orderDate` DATETIME,
  `requiredDate` DATETIME,
  `shippedDate` DATETIME,
  `shipVia` INT,
  `freight` DECIMAL(10,2),
  `shipName` VARCHAR(64),
  `shipAddress` VARCHAR(64),
  `shipCity` VARCHAR(64),
  `shipRegion` VARCHAR(64),
  `shipPostalCode` VARCHAR(64),
  `shipCountry` VARCHAR(64),
  PRIMARY KEY (`orderID`)
) CHARACTER SET latin1;

CREATE TABLE `order_details` (
  `orderID` INT,
  `productID` INT,
  `unitPrice` DECIMAL(10,2),
  `quantity` INT,
  `discount` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_261982_myfirstsql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_261982_myfirstsql') AS relationships;
DROP DATABASE `db_261982_myfirstsql`;
UNINSTALL EXTENSION vsql_schematron;
