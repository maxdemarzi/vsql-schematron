INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228309_database
--echo #
CREATE DATABASE `db_228309_database`;
USE `db_228309_database`;
CREATE TABLE `user` (
  `user_id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `confirmed` TINYINT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
  `task_id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `completed` TINYINT,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
CREATE TABLE `habit` (
  `habit_id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `schedule` VARCHAR(50),
  `completions` VARCHAR(50),
  `daily` DATETIME,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`habit_id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `event_id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `date` DATETIME,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228309_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228309_database') AS relationships;
DROP DATABASE `db_228309_database`;
UNINSTALL EXTENSION vsql_schematron;
