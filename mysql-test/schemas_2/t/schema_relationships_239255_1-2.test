INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239255_1-2
--echo #
CREATE DATABASE `db_239255_1_2`;
USE `db_239255_1_2`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` CHAR(50),
  `name_surname` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_login_history` (
  `id` INT NOT NULL,
  `user_id` INT,
  `login_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239255_1_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239255_1_2') AS relationships;
DROP DATABASE `db_239255_1_2`;
UNINSTALL EXTENSION vsql_schematron;
