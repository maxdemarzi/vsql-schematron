INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 255927_db_life_saved
--echo #
CREATE DATABASE `db_255927_db_life_saved`;
USE `db_255927_db_life_saved`;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `nome` VARCHAR(50),
  `senha` CHAR(50),
  `email` VARCHAR(50),
  `cpf` CHAR(50),
  `telefone` VARCHAR(50),
  `sexo` CHAR(50),
  `foto` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `clinica` (
  `id_clinica` INT NOT NULL,
  `id_usuario` INT,
  `nome` VARCHAR(50),
  `senha` CHAR(50),
  `email` VARCHAR(50),
  `cnpj` CHAR(50),
  `estado` CHAR(50),
  `telefone` VARCHAR(50),
  `descricao` TEXT,
  PRIMARY KEY (`id_clinica`)
) CHARACTER SET latin1;
CREATE TABLE `contato` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `mensagem` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estados` (
  `id_estado` INT,
  `nome` VARCHAR(50),
  `sigla` CHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_255927_db_life_saved') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_255927_db_life_saved') AS relationships;
DROP DATABASE `db_255927_db_life_saved`;
UNINSTALL EXTENSION vsql_schematron;
