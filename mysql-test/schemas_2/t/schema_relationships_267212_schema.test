INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 267212_schema
--echo #
CREATE DATABASE `db_267212_schema`;
USE `db_267212_schema`;
CREATE TABLE `pm_conversations` (
  `id` VARCHAR(50) NOT NULL,
  `headline` VARCHAR(50),
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pm_messages` (
  `id` VARCHAR(50),
  `conversation_id` VARCHAR(50),
  `message` VARCHAR(50),
  `from_id` VARCHAR(50),
  `date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `pm_receivers` (
  `id` VARCHAR(50),
  `conversation_id` VARCHAR(50),
  `to_user_id` VARCHAR(50),
  `unread` TINYINT,
  `deleted` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_267212_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_267212_schema') AS relationships;
DROP DATABASE `db_267212_schema`;
UNINSTALL EXTENSION vsql_schematron;
