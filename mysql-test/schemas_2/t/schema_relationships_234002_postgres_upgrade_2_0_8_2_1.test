) CHARACTER SET latin1;

CREATE TABLE `ir_metadata_marc.identifier_type_sub_field_mapper` (
  `identifier_type_sub_field_mapper_id` INT,
  `data_field_mapper_id` INT,
  `marc_sub_field_id` INT,
  `identifier_type_id` INT,
  `version` INT,
  PRIMARY KEY (`identifier_type_sub_field_mapper_id`)
) CHARACTER SET latin1;

CREATE TABLE `ir_metadata_marc.extent_type_sub_field_mapper` (
  `extent_type_sub_field_mapper_id` INT,
  `data_field_mapper_id` INT,
  `marc_sub_field_id` INT,
  `extent_type_id` INT,
  `version` INT,
  PRIMARY KEY (`extent_type_sub_field_mapper_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_234002_postgres_upgrade_2_0_8_2_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_234002_postgres_upgrade_2_0_8_2_1') AS relationships;
DROP DATABASE `db_234002_postgres_upgrade_2_0_8_2_1`;
UNINSTALL EXTENSION vsql_schematron;
