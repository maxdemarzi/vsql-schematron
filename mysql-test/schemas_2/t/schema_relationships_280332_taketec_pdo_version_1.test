INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280332_taketec_pdo_version_1
--echo #
CREATE DATABASE `db_280332_taketec_pdo_version_1`;
USE `db_280332_taketec_pdo_version_1`;

CREATE TABLE `category` (
  `catId` INT,
  `description` VARCHAR(255),
  PRIMARY KEY (`catId`)
) CHARACTER SET latin1;

CREATE TABLE `category_has_news` (
  `catId` INT,
  `newsId` INT
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `commentId` INT,
  `content` VARCHAR(255),
  `newsId` INT,
  `userId` INT
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `imageId` INT,
  `imagePath` VARCHAR(255),
  `copyright` VARCHAR(255),
  `newsId` INT
) CHARACTER SET latin1;

CREATE TABLE `news` (
  `newsId` INT,
  `creation` DATETIME,
  `updated` DATETIME,
  `userId` INT,
  `content` VARCHAR(255),
  `copyright` VARCHAR(255),
  `paidNew` INT,
  `price` DECIMAL(10,2),
  `newsTitle` VARCHAR(255),
  `newsShortDescription` VARCHAR(255),
  `likes` INT,
  PRIMARY KEY (`newsId`)
) CHARACTER SET latin1;

CREATE TABLE `payment_method` (
  `paymentMethodId` INT,
  `userId` INT,
  `cardType` INT,
  `cardNumber` VARCHAR(255),
  `CVV` VARCHAR(255),
  `nameOnCard` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `purchased_article` (
  `newsId` INT,
  `userId` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `userId` INT,
  `firstName` VARCHAR(255),
  `surname` VARCHAR(255),
  `password` VARCHAR(255),
  `gender` VARCHAR(255),
  `DOB` DATETIME,
  `country` VARCHAR(255),
  `phone` VARCHAR(255),
  `eMail` VARCHAR(255),
  `permission` INT,
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280332_taketec_pdo_version_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280332_taketec_pdo_version_1') AS relationships;
DROP DATABASE `db_280332_taketec_pdo_version_1`;
UNINSTALL EXTENSION vsql_schematron;
