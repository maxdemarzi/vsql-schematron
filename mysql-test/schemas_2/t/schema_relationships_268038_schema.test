INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 268038_schema
--echo #
CREATE DATABASE `db_268038_schema`;
USE `db_268038_schema`;

CREATE TABLE `AD_CONTENT` (
  `AD_CONTENT_ID` INT,
  `CLICKTRACKERS` VARCHAR(64),
  `LINK_URL` VARCHAR(64),
  `TITLE` VARCHAR(64),
  PRIMARY KEY (`AD_CONTENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AD_CONTENT_ASSET` (
  `ID` INT,
  `DATA_LABEL` VARCHAR(64),
  `DATA_VALUE` VARCHAR(64),
  `IMAGE_HEIGHT` INT,
  `IMAGE_URL` VARCHAR(64),
  `IMAGE_WIDTH` INT,
  `CLICKTRACKERS` VARCHAR(64),
  `LINK_URL` VARCHAR(64),
  `DATA_NULLOR_DATA_VALUE_NULL` VARCHAR(64),
  `IMG_NULLOR_IMG_URL_NULL` VARCHAR(64),
  `LINK_NULLOR_LINK_URL_NULL` VARCHAR(64),
  `TITLE_TEXT` VARCHAR(64),
  `AD_CONTENT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `AD_CONTENT_IMPRESSION_URL` (
  `AD_CONTENT_ID` INT,
  `IMPRESSION_URL` VARCHAR(64),
  PRIMARY KEY (`AD_CONTENT_ID`, `IMPRESSION_URL`)
) CHARACTER SET latin1;

CREATE TABLE `AD_CONTENT_VIEW_URL` (
  `AD_CONTENT_ID` INT,
  `VIEW_URL` VARCHAR(64),
  PRIMARY KEY (`AD_CONTENT_ID`, `VIEW_URL`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_268038_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_268038_schema') AS relationships;
DROP DATABASE `db_268038_schema`;
UNINSTALL EXTENSION vsql_schematron;
