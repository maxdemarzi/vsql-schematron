INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 261159_bd_ahrm_cds
--echo #
CREATE DATABASE `db_261159_bd_ahrm_cds`;
USE `db_261159_bd_ahrm_cds`;

CREATE TABLE `uf` (
  `sigla` VARCHAR(64),
  `nome` VARCHAR(64),
  PRIMARY KEY (`sigla`)
) CHARACTER SET latin1;

CREATE TABLE `medico` (
  `codigo` INT,
  `nome_medico` VARCHAR(64),
  `cpf_medico` VARCHAR(64),
  `crm` VARCHAR(64),
  `email_medico` VARCHAR(64),
  `telefone` VARCHAR(64),
  `senha` VARCHAR(64),
  `uf` VARCHAR(64),
  `cidade` VARCHAR(64),
  `bairro` VARCHAR(64),
  `rua` VARCHAR(64),
  `numero` VARCHAR(64),
  `genero` VARCHAR(64),
  `data_de_nascimento` DATETIME,
  `nome_imagem_perfil` VARCHAR(64),
  `tamanho_imagem_perfil` VARCHAR(64),
  `tipo_imagem_perfil` VARCHAR(64),
  `imagem_perfil` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `paciente` (
  `codigo` INT,
  `nome_paciente` VARCHAR(64),
  `cpf_paciente` VARCHAR(64),
  `email_paciente` VARCHAR(64),
  `telefone` VARCHAR(64),
  `senha` VARCHAR(64),
  `uf` VARCHAR(64),
  `cidade` VARCHAR(64),
  `bairro` VARCHAR(64),
  `rua` VARCHAR(64),
  `numero` VARCHAR(64),
  `genero` VARCHAR(64),
  `peso` VARCHAR(64),
  `altura` VARCHAR(64),
  `diabetico` VARCHAR(64),
  `data_de_nascimento` DATETIME,
  `nome_imagem_perfil` VARCHAR(64),
  `tamanho_imagem_perfil` VARCHAR(64),
  `tipo_imagem_perfil` VARCHAR(64),
  `imagem_perfil` VARCHAR(64),
  `medico_paciente` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `pedido_vinculo` (
  `codigo` INT,
  `codigo_medico` INT,
  `codigo_paciente` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `vinculo` (
  `codigo` INT,
  `codigo_medico` INT,
  `codigo_paciente` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `sintoma` (
  `codigo` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `exame` (
  `codigo` INT,
  `codigo_paciente` INT,
  `codigo_medico` INT,
  `data_do_exame` DATETIME,
  `tipo_exame` VARCHAR(64),
  `descricao_exame` VARCHAR(64),
  `nome_pdf` VARCHAR(64),
  `tamanho_pdf` VARCHAR(64),
  `tipo_pdf` VARCHAR(64),
  `pdf` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `laudo` (
  `codigo` INT,
  `codigo_paciente` INT,
  `codigo_medico` INT,
  `data_do_laudo` DATETIME,
  `descricao_laudo` VARCHAR(64),
  `nome_pdf` VARCHAR(64),
  `tamanho_pdf` VARCHAR(64),
  `tipo_pdf` VARCHAR(64),
  `pdf` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `tratamento` (
  `codigo` INT,
  `codigo_paciente` INT,
  `codigo_medico` INT,
  `data_do_tratamento` DATETIME,
  `descricao_tratamento` VARCHAR(64),
  `nome_pdf` VARCHAR(64),
  `tamanho_pdf` VARCHAR(64),
  `tipo_pdf` VARCHAR(64),
  `pdf` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_261159_bd_ahrm_cds') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_261159_bd_ahrm_cds') AS relationships;
DROP DATABASE `db_261159_bd_ahrm_cds`;
UNINSTALL EXTENSION vsql_schematron;
