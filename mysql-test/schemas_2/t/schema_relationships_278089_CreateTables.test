INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278089_CreateTables
--echo #
CREATE DATABASE `db_278089_CreateTables`;
USE `db_278089_CreateTables`;

CREATE TABLE `roles` (
  `id` INT,
  `roleName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `isActive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `userId` INT,
  `roleId` INT
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `categoryName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `statuses` (
  `id` INT,
  `statusName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `activities` (
  `id` INT,
  `activityName` VARCHAR(64),
  `dateStart` DATETIME,
  `dateEnd` DATETIME,
  `categoryId` INT,
  `statusId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_activities` (
  `id` INT,
  `activityId` INT,
  `activityOwner` INT,
  `activityPerformer` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278089_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278089_CreateTables') AS relationships;
DROP DATABASE `db_278089_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
