INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220877_create-table
--echo #
CREATE DATABASE `db_220877_create_table`;
USE `db_220877_create_table`;
CREATE TABLE `users` (
  `oid` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `Age` VARCHAR(50),
  `Sex` VARCHAR(50),
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
  `id` INT NOT NULL,
  `item` VARCHAR(50),
  `owner_oid` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220877_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220877_create_table') AS relationships;
DROP DATABASE `db_220877_create_table`;
UNINSTALL EXTENSION vsql_schematron;
