INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266672_20200929003456_create_base_tables
--echo #
CREATE DATABASE `db_266672_20200929003456_create_base_tables`;
USE `db_266672_20200929003456_create_base_tables`;

CREATE TABLE `beer` (
  `id` INT,
  `name` VARCHAR(255),
  `style` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `batch` (
  `id` INT,
  `beer_id` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `batch_measurement` (
  `batch_id` INT,
  `name` VARCHAR(255),
  `value` DECIMAL(10,2),
  `time` DATETIME,
  PRIMARY KEY (`batch_id`, `name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266672_20200929003456_create_base_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266672_20200929003456_create_base_tables') AS relationships;
DROP DATABASE `db_266672_20200929003456_create_base_tables`;
UNINSTALL EXTENSION vsql_schematron;
