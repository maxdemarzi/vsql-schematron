INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213370_migration
--echo #
CREATE DATABASE `db_213370_migration`;
USE `db_213370_migration`;

CREATE TABLE `users` (
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `github_id` VARCHAR(64),
  `gitlab_id` VARCHAR(64),
  `picture_url` VARCHAR(64),
  `occupation` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_technologies` (
  `user_id` VARCHAR(64),
  `category_id` VARCHAR(64),
  `focus` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`user_id`, `category_id`)
) CHARACTER SET latin1;

CREATE TABLE `challenges` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `difficulty` VARCHAR(64),
  `helps` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `challenge_resolutions` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `challenge_id` VARCHAR(64),
  `created_at` DATETIME,
  `resolution_link` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `challenge_resolution_comments` (
  `id` VARCHAR(64),
  `resolution_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `message` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` VARCHAR(64),
  `from_id` VARCHAR(64),
  `message` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ChallengeCategory` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213370_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213370_migration') AS relationships;
DROP DATABASE `db_213370_migration`;
UNINSTALL EXTENSION vsql_schematron;
