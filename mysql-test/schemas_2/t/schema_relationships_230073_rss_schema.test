INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 230073_rss_schema
--echo #
CREATE DATABASE `db_230073_rss_schema`;
USE `db_230073_rss_schema`;

CREATE TABLE `channel` (
  `id` INT,
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `channel_id` INT,
  `channel` INT,
  `title` VARCHAR(64),
  `link` VARCHAR(64),
  `description` VARCHAR(64),
  `language` VARCHAR(64),
  `copyright` VARCHAR(64),
  `managing_editor` VARCHAR(64),
  `web_master` VARCHAR(64),
  `pub_date` DATETIME,
  `last_build_date` DATETIME,
  `generator` VARCHAR(64),
  `docs` VARCHAR(64),
  `cloud_id` INT,
  `ttl` INT,
  `image_id` INT,
  `skip_hours` VARCHAR(64),
  `skip_days` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `category` VARCHAR(64),
  `domain` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_category` (
  `id` INT,
  `category_id` INT,
  `item_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `id` INT,
  `url` VARCHAR(64),
  `title` VARCHAR(64),
  `link` VARCHAR(64),
  `width` INT,
  `height` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cloud` (
  `id` INT,
  `domain` VARCHAR(64),
  `port` VARCHAR(64),
  `path` VARCHAR(64),
  `register_procedure` VARCHAR(64),
  `protocol` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_230073_rss_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_230073_rss_schema') AS relationships;
DROP DATABASE `db_230073_rss_schema`;
UNINSTALL EXTENSION vsql_schematron;
