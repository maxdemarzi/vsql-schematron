INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 237838_cinema
--echo #
CREATE DATABASE `db_237838_cinema`;
USE `db_237838_cinema`;

CREATE TABLE `cinema` (
  `cinemaId` INT,
  `cinemaName` VARCHAR(64),
  `mailingAddress` VARCHAR(64),
  PRIMARY KEY (`cinemaId`)
) CHARACTER SET latin1;

CREATE TABLE `movie` (
  `movieId` INT,
  `title` VARCHAR(64),
  `releaseYear` INT,
  `rating` VARCHAR(64),
  PRIMARY KEY (`movieId`)
) CHARACTER SET latin1;

CREATE TABLE `moviesShown` (
  `movieId` INT,
  `screenId` INT,
  PRIMARY KEY (`movieId`, `screenId`)
) CHARACTER SET latin1;

CREATE TABLE `projector` (
  `serialNo` VARCHAR(64),
  `screenId` INT,
  `projectorType` VARCHAR(64),
  `modelNumber` VARCHAR(64),
  `resolution` VARCHAR(64),
  `usedHours` DECIMAL(10,2),
  PRIMARY KEY (`serialNo`)
) CHARACTER SET latin1;

CREATE TABLE `screen` (
  `screenId` INT,
  `cinemaId` INT,
  `size` DECIMAL(10,2),
  `capacity` INT,
  `goldclass` INT,
  PRIMARY KEY (`screenId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_237838_cinema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_237838_cinema') AS relationships;
DROP DATABASE `db_237838_cinema`;
UNINSTALL EXTENSION vsql_schematron;
