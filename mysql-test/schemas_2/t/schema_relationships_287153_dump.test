INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 287153_dump
--echo #
CREATE DATABASE `db_287153_dump`;
USE `db_287153_dump`;

CREATE TABLE `hibernate_sequence` (
  `next_val` INT
) CHARACTER SET latin1;

CREATE TABLE `mood_entry` (
  `id` INT,
  `creation_time` DATETIME,
  `description` VARCHAR(64),
  `mood` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mood_entry_tags` (
  `mood_entry_id` INT,
  `tags_id` INT,
  PRIMARY KEY (`mood_entry_id`, `tags_id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `keyword` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_287153_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_287153_dump') AS relationships;
DROP DATABASE `db_287153_dump`;
UNINSTALL EXTENSION vsql_schematron;
