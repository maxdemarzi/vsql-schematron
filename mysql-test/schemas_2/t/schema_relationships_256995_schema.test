INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 256995_schema
--echo #
CREATE DATABASE `db_256995_schema`;
USE `db_256995_schema`;
CREATE TABLE `locations` (
  `id` INT NOT NULL,
  `search_query` VARCHAR(50),
  `formatted_query` VARCHAR(50),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
  `id` INT NOT NULL,
  `forecast` VARCHAR(50),
  `time` VARCHAR(50),
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `overview` VARCHAR(50),
  `average_votes` DOUBLE,
  `total_votes` INT,
  `image_url` VARCHAR(50),
  `popularity` DECIMAL(10,2),
  `released_on` CHAR(50),
  `created_at` BIGINT,
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `yelp` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `price` CHAR(50),
  `rating` DECIMAL(10,2),
  `image_url` VARCHAR(50),
  `created_at` BIGINT,
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_256995_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_256995_schema') AS relationships;
DROP DATABASE `db_256995_schema`;
UNINSTALL EXTENSION vsql_schematron;
