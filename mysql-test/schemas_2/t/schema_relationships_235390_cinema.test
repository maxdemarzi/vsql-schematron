INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235390_cinema
--echo #
CREATE DATABASE `db_235390_cinema`;
USE `db_235390_cinema`;
CREATE TABLE `movielist` (
  `movienum` INT NOT NULL,
  `name` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`movienum`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
  `name` VARCHAR(50),
  `phone` VARCHAR(50) NOT NULL,
  `age` INT,
  PRIMARY KEY (`phone`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `ordernum` INT NOT NULL,
  `phone` VARCHAR(50),
  `movienum` INT,
  `time` INT,
  `seat` INT,
  PRIMARY KEY (`ordernum`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235390_cinema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235390_cinema') AS relationships;
DROP DATABASE `db_235390_cinema`;
UNINSTALL EXTENSION vsql_schematron;
