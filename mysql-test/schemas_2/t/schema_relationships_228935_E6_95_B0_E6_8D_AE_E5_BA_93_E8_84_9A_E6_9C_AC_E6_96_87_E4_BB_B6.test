INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228935_%E6%95%B0%E6%8D%AE%E5%BA%93%E8%84%9A%E6%9C%AC%E6%96%87%E4%BB%B6
--echo #
CREATE DATABASE `db_228935_E6_95_B0_E6_8D_AE_E5_BA_93_E8_84_9A_E6_9C_AC_E6_96`;
USE `db_228935_E6_95_B0_E6_8D_AE_E5_BA_93_E8_84_9A_E6_9C_AC_E6_96`;

CREATE TABLE `tb_role` (
  `id` INT,
  `role_name` VARCHAR(64),
  `role_author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_user_role` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_address_province` (
  `id` INT,
  `pro_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_address_city` (
  `id` INT,
  `pro_id` INT,
  `city_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_address_area` (
  `id` INT,
  `pro_id` INT,
  `city_id` INT,
  `area_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228935_E6_95_B0_E6_8D_AE_E5_BA_93_E8_84_9A_E6_9C_AC_E6_96') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228935_E6_95_B0_E6_8D_AE_E5_BA_93_E8_84_9A_E6_9C_AC_E6_96') AS relationships;
DROP DATABASE `db_228935_E6_95_B0_E6_8D_AE_E5_BA_93_E8_84_9A_E6_9C_AC_E6_96`;
UNINSTALL EXTENSION vsql_schematron;
