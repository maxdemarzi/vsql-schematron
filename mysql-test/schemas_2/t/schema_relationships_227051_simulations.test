INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227051_simulations
--echo #
CREATE DATABASE `db_227051_simulations`;
USE `db_227051_simulations`;
CREATE TABLE `Simulations` (
  `SIMID` VARCHAR(50) NOT NULL,
  `FullName` TEXT,
  `Shortname` TEXT,
  `Executable` TEXT,
  `Output` TEXT,
  `Configuration` BLOB,
  `ExecutionPrefix` TEXT,
  `ExecutionHostFile` TEXT,
  PRIMARY KEY (`SIMID`)
) CHARACTER SET latin1;
CREATE TABLE `Instances` (
  `IID` VARCHAR(50) NOT NULL,
  `SIMID` TEXT,
  `Status` TEXT,
  PRIMARY KEY (`IID`)
) CHARACTER SET latin1;
CREATE TABLE `Data` (
  `DIID` INT NOT NULL,
  `IID` TEXT,
  `Source` TEXT,
  PRIMARY KEY (`DIID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227051_simulations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227051_simulations') AS relationships;
DROP DATABASE `db_227051_simulations`;
UNINSTALL EXTENSION vsql_schematron;
