INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 282421_schema
--echo #
CREATE DATABASE `db_282421_schema`;
USE `db_282421_schema`;

CREATE TABLE `Employees` (
  `tfn` VARCHAR(64),
  `givenName` VARCHAR(64),
  `familyName` VARCHAR(64),
  `hoursPweek` DECIMAL(10,2),
  PRIMARY KEY (`tfn`)
) CHARACTER SET latin1;

CREATE TABLE `Departments` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `manager` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `DeptMissions` (
  `department` VARCHAR(64),
  `keyword` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `WorksFor` (
  `employee` VARCHAR(64),
  `department` VARCHAR(64),
  `percentage` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_282421_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_282421_schema') AS relationships;
DROP DATABASE `db_282421_schema`;
UNINSTALL EXTENSION vsql_schematron;
