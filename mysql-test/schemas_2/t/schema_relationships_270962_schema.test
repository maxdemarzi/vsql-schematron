INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 270962_schema
--echo #
CREATE DATABASE `db_270962_schema`;
USE `db_270962_schema`;
CREATE TABLE `VIZO_DS_ORDER` (
  `ID` BIGINT NOT NULL,
  `BUYER_NAME` VARCHAR(50),
  `TOTAL` DOUBLE,
  `CREATED_ON` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VIZO_DS_ITEM` (
  `ID` BIGINT NOT NULL,
  `PRICE` DOUBLE,
  `ORDER_ID` BIGINT,
  `CREATED_ON` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_270962_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_270962_schema') AS relationships;
DROP DATABASE `db_270962_schema`;
UNINSTALL EXTENSION vsql_schematron;
