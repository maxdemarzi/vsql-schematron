INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 262314_pizzaria
--echo #
CREATE DATABASE `db_262314_pizzaria`;
USE `db_262314_pizzaria`;
CREATE TABLE `pizzas` (
  `idpizzas` INT NOT NULL,
  `pizzas` VARCHAR(50),
  `valor` DOUBLE,
  PRIMARY KEY (`idpizzas`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `idpedido` INT NOT NULL,
  `idpizzas` INT,
  `quantidade` INT,
  `valorPedido` DOUBLE,
  PRIMARY KEY (`idpedido`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_262314_pizzaria') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_262314_pizzaria') AS relationships;
DROP DATABASE `db_262314_pizzaria`;
UNINSTALL EXTENSION vsql_schematron;
