INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281704_1
--echo #
CREATE DATABASE `db_281704_1`;
USE `db_281704_1`;

CREATE TABLE `app_user` (
  `app_user_id` VARCHAR(64),
  `username` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `is_manager` BOOL,
  `timestamp_created` DATETIME,
  `timestamp_edited` DATETIME,
  PRIMARY KEY (`app_user_id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `project_id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `timestamp_created` DATETIME,
  `timestamp_edited` DATETIME,
  `billable` BOOL,
  `owned_by` VARCHAR(64),
  `created_by` VARCHAR(64),
  `last_edited_by` VARCHAR(64),
  `client_id` VARCHAR(64),
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;

CREATE TABLE `project_app_user` (
  `project_id` VARCHAR(64),
  `app_user_id` VARCHAR(64),
  PRIMARY KEY (`project_id`, `app_user_id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `client_id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `timestamp_created` DATETIME,
  `timestamp_edited` DATETIME,
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281704_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281704_1') AS relationships;
DROP DATABASE `db_281704_1`;
UNINSTALL EXTENSION vsql_schematron;
