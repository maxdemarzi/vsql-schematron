INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228814_schema
--echo #
CREATE DATABASE `db_228814_schema`;
USE `db_228814_schema`;

CREATE TABLE `lang` (
  `lang` VARCHAR(64),
  `lang_name` VARCHAR(64),
  PRIMARY KEY (`lang`)
) CHARACTER SET latin1;

CREATE TABLE `datatype` (
  `datatype` VARCHAR(64),
  `datatype_name` VARCHAR(64),
  PRIMARY KEY (`datatype`)
) CHARACTER SET latin1;

CREATE TABLE `usr` (
  `usr` VARCHAR(64),
  `usr_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `source` (
  `source` VARCHAR(64),
  `source_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `tag` VARCHAR(64),
  `tag_name` VARCHAR(64),
  `datatype` VARCHAR(64),
  PRIMARY KEY (`tag`)
) CHARACTER SET latin1;

CREATE TABLE `dataset` (
  `dataset` VARCHAR(64),
  `source` VARCHAR(64),
  `dataset_name` VARCHAR(64),
  PRIMARY KEY (`dataset`)
) CHARACTER SET latin1;

CREATE TABLE `import` (
  `import` INT,
  `stamp` DATETIME,
  `dataset` VARCHAR(64),
  `usr` VARCHAR(64),
  PRIMARY KEY (`import`)
) CHARACTER SET latin1;

CREATE TABLE `col` (
  `col` INT,
  `import` INT,
  `tag` VARCHAR(64),
  `header` VARCHAR(64),
  PRIMARY KEY (`col`)
) CHARACTER SET latin1;

CREATE TABLE `row` (
  `row` INT,
  PRIMARY KEY (`row`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228814_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228814_schema') AS relationships;
DROP DATABASE `db_228814_schema`;
UNINSTALL EXTENSION vsql_schematron;
