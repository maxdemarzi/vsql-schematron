INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283597_Countries
--echo #
CREATE DATABASE `db_283597_Countries`;
USE `db_283597_Countries`;

CREATE TABLE `country` (
  `country_code_id` INT,
  PRIMARY KEY (`country_code_id`)
) CHARACTER SET latin1;

CREATE TABLE `country_code` (
  `country_code_id` INT,
  `country_code_value` VARCHAR(64),
  PRIMARY KEY (`country_code_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283597_Countries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283597_Countries') AS relationships;
DROP DATABASE `db_283597_Countries`;
UNINSTALL EXTENSION vsql_schematron;
