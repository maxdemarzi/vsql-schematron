INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 265685_create-tables
--echo #
CREATE DATABASE `db_265685_create_tables`;
USE `db_265685_create_tables`;
CREATE TABLE `tweets` (
  `id` VARCHAR(50) NOT NULL,
  `text` TEXT,
  `url` TEXT,
  `datetime` TEXT,
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `icon_url` TEXT,
  `user_url` TEXT,
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets_x_users` (
  `tweet_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50) NOT NULL,
  `omukae_done` INT,
  `created_at` INT,
  PRIMARY KEY (`tweet_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `scrape_histories` (
  `completed` INT,
  `created_at` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_265685_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_265685_create_tables') AS relationships;
DROP DATABASE `db_265685_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
