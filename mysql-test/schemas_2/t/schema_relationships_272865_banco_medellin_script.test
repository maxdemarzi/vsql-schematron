INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 272865_banco_medellin_script
--echo #
CREATE DATABASE `db_272865_banco_medellin_script`;
USE `db_272865_banco_medellin_script`;

CREATE TABLE `ciudad` (
  `id` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cuenta` (
  `num` INT,
  `cedula` VARCHAR(64),
  `nombre` VARCHAR(64),
  `telefono` VARCHAR(64),
  `saldo` DECIMAL(10,2),
  `ciudad_id` INT,
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;

CREATE TABLE `tipo_transaccion` (
  `id` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaccion` (
  `id` INT,
  `valor` DECIMAL(10,2),
  `fecha` DATETIME,
  `tipo` INT,
  `cuenta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_272865_banco_medellin_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_272865_banco_medellin_script') AS relationships;
DROP DATABASE `db_272865_banco_medellin_script`;
UNINSTALL EXTENSION vsql_schematron;
