INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 274266_init
--echo #
CREATE DATABASE `db_274266_init`;
USE `db_274266_init`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `created_on` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `book_id` VARCHAR(64),
  `isbn` VARCHAR(64),
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `publisher` VARCHAR(64),
  `pages` INT,
  `year` INT,
  `submitter` VARCHAR(64),
  `created_on` DATETIME,
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_book_list` (
  `book_id` VARCHAR(64),
  `username` VARCHAR(64),
  `status` VARCHAR(64),
  `score` INT,
  `start_date` DATETIME,
  `end_date` DATETIME,
  `created_on` DATETIME,
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `movie_id` VARCHAR(64),
  `title` VARCHAR(64),
  `studio` VARCHAR(64),
  `director` VARCHAR(64),
  `writer` VARCHAR(64),
  `duration` INT,
  `year` INT,
  `submitter` VARCHAR(64),
  `created_on` DATETIME,
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_movie_list` (
  `movie_id` VARCHAR(64),
  `username` VARCHAR(64),
  `status` VARCHAR(64),
  `score` INT,
  `start_date` DATETIME,
  `end_date` DATETIME,
  `created_on` DATETIME,
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_274266_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_274266_init') AS relationships;
DROP DATABASE `db_274266_init`;
UNINSTALL EXTENSION vsql_schematron;
