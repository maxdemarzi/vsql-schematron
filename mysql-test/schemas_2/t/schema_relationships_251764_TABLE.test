INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 251764_TABLE
--echo #
CREATE DATABASE `db_251764_TABLE`;
USE `db_251764_TABLE`;

CREATE TABLE `USER` (
  `ID` INT,
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `PHONE` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `TYPE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `STAFF` (
  `ID` INT,
  `ROLE` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Card` (
  `CardID` INT,
  `Card_Number` INT,
  `CVC` INT,
  `Expiry` DATETIME,
  PRIMARY KEY (`CardID`)
) CHARACTER SET latin1;

CREATE TABLE `RoomType` (
  `RoomTypeID` INT,
  `CostPerDay` DECIMAL(10,2),
  `NumBeds` INT,
  `Suite` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`RoomTypeID`)
) CHARACTER SET latin1;

CREATE TABLE `Room` (
  `RoomID` INT,
  `RoomTypeID` INT,
  PRIMARY KEY (`RoomID`)
) CHARACTER SET latin1;

CREATE TABLE `Booking` (
  `BookingID` INT,
  `UserID` INT,
  `RoomID` INT,
  `Starting_Date` DATETIME,
  `Ending_Date` DATETIME,
  `Status` VARCHAR(64),
  `Paid` BOOL,
  `Total_Cost` DECIMAL(10,2),
  PRIMARY KEY (`BookingID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_251764_TABLE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_251764_TABLE') AS relationships;
DROP DATABASE `db_251764_TABLE`;
UNINSTALL EXTENSION vsql_schematron;
