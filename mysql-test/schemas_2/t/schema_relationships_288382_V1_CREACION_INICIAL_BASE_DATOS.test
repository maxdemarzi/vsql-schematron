INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 288382_V1__CREACION_INICIAL_BASE_DATOS
--echo #
CREATE DATABASE `db_288382_V1_CREACION_INICIAL_BASE_DATOS`;
USE `db_288382_V1_CREACION_INICIAL_BASE_DATOS`;

CREATE TABLE `comuna` (
  `id_comuna` INT,
  `id_provincia` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id_comuna`)
) CHARACTER SET latin1;

CREATE TABLE `perfil_usuario` (
  `id_perfil_usuario` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id_perfil_usuario`)
) CHARACTER SET latin1;

CREATE TABLE `persona` (
  `id_persona` INT,
  `id_comuna` INT,
  `run` INT,
  `nombres` VARCHAR(64),
  `apellido_paterno` VARCHAR(64),
  `apellido_materno` VARCHAR(64),
  `fechanacimiento` DATETIME,
  `telefono` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id_persona`)
) CHARACTER SET latin1;

CREATE TABLE `provincia` (
  `id_provincia` INT,
  `id_region` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id_provincia`)
) CHARACTER SET latin1;

CREATE TABLE `region` (
  `id_region` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id_region`)
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id_persona` INT,
  `id_perfil_usuario` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `habilitado` BOOL,
  PRIMARY KEY (`id_persona`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_288382_V1_CREACION_INICIAL_BASE_DATOS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_288382_V1_CREACION_INICIAL_BASE_DATOS') AS relationships;
DROP DATABASE `db_288382_V1_CREACION_INICIAL_BASE_DATOS`;
UNINSTALL EXTENSION vsql_schematron;
