INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 267941_db_schema
--echo #
CREATE DATABASE `db_267941_db_schema`;
USE `db_267941_db_schema`;

CREATE TABLE `Point` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `photos` VARCHAR(255),
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  `address` VARCHAR(255),
  `address_components` VARCHAR(255),
  `trip_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Trip` (
  `id` VARCHAR(255),
  `tripname` VARCHAR(255),
  `is_completed` VARCHAR(255),
  `first_point_name` VARCHAR(255),
  `last_point_name` VARCHAR(255),
  `photo` VARCHAR(255),
  `user_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `uid` VARCHAR(255),
  `email` VARCHAR(255),
  `nickname` VARCHAR(255),
  `password` VARCHAR(255),
  `photo` VARCHAR(255),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `Subscription` (
  `from_user` VARCHAR(255),
  `to_user` VARCHAR(255),
  PRIMARY KEY (`from_user`, `to_user`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_267941_db_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_267941_db_schema') AS relationships;
DROP DATABASE `db_267941_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
