INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277873_migration
--echo #
CREATE DATABASE `db_277873_migration`;
USE `db_277873_migration`;
CREATE TABLE `Post` (
  `id` TEXT,
  `user` TEXT,
  `title` TEXT,
  `description` TEXT,
  `image` TEXT,
  `likes` INT,
  `createdAt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id` TEXT,
  `content` TEXT,
  `user` TEXT,
  `likes` INT,
  `createdAt` TIMESTAMP NULL,
  `postId` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277873_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277873_migration') AS relationships;
DROP DATABASE `db_277873_migration`;
UNINSTALL EXTENSION vsql_schematron;
