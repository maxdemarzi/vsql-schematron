INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 237966_DB
--echo #
CREATE DATABASE `db_237966_DB`;
USE `db_237966_DB`;

CREATE TABLE `articles` (
  `title` VARCHAR(255),
  `image` VARCHAR(255),
  `description` VARCHAR(255),
  `create_date` DATETIME,
  `article_id` INT,
  `user_id` INT,
  PRIMARY KEY (`article_id`)
) CHARACTER SET latin1;

CREATE TABLE `chats` (
  `name` VARCHAR(255),
  `short_description` VARCHAR(255),
  `chat_id` INT,
  PRIMARY KEY (`chat_id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `chat_id` INT,
  `user_id` INT,
  `m_text` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `login` VARCHAR(255),
  `password` VARCHAR(255),
  `salt` VARCHAR(255),
  `img` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `articles_to_users` (
  `article_id` INT,
  `user_id` INT,
  PRIMARY KEY (`user_id`, `article_id`)
) CHARACTER SET latin1;

CREATE TABLE `chats_to_users` (
  `chat_id` INT,
  `user_id` INT,
  PRIMARY KEY (`user_id`, `chat_id`)
) CHARACTER SET latin1;

CREATE TABLE `tags_to_articles` (
  `article_id` INT,
  `tag` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_237966_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_237966_DB') AS relationships;
DROP DATABASE `db_237966_DB`;
UNINSTALL EXTENSION vsql_schematron;
