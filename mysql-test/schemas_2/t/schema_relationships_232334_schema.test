INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232334_schema
--echo #
CREATE DATABASE `db_232334_schema`;
USE `db_232334_schema`;
CREATE TABLE `USERS` (
  `userid` INT NOT NULL,
  `username` VARCHAR(50),
  `salt` VARCHAR(50),
  `password` VARCHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `NOTES` (
  `noteid` INT NOT NULL,
  `notetitle` VARCHAR(50),
  `notedescription` VARCHAR(50),
  `userid` INT,
  PRIMARY KEY (`noteid`)
) CHARACTER SET latin1;
CREATE TABLE `FILES` (
  `fileid` INT NOT NULL,
  `filename` VARCHAR(50),
  `contenttype` VARCHAR(50),
  `filesize` VARCHAR(50),
  `filedata` BLOB,
  `userid` INT,
  PRIMARY KEY (`fileid`)
) CHARACTER SET latin1;
CREATE TABLE `CREDENTIALS` (
  `credentialid` INT NOT NULL,
  `url` VARCHAR(50),
  `username` VARCHAR(50),
  `key` VARCHAR(50),
  `password` VARCHAR(50),
  `userid` INT,
  PRIMARY KEY (`credentialid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232334_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232334_schema') AS relationships;
DROP DATABASE `db_232334_schema`;
UNINSTALL EXTENSION vsql_schematron;
