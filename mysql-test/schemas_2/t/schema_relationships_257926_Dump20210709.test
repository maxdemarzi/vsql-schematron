INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257926_Dump20210709
--echo #
CREATE DATABASE `db_257926_Dump20210709`;
USE `db_257926_Dump20210709`;

CREATE TABLE `agendamedicamento` (
  `idAgendamento` INT,
  `frequencia` INT,
  `dataInicio` DATETIME,
  `dataTermino` DATETIME,
  `intervalo` INT,
  `idPessoa` INT,
  `idAnimal` INT,
  `idMedicamento` INT,
  `idConsulta` INT,
  `dosagem` VARCHAR(64),
  PRIMARY KEY (`idAgendamento`)
) CHARACTER SET latin1;

CREATE TABLE `aplicamedicamento` (
  `idAplicaMedicamento` INT,
  `dosagem` VARCHAR(64),
  `dataAplicacao` DATETIME,
  `horario` DATETIME,
  `idPessoa` INT,
  `idAnimal` INT,
  `idMedicamento` INT,
  `observacoes` VARCHAR(64),
  PRIMARY KEY (`idAplicaMedicamento`)
) CHARACTER SET latin1;

CREATE TABLE `medicamento` (
  `idMedicamento` INT,
  `nome` VARCHAR(64),
  `isVacina` INT,
  `idEspecieAnimal` INT,
  PRIMARY KEY (`idMedicamento`)
) CHARACTER SET latin1;

CREATE TABLE `pessoaorganizacao` (
  `idPessoa` INT,
  `idOrganizacao` INT,
  PRIMARY KEY (`idPessoa`, `idOrganizacao`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257926_Dump20210709') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257926_Dump20210709') AS relationships;
DROP DATABASE `db_257926_Dump20210709`;
UNINSTALL EXTENSION vsql_schematron;
