INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279274_create_tables
--echo #
CREATE DATABASE `db_279274_create_tables`;
USE `db_279274_create_tables`;

CREATE TABLE `product` (
  `product_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

CREATE TABLE `country` (
  `country_id` INT,
  `country_name` VARCHAR(64),
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;

CREATE TABLE `city` (
  `city_id` INT,
  `city_name` VARCHAR(64),
  `country_id` INT,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;

CREATE TABLE `store` (
  `store_id` INT,
  `name` VARCHAR(64),
  `city_id` INT,
  PRIMARY KEY (`store_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `status_name` (
  `status_name_id` INT,
  `status_name` VARCHAR(64),
  PRIMARY KEY (`status_name_id`)
) CHARACTER SET latin1;

CREATE TABLE `sale` (
  `sale_id` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `date_sale` DATETIME,
  `product_id` INT,
  `user_id` INT,
  `store_id` INT,
  PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_status` (
  `order_status_id` VARCHAR(64),
  `update_at` DATETIME,
  `sale_id` VARCHAR(64),
  `status_name_id` INT,
  PRIMARY KEY (`order_status_id`)
) CHARACTER SET latin1;

CREATE TABLE `Dim_Centres` (
  `Region` VARCHAR(64),
  `Centre_Id` VARCHAR(64),
  `Centre_Name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Map_Centre_Cust` (
  `Centre_Id` VARCHAR(64),
  `Cust_Id` INT
) CHARACTER SET latin1;

CREATE TABLE `Fact_Centre_Txn` (
  `Centre_Id` VARCHAR(64),
  `Cust_Id` INT,
  `Visit_Date` DATETIME,
  `Transaction_Id` VARCHAR(64),
  `Closing_Balance` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279274_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279274_create_tables') AS relationships;
DROP DATABASE `db_279274_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
