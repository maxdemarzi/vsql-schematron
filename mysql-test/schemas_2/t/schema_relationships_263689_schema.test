INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 263689_schema
--echo #
CREATE DATABASE `db_263689_schema`;
USE `db_263689_schema`;
CREATE TABLE `TB_MEMBER` (
  `MEMBER_ID` INT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `DOJ` TIMESTAMP NULL,
  `CREATED_BY` VARCHAR(50),
  `CREATED_DT` TIMESTAMP NULL,
  `MODIFIED_BY` VARCHAR(50),
  `MODIFIED_DT` TIMESTAMP NULL,
  PRIMARY KEY (`MEMBER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TB_FILE` (
  `FILE_ID` INT NOT NULL,
  `FILE` BLOB,
  `FILE_TYPE` VARCHAR(50),
  `FILE_NAME` VARCHAR(50),
  `CREATED_BY` VARCHAR(50),
  `CREATED_DT` TIMESTAMP NULL,
  `MODIFIED_BY` VARCHAR(50),
  `MODIFIED_DT` TIMESTAMP NULL,
  `MEMBER_ID` INT,
  PRIMARY KEY (`FILE_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_263689_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_263689_schema') AS relationships;
DROP DATABASE `db_263689_schema`;
UNINSTALL EXTENSION vsql_schematron;
