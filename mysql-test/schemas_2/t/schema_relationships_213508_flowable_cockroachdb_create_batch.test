INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213508_flowable_cockroachdb_create_batch
--echo #
CREATE DATABASE `db_213508_flowable_cockroachdb_create_batch`;
USE `db_213508_flowable_cockroachdb_create_batch`;

CREATE TABLE `FLW_RU_BATCH` (
  `ID_` VARCHAR(64),
  `REV_` INT,
  `TYPE_` VARCHAR(64),
  `SEARCH_KEY_` VARCHAR(64),
  `SEARCH_KEY2_` VARCHAR(64),
  `CREATE_TIME_` DATETIME,
  `COMPLETE_TIME_` DATETIME,
  `STATUS_` VARCHAR(64),
  `BATCH_DOC_ID_` VARCHAR(64),
  `TENANT_ID_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

CREATE TABLE `FLW_RU_BATCH_PART` (
  `ID_` VARCHAR(64),
  `REV_` INT,
  `BATCH_ID_` VARCHAR(64),
  `TYPE_` VARCHAR(64),
  `SCOPE_ID_` VARCHAR(64),
  `SUB_SCOPE_ID_` VARCHAR(64),
  `SCOPE_TYPE_` VARCHAR(64),
  `SEARCH_KEY_` VARCHAR(64),
  `SEARCH_KEY2_` VARCHAR(64),
  `CREATE_TIME_` DATETIME,
  `COMPLETE_TIME_` DATETIME,
  `STATUS_` VARCHAR(64),
  `RESULT_DOC_ID_` VARCHAR(64),
  `TENANT_ID_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213508_flowable_cockroachdb_create_batch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213508_flowable_cockroachdb_create_batch') AS relationships;
DROP DATABASE `db_213508_flowable_cockroachdb_create_batch`;
UNINSTALL EXTENSION vsql_schematron;
