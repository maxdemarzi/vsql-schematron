INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202653_dbweb
--echo #
CREATE DATABASE `db_202653_dbweb`;
USE `db_202653_dbweb`;

CREATE TABLE `alembic_version` (
  `version_num` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `stocks` (
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `user_stock` (
  `user_id` INT,
  `stock_id` VARCHAR(64),
  `average_price` DECIMAL(10,2),
  `own_num` INT,
  PRIMARY KEY (`user_id`, `stock_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202653_dbweb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202653_dbweb') AS relationships;
DROP DATABASE `db_202653_dbweb`;
UNINSTALL EXTENSION vsql_schematron;
