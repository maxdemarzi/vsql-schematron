INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231793_V0001__initial
--echo #
CREATE DATABASE `db_231793_V0001__initial`;
USE `db_231793_V0001__initial`;
CREATE TABLE `app_user` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `recovery_token` BLOB,
  `registration_start` TIMESTAMP NULL,
  `registration_add_start` TIMESTAMP NULL,
  `registration_add_token` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `credentials` (
  `id` VARCHAR(50) NOT NULL,
  `app_user_id` BIGINT NOT NULL,
  `count` BIGINT,
  `public_key_cose` BLOB,
  PRIMARY KEY (`id`, `app_user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231793_V0001__initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231793_V0001__initial') AS relationships;
DROP DATABASE `db_231793_V0001__initial`;
UNINSTALL EXTENSION vsql_schematron;
