INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 296911_dabase_schema
--echo #
CREATE DATABASE `db_296911_dabase_schema`;
USE `db_296911_dabase_schema`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `enabled` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `api_client` (
  `id` INT,
  `api_key` VARCHAR(64),
  `secret_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `api_role` (
  `api_client_id` INT,
  `role_id` INT,
  PRIMARY KEY (`api_client_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `permission` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_permission` (
  `role_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`role_id`, `permission_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_296911_dabase_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_296911_dabase_schema') AS relationships;
DROP DATABASE `db_296911_dabase_schema`;
UNINSTALL EXTENSION vsql_schematron;
