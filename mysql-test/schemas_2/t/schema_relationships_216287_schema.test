INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 216287_schema
--echo #
CREATE DATABASE `db_216287_schema`;
USE `db_216287_schema`;

CREATE TABLE `admin` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `production` (
  `id` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `synopsis` VARCHAR(64),
  `status` VARCHAR(64),
  `release_date` DATETIME,
  `format` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `duration` INT,
  `episodes` INT,
  `demography` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlist` (
  `id` INT,
  `name` VARCHAR(64),
  `usuario_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlist_content` (
  `id` INT,
  `playlist_id` INT,
  `production_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `tag` VARCHAR(64),
  `production_id` INT,
  PRIMARY KEY (`id`, `production_id`)
) CHARACTER SET latin1;

CREATE TABLE `casting` (
  `id` INT,
  `cast` VARCHAR(64),
  `production_id` INT,
  PRIMARY KEY (`id`, `production_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_216287_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_216287_schema') AS relationships;
DROP DATABASE `db_216287_schema`;
UNINSTALL EXTENSION vsql_schematron;
