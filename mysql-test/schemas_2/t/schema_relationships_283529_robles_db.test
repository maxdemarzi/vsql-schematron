INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283529_robles_db
--echo #
CREATE DATABASE `db_283529_robles_db`;
USE `db_283529_robles_db`;
CREATE TABLE `categoria` (
  `id_categoria` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `cliente` (
  `id_cliente` INT NOT NULL,
  `correo` VARCHAR(50),
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `producto` (
  `id_producto` INT,
  `nombre` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `id_categoria` INT,
  `precio` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `servicio` (
  `id_servicio` INT NOT NULL,
  `nombre` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `precio` DOUBLE,
  PRIMARY KEY (`id_servicio`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283529_robles_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283529_robles_db') AS relationships;
DROP DATABASE `db_283529_robles_db`;
UNINSTALL EXTENSION vsql_schematron;
