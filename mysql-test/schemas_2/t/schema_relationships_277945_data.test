INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277945_data
--echo #
CREATE DATABASE `db_277945_data`;
USE `db_277945_data`;
CREATE TABLE `Usuario` (
  `id_Usuario` INT NOT NULL,
  `usuario` VARCHAR(50),
  `nombre` VARCHAR(50),
  `contrasena` VARCHAR(50),
  PRIMARY KEY (`id_Usuario`)
) CHARACTER SET latin1;
CREATE TABLE `Cliente` (
  `id_Cliente` INT NOT NULL,
  `nombre` VARCHAR(50),
  `identificacion` CHAR(50),
  `direccion` VARCHAR(50),
  `telefono` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id_Cliente`)
) CHARACTER SET latin1;
CREATE TABLE `Cotizacion` (
  `id_Cotizacion` INT NOT NULL,
  `id_Cliente` INT,
  `fecha` DATE,
  `observaciones` VARCHAR(50),
  `total` INT,
  PRIMARY KEY (`id_Cotizacion`)
) CHARACTER SET latin1;
CREATE TABLE `Producto` (
  `id_Producto` INT NOT NULL,
  `referencia` INT,
  `descripcion` VARCHAR(50),
  `precio_unidad` INT,
  PRIMARY KEY (`id_Producto`)
) CHARACTER SET latin1;
CREATE TABLE `Cuenta_de_cobro` (
  `id_Cuenta_de_cobro` INT NOT NULL,
  `id_Cotizacion` INT,
  `fecha` DATE,
  PRIMARY KEY (`id_Cuenta_de_cobro`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277945_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277945_data') AS relationships;
DROP DATABASE `db_277945_data`;
UNINSTALL EXTENSION vsql_schematron;
