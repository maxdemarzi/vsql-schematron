INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220445_V10__liga__create
--echo #
CREATE DATABASE `db_220445_V10_liga_create`;
USE `db_220445_V10_liga_create`;

CREATE TABLE `liga` (
  `liga_id` DECIMAL(10,2),
  `liga_region_id` DECIMAL(10,2),
  `liga_name` VARCHAR(64),
  `liga_uebergeordnet` DECIMAL(10,2),
  `liga_verantwortlich` DECIMAL(10,2),
  `created_at_utc` DATETIME,
  `created_by` DECIMAL(10,2),
  `last_modified_at_utc` DATETIME,
  `last_modified_by` DECIMAL(10,2),
  `version` DECIMAL(10,2),
  PRIMARY KEY (`liga_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220445_V10_liga_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220445_V10_liga_create') AS relationships;
DROP DATABASE `db_220445_V10_liga_create`;
UNINSTALL EXTENSION vsql_schematron;
