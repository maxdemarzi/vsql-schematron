INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233561_script
--echo #
CREATE DATABASE `db_233561_script`;
USE `db_233561_script`;
CREATE TABLE `Courses` (
  `CourseID` INT NOT NULL,
  `Title` VARCHAR(50),
  `Credits` INT,
  `DepartmentID` INT,
  PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;
CREATE TABLE `CourseInstructor` (
  `CoursesCourseID` INT NOT NULL,
  `InstructorsID` INT NOT NULL,
  PRIMARY KEY (`CoursesCourseID`, `InstructorsID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233561_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233561_script') AS relationships;
DROP DATABASE `db_233561_script`;
UNINSTALL EXTENSION vsql_schematron;
