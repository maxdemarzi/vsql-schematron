INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215313_initial
--echo #
CREATE DATABASE `db_215313_initial`;
USE `db_215313_initial`;

CREATE TABLE `characters` (
  `charaId` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `lifeStage` VARCHAR(64),
  `region` VARCHAR(64),
  `specialty` VARCHAR(64),
  `available` INT,
  PRIMARY KEY (`charaId`)
) CHARACTER SET latin1;

CREATE TABLE `enchants` (
  `enchantId` INT,
  `enchantName` VARCHAR(64),
  `auraColor` VARCHAR(64),
  `strength` INT,
  `effect` VARCHAR(64),
  PRIMARY KEY (`enchantId`)
) CHARACTER SET latin1;

CREATE TABLE `charEquip` (
  `charaID` INT,
  `equipID` INT,
  PRIMARY KEY (`charaID`, `equipID`)
) CHARACTER SET latin1;

CREATE TABLE `charTools` (
  `charaID` INT,
  `toolID` INT,
  PRIMARY KEY (`charaID`, `toolID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215313_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215313_initial') AS relationships;
DROP DATABASE `db_215313_initial`;
UNINSTALL EXTENSION vsql_schematron;
