INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297711_Creation
--echo #
CREATE DATABASE `db_297711_Creation`;
USE `db_297711_Creation`;

CREATE TABLE `Adherent` (
  `numA` DECIMAL(10,2),
  `nom` VARCHAR(64),
  `prenom` VARCHAR(64),
  `adresse` VARCHAR(64),
  PRIMARY KEY (`numA`)
) CHARACTER SET latin1;

CREATE TABLE `Emprunt` (
  `numA` DECIMAL(10,2),
  `dateE` DATETIME,
  `dateR` DATETIME,
  PRIMARY KEY (`numA`, `dateE`)
) CHARACTER SET latin1;

CREATE TABLE `Livre` (
  `ISBN` DECIMAL(10,2),
  `titre` VARCHAR(64),
  `editeur` VARCHAR(64),
  `anneeParution` DECIMAL(10,2),
  `auteurs` VARCHAR(64),
  `nbE` DECIMAL(10,2),
  `dateDE` DATETIME,
  PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;

CREATE TABLE `Exemplaire` (
  `numInv` DECIMAL(10,2),
  `ISBN` DECIMAL(10,2),
  PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;

CREATE TABLE `ExemplaireEmprunte` (
  `numInv` DECIMAL(10,2),
  `numA` DECIMAL(10,2),
  `dateE` DATETIME,
  PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297711_Creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297711_Creation') AS relationships;
DROP DATABASE `db_297711_Creation`;
UNINSTALL EXTENSION vsql_schematron;
