INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 250827_DB2_20Schema
--echo #
CREATE DATABASE `db_250827_DB2_20Schema`;
USE `db_250827_DB2_20Schema`;

CREATE TABLE `TB_DETAIL` (
  `ID` VARCHAR(64),
  `TB_MASTER_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `CODE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MANY1` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `CODE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MANY2` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `CODE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MANY_REL` (
  `TB_MANY1_ID` VARCHAR(64),
  `TB_MANY2_ID` VARCHAR(64),
  PRIMARY KEY (`TB_MANY1_ID`, `TB_MANY2_ID`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MASTER` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `CODE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_250827_DB2_20Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_250827_DB2_20Schema') AS relationships;
DROP DATABASE `db_250827_DB2_20Schema`;
UNINSTALL EXTENSION vsql_schematron;
