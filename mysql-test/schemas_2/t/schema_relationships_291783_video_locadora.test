INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 291783_video_locadora
--echo #
CREATE DATABASE `db_291783_video_locadora`;
USE `db_291783_video_locadora`;

CREATE TABLE `ceps` (
  `id` INT,
  `cep` VARCHAR(64),
  `tipo` VARCHAR(64),
  `logradouro` VARCHAR(64),
  `bairro` VARCHAR(64),
  `municipio` VARCHAR(64),
  `uf` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `empresas` (
  `id` INT,
  `cnpj` VARCHAR(64),
  `razao_social` VARCHAR(64),
  `cep_id` INT,
  `site` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `funcionarios` (
  `id` INT,
  `cpf` VARCHAR(64),
  `nome` VARCHAR(64),
  `rg` VARCHAR(64),
  `data_admissao` DATETIME,
  `cep_id` INT,
  `telefone` VARCHAR(64),
  `celular` VARCHAR(64),
  `foto` VARCHAR(64),
  `administrador` VARCHAR(64),
  `empresa_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clientes` (
  `id` INT,
  `cpf` VARCHAR(64),
  `nome` VARCHAR(64),
  `rg` VARCHAR(64),
  `foto` VARCHAR(64),
  `data_cadastro` DATETIME,
  `taxa_inscricao` DECIMAL(10,2),
  `cep_id` INT,
  `telefone` VARCHAR(64),
  `email` VARCHAR(64),
  `referencias` VARCHAR(64),
  `receber_novidades_email` VARCHAR(64),
  `liberado` VARCHAR(64),
  `funcionario_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dependentes` (
  `id` INT,
  `nome` VARCHAR(64),
  `cliente_id` INT,
  `foto` VARCHAR(64),
  `data_cadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fornecedores` (
  `id` INT,
  `razao_social` VARCHAR(64),
  `cpf` VARCHAR(64),
  `cnpj` VARCHAR(64),
  `inscricao_estadual` VARCHAR(64),
  `cep_id` INT,
  `telefone` VARCHAR(64),
  `site` VARCHAR(64),
  `contato` VARCHAR(64),
  `contato_fone` VARCHAR(64),
  `fax` VARCHAR(64),
  `observacao` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `generos` (
  `id` INT,
  `descricao` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `distribuidoras` (
  `id` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `filmes` (
  `id` INT,
  `diretor` VARCHAR(64),
  `duracao` VARCHAR(64),
  `sinopse` VARCHAR(64),
  `foto_cena` VARCHAR(64),
  `ano` VARCHAR(64),
  `ator_principal` VARCHAR(64),
  `ator_coadjuvante` VARCHAR(64),
  `genero_id` INT,
  `distribuidora_id` INT,
  `titulo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `compras` (
  `id` INT,
  `data` DATETIME,
  `fornecedor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `compra_itens` (
  `id` INT,
  `compra_id` INT,
  `filme_id` INT,
  `quantidade` INT,
  `preco_unitario` DECIMAL(10,2),
  `estoque_min` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fitas` (
  `id` INT,
  `fornecedor_id` INT,
  `tipo` VARCHAR(64),
  `filme_id` INT,
  `cotacao` VARCHAR(64),
  `custo_aquisicao` DECIMAL(10,2),
  `data_aquisicao` DATETIME,
  `quantidade_copias` INT,
  `dub_leg` VARCHAR(64),
  `lancamento` VARCHAR(64),
  `observacao` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `locacoes` (
  `id` INT,
  `fita_id` INT,
  `cliente_id` INT,
  `data_locacao` DATETIME,
  `data_devolucao` DATETIME,
  `cheque` VARCHAR(64),
  `forma_pagamento` INT,
  `multa_atrazo` DECIMAL(10,2),
  `valor_total` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_291783_video_locadora') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_291783_video_locadora') AS relationships;
DROP DATABASE `db_291783_video_locadora`;
UNINSTALL EXTENSION vsql_schematron;
