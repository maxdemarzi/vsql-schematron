INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276237_e_fkey.test_18
--echo #
CREATE DATABASE `db_276237_e_fkey_test_18`;
USE `db_276237_e_fkey_test_18`;
CREATE TABLE `artist` (
  `artistid` INT NOT NULL,
  `artistname` TEXT,
  PRIMARY KEY (`artistid`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
  `trackid` INT,
  `trackname` TEXT,
  `trackartist` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276237_e_fkey_test_18') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276237_e_fkey_test_18') AS relationships;
DROP DATABASE `db_276237_e_fkey_test_18`;
UNINSTALL EXTENSION vsql_schematron;
