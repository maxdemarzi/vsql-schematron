  `NUM_OF_THREAD` INT,
  `INTERVAL_TIME` INT,
  `BOOST` DECIMAL(10,2),
  `AVAILABLE` VARCHAR(64),
  `SORT_ORDER` INT,
  `CREATED_BY` VARCHAR(64),
  `CREATED_TIME` DATETIME,
  `UPDATED_BY` VARCHAR(64),
  `UPDATED_TIME` DATETIME,
  `DELETED_BY` VARCHAR(64),
  `DELETED_TIME` DATETIME,
  `VERSION_NO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

