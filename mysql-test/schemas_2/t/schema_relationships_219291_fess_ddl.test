CREATE TABLE `WEB_CRAWLING_CONFIG` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `URLS` VARCHAR(64),
  `INCLUDED_URLS` VARCHAR(64),
  `EXCLUDED_URLS` VARCHAR(64),
  `INCLUDED_DOC_URLS` VARCHAR(64),
