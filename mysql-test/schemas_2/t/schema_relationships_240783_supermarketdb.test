INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 240783_supermarketdb
--echo #
CREATE DATABASE `db_240783_supermarketdb`;
USE `db_240783_supermarketdb`;

CREATE TABLE `branch_details` (
  `Branch` VARCHAR(64),
  `BranchCity` VARCHAR(64),
  PRIMARY KEY (`Branch`)
) CHARACTER SET latin1;

CREATE TABLE `income_details` (
  `InvoiceID` VARCHAR(64),
  `COGS` DECIMAL(10,2),
  `GrossMarginPercentage` DECIMAL(10,2),
  `GrossIncome` DECIMAL(10,2),
  PRIMARY KEY (`InvoiceID`)
) CHARACTER SET latin1;

CREATE TABLE `invoice_details` (
  `InvoiceID` VARCHAR(64),
  `ProductLine` VARCHAR(64),
  `Date` DATETIME,
  `Time` DATETIME,
  `PaymentMode` VARCHAR(64),
  `UnitPrice` DECIMAL(10,2),
  `Quantity` INT,
  `Tax5%` DECIMAL(10,2),
  `TotalAmount` DECIMAL(10,2),
  `Rating` DECIMAL(10,2),
  `CustomerID` INT,
  `Branch` VARCHAR(64),
  PRIMARY KEY (`InvoiceID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_240783_supermarketdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_240783_supermarketdb') AS relationships;
DROP DATABASE `db_240783_supermarketdb`;
UNINSTALL EXTENSION vsql_schematron;
