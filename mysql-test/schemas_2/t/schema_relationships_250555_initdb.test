INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 250555_initdb
--echo #
CREATE DATABASE `db_250555_initdb`;
USE `db_250555_initdb`;
CREATE TABLE `iot.users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `refresh_token` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `iot.microcontrollers` (
  `username` VARCHAR(50),
  `ip` VARCHAR(50) NOT NULL,
  `measure` VARCHAR(50) NOT NULL,
  `sensor` VARCHAR(50),
  PRIMARY KEY (`ip`, `measure`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_250555_initdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_250555_initdb') AS relationships;
DROP DATABASE `db_250555_initdb`;
UNINSTALL EXTENSION vsql_schematron;
