INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 232386_V1.0.0__Initial
--echo #
CREATE DATABASE `db_232386_V1_0_0__Initial`;
USE `db_232386_V1_0_0__Initial`;
CREATE TABLE `Users` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `active` BOOLEAN,
  `birthDate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Adventurers` (
  `id` BIGINT NOT NULL,
  `userId` BIGINT,
  `avatar` VARCHAR(50),
  `name` VARCHAR(50),
  `title` VARCHAR(50),
  `level` SMALLINT,
  `currentExperience` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_232386_V1_0_0__Initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_232386_V1_0_0__Initial') AS relationships;
DROP DATABASE `db_232386_V1_0_0__Initial`;
UNINSTALL EXTENSION vsql_schematron;
