INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 298207_V1__initial_version
--echo #
CREATE DATABASE `db_298207_V1_initial_version`;
USE `db_298207_V1_initial_version`;

CREATE TABLE `annotation` (
  `id` INT,
  `code` VARCHAR(64),
  `type` VARCHAR(64),
  `text` VARCHAR(64),
  `description` VARCHAR(64),
  `de_description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `annotation_layer` (
  `id` INT,
  `foundry_id` INT,
  `layer_id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `annotation_key` (
  `id` INT,
  `layer_id` INT,
  `key_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `annotation_value` (
  `id` INT,
  `key_id` INT,
  `value_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `resource` (
  `id` VARCHAR(64),
  `de_title` VARCHAR(64),
  `en_title` VARCHAR(64),
  `en_description` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `resource_layer` (
  `id` INT,
  `resource_id` VARCHAR(64),
  `layer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_298207_V1_initial_version') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_298207_V1_initial_version') AS relationships;
DROP DATABASE `db_298207_V1_initial_version`;
UNINSTALL EXTENSION vsql_schematron;
