INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277620_schema
--echo #
CREATE DATABASE `db_277620_schema`;
USE `db_277620_schema`;
CREATE TABLE `cafeteria_order` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_item` (
  `id` INT NOT NULL,
  `menu_item_id` INT,
  `id_order` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277620_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277620_schema') AS relationships;
DROP DATABASE `db_277620_schema`;
UNINSTALL EXTENSION vsql_schematron;
