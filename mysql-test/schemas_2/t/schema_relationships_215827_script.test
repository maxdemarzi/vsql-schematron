INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 215827_script
--echo #
CREATE DATABASE `db_215827_script`;
USE `db_215827_script`;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
  `user_role_id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_215827_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_215827_script') AS relationships;
DROP DATABASE `db_215827_script`;
UNINSTALL EXTENSION vsql_schematron;
