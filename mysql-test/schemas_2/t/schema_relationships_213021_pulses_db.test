INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 213021_pulses_db
--echo #
CREATE DATABASE `db_213021_pulses_db`;
USE `db_213021_pulses_db`;
CREATE TABLE `dimensao` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `perguntas` (
  `id` INT,
  `id_dimensao` INT,
  `texto` TEXT,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_213021_pulses_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_213021_pulses_db') AS relationships;
DROP DATABASE `db_213021_pulses_db`;
UNINSTALL EXTENSION vsql_schematron;
