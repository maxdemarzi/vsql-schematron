INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 262537_schema
--echo #
CREATE DATABASE `db_262537_schema`;
USE `db_262537_schema`;

CREATE TABLE `Movies` (
  `title` VARCHAR(64),
  `releaseYear` INT,
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;

CREATE TABLE `Cinemas` (
  `name` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Spectators` (
  `name` VARCHAR(64),
  `birthYear` INT,
  `city` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Opinions` (
  `spectator` VARCHAR(64),
  `movie` VARCHAR(64),
  `stars` INT,
  PRIMARY KEY (`spectator`, `movie`)
) CHARACTER SET latin1;

CREATE TABLE `Frequents` (
  `spectator` VARCHAR(64),
  `cinema` VARCHAR(64),
  PRIMARY KEY (`spectator`, `cinema`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_262537_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_262537_schema') AS relationships;
DROP DATABASE `db_262537_schema`;
UNINSTALL EXTENSION vsql_schematron;
