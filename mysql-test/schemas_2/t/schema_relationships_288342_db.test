INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 288342_db
--echo #
CREATE DATABASE `db_288342_db`;
USE `db_288342_db`;

CREATE TABLE `client` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `good_type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hall` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `good` (
  `id` INT,
  `type_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `weight` INT,
  `price` INT,
  `photo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_` (
  `id` INT,
  `client_id` INT,
  `hall_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `good_hall` (
  `id` INT,
  `good_id` INT,
  `hall_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_element` (
  `id` INT,
  `order_id` INT,
  `good_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sale` (
  `id` INT,
  `good_id` INT,
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_288342_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_288342_db') AS relationships;
DROP DATABASE `db_288342_db`;
UNINSTALL EXTENSION vsql_schematron;
