INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295130_V1__CreateDB
--echo #
CREATE DATABASE `db_295130_V1_CreateDB`;
USE `db_295130_V1_CreateDB`;

CREATE TABLE `client` (
  `id` INT,
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_roles` (
  `client_id` INT,
  `roles` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `repeatable_task` (
  `id` INT,
  `description` VARCHAR(64),
  `end_date` DATETIME,
  `name` VARCHAR(64),
  `period_mode` INT,
  `priority` INT,
  `start_date` DATETIME,
  `client_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `task` (
  `id` INT,
  `date` DATETIME,
  `description` VARCHAR(64),
  `name` VARCHAR(64),
  `priority` INT,
  `progress` INT,
  `client_id` INT,
  `repeatable_task_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295130_V1_CreateDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295130_V1_CreateDB') AS relationships;
DROP DATABASE `db_295130_V1_CreateDB`;
UNINSTALL EXTENSION vsql_schematron;
