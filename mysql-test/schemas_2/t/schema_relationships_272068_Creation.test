INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 272068_Creation
--echo #
CREATE DATABASE `db_272068_Creation`;
USE `db_272068_Creation`;

CREATE TABLE `Users` (
  `User_id` DECIMAL(10,2),
  `Name` VARCHAR(64),
  `CNIC` DECIMAL(10,2),
  `Gender` VARCHAR(64),
  `Height` DECIMAL(10,2),
  `Weight` DECIMAL(10,2),
  `BMI` DECIMAL(10,2),
  `Goal_weight` DECIMAL(10,2),
  `nutritional_intake` VARCHAR(64),
  `Plan_id` DECIMAL(10,2),
  `Progress_id` DECIMAL(10,2),
  PRIMARY KEY (`User_id`)
) CHARACTER SET latin1;

CREATE TABLE `Plan` (
  `Plan_id` DECIMAL(10,2),
  `Plan_type` VARCHAR(64),
  PRIMARY KEY (`Plan_id`)
) CHARACTER SET latin1;

CREATE TABLE `Exercise` (
  `Name` VARCHAR(64),
  `Muscle` VARCHAR(64),
  `Equipment` VARCHAR(64),
  `Optimal_sets` DECIMAL(10,2),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `Contain` (
  `Plan_id` DECIMAL(10,2),
  `Name` VARCHAR(64),
  `Day` VARCHAR(64),
  PRIMARY KEY (`Plan_id`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `Progress` (
  `Progress_id` DECIMAL(10,2),
  `Targets_fulfilled` DECIMAL(10,2),
  `Weight_change` DECIMAL(10,2),
  `BMI_change` DECIMAL(10,2),
  PRIMARY KEY (`Progress_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_272068_Creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_272068_Creation') AS relationships;
DROP DATABASE `db_272068_Creation`;
UNINSTALL EXTENSION vsql_schematron;
