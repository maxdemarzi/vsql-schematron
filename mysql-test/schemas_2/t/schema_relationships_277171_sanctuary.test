INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 277171_sanctuary
--echo #
CREATE DATABASE `db_277171_sanctuary`;
USE `db_277171_sanctuary`;

CREATE TABLE `animals` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `date_of_birth` DATETIME,
  `description` VARCHAR(64),
  `type` VARCHAR(64),
  `image` VARCHAR(64),
  `available` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `requests` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `animal_id` INT,
  `user_id` INT,
  `adoption_status` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `forename` VARCHAR(64),
  `surname` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `role` INT,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_277171_sanctuary') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_277171_sanctuary') AS relationships;
DROP DATABASE `db_277171_sanctuary`;
UNINSTALL EXTENSION vsql_schematron;
