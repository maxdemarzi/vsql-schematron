INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 263685_migration
--echo #
CREATE DATABASE `db_263685_migration`;
USE `db_263685_migration`;

CREATE TABLE `User` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `roleId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Permission` (
  `id` INT,
  `resource` VARCHAR(64),
  `action` VARCHAR(64),
  `attributes` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_PermissionToRole` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_263685_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_263685_migration') AS relationships;
DROP DATABASE `db_263685_migration`;
UNINSTALL EXTENSION vsql_schematron;
