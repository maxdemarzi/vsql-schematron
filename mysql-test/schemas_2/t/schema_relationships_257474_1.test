INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257474_1
--echo #
CREATE DATABASE `db_257474_1`;
USE `db_257474_1`;
CREATE TABLE `location` (
  `address` VARCHAR(50) NOT NULL,
  `label` VARCHAR(50),
  PRIMARY KEY (`address`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `locationAddress` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measuredPhenomenon` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `unit` VARCHAR(50),
  `aggregationStrategy` VARCHAR(50),
  `sensorId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257474_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257474_1') AS relationships;
DROP DATABASE `db_257474_1`;
UNINSTALL EXTENSION vsql_schematron;
