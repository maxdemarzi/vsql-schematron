INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273664_tables
--echo #
CREATE DATABASE `db_273664_tables`;
USE `db_273664_tables`;

CREATE TABLE `admin` (
  `name` VARCHAR(64),
  `id` INT,
  `password_hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `name_zh` VARCHAR(64),
  `name_en` VARCHAR(64),
  `brief` VARCHAR(64),
  `syllabus` VARCHAR(64),
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teach` (
  `tid` INT,
  `cid` INT
) CHARACTER SET latin1;

CREATE TABLE `take` (
  `cid` INT,
  `sid` INT
) CHARACTER SET latin1;

CREATE TABLE `info` (
  `id` INT,
  `content` VARCHAR(64),
  `cid` INT,
  `release_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `submission` (
  `id` INT,
  `sid` INT,
  `hid` INT,
  `submission_text` VARCHAR(64),
  `creation_time` DATETIME,
  `latest_modification_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `attachment` (
  `id` INT,
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  `brief` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `attach_to` (
  `aid` INT,
  `uid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273664_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273664_tables') AS relationships;
DROP DATABASE `db_273664_tables`;
UNINSTALL EXTENSION vsql_schematron;
