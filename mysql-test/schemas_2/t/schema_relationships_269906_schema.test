INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269906_schema
--echo #
CREATE DATABASE `db_269906_schema`;
USE `db_269906_schema`;

CREATE TABLE `user_detail` (
  `uid` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `phone` INT,
  `email` VARCHAR(64),
  `usertype` VARCHAR(64),
  `password` VARCHAR(64),
  `status` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `user_session` (
  `uid` INT,
  `ID` INT,
  `token` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `verification` (
  `uid` INT,
  `otp` VARCHAR(64),
  `encodedMail` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `savepolicy` (
  `uid` INT,
  `ID` INT,
  `consignmentWeight` INT,
  `consignmentValue` INT,
  `invoiceNo` INT,
  `modeofTransport` VARCHAR(64),
  `packingMode` VARCHAR(64),
  `contractType` VARCHAR(64),
  `policyType` VARCHAR(64),
  `consignmentType` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `issuedpolicy` (
  `uid` INT,
  `ID` INT,
  `consignmentWeight` INT,
  `consignmentValue` INT,
  `policyName` VARCHAR(64),
  `sumInsured` INT,
  `premiumAmount` INT,
  `modeofTransport` VARCHAR(64),
  `packingMode` VARCHAR(64),
  `consignmentType` VARCHAR(64),
  `contractType` VARCHAR(64),
  `policyType` VARCHAR(64),
  `email` VARCHAR(64),
  `policyHolderName` VARCHAR(64),
  `userType` VARCHAR(64),
  `invoiceNo` INT,
  `policyNumber` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269906_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269906_schema') AS relationships;
DROP DATABASE `db_269906_schema`;
UNINSTALL EXTENSION vsql_schematron;
