INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279670_jobsearchplusDB
--echo #
CREATE DATABASE `db_279670_jobsearchplusDB`;
USE `db_279670_jobsearchplusDB`;

CREATE TABLE `specialties` (
  `id` INT,
  `name` VARCHAR(255),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `jobs_status` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` VARCHAR(255),
  `authority` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` VARCHAR(255),
  `role_id` VARCHAR(255),
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `jobs` (
  `record_id` INT,
  `title` VARCHAR(255),
  `region` VARCHAR(255),
  `salary` VARCHAR(255),
  `job_category` VARCHAR(255),
  `company_name` VARCHAR(255),
  `description` VARCHAR(255),
  `updated_date` DATETIME,
  `expire_date` DATETIME,
  PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;

CREATE TABLE `jobs_history` (
  `id` VARCHAR(255),
  `faculty_number` VARCHAR(255),
  `job_record_id` INT,
  `old_status_id` INT,
  `new_status_id` INT,
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279670_jobsearchplusDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279670_jobsearchplusDB') AS relationships;
DROP DATABASE `db_279670_jobsearchplusDB`;
UNINSTALL EXTENSION vsql_schematron;
