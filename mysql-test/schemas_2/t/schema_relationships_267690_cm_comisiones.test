INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 267690_cm_comisiones
--echo #
CREATE DATABASE `db_267690_cm_comisiones`;
USE `db_267690_cm_comisiones`;

CREATE TABLE `cm_vendedores` (
  `ven_idvendedor` INT,
  `ven_nombre` VARCHAR(64),
  `ven_ape_pat` VARCHAR(64),
  `ven_ape_mat` VARCHAR(64),
  `ven_porcentaje` DECIMAL(10,2),
  `ven_activo` INT,
  PRIMARY KEY (`ven_idvendedor`)
) CHARACTER SET latin1;

CREATE TABLE `cm_vendedores_clientes` (
  `ven_cl_idcliente` INT,
  `ven_cl_idvendedor` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_267690_cm_comisiones') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_267690_cm_comisiones') AS relationships;
DROP DATABASE `db_267690_cm_comisiones`;
UNINSTALL EXTENSION vsql_schematron;
