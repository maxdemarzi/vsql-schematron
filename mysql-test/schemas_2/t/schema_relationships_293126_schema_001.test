INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293126_schema-001
--echo #
CREATE DATABASE `db_293126_schema_001`;
USE `db_293126_schema_001`;

CREATE TABLE `CONTAINERS` (
  `ID` INT,
  `PATH` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATA_SETS` (
  `ID` INT,
  `CODE` VARCHAR(64),
  `CTNR_ID` VARCHAR(64),
  `SIZE_IN_BYTES` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293126_schema_001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293126_schema_001') AS relationships;
DROP DATABASE `db_293126_schema_001`;
UNINSTALL EXTENSION vsql_schematron;
