INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231642_V26__spring_session
--echo #
CREATE DATABASE `db_231642_V26__spring_session`;
USE `db_231642_V26__spring_session`;
CREATE TABLE `SPRING_SESSION` (
  `SESSION_ID` VARCHAR(50) NOT NULL,
  `CREATION_TIME` BIGINT,
  `LAST_ACCESS_TIME` BIGINT,
  `MAX_INACTIVE_INTERVAL` INT,
  `PRINCIPAL_NAME` VARCHAR(50),
  PRIMARY KEY (`SESSION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SPRING_SESSION_ATTRIBUTES` (
  `SESSION_ID` VARCHAR(50) NOT NULL,
  `ATTRIBUTE_NAME` VARCHAR(50) NOT NULL,
  `ATTRIBUTE_BYTES` BLOB,
  PRIMARY KEY (`SESSION_ID`, `ATTRIBUTE_NAME`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231642_V26__spring_session') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231642_V26__spring_session') AS relationships;
DROP DATABASE `db_231642_V26__spring_session`;
UNINSTALL EXTENSION vsql_schematron;
