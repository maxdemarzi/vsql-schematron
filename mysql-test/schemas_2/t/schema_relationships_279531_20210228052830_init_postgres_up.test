INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279531_20210228052830_init.postgres.up
--echo #
CREATE DATABASE `db_279531_20210228052830_init_postgres_up`;
USE `db_279531_20210228052830_init_postgres_up`;

CREATE TABLE `oauths` (
  `id` INT,
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `blocked` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_users` (
  `oauth_id` INT,
  `user_id` INT,
  PRIMARY KEY (`oauth_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279531_20210228052830_init_postgres_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279531_20210228052830_init_postgres_up') AS relationships;
DROP DATABASE `db_279531_20210228052830_init_postgres_up`;
UNINSTALL EXTENSION vsql_schematron;
