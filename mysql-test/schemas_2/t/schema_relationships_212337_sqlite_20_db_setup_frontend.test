INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212337_sqlite%20_db_setup_frontend
--echo #
CREATE DATABASE `db_212337_sqlite_20_db_setup_frontend`;
USE `db_212337_sqlite_20_db_setup_frontend`;
CREATE TABLE `publication` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `title` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `purchase` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `publication_id` INT,
  `user_id` INT,
  `license_uuid` VARCHAR(50),
  `type` VARCHAR(50),
  `transaction_date` DATETIME,
  `start_date` DATETIME,
  `end_date` DATETIME,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `hint` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `license_view` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `device_count` INT,
  `status` VARCHAR(50),
  `message` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212337_sqlite_20_db_setup_frontend') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212337_sqlite_20_db_setup_frontend') AS relationships;
DROP DATABASE `db_212337_sqlite_20_db_setup_frontend`;
UNINSTALL EXTENSION vsql_schematron;
