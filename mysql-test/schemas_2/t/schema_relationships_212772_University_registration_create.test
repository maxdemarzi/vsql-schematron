INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212772_University_registration_create
--echo #
CREATE DATABASE `db_212772_University_registration_create`;
USE `db_212772_University_registration_create`;

CREATE TABLE `enrollment` (
  `student_id` INT,
  `course_id` INT,
  `enrolled_date` DATETIME,
  `final_grade` INT,
  PRIMARY KEY (`student_id`, `course_id`)
) CHARACTER SET latin1;

CREATE TABLE `assignment` (
  `assignment_id` INT,
  `student_id` INT,
  `course_id` INT,
  `grade` INT,
  PRIMARY KEY (`assignment_id`, `student_id`, `course_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212772_University_registration_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212772_University_registration_create') AS relationships;
DROP DATABASE `db_212772_University_registration_create`;
UNINSTALL EXTENSION vsql_schematron;
