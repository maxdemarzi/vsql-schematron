INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264667_komunitas
--echo #
CREATE DATABASE `db_264667_komunitas`;
USE `db_264667_komunitas`;

CREATE TABLE `comments` (
  `id` INT,
  `content` VARCHAR(64),
  `vote` INT,
  `user_id` INT,
  `post_id` INT,
  `parent_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `comunities` (
  `id` INT,
  `banner` VARCHAR(64),
  `type` VARCHAR(64),
  `name` VARCHAR(64),
  `followers` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eventcomunity` (
  `id` INT,
  `event_id` INT,
  `comunity_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` INT,
  `content` VARCHAR(64),
  `type` VARCHAR(64),
  `date` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `media` VARCHAR(64),
  `content` VARCHAR(64),
  `vote` INT,
  `view` INT,
  `user_id` INT,
  `comunity_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `statuses` (
  `id` INT,
  `status` VARCHAR(64),
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `usercomunity` (
  `id` INT,
  `user_id` INT,
  `comunity_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `avatar` VARCHAR(64),
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264667_komunitas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264667_komunitas') AS relationships;
DROP DATABASE `db_264667_komunitas`;
UNINSTALL EXTENSION vsql_schematron;
