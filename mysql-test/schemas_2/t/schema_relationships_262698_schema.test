INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 262698_schema
--echo #
CREATE DATABASE `db_262698_schema`;
USE `db_262698_schema`;

CREATE TABLE `role` (
  `id` VARCHAR(64),
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `deleted` INT,
  `updatedAt` DATETIME,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `resource` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `description` VARCHAR(64),
  `deleted` INT,
  `updatedAt` DATETIME,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `maintenance` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `message` VARCHAR(64),
  `is_down` INT,
  `updatedAt` DATETIME,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `maintenance_history` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `message` VARCHAR(64),
  `status` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` VARCHAR(64),
  `role_id` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `activated` INT,
  `deleted` INT,
  `updatedAt` DATETIME,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `user_id` VARCHAR(64),
  `prefix` VARCHAR(64),
  `suffix` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `avatar` VARCHAR(64),
  `avatar_url` VARCHAR(64),
  `title` VARCHAR(64),
  `position` VARCHAR(64),
  `mobile` VARCHAR(64),
  `website` VARCHAR(64),
  `updatedAt` DATETIME,
  `timestamp` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `audit_log` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `message` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_262698_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_262698_schema') AS relationships;
DROP DATABASE `db_262698_schema`;
UNINSTALL EXTENSION vsql_schematron;
