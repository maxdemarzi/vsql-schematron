INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 272914_schema
--echo #
CREATE DATABASE `db_272914_schema`;
USE `db_272914_schema`;
CREATE TABLE `authors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `dob` DATE,
  `sex` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_authors` (
  `book_id` SMALLINT NOT NULL,
  `author_id` SMALLINT NOT NULL,
  PRIMARY KEY (`author_id`, `book_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_272914_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_272914_schema') AS relationships;
DROP DATABASE `db_272914_schema`;
UNINSTALL EXTENSION vsql_schematron;
