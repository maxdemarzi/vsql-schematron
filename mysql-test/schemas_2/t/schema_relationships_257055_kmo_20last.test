INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257055_kmo_20last
--echo #
CREATE DATABASE `db_257055_kmo_20last`;
USE `db_257055_kmo_20last`;

CREATE TABLE `city` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `exam` (
  `id` INT,
  `examtitle` VARCHAR(64),
  `filepath` VARCHAR(64),
  `examdate` DATETIME,
  `starttime` DATETIME,
  `endtime` DATETIME,
  `description` VARCHAR(64),
  `examstatus` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `examresult` (
  `id` INT,
  `userid` INT,
  `examid` INT,
  `filepath` VARCHAR(64),
  `score` INT,
  `collecttime` DATETIME,
  `resultstatus` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `id` INT,
  `userid` INT,
  `accountname` VARCHAR(64),
  `bank` VARCHAR(64),
  `paymentslip` VARCHAR(64),
  `paymentstatus` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `nisn` VARCHAR(64),
  `fullname` VARCHAR(64),
  `email` VARCHAR(64),
  `gender` VARCHAR(64),
  `school` VARCHAR(64),
  `address` VARCHAR(64),
  `phoneNumber` VARCHAR(64),
  `dateOfBirth` DATETIME,
  `photo` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  `privilege` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257055_kmo_20last') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257055_kmo_20last') AS relationships;
DROP DATABASE `db_257055_kmo_20last`;
UNINSTALL EXTENSION vsql_schematron;
