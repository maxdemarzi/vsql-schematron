INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 256426_posm-paths
--echo #
CREATE DATABASE `db_256426_posm_paths`;
USE `db_256426_posm_paths`;

CREATE TABLE `Users` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sequences` (
  `id` VARCHAR(64),
  `userId` INT,
  `images` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Images` (
  `id` VARCHAR(64),
  `path` VARCHAR(64),
  `time` INT,
  `seqId` INT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_256426_posm_paths') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_256426_posm_paths') AS relationships;
DROP DATABASE `db_256426_posm_paths`;
UNINSTALL EXTENSION vsql_schematron;
