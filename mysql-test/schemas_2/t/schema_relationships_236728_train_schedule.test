INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 236728_train_schedule
--echo #
CREATE DATABASE `db_236728_train_schedule`;
USE `db_236728_train_schedule`;
CREATE TABLE `break_station` (
  `bs_id` INT,
  `train_number` VARCHAR(50),
  `break_train_come_time` TIME,
  `break_train_out_time` TIME
) CHARACTER SET latin1;
CREATE TABLE `train_number` (
  `train_number` VARCHAR(50) NOT NULL,
  `train_type` VARCHAR(50),
  PRIMARY KEY (`train_number`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_236728_train_schedule') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_236728_train_schedule') AS relationships;
DROP DATABASE `db_236728_train_schedule`;
UNINSTALL EXTENSION vsql_schematron;
