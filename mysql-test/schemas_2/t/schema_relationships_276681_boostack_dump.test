INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276681_boostack_dump
--echo #
CREATE DATABASE `db_276681_boostack_dump`;
USE `db_276681_boostack_dump`;
CREATE TABLE `boostack_api_request` (
  `id` VARCHAR(50) NOT NULL,
  `method` VARCHAR(50),
  `endpoint` VARCHAR(50),
  `verb` VARCHAR(50),
  `get_args` TEXT,
  `post_args` TEXT,
  `remote_address` VARCHAR(50),
  `remote_user_agent` VARCHAR(50),
  `error` VARCHAR(50),
  `code` SMALLINT,
  `message` VARCHAR(50),
  `output` TEXT,
  `created_at` BIGINT,
  `last_update` BIGINT,
  `last_access` BIGINT,
  `file_args` VARCHAR(50),
  `created_datetime` DATETIME,
  `client_code` VARCHAR(50),
  `app_code` VARCHAR(50),
  `user_code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_cache` (
  `key` VARCHAR(50) NOT NULL,
  `value` VARCHAR(50),
  `created_at` BIGINT,
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_http_session` (
  `id` INT NOT NULL,
  `ascii_session_id` VARCHAR(50),
  `logged_in` VARCHAR(50),
  `user_id` INT,
  `last_impression` INT,
  `created` INT,
  `user_agent` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_log` (
  `id` INT NOT NULL,
  `level` VARCHAR(50),
  `datetime` INT,
  `username` VARCHAR(50),
  `ip` VARCHAR(50),
  `useragent` VARCHAR(50),
  `referrer` VARCHAR(50),
  `query` VARCHAR(50),
  `message` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_session_variable` (
  `id` INT NOT NULL,
  `session_id` INT,
  `variable_name` VARCHAR(50),
  `variable_value` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_user_registration` (
  `id` INT NOT NULL,
  `activation_date` INT,
  `access_code` VARCHAR(50),
  `ip` VARCHAR(50),
  `join_date` INT,
  `join_idconfirm` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_user_info` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `name` VARCHAR(50),
  `locale` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50),
  `zip` VARCHAR(50),
  `about_me` TEXT,
  `tel` VARCHAR(50),
  `cell` VARCHAR(50),
  `profession` VARCHAR(50),
  `company` VARCHAR(50),
  `birthday` VARCHAR(50),
  `movies` VARCHAR(50),
  `music` VARCHAR(50),
  `political` VARCHAR(50),
  `interests` VARCHAR(50),
  `tv` VARCHAR(50),
  `religion` VARCHAR(50),
  `pic_big` VARCHAR(50),
  `sex` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_user_privilege` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `boostack_user_social` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `uid` VARCHAR(50),
  `uid_token` VARCHAR(50),
  `uid_token_secret` VARCHAR(50),
  `autosharing` VARCHAR(50),
  `website` VARCHAR(50),
  `extra` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276681_boostack_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276681_boostack_dump') AS relationships;
DROP DATABASE `db_276681_boostack_dump`;
UNINSTALL EXTENSION vsql_schematron;
