INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 200735_zhkuas_construct
--echo #
CREATE DATABASE `db_200735_zhkuas_construct`;
USE `db_200735_zhkuas_construct`;
CREATE TABLE `zk_campus` (
  `campusId` INT NOT NULL,
  `campusName` VARCHAR(50),
  PRIMARY KEY (`campusId`)
) CHARACTER SET latin1;
CREATE TABLE `zk_electivetime` (
  `electiveTimeId` INT NOT NULL,
  `electiveTimeBegin` DATETIME,
  `electiveTimeEnd` DATETIME,
  `electiveTimeOrder` TINYINT,
  `electiveTimeDescript` VARCHAR(50),
  PRIMARY KEY (`electiveTimeId`)
) CHARACTER SET latin1;
CREATE TABLE `zk_electivetime_class_rs` (
  `electiveTime_class_rs_id` INT NOT NULL,
  `electiveTimeId` INT,
  `classNo` VARCHAR(50),
  PRIMARY KEY (`electiveTime_class_rs_id`)
) CHARACTER SET latin1;
CREATE TABLE `zk_notice` (
  `noticeId` INT NOT NULL,
  `content` VARCHAR(50),
  `termNo` VARCHAR(50),
  PRIMARY KEY (`noticeId`)
) CHARACTER SET latin1;
CREATE TABLE `zk_temp_course_type` (
  `tctId` INT NOT NULL,
  `cName` VARCHAR(50),
  `pctId` INT,
  PRIMARY KEY (`tctId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_200735_zhkuas_construct') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_200735_zhkuas_construct') AS relationships;
DROP DATABASE `db_200735_zhkuas_construct`;
UNINSTALL EXTENSION vsql_schematron;
