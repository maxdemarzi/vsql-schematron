INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 233265_transaction-services-schema-mysql
--echo #
CREATE DATABASE `db_233265_transaction_services_schema_mysql`;
USE `db_233265_transaction_services_schema_mysql`;

CREATE TABLE `transaction_table` (
  `id` INT,
  `uid` VARCHAR(64),
  `txn_id` VARCHAR(64),
  `txn_type` VARCHAR(64),
  `txn_status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `money_reload_txn_table` (
  `id` INT,
  `txn_id` VARCHAR(64),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `airtime_send_txn_table` (
  `id` INT,
  `txn_id` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `phone_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_233265_transaction_services_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_233265_transaction_services_schema_mysql') AS relationships;
DROP DATABASE `db_233265_transaction_services_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
