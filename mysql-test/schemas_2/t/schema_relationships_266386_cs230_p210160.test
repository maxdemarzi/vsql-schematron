INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266386_cs230_p210160
--echo #
CREATE DATABASE `db_266386_cs230_p210160`;
USE `db_266386_cs230_p210160`;

CREATE TABLE `Home_Address` (
  `Home_Address_ID` INT,
  `Line1` VARCHAR(64),
  `Line2` VARCHAR(64),
  `Town` VARCHAR(64),
  `County` VARCHAR(64),
  `Eircode` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Shipping_Address` (
  `Ship_Address_ID` INT,
  `Line1` VARCHAR(64),
  `Line2` VARCHAR(64),
  `Town` VARCHAR(64),
  `County` VARCHAR(64),
  `Eircode` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `USERS` (
  `Customer_ID` INT,
  `Title` VARCHAR(64),
  `FName` VARCHAR(64),
  `LName` VARCHAR(64),
  `Mobile` VARCHAR(64),
  `Email` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266386_cs230_p210160') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266386_cs230_p210160') AS relationships;
DROP DATABASE `db_266386_cs230_p210160`;
UNINSTALL EXTENSION vsql_schematron;
