INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217296_script
--echo #
CREATE DATABASE `db_217296_script`;
USE `db_217296_script`;
CREATE TABLE `perfis` (
  `id_perfil` INT NOT NULL,
  `perfil` VARCHAR(50),
  PRIMARY KEY (`id_perfil`)
) CHARACTER SET latin1;
CREATE TABLE `equipamentos` (
  `id_equipamento` INT NOT NULL,
  `equipamento` VARCHAR(50),
  `imagem` VARCHAR(50),
  `descricao` VARCHAR(50),
  `ativo` INT,
  `data` DATETIME,
  PRIMARY KEY (`id_equipamento`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id_usuario` INT NOT NULL,
  `senha` VARCHAR(50),
  `fk_id_perfil` INT,
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `comentarios` (
  `id_comentario` INT NOT NULL,
  `comentario` VARCHAR(50),
  `data` DATETIME,
  `fk_id_equipamento` INT,
  `fk_id_perfil` INT,
  PRIMARY KEY (`id_comentario`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217296_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217296_script') AS relationships;
DROP DATABASE `db_217296_script`;
UNINSTALL EXTENSION vsql_schematron;
