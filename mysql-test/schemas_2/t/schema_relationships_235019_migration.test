INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235019_migration
--echo #
CREATE DATABASE `db_235019_migration`;
USE `db_235019_migration`;
CREATE TABLE `Category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `transactionType` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Transaction` (
  `id` INT NOT NULL,
  `amount` DECIMAL(10,2),
  `date` TIMESTAMP NULL,
  `description` VARCHAR(50),
  `transactionType` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `categoryId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235019_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235019_migration') AS relationships;
DROP DATABASE `db_235019_migration`;
UNINSTALL EXTENSION vsql_schematron;
