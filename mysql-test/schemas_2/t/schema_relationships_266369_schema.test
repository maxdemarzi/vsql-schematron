INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266369_schema
--echo #
CREATE DATABASE `db_266369_schema`;
USE `db_266369_schema`;

CREATE TABLE `CreditCard` (
  `id` INT,
  `ownerFullName` VARCHAR(64),
  `number` VARCHAR(64),
  `pin` VARCHAR(64),
  `expirationDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Faculty` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `id` INT,
  `faculty_id` INT,
  `required_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Person` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `birthDate` DATETIME,
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Assistant` (
  `id` INT,
  `details_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `id` INT,
  `details_id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `creditCard_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Inscription` (
  `id` INT,
  `student_id` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Teacher` (
  `id` INT,
  `details_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Session` (
  `id` INT,
  `course_id` INT,
  `teacher_id` INT,
  `assistant_id` INT,
  `academicYear` INT,
  `firstLesson` DATETIME,
  `lastLesson` DATETIME,
  `code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `inscription_session` (
  `inscription_id` INT,
  `session_id` INT,
  PRIMARY KEY (`inscription_id`, `session_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266369_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266369_schema') AS relationships;
DROP DATABASE `db_266369_schema`;
UNINSTALL EXTENSION vsql_schematron;
