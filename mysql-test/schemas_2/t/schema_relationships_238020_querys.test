INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 238020_querys
--echo #
CREATE DATABASE `db_238020_querys`;
USE `db_238020_querys`;
CREATE TABLE `tb_clientes` (
  `id` INT NOT NULL,
  `cliente_ativo` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_tipo_contatos` (
  `tipo_contato` INT NOT NULL,
  `descricao` VARCHAR(50),
  PRIMARY KEY (`tipo_contato`)
) CHARACTER SET latin1;
CREATE TABLE `tb_contatos` (
  `id` INT NOT NULL,
  `tipo_contato` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_238020_querys') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_238020_querys') AS relationships;
DROP DATABASE `db_238020_querys`;
UNINSTALL EXTENSION vsql_schematron;
