INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 273056_20210530213127_simple_tokens
--echo #
CREATE DATABASE `db_273056_20210530213127_simple_tokens`;
USE `db_273056_20210530213127_simple_tokens`;
CREATE TABLE `shares` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schemas` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `share_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `schema_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
  `id` VARCHAR(50) NOT NULL,
  `token` TEXT,
  `expires_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens_for_tables` (
  `id` VARCHAR(50) NOT NULL,
  `token_id` VARCHAR(50),
  `table_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_273056_20210530213127_simple_tokens') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_273056_20210530213127_simple_tokens') AS relationships;
DROP DATABASE `db_273056_20210530213127_simple_tokens`;
UNINSTALL EXTENSION vsql_schematron;
