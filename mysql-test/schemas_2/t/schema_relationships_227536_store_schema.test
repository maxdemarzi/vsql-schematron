INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227536_store_schema
--echo #
CREATE DATABASE `db_227536_store_schema`;
USE `db_227536_store_schema`;

CREATE TABLE `CUSTOMER` (
  `ID` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `IS_ACTIVE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CUSTOMER_PHONE` (
  `ID` VARCHAR(64),
  `CUSTOMER_ID` VARCHAR(64),
  `AREA_CODE` INT,
  `EXCHANGE` INT,
  `NUMBER` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DAILY_SALES_SUMMARY` (
  `DATE` DATETIME,
  `STORE_ID` VARCHAR(64),
  `TOTAL_SALE` DECIMAL(10,2),
  `TOTAL_TAX` DECIMAL(10,2),
  `TOTLA_TIP` DECIMAL(10,2),
  `TOTAL_DISCOUNT` DECIMAL(10,2),
  PRIMARY KEY (`STORE_ID`, `DATE`)
) CHARACTER SET latin1;

CREATE TABLE `STORE` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `IMAGE` VARCHAR(64),
  `CREATED_TIME` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `STORE_SETTINGS` (
  `ID` VARCHAR(64),
  `STORE_ID` VARCHAR(64),
  `SETTING_KEY` VARCHAR(64),
  `SETTING_VALUE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227536_store_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227536_store_schema') AS relationships;
DROP DATABASE `db_227536_store_schema`;
UNINSTALL EXTENSION vsql_schematron;
