INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295762_iniTMy
--echo #
CREATE DATABASE `db_295762_iniTMy`;
USE `db_295762_iniTMy`;

CREATE TABLE `addresses` (
  `id` INT,
  `line1` VARCHAR(64),
  `line2` VARCHAR(64),
  `line3` VARCHAR(64),
  `city` VARCHAR(64),
  `province` VARCHAR(64),
  `zip` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `phones` (
  `id` INT,
  `phone_num` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `faxes` (
  `id` INT,
  `fax_num` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `item_name` VARCHAR(64),
  `sku` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authors` (
  `id` INT,
  `nickname` VARCHAR(64),
  `user_group` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `customer_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_num` INT,
  `billing_address_id` INT,
  `shipping_address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clerks` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `preference` VARCHAR(64),
  `phone_id` INT,
  `fax_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `suppliers` (
  `id` INT,
  `supplier_name` VARCHAR(64),
  `address_id` INT,
  `contact_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `magento_id` INT,
  `customer_id` INT,
  `shipping_address_id` INT,
  `shipping_phone_id` INT,
  `magento_time` DATETIME,
  `orsys_timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_details` (
  `id` INT,
  `order_id` INT,
  `status` VARCHAR(64),
  `status_switch` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `invoices` (
  `id` INT,
  `author_id` INT,
  `supplier_id` INT,
  `resolved` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295762_iniTMy') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295762_iniTMy') AS relationships;
DROP DATABASE `db_295762_iniTMy`;
UNINSTALL EXTENSION vsql_schematron;
