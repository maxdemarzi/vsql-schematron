INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 255228_SCRIPT_1
--echo #
CREATE DATABASE `db_255228_SCRIPT_1`;
USE `db_255228_SCRIPT_1`;
CREATE TABLE `DEPARTMENT` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHIEF` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `SALARY` INT,
  `DEPARTMENT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `SALARY` INT,
  `DEPARTMENT_ID` INT,
  `CHIEF_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_255228_SCRIPT_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_255228_SCRIPT_1') AS relationships;
DROP DATABASE `db_255228_SCRIPT_1`;
UNINSTALL EXTENSION vsql_schematron;
