INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227531_final_pos
--echo #
CREATE DATABASE `db_227531_final_pos`;
USE `db_227531_final_pos`;

CREATE TABLE `attributes` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute_values` (
  `id` INT,
  `value` VARCHAR(64),
  `attribute_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `parent_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories_items` (
  `id` INT,
  `category_id` INT,
  `item_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `user_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `address1` VARCHAR(64),
  `address2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `country` VARCHAR(64),
  `company` VARCHAR(64),
  `account` VARCHAR(64),
  `total` DECIMAL(10,2),
  `discount` INT,
  `taxable` INT,
  `comments` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `loginname` VARCHAR(64),
  `user_id` INT,
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `image` VARCHAR(64),
  `employeeid` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `giftcards` (
  `id` INT,
  `customer_id` INT,
  `card_number` VARCHAR(64),
  `expire_date` DATETIME,
  `value` INT,
  `card_image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `item_id` INT,
  `name` VARCHAR(64),
  `note` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `item_kits` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `baseimage` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_kit_products` (
  `id` INT,
  `item_kits_id` INT,
  `item_id` INT,
  `quantity` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `reports` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `invoice_id` VARCHAR(64),
  `customer_id` INT,
  `employee_id` INT,
  `comments` VARCHAR(64),
  `total` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `coupon` VARCHAR(64),
  `finaltotal` DECIMAL(10,2),
  `payment_type` VARCHAR(64),
  `payment_status` VARCHAR(64),
  `sale_type` VARCHAR(64),
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `order_status` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `shipping_details` (
  `id` INT,
  `sales_id` INT,
  `full_name` VARCHAR(64),
  `company_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `country` VARCHAR(64),
  `state` VARCHAR(64),
  `city` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `storeconfigs` (
  `id` INT,
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `suppliers` (
  `id` INT,
  `user_id` INT,
  `company_name` VARCHAR(64),
  `agency_name` VARCHAR(64),
  `account_number` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `address1` VARCHAR(64),
  `address2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `country` VARCHAR(64),
  `comments` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `who_useds` (
  `id` INT,
  `user_id` INT,
  `coupon_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `wishlists` (
  `id` INT,
  `user_id` INT,
  `item_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227531_final_pos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227531_final_pos') AS relationships;
DROP DATABASE `db_227531_final_pos`;
UNINSTALL EXTENSION vsql_schematron;
