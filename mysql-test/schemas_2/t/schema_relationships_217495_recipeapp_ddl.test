INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217495_recipeapp_ddl
--echo #
CREATE DATABASE `db_217495_recipeapp_ddl`;
USE `db_217495_recipeapp_ddl`;

CREATE TABLE `RECIPE` (
  `RECIPE_ID` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `DIFFICULTY` VARCHAR(255),
  `SERVINGS` INT,
  `SOURCE` VARCHAR(255),
  `URL` VARCHAR(255),
  `IMAGE` VARCHAR(255),
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`RECIPE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CATEGORY` (
  `CATEGORY_ID` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`CATEGORY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `STEP` (
  `STEP_ID` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `PREPARATION_TIME` INT,
  `COOKING_TIME` INT,
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`STEP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `INGREDIENT` (
  `INGREDIENT_ID` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`INGREDIENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `UOM` (
  `UOM_ID` INT,
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  PRIMARY KEY (`UOM_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RECIPE_CATEGORY` (
  `RECIPE_ID` INT,
  `CATEGORY_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `RECIPE_STEP` (
  `RECIPE_STEP_ID` INT,
  `RECIPE_ID` INT,
  `STEP_ID` INT,
  `ORDINAL` INT,
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`RECIPE_STEP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `STEP_INGREDIENT` (
  `STEP_INGREDIENT_ID` INT,
  `STEP_ID` INT,
  `INGREDIENT_ID` INT,
  `UOM_ID` INT,
  `UOM_COUNT` DECIMAL(10,2),
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`STEP_INGREDIENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `NOTE` (
  `NOTE_ID` INT,
  `RECIPE_ID` INT,
  `NOTE_TEXT` VARCHAR(255),
  `CREATED_TIMESTAMP` DATETIME,
  `MODIFIED_TIMESTAMP` DATETIME,
  PRIMARY KEY (`NOTE_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217495_recipeapp_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217495_recipeapp_ddl') AS relationships;
DROP DATABASE `db_217495_recipeapp_ddl`;
UNINSTALL EXTENSION vsql_schematron;
