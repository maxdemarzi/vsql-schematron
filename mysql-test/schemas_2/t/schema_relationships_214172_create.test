INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 214172_create
--echo #
CREATE DATABASE `db_214172_create`;
USE `db_214172_create`;

CREATE TABLE `USERS` (
  `username` VARCHAR(64),
  `pass` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `MESSAGES` (
  `id` INT,
  `mess` VARCHAR(64),
  `sender` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_214172_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_214172_create') AS relationships;
DROP DATABASE `db_214172_create`;
UNINSTALL EXTENSION vsql_schematron;
