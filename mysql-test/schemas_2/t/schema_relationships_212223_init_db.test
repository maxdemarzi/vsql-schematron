INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212223_init_db
--echo #
CREATE DATABASE `db_212223_init_db`;
USE `db_212223_init_db`;

CREATE TABLE `Session` (
  `Id` INT,
  `SessionStart` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Event` (
  `Id` INT,
  `SessionId` INT,
  `TimeStamp` INT,
  `Key` VARCHAR(64),
  `Type` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ValueBool` (
  `Id` INT,
  `Value` BOOL,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ValueString` (
  `Id` INT,
  `Value` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ValueNumber` (
  `Id` INT,
  `Value` DECIMAL(10,2),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212223_init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212223_init_db') AS relationships;
DROP DATABASE `db_212223_init_db`;
UNINSTALL EXTENSION vsql_schematron;
