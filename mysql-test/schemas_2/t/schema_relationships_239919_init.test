INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239919_init
--echo #
CREATE DATABASE `db_239919_init`;
USE `db_239919_init`;

CREATE TABLE `user_group` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exercise` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `solution` (
  `id` INT,
  `created` DATETIME,
  `updated` DATETIME,
  `description` VARCHAR(64),
  `exercise_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239919_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239919_init') AS relationships;
DROP DATABASE `db_239919_init`;
UNINSTALL EXTENSION vsql_schematron;
