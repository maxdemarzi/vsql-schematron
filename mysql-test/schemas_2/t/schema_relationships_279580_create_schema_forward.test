INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279580_create-schema-forward
--echo #
CREATE DATABASE `db_279580_create_schema_forward`;
USE `db_279580_create_schema_forward`;

CREATE TABLE `exotic_types` (
  `login` VARCHAR(64),
  `countries` BOOL,
  `authorizations` VARCHAR(64),
  `scores` VARCHAR(64),
  `gpa` VARCHAR(64),
  `status` VARCHAR(64),
  `custom` VARCHAR(64),
  PRIMARY KEY (`login`)
) CHARACTER SET latin1;

CREATE TABLE `widget` (
  `id` INT,
  `name` VARCHAR(64),
  `login_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `simple_type` (
  `id` INT,
  `amount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `planet` (
  `name` VARCHAR(64),
  `position` INT,
  `distance` INT,
  PRIMARY KEY (`name`, `position`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279580_create_schema_forward') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279580_create_schema_forward') AS relationships;
DROP DATABASE `db_279580_create_schema_forward`;
UNINSTALL EXTENSION vsql_schematron;
