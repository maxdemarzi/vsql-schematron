) CHARACTER SET latin1;
CREATE TABLE `item` (
`id` BIGINT NOT NULL,
`description` VARCHAR(50),
`user_id` BIGINT,
`created` BIGINT,
`done` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
