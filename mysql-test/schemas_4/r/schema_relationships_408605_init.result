CREATE TABLE `hotels` (
`id` INT NOT NULL,
`description` TEXT,
`cost` INT,
`creation_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
`booking_id` INT NOT NULL,
`hotel_id` INT,
`begin_data` DATE,
`end_date` DATE,
PRIMARY KEY (`booking_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_408605_init') AS relationships;
