INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 403152_slam
#
CREATE DATABASE `db_403152_slam`;
USE `db_403152_slam`;
CREATE TABLE `classes` (
`class_id` INT,
`name` VARCHAR(64),
`teacher_id` INT,
`prefect_id` INT,
PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`message_id` INT,
`body` VARCHAR(64),
`destination` VARCHAR(64),
`origin` VARCHAR(64),
`read_status` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted` INT,
PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`student_id` INT,
`name` VARCHAR(64),
`hash` VARCHAR(64),
`birthday` VARCHAR(64),
`sex` VARCHAR(64),
`religion` VARCHAR(64),
`blood_group` VARCHAR(64),
`address` VARCHAR(64),
`parent_phone` VARCHAR(64),
`parent_email` VARCHAR(64),
`password` VARCHAR(64),
`father_name` VARCHAR(64),
`mother_name` VARCHAR(64),
`class_id` INT,
`role` VARCHAR(64),
`profileUrl` VARCHAR(64),
`authentication_key` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
`subject_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `subjectteacher` (
`subject_id` INT,
`teacher_id` INT
) CHARACTER SET latin1;
CREATE TABLE `teacherclass` (
`class_id` INT,
`teacher_id` INT
) CHARACTER SET latin1;
CREATE TABLE `teachers` (
`teacher_id` INT,
`hash` VARCHAR(64),
`name` VARCHAR(64),
`birthday` VARCHAR(64),
`sex` VARCHAR(64),
`religion` VARCHAR(64),
`profileUrl` VARCHAR(64),
`blood_group` VARCHAR(64),
`role` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`country` VARCHAR(64),
`county` VARCHAR(64),
`subjects` VARCHAR(64),
`authentication_key` VARCHAR(64),
PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_403152_slam') AS relationships;
relationships
