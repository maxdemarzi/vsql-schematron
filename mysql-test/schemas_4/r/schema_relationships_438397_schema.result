PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rentals` (
`id` INT,
`title` VARCHAR(64),
`created` INT,
`category_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`member_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `access` (
`id` INT,
`password` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
`id` INT,
`user_id` INT,
