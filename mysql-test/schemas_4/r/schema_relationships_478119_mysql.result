INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 478119_mysql
#
CREATE DATABASE `db_478119_mysql`;
USE `db_478119_mysql`;
CREATE TABLE `questions` (
`id` INT NOT NULL,
`text` VARCHAR(50),
`enabled` TINYINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
`id` INT NOT NULL,
`question_id` INT,
`text` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`id` INT NOT NULL,
`answer_id` INT,
`ip_address` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` INT,
`deleted_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_478119_mysql') AS relationships;
