CREATE DATABASE `db_478301_db_create_all`;
USE `db_478301_db_create_all`;
CREATE TABLE `address` (
`id` INT,
`address` VARCHAR(64),
`city` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact` (
`id` INT,
`contact` VARCHAR(64),
`type` VARCHAR(64),
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`id` INT,
`name` VARCHAR(64),
`doc_number` VARCHAR(64),
`status` INT,
`registered` DATETIME,
`billing_address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
`id` INT,
`message` VARCHAR(64),
`fecha` DATETIME,
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_478301_db_create_all') AS relationships;
