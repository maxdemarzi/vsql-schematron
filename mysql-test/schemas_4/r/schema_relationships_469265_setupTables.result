CREATE TABLE `Users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`emailVerified` BOOLEAN,
`verifyEmailCode` VARCHAR(50),
`password` VARCHAR(50),
`tempMfaSecret` VARCHAR(50),
`mfaSecret` VARCHAR(50),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
