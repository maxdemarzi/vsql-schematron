PRIMARY KEY (`iddepartment`)
) CHARACTER SET latin1;
CREATE TABLE `ucycles_software` (
`idsoftware` INT,
`name` VARCHAR(64),
`department_id` INT,
PRIMARY KEY (`idsoftware`)
) CHARACTER SET latin1;
