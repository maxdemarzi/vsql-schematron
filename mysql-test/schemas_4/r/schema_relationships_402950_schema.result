[Implied]  activity.fk_activity_group -> activity_group.id
[Implied]  activity_group.fk_initiative -> initiative.id
[Implied]  count.fk_location -> location.id
[Implied]  count.fk_session -> session.id
[Implied]  count_activity_join.fk_activity -> activity.id
[Implied]  count_activity_join.fk_activity -> activity_group.id
[Implied]  count_activity_join.id -> count.id
[Implied]  initiative.fk_root_location -> location.id
[Implied]  location.fk_parent -> location.id
[Implied]  note.fk_session -> session.id
[Implied]  session.fk_initiative -> initiative.id
[Implied]  session.fk_transaction -> transaction.id

DROP DATABASE `db_402950_schema`;
UNINSTALL EXTENSION vsql_schematron;
