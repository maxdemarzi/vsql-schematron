[Implied]  module_state.participant_id -> participant.id
[Implied]  participant.session_id -> session.id
[Implied]  random_idea.participant_id -> participant.id
[Implied]  resource.session_id -> session.id
[Implied]  selection.topic_id -> topic.id
[Implied]  selection_idea.selection_id -> selection.id
[Implied]  session_role.session_id -> session.id
[Implied]  session_role.user_id -> user.id
[Implied]  topic.session_id -> session.id
[Implied]  vote.participant_id -> participant.id

DROP DATABASE `db_447537_schema`;
UNINSTALL EXTENSION vsql_schematron;
