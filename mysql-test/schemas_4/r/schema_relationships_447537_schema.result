INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 447537_schema
#
CREATE DATABASE `db_447537_schema`;
USE `db_447537_schema`;
CREATE TABLE `hierarchy` (
`category_idea_id` VARCHAR(64),
`sub_idea_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `module_state` (
`module_id` VARCHAR(64),
`participant_id` VARCHAR(64),
`state` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `participant` (
`id` VARCHAR(64),
`session_id` VARCHAR(64),
`browser_key` VARCHAR(64),
`state` VARCHAR(64),
`color` VARCHAR(64),
`symbol` VARCHAR(64),
`ip_hash` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `random_idea` (
`idea_id` VARCHAR(64),
`participant_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `resource` (
`id` VARCHAR(64),
`session_id` VARCHAR(64),
`title` VARCHAR(64),
`image` VARCHAR(64),
`link` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `selection` (
`id` VARCHAR(64),
`topic_id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `selection_idea` (
`selection_id` VARCHAR(64),
`idea_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `session` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`connection_key` VARCHAR(64),
`max_participants` INT,
`expiration_date` DATETIME,
`creation_date` DATETIME,
`public_screen_module_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session_role` (
`session_id` VARCHAR(64),
`user_id` VARCHAR(64),
`role` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `topic` (
`id` VARCHAR(64),
`session_id` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`active_task_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `vote` (
`id` VARCHAR(64),
`task_id` VARCHAR(64),
`participant_id` VARCHAR(64),
`idea_id` VARCHAR(64),
`rating` INT,
`detail_rating` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_447537_schema') AS relationships;
relationships
Database: db_447537_schema

Table Connections:
