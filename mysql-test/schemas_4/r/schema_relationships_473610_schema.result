CREATE DATABASE `db_473610_schema`;
USE `db_473610_schema`;
CREATE TABLE `__EFMigrationsHistory` (
`MigrationId` VARCHAR(50) NOT NULL,
`ProductVersion` CHAR(50),
PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`file_size` INT,
`file_type` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `claims` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`document_id` VARCHAR(50),
`service_area_created_by` TEXT,
`user_created_by` TEXT,
`api_created_by` TEXT,
`retention_expires_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
