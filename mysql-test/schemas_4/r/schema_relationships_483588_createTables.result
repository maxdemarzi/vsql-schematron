CREATE TABLE `User` (
`uid` INT,
`username` VARCHAR(64),
`pass` VARCHAR(64),
`userNo` VARCHAR(64),
`phone` VARCHAR(64),
`userType` BOOL,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `StudentSheet` (
`sheetID` INT,
`uid` INT,
`sheetName` VARCHAR(64),
PRIMARY KEY (`sheetID`)
) CHARACTER SET latin1;
CREATE TABLE `Student` (
`sid` INT,
`clientID` VARCHAR(64),
`sheetID` INT,
`studentName` VARCHAR(64),
`studentNO` VARCHAR(64),
`className` VARCHAR(64),
PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
`cid` INT,
`uid` INT,
`courseName` VARCHAR(64),
`startDates` VARCHAR(64),
`numberOfWeeks` INT,
PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `SignInfo` (
`signID` INT,
`cid` INT,
`sid` INT,
`signDetail` VARCHAR(64),
`signTimes` INT,
`lastSignPhoto` VARCHAR(64),
PRIMARY KEY (`signID`)
) CHARACTER SET latin1;
