INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 440590_database
#
CREATE DATABASE `db_440590_database`;
USE `db_440590_database`;
CREATE TABLE `questions` (
`id` INT,
`description` VARCHAR(64),
`option_a` VARCHAR(64),
`option_b` VARCHAR(64),
`option_c` VARCHAR(64),
`option_d` VARCHAR(64),
`correct_option` VARCHAR(64),
`difficulty` INT,
`subject` INT,
`author` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `difficulties` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question_subjects` (
`id` INT,
`subject` VARCHAR(64),
`is_general_subject` BOOL,
`channel` VARCHAR(64),
`subject_simplified` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_440590_database') AS relationships;
relationships
Database: db_440590_database

