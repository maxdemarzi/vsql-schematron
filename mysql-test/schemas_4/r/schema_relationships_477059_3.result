INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 477059_3
#
CREATE DATABASE `db_477059_3`;
USE `db_477059_3`;
CREATE TABLE `wiki` (
`id` INT NOT NULL,
`title` CHAR(50),
`language` CHAR(50),
`canonical` CHAR(50),
`editable` BOOLEAN,
`visible` BOOLEAN,
`group_id` INT,
`parent_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wikiversion` (
`id` INT NOT NULL,
`date` DATE,
`content` TEXT,
`active` BOOLEAN,
`wiki_id` INT,
`user_id` INT,
`image` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wikicomment` (
`id` INT NOT NULL,
`title` CHAR(50),
`content` TEXT,
`date` DATE,
`wiki_id` INT,
`parent_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_477059_3') AS relationships;
