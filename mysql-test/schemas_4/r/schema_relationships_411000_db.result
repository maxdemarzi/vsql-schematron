INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 411000_db
#
CREATE DATABASE `db_411000_db`;
USE `db_411000_db`;
CREATE TABLE `Maestro` (
`id` INT NOT NULL,
`nombreMaestro` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Alumno` (
`id` INT NOT NULL,
`matricula` CHAR(50),
`nombreAlumno` CHAR(50),
`semestre` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Materia` (
`id` INT NOT NULL,
`nombreMateria` VARCHAR(50),
`idMaestro` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Grupo` (
`id` INT NOT NULL,
`nombreGrupo` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Horario` (
`id` INT NOT NULL,
`idAlumno` INT,
`idGrupo` INT,
`idMateria` INT,
`hora` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_411000_db') AS relationships;
relationships
Database: db_411000_db

Table Connections:
------------------
[Implied]  Horario.idAlumno -> Alumno.id
[Implied]  Horario.idGrupo -> Grupo.id
[Implied]  Horario.idMateria -> Materia.id
[Implied]  Materia.idMaestro -> Maestro.id

DROP DATABASE `db_411000_db`;
UNINSTALL EXTENSION vsql_schematron;
