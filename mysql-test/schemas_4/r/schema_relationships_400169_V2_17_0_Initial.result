INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 400169_V2_17_0_Initial
#
CREATE DATABASE `db_400169_V2_17_0_Initial`;
USE `db_400169_V2_17_0_Initial`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(255),
`cpa` VARCHAR(255),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `url_mapping` (
`source` VARCHAR(255),
`destination` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `certificate_mapping` (
`id` VARCHAR(255),
`source` VARCHAR(255),
`destination` VARCHAR(255),
`cpa_id` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`id` INT,
`time_stamp` DATETIME,
`cpa_id` VARCHAR(255),
`conversation_id` VARCHAR(255),
`message_id` VARCHAR(255),
`message_nr` INT,
`ref_to_message_id` VARCHAR(255),
`time_to_live` DATETIME,
`persist_time` DATETIME,
`from_party_id` VARCHAR(255),
`from_role` VARCHAR(255),
`to_party_id` VARCHAR(255),
`to_role` VARCHAR(255),
`service` VARCHAR(255),
`action` VARCHAR(255),
`content` VARCHAR(255),
`status` INT,
`status_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`ebms_message_id` INT,
`order_nr` INT,
`name` VARCHAR(255),
`content_id` VARCHAR(255),
`content_type` VARCHAR(255),
`content` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event` (
`cpa_id` VARCHAR(255),
`send_channel_id` VARCHAR(255),
`receive_channel_id` VARCHAR(255),
`message_id` VARCHAR(255),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`is_confidential` VARCHAR(255),
`retries` INT,
`server_id` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event_log` (
`message_id` VARCHAR(255),
`time_stamp` DATETIME,
`uri` VARCHAR(255),
`status` INT,
`error_message` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message_event` (
`message_id` VARCHAR(255),
`event_type` INT,
`time_stamp` DATETIME,
`processed` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_400169_V2_17_0_Initial') AS relationships;
relationships
Database: db_400169_V2_17_0_Initial

Table Connections:
