) CHARACTER SET latin1;
CREATE TABLE `habit` (
`habit_id` INT NOT NULL,
`name` TEXT,
`description` TEXT,
`user_id` INT,
PRIMARY KEY (`habit_id`)
) CHARACTER SET latin1;
CREATE TABLE `record` (
`record_date` VARCHAR(50) NOT NULL,
`status` INT,
`habit_id` INT NOT NULL,
PRIMARY KEY (`habit_id`, `record_date`)
) CHARACTER SET latin1;
