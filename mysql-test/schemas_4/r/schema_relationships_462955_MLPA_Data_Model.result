INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 462955_MLPA-Data-Model
#
CREATE DATABASE `db_462955_MLPA_Data_Model`;
USE `db_462955_MLPA_Data_Model`;
CREATE TABLE `genes` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genes_variations` (
`gene_id` INT,
`variation_id` INT
) CHARACTER SET latin1;
CREATE TABLE `variations` (
`id` INT,
`variation` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `variations_results` (
`variation_id` INT,
`result_id` INT
) CHARACTER SET latin1;
CREATE TABLE `results` (
`id` INT,
`result` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `interpretations` (
`id` INT,
`interpretations` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `results_interpretations` (
`result_id` VARCHAR(64),
`interpretations_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_462955_MLPA_Data_Model') AS relationships;
relationships
Database: db_462955_MLPA_Data_Model

Table Connections:
