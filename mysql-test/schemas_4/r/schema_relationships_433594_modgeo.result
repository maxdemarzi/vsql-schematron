INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 433594_modgeo
#
CREATE DATABASE `db_433594_modgeo`;
USE `db_433594_modgeo`;
CREATE TABLE `empresa` (
`id_empresa` INT,
`nmEmpresa` VARCHAR(64),
`nrCnpj` VARCHAR(64),
`nmCidadeOrigem` VARCHAR(64),
`nmEmail` VARCHAR(64),
`nrTelefone` VARCHAR(64),
`dtInclusao` DATETIME,
PRIMARY KEY (`id_empresa`)
) CHARACTER SET latin1;
CREATE TABLE `nome_sondagem` (
`id_sondagem` INT,
`nmSondagem` VARCHAR(64),
`nmResponsavel` VARCHAR(64),
`dtInicio` DATETIME,
`dtTermino` DATETIME,
`nrCoord_x` DECIMAL(10,2),
`nrCoord_y` DECIMAL(10,2),
`nrCota` DECIMAL(10,2),
`nrDirecao` VARCHAR(64),
`nrProfundidade` DECIMAL(10,2),
`nrInclinacao` DECIMAL(10,2),
`nrGeoreferenciamento` DECIMAL(10,2),
`txtComentario` VARCHAR(64),
`dtInclusao` DATETIME,
PRIMARY KEY (`id_sondagem`)
) CHARACTER SET latin1;
CREATE TABLE `parametros_sondagem` (
`id_parametros_sondagem` INT,
`nrAlteracao` INT,
`nrConsistencia` INT,
`nrFraturamento` INT,
`nrRqd` INT,
`id_sondagem` INT
) CHARACTER SET latin1;
CREATE TABLE `tipo_ocorrencia_sondagem` (
`id_tipo_ocorrencia_sondagem` INT,
`nrProfundidadeMin` DECIMAL(10,2),
`nrProfundidadeMax` DECIMAL(10,2),
`nmTipoRocha` VARCHAR(64),
`id_sondagem` INT,
`nmHachuras` VARCHAR(64),
`nmCor` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_433594_modgeo') AS relationships;
relationships
