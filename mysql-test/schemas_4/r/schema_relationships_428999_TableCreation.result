CREATE TABLE `User` (
`UserName` VARCHAR(50) NOT NULL,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`Password` VARCHAR(50),
`Wallet` VARCHAR(50),
`CreditCard` VARCHAR(50),
`Admin` VARCHAR(50),
PRIMARY KEY (`UserName`)
) CHARACTER SET latin1;
CREATE TABLE `GameTag` (
`GameId` INT NOT NULL,
`TagId` INT NOT NULL,
PRIMARY KEY (`GameId`, `TagId`)
) CHARACTER SET latin1;
CREATE TABLE `UserDLC` (
`UserName` VARCHAR(50) NOT NULL,
`DLCId` INT NOT NULL,
PRIMARY KEY (`UserName`, `DLCId`)
) CHARACTER SET latin1;
