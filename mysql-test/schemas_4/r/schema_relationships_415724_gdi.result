INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 415724_gdi
#
CREATE DATABASE `db_415724_gdi`;
USE `db_415724_gdi`;
CREATE TABLE `comments` (
`id` INT,
`userid` INT,
`complainid` INT,
`comment` VARCHAR(255),
`username` VARCHAR(255),
`admin` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `complains` (
`id` INT,
`userid` INT,
`email` VARCHAR(255),
`username` VARCHAR(255),
`status` VARCHAR(255),
`title` VARCHAR(255),
`message` VARCHAR(255),
`date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`userid` INT,
`name` VARCHAR(255),
`surname` VARCHAR(255),
`email` VARCHAR(255),
`username` VARCHAR(255),
`password` VARCHAR(255),
`admin` VARCHAR(255),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_415724_gdi') AS relationships;
