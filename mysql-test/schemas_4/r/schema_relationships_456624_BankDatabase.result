INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 456624_BankDatabase
#
CREATE DATABASE `db_456624_BankDatabase`;
USE `db_456624_BankDatabase`;
CREATE TABLE `ACCTYPE` (
`ACCOUNT_TYPE` DECIMAL(10,2),
`INTEREST_RATE` DECIMAL(10,2),
PRIMARY KEY (`ACCOUNT_TYPE`)
) CHARACTER SET latin1;
CREATE TABLE `ZIP` (
`ZIP_CODE` VARCHAR(255),
`CITY` VARCHAR(255),
`STREET_NAME` VARCHAR(255),
PRIMARY KEY (`ZIP_CODE`)
) CHARACTER SET latin1;
CREATE TABLE `LOANTYPE` (
`LOAN_TYPE` VARCHAR(255),
`INTEREST_RATE` DECIMAL(10,2),
`LOAN_DESCRIPTION` VARCHAR(255),
PRIMARY KEY (`LOAN_TYPE`)
) CHARACTER SET latin1;
CREATE TABLE `Bank_Branch` (
`BRANCH_ID` VARCHAR(255),
`STREET_NO` VARCHAR(255),
`APT_NO` VARCHAR(255),
`STREET_NAME` VARCHAR(255),
`ZIP_CODE` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `Banker` (
`BANKER_ID` VARCHAR(255),
`BANKER_EMAIL` VARCHAR(255),
`FIRST_NAME` VARCHAR(255),
`LAST_NAME` VARCHAR(255),
`PHONE` VARCHAR(255),
`BRANCH_ID` VARCHAR(255),
PRIMARY KEY (`BANKER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`CUST_ID` DECIMAL(10,2),
`FIRST_NAME` VARCHAR(255),
`LAST_NAME` VARCHAR(255),
`STREET_NAME` VARCHAR(255),
`STREET_NO` VARCHAR(255),
`APT_NO` DECIMAL(10,2),
`EMAIL` VARCHAR(255),
`GENDER` VARCHAR(255),
`BIRTH_DATE` DATETIME,
`ZIP_CODE` VARCHAR(255),
`BANKER_ID` VARCHAR(255),
PRIMARY KEY (`CUST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHONES` (
`CUST_ID` DECIMAL(10,2),
`PHONE_NO` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNT` (
`ACCOUNT_NUMBER` VARCHAR(255),
`IBAN` VARCHAR(255),
`BALANCE` DECIMAL(10,2),
`OPEN_DATE` DATETIME,
`BRANCH_ID` VARCHAR(255),
`CUST_ID` DECIMAL(10,2),
`ACCOUNT_TYPE` DECIMAL(10,2),
PRIMARY KEY (`ACCOUNT_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `CARD` (
`CARD_ID` DECIMAL(10,2),
`CARD_TYPE` VARCHAR(255),
`PASSWORD` DECIMAL(10,2),
`EXPIRE_DATE` DATETIME,
`CVC` VARCHAR(255),
`ACCOUNT_NUMBER` VARCHAR(255),
PRIMARY KEY (`CARD_ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOAN` (
`LOAN_ID` DECIMAL(10,2),
`LOAN_TYPE` VARCHAR(255),
`AMOUNT` DECIMAL(10,2),
`DATE_OF_LOAN` DATETIME,
`DURATION` DECIMAL(10,2),
`BRANCH_ID` VARCHAR(255),
`CUST_ID` DECIMAL(10,2),
PRIMARY KEY (`LOAN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSACTION` (
`TRANSACTION_ID` DECIMAL(10,2),
`TRANSACTION_DATE` DATETIME,
`AMOUNT` DECIMAL(10,2),
`TRANSACTION_TYPE` VARCHAR(255),
`SENDER_ID` DECIMAL(10,2),
`RECEIVER_ID` DECIMAL(10,2),
`ACCOUNT_NUMBER` VARCHAR(255),
PRIMARY KEY (`TRANSACTION_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_456624_BankDatabase') AS relationships;
relationships
Database: db_456624_BankDatabase

