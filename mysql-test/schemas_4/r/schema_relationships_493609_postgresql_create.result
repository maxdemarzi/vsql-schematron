[Implied]  ebms_message.cpa_id -> cpa.cpa_id
[Implied]  ebms_message_event.message_id -> ebms_message.message_id

DROP DATABASE `db_493609_postgresql_create`;
UNINSTALL EXTENSION vsql_schematron;
