INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 493609_postgresql_create
#
CREATE DATABASE `db_493609_postgresql_create`;
USE `db_493609_postgresql_create`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(64),
`cpa` VARCHAR(64),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `url` (
`source` VARCHAR(64),
`destination` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`time_stamp` DATETIME,
`cpa_id` VARCHAR(64),
`conversation_id` VARCHAR(64),
`message_id` VARCHAR(64),
`message_nr` INT,
`ref_to_message_id` VARCHAR(64),
`time_to_live` DATETIME,
`persist_time` DATETIME,
`from_party_id` VARCHAR(64),
`from_role` VARCHAR(64),
`to_party_id` VARCHAR(64),
`to_role` VARCHAR(64),
`service` VARCHAR(64),
`action` VARCHAR(64),
`content` VARCHAR(64),
`status` INT,
`status_time` DATETIME,
PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`message_id` VARCHAR(64),
`message_nr` INT,
`order_nr` INT,
`name` VARCHAR(64),
`content_id` VARCHAR(64),
`content_type` VARCHAR(64),
`content` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event` (
`cpa_id` VARCHAR(64),
`client_alias` VARCHAR(64),
`channel_id` VARCHAR(64),
`message_id` VARCHAR(64),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`is_confidential` VARCHAR(64),
`retries` INT,
`server_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event_log` (
`message_id` VARCHAR(64),
`time_stamp` DATETIME,
`uri` VARCHAR(64),
`status` INT,
`error_message` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message_event` (
`message_id` VARCHAR(64),
`event_type` INT,
`time_stamp` DATETIME,
`processed` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_493609_postgresql_create') AS relationships;
relationships
