INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 439845_ddl
#
CREATE DATABASE `db_439845_ddl`;
USE `db_439845_ddl`;
CREATE TABLE `Game` (
`game_id` INT NOT NULL,
`turn_number` INT,
`grid_number` INT,
`user_name` TEXT,
`win` INT,
PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `Fighter` (
`fighter_id` INT NOT NULL,
`name` TEXT,
`strength` INT,
`ship_id` INT,
PRIMARY KEY (`fighter_id`)
) CHARACTER SET latin1;
CREATE TABLE `Ship` (
`ship_id` INT NOT NULL,
`strength` INT,
`position` INT,
`game_id` INT,
`name` INT,
`type` INT,
PRIMARY KEY (`ship_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_439845_ddl') AS relationships;
