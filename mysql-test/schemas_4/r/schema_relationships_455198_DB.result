INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 455198_DB
#
CREATE DATABASE `db_455198_DB`;
USE `db_455198_DB`;
CREATE TABLE `Shops` (
`shop_id` INT NOT NULL,
`adress` VARCHAR(50),
`shop_name` VARCHAR(50),
PRIMARY KEY (`shop_id`)
) CHARACTER SET latin1;
CREATE TABLE `Med_groups` (
`group_id` INT NOT NULL,
`group_name` VARCHAR(50),
PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `Medicine` (
`med_id` INT NOT NULL,
`group_id` INT,
`med_name` VARCHAR(50),
PRIMARY KEY (`med_id`)
) CHARACTER SET latin1;
CREATE TABLE `Availability` (
`id` INT NOT NULL,
`shop_id` INT,
`med_id` INT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
`emp_id` INT NOT NULL,
`shop_id` INT,
`emp_name` VARCHAR(50),
`position` VARCHAR(50),
PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
CREATE TABLE `Sales` (
`sale_id` INT NOT NULL,
`shop_id` INT,
`med_id` INT,
`price` DOUBLE,
`sale_date` VARCHAR(50),
PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_455198_DB') AS relationships;
relationships
Database: db_455198_DB

Table Connections:
------------------
[Implied]  Availability.med_id -> Medicine.med_id
[Implied]  Availability.shop_id -> Shops.shop_id
[Implied]  Employees.shop_id -> Shops.shop_id
[Implied]  Medicine.group_id -> Med_groups.group_id
[Implied]  Sales.med_id -> Medicine.med_id
[Implied]  Sales.shop_id -> Shops.shop_id

DROP DATABASE `db_455198_DB`;
UNINSTALL EXTENSION vsql_schematron;
