CREATE TABLE `shareas` (
`id` VARCHAR(50) NOT NULL,
`creator_id` VARCHAR(50),
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `medias` (
`id` VARCHAR(50) NOT NULL,
`sharea_id` VARCHAR(50),
`creator_id` VARCHAR(50),
`name` VARCHAR(50),
`type` VARCHAR(50),
`content` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media_like` (
`id` VARCHAR(50) NOT NULL,
`media_id` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
