INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 499217_reviewersMovie
#
CREATE DATABASE `db_499217_reviewersMovie`;
USE `db_499217_reviewersMovie`;
CREATE TABLE `reviewer` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`release_year` INT,
`genre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT NOT NULL,
`rating` DECIMAL(10,2),
`series_id` INT,
`reviewer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_499217_reviewersMovie') AS relationships;
relationships
