) CHARACTER SET latin1;
CREATE TABLE `subject_teachers` (
`id` BIGINT NOT NULL,
`subjectid` BIGINT,
`departmentid` BIGINT,
`teacherid` BIGINT,
`year` VARCHAR(50),
`semester` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
