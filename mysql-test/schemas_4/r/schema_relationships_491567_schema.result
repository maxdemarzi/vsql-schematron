INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 491567_schema
#
CREATE DATABASE `db_491567_schema`;
USE `db_491567_schema`;
CREATE TABLE `requirement_sets` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`filename` VARCHAR(64),
`placement_order` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `requirement_set_metadata` (
`id` VARCHAR(64),
`key` VARCHAR(64),
`value` VARCHAR(64),
`placement_order` INT,
PRIMARY KEY (`id`, `key`)
) CHARACTER SET latin1;
CREATE TABLE `requirements` (
`set_id` VARCHAR(64),
`id` VARCHAR(64),
`key` VARCHAR(64),
`value` VARCHAR(64),
`placement_order` INT,
PRIMARY KEY (`set_id`, `id`, `key`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
`from_set_id` VARCHAR(64),
`from_id` VARCHAR(64),
`to_set_id` VARCHAR(64),
`to_id` VARCHAR(64),
`placement_order` INT,
PRIMARY KEY (`from_set_id`, `from_id`, `to_set_id`, `to_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_491567_schema') AS relationships;
