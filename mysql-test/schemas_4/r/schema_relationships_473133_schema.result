INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 473133_schema
#
CREATE DATABASE `db_473133_schema`;
USE `db_473133_schema`;
CREATE TABLE `item` (
`id` INT NOT NULL,
`owner_id` VARCHAR(50),
`price` INT,
`place` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player` (
`id` VARCHAR(50) NOT NULL,
`credits` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
`id` INT NOT NULL,
`player_id` VARCHAR(50),
`created` DATETIME,
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_473133_schema') AS relationships;
