) CHARACTER SET latin1;
CREATE TABLE `Post` (
`id` INT NOT NULL,
`title` TEXT,
`blogId` INT,
`status` VARCHAR(50),
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`id` INT NOT NULL,
`value` TEXT,
`postId` INT,
