CREATE DATABASE `db_403839_Oracle4Quartz`;
USE `db_403839_Oracle4Quartz`;
CREATE TABLE `AIDEV_QRTZ_JOB_DETAILS` (
`sched_name` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`description` VARCHAR(64),
`job_class_name` VARCHAR(64),
`is_durable` VARCHAR(64),
