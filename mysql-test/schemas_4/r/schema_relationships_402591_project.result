CREATE DATABASE `db_402591_project`;
USE `db_402591_project`;
CREATE TABLE `company` (
`Id` INT,
`Name` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `educationalbackground` (
`Id` INT,
`UserId` INT,
`Field` VARCHAR(64),
`University` VARCHAR(64),
`Grade` INT,
`FromDate` VARCHAR(64),
`ToDate` VARCHAR(64),
`Activity` INT
) CHARACTER SET latin1;
CREATE TABLE `personalinformation` (
`Id` INT,
`UserId` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`FirstNameEn` VARCHAR(64),
`LastNameEn` VARCHAR(64),
`Email` VARCHAR(64),
`Mobile` INT,
`Gender` INT,
`MaritalStatus` INT,
`Born` VARCHAR(64),
`City` INT,
`Address` VARCHAR(64),
`MilitaryService` INT
) CHARACTER SET latin1;
CREATE TABLE `skills` (
`Id` INT,
`UserId` INT,
`Name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `socialnetwork` (
`Id` INT,
`UserId` INT,
`Category` INT,
`NetworkId` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`Id` INT,
`UserName` VARCHAR(64),
`Password` VARCHAR(64),
`Status` INT,
`ReferralCode` VARCHAR(64),
`MyReferralCode` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `workexperience` (
`Id` INT,
`UserId` INT,
`JobTitle` VARCHAR(64),
`Company` VARCHAR(64),
`FromDate` VARCHAR(64),
`ToDate` VARCHAR(64),
`Description` VARCHAR(64),
`Activity` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_402591_project') AS relationships;
