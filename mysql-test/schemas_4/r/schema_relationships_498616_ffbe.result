`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialisations` (
`id` INT,
`name` VARCHAR(255),
`stats` VARCHAR(255),
`team_pick_order` INT,
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `units` (
`id` INT,
`name` VARCHAR(255),
