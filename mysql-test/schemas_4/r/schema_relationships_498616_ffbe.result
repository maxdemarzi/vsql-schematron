`image` VARCHAR(255),
`image_dir` VARCHAR(255),
`hp` INT,
`mp` INT,
`atk` INT,
`def` INT,
`mag` INT,
`spr` INT,
`hits` INT,
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
`role` VARCHAR(255),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
