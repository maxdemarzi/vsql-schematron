`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
`id` INT,
`name` VARCHAR(255),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `origins` (
`id` INT,
`name` VARCHAR(255),
`shortname` VARCHAR(255),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phinxlog` (
`version` INT,
`migration_name` VARCHAR(255),
`start_time` DATETIME,
`end_time` DATETIME,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `practises` (
`id` INT,
`unit_id` INT,
`specialisation_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `races` (
`id` INT,
