CREATE TABLE `users` (
`user_id` INT,
`full_name` VARCHAR(64),
`graduating_year` INT,
`graduating_semester` VARCHAR(64),
`major` VARCHAR(64),
`pw_hash` VARCHAR(64),
`username` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`role_name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `role_assignments` (
`user_id` INT,
`role_name` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
