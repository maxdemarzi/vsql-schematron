`address` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BA_EMPLOYEES_CASH` (
`id` INT,
`emid` INT,
`opid` INT,
