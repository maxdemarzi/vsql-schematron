[Implied]  events.location_id -> locations.id
[Implied]  movies.location_id -> locations.id
[Implied]  restaurants.location_id -> locations.id
[Implied]  weathers.location_id -> locations.id

DROP DATABASE `db_485383_schema`;
UNINSTALL EXTENSION vsql_schematron;
