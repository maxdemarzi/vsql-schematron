INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 449228_schema
#
CREATE DATABASE `db_449228_schema`;
USE `db_449228_schema`;
CREATE TABLE `User` (
`UID` INT,
`Username` VARCHAR(64),
`Salt` VARCHAR(64),
`Password` VARCHAR(64),
PRIMARY KEY (`UID`)
) CHARACTER SET latin1;
CREATE TABLE `List` (
`LID` INT,
`UID` INT,
`Listname` VARCHAR(64),
PRIMARY KEY (`LID`)
) CHARACTER SET latin1;
CREATE TABLE `Element` (
`ELD` INT,
`LID` INT,
`Title` VARCHAR(64),
`StartDate` DATETIME,
`DeadLine` DATETIME,
`Status` BOOL,
PRIMARY KEY (`ELD`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_449228_schema') AS relationships;
