`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`note_id`)
) CHARACTER SET latin1;
CREATE TABLE `pur_detail_notes` (
`note_id` INT,
`pur_detail_id` INT,
`note_type_id` INT,
`seq` INT,
`note_text` VARCHAR(64),
`rev_enabled` VARCHAR(64),
`rev_number` INT,
`created_by` INT,
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`note_id`)
) CHARACTER SET latin1;
