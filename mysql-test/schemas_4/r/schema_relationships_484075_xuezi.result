[Implied]  xz_order_detail.product_id -> xz_index_product.pid
[Implied]  xz_receiver_address.user_id -> xz_user.uid
[Implied]  xz_shopping_cart.product_id -> xz_index_product.pid
[Implied]  xz_shopping_cart.user_id -> xz_user.uid

DROP DATABASE `db_484075_xuezi`;
UNINSTALL EXTENSION vsql_schematron;
