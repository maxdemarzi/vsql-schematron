INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 484075_xuezi
#
CREATE DATABASE `db_484075_xuezi`;
USE `db_484075_xuezi`;
CREATE TABLE `xz_laptop_family` (
`fid` INT,
`name` VARCHAR(64),
PRIMARY KEY (`fid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_laptop` (
`lid` INT,
`family_id` INT,
`title` VARCHAR(64),
`subtitle` VARCHAR(64),
`price` DECIMAL(10,2),
`promise` VARCHAR(64),
`spec` VARCHAR(64),
`name` VARCHAR(64),
`os` VARCHAR(64),
`memory` VARCHAR(64),
`resolution` VARCHAR(64),
`video_card` VARCHAR(64),
`cpu` VARCHAR(64),
`video_memory` VARCHAR(64),
`category` VARCHAR(64),
`disk` VARCHAR(64),
`details` VARCHAR(64),
`shelf_time` INT,
`sold_count` INT,
`is_onsale` INT,
PRIMARY KEY (`lid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_laptop_pic` (
`pic` INT,
`laptop_id` INT,
`sm` VARCHAR(64),
`md` VARCHAR(64),
`lg` VARCHAR(64),
PRIMARY KEY (`pic`)
) CHARACTER SET latin1;
CREATE TABLE `xz_user` (
`uid` INT,
`name` VARCHAR(64),
`upwd` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`avatar` VARCHAR(64),
`user_name` VARCHAR(64),
`gender` INT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_receiver_address` (
`aid` INT,
`user_id` INT,
`receiver` VARCHAR(64),
`province` VARCHAR(64),
`city` VARCHAR(64),
`county` VARCHAR(64),
`address` VARCHAR(64),
`cellphone` VARCHAR(64),
`fixedphone` VARCHAR(64),
`postcode` VARCHAR(64),
`tag` VARCHAR(64),
`is_default` INT,
PRIMARY KEY (`aid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_shopping_cart` (
`cid` INT,
`user_id` INT,
`product_id` INT,
`count` INT,
PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_order` (
`oid` INT,
`user_id` INT,
`address_id` INT,
`status` INT,
`order_time` INT,
`pay_time` INT,
`deliver_time` INT,
`received_time` INT,
PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_order_detail` (
`did` INT,
`order_id` INT,
`product_id` INT,
`count` INT,
PRIMARY KEY (`did`)
) CHARACTER SET latin1;
CREATE TABLE `xz_carousel` (
`cid` INT,
`img` VARCHAR(64),
`title` VARCHAR(64),
`href` VARCHAR(64),
PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `xz_index_product` (
`pid` INT,
`title` VARCHAR(64),
`details` VARCHAR(64),
`pic` VARCHAR(64),
`price` DECIMAL(10,2),
`href` VARCHAR(64),
`seq_recommended` INT,
`seq_new_arrival` INT,
`seq_top_sale` INT,
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_484075_xuezi') AS relationships;
relationships
Database: db_484075_xuezi

Table Connections:
