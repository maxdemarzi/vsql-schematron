INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 416186_seed
#
CREATE DATABASE `db_416186_seed`;
USE `db_416186_seed`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`nickname` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_416186_seed') AS relationships;
relationships
Database: db_416186_seed

Table Connections:
