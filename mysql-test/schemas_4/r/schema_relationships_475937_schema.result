INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 475937_schema
#
CREATE DATABASE `db_475937_schema`;
USE `db_475937_schema`;
CREATE TABLE `T_USER` (
`ID` INT,
`CREATED_AT` DATETIME,
`EMAIL` VARCHAR(64),
`ENABLED` BOOL,
`LOCKED` BOOL,
`PASSWORD` VARCHAR(64),
`USER_ROLE` VARCHAR(64),
`USERNAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_COMMUNITY` (
`ID` INT,
`CREATED_AT` DATETIME,
`DESCRIPTION` VARCHAR(64),
`NAME` VARCHAR(64),
`CREATED_BY_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_CONFIRMATION_TOKEN` (
`ID` INT,
`CONFIRMED_AT` DATETIME,
`CREATED_AT` DATETIME,
`EXPIRES_AT` DATETIME,
`TOKEN` VARCHAR(64),
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_POST` (
`ID` INT,
`BODY` VARCHAR(64),
`CREATED_AT` DATETIME,
`TITLE` VARCHAR(64),
`URL` VARCHAR(64),
`VOTE_COUNT` INT,
`COMMUNITY_ID` INT,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_COMMENT` (
`ID` INT,
`BODY` VARCHAR(64),
`CREATED_AT` DATETIME,
`POST_ID` INT,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_USER_COMMUNITY` (
`USER_ID` INT,
`COMMUNITY_ID` INT,
PRIMARY KEY (`USER_ID`, `COMMUNITY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_VOTE` (
`ID` INT,
`VOTE_TYPE` VARCHAR(64),
`POST_ID` INT,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_475937_schema') AS relationships;
