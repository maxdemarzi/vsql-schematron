CREATE DATABASE `db_447112_taksi_schema`;
USE `db_447112_taksi_schema`;
CREATE TABLE `personel` (
`ssn` VARCHAR(64),
`ad` VARCHAR(64),
`soyad` VARCHAR(64),
`dogum_tarihi` DATETIME,
`maas` INT,
`kan_grubu` VARCHAR(64),
`arac_plaka` VARCHAR(64),
`superssn` VARCHAR(64),
PRIMARY KEY (`ssn`)
) CHARACTER SET latin1;
CREATE TABLE `araclar` (
`plaka_no` VARCHAR(64),
`marka` VARCHAR(64),
`model` VARCHAR(64),
`kayit_tarihi` DATETIME,
`sofor_id` VARCHAR(64),
PRIMARY KEY (`plaka_no`)
) CHARACTER SET latin1;
CREATE TABLE `musteriler` (
`tc` VARCHAR(64),
`ad` VARCHAR(64),
`soyad` VARCHAR(64),
`adres` VARCHAR(64),
`cinsiyet` VARCHAR(64),
`toplam_yolculuk_sayisi` INT,
PRIMARY KEY (`tc`)
) CHARACTER SET latin1;
CREATE TABLE `yolculuk` (
`yolculuk_id` INT,
`baslangic` VARCHAR(64),
`bitis` VARCHAR(64),
`tutar` INT,
`arac_plaka` VARCHAR(64),
`musteri_id` VARCHAR(64),
`sofor_id` VARCHAR(64),
PRIMARY KEY (`yolculuk_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_447112_taksi_schema') AS relationships;
