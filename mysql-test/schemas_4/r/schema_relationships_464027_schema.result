INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 464027_schema
#
CREATE DATABASE `db_464027_schema`;
USE `db_464027_schema`;
CREATE TABLE `owners` (
`id` INT,
`full_name` VARCHAR(64),
`age` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `species` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vets` (
`id` INT,
`name` VARCHAR(64),
`age` INT,
`date_of_graduation` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specializations` (
`vets_id` INT,
`species_id` INT,
PRIMARY KEY (`vets_id`, `species_id`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
`vets_id` INT,
`animals_id` INT,
`date_of_visit` DATETIME,
PRIMARY KEY (`vets_id`, `animals_id`, `date_of_visit`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_464027_schema') AS relationships;
