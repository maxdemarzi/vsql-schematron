CREATE DATABASE `db_476540_V001__create_tables_for_territory_and_initial_load`;
USE `db_476540_V001__create_tables_for_territory_and_initial_load`;
CREATE TABLE `province` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `district` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`status` INT,
`province_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `administrative_post` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`status` INT,
`district_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locality` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`status` INT,
`administrative_post_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
