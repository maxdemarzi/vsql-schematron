CREATE TABLE `mailer_template` (
`id` VARCHAR(64),
`version` VARCHAR(64),
`space_id` VARCHAR(64),
`is_active` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
`title` VARCHAR(64),
`language` VARCHAR(64),
`body_html` VARCHAR(64),
`body_text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mailer_template_stream` (
`id` VARCHAR(64),
`template_id` VARCHAR(64),
`user_id` VARCHAR(64),
`key` VARCHAR(64),
`payload` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
