[Implied]  E_AVALIADO.RA_ALUNO -> ALUNO.RA_ALUNO
[Implied]  OFERECIDA.COD_DISCIPLINA -> DISCIPLINA.COD_DISCIPLINA
[Implied]  OFERECIDA.MATRICULA_PROF -> PROFESSOR.MATRICULA_PROF

DROP DATABASE `db_441793_CRIACAO_TABELAS`;
UNINSTALL EXTENSION vsql_schematron;
