`BookID` INT,
`StartDate` DATETIME,
`DueDate` DATETIME,
`PickedUp` INT,
`Late` INT,
`Lost` INT,
`Active` INT,
PRIMARY KEY (`ReportID`)
) CHARACTER SET latin1;
