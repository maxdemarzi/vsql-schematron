CREATE DATABASE `db_494982_1__20People_Table`;
USE `db_494982_1__20People_Table`;
CREATE TABLE `people` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`DOB` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`amount` DECIMAL(10,2),
`person_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
`id` INT NOT NULL,
`person_id` INT,
`address` TEXT,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_494982_1__20People_Table') AS relationships;
