INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 464779_init_products
#
CREATE DATABASE `db_464779_init_products`;
USE `db_464779_init_products`;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`slogan` VARCHAR(64),
`description` VARCHAR(64),
`category` VARCHAR(64),
`default_price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `features` (
`id` INT,
`product_id` INT,
`feature` VARCHAR(64),
`value` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
`style_id` INT,
`product_id` INT,
`name` VARCHAR(64),
`sale_price` VARCHAR(64),
`original_price` VARCHAR(64),
`default_style` VARCHAR(64),
PRIMARY KEY (`style_id`)
) CHARACTER SET latin1;
CREATE TABLE `skus` (
`id` INT,
`styleId` INT,
`size` VARCHAR(64),
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT,
`styleId` INT,
`url` VARCHAR(64),
`thumbnail_url` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `related` (
`id` INT,
`current_product_id` INT,
`related_product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_464779_init_products') AS relationships;
relationships
Database: db_464779_init_products

Table Connections:
------------------
[Implied]  features.product_id -> products.id
[Implied]  photos.styleId -> styles.style_id
[Implied]  related.current_product_id -> products.id
[Implied]  related.related_product_id -> products.id
[Implied]  skus.styleId -> styles.style_id
[Implied]  styles.product_id -> products.id

DROP DATABASE `db_464779_init_products`;
UNINSTALL EXTENSION vsql_schematron;
