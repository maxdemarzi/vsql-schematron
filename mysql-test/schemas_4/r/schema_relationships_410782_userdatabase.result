CREATE DATABASE `db_410782_userdatabase`;
USE `db_410782_userdatabase`;
CREATE TABLE `chatUser` (
`id` INT NOT NULL,
`userName` TEXT,
`tgID` INT,
`pingAllowed` TINYINT,
`MarkovAskAllowed` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aliases` (
`id` INT NOT NULL,
`name` TEXT,
`userID` INT,
`changeDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `warning` (
`id` INT NOT NULL,
`userID` INT,
`warningText` TEXT,
`warnDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_410782_userdatabase') AS relationships;
