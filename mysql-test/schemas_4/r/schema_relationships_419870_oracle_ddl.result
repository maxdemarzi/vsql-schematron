INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 419870_oracle_ddl
#
CREATE DATABASE `db_419870_oracle_ddl`;
USE `db_419870_oracle_ddl`;
CREATE TABLE `ENCRYPTED_TRANSACTION` (
`ENCODED_PAYLOAD` VARCHAR(255),
`HASH` VARCHAR(255),
`TIMESTAMP` DECIMAL(10,2),
PRIMARY KEY (`HASH`)
) CHARACTER SET latin1;
CREATE TABLE `ENCRYPTED_RAW_TRANSACTION` (
`ENCRYPTED_KEY` VARCHAR(255),
`ENCRYPTED_PAYLOAD` VARCHAR(255),
`NONCE` VARCHAR(255),
`SENDER` VARCHAR(255),
`TIMESTAMP` DECIMAL(10,2),
`HASH` VARCHAR(255),
PRIMARY KEY (`HASH`)
) CHARACTER SET latin1;
CREATE TABLE `PRIVACY_GROUP` (
`ID` VARCHAR(255),
`LOOKUP_ID` VARCHAR(255),
`DATA` VARCHAR(255),
`TIMESTAMP` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ST_TRANSACTION` (
`ID` DECIMAL(10,2),
`HASH` VARCHAR(255),
`PAYLOAD` VARCHAR(255),
`PRIVACY_MODE` INT,
`TIMESTAMP` DECIMAL(10,2),
`VALIDATION_STAGE` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ST_AFFECTED_TRANSACTION` (
`ID` DECIMAL(10,2),
`AFFECTED_HASH` VARCHAR(255),
`TXN_ID` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_419870_oracle_ddl') AS relationships;
relationships
