INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 471585_events
#
CREATE DATABASE `db_471585_events`;
USE `db_471585_events`;
CREATE TABLE `user_info` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`website` VARCHAR(64),
`profileimg` VARCHAR(64),
`bio` VARCHAR(64),
`gender` INT,
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `institution` (
`id` INT,
`name` VARCHAR(64),
`emblem` VARCHAR(64),
`description` VARCHAR(64),
`address` VARCHAR(64),
`gmap_location` VARCHAR(64),
`website_url` VARCHAR(64),
`institution_category` VARCHAR(64),
`country` VARCHAR(64),
`state` VARCHAR(64),
`city` INT,
`postal_code` VARCHAR(64),
`facebook` VARCHAR(64),
`linkedin` VARCHAR(64),
`twitter` VARCHAR(64),
`google` VARCHAR(64),
`status` VARCHAR(64),
`created_at` DATETIME,
`modified_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event_type` (
`id` INT,
`name` VARCHAR(64),
`name_code` VARCHAR(64),
`category` VARCHAR(64),
`category_code` VARCHAR(64),
`status` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `symposium` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`mobile_description` VARCHAR(64),
`logo` VARCHAR(64),
`banner` VARCHAR(64),
`url_key` VARCHAR(64),
`contact_info` VARCHAR(64),
`event_from` DATETIME,
`event_to` DATETIME,
`allowed_users` INT,
`address` VARCHAR(64),
`website` VARCHAR(64),
`gmap_location` VARCHAR(64),
`status` VARCHAR(64),
`user_id` INT,
`institution_id` INT,
`event_type` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`contact_us` VARCHAR(64),
`event_from` DATETIME,
`event_to` DATETIME,
`sym_id` INT,
`allowed_users` INT,
`status` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subscribers` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`phone_no` VARCHAR(64),
`institution_id` INT,
`program_id` INT,
`event_ids` VARCHAR(64),
`event_type` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hsm_admin` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`status` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_471585_events') AS relationships;
