INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 455647_database
#
CREATE DATABASE `db_455647_database`;
USE `db_455647_database`;
CREATE TABLE `chefs` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT,
`name` VARCHAR(64),
`path` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_files` (
`id` INT,
`recipe_id` INT,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`reset_token` VARCHAR(64),
`reset_token_expires` VARCHAR(64),
`is_admin` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_455647_database') AS relationships;
