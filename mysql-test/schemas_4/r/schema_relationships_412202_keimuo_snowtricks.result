INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 412202_keimuo_snowtricks
#
CREATE DATABASE `db_412202_keimuo_snowtricks`;
USE `db_412202_keimuo_snowtricks`;
CREATE TABLE `comment` (
`id` INT,
`trick_id` INT,
`content` VARCHAR(255),
`add_date` DATETIME,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `migration_versions` (
`version` VARCHAR(255),
`executed_at` DATETIME,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `picture` (
`id` INT,
`trick_id` INT,
`name` VARCHAR(255),
`statut` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
`id` INT,
`image_name` VARCHAR(255),
`updated_at` DATETIME,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `trick` (
`id` INT,
`name` VARCHAR(255),
`content` VARCHAR(255),
`category` VARCHAR(255),
`date_post` DATETIME,
`date_update` DATETIME,
`main_picture` VARCHAR(255),
`slug` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `video` (
`id` INT,
`trick_id` INT,
`url` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_412202_keimuo_snowtricks') AS relationships;
relationships
