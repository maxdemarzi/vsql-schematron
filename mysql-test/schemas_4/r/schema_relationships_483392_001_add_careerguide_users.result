`job_id` INT,
`type` VARCHAR(64),
`time_stamp` DATETIME,
PRIMARY KEY (`user_id`, `job_id`)
) CHARACTER SET latin1;
CREATE TABLE `pontoonapps_careerguide.shortlists` (
`user_id` INT,
`job_id` INT,
`time_stamp` DATETIME,
PRIMARY KEY (`user_id`, `job_id`)
) CHARACTER SET latin1;
CREATE TABLE `pontoonapps_careerguide.answers` (
`user_id` INT,
`question_id` INT,
`option_number` INT,
`time_stamp` DATETIME,
PRIMARY KEY (`user_id`, `question_id`)
) CHARACTER SET latin1;
