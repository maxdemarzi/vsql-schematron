INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 466808_snapshot_0
#
CREATE DATABASE `db_466808_snapshot_0`;
USE `db_466808_snapshot_0`;
CREATE TABLE `mes_types` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`x_par` VARCHAR(64),
`y_par` VARCHAR(64),
`t_par` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `robots` (
`id` INT,
`user_id` INT,
`ip_address` VARCHAR(64),
`port` VARCHAR(64),
`topic_id` INT
) CHARACTER SET latin1;
CREATE TABLE `topics` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`mes_id` INT,
`max_x` DECIMAL(10,2),
`min_x` DECIMAL(10,2),
`max_y` DECIMAL(10,2),
`min_y` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`activation_code` VARCHAR(64),
`activated` INT,
`forgotten_password_code` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_466808_snapshot_0') AS relationships;
