INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 466284_cyf-data
#
CREATE DATABASE `db_466284_cyf_data`;
USE `db_466284_cyf_data`;
CREATE TABLE `region` (
`id` INT,
`location` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`roles_id` INT,
`region_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`token` VARCHAR(64),
`users_id` INT,
`creation_date` DATETIME,
PRIMARY KEY (`token`)
) CHARACTER SET latin1;
CREATE TABLE `techskills` (
`id` INT,
`lessons` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `learningobjectives` (
`id` INT,
`objectives` VARCHAR(64),
`lesson_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `competencylevels` (
`id` INT,
`competency` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mappingskills` (
`id` INT,
`users_id` INT,
`obj_id` INT,
`comp_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_466284_cyf_data') AS relationships;
relationships
Database: db_466284_cyf_data

Table Connections:
------------------
[Implied]  mappingskills.comp_id -> competencylevels.id
[Implied]  mappingskills.users_id -> users.id
[Implied]  tokens.users_id -> users.id
[Implied]  users.region_id -> region.id
[Implied]  users.roles_id -> roles.id

DROP DATABASE `db_466284_cyf_data`;
UNINSTALL EXTENSION vsql_schematron;
