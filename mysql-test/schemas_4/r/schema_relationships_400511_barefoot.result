[Implied]  comments.user_id -> users.id
[Implied]  posts.category_id -> categories.id
[Implied]  posts.user_id -> users.id
[Implied]  posts_likes.post_id -> posts.id
[Implied]  posts_likes.user_id -> users.id
[Implied]  posts_tags.post_id -> posts.id
[Implied]  posts_tags.tag_id -> tags.id
[Implied]  socials.user_id -> users.id

DROP DATABASE `db_400511_barefoot`;
UNINSTALL EXTENSION vsql_schematron;
