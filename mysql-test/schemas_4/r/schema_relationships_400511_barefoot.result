INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 400511_barefoot
#
CREATE DATABASE `db_400511_barefoot`;
USE `db_400511_barefoot`;
CREATE TABLE `bookmarks` (
`id` INT,
`user_id` INT,
`post_id` INT
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`name` VARCHAR(64),
`slug` VARCHAR(64),
`icon` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`user_id` INT,
`post_id` INT,
`comment` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`user_id` INT,
`title` VARCHAR(64),
`slug` VARCHAR(64),
`reading_time` INT,
`youtube_url` VARCHAR(64),
`category_id` INT,
`image` VARCHAR(64),
`body` VARCHAR(64),
`is_published` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts_likes` (
`id` INT,
`user_id` INT,
`post_id` INT,
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts_tags` (
`id` INT,
`post_id` INT,
`tag_id` INT,
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `socials` (
`id` INT,
`user_id` INT,
`facebook` VARCHAR(64),
`instagram` VARCHAR(64),
`twitter` VARCHAR(64),
`youtube` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`verified` INT,
`token` VARCHAR(64),
`password` VARCHAR(64),
`profile_image` VARCHAR(64),
`banner_title` VARCHAR(64),
`banner_image` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_400511_barefoot') AS relationships;
relationships
Database: db_400511_barefoot

