CREATE DATABASE `db_456945_V1_ddl`;
USE `db_456945_V1_ddl`;
CREATE TABLE `user` (
`usr_id` INT,
`usr_username` VARCHAR(255),
`usr_name` VARCHAR(255),
`usr_password` VARCHAR(255),
PRIMARY KEY (`usr_id`)
) CHARACTER SET latin1;
CREATE TABLE `folder` (
`fol_id` INT,
`fol_name` VARCHAR(255),
`fol_usr_id` INT,
PRIMARY KEY (`fol_id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
`tak_id` INT,
`tak_order` INT,
`tak_text` VARCHAR(255),
`tak_done` VARCHAR(255),
`tak_fol_id` INT,
PRIMARY KEY (`tak_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_456945_V1_ddl') AS relationships;
