CREATE DATABASE `db_487488_V1_0_2_blog`;
USE `db_487488_V1_0_2_blog`;
CREATE TABLE `user_table` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`profile` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogpost` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`tags` VARCHAR(64),
`status` INT,
`create_time` INT,
`update_time` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ccomment` (
`id` INT,
`content` VARCHAR(64),
`status` INT,
`create_time` INT,
`author` VARCHAR(64),
`email` VARCHAR(64),
`url` VARCHAR(64),
`post_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag_table` (
`id` INT,
`name` VARCHAR(64),
`frequency` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `preferences` (
`id` INT,
`locale` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_487488_V1_0_2_blog') AS relationships;
