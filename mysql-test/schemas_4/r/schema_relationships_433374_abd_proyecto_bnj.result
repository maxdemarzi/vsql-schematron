`cantidad` INT,
`subvencionado` VARCHAR(64),
`id_remesa` INT,
`estado` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `seccion` (
`nombre` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tutores` (
`nombre_completo` VARCHAR(64),
`email` VARCHAR(64),
`dni` VARCHAR(64),
`telefono` INT,
`numero_cuenta` VARCHAR(64)
) CHARACTER SET latin1;
