`seccion` VARCHAR(64),
`dni_monitor` VARCHAR(64),
`cargo` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `remesa` (
