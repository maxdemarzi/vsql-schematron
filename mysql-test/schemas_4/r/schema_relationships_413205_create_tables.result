INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 413205_create_tables
#
CREATE DATABASE `db_413205_create_tables`;
USE `db_413205_create_tables`;
CREATE TABLE `account` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `card` (
`id` INT,
`card_type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
`id` INT,
`status` VARCHAR(64),
`weapon_id` INT,
`suspect_id` INT,
`room_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player` (
`id` INT,
`account_id` INT,
`game_id` INT,
`number` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player_card` (
`player_id` INT,
`card_id` INT
) CHARACTER SET latin1;
CREATE TABLE `move` (
`id` INT,
`player_id` INT,
`number` INT,
`location` INT,
`weapon_id` INT,
`suspect_id` INT,
`room_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_413205_create_tables') AS relationships;
relationships
Database: db_413205_create_tables

Table Connections:
------------------
[Implied]  move.player_id -> player.id
[Implied]  player.account_id -> account.id
[Implied]  player.game_id -> game.id
[Implied]  player_card.card_id -> card.id
[Implied]  player_card.player_id -> player.id

DROP DATABASE `db_413205_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
