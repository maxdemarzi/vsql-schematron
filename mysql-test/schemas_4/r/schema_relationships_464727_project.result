`date_of_birth` VARCHAR(64),
`address` VARCHAR(64),
`contact_num` VARCHAR(64),
`ZIP_code` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Plane` (
