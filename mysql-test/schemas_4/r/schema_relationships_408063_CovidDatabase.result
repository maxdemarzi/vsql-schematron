INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 408063_CovidDatabase
#
CREATE DATABASE `db_408063_CovidDatabase`;
USE `db_408063_CovidDatabase`;
CREATE TABLE `AGEGROUP` (
`ID_AGE_GROUP` INT,
`AGE_GROUP` VARCHAR(64),
PRIMARY KEY (`ID_AGE_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `APPROVALRATING` (
`ID_APPROVAL` INT,
`ID_RECORD` INT,
`APPROVAL_ESTIMATE` DECIMAL(10,2),
`APPROVAL_HIGH` DECIMAL(10,2),
`APPROVAL_LOW` DECIMAL(10,2),
`DATE` DATETIME,
PRIMARY KEY (`ID_APPROVAL`)
) CHARACTER SET latin1;
CREATE TABLE `BYGENDER` (
`ID_AGE_GROUP` INT,
`CODE` VARCHAR(64),
`GENDER` VARCHAR(64),
`REPORT_DATE` DATETIME,
`COVID_DEATHS_BY_GENDER` INT,
`TOTAL_DEATHS_BY_GENDER` INT,
PRIMARY KEY (`ID_AGE_GROUP`, `CODE`, `GENDER`)
) CHARACTER SET latin1;
CREATE TABLE `CITY` (
`ID_CITY` INT,
`CITY_NAME` VARCHAR(64),
PRIMARY KEY (`ID_CITY`)
) CHARACTER SET latin1;
CREATE TABLE `CONTINENT` (
`ID_CONTINENT` INT,
`CONTINENT_NAME` VARCHAR(64),
PRIMARY KEY (`ID_CONTINENT`)
) CHARACTER SET latin1;
CREATE TABLE `COUNTRY` (
`ISO` VARCHAR(64),
`ID_CONTINENT` INT,
`COUNTRY_NAME` VARCHAR(64),
`POPULATION` INT,
`POPULATION_DENSITY` DECIMAL(10,2),
`MEDIAN_AGE` DECIMAL(10,2),
`AGED_65_OR_OLDER` DECIMAL(10,2),
`AGED_70_OR_OLDER` DECIMAL(10,2),
`GDP_PER_CAPITA` DECIMAL(10,2),
`EXTREME_POVERTY` DECIMAL(10,2),
`CARDIO_VASC_DEATH_RATE` DECIMAL(10,2),
`DIABETES_PREVALENCE` DECIMAL(10,2),
`FEMALE_SMOKERS` DECIMAL(10,2),
`MALE_SMOKERS` DECIMAL(10,2),
`HANDWASHING_FACILITIES` DECIMAL(10,2),
`HOSPITAL_BEDS_PER_THOUSAND` DECIMAL(10,2),
`LIFE_EXPECTANCY` DECIMAL(10,2),
`HUMAN_DEVELOPMENT_INDEX` DECIMAL(10,2),
PRIMARY KEY (`ISO`)
) CHARACTER SET latin1;
CREATE TABLE `COUNTY` (
`FIPS` INT,
`CODE` VARCHAR(64),
`COUNTY_NAME` VARCHAR(64),
PRIMARY KEY (`FIPS`)
) CHARACTER SET latin1;
CREATE TABLE `COVID19` (
`ID_RECORD` INT,
`ID_CITY` INT,
`CODE` VARCHAR(64),
`FIPS` INT,
`ISO` VARCHAR(64),
`ID_APPROVAL` INT,
`REPRODUCTION_RATE` DECIMAL(10,2),
`NEW_TESTS` INT,
`NEW_TESTS_PER_THOUSAND` DECIMAL(10,2),
`TOTAL_TESTS` INT,
`TOTAL_TESTS_PER_THOUSAND` DECIMAL(10,2),
`NEW_TESTS_SMOOTHED` DECIMAL(10,2),
`NEW_TESTS_SMOOTHED_PER_THOUSAND` DECIMAL(10,2),
`POSITIVE_RATE` DECIMAL(10,2),
`TESTS_PER_CASE` DECIMAL(10,2),
`TESTS_UNIT` VARCHAR(64),
`TOTAL_VACCINATIONS` INT,
`TOTAL_VACCINATIONS_PER_HUNDRED` DECIMAL(10,2),
`STRINGENCY_INDEX` DECIMAL(10,2),
`NEW_CASES` DECIMAL(10,2),
`TOTAL_DEATHS__` DECIMAL(10,2),
`NEW_CASES_SMOOTHED` DECIMAL(10,2),
`TOTAL_CASES` DECIMAL(10,2),
`NEW_DEATHS` DECIMAL(10,2),
`NEW_DEATHS_SMOOTHED` DECIMAL(10,2),
`ICU_PATIENTS` DECIMAL(10,2),
`HOSP_PATIENTS` DECIMAL(10,2),
`WEEKLY_ICU_ADMISSIONS` DECIMAL(10,2),
`WEEKLY_HOSP_ADMISSIONS` DECIMAL(10,2),
`DATE` DATETIME,
PRIMARY KEY (`ID_RECORD`)
) CHARACTER SET latin1;
CREATE TABLE `HOSPITAL` (
`HOSPITAL_ID` INT,
`FIPS` INT,
`CODE` VARCHAR(64),
`ID_SEVERITY` INT,
`HOSPITAL_NAME` VARCHAR(64),
`TYPE` VARCHAR(64),
`ADDRESS` VARCHAR(64),
`CITY` VARCHAR(64),
`ZIP` VARCHAR(64),
`LICENCED_BEDS` INT,
`STAFFED_BEDS` INT,
`ICU_BEDS` INT,
`ADULT_ICU_BEDS` INT,
`PEDI_ICU_BEDS` INT,
`BED_UTILIZATION` DECIMAL(10,2),
`POTENTIAL` DECIMAL(10,2),
`AVG_VENTILATION_USE` DECIMAL(10,2),
`LAT` DECIMAL(10,2),
`LON` DECIMAL(10,2),
PRIMARY KEY (`HOSPITAL_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MEASURES` (
`MEASURE_ID` INT,
`CODE` VARCHAR(64),
`INDUSTRY` INT,
`PERSONAL_CARE` INT,
`ENTERTAINMENT` INT,
`OUTDOOR_RECREATION` INT,
`RETAIL` INT,
`HOUSE_OF_WORSHIP` INT,
`FOOD_DRINK` INT,
PRIMARY KEY (`MEASURE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SEVERITYPREDICTION` (
`ID_SEVERITY` INT,
`HOSPITAL_ID` INT,
`SEVERITY_1DAY` INT,
`SEVERITY_2DAY` INT,
`SEVERITY_3DAY` INT,
`SEVERITY_4DAY` INT,
`SEVERITY_5DAY` INT,
`SEVERITY_6DAY` INT,
`SEVERITY_7DAY` INT,
`LAT_HOSPITAL` DECIMAL(10,2),
`LON_HOSPITAL` DECIMAL(10,2),
PRIMARY KEY (`ID_SEVERITY`)
) CHARACTER SET latin1;
CREATE TABLE `STATE` (
`CODE` VARCHAR(64),
`ISO` VARCHAR(64),
`MEASURE_ID` INT,
`STATE_NAME` VARCHAR(64),
`POPULATION` INT,
`COVID_DEATHS` INT,
`TOTAL_DEATHS` INT,
PRIMARY KEY (`CODE`)
) CHARACTER SET latin1;
CREATE TABLE `UNEMPLOYMENT` (
`UNEMPLOYMENT_ID` INT,
`ISO` VARCHAR(64),
`UNEMPLOYMENT_DATE` DATETIME,
`VALUE` DECIMAL(10,2),
PRIMARY KEY (`UNEMPLOYMENT_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_408063_CovidDatabase') AS relationships;
