INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 426436_init
#
CREATE DATABASE `db_426436_init`;
USE `db_426436_init`;
CREATE TABLE `allyear` (
`yearID` INT,
PRIMARY KEY (`yearID`)
) CHARACTER SET latin1;
CREATE TABLE `taking` (
`takingID` INT,
`classID` INT,
`studentID` INT,
`state` BOOL,
PRIMARY KEY (`takingID`)
) CHARACTER SET latin1;
CREATE TABLE `Manager` (
`managerID` VARCHAR(64),
`PASSWORD` VARCHAR(64),
PRIMARY KEY (`managerID`)
) CHARACTER SET latin1;
CREATE TABLE `class` (
`classID` INT,
`courseID` INT,
`teacherID` INT,
`studentnum` INT,
`education` INT,
`grade` INT,
`start_year` INT,
`state` BOOL,
`order_number` INT,
`maxstudentnum` INT,
PRIMARY KEY (`classID`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`courseID` INT,
`coursename` VARCHAR(64),
`education` INT,
`price` DECIMAL(10,2),
`state` BOOL,
PRIMARY KEY (`courseID`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`studentID` INT,
`NAME` VARCHAR(64),
`education` INT,
`birthday` DATETIME,
`sex` VARCHAR(64),
`state` BOOL,
`PASSWORD` VARCHAR(64),
PRIMARY KEY (`studentID`)
) CHARACTER SET latin1;
CREATE TABLE `teacher` (
`teacherID` INT,
`NAME` VARCHAR(64),
`salary` DECIMAL(10,2),
`state` BOOL,
`sex` VARCHAR(64),
`birthday` DATETIME,
`PASSWORD` VARCHAR(64),
PRIMARY KEY (`teacherID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_426436_init') AS relationships;
relationships
Database: db_426436_init

Table Connections:
