`expireTime` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `House` (
`houseId` VARCHAR(64),
`ownerId` VARCHAR(64),
`area` INT,
`imageUrl` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`description` VARCHAR(64),
`buildingType` VARCHAR(64),
`dealType` VARCHAR(64),
`priceBase` INT,
`priceRent` INT,
`priceSell` INT,
`toDelete` BOOL,
PRIMARY KEY (`houseId`, `ownerId`)
) CHARACTER SET latin1;
