) CHARACTER SET latin1;
CREATE TABLE `mapping.organisation` (
`ods_code` VARCHAR(50) NOT NULL,
`organisation_name` VARCHAR(50),
`organisation_type` CHAR(50),
`address_line1` VARCHAR(50),
`address_line2` VARCHAR(50),
`town` VARCHAR(50),
`county` VARCHAR(50),
`postcode` VARCHAR(50),
`phone_number` VARCHAR(50),
`is_mapped` BOOLEAN,
`last_updated` TIMESTAMP NULL,
PRIMARY KEY (`ods_code`)
) CHARACTER SET latin1;
