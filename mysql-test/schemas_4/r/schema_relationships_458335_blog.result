CREATE DATABASE `db_458335_blog`;
USE `db_458335_blog`;
CREATE TABLE `articles` (
`id` INT,
`title` VARCHAR(50),
`slug` VARCHAR(50),
`body` TEXT,
`createdAt` DATETIME,
`updatedAt` DATETIME,
`categoryId` INT
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`slug` VARCHAR(50),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
