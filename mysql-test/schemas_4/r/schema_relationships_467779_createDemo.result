CREATE DATABASE `db_467779_createDemo`;
USE `db_467779_createDemo`;
CREATE TABLE `CURRENCY` (
`CODE` VARCHAR(64),
PRIMARY KEY (`CODE`)
) CHARACTER SET latin1;
CREATE TABLE `INSTRUMENT_TYPE` (
`INSTRUMENT_TYPE_ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`INSTRUMENT_TYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `INSTRUMENT` (
`INSTRUMENT_ID` INT,
`CURRENCY` VARCHAR(64),
`INSTRUMENT_TYPE_ID` INT,
`DESCRIPTION` VARCHAR(64),
`VALID` VARCHAR(64),
`ISSUER_COUNTRY` VARCHAR(64),
PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOND` (
`INSTRUMENT_ID` INT,
`MATURITYDATE` DATETIME,
`PARAMOUNT` DECIMAL(10,2),
`COUPON` DECIMAL(10,2),
`ZSPREAD` DECIMAL(10,2),
PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOND_FUTURE` (
`INSTRUMENT_ID` INT,
`CONTRACTSIZE` DECIMAL(10,2),
`FIRSTDELIVERYDATE` DATETIME,
`LASTDELIVERYDATE` DATETIME,
PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RATING` (
`RATING_ID` INT,
`RATER` VARCHAR(64),
`RATING` VARCHAR(64),
PRIMARY KEY (`RATING_ID`)
) CHARACTER SET latin1;
CREATE TABLE `INSTRUMENT_RATING` (
`INSTRUMENT_ID` INT,
`RATING_ID` INT,
PRIMARY KEY (`INSTRUMENT_ID`, `RATING_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TRADE_TYPE` (
`TRADE_TYPE_ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`TRADE_TYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `VERSION_STATUS` (
`VERSION_STATUS_ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`VERSION_STATUS_ID`)
) CHARACTER SET latin1;
CREATE TABLE `COUNTERPARTY` (
`COUNTERPARTY_ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
PRIMARY KEY (`COUNTERPARTY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TRADE` (
`TRADE_ID` INT,
`VERSION` INT,
`VERSION_STATUS_ID` INT,
`TRADE_DATE` DATETIME,
`TRADE_TYPE_ID` INT,
`INSTRUMENT_ID` INT,
`COMMENTS` VARCHAR(64),
`COUNTERPARTY_ID` DECIMAL(10,2),
`QUANTITY` DECIMAL(10,2),
`PRICE` DECIMAL(10,2),
PRIMARY KEY (`TRADE_ID`, `VERSION`)
) CHARACTER SET latin1;
CREATE TABLE `POSITION2` (
`INSTRUMENT_ID` INT,
`QUANTITY` DECIMAL(10,2),
`UPDATE_TIMESTAMP` DATETIME,
PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
