[Implied]  Ratings.author_id -> Students.id
[Implied]  Students_Classes.class_id -> Classes.id
[Implied]  Students_Classes.student_id -> Students.id
[Implied]  Votes.comment_id -> Comments.id
[Implied]  Votes.student_id -> Students.id

DROP DATABASE `db_410792_01_DataDefinition`;
UNINSTALL EXTENSION vsql_schematron;
