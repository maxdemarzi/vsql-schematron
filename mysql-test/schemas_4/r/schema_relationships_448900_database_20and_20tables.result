CREATE DATABASE `db_448900_database_20and_20tables`;
USE `db_448900_database_20and_20tables`;
CREATE TABLE `admin` (
`adminid` INT,
`adminUsername` VARCHAR(255),
`adminPassword` VARCHAR(255),
PRIMARY KEY (`adminid`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`customerid` INT,
`firstname` VARCHAR(255),
`lastname` VARCHAR(255),
`email` VARCHAR(255),
`phonenumber` VARCHAR(255),
PRIMARY KEY (`customerid`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
`cityid` INT,
`city` VARCHAR(255),
PRIMARY KEY (`cityid`)
) CHARACTER SET latin1;
CREATE TABLE `restaurant` (
`restaurantid` INT,
`cityid` INT,
`restaurantname` VARCHAR(255),
`description` VARCHAR(255),
`timeavailable` DATETIME,
`timeend` DATETIME,
PRIMARY KEY (`restaurantid`)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
`tableid` INT,
`restaurantid` INT,
`tableno` VARCHAR(255),
`tablecapacity` VARCHAR(255),
PRIMARY KEY (`tableid`)
) CHARACTER SET latin1;
CREATE TABLE `reservedtables` (
`restableid` INT,
`restaurantid` INT,
`tableid` INT,
`tableno` VARCHAR(255),
`numberofpeople` VARCHAR(255),
`dates` DATETIME,
`times` DATETIME,
PRIMARY KEY (`restableid`)
) CHARACTER SET latin1;
CREATE TABLE `dates` (
`dateid` INT,
`restaurantid` INT,
`dates` DATETIME,
PRIMARY KEY (`dateid`)
) CHARACTER SET latin1;
CREATE TABLE `datesfull` (
`dateid` INT,
`restaurantid` INT,
`datesfull` DATETIME,
PRIMARY KEY (`dateid`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`bookingid` INT,
`customerid` INT,
`restableid` INT,
PRIMARY KEY (`bookingid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_448900_database_20and_20tables') AS relationships;
