INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 431030_initdb
#
CREATE DATABASE `db_431030_initdb`;
USE `db_431030_initdb`;
CREATE TABLE `users` (
`user_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_urls` (
`id` VARCHAR(50),
`url` TEXT,
`code` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
`total_click` INT,
`user_id` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_431030_initdb') AS relationships;
