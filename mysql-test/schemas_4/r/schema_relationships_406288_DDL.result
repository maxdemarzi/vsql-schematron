INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 406288_DDL
#
CREATE DATABASE `db_406288_DDL`;
USE `db_406288_DDL`;
CREATE TABLE `users` (
`userID` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `administrator` (
`userID` INT,
`permissions` BOOL
) CHARACTER SET latin1;
CREATE TABLE `interview` (
`id` INT,
`title` VARCHAR(64),
`date` DATETIME,
`audio` VARCHAR(64),
`thumbnail` VARCHAR(64),
`script` VARCHAR(64),
`uID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `assets` (
`FiD` INT,
`timestamp` VARCHAR(64),
`hyperlink` VARCHAR(64),
`image` VARCHAR(64),
`text` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_406288_DDL') AS relationships;
