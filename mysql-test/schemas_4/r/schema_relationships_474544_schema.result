INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 474544_schema
#
CREATE DATABASE `db_474544_schema`;
USE `db_474544_schema`;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`name` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`is_active` VARCHAR(64),
`is_admin` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
`id` INT,
`name` VARCHAR(64),
`is_favorite` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alumn` (
`id` INT,
`image` VARCHAR(64),
`name` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`c1_fullname` VARCHAR(64),
`c1_address` VARCHAR(64),
`c1_phone` VARCHAR(64),
`c1_note` VARCHAR(64),
`c2_fullname` VARCHAR(64),
`c2_address` VARCHAR(64),
`c2_phone` VARCHAR(64),
`c2_note` VARCHAR(64),
`is_active` VARCHAR(64),
`created_at` DATETIME,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alumn_team` (
`id` INT,
`alumn_id` INT,
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `assistance` (
`id` INT,
`kind_id` INT,
`date_at` DATETIME,
`alumn_id` INT,
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `behavior` (
`id` INT,
`kind_id` INT,
`date_at` DATETIME,
`alumn_id` INT,
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `block` (
`id` INT,
`name` VARCHAR(64),
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `calification` (
`id` INT,
`val` DECIMAL(10,2),
`alumn_id` INT,
`block_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
