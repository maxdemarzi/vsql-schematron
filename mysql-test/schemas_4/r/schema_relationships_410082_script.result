INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 410082_script
#
CREATE DATABASE `db_410082_script`;
USE `db_410082_script`;
CREATE TABLE `users` (
`code` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`tag` VARCHAR(50),
`userID` VARCHAR(50),
`time` DATETIME,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `commands` (
`code` VARCHAR(50) NOT NULL,
`command` VARCHAR(50),
`authorCode` VARCHAR(50),
`channel` VARCHAR(50),
`server` VARCHAR(50),
`time` DATETIME,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_410082_script') AS relationships;
