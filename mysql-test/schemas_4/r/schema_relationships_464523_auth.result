CREATE DATABASE `db_464523_auth`;
USE `db_464523_auth`;
CREATE TABLE `user` (
`created_at` TIMESTAMP NULL,
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `privilege` (
`created_at` TIMESTAMP NULL,
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_privelege` (
`user` INT,
`created_at` TIMESTAMP NULL,
`id` INT NOT NULL,
`privilege` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_companies` (
`user` INT,
`created_at` TIMESTAMP NULL,
`id` INT NOT NULL,
`company` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_464523_auth') AS relationships;
