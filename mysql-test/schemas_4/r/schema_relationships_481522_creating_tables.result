INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 481522_creating_tables
#
CREATE DATABASE `db_481522_creating_tables`;
USE `db_481522_creating_tables`;
CREATE TABLE `department` (
`Dep_Name` VARCHAR(50),
`Dep_Number` INT NOT NULL,
`Manager_SSN` CHAR(50),
`Manager_start_date` CHAR(50),
PRIMARY KEY (`Dep_Number`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`Emp_Name` VARCHAR(50),
`SSN` VARCHAR(50) NOT NULL,
`SSN_Bdate` VARCHAR(50),
`address` VARCHAR(50),
`gender` CHAR(50),
`Salary` DOUBLE,
`Super_SSN` VARCHAR(50),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_481522_creating_tables') AS relationships;
