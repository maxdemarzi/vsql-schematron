PRIMARY KEY (`IdPedido`)
) CHARACTER SET latin1;
CREATE TABLE `PedidoXItem` (
`IdPedidoxItem` INT,
`IdPedido` INT,
`IdItem` INT,
`Quantidade` INT,
PRIMARY KEY (`IdPedidoxItem`)
) CHARACTER SET latin1;
CREATE TABLE `grupo` (
`IdGrupo` INT,
`Nome` VARCHAR(64),
PRIMARY KEY (`IdGrupo`)
) CHARACTER SET latin1;
CREATE TABLE `GrupoXUsuario` (
`IdGrupoXUsuario` INT,
`IdGrupo` INT,
`IdUsuario` INT,
PRIMARY KEY (`IdGrupoXUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `carrinho` (
`IdCarrinho` INT,
`Nome` VARCHAR(64),
`IdPedido` INT,
`Disponivel` BOOL,
`IdUltimoSensor` INT,
`HashRota` VARCHAR(64),
