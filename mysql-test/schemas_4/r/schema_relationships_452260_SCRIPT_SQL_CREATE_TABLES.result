`IdDirecao` INT,
`DirecaoRota` VARCHAR(64),
`HashNum` VARCHAR(64),
`Ativo` BOOL,
PRIMARY KEY (`IdSensor`)
) CHARACTER SET latin1;
CREATE TABLE `local` (
`IdLocal` INT,
`Nome` VARCHAR(64),
`IdSensor` INT,
`DataCriacao` DATETIME,
`Ativo` BOOL,
PRIMARY KEY (`IdLocal`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`IdItem` INT,
`Nome` VARCHAR(64),
`Ativo` BOOL,
`DataCriacao` DATETIME,
PRIMARY KEY (`IdItem`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`IdUsuario` INT,
`Nome` VARCHAR(64),
`DataCriacao` DATETIME,
`Ativo` BOOL,
`Idade` INT,
`Senha` VARCHAR(64),
PRIMARY KEY (`IdUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `rota` (
