INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 476445_schema-001
#
CREATE DATABASE `db_476445_schema_001`;
USE `db_476445_schema_001`;
CREATE TABLE `Accounts` (
`id` INT NOT NULL,
`key_exponent` BLOB,
`key_modulus` BLOB,
`display_name` VARCHAR(50),
`hashed_phone_number` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LoginChallenges` (
`id` INT NOT NULL,
`challenge` BLOB,
`account_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
`id` INT NOT NULL,
`auth_token` TEXT,
`account_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GamesCompletedAt` (
`id` INT NOT NULL,
`completed_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Games` (
`id` INT NOT NULL,
`completed_at_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Turns` (
`id` INT NOT NULL,
`account_id` INT,
`game_id` INT,
`is_complete` BOOLEAN,
`is_drawing` BOOLEAN,
`label` TEXT,
`drawing` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_476445_schema_001') AS relationships;
relationships
Database: db_476445_schema_001

Table Connections:
------------------
[Implied]  Games.completed_at_id -> GamesCompletedAt.id
[Implied]  LoginChallenges.account_id -> Accounts.id
[Implied]  Sessions.account_id -> Accounts.id
[Implied]  Turns.account_id -> Accounts.id
[Implied]  Turns.game_id -> Games.id

DROP DATABASE `db_476445_schema_001`;
UNINSTALL EXTENSION vsql_schematron;
