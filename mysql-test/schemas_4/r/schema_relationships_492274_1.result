CREATE DATABASE `db_492274_1`;
USE `db_492274_1`;
CREATE TABLE `POLLS` (
`id` BIGINT NOT NULL,
`owner_id` BIGINT,
`description` VARCHAR(50),
`hash_tag` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CHOICES` (
`id` BIGINT NOT NULL,
`poll_id` BIGINT,
`description` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `RESPONSES` (
`id` BIGINT NOT NULL,
`twitter_user_id` BIGINT,
`poll_id` BIGINT,
`choice_id` BIGINT,
`explanation` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TARGETS` (
`id` BIGINT NOT NULL,
`twitter_user_id` BIGINT,
`poll_id` BIGINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
