CREATE TABLE `chatting_message` (
`id` INT,
`chatting_type` INT,
`group_id` INT,
`is_group` INT,
`message` VARCHAR(64),
`receiver_user_id` VARCHAR(64),
`sender_user_id` VARCHAR(64),
`time` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`group_id` INT,
`user_id` VARCHAR(64),
PRIMARY KEY (`user_id`, `group_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` VARCHAR(64),
`user_headIndex` INT,
`user_name` VARCHAR(64),
`user_password` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_friends` (
`user_id` VARCHAR(64),
`friend_id` VARCHAR(64),
PRIMARY KEY (`user_id`, `friend_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_group` (
`group_id` INT,
`group_name` VARCHAR(64),
`creater_id` VARCHAR(64),
PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
