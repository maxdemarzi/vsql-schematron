INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 452516_schema
#
CREATE DATABASE `db_452516_schema`;
USE `db_452516_schema`;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`owner_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `balances` (
`id` INT NOT NULL,
`account_id` INT,
`timestamp` TIMESTAMP NULL,
`value` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stores` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `store_locations` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`store_id` INT,
`street` VARCHAR(50),
`number` VARCHAR(50),
`zip_code` VARCHAR(50),
`city` VARCHAR(50),
`country` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `purchases` (
`id` INT NOT NULL,
`DATE` DATE,
`amount` DECIMAL(10,2),
`store_location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT NOT NULL,
`request_timestamp` TIMESTAMP NULL,
`request_method` VARCHAR(50),
`request_uri` VARCHAR(50),
`request_payload` TEXT,
`response_timestamp` TIMESTAMP NULL,
`response_status` INT,
`response_payload` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_452516_schema') AS relationships;
relationships
Database: db_452516_schema

Table Connections:
------------------
[Implied]  balances.account_id -> accounts.id
[Implied]  purchases.store_location_id -> store_locations.id
[Implied]  store_locations.store_id -> stores.id

DROP DATABASE `db_452516_schema`;
UNINSTALL EXTENSION vsql_schematron;
