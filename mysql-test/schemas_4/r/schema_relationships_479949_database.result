CREATE TABLE `centrosMedicos` (
`IDcentroMedico` INT,
`nombreCentroMedico` VARCHAR(64),
`numeroDeSerie` VARCHAR(64),
`codigoAcceso` VARCHAR(64),
`ciudad` VARCHAR(64),
`imagenLogo` VARCHAR(64),
`fechaUnion` DATETIME,
PRIMARY KEY (`IDcentroMedico`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
`IDuser` INT,
`vacunadoPor` VARCHAR(64),
`nombreUser` VARCHAR(64),
`tipoIdentificacion` VARCHAR(64),
`numeroIdentificacion` VARCHAR(64),
`imagenUser` VARCHAR(64),
`tipoVacuna` VARCHAR(64),
`dosis` VARCHAR(64),
`fechaUnion` DATETIME,
`correo` VARCHAR(64),
PRIMARY KEY (`IDuser`)
) CHARACTER SET latin1;
