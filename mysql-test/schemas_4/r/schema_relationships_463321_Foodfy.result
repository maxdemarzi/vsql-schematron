INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 463321_Foodfy
#
CREATE DATABASE `db_463321_Foodfy`;
USE `db_463321_Foodfy`;
CREATE TABLE `chefs` (
`id` INT,
`name` VARCHAR(255),
`file_id` INT,
`created_at` DATETIME,
`update_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`id` INT,
`chef_id` INT,
`title` VARCHAR(255),
`ingredients` VARCHAR(255),
`preparation` VARCHAR(255),
`information` VARCHAR(255),
`created_at` DATETIME,
`update_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT,
`name` VARCHAR(255),
`path` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_files` (
`id` INT,
`recipe_id` INT,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_463321_Foodfy') AS relationships;
relationships
