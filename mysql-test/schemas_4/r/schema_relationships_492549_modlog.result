`timestamp` INT,
`roomid` VARCHAR(64),
`action` VARCHAR(64),
`visual_roomid` VARCHAR(64),
`action_taker_userid` VARCHAR(64),
`userid` VARCHAR(64),
`autoconfirmed_userid` VARCHAR(64),
`ip` VARCHAR(64),
`note` VARCHAR(64),
PRIMARY KEY (`modlog_id`)
) CHARACTER SET latin1;
CREATE TABLE `alts` (
`modlog_id` INT,
`userid` VARCHAR(64),
PRIMARY KEY (`modlog_id`, `userid`)
) CHARACTER SET latin1;
