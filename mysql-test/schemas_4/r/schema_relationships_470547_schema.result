INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 470547_schema
#
CREATE DATABASE `db_470547_schema`;
USE `db_470547_schema`;
CREATE TABLE `artists` (
`id` INT,
`name` VARCHAR(255),
`genre` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `albums` (
`id` INT,
`artist_id` INT,
`title` VARCHAR(255),
`year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs` (
`id` INT,
`title` VARCHAR(255),
`album_id` INT,
`length` INT,
`track_no` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlists` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlist_songs` (
`song_id` INT,
`playlist_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_470547_schema') AS relationships;
relationships
Database: db_470547_schema

Table Connections:
------------------
[Implied]  albums.artist_id -> artists.id
[Implied]  playlist_songs.playlist_id -> playlists.id
[Implied]  playlist_songs.song_id -> songs.id
[Implied]  songs.album_id -> albums.id

DROP DATABASE `db_470547_schema`;
UNINSTALL EXTENSION vsql_schematron;
