INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 492259_urlshortener
#
CREATE DATABASE `db_492259_urlshortener`;
USE `db_492259_urlshortener`;
CREATE TABLE `stats` (
`id` INT,
`url_id` INT,
`clickdate` TIMESTAMP NULL,
`ip` VARCHAR(50),
`referer` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `urls` (
`id` INT,
`url` VARCHAR(50),
`segment` VARCHAR(50),
`datetime_added` TIMESTAMP NULL,
`ip` VARCHAR(50),
`num_of_clicks` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_492259_urlshortener') AS relationships;
relationships
