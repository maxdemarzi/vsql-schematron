INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 491837_schema
#
CREATE DATABASE `db_491837_schema`;
USE `db_491837_schema`;
CREATE TABLE `department` (
`id` INT,
`dep_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
`is_manager` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_491837_schema') AS relationships;
relationships
Database: db_491837_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> roles.id
[Implied]  roles.department_id -> department.id

DROP DATABASE `db_491837_schema`;
UNINSTALL EXTENSION vsql_schematron;
