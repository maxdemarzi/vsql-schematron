INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 463336_db
#
CREATE DATABASE `db_463336_db`;
USE `db_463336_db`;
CREATE TABLE `family` (
`fam_id` VARCHAR(255),
`fam_name` VARCHAR(255),
`image` VARCHAR(255),
PRIMARY KEY (`fam_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` VARCHAR(255),
`fam_id` VARCHAR(255),
`user_name` VARCHAR(255),
`user_email` VARCHAR(255),
`user_password` VARCHAR(255),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`pro_id` VARCHAR(255),
`fam_id` VARCHAR(255),
`user_id` VARCHAR(255),
`requsted_by` VARCHAR(255),
`product_name` VARCHAR(255),
`requsted_at` VARCHAR(255),
PRIMARY KEY (`pro_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_463336_db') AS relationships;
relationships
