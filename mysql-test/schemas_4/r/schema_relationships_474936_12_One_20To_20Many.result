CREATE TABLE `customers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`order_date` DATETIME,
`amount` DECIMAL(10,2),
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`id` INT,
`first_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `papers` (
`title` VARCHAR(64),
`grade` INT,
`student_id` INT
) CHARACTER SET latin1;
