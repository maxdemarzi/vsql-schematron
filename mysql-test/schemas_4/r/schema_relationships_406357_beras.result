CREATE DATABASE `db_406357_beras`;
USE `db_406357_beras`;
CREATE TABLE `barang` (
`id_barang` VARCHAR(50) NOT NULL,
`nama_barang` VARCHAR(50),
`stok` INT,
`harga_beli` INT,
`harga_jual` INT,
PRIMARY KEY (`id_barang`)
) CHARACTER SET latin1;
CREATE TABLE `transaksi` (
`id_transaksi` INT,
`id_barang` VARCHAR(50),
`tipe` VARCHAR(50),
`tanggal` DATE,
`jumlah` INT,
`total` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`nama` VARCHAR(50)
) CHARACTER SET latin1;
