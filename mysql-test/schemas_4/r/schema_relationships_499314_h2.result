INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 499314_h2
#
CREATE DATABASE `db_499314_h2`;
USE `db_499314_h2`;
CREATE TABLE `regions` (
`region_id` INT,
`region_name` VARCHAR(64),
PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
`country_id` VARCHAR(64),
`country_name` VARCHAR(64),
`region_id` INT,
PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
`location_id` INT,
`address` VARCHAR(64),
`postal_code` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`country_id` VARCHAR(64),
PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `warehouses` (
`warehouse_id` INT,
`warehouse_name` VARCHAR(64),
`location_id` INT,
PRIMARY KEY (`warehouse_id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`employee_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`hire_date` DATETIME,
`manager_id` INT,
`job_title` VARCHAR(64),
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `product_categories` (
`category_id` INT,
`category_name` VARCHAR(64),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`product_id` INT,
`product_name` VARCHAR(64),
`description` VARCHAR(64),
`standard_cost` DECIMAL(10,2),
`list_price` DECIMAL(10,2),
`category_id` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
`website` VARCHAR(64),
`credit_limit` DECIMAL(10,2),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
`contact_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`customer_id` INT,
PRIMARY KEY (`contact_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`customer_id` INT,
`status` VARCHAR(64),
`salesman_id` INT,
`order_date` DATETIME,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_id` INT,
`item_id` INT,
`product_id` INT,
`quantity` DECIMAL(10,2),
`unit_price` DECIMAL(10,2),
PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
CREATE TABLE `inventories` (
`product_id` INT,
`warehouse_id` INT,
`quantity` DECIMAL(10,2),
PRIMARY KEY (`product_id`, `warehouse_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_499314_h2') AS relationships;
relationships
Database: db_499314_h2

Table Connections:
------------------
[Implied]  contacts.customer_id -> customers.customer_id
[Implied]  countries.region_id -> regions.region_id
[Implied]  employees.manager_id -> customers.customer_id
[Implied]  inventories.product_id -> products.product_id
[Implied]  inventories.warehouse_id -> warehouses.warehouse_id
[Implied]  locations.country_id -> countries.country_id
[Implied]  order_items.order_id -> orders.order_id
[Implied]  order_items.product_id -> products.product_id
[Implied]  orders.customer_id -> customers.customer_id
[Implied]  products.category_id -> product_categories.category_id
[Implied]  warehouses.location_id -> locations.location_id

DROP DATABASE `db_499314_h2`;
UNINSTALL EXTENSION vsql_schematron;
