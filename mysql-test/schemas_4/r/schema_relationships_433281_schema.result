INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 433281_schema
#
CREATE DATABASE `db_433281_schema`;
USE `db_433281_schema`;
CREATE TABLE `podcast` (
`id` INT NOT NULL,
`src` TEXT,
`url` TEXT,
`title` TEXT,
`image` TEXT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `episode` (
`id` INT NOT NULL,
`guid` TEXT,
`title` TEXT,
`src` TEXT,
`progress` INT,
`duration` INT,
`publication` INT,
`image` TEXT,
`position` INT,
`notes` TEXT,
`podcast` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`name` VARCHAR(50) NOT NULL,
`password` TEXT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_433281_schema') AS relationships;
