INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 413180_DDL
#
CREATE DATABASE `db_413180_DDL`;
USE `db_413180_DDL`;
CREATE TABLE `student` (
`student_id` INT NOT NULL,
`student_number` BIGINT,
`last_name` VARCHAR(50),
`first_name` VARCHAR(50),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `unit` (
`unit_id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`unit_id`)
) CHARACTER SET latin1;
CREATE TABLE `standard` (
`standard_id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`standard_id`)
) CHARACTER SET latin1;
CREATE TABLE `unit_standard` (
`unit_standard_id` INT NOT NULL,
`unit_id` INT,
`standard_id` INT,
PRIMARY KEY (`unit_standard_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_413180_DDL') AS relationships;
