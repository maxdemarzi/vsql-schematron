CREATE TABLE `COURSE` (
`cNo` VARCHAR(64),
`cName` VARCHAR(64),
`credit` INT,
`offer` INT,
PRIMARY KEY (`cNo`)
) CHARACTER SET latin1;
CREATE TABLE `DEGREE` (
`name` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `bucket_of_electives` (
`dName` VARCHAR(64),
`numOfCourses` INT,
`bNo` INT,
PRIMARY KEY (`bNo`, `dName`)
) CHARACTER SET latin1;
CREATE TABLE `contains` (
`dName` VARCHAR(64),
`cNo` VARCHAR(64),
`bNo` INT,
PRIMARY KEY (`bNo`, `cNo`, `dName`)
) CHARACTER SET latin1;
CREATE TABLE `prereq` (
`prereqCNo` VARCHAR(64),
`cNo` VARCHAR(64),
`v` INT,
PRIMARY KEY (`prereqCNo`, `cNo`)
) CHARACTER SET latin1;
CREATE TABLE `required` (
`dName` VARCHAR(64),
`cNo` VARCHAR(64),
`v` INT,
PRIMARY KEY (`dName`, `cNo`)
) CHARACTER SET latin1;
