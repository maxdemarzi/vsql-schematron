CREATE DATABASE `db_432891_testdb`;
USE `db_432891_testdb`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`role` VARCHAR(50),
`password` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guestbook` (
`id` VARCHAR(50) NOT NULL,
`userId` VARCHAR(50),
`comment` VARCHAR(50),
`approved` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_432891_testdb') AS relationships;
