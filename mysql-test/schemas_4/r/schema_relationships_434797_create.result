) CHARACTER SET latin1;
CREATE TABLE `productImages` (
`imageId` INT NOT NULL,
`productId` INT,
`path` VARCHAR(50),
PRIMARY KEY (`imageId`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`categoryId` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`categoryId`)
) CHARACTER SET latin1;
