CREATE DATABASE `db_460424_initial`;
USE `db_460424_initial`;
CREATE TABLE `user` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`created_at` DATETIME,
`confirmed_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
