INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 446529_creation
#
CREATE DATABASE `db_446529_creation`;
USE `db_446529_creation`;
CREATE TABLE `DEPT` (
`DEPTNO` DECIMAL(10,2),
`DNAME` VARCHAR(64),
`LOC` VARCHAR(64),
PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
`EMPNO` DECIMAL(10,2),
`ENAME` VARCHAR(64),
`EFIRST` VARCHAR(64),
`JOB` VARCHAR(64),
`MGR` DECIMAL(10,2),
`HIREDATE` DATETIME,
`SAL` DECIMAL(10,2),
`COMM` DECIMAL(10,2),
`TEL` VARCHAR(64),
`DEPTNO` DECIMAL(10,2),
PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `DEPENDENTS` (
`DNO` DECIMAL(10,2),
`DNAME` VARCHAR(64),
`DFIRST` VARCHAR(64),
`EMPNO` DECIMAL(10,2),
PRIMARY KEY (`DNO`, `EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `BONUS` (
`ENAME` VARCHAR(64),
`JOB` VARCHAR(64),
`SAL` DECIMAL(10,2),
`COMM` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `SALGRADE` (
`GRADE` DECIMAL(10,2),
`LOSAL` DECIMAL(10,2),
`HISAL` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_446529_creation') AS relationships;
relationships
