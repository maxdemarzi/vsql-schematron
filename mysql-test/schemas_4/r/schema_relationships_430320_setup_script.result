CREATE DATABASE `db_430320_setup_script`;
USE `db_430320_setup_script`;
CREATE TABLE `UserLogin` (
`Id` INT,
`Username` VARCHAR(64),
`ValidationKey` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `UserApiKeys` (
`Id` INT,
`UserId` INT,
`ApiKey` VARCHAR(64),
`EncryptionKey` VARCHAR(64),
`KeyName` VARCHAR(64),
`Expires` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `TmpState` (
`KeyId` INT,
`System` VARCHAR(64),
`State` VARCHAR(64),
`Key` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `UserTokens` (
`Id` INT,
`KeyId` INT,
`System` VARCHAR(64),
`Expires` INT,
`AccessTokenObj` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
