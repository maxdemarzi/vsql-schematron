INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 402149_ddl
#
CREATE DATABASE `db_402149_ddl`;
USE `db_402149_ddl`;
CREATE TABLE `files` (
`id` INT NOT NULL,
`path` VARCHAR(50),
`id_user` INT,
`file_name` VARCHAR(50),
`file_types` VARCHAR(50),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`id_specialist` INT,
`id_customer` INT,
`name` VARCHAR(50),
`description` TEXT,
`price` INT,
`deadline` INT,
`remote` TINYINT,
`id_skill` INT,
`id_city` INT,
`longitude` DOUBLE,
`latitude` DOUBLE,
`address` TEXT,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chat` (
`id` INT NOT NULL,
`id_task` INT,
`id_customer` INT,
`id_specialist` INT,
`message` TEXT,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_402149_ddl') AS relationships;
