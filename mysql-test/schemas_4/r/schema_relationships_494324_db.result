INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 494324_db
#
CREATE DATABASE `db_494324_db`;
USE `db_494324_db`;
CREATE TABLE `buildings` (
`id` INT,
`name` VARCHAR(64),
`sudo_name` VARCHAR(64),
`surname_contact` VARCHAR(64),
`forename_contact` VARCHAR(64),
`email_contact` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room` (
`id` INT,
`room_name` VARCHAR(64),
`building_id` INT,
`num_people` INT,
`num_computers` INT,
`hireable` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` VARCHAR(64),
`surname` VARCHAR(64),
`forename` VARCHAR(64),
`email` VARCHAR(64),
`room_id` INT,
`last_check_in_location` INT,
`last_check_in_date` DATETIME,
`last_check_in_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classes` (
`id` INT,
`class_name` VARCHAR(64),
`class_code` VARCHAR(64),
`lecturer` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room_bookings` (
`id` INT,
`surname` VARCHAR(64),
`forename` VARCHAR(64),
`email` VARCHAR(64),
`room_id` INT,
`date_booked` DATETIME,
`time_booked` DATETIME,
`time_booked_until` DATETIME,
`length_min` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_494324_db') AS relationships;
relationships
Database: db_494324_db

Table Connections:
