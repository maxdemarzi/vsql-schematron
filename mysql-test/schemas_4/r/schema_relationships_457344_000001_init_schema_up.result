INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 457344_000001_init_schema.up
#
CREATE DATABASE `db_457344_000001_init_schema_up`;
USE `db_457344_000001_init_schema_up`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`login` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `languages` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`time_limit` INT,
`memory` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_cases` (
`id` INT NOT NULL,
`task_id` INT,
`test_data` TEXT,
`answer` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history_user` (
`uuid` VARCHAR(50) NOT NULL,
`user_id` INT,
`task_id` INT,
`language_id` INT,
`solution` TEXT,
`result` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_457344_000001_init_schema_up') AS relationships;
relationships
