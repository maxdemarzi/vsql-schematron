CREATE DATABASE `db_476661_tpch`;
USE `db_476661_tpch`;
CREATE TABLE `tpch_part` (
`P_PARTKEY` INT,
`P_NAME` VARCHAR(64),
`P_MFGR` VARCHAR(64),
`P_BRAND` VARCHAR(64),
`P_TYPE` VARCHAR(64),
`P_SIZE` INT,
`P_CONTAINER` VARCHAR(64),
`P_RETAILPRICE` DECIMAL(10,2),
`P_COMMENT` VARCHAR(64),
PRIMARY KEY (`P_PARTKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_region` (
`R_REGIONKEY` INT,
`R_NAME` VARCHAR(64),
`R_COMMENT` VARCHAR(64),
PRIMARY KEY (`R_REGIONKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_nation` (
`N_NATIONKEY` INT,
`N_NAME` VARCHAR(64),
`N_REGIONKEY` INT,
`N_COMMENT` VARCHAR(64),
PRIMARY KEY (`N_NATIONKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_supplier` (
`S_SUPPKEY` INT,
`S_NAME` VARCHAR(64),
`S_ADDRESS` VARCHAR(64),
`S_NATIONKEY` INT,
`S_PHONE` VARCHAR(64),
`S_ACCTBAL` DECIMAL(10,2),
`S_COMMENT` VARCHAR(64),
PRIMARY KEY (`S_SUPPKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_partsupp` (
`PS_PARTKEY` INT,
`PS_SUPPKEY` INT,
`PS_AVAILQTY` INT,
`PS_SUPPLYCOST` DECIMAL(10,2),
`PS_COMMENT` VARCHAR(64),
PRIMARY KEY (`PS_PARTKEY`, `PS_SUPPKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_customer` (
`C_CUSTKEY` INT,
`C_NAME` VARCHAR(64),
`C_ADDRESS` VARCHAR(64),
`C_NATIONKEY` INT,
`C_PHONE` VARCHAR(64),
`C_ACCTBAL` DECIMAL(10,2),
`C_MKTSEGMENT` VARCHAR(64),
`C_COMMENT` VARCHAR(64),
PRIMARY KEY (`C_CUSTKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_orders` (
`O_ORDERKEY` INT,
`O_CUSTKEY` INT,
`O_ORDERSTATUS` VARCHAR(64),
`O_TOTALPRICE` DECIMAL(10,2),
`O_ORDERDATE` DATETIME,
`O_ORDERPRIORITY` VARCHAR(64),
`O_CLERK` VARCHAR(64),
`O_SHIPPRIORITY` INT,
`O_COMMENT` VARCHAR(64),
PRIMARY KEY (`O_ORDERKEY`)
) CHARACTER SET latin1;
CREATE TABLE `tpch_lineitem` (
`L_ORDERKEY` INT,
`L_PARTKEY` INT,
`L_SUPPKEY` INT,
`L_LINENUMBER` INT,
`L_QUANTITY` DECIMAL(10,2),
`L_EXTENDEDPRICE` DECIMAL(10,2),
`L_DISCOUNT` DECIMAL(10,2),
`L_TAX` DECIMAL(10,2),
`L_RETURNFLAG` VARCHAR(64),
`L_LINESTATUS` VARCHAR(64),
`L_SHIPDATE` DATETIME,
`L_COMMITDATE` DATETIME,
`L_RECEIPTDATE` DATETIME,
`L_SHIPINSTRUCT` VARCHAR(64),
`L_SHIPMODE` VARCHAR(64),
`L_COMMENT` VARCHAR(64),
PRIMARY KEY (`L_ORDERKEY`, `L_LINENUMBER`)
) CHARACTER SET latin1;
