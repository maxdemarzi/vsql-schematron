CREATE DATABASE `db_497663_base_bob`;
USE `db_497663_base_bob`;
CREATE TABLE `users` (
`id` INT,
`nickname` VARCHAR(64),
`password` VARCHAR(64),
`created_at` DATETIME,
`when_online` DATETIME,
`path_avatar` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
`user_id` INT,
`friend_id` INT,
PRIMARY KEY (`user_id`, `friend_id`)
) CHARACTER SET latin1;
CREATE TABLE `blocked_users` (
`from_id` INT,
`to_id` INT,
PRIMARY KEY (`from_id`, `to_id`)
) CHARACTER SET latin1;
CREATE TABLE `dialog` (
`id` INT,
`user1_id` INT,
`user2_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parties` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`founder_id` INT,
`path_avatar` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `party_users` (
`party_id` INT,
`user_id` INT,
PRIMARY KEY (`party_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `party_admins` (
`party_id` INT,
`admin_id` INT,
PRIMARY KEY (`party_id`, `admin_id`)
) CHARACTER SET latin1;
CREATE TABLE `companion_writes` (
`user_id` INT,
`to_user_id` INT,
`when_writed` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `party_writes` (
`user_id` INT,
`to_party_id` INT,
`when_writed` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT,
`to_id` INT,
`from_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`text` VARCHAR(64),
`file_id` INT,
`photo_id` INT,
`party_id` INT,
`important` BOOL,
`removable` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `who_saw_message` (
`message_id` INT,
`who_saw_id` INT,
PRIMARY KEY (`message_id`, `who_saw_id`)
) CHARACTER SET latin1;
CREATE TABLE `errors` (
`user_id` INT,
`error` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
