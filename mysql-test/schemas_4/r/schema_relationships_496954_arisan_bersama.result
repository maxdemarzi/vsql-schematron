CREATE DATABASE `db_496954_arisan_bersama`;
USE `db_496954_arisan_bersama`;
CREATE TABLE `arisan` (
`id` INT,
`user_id` INT,
`unique_id` VARCHAR(64),
`title` VARCHAR(64),
`nominal` INT,
`description` VARCHAR(64),
`time_start` DATETIME,
`period` VARCHAR(64),
`long_time` INT,
`max_join` DATETIME,
`status` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_participant` (
`id` INT,
`arisan_id` INT,
`user_id` INT,
`number` INT,
`income` INT,
`status` VARCHAR(64),
`img` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`id` INT,
`arisan_id` INT,
`user_id` INT,
`payment_amount` INT,
`label` VARCHAR(64),
`status` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
`name` VARCHAR(64),
`tel` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_496954_arisan_bersama') AS relationships;
