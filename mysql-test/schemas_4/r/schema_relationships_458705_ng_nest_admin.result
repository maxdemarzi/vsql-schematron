CREATE DATABASE `db_458705_ng_nest_admin`;
USE `db_458705_ng_nest_admin`;
CREATE TABLE `design_col` (
`id` VARCHAR(255),
`label` VARCHAR(255),
`name` VARCHAR(255),
`sort` INT,
`type` VARCHAR(255),
`length` INT,
`primary` INT,
`nullable` INT,
`unique` INT,
`default` VARCHAR(255),
`tableId` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `design_control` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`code` VARCHAR(255),
`description` VARCHAR(255),
`required` INT,
`disabled` INT,
`readonly` INT,
`hide` INT,
`primary` INT,
`sort` INT,
`col` VARCHAR(255),
`type` VARCHAR(255),
`group` VARCHAR(255),
`pageId` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `design_module` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`code` VARCHAR(255),
`description` VARCHAR(255),
`icon` VARCHAR(255),
`createTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `design_page` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`code` VARCHAR(255),
`description` VARCHAR(255),
`moduleId` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `design_page_relation` (
`fromPageId` VARCHAR(255),
`toPageId` VARCHAR(255),
PRIMARY KEY (`fromPageId`, `toPageId`)
) CHARACTER SET latin1;
CREATE TABLE `design_table` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`code` VARCHAR(255),
`description` VARCHAR(255),
`transform` VARCHAR(255),
`moduleId` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_458705_ng_nest_admin') AS relationships;
