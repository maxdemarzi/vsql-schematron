[Implied]  orderList.userID -> users.ID
[Implied]  users.accountTypeKey -> accountType.ID
[Implied]  users.cafeEmployment -> cafe.cafeID

DROP DATABASE `db_410444_test`;
UNINSTALL EXTENSION vsql_schematron;
