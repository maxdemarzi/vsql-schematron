INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 410444_test
#
CREATE DATABASE `db_410444_test`;
USE `db_410444_test`;
CREATE TABLE `cafe` (
`cafeID` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
`openTime` DATETIME,
`closeTime` DATETIME,
PRIMARY KEY (`cafeID`)
) CHARACTER SET latin1;
CREATE TABLE `foodType` (
`typeID` INT,
`name` VARCHAR(255),
PRIMARY KEY (`typeID`)
) CHARACTER SET latin1;
CREATE TABLE `masterFoodList` (
`itemID` INT,
`name` VARCHAR(255),
`imagePath` VARCHAR(255),
`price` DECIMAL(10,2),
`description` VARCHAR(255),
`type` INT,
`startDate` DATETIME,
`endDate` DATETIME,
PRIMARY KEY (`itemID`)
) CHARACTER SET latin1;
CREATE TABLE `item_to_cafe` (
`itemID` INT,
`cafeID` INT
) CHARACTER SET latin1;
CREATE TABLE `accountType` (
`ID` INT,
`accountType` VARCHAR(255),
`accessCode` VARCHAR(255),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`ID` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`email` VARCHAR(255),
`activeAccount` VARCHAR(255),
`imagePath` VARCHAR(255),
`accountTypeKey` INT,
`idNumber` VARCHAR(255),
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`gender` VARCHAR(255),
`CCnumber` VARCHAR(255),
`CCName` VARCHAR(255),
`CCCVC` VARCHAR(255),
`CCExpDate` VARCHAR(255),
`accountBalance` DECIMAL(10,2),
`cafeEmployment` INT,
`creationTimeStamp` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `orderList` (
`ID` INT,
`userID` INT,
`price` DECIMAL(10,2),
`cafeID` INT,
`pickupTime` DATETIME,
`orderNotes` VARCHAR(255),
`paid` VARCHAR(255),
`orderCompleted` VARCHAR(255),
`orderPickedUp` VARCHAR(255),
`orderDelivered` VARCHAR(255),
`creationTimeStamp` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `item_to_order` (
`orderID` INT,
`itemID` INT,
`quantity` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_410444_test') AS relationships;
relationships
Database: db_410444_test

