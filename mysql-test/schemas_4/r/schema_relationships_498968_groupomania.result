CREATE DATABASE `db_498968_groupomania`;
USE `db_498968_groupomania`;
CREATE TABLE `comments` (
`id` INT,
`comment` VARCHAR(64),
`postId` INT,
`userId` INT,
`createdAt` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`userId` INT,
`title` VARCHAR(64),
`message` VARCHAR(64),
`media` VARCHAR(64),
`createdAt` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`avatar` VARCHAR(64),
`admin` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_498968_groupomania') AS relationships;
