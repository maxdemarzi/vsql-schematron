CREATE DATABASE `db_498968_groupomania`;
USE `db_498968_groupomania`;
CREATE TABLE `comments` (
`id` INT,
`comment` VARCHAR(255),
`postId` INT,
`userId` INT,
`createdAt` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`userId` INT,
`title` VARCHAR(255),
`message` VARCHAR(255),
`media` VARCHAR(255),
`createdAt` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`firstname` VARCHAR(255),
`lastname` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
`avatar` VARCHAR(255),
`admin` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_498968_groupomania') AS relationships;
