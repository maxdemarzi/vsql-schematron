INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 486200_schema
#
CREATE DATABASE `db_486200_schema`;
USE `db_486200_schema`;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`job_id` INT,
`leader_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`subtitle` VARCHAR(255),
`rate` DECIMAL(10,2),
`branch_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_486200_schema') AS relationships;
