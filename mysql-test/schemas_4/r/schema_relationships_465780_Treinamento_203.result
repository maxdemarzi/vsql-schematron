CREATE DATABASE `db_465780_Treinamento_203`;
USE `db_465780_Treinamento_203`;
CREATE TABLE `EMPR` (
`MATR` VARCHAR(64),
`NOME` VARCHAR(64),
`SOBRENOME` VARCHAR(64),
`DEPT` VARCHAR(64),
`FONE` VARCHAR(64),
`DINADIM` DATETIME,
`CARGO` VARCHAR(64),
`NIVELED` INT,
`SEXO` VARCHAR(64),
`DATANAS` DATETIME,
`SALARIO` DECIMAL(10,2),
`BONUS` DECIMAL(10,2),
`COMIS` DECIMAL(10,2),
PRIMARY KEY (`MATR`)
) CHARACTER SET latin1;
CREATE TABLE `DEPT` (
`DCODIGO` VARCHAR(64),
`DNOME` VARCHAR(64),
`GERENTE` VARCHAR(64),
`DSUPER` VARCHAR(64),
PRIMARY KEY (`DCODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `PROJETO` (
`PCODIGO` VARCHAR(64),
`PNOME` VARCHAR(64),
`DCODIGO` VARCHAR(64),
`RESP` VARCHAR(64),
`EQUIPE` INT,
`DATAINI` DATETIME,
`DATAFIM` DATETIME,
`PSUPER` VARCHAR(64),
PRIMARY KEY (`PCODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `TrabalhaEM` (
`MATR` VARCHAR(64),
`PCODIGO` VARCHAR(64),
`HORASALOCACAO` INT,
PRIMARY KEY (`MATR`, `PCODIGO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_465780_Treinamento_203') AS relationships;
