INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 483620_database
#
CREATE DATABASE `db_483620_database`;
USE `db_483620_database`;
CREATE TABLE `BLOCK` (
`GENKEY` VARCHAR(64),
`NAME` VARCHAR(64),
`DISC` VARCHAR(64),
PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;
CREATE TABLE `POST` (
`GENKEY` VARCHAR(64),
`TITLE` VARCHAR(64),
`BLOCK_GK` VARCHAR(64),
`AUTHOR_GK` VARCHAR(64),
PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;
CREATE TABLE `REPLY` (
`GENKEY` VARCHAR(64),
`POST_GK` VARCHAR(64),
`LEVEL` INT,
`AUTHOR_GK` VARCHAR(64),
`COMMENT` VARCHAR(64),
`REPLY_TO_GK` VARCHAR(64),
PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
`GENKEY` VARCHAR(64),
`USERNAME` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`PHONE` INT,
`EMAIL` VARCHAR(64),
`QQ` INT,
PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_483620_database') AS relationships;
relationships
Database: db_483620_database

Table Connections:
