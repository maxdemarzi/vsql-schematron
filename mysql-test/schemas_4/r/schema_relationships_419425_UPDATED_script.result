INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 419425_UPDATED_script
#
CREATE DATABASE `db_419425_UPDATED_script`;
USE `db_419425_UPDATED_script`;
CREATE TABLE `Users` (
`code` INT,
`stars` INT,
`name` VARCHAR(64),
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Employee_Users` (
`empId` INT,
`userId` INT,
PRIMARY KEY (`empId`, `userId`)
) CHARACTER SET latin1;
CREATE TABLE `Jobs` (
`jobId` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`jobId`)
) CHARACTER SET latin1;
CREATE TABLE `Users_Have_Jobs` (
`userId` INT,
`jobId` INT,
PRIMARY KEY (`userId`, `jobId`)
) CHARACTER SET latin1;
CREATE TABLE `SubJobs` (
`subJobId` INT,
`jobId` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`imgLink` VARCHAR(64),
`orderNumber` INT,
PRIMARY KEY (`subJobId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_419425_UPDATED_script') AS relationships;
