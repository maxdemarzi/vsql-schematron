INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 476309_init
#
CREATE DATABASE `db_476309_init`;
USE `db_476309_init`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`user_name` TEXT,
`pass_word` TEXT,
`role` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT NOT NULL,
`name` TEXT,
`author` TEXT,
`publisher` TEXT,
`total_page` INT,
`published_date` TIMESTAMP NULL,
`price` BIGINT,
`stock` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`users_id` BIGINT,
`books_id` BIGINT,
`quantity` INT,
`shipping_details` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_476309_init') AS relationships;
relationships
Database: db_476309_init

