INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 444656_music
#
CREATE DATABASE `db_444656_music`;
USE `db_444656_music`;
CREATE TABLE `album` (
`id` INT,
`title` VARCHAR(255),
`release_year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
`id` INT,
`title` VARCHAR(255),
`album_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist_album` (
`artist_id` INT,
`album_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_444656_music') AS relationships;
relationships
