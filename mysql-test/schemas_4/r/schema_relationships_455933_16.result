) CHARACTER SET latin1;
CREATE TABLE `mission` (
`mission_id` INT NOT NULL,
`region_id` INT,
`label` TEXT,
`level` INT,
`deleted` BOOLEAN,
`coverage` DOUBLE,
`distance` DOUBLE,
`distance_ft` DOUBLE,
`distance_mi` DOUBLE,
PRIMARY KEY (`mission_id`)
) CHARACTER SET latin1;
CREATE TABLE `mission_user` (
`mission_user_id` INT NOT NULL,
`mission_id` INT,
`user_id` TEXT,
`paid` BOOLEAN,
`pay_per_mile` DOUBLE,
PRIMARY KEY (`mission_user_id`)
) CHARACTER SET latin1;
