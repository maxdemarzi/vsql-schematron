[Implied]  tags.id -> postags.id
[Implied]  usersposmatchids.id -> posmatchids.id
[Implied]  usersposmatchids.username -> users.username

DROP DATABASE `db_440593_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
