INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 470307_starting_schema
#
CREATE DATABASE `db_470307_starting_schema`;
USE `db_470307_starting_schema`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(255),
`device` VARCHAR(255),
`current_zone_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zones` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
`fk_user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT,
`text` VARCHAR(255),
`fk_message_type_id` INT,
`fk_zone_id` INT,
`fk_user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message_types` (
`id` INT,
`name` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_470307_starting_schema') AS relationships;
relationships
Database: db_470307_starting_schema

