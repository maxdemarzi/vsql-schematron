`trader_id` INT,
`cost` DECIMAL(10,2),
`profit` DECIMAL(10,2),
`result` VARCHAR(255),
`status` VARCHAR(255),
PRIMARY KEY (`trade_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`trade_id` INT,
`time_stamp` DATETIME,
`year` INT,
`month` INT,
`day` INT,
`hour` INT,
`minute` INT,
`ticker` VARCHAR(255),
`buy_price` DECIMAL(10,2),
`sell_price` DECIMAL(10,2),
`quantity` INT,
`order_type` VARCHAR(255),
`trader_id` INT,
`cost` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
