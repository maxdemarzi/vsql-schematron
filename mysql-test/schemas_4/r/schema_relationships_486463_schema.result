CREATE DATABASE `db_486463_schema`;
USE `db_486463_schema`;
CREATE TABLE `organizations` (
`id` INT,
`name` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`deleted_at` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`deleted_at` VARCHAR(64),
`organization` INT,
`is_admin` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
`id` INT,
`note` VARCHAR(64),
`created_by` INT,
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`deleted_at` VARCHAR(64),
`is_public` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
