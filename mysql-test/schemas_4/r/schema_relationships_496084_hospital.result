`id` INT,
`fecha` DATETIME,
`tipo` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `atiende` (
`id_doc` VARCHAR(64),
`diagnostico` VARCHAR(64),
`folio` VARCHAR(64)
) CHARACTER SET latin1;
