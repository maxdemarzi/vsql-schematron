PRIMARY KEY (`UserId`)
) CHARACTER SET latin1;
CREATE TABLE `bookTable` (
`ISBN` VARCHAR(64),
`BookName` VARCHAR(64),
`Publisher` VARCHAR(64),
`Author` VARCHAR(64),
`CollectionNum` INT,
`CanBorrowNum` INT,
`CanBorrow` VARCHAR(64),
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `readerTable` (
`ReaderId` VARCHAR(64),
`ReaderName` VARCHAR(64),
`Sex` VARCHAR(64),
`JobTitle` VARCHAR(64),
`CanBorrowNum` INT,
`BorrowedNum` INT,
`Department` VARCHAR(64),
`PhoneNumber` VARCHAR(64),
PRIMARY KEY (`ReaderId`)
) CHARACTER SET latin1;
CREATE TABLE `borrowTable` (
`ReaderId` VARCHAR(64),
`ISBN` VARCHAR(64),
`BorrowedDate` VARCHAR(64),
`BorrowPeriod` INT,
`ReturnDate` VARCHAR(64),
`Fine` INT,
PRIMARY KEY (`ReaderId`, `ISBN`)
) CHARACTER SET latin1;
