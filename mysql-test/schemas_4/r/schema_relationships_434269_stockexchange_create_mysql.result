INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 434269_stockexchange-create-mysql
#
CREATE DATABASE `db_434269_stockexchange_create_mysql`;
USE `db_434269_stockexchange_create_mysql`;
CREATE TABLE `address` (
`id` INT,
`street` VARCHAR(64),
`number` INT,
`city` VARCHAR(64),
`state` VARCHAR(64),
`country` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT,
`name` VARCHAR(64),
`lastname` VARCHAR(64),
`dateofbirth` DATETIME,
`ssn` VARCHAR(64),
`addressid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `broker` (
`id` INT
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT
) CHARACTER SET latin1;
CREATE TABLE `brokerworksfor` (
`brokerid` INT,
`companyid` INT,
`clientid` INT
) CHARACTER SET latin1;
CREATE TABLE `company` (
`id` INT,
`name` VARCHAR(64),
`marketshares` INT,
`networth` DECIMAL(10,2),
`addressid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stockbooklist` (
`date` DATETIME,
`stockid` INT,
PRIMARY KEY (`date`)
) CHARACTER SET latin1;
CREATE TABLE `stockinformation` (
`id` INT,
`numberofshares` INT,
`sharetype` BOOL,
`companyid` INT,
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`id` INT,
`date` DATETIME,
`stockid` INT,
`type` BOOL,
`brokerid` INT,
`forclientid` INT,
`forcompanyid` INT,
`amount` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_434269_stockexchange_create_mysql') AS relationships;
relationships
