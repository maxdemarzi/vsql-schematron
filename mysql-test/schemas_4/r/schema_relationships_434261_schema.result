INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 434261_schema
#
CREATE DATABASE `db_434261_schema`;
USE `db_434261_schema`;
CREATE TABLE `admins` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `announcements` (
`id` INT NOT NULL,
`owner_id` INT,
`name` VARCHAR(50),
`description` VARCHAR(50),
`location` VARCHAR(50),
`category` INT,
`created_date` DATE,
`duration` INT,
`status` INT,
`price_per_day` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlists` (
`id` INT NOT NULL,
`owner_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlist_items` (
`id` INT NOT NULL,
`wishlist_id` INT,
`announcement_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `discussions` (
`id` INT NOT NULL,
`interested_user_id` INT,
`announcement_id` INT,
`created_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `loans` (
`id` INT NOT NULL,
`discussion_id` INT,
`loan_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `closed_loans` (
`id` INT NOT NULL,
`loan_id` INT,
`close_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_434261_schema') AS relationships;
relationships
