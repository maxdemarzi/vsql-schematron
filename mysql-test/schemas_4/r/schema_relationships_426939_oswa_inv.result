CREATE DATABASE `db_426939_oswa_inv`;
USE `db_426939_oswa_inv`;
CREATE TABLE `AssetType` (
`id` INT,
`Type` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `media` (
`id` INT,
`file_name` VARCHAR(255),
`file_type` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Assets` (
`id` INT,
`Assetname` VARCHAR(255),
`description` VARCHAR(255),
`purpose` VARCHAR(255),
`owner` VARCHAR(255),
`financial_value` INT,
`location` VARCHAR(255),
`date` DATETIME,
`returns` VARCHAR(255),
`dateOfReturn` DATETIME,
`status` VARCHAR(255),
`comments` VARCHAR(255),
`assettype_id` INT,
`media_id` INT
) CHARACTER SET latin1;
CREATE TABLE `sales` (
`id` INT,
`Assetid` INT,
`qty` INT,
`price` DECIMAL(10,2),
`date` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_426939_oswa_inv') AS relationships;
