INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 442029_schema
#
CREATE DATABASE `db_442029_schema`;
USE `db_442029_schema`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`token` VARCHAR(50),
`created_on` TIMESTAMP NULL,
`last_login` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` VARCHAR(50) NOT NULL,
`category` VARCHAR(50),
`labels` VARCHAR(50),
`name` VARCHAR(50),
`brand` VARCHAR(50),
`color` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `price` (
`id` VARCHAR(50) NOT NULL,
`of_product` VARCHAR(50),
`price` DOUBLE,
`unit` VARCHAR(50),
`currency` VARCHAR(50),
`_created` DATE,
`_version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_442029_schema') AS relationships;
