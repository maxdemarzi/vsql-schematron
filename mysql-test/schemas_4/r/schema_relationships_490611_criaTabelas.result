CREATE DATABASE `db_490611_criaTabelas`;
USE `db_490611_criaTabelas`;
CREATE TABLE `emp` (
`nemp` DECIMAL(10,2),
`nome` VARCHAR(64),
`funcao` VARCHAR(64),
`encar` DECIMAL(10,2),
`data_entrada` DATETIME,
`sal` DECIMAL(10,2),
`premios` DECIMAL(10,2),
`ndep` DECIMAL(10,2),
PRIMARY KEY (`nemp`)
) CHARACTER SET latin1;
CREATE TABLE `dep` (
`ndep` DECIMAL(10,2),
`nome` VARCHAR(64),
`local` VARCHAR(64),
PRIMARY KEY (`ndep`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_490611_criaTabelas') AS relationships;
