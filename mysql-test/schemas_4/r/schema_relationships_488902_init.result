INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 488902_init
#
CREATE DATABASE `db_488902_init`;
USE `db_488902_init`;
CREATE TABLE `role` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`descn` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`status` INT,
`descn` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` BIGINT NOT NULL,
`role_id` BIGINT NOT NULL,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_488902_init') AS relationships;
