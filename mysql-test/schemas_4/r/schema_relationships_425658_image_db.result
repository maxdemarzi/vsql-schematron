CREATE TABLE `img_types` (
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`name` VARCHAR(64),
`imagetype` VARCHAR(64),
`width` INT,
`height` INT,
`image` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`imgname` VARCHAR(64),
`rnk` INT,
`label` VARCHAR(64),
PRIMARY KEY (`imgname`, `rnk`)
) CHARACTER SET latin1;
