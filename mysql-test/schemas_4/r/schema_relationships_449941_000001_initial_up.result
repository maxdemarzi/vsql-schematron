CREATE DATABASE `db_449941_000001_initial_up`;
USE `db_449941_000001_initial_up`;
CREATE TABLE `users` (
`id` INT,
`phone_number` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `channels` (
`id` INT,
`creator_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `channel_members` (
`channel_id` INT,
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`channel_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `channel_permissions` (
`channel_id` INT,
`user_id` INT,
`permission` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`channel_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT,
`origin_id` INT,
`dst_id` INT,
`parent_id` INT,
`body` VARCHAR(64),
`state` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
