CREATE DATABASE `db_449975_init`;
USE `db_449975_init`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`active` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`user_role_id` INT NOT NULL,
`user_id` INT,
`role` VARCHAR(50),
PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_449975_init') AS relationships;
