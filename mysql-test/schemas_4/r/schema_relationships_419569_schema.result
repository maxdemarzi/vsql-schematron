CREATE DATABASE `db_419569_schema`;
USE `db_419569_schema`;
CREATE TABLE `employee` (
`id` INT,
`department_id` INT,
`name` VARCHAR(64),
`position` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`id` INT,
`head_id` INT,
`company_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_419569_schema') AS relationships;
