CREATE DATABASE `db_401713_banco`;
USE `db_401713_banco`;
CREATE TABLE `Compra` (
`lote` INT,
`idVacina` INT,
`custo` INT,
`dataCompra` DATETIME,
`fabricacao` DATETIME,
`validade` DATETIME,
PRIMARY KEY (`lote`)
) CHARACTER SET latin1;
CREATE TABLE `Estoque` (
`idVacina` INT,
`vacAplicadas` INT,
`vacDescartadas` INT,
`dosesTotal` INT,
PRIMARY KEY (`idVacina`)
) CHARACTER SET latin1;
CREATE TABLE `Historico` (
`idVacinaGeral` INT,
`idFaixaEtaria` INT,
`idAno` INT,
`idPessoa` INT,
`idUnidadeSaude` INT,
`data` DATETIME,
`doseAtual` INT,
`idVacina` INT,
PRIMARY KEY (`idVacinaGeral`, `idFaixaEtaria`, `idAno`, `idPessoa`)
) CHARACTER SET latin1;
CREATE TABLE `Vacina_Doenca` (
`idVacina` INT,
`idDoenca` INT,
`idVacinaGeral` INT,
PRIMARY KEY (`idVacina`, `idDoenca`, `idVacinaGeral`)
) CHARACTER SET latin1;
CREATE TABLE `Vacinacao` (
`idVacinaGeral` INT,
`idFaixaEtaria` INT,
`idAno` INT,
PRIMARY KEY (`idVacinaGeral`, `idFaixaEtaria`, `idAno`)
) CHARACTER SET latin1;
