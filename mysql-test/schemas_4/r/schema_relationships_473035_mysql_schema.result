`vl_password` VARCHAR(64),
`vl_img` VARCHAR(64),
`vl_key` VARCHAR(64),
`checked` INT,
`dt_creation` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tb_proprietaries` (
`cd_proprietary` INT,
