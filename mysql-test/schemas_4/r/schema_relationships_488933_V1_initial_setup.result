CREATE DATABASE `db_488933_V1_initial_setup`;
USE `db_488933_V1_initial_setup`;
CREATE TABLE `ptah_addresses` (
`id` INT,
`street` VARCHAR(64),
`city` VARCHAR(64),
`postal_code` VARCHAR(64),
`region` VARCHAR(64),
`country_code` VARCHAR(64),
`country` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptah_group_definitions` (
`id` INT,
`identifier` VARCHAR(64),
`description` VARCHAR(64),
`minimal_size` INT,
`maximal_size` INT,
`number_of_meetings` INT,
`frequency` VARCHAR(64),
`adjustment` VARCHAR(64),
`created_on` DATETIME,
`created_by` VARCHAR(64),
`last_modified_on` DATETIME,
`last_modified_by` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptah_groups` (
`id` INT,
`identifier` VARCHAR(64),
`group_definition_id` INT,
`a_name` VARCHAR(64),
`leaders` VARCHAR(64),
`members` VARCHAR(64),
`office` VARCHAR(64),
`assigned_employee` VARCHAR(64),
`weekday` INT,
`group_status` VARCHAR(64),
`current_cycle` INT,
`address_id` INT,
`created_on` DATETIME,
`created_by` VARCHAR(64),
`last_modified_on` DATETIME,
`last_modified_by` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptah_group_commands` (
`id` INT,
`group_id` INT,
`a_action` VARCHAR(64),
`note` VARCHAR(64),
`created_on` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptah_meetings` (
`id` INT,
`group_id` INT,
`meeting_sequence` INT,
`current_cycle` INT,
`scheduled_for` DATETIME,
`held_on` DATETIME,
`duration` INT,
`created_on` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptah_attendees` (
`id` INT,
`meeting_id` INT,
`customer_identifier` VARCHAR(64),
`a_status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
