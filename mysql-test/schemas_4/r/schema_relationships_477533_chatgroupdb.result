CREATE DATABASE `db_477533_chatgroupdb`;
USE `db_477533_chatgroupdb`;
CREATE TABLE `message` (
`id` INT,
`content` VARCHAR(50),
`deleted` TINYINT,
`created_at` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(50),
`password` VARCHAR(50),
`role` INT,
`authKey` VARCHAR(50),
`accessToken` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_477533_chatgroupdb') AS relationships;
