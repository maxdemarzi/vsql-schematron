INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 440492_database
#
CREATE DATABASE `db_440492_database`;
USE `db_440492_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`description` VARCHAR(50),
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_440492_database') AS relationships;
