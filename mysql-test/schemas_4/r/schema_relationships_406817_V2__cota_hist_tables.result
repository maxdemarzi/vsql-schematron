CREATE DATABASE `db_406817_V2__cota_hist_tables`;
USE `db_406817_V2__cota_hist_tables`;
CREATE TABLE `cotahist_header` (
`id` INT NOT NULL,
`cod_ori` VARCHAR(50),
`dat_ger` DATE,
`nom_arq` VARCHAR(50),
`tip_reg` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cotahist_line` (
`id` INT NOT NULL,
`cod_neg` VARCHAR(50),
`bdi` INT,
`dt_preg` DATE,
`pre_ult` DECIMAL(10,2),
`cod_isi` VARCHAR(50),
`dat_ven` DATE,
`dismes` INT,
`especi` VARCHAR(50),
`fat_cot` INT,
`ind_opc` VARCHAR(50),
`mod_ref` VARCHAR(50),
`nom_res` VARCHAR(50),
`prazo_t` VARCHAR(50),
`pre_abe` DECIMAL(10,2),
`pre_exe` DECIMAL(10,2),
`pre_max` DECIMAL(10,2),
`pre_med` DECIMAL(10,2),
`pre_min` DECIMAL(10,2),
`pre_ofc` DECIMAL(10,2),
`pre_ofv` DECIMAL(10,2),
`pto_exe` DECIMAL(10,2),
`qua_tot` INT,
`tip_reg` INT,
`tot_neg` INT,
`tp_merc` VARCHAR(50),
`vol_tot` INT,
`header_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cotahist_trailer` (
`id` INT NOT NULL,
`cod_org` VARCHAR(50),
`dat_ger` DATE,
`nom_arq` VARCHAR(50),
`tip_reg` INT,
`tot_reg` INT,
`header_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_406817_V2__cota_hist_tables') AS relationships;
