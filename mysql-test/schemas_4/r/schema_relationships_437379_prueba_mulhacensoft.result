INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 437379_prueba_mulhacensoft
#
CREATE DATABASE `db_437379_prueba_mulhacensoft`;
USE `db_437379_prueba_mulhacensoft`;
CREATE TABLE `diagnosticos` (
`id` INT,
`id_paciente` INT,
`descripcion` VARCHAR(50),
`fecha_diagnostico` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `historico` (
`id` INT NOT NULL,
`accion` VARCHAR(50),
`tipo` INT,
`fecha` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pacientes` (
`id` INT,
`nombre` VARCHAR(50),
`dni` VARCHAR(50),
`fecha_nacimiento` DATE,
`direccion` VARCHAR(50),
`email` VARCHAR(50),
`fecha_registro` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`fecha_registro` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_437379_prueba_mulhacensoft') AS relationships;
