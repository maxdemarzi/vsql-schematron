INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 483400_hiring_channel_db_newest
#
CREATE DATABASE `db_483400_hiring_channel_db_newest`;
USE `db_483400_hiring_channel_db_newest`;
CREATE TABLE `history` (
`user_id` INT,
`corporate_id` INT,
`rating` INT,
`hire_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `type` (
`type_id` INT,
`type_name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`corporate_name` VARCHAR(64),
`type_id` INT,
`image` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`is_open` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_detail` (
`user_id` INT,
`description` VARCHAR(64),
`field` VARCHAR(64),
`skill` VARCHAR(64),
`location` VARCHAR(64),
`rating` INT,
`total_project` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_483400_hiring_channel_db_newest') AS relationships;
relationships
Database: db_483400_hiring_channel_db_newest

Table Connections:
------------------
[Implied]  history.user_id -> users.id
[Implied]  users.type_id -> type.type_id
