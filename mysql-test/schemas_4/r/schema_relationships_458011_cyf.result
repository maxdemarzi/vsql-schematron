INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 458011_cyf
#
CREATE DATABASE `db_458011_cyf`;
USE `db_458011_cyf`;
CREATE TABLE `comments` (
`id` INT,
`comment` VARCHAR(64),
`postId` INT,
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`createdBy` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`role` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_profile` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
`phone_number` VARCHAR(64),
`hobbies` VARCHAR(64),
`is_married` INT,
`school` VARCHAR(64),
`skills` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_458011_cyf') AS relationships;
relationships
Database: db_458011_cyf

Table Connections:
------------------
[Implied]  comments.postId -> posts.id
[Implied]  posts.createdBy -> users.id
[Implied]  users_profile.user_id -> users.id

DROP DATABASE `db_458011_cyf`;
UNINSTALL EXTENSION vsql_schematron;
