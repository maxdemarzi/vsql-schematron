INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 473366_schema
#
CREATE DATABASE `db_473366_schema`;
USE `db_473366_schema`;
CREATE TABLE `users` (
`user_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`enabled` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`article_id` INT,
`title` VARCHAR(64),
`body` VARCHAR(64),
`timestamp` VARCHAR(64),
`is_published` INT,
PRIMARY KEY (`article_id`)
) CHARACTER SET latin1;
CREATE TABLE `authors_articles` (
`user_id` INT,
`article_id` INT,
PRIMARY KEY (`user_id`, `article_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`comment_id` INT,
`comment` VARCHAR(64),
`article_id` INT,
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_473366_schema') AS relationships;
relationships
Database: db_473366_schema

Table Connections:
------------------
[Implied]  authors_articles.article_id -> articles.article_id
[Implied]  authors_articles.user_id -> users.user_id
[Implied]  comments.article_id -> articles.article_id
[Implied]  users_roles.role_id -> roles.role_id
[Implied]  users_roles.user_id -> users.user_id

DROP DATABASE `db_473366_schema`;
UNINSTALL EXTENSION vsql_schematron;
