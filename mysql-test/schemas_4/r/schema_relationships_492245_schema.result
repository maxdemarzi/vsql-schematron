INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 492245_schema
#
CREATE DATABASE `db_492245_schema`;
USE `db_492245_schema`;
CREATE TABLE `banner` (
`id` INT,
`project_id` INT,
`image_url` VARCHAR(64),
`image_text` VARCHAR(64),
`banner_url` VARCHAR(64),
`text_font` VARCHAR(64),
`text_color` VARCHAR(64),
`font_size` INT,
`additional_info` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `banner_position` (
`id` INT,
`banner_id` INT,
`position_index` INT,
`delay` INT,
`show_label` INT,
`x_position` INT,
`y_position` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT,
`project_id` INT,
`client_text` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client_banner` (
`id` INT,
`banner_id` INT,
`client_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT,
`name` VARCHAR(64),
`url` VARCHAR(64),
`header` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_492245_schema') AS relationships;
relationships
Database: db_492245_schema

