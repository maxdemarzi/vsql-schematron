CREATE DATABASE `db_492424_create_adventuresOverflow`;
USE `db_492424_create_adventuresOverflow`;
CREATE TABLE `sales.DimDate` (
`DateKey` INT NOT NULL,
`FullDateAlternateKey` DATE,
`EnglishDayNameOfWeek` VARCHAR(50),
`EnglishMonthName` VARCHAR(50),
`FiscalQuarter` SMALLINT,
`FiscalYear` SMALLINT,
`FiscalSemester` SMALLINT,
PRIMARY KEY (`DateKey`)
) CHARACTER SET latin1;
CREATE TABLE `sales.DimSalesTerritory` (
`SalesTerritoryKey` INT NOT NULL,
`SalesTerritoryRegion` VARCHAR(50),
`SalesTerritoryCountry` VARCHAR(50),
`SalesTerritoryGroup` VARCHAR(50),
PRIMARY KEY (`SalesTerritoryKey`)
) CHARACTER SET latin1;
CREATE TABLE `sales.DimDateHoliday` (
`DateHolidayKey` VARCHAR(50) NOT NULL,
`DateKey` INT,
`TerritoryCode` CHAR(50),
`HolidayFlag` BOOLEAN,
`HolidayName` VARCHAR(50),
PRIMARY KEY (`DateHolidayKey`)
) CHARACTER SET latin1;
CREATE TABLE `sales.DimCustomer` (
`CustomerKey` INT NOT NULL,
`GeographyKey` DATE,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`BirthDate` DATE,
`MaritalStatus` CHAR(50),
`Gender` VARCHAR(50),
`EmailAddress` VARCHAR(50),
`YearlyIncome` VARCHAR(50),
`EnglishEducation` VARCHAR(50),
`DateFirstPurchase` DATE,
`SalesTerritoryKey` INT,
`City` VARCHAR(50),
PRIMARY KEY (`CustomerKey`)
) CHARACTER SET latin1;
CREATE TABLE `sales.FactInternetSales` (
`OrderSalesNumber` INT NOT NULL,
`ProductKey` INT,
`OrderDateKey` INT,
`DueDateKey` INT,
`ShipDateKey` INT,
`CustomerKey` INT,
`SalesTerritoryKey` INT,
`OrderQuantity` SMALLINT,
`UnitPrice` VARCHAR(50),
`DiscountAmount` DECIMAL(10,2),
`SalesAmount` VARCHAR(50),
`OrderDate` TIMESTAMP NULL,
`DueDate` TIMESTAMP NULL,
`ShipDate` TIMESTAMP NULL,
PRIMARY KEY (`OrderSalesNumber`)
) CHARACTER SET latin1;
CREATE TABLE `sales.FactPosts` (
`PostKey` INT NOT NULL,
`AnswerCount` INT,
`Body` VARCHAR(50),
`ClosedDate` TIMESTAMP NULL,
`CommentCount` INT,
`CreationDate` TIMESTAMP NULL,
`FavoriteCount` INT,
`LastActivityDate` TIMESTAMP NULL,
`LastEditDate` TIMESTAMP NULL,
`Score` INT,
`Title` VARCHAR(50),
`ViewCount` INT,
`ClosedDateKey` INT,
`CreationDateKey` INT,
`LastActivityDateKey` INT,
`LastEditDateKey` INT,
PRIMARY KEY (`PostKey`)
) CHARACTER SET latin1;
