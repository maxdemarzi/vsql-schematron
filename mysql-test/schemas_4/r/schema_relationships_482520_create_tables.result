CREATE TABLE `mail_log` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`to_mail` VARCHAR(50),
`to_name` VARCHAR(50),
`subject` VARCHAR(50),
`error` VARCHAR(50),
`inserted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plane` (
`id` VARCHAR(50) NOT NULL,
`model` VARCHAR(50),
`lfz` CHAR(50),
`wkz` VARCHAR(50),
`alias` VARCHAR(50),
`available` TINYINT,
`updated_at` TIMESTAMP NULL,
`inserted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plane_selection` (
`attendance_id` VARCHAR(50) NOT NULL,
`plane_id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`attendance_id`, `plane_id`)
) CHARACTER SET latin1;
