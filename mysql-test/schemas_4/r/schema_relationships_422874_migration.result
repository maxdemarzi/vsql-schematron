PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`accessibility` BOOL,
`createdAt` DATETIME,
`updatedAt` DATETIME,
`owner` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sections` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`order` INT,
`createdAt` DATETIME,
`updatedAt` DATETIME,
`projectId` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`dueDate` DATETIME,
`description` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`sectionId` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
`role` VARCHAR(64),
`reset_token` VARCHAR(64),
`reset_token_expires` DATETIME,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
