INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 492916_demo
#
CREATE DATABASE `db_492916_demo`;
USE `db_492916_demo`;
CREATE TABLE `ADDRESS` (
`ID` INT NOT NULL,
`COUNTRY` VARCHAR(50),
`CITY` VARCHAR(50),
`STREET` VARCHAR(50),
`NUMBER` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMPANY` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`ADDRESS_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`ID` INT NOT NULL,
`FIRST_NAME` VARCHAR(50),
`LAST_NAME` VARCHAR(50),
`ADDRESS_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`CATEGORY` VARCHAR(50),
`COMPANY_ID` INT,
`PRICE` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PURCHASE` (
`ID` INT NOT NULL,
`TIME` DATETIME,
`CUSTOMER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PURCHASED_ITEMS` (
`PURCHASE_ID` INT,
`PRODUCT_ID` INT,
`QUANTITY` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_492916_demo') AS relationships;
relationships
Database: db_492916_demo

Table Connections:
------------------
[Implied]  COMPANY.ADDRESS_ID -> ADDRESS.ID
[Implied]  CUSTOMER.ADDRESS_ID -> ADDRESS.ID
[Implied]  PRODUCT.COMPANY_ID -> COMPANY.ID
[Implied]  PURCHASE.CUSTOMER_ID -> CUSTOMER.ID
[Implied]  PURCHASED_ITEMS.PRODUCT_ID -> PRODUCT.ID
[Implied]  PURCHASED_ITEMS.PURCHASE_ID -> PURCHASE.ID

DROP DATABASE `db_492916_demo`;
UNINSTALL EXTENSION vsql_schematron;
