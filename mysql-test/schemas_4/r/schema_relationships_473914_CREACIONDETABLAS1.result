`ID_PRODUCTO1` DECIMAL(10,2),
`ID_PRODUCTO2` DECIMAL(10,2),
PRIMARY KEY (`ID_PRODUCTO1`, `ID_PRODUCTO2`)
) CHARACTER SET latin1;
CREATE TABLE `INGREDIENTESSIMILARES` (
`ID_INGREDIENTE1` DECIMAL(10,2),
`ID_INGREDIENTE2` DECIMAL(10,2),
PRIMARY KEY (`ID_INGREDIENTE1`, `ID_INGREDIENTE2`)
) CHARACTER SET latin1;
