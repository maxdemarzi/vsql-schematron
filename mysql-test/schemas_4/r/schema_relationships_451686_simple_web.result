INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 451686_simple_web
#
CREATE DATABASE `db_451686_simple_web`;
USE `db_451686_simple_web`;
CREATE TABLE `product` (
`prodid` INT,
`reference` VARCHAR(64),
`price` DECIMAL(10,2),
`state` VARCHAR(64),
PRIMARY KEY (`prodid`)
) CHARACTER SET latin1;
CREATE TABLE `product_tag` (
`prodid` INT,
`tag` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `product_data` (
`proddataid` INT,
`prodid` INT,
`lang` VARCHAR(64),
`title` VARCHAR(64),
`desc_short` VARCHAR(64),
`desc_extended` VARCHAR(64),
`img_small_url` VARCHAR(64),
`img_big_url` VARCHAR(64),
PRIMARY KEY (`proddataid`)
) CHARACTER SET latin1;
CREATE TABLE `order_data` (
`orderid` INT,
`creation_date` DATETIME,
PRIMARY KEY (`orderid`)
) CHARACTER SET latin1;
CREATE TABLE `order_state` (
`orderstateid` INT,
`orderid` INT,
`state` VARCHAR(64),
`state_date` DATETIME,
PRIMARY KEY (`orderstateid`)
) CHARACTER SET latin1;
CREATE TABLE `order_product` (
`orderprodid` INT,
`orderid` INT,
`prodid` INT,
`reference` VARCHAR(64),
`title` VARCHAR(64),
`price` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`orderprodid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_451686_simple_web') AS relationships;
relationships
Database: db_451686_simple_web

Table Connections:
------------------
[Implied]  order_product.orderid -> order_data.orderid
[Implied]  order_product.prodid -> product.prodid
[Implied]  order_state.orderid -> order_data.orderid
[Implied]  product_data.prodid -> product.prodid
[Implied]  product_tag.prodid -> product.prodid

DROP DATABASE `db_451686_simple_web`;
UNINSTALL EXTENSION vsql_schematron;
