CREATE DATABASE `db_449116_1501160298`;
USE `db_449116_1501160298`;
CREATE TABLE `organization` (
`id` INT,
`organization_name` VARCHAR(64),
`kind` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organization_email_domain` (
`organization_id` INT,
`domain` VARCHAR(64),
PRIMARY KEY (`organization_id`, `domain`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
`id` INT,
`replay_name` VARCHAR(64),
`replay_bucket` INT,
`map_width` INT,
`map_height` INT,
`map_seed` INT,
`map_generator` VARCHAR(64),
`time_played` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_participant` (
`game_id` INT,
`user_id` INT,
`bot_id` INT,
`version_number` INT,
`log_name` VARCHAR(64),
`rank` INT,
`player_index` INT,
`timed_out` VARCHAR(64),
PRIMARY KEY (`game_id`, `user_id`, `bot_id`)
) CHARACTER SET latin1;
CREATE TABLE `bot_history` (
`user_id` INT,
`bot_id` INT,
`version_number` INT,
`last_rank` INT,
`last_score` DECIMAL(10,2),
`last_num_players` INT,
`last_games_played` INT,
`language` VARCHAR(64),
`when_retired` DATETIME,
PRIMARY KEY (`user_id`, `bot_id`, `version_number`)
) CHARACTER SET latin1;
CREATE TABLE `user_notification` (
`id` INT,
`user_id` INT,
`title` VARCHAR(64),
`body` VARCHAR(64),
`mood` VARCHAR(64),
`creation_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
