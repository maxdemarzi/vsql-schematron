INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 462744_schema
#
CREATE DATABASE `db_462744_schema`;
USE `db_462744_schema`;
CREATE TABLE `locations` (
`id` INT NOT NULL,
`search_query` VARCHAR(50),
`formatted_address` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weathers` (
`id` INT NOT NULL,
`forecast` VARCHAR(50),
`time` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT NOT NULL,
`link` VARCHAR(50),
`name` VARCHAR(50),
`event_date` VARCHAR(50),
`summary` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_462744_schema') AS relationships;
