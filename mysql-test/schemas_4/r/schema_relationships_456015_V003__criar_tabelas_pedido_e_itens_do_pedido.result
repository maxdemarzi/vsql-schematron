`valor_total` DECIMAL(10,2),
`status` VARCHAR(50),
`dias_entrega` INT,
`data_separacao` DATE,
`data_transporte` DATE,
`data_entrega` DATE,
`cep` CHAR(50),
`logradouro` VARCHAR(50),
`numero` VARCHAR(50),
`complemento` VARCHAR(50),
`bairro` VARCHAR(50),
`cidade` VARCHAR(50),
`uf` CHAR(50),
`referencia` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `itens_pedido` (
`id` BIGINT NOT NULL,
`id_pedido` BIGINT,
`id_produto` BIGINT,
`quantidade` INT,
`valor_unitario` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
