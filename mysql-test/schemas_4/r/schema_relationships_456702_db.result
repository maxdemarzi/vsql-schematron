) CHARACTER SET latin1;
CREATE TABLE `book` (
`BOOK_ID` INT NOT NULL,
`Title` VARCHAR(50),
`Subtitle` VARCHAR(50),
`PUBLISHER_ID` INT,
PRIMARY KEY (`BOOK_ID`)
) CHARACTER SET latin1;
