INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 409921_Ex9
#
CREATE DATABASE `db_409921_Ex9`;
USE `db_409921_Ex9`;
CREATE TABLE `Cliente` (
`idCliente` INT NOT NULL,
`nome` VARCHAR(50),
`CPF` CHAR(50),
`endereco` VARCHAR(50),
`fone` VARCHAR(50),
`CNH` CHAR(50),
`idade` INT,
PRIMARY KEY (`idCliente`)
) CHARACTER SET latin1;
CREATE TABLE `Marca` (
`idMarca` INT NOT NULL,
`marca` VARCHAR(50),
`nacionalidade` VARCHAR(50),
PRIMARY KEY (`idMarca`)
) CHARACTER SET latin1;
CREATE TABLE `Carro` (
`idCarro` INT NOT NULL,
`marca` INT,
`modelo` VARCHAR(50),
`ano` INT,
`cor` VARCHAR(50),
`placa` CHAR(50),
`nChassi` CHAR(50),
PRIMARY KEY (`idCarro`)
) CHARACTER SET latin1;
CREATE TABLE `Aluga` (
`idCliente` INT NOT NULL,
`idCarro` INT NOT NULL,
`data` DATE NOT NULL,
`km` INT,
PRIMARY KEY (`idCliente`, `idCarro`, `data`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_409921_Ex9') AS relationships;
relationships
Database: db_409921_Ex9

