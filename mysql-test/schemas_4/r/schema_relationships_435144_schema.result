CREATE DATABASE `db_435144_schema`;
USE `db_435144_schema`;
CREATE TABLE `public.users` (
`id` VARCHAR(64),
`score` INT,
`username` VARCHAR(64),
`name` VARCHAR(64),
`bio` VARCHAR(64),
`avatar` VARCHAR(64),
`hidden` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.ranks` (
`id` VARCHAR(64),
`rank` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.posts` (
`id` VARCHAR(64),
`creation_time` DATETIME,
`type` VARCHAR(64),
`creator` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_435144_schema') AS relationships;
