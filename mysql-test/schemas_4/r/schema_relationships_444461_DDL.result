INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 444461_DDL
#
CREATE DATABASE `db_444461_DDL`;
USE `db_444461_DDL`;
CREATE TABLE `account` (
`id` BIGINT NOT NULL,
`email` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
`id` BIGINT NOT NULL,
`ticker_symbol` CHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `industry` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `company_industry_affiliation` (
`id` BIGINT NOT NULL,
`company_id` BIGINT,
`industry_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stock` (
`id` BIGINT NOT NULL,
`date` DATE,
`closing_price` BIGINT,
`difference_from_yesterday` BIGINT,
`fluctuation_rate` DECIMAL(10,2),
`opening_price` BIGINT,
`high_price` BIGINT,
`low_price` BIGINT,
`market_capitalization` BIGINT,
`company_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` BIGINT NOT NULL,
`content` VARCHAR(50),
`positivity` BIGINT,
`company_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookmark` (
`id` BIGINT NOT NULL,
`account_id` BIGINT,
`company_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_444461_DDL') AS relationships;
relationships
Database: db_444461_DDL

Table Connections:
