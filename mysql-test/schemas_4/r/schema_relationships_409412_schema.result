INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 409412_schema
#
CREATE DATABASE `db_409412_schema`;
USE `db_409412_schema`;
CREATE TABLE `experiment` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`type` VARCHAR(50),
`protocol` VARCHAR(50),
`lab` VARCHAR(50),
`experimenter` VARCHAR(50),
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `experiment_property` (
`id` VARCHAR(50) NOT NULL,
`experiment_id` VARCHAR(50),
`type` VARCHAR(50),
`value` TEXT,
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sequence` (
`id` VARCHAR(50) NOT NULL,
`experiment_id` VARCHAR(50),
`name` VARCHAR(50),
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sequence_property` (
`id` VARCHAR(50) NOT NULL,
`sequence_id` VARCHAR(50),
`type` VARCHAR(50),
`value` TEXT,
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region` (
`id` VARCHAR(50) NOT NULL,
`experiment_id` VARCHAR(50),
`line` VARCHAR(50),
`name` VARCHAR(50),
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region_property` (
`id` VARCHAR(50) NOT NULL,
`region_id` VARCHAR(50),
`type` VARCHAR(50),
`value` TEXT,
`create_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_409412_schema') AS relationships;
relationships
