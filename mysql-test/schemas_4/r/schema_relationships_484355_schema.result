CREATE DATABASE `db_484355_schema`;
USE `db_484355_schema`;
CREATE TABLE `_meta` (
`k` VARCHAR(64),
`v` VARCHAR(64),
PRIMARY KEY (`k`)
) CHARACTER SET latin1;
CREATE TABLE `plug_proc` (
`plug_proc_id` VARCHAR(64),
`url` VARCHAR(64),
`tag` VARCHAR(64),
`t_ins` VARCHAR(64),
PRIMARY KEY (`plug_proc_id`)
) CHARACTER SET latin1;
CREATE TABLE `plug_strm` (
`plug_strm_id` VARCHAR(64),
`url` VARCHAR(64),
`tag` VARCHAR(64),
`t_ins` VARCHAR(64),
PRIMARY KEY (`plug_strm_id`)
) CHARACTER SET latin1;
CREATE TABLE `site` (
`site_id` VARCHAR(64),
`url` VARCHAR(64),
`auto` INT,
`t_ins` VARCHAR(64),
PRIMARY KEY (`site_id`)
) CHARACTER SET latin1;
CREATE TABLE `page` (
`page_id` VARCHAR(64),
`site_id` VARCHAR(64),
`url` VARCHAR(64),
PRIMARY KEY (`page_id`)
) CHARACTER SET latin1;
CREATE TABLE `crwl` (
`site_id` VARCHAR(64),
`site_v` VARCHAR(64),
`status` VARCHAR(64),
`plug_proc_conf` VARCHAR(64),
PRIMARY KEY (`site_id`, `site_v`)
) CHARACTER SET latin1;
CREATE TABLE `crwl_plug_proc` (
`site_id` VARCHAR(64),
`site_v` VARCHAR(64),
`plug_proc_id` VARCHAR(64),
PRIMARY KEY (`site_id`, `site_v`, `plug_proc_id`)
) CHARACTER SET latin1;
CREATE TABLE `crwl_plug_strm` (
`site_id` VARCHAR(64),
`site_v` VARCHAR(64),
`plug_strm_id` VARCHAR(64),
PRIMARY KEY (`site_id`, `site_v`, `plug_strm_id`)
) CHARACTER SET latin1;
CREATE TABLE `crwl_page` (
`site_id` VARCHAR(64),
`site_v` VARCHAR(64),
`page_id` VARCHAR(64),
`page_v` VARCHAR(64),
`plug_proc_id` VARCHAR(64),
`p_page_id` VARCHAR(64),
`p_page_v` VARCHAR(64),
`p_plug_proc_id` VARCHAR(64),
`t_ins` VARCHAR(64),
PRIMARY KEY (`site_id`, `site_v`, `page_id`, `plug_proc_id`)
) CHARACTER SET latin1;
