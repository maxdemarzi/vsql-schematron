CREATE DATABASE `db_459247_schema`;
USE `db_459247_schema`;
CREATE TABLE `main` (
`id` INT,
`date` DATETIME,
`wpm` INT,
`book_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`name` VARCHAR(64),
`author` VARCHAR(64),
`thresh_lines` INT,
`thresh_pages` INT,
`wpp` INT,
`wpl` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_459247_schema') AS relationships;
