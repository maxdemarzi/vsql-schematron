`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
`description` TEXT,
`url` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50),
`ip` BLOB,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
