INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 455712_console
#
CREATE DATABASE `db_455712_console`;
USE `db_455712_console`;
CREATE TABLE `student` (
`Number` INT NOT NULL,
`Name` CHAR(50),
`Gender` CHAR(50),
`Birth` DATE,
`Major` CHAR(50),
`Class` INT,
PRIMARY KEY (`Number`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`Number` INT NOT NULL,
`Name` CHAR(50),
`Credit` DOUBLE,
`Capacity` INT,
PRIMARY KEY (`Number`)
) CHARACTER SET latin1;
CREATE TABLE `course_teacher` (
`CourseNum` INT,
`Teacher` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `course_choose` (
`StudentNum` INT,
`CourseNum` INT,
`Teacher` CHAR(50),
`Grade` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `user` (
`Username` VARCHAR(50) NOT NULL,
`Email` CHAR(50),
`Homepage` CHAR(50),
`Telephone` CHAR(50),
`Address` CHAR(50),
PRIMARY KEY (`Username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_455712_console') AS relationships;
relationships
Database: db_455712_console

Table Connections:
------------------
[Implied]  course_choose.CourseNum -> course.Number
[Implied]  course_choose.StudentNum -> student.Number
[Implied]  course_teacher.CourseNum -> course.Number

DROP DATABASE `db_455712_console`;
UNINSTALL EXTENSION vsql_schematron;
