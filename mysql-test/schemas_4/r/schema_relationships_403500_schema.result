[Implied]  transaction.subscription_id -> subscription.id
[Implied]  transaction.user_id -> user_group.user_id
[Implied]  vat_registration.user_id -> user_group.user_id

DROP DATABASE `db_403500_schema`;
UNINSTALL EXTENSION vsql_schematron;
