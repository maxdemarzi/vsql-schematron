[Implied]  author_titles.author_id -> authors.id
[Implied]  author_titles.title_id -> titles.id
[Implied]  distributions.publisher_id -> publishers.id
[Implied]  distributions.title_id -> titles.id
[Implied]  reader_distributions.distribution_id -> distributions.id
[Implied]  reader_distributions.user_id -> authors.id
[Implied]  readers.user_id -> authors.id
[Implied]  titles.publisher_id -> publishers.id

DROP DATABASE `db_488058_up`;
UNINSTALL EXTENSION vsql_schematron;
