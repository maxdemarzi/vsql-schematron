INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 400916_db_scheme
#
CREATE DATABASE `db_400916_db_scheme`;
USE `db_400916_db_scheme`;
CREATE TABLE `hashtag` (
`hashtag_id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`hashtag_id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tags` (
`hashtag_id` INT,
`post_id` INT,
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `post` (
`post_id` INT NOT NULL,
`user_id` INT,
`caption` TEXT,
`created_at` DATETIME,
`attachment` VARCHAR(50),
`tag_id` INT,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`bio` TEXT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_400916_db_scheme') AS relationships;
relationships
Database: db_400916_db_scheme

Table Connections:
------------------
[Implied]  post.user_id -> user.user_id
[Implied]  post_tags.hashtag_id -> hashtag.hashtag_id
[Implied]  post_tags.post_id -> post.post_id

DROP DATABASE `db_400916_db_scheme`;
UNINSTALL EXTENSION vsql_schematron;
