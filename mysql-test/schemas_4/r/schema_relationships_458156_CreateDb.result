`MesureId` INT,
`ImgProduit` VARCHAR(64),
PRIMARY KEY (`IdProduit`)
) CHARACTER SET latin1;
CREATE TABLE `suivicommande` (
`IdCommande` INT,
`ClientId` INT,
`DescriptionCmd` VARCHAR(64),
`DateSortie` DATETIME,
PRIMARY KEY (`IdCommande`)
) CHARACTER SET latin1;
CREATE TABLE `geocommande` (
