PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Instructor` (
`ID` INT,
`HireDate` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Student` (
`ID` INT,
`EnrollmentDate` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Department` (
`DepartmentID` INT,
`Name` VARCHAR(64),
`Budget` VARCHAR(64),
`StartDate` VARCHAR(64),
`InstructorID` INT,
`RowVersion` VARCHAR(64),
PRIMARY KEY (`DepartmentID`)
) CHARACTER SET latin1;
CREATE TABLE `OfficeAssignment` (
`InstructorID` INT,
`Location` VARCHAR(64),
PRIMARY KEY (`InstructorID`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
`CourseID` INT,
`Title` VARCHAR(64),
`Credits` INT,
`DepartmentID` INT,
PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;
CREATE TABLE `CourseAssignment` (
`InstructorID` INT,
`CourseID` INT,
PRIMARY KEY (`CourseID`, `InstructorID`)
) CHARACTER SET latin1;
CREATE TABLE `Enrollment` (
`EnrollmentID` INT,
`CourseID` INT,
`StudentID` INT,
`Grade` INT,
PRIMARY KEY (`EnrollmentID`)
) CHARACTER SET latin1;
