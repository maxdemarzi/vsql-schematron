INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 472106_sql
#
CREATE DATABASE `db_472106_sql`;
USE `db_472106_sql`;
CREATE TABLE `Books` (
`ID` INT NOT NULL,
`Title` VARCHAR(50),
`Price` DECIMAL(10,2),
`Author` VARCHAR(50),
`IssuingCompany` VARCHAR(50),
`DateofPublication` VARCHAR(50),
`Dimensions` VARCHAR(50),
`CoverType` VARCHAR(50),
`NumberofPages` INT,
`PublishingCompany` VARCHAR(50),
`SKU` VARCHAR(50),
`Description` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
`ID` INT NOT NULL,
`Email` VARCHAR(50),
`Password` VARCHAR(50),
`Name` VARCHAR(50),
`Address` VARCHAR(50),
`Phone` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`ID` INT NOT NULL,
`CustomerID` INT,
`Date` DATETIME,
`Status` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
`BookID` INT NOT NULL,
`OrderID` INT NOT NULL,
`Amount` INT,
`UnitPrice` DECIMAL(10,2),
PRIMARY KEY (`BookID`, `OrderID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_472106_sql') AS relationships;
relationships
Database: db_472106_sql

Table Connections:
------------------
[Implied]  OrderDetails.BookID -> Books.ID
[Implied]  OrderDetails.OrderID -> Orders.ID
[Implied]  Orders.CustomerID -> Customers.ID

DROP DATABASE `db_472106_sql`;
UNINSTALL EXTENSION vsql_schematron;
