`name` VARCHAR(64),
`external_id` VARCHAR(64),
`description` VARCHAR(64),
`parent` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_role` (
`project_id` INT,
`username` VARCHAR(64),
`role` INT,
PRIMARY KEY (`project_id`, `username`)
) CHARACTER SET latin1;
