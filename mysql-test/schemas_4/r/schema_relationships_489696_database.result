INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 489696_database
#
CREATE DATABASE `db_489696_database`;
USE `db_489696_database`;
CREATE TABLE `product` (
`idProduct` INT NOT NULL,
`title` TEXT,
`optprice` INT,
`rozprice` TEXT,
`description` VARCHAR(50),
PRIMARY KEY (`idProduct`)
) CHARACTER SET latin1;
CREATE TABLE `deal` (
`idDeal` INT NOT NULL,
`dealdate` DATE,
`idProduct` INT,
`kolvo` INT,
`idCustomer` INT,
`isOpt` BOOLEAN,
PRIMARY KEY (`idDeal`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`idCustomer` INT NOT NULL,
`phone` TEXT,
`name` TEXT,
`address` TEXT,
PRIMARY KEY (`idCustomer`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_489696_database') AS relationships;
