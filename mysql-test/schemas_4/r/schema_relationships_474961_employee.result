INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 474961_employee
#
CREATE DATABASE `db_474961_employee`;
USE `db_474961_employee`;
CREATE TABLE `employee` (
`employee_name` VARCHAR(64),
`street` VARCHAR(64),
`city` VARCHAR(64),
PRIMARY KEY (`employee_name`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
`company_name` VARCHAR(64),
`city` VARCHAR(64),
PRIMARY KEY (`company_name`)
) CHARACTER SET latin1;
CREATE TABLE `works` (
`employee_name` VARCHAR(64),
`company_name` VARCHAR(64),
`salary` DECIMAL(10,2),
PRIMARY KEY (`employee_name`)
) CHARACTER SET latin1;
CREATE TABLE `manages` (
`employee_name` VARCHAR(64),
`manager_name` VARCHAR(64),
PRIMARY KEY (`employee_name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_474961_employee') AS relationships;
relationships
Database: db_474961_employee

