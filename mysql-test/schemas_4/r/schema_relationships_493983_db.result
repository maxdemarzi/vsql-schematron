INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 493983_db
#
CREATE DATABASE `db_493983_db`;
USE `db_493983_db`;
CREATE TABLE `group_authorities` (
`group_id` INT,
`authority` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`id` INT,
`username` VARCHAR(64),
`group_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` INT,
`group_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`username` VARCHAR(64),
`password` VARCHAR(64),
`enabled` INT,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_493983_db') AS relationships;
