`revision_date` TIMESTAMP NULL,
`name` VARCHAR(50),
`content` VARCHAR(50),
`revision_note` VARCHAR(50),
`is_undone` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bans` (
`id` INT NOT NULL,
`user_id` INT,
`untill` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classifications` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`short_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cognates` (
`id` INT NOT NULL,
`word_id_1` INT,
`word_id_2` INT,
`score` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `columns` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`short_name` VARCHAR(50),
`hidden_native_entry` VARCHAR(50),
`hidden_native_entry_short` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `column_apply` (
`id` INT NOT NULL,
`column_id` INT,
