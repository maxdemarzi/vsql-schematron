`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `s_role_permission` (
`id_role` VARCHAR(64),
`id_permission` VARCHAR(64),
