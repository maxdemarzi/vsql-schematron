) CHARACTER SET latin1;
CREATE TABLE `s_user` (
`id` VARCHAR(64),
`username` VARCHAR(64),
`active` VARCHAR(64),
`id_role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `s_user_password` (
`id` VARCHAR(64),
`id_user` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
