INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 413306_data
#
CREATE DATABASE `db_413306_data`;
USE `db_413306_data`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`joined_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`title` VARCHAR(64),
`author` VARCHAR(64),
`description` VARCHAR(64),
`year` INT,
`borrowed_by` INT,
`borrowed_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_413306_data') AS relationships;
