CREATE DATABASE `db_432337_V001_INIT_DATABASE`;
USE `db_432337_V001_INIT_DATABASE`;
CREATE TABLE `PERSON` (
`ID` INT,
`EMAIL` VARCHAR(64),
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TODO` (
`ID` INT,
`DESCRIPTION` VARCHAR(64),
`DUE_DATE` DATETIME,
`PRIORITY` INT,
`STATUS` VARCHAR(64),
`TITLE` VARCHAR(64),
`OWNER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `NOTE` (
`ID` INT,
`CONTENT` VARCHAR(64),
`TODO_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON_OWNED_TODOS` (
`PERSON_ID` INT,
`OWNED_TODOS_ID` INT
) CHARACTER SET latin1;
CREATE TABLE `REMINDER` (
`ID` INT,
`DUE_DATE` DATETIME,
`TODO_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TODO_COLLABORATION` (
`TODO_ID` INT,
`COLLABORATOR_ID` INT
) CHARACTER SET latin1;
CREATE TABLE `TODO_COLLABORATION_REQUEST` (
`ID` INT,
`COLLABORATOR_ID` INT,
`TODO_ID` INT,
`TOKEN` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_432337_V001_INIT_DATABASE') AS relationships;
