CREATE TABLE `vehicle` (
`id` INT NOT NULL,
`make` VARCHAR(50),
`model` VARCHAR(50),
`year` INT,
`description` VARCHAR(50),
`retailprice` DECIMAL(10,2),
`availablestarting` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehiclepart` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`partnumber` VARCHAR(50),
`vehicleid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
