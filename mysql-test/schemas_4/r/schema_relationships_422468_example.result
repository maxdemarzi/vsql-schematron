INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 422468_example
#
CREATE DATABASE `db_422468_example`;
USE `db_422468_example`;
CREATE TABLE `contact` (
`ID` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birth_date` DATETIME,
`version` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `hobby` (
`hobby_id` VARCHAR(64),
PRIMARY KEY (`hobby_id`)
) CHARACTER SET latin1;
CREATE TABLE `contact_tel_detail` (
`id` INT,
`contact_id` INT,
`tel_type` VARCHAR(64),
`tel_number` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact_hobby_detail` (
`contact_id` INT,
`hobby_id` VARCHAR(64),
PRIMARY KEY (`contact_id`, `hobby_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_422468_example') AS relationships;
