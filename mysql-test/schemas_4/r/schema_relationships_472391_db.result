INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 472391_db
#
CREATE DATABASE `db_472391_db`;
USE `db_472391_db`;
CREATE TABLE `player` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`code` VARCHAR(50),
`last` INT,
`medals` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player_country` (
`player_id` INT,
`country_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_472391_db') AS relationships;
