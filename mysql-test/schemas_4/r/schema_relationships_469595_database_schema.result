[Implied]  contributions.user_id -> users.user_id
[Implied]  fullfillments.campaign_id -> campaigns.campaign_id
[Implied]  recipients.campaign_id -> campaigns.campaign_id
[Implied]  recipients.user_id -> users.user_id
[Implied]  revocations.commitment_id -> commitments.commitment_id

DROP DATABASE `db_469595_database_schema`;
UNINSTALL EXTENSION vsql_schematron;
