INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 401515_help
#
CREATE DATABASE `db_401515_help`;
USE `db_401515_help`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`registration_time` TIMESTAMP NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`is_moderator` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`date` TIMESTAMP NULL,
`header` VARCHAR(50),
`description` BLOB,
`comments_count` INT,
`tags` BLOB,
`user_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_401515_help') AS relationships;
relationships
