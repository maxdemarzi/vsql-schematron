CREATE DATABASE `db_402477_erratums_shome`;
USE `db_402477_erratums_shome`;
CREATE TABLE `boardtype` (
`BOARDID` INT,
`BOARDNAME` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `devices` (
`DEVICEID` INT,
`DEVICENAME` VARCHAR(64),
`USERID` INT,
`LAYOUTINDEX` INT,
`BOARDID` INT,
`UNIQUEID` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `gadgets` (
`GADGETID` INT,
`GADGETNAME` VARCHAR(64),
`DEVICEID` INT,
`PINTYPE` VARCHAR(64),
`LAYOUTINDEX` INT,
`HIDEPAIR` VARCHAR(64),
`INVERTED` VARCHAR(64),
`VALUE` VARCHAR(64),
`IMAGECODE` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `options` (
`OID` INT,
`OPT_NAME` VARCHAR(64),
`OPT_VALUE` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`USERID` INT,
`USERNAME` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`CREATED_AT` DATETIME,
PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_402477_erratums_shome') AS relationships;
