CREATE DATABASE `db_445085_EventDAL`;
USE `db_445085_EventDAL`;
CREATE TABLE `UserDB` (
`user_name` VARCHAR(64),
`user_password` VARCHAR(64),
`name_user` VARCHAR(64),
`age` INT,
`type_account` INT,
`job` VARCHAR(64),
`address` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` INT,
PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;
CREATE TABLE `EventDB` (
`event_id` INT,
`event_name` VARCHAR(64),
`address` VARCHAR(64),
`description` VARCHAR(64),
`event_time` VARCHAR(64),
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `EventDetailsDB` (
`username` VARCHAR(64),
`event_id` INT,
`event_status` VARCHAR(64),
PRIMARY KEY (`username`, `event_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_445085_EventDAL') AS relationships;
