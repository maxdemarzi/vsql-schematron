) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`idcli` INT NOT NULL,
`nome` VARCHAR(50),
`fone` VARCHAR(50),
PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
`os` INT NOT NULL,
`equipamento` VARCHAR(50),
`defeito` VARCHAR(50),
`dataos` TIMESTAMP NULL,
`statusOs` VARCHAR(50),
`valor` DECIMAL(10,2),
`idcli` INT,
PRIMARY KEY (`os`)
) CHARACTER SET latin1;
