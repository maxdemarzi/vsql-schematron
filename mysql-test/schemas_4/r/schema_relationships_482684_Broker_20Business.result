INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 482684_Broker%20Business
#
CREATE DATABASE `db_482684_Broker_20Business`;
USE `db_482684_Broker_20Business`;
CREATE TABLE `cities` (
`id` INT,
`name` VARCHAR(64),
`country_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `companies` (
`id` INT,
`name` VARCHAR(64),
`rate` INT,
`created_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `building_types` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `persons` (
`id` INT,
`username` VARCHAR(64),
`company_id` INT,
`city_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person_info` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`money` DECIMAL(10,2),
`person_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `buildings` (
`id` INT,
`name` VARCHAR(64),
`rent_amount` DECIMAL(10,2),
`height` DECIMAL(10,2),
`floors` INT,
`finished_year` INT,
`status` VARCHAR(64),
`city_id` INT,
`type_id` INT,
`company_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `persons_buildings` (
`person_id` INT,
`building_id` INT,
PRIMARY KEY (`person_id`, `building_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_482684_Broker_20Business') AS relationships;
relationships
Database: db_482684_Broker_20Business

Table Connections:
------------------
[Implied]  buildings.city_id -> cities.id
[Implied]  buildings.company_id -> companies.id
[Implied]  person_info.person_id -> persons.id
[Implied]  persons.city_id -> cities.id
[Implied]  persons.company_id -> companies.id
[Implied]  persons_buildings.building_id -> buildings.id
[Implied]  persons_buildings.person_id -> persons.id

DROP DATABASE `db_482684_Broker_20Business`;
UNINSTALL EXTENSION vsql_schematron;
