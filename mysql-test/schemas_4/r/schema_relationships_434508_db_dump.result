INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 434508_db_dump
#
CREATE DATABASE `db_434508_db_dump`;
USE `db_434508_db_dump`;
CREATE TABLE `Chill` (
`version` INT
) CHARACTER SET latin1;
CREATE TABLE `Query` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Template` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Node` (
`id` INT,
`name` VARCHAR(64),
`value` VARCHAR(64),
`template` INT,
`query` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Node_Node` (
`node_id` INT,
`target_node_id` INT
) CHARACTER SET latin1;
CREATE TABLE `Route` (
`id` INT,
`path` VARCHAR(64),
`node_id` INT,
`weight` INT,
`method` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_434508_db_dump') AS relationships;
