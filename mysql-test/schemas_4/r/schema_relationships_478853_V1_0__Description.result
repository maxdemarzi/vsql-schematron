CREATE DATABASE `db_478853_V1_0__Description`;
USE `db_478853_V1_0__Description`;
CREATE TABLE `oauth_client_details` (
`client_id` VARCHAR(50) NOT NULL,
`client_secret` VARCHAR(50),
`resource_ids` VARCHAR(50),
`scope` VARCHAR(50),
`authorized_grant_types` VARCHAR(50),
`web_server_redirect_uri` VARCHAR(50),
`authorities` VARCHAR(50),
`access_token_validity` INT,
`refresh_token_validity` INT,
`additional_information` VARCHAR(50),
`autoapprove` VARCHAR(50),
PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`nombre_usuario` VARCHAR(50),
`contrasena` VARCHAR(50),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id_rol` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `usuario_rol` (
`id_rol` INT,
`id_usuario` INT
) CHARACTER SET latin1;
