INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 434203_Create_JABCHR_Schema
#
CREATE DATABASE `db_434203_Create_JABCHR_Schema`;
USE `db_434203_Create_JABCHR_Schema`;
CREATE TABLE `ROLE` (
`ROLE_ID` INT,
`ROLE_NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
PRIMARY KEY (`ROLE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
`EMPLOYEE_ID` INT,
PRIMARY KEY (`EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `HR_RECORD` (
`EMPLOYEE_ID` INT,
`VERSION` INT,
`CREATED_BY` INT,
`ROLE` INT,
`SIN` INT,
`EMAIL` VARCHAR(64),
`FIRST_NAME` VARCHAR(64),
`LAST_NAME` VARCHAR(64),
`ADDRESS` VARCHAR(64),
`BIRTHDATE` DATETIME,
`VACATION_DAYS` INT,
`REMAINING_VACATION_DAYS` INT,
`FTE` INT,
`STATUS` INT,
`PASSWORD` VARCHAR(64),
`SALARY` DECIMAL(10,2),
`DATE_JOINED` DATETIME,
`ADMIN_LEVEL` INT,
`CREATED_DATE` DATETIME,
`PHONE_NUMBER` VARCHAR(64),
PRIMARY KEY (`EMPLOYEE_ID`, `VERSION`)
) CHARACTER SET latin1;
CREATE TABLE `DOC_TYPE` (
`DOC_TYPE_ID` INT,
`DOC_NAME` VARCHAR(64),
`TEMPLATE_FILE` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`MIME_TYPE` VARCHAR(64),
PRIMARY KEY (`DOC_TYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ONBOARDING_TASK` (
`ONBOARDING_TASK_ID` INT,
`EMPLOYEE_ID` INT,
`CREATED_DATE` DATETIME,
`DUE_DATE` DATETIME,
`EXPIRY_DATE` DATETIME,
`DESCRIPTION` VARCHAR(64),
`DOC_TYPE_ID` INT,
`ACTUAL_FILE` VARCHAR(64),
`REQUIRE_DOC` INT,
`STATUS` INT,
`MIME_TYPE` VARCHAR(64),
PRIMARY KEY (`ONBOARDING_TASK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `VACATION_REQUEST` (
`VACATION_REQUEST_ID` INT,
`EMPLOYEE_ID` INT,
`APPROVER_ID` INT,
`REQUESTED_DAYS` INT,
`REQUEST_STATUS` INT,
`DATE` DATETIME,
PRIMARY KEY (`VACATION_REQUEST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERFORMANCE_PLAN` (
`PERFORMANCE_PLAN_ID` INT,
`START_YEAR` INT,
`STATUS` INT,
`EMPLOYEE_ID` INT,
`END_YEAR` INT,
`CREATE_DATE` DATETIME,
PRIMARY KEY (`PERFORMANCE_PLAN_ID`, `EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROBATION` (
`PROBATION_ID` INT,
`START_DATE` DATETIME,
`REVIEW_DATE` DATETIME,
`STATUS` INT,
`EMPLOYEE_ID` INT,
PRIMARY KEY (`PROBATION_ID`, `EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `QUESTION` (
`QUESTION_ID` INT,
`QUESTION` VARCHAR(64),
`ANSWER` VARCHAR(64),
`PROBATION_ID` INT,
PRIMARY KEY (`QUESTION_ID`, `PROBATION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MANAGER_EMPLOYEE` (
`MANAGER_ID` INT,
`EMPLOYEE_ID` INT,
PRIMARY KEY (`MANAGER_ID`, `EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERFORMANCE_REVIEW` (
`PERFORMANCE_REVIEW_ID` INT,
`WORK_PLAN_ID` INT,
`STATUS` INT,
`EMPLOYEE_ID` INT,
`CREATE_DATE` DATETIME,
PRIMARY KEY (`PERFORMANCE_REVIEW_ID`, `EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERFORMANCE_SECTION` (
`SECTION_ID` INT,
`DATA` VARCHAR(64),
`PERFORMANCE_REVIEW_ID` INT,
`PERFORMANCE_PLAN_ID` INT,
`SECTION_NAME` VARCHAR(64),
PRIMARY KEY (`SECTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMPETENCY` (
`COMPETENCY_ID` INT,
`ROLE_ID` INT,
`COMPETENCY_NAME` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
PRIMARY KEY (`COMPETENCY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMMENT` (
`COMMENT_ID` INT,
`DATE` DATETIME,
`PERFORMANCE_PLAN_ID` INT,
`COMMENTER_ID` INT,
`PERFORMANCE_REVIEW_ID` INT,
`COMMENT` VARCHAR(64),
PRIMARY KEY (`COMMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `FAQ` (
`FAQ_ID` INT,
`QUESTION` VARCHAR(64),
`ANSWER` VARCHAR(64),
PRIMARY KEY (`FAQ_ID`)
) CHARACTER SET latin1;
