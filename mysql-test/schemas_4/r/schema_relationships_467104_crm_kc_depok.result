CREATE DATABASE `db_467104_crm_kc_depok`;
USE `db_467104_crm_kc_depok`;
CREATE TABLE `admin_task` (
`admin_task_id` INT,
`start_date` DATETIME,
`end_date` DATETIME,
`data_source` VARCHAR(255),
`company_id` INT,
`user_id` INT,
`created_by` VARCHAR(255),
`created_at` DATETIME,
`updated_by` VARCHAR(255),
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `company` (
`company_id` INT,
`name` VARCHAR(255),
`address` VARCHAR(255),
`contact` VARCHAR(255),
`pic_name` VARCHAR(255),
`email` VARCHAR(255),
`employee` INT,
`employee_family` INT,
`created_by` VARCHAR(255),
`created_at` DATETIME,
`updated_by` VARCHAR(255),
`updated_at` DATETIME,
PRIMARY KEY (`company_id`)
) CHARACTER SET latin1;
CREATE TABLE `parameter` (
`name` VARCHAR(255),
`value` VARCHAR(255),
`description` VARCHAR(255),
PRIMARY KEY (`name`, `value`)
) CHARACTER SET latin1;
CREATE TABLE `ro_task` (
`ro_task_id` INT,
`admin_task_id` INT,
`call_date` DATETIME,
`call_response` VARCHAR(255),
`result` VARCHAR(255),
`notes` VARCHAR(255),
`created_by` VARCHAR(255),
`created_at` DATETIME,
`updated_by` VARCHAR(255),
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT,
`npp` VARCHAR(255),
`email` VARCHAR(255),
`username` VARCHAR(255),
`fullname` VARCHAR(255),
`address` VARCHAR(255),
`role` VARCHAR(255),
`password` VARCHAR(255),
`is_active` INT,
`last_login` DATETIME,
`created_by` VARCHAR(255),
`created_at` DATETIME,
`updated_by` VARCHAR(255),
`updated_at` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_467104_crm_kc_depok') AS relationships;
