INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 449380_postgresql-reviews
#
CREATE DATABASE `db_449380_postgresql_reviews`;
USE `db_449380_postgresql_reviews`;
CREATE TABLE `characteristics` (
`id` INT NOT NULL,
`product_id` BIGINT,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characteristic_reviews` (
`id` INT NOT NULL,
`characteristic_id` BIGINT,
`review_id` BIGINT,
`value` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews_temp` (
`id` BIGINT,
`product_id` BIGINT,
`rating` SMALLINT,
`date` VARCHAR(50),
`summary` VARCHAR(50),
`body` VARCHAR(50),
`recommend` VARCHAR(50),
`reported` VARCHAR(50),
`reviewer_name` VARCHAR(50),
`reviewer_email` VARCHAR(50),
`response` VARCHAR(50),
`helpfulness` SMALLINT
) CHARACTER SET latin1;
CREATE TABLE `reviews_photos` (
`id` INT NOT NULL,
`review_id` BIGINT,
`url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_449380_postgresql_reviews') AS relationships;
