INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 407201_schema
#
CREATE DATABASE `db_407201_schema`;
USE `db_407201_schema`;
CREATE TABLE `types` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owners` (
`id_owner` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`telephone` VARCHAR(64),
PRIMARY KEY (`id_owner`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
`id_pet` INT,
`name` VARCHAR(64),
`birth_date` DATETIME,
`type_id` INT,
`owner_id` INT,
PRIMARY KEY (`id_pet`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_407201_schema') AS relationships;
relationships
Database: db_407201_schema

Table Connections:
