CREATE DATABASE `db_458817_student_exams`;
USE `db_458817_student_exams`;
CREATE TABLE `students` (
`student_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `exams` (
`exam_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`exam_id`)
) CHARACTER SET latin1;
CREATE TABLE `students_exams` (
`student_id` INT NOT NULL,
`exam_id` INT NOT NULL,
PRIMARY KEY (`student_id`, `exam_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_458817_student_exams') AS relationships;
