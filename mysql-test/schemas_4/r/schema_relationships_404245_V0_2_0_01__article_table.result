CREATE DATABASE `db_404245_V0_2_0_01__article_table`;
USE `db_404245_V0_2_0_01__article_table`;
CREATE TABLE `article` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entity` (
`entity_value` VARCHAR(50) NOT NULL,
`entity_value_raw` VARCHAR(50),
`entity_type` VARCHAR(50),
PRIMARY KEY (`entity_value`)
) CHARACTER SET latin1;
CREATE TABLE `entity_score` (
`id` VARCHAR(50),
`entity_value` VARCHAR(50),
`average_score` INT,
`number_of_mentions` INT,
`weight` INT,
`article_id` VARCHAR(50),
`document_score_id` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_404245_V0_2_0_01__article_table') AS relationships;
