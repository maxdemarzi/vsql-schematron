INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 480693_up
#
CREATE DATABASE `db_480693_up`;
USE `db_480693_up`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`created_at` TIMESTAMP NULL,
`name` TEXT,
`screen_name` TEXT,
`bcrypt_hash` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ssh_keys` (
`id` INT NOT NULL,
`created_at` TIMESTAMP NULL,
`key` TEXT,
`user_id` INT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT NOT NULL,
`created_at` TIMESTAMP NULL,
`user_id` INT,
`name` TEXT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_480693_up') AS relationships;
