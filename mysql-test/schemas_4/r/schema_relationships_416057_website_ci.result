`artikel_konten` VARCHAR(255),
`artikel_sampul` VARCHAR(255),
`artikel_author` INT,
`artikel_kategori` INT,
`artikel_status` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `galeri` (
`galeri_id` INT,
`galeri_judul` VARCHAR(255),
`galeri_tanggal` DATETIME,
`galeri_gambar` VARCHAR(255),
`galeri_album_id` INT,
`galeri_author` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `jabatan` (
`jabatan_id` INT,
`jabatan_nama` VARCHAR(255),
PRIMARY KEY (`jabatan_id`)
) CHARACTER SET latin1;
CREATE TABLE `jurusan` (
