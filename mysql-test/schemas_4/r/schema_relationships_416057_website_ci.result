`tanggal_selesai` DATETIME,
`pengumuman_author` VARCHAR(255),
PRIMARY KEY (`pengumuman_id`)
) CHARACTER SET latin1;
CREATE TABLE `siswa` (
`siswa_id` INT,
`siswa_nis` VARCHAR(255),
`siswa_nama` VARCHAR(255),
`siswa_jenis_kelamin` VARCHAR(255),
`siswa_jabatan_id` INT,
`siswa_kelas_id` INT,
`siswa_jurusan_id` INT,
