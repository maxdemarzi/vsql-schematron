CREATE DATABASE `db_416057_website_ci`;
USE `db_416057_website_ci`;
CREATE TABLE `agenda` (
`agenda_id` INT,
`agenda_nama` VARCHAR(255),
`agenda_tanggal` DATETIME,
`agenda_deskripsi` VARCHAR(255),
`agenda_mulai` DATETIME,
`agenda_selesai` DATETIME,
`agenda_tempat` VARCHAR(255),
`agenda_waktu` VARCHAR(255),
`agenda_author` VARCHAR(255),
PRIMARY KEY (`agenda_id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
`album_id` INT,
`album_nama` VARCHAR(255),
`album_slug` VARCHAR(255),
`album_tanggal` DATETIME,
PRIMARY KEY (`album_id`)
) CHARACTER SET latin1;
CREATE TABLE `artikel` (
`artikel_id` INT,
`artikel_tanggal` DATETIME,
`artikel_judul` VARCHAR(255),
