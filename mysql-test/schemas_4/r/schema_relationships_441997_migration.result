CREATE DATABASE `db_441997_migration`;
USE `db_441997_migration`;
CREATE TABLE `users` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified` DATETIME,
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` VARCHAR(64),
`user_id` VARCHAR(64),
`type` VARCHAR(64),
`provider` VARCHAR(64),
`provider_account_id` VARCHAR(64),
`refresh_token` VARCHAR(64),
`access_token` VARCHAR(64),
`token_type` VARCHAR(64),
`expires_at` INT,
`scope` VARCHAR(64),
`id_token` VARCHAR(64),
`session_state` VARCHAR(64),
`oauth_token_secret` VARCHAR(64),
`oauth_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`id` VARCHAR(64),
`session_token` VARCHAR(64),
`user_id` VARCHAR(64),
`expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `verification_requests` (
`id` VARCHAR(64),
`identifier` VARCHAR(64),
`token` VARCHAR(64),
`expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` VARCHAR(64),
`active` BOOL,
`name` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`metadata` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `prices` (
`id` VARCHAR(64),
`product_id` VARCHAR(64),
`active` BOOL,
`currency` VARCHAR(64),
`interval` INT,
`unit_amount` INT,
`interval_count` INT,
`trial_period_days` INT,
`type` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subscriptions` (
`id` VARCHAR(64),
`user_id` VARCHAR(64),
`priceId` VARCHAR(64),
`status` VARCHAR(64),
`start_date` DATETIME,
`ended_at` DATETIME,
`trial_end` DATETIME,
`trial_start` DATETIME,
`cancel_at` DATETIME,
`cancel_at_period_end` BOOL,
`canceled_at` DATETIME,
`metadata` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
