INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 432784_posta
#
CREATE DATABASE `db_432784_posta`;
USE `db_432784_posta`;
CREATE TABLE `comments` (
`comment_id` INT,
`comment_name` VARCHAR(64),
`post_id` INT,
`comment_user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`migration` VARCHAR(64),
`batch` INT
) CHARACTER SET latin1;
CREATE TABLE `notification` (
`notification_id` INT,
`comment_user_id` INT,
`post_id` INT,
`comment_user_name` VARCHAR(64),
`post_user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`post_id` INT,
`post_name` VARCHAR(64),
`post_user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`remember_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_432784_posta') AS relationships;
relationships
Database: db_432784_posta

Table Connections:
