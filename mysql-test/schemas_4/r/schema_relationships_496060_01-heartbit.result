CREATE TABLE `Users` (
`ID` INT NOT NULL,
`LastName` VARCHAR(50),
`FirstName` VARCHAR(50),
`Email` VARCHAR(50),
`GenderCode` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UserData` (
`DataID` INT NOT NULL,
`Heartrate` INT,
`GeoLocation` INT,
`TimeStamp` TIMESTAMP NULL,
`Pulse` INT,
`UserID` INT,
PRIMARY KEY (`DataID`)
) CHARACTER SET latin1;
