CREATE DATABASE `db_470215_create_tables`;
USE `db_470215_create_tables`;
CREATE TABLE `Users` (
`id` INT,
`display_name` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`image_url` VARCHAR(64),
`last_active` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SigninOptions` (
`service_name` VARCHAR(64),
`email` VARCHAR(64),
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`service_name`, `email`)
) CHARACTER SET latin1;
CREATE TABLE `Contacts` (
`contact_id` INT,
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`contact_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Conversations` (
`id` INT,
`title` VARCHAR(64),
`image_url` VARCHAR(64),
`user_editable_image` VARCHAR(64),
`user_editable_title` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Participants` (
`user_id` INT,
`conversation_id` INT,
`is_admin` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`user_id`, `conversation_id`)
) CHARACTER SET latin1;
CREATE TABLE `Messages` (
`id` INT,
`content` VARCHAR(64),
`conversation_id` INT,
`sender_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
