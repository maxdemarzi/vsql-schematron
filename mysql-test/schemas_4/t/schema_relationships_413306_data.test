INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 413306_data
--echo #
CREATE DATABASE `db_413306_data`;
USE `db_413306_data`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `joined_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `description` VARCHAR(64),
  `year` INT,
  `borrowed_by` INT,
  `borrowed_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_413306_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_413306_data') AS relationships;
DROP DATABASE `db_413306_data`;
UNINSTALL EXTENSION vsql_schematron;
