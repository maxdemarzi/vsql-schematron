INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455647_database
--echo #
CREATE DATABASE `db_455647_database`;
USE `db_455647_database`;

CREATE TABLE `chefs` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `file_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` INT,
  `name` VARCHAR(255),
  `path` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipe_files` (
  `id` INT,
  `recipe_id` INT,
  `file_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `reset_token` VARCHAR(255),
  `reset_token_expires` VARCHAR(255),
  `is_admin` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455647_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455647_database') AS relationships;
DROP DATABASE `db_455647_database`;
UNINSTALL EXTENSION vsql_schematron;
