INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 404100_007-cldr-bcp-47-extensions
--echo #
CREATE DATABASE `db_404100_007_cldr_bcp_47_extensions`;
USE `db_404100_007_cldr_bcp_47_extensions`;

CREATE TABLE `subtag_ext_key_value_type` (
  `value_type` VARCHAR(64),
  PRIMARY KEY (`value_type`)
) CHARACTER SET latin1;

CREATE TABLE `subtag_ext_key` (
  `ext_id` VARCHAR(64),
  `id` VARCHAR(64),
  `description` VARCHAR(64),
  `deprecated` VARCHAR(64),
  `preferred` VARCHAR(64),
  `alias` VARCHAR(64),
  `value_type` VARCHAR(64),
  PRIMARY KEY (`ext_id`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `subtag_ext_key_type` (
  `ext_id` VARCHAR(64),
  `key_id` VARCHAR(64),
  `id` VARCHAR(64),
  `description` VARCHAR(64),
  `deprecated` VARCHAR(64),
  `preferred` VARCHAR(64),
  `alias` VARCHAR(64),
  PRIMARY KEY (`ext_id`, `key_id`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `subtag_ext_attr` (
  `id` VARCHAR(64),
  `description` VARCHAR(64),
  `deprecated` VARCHAR(64),
  `preferred` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_404100_007_cldr_bcp_47_extensions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_404100_007_cldr_bcp_47_extensions') AS relationships;
DROP DATABASE `db_404100_007_cldr_bcp_47_extensions`;
UNINSTALL EXTENSION vsql_schematron;
