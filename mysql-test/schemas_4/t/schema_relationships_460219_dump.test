INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 460219_dump
--echo #
CREATE DATABASE `db_460219_dump`;
USE `db_460219_dump`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `invitedUser` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_460219_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_460219_dump') AS relationships;
DROP DATABASE `db_460219_dump`;
UNINSTALL EXTENSION vsql_schematron;
