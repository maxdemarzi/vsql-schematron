INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417723_V6__metrics
--echo #
CREATE DATABASE `db_417723_V6_metrics`;
USE `db_417723_V6_metrics`;

CREATE TABLE `users.metrics_tokens_costs_history` (
  `id` INT,
  `key` VARCHAR(64),
  `cost` DECIMAL(10,2),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users.metrics_tokens_costs` (
  `id` INT,
  `key` VARCHAR(64),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users.metrics_tokens_usage` (
  `id` INT,
  `job_uuid` VARCHAR(64),
  `key` VARCHAR(64),
  `units` INT,
  `tokens` DECIMAL(10,2),
  `version` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417723_V6_metrics') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417723_V6_metrics') AS relationships;
DROP DATABASE `db_417723_V6_metrics`;
UNINSTALL EXTENSION vsql_schematron;
