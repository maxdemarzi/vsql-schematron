INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444656_music
--echo #
CREATE DATABASE `db_444656_music`;
USE `db_444656_music`;

CREATE TABLE `album` (
  `id` INT,
  `title` VARCHAR(255),
  `release_year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `artist` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `track` (
  `id` INT,
  `title` VARCHAR(255),
  `album_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `artist_album` (
  `artist_id` INT,
  `album_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444656_music') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444656_music') AS relationships;
DROP DATABASE `db_444656_music`;
UNINSTALL EXTENSION vsql_schematron;
