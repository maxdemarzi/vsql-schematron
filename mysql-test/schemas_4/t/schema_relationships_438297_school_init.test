INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438297_school-init
--echo #
CREATE DATABASE `db_438297_school_init`;
USE `db_438297_school_init`;

CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(64),
  `ProductVersion` VARCHAR(64),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;

CREATE TABLE `Person` (
  `ID` INT,
  `LastName` VARCHAR(64),
  `FirstName` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Instructor` (
  `ID` INT,
  `HireDate` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `ID` INT,
  `EnrollmentDate` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Department` (
  `DepartmentID` INT,
  `Name` VARCHAR(64),
  `Budget` VARCHAR(64),
  `StartDate` VARCHAR(64),
  `InstructorID` INT,
  `RowVersion` VARCHAR(64),
  PRIMARY KEY (`DepartmentID`)
) CHARACTER SET latin1;

CREATE TABLE `OfficeAssignment` (
  `InstructorID` INT,
  `Location` VARCHAR(64),
  PRIMARY KEY (`InstructorID`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `CourseID` INT,
  `Title` VARCHAR(64),
  `Credits` INT,
  `DepartmentID` INT,
  PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;

CREATE TABLE `CourseAssignment` (
  `InstructorID` INT,
  `CourseID` INT,
  PRIMARY KEY (`CourseID`, `InstructorID`)
) CHARACTER SET latin1;

CREATE TABLE `Enrollment` (
  `EnrollmentID` INT,
  `CourseID` INT,
  `StudentID` INT,
  `Grade` INT,
  PRIMARY KEY (`EnrollmentID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438297_school_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438297_school_init') AS relationships;
DROP DATABASE `db_438297_school_init`;
UNINSTALL EXTENSION vsql_schematron;
