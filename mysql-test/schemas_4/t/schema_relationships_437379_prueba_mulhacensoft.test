INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 437379_prueba_mulhacensoft
--echo #
CREATE DATABASE `db_437379_prueba_mulhacensoft`;
USE `db_437379_prueba_mulhacensoft`;
CREATE TABLE `diagnosticos` (
  `id` INT,
  `id_paciente` INT,
  `descripcion` VARCHAR(50),
  `fecha_diagnostico` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `historico` (
  `id` INT NOT NULL,
  `accion` VARCHAR(50),
  `tipo` INT,
  `fecha` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pacientes` (
  `id` INT,
  `nombre` VARCHAR(50),
  `dni` VARCHAR(50),
  `fecha_nacimiento` DATE,
  `direccion` VARCHAR(50),
  `email` VARCHAR(50),
  `fecha_registro` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `fecha_registro` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_437379_prueba_mulhacensoft') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_437379_prueba_mulhacensoft') AS relationships;
DROP DATABASE `db_437379_prueba_mulhacensoft`;
UNINSTALL EXTENSION vsql_schematron;
