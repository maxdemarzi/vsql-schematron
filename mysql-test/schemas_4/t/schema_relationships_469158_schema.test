INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 469158_schema
--echo #
CREATE DATABASE `db_469158_schema`;
USE `db_469158_schema`;
CREATE TABLE `Users` (
  `Id` INT NOT NULL,
  `Uuid` VARCHAR(50),
  `BalanceRs` DOUBLE,
  `BalanceOsrs` DOUBLE,
  `IsCashier` BOOLEAN,
  `MaxCashIn` DOUBLE,
  `MinBalance` DOUBLE,
  `DateJoined` DATETIME,
  `LastUpdated` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Pairs` (
  `Id` INT NOT NULL,
  `UserId` INT,
  `ServerSeed` VARCHAR(50),
  `ServerHash` VARCHAR(50),
  `UserSeed` VARCHAR(50),
  `Result` VARCHAR(50),
  `Used` BOOLEAN,
  `DateAdded` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Games` (
  `Id` INT NOT NULL,
  `PairId` INT,
  `Amount` DOUBLE,
  `Win` BOOLEAN,
  `GameType` INT,
  `Server` VARCHAR(50),
  `DateAdded` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Transactions` (
  `Id` INT NOT NULL,
  `CashierUuid` VARCHAR(50),
  `UserId` INT,
  `Amount` DOUBLE,
  `Server` VARCHAR(50),
  `CashIn` BOOLEAN,
  `DateAdded` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_469158_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_469158_schema') AS relationships;
DROP DATABASE `db_469158_schema`;
UNINSTALL EXTENSION vsql_schematron;
