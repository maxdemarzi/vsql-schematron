INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 466253_db_setup
--echo #
CREATE DATABASE `db_466253_db_setup`;
USE `db_466253_db_setup`;
CREATE TABLE `company` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `salary` DOUBLE,
  `company_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_466253_db_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_466253_db_setup') AS relationships;
DROP DATABASE `db_466253_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
