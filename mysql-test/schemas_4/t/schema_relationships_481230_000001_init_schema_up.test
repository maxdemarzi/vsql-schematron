INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481230_000001_init_schema.up
--echo #
CREATE DATABASE `db_481230_000001_init_schema_up`;
USE `db_481230_000001_init_schema_up`;

CREATE TABLE `users` (
  `user_id` INT,
  `username` VARCHAR(64),
  `profile_name` VARCHAR(64),
  `bio` VARCHAR(64),
  `avatar` VARCHAR(64),
  `password_hash` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `post_id` INT,
  `user_id` INT,
  `content` VARCHAR(64),
  `date_created` DATETIME,
  `date_updated` DATETIME,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;

CREATE TABLE `topics` (
  `topic_id` INT,
  `topic_name` VARCHAR(64),
  PRIMARY KEY (`topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_to_topics` (
  `post_id` INT,
  `topic_id` INT,
  PRIMARY KEY (`post_id`, `topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `users_to_topics` (
  `user_id` INT,
  `topic_id` INT,
  PRIMARY KEY (`user_id`, `topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `followings` (
  `user_id` INT,
  `following_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`user_id`, `following_id`)
) CHARACTER SET latin1;

CREATE TABLE `upvotes` (
  `user_id` INT,
  `post_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`user_id`, `post_id`)
) CHARACTER SET latin1;

CREATE TABLE `bookmarks` (
  `user_id` INT,
  `post_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`user_id`, `post_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481230_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481230_000001_init_schema_up') AS relationships;
DROP DATABASE `db_481230_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
