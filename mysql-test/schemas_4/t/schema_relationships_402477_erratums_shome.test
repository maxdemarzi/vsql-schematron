INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402477_erratums_shome
--echo #
CREATE DATABASE `db_402477_erratums_shome`;
USE `db_402477_erratums_shome`;

CREATE TABLE `boardtype` (
  `BOARDID` INT,
  `BOARDNAME` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `devices` (
  `DEVICEID` INT,
  `DEVICENAME` VARCHAR(255),
  `USERID` INT,
  `LAYOUTINDEX` INT,
  `BOARDID` INT,
  `UNIQUEID` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `gadgets` (
  `GADGETID` INT,
  `GADGETNAME` VARCHAR(255),
  `DEVICEID` INT,
  `PINTYPE` VARCHAR(255),
  `LAYOUTINDEX` INT,
  `HIDEPAIR` VARCHAR(255),
  `INVERTED` VARCHAR(255),
  `VALUE` VARCHAR(255),
  `IMAGECODE` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `options` (
  `OID` INT,
  `OPT_NAME` VARCHAR(255),
  `OPT_VALUE` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `USERID` INT,
  `USERNAME` VARCHAR(255),
  `PASSWORD` VARCHAR(255),
  `CREATED_AT` DATETIME,
  PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402477_erratums_shome') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402477_erratums_shome') AS relationships;
DROP DATABASE `db_402477_erratums_shome`;
UNINSTALL EXTENSION vsql_schematron;
