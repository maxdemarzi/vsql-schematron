INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428739_person.dump
--echo #
CREATE DATABASE `db_428739_person_dump`;
USE `db_428739_person_dump`;

CREATE TABLE `person` (
  `id` VARCHAR(64),
  `person1` VARCHAR(64),
  `person2` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428739_person_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428739_person_dump') AS relationships;
DROP DATABASE `db_428739_person_dump`;
UNINSTALL EXTENSION vsql_schematron;
