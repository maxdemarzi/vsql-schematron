  `card_number` VARCHAR(64),
  `validation` VARCHAR(64),
  `period` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
