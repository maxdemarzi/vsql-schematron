CREATE DATABASE `db_411322_outro_quarto`;
USE `db_411322_outro_quarto`;

CREATE TABLE `announces` (
  `id` INT,
  `user_id` INT,
  `house_code` VARCHAR(64),
  `city` VARCHAR(64),
  `county` VARCHAR(64),
  `district` VARCHAR(64),
  `street` VARCHAR(64),
  `period` VARCHAR(64),
  `type` VARCHAR(64),
  `payment_METHOD` VARCHAR(64),
  `price` VARCHAR(64),
  `room` VARCHAR(64),
  `living_room` VARCHAR(64),
  `kitchen` VARCHAR(64),
  `bathroom` VARCHAR(64),
  `garden` VARCHAR(64),
  `furniture` VARCHAR(64),
  `state` VARCHAR(64),
  `description` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `profile` VARCHAR(64),
  `slug` VARCHAR(64),
  `truth` INT,
  `untrue` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `appointments` (
  `id` INT,
  `user_id` INT,
  `house_code` VARCHAR(64),
  `name` VARCHAR(64),
  `identity` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `date` VARCHAR(64),
  `time` VARCHAR(64),
  `payment` VARCHAR(64),
