  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `favourites` (
