INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450363_20160610_2106_install_schema
--echo #
CREATE DATABASE `db_450363_20160610_2106_install_schema`;
USE `db_450363_20160610_2106_install_schema`;

CREATE TABLE `Files` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Size` INT,
  `Found` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Functions` (
  `Id` INT,
  `FileId` INT,
  `Name` VARCHAR(64),
  `ParameterCount` INT,
  `RequiredParameterCount` INT,
  `IsVariadic` INT,
  `ReturnsReference` INT,
  `HasReturnType` INT,
  `ReturnType` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `FunctionParameters` (
  `FunctionId` INT,
  `Name` VARCHAR(64),
  `Position` INT,
  `TypeClass` VARCHAR(64),
  `HasType` INT,
  `TypeName` VARCHAR(64),
  `AllowsNull` INT,
  `IsArray` INT,
  `IsCallable` INT,
  `IsOptional` INT,
  `IsVariadic` INT,
  `CanBePassedByValue` INT,
  `IsPassedByReference` INT,
  `HasDefaultValue` INT,
  `DefaultValue` VARCHAR(64),
  `DefaultConstant` VARCHAR(64),
  PRIMARY KEY (`FunctionId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `Constants` (
  `FileId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`FileId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `Classes` (
  `Id` INT,
  `FileId` INT,
  `Name` VARCHAR(64),
  `ClassType` INT,
  `IsAbstract` INT,
  `IsFinal` INT,
  `RawRelations` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ClassRelations` (
  `ClassId` INT,
  `RelatedClass` VARCHAR(64),
  `RelatedClassId` INT,
  `RelationType` INT,
  PRIMARY KEY (`ClassId`, `RelatedClass`, `RelatedClassId`)
) CHARACTER SET latin1;

CREATE TABLE `ClassConstants` (
  `ClassId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`ClassId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `ClassProperties` (
  `ClassId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  `Scope` INT,
  `IsStatic` INT,
  PRIMARY KEY (`ClassId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `ClassMethods` (
  `Id` INT,
  `ClassId` INT,
  `Name` VARCHAR(64),
  `ParameterCount` INT,
  `RequiredParameterCount` INT,
  `Scope` INT,
  `IsAbstract` INT,
  `IsFinal` INT,
  `IsStatic` INT,
  `IsVariadic` INT,
  `ReturnsReference` INT,
  `HasReturnType` INT,
  `ReturnType` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `MethodParameters` (
  `MethodId` INT,
  `Name` VARCHAR(64),
  `Position` INT,
  `TypeClass` VARCHAR(64),
  `HasType` INT,
  `TypeName` VARCHAR(64),
  `AllowsNull` INT,
  `IsArray` INT,
  `IsCallable` INT,
  `IsOptional` INT,
  `IsVariadic` INT,
  `CanBePassedByValue` INT,
  `IsPassedByReference` INT,
  `HasDefaultValue` INT,
  `DefaultValue` VARCHAR(64),
  `DefaultConstant` VARCHAR(64),
  PRIMARY KEY (`MethodId`, `Name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450363_20160610_2106_install_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450363_20160610_2106_install_schema') AS relationships;
DROP DATABASE `db_450363_20160610_2106_install_schema`;
UNINSTALL EXTENSION vsql_schematron;
