INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464027_schema
--echo #
CREATE DATABASE `db_464027_schema`;
USE `db_464027_schema`;

CREATE TABLE `owners` (
  `id` INT,
  `full_name` VARCHAR(64),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `species` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vets` (
  `id` INT,
  `name` VARCHAR(64),
  `age` INT,
  `date_of_graduation` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `specializations` (
  `vets_id` INT,
  `species_id` INT,
  PRIMARY KEY (`vets_id`, `species_id`)
) CHARACTER SET latin1;

CREATE TABLE `visits` (
  `vets_id` INT,
  `animals_id` INT,
  `date_of_visit` DATETIME,
  PRIMARY KEY (`vets_id`, `animals_id`, `date_of_visit`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464027_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464027_schema') AS relationships;
DROP DATABASE `db_464027_schema`;
UNINSTALL EXTENSION vsql_schematron;
