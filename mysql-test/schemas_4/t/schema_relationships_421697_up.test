INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421697_up
--echo #
CREATE DATABASE `db_421697_up`;
USE `db_421697_up`;
CREATE TABLE `polls` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `multi_choice` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `poll_options` (
  `id` INT NOT NULL,
  `poll_id` INT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421697_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421697_up') AS relationships;
DROP DATABASE `db_421697_up`;
UNINSTALL EXTENSION vsql_schematron;
