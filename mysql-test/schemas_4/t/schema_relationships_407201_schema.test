INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 407201_schema
--echo #
CREATE DATABASE `db_407201_schema`;
USE `db_407201_schema`;

CREATE TABLE `types` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `owners` (
  `id_owner` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `telephone` VARCHAR(64),
  PRIMARY KEY (`id_owner`)
) CHARACTER SET latin1;

CREATE TABLE `pets` (
  `id_pet` INT,
  `name` VARCHAR(64),
  `birth_date` DATETIME,
  `type_id` INT,
  `owner_id` INT,
  PRIMARY KEY (`id_pet`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_407201_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_407201_schema') AS relationships;
DROP DATABASE `db_407201_schema`;
UNINSTALL EXTENSION vsql_schematron;
