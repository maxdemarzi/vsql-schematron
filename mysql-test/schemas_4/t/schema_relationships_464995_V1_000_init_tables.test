INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464995_V1_000_init_tables
--echo #
CREATE DATABASE `db_464995_V1_000_init_tables`;
USE `db_464995_V1_000_init_tables`;

CREATE TABLE `users` (
  `id` INT,
  `registered_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `guides` (
  `id` INT,
  `delay` INT,
  `title` VARCHAR(64),
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_guides` (
  `user_id` INT,
  `guide_id` INT,
  PRIMARY KEY (`user_id`, `guide_id`)
) CHARACTER SET latin1;

CREATE TABLE `answers` (
  `id` INT,
  `text` VARCHAR(64),
  `question_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `questions` (
  `id` INT,
  `text` VARCHAR(64),
  `guide_id` INT,
  `answer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464995_V1_000_init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464995_V1_000_init_tables') AS relationships;
DROP DATABASE `db_464995_V1_000_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
