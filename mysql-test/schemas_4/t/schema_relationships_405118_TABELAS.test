INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405118_TABELAS
--echo #
CREATE DATABASE `db_405118_TABELAS`;
USE `db_405118_TABELAS`;
CREATE TABLE `usuarios` (
  `cpf` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  `sobrenome` VARCHAR(50),
  `status_user` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  `acesso` VARCHAR(50),
  `curl` VARCHAR(50),
  `ativo` BOOLEAN,
  `img_perfil` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` DATETIME,
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `notificacoes` (
  `id_notificacao` VARCHAR(50) NOT NULL,
  `titulo` VARCHAR(50),
  `mensagem` VARCHAR(50),
  `visualizado` BOOLEAN,
  `cpf_usuario` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_notificacao`)
) CHARACTER SET latin1;
CREATE TABLE `tipos_quarto` (
  `id_tipo_quarto` VARCHAR(50) NOT NULL,
  `nome_tipo` VARCHAR(50),
  PRIMARY KEY (`id_tipo_quarto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405118_TABELAS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405118_TABELAS') AS relationships;
DROP DATABASE `db_405118_TABELAS`;
UNINSTALL EXTENSION vsql_schematron;
