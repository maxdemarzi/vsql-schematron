INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 479247_migration
--echo #
CREATE DATABASE `db_479247_migration`;
USE `db_479247_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `clerkId` VARCHAR(64),
  `username` VARCHAR(64),
  `description` VARCHAR(64),
  `clerkData` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Folder` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `isArchived` BOOL,
  `ownerId` VARCHAR(64),
  `folderId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Repo` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `private` BOOL,
  `url` VARCHAR(64),
  `isArchived` BOOL,
  `folderId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_479247_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_479247_migration') AS relationships;
DROP DATABASE `db_479247_migration`;
UNINSTALL EXTENSION vsql_schematron;
