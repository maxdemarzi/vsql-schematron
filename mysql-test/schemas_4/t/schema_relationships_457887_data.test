INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 457887_data
--echo #
CREATE DATABASE `db_457887_data`;
USE `db_457887_data`;

CREATE TABLE `users` (
  `userid` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `passwordHash` VARCHAR(64),
  `isStudent` BOOL,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

CREATE TABLE `class` (
  `classid` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`classid`)
) CHARACTER SET latin1;

CREATE TABLE `teaches` (
  `classid` INT,
  `instructorid` INT,
  PRIMARY KEY (`classid`, `instructorid`)
) CHARACTER SET latin1;

CREATE TABLE `member` (
  `studentid` INT,
  `classid` INT,
  PRIMARY KEY (`studentid`, `classid`)
) CHARACTER SET latin1;

CREATE TABLE `lecture` (
  `lectureid` INT,
  `classid` INT,
  `starttime` DATETIME,
  `endtime` DATETIME,
  `lectureurl` VARCHAR(64),
  `day` DATETIME,
  PRIMARY KEY (`lectureid`)
) CHARACTER SET latin1;

CREATE TABLE `muted` (
  `studentid` INT,
  `lectureid` INT,
  PRIMARY KEY (`studentid`, `lectureid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_457887_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_457887_data') AS relationships;
DROP DATABASE `db_457887_data`;
UNINSTALL EXTENSION vsql_schematron;
