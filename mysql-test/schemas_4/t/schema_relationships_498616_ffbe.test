INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498616_ffbe
--echo #
CREATE DATABASE `db_498616_ffbe`;
USE `db_498616_ffbe`;

CREATE TABLE `acquires` (
  `id` INT,
  `user_id` INT,
  `unit_id` INT,
  `level` INT,
  `rarity_id` INT,
  `trust` DECIMAL(10,2),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genders` (
  `id` INT,
  `name` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `jobs` (
  `id` INT,
  `name` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `origins` (
  `id` INT,
  `name` VARCHAR(64),
  `shortname` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `phinxlog` (
  `version` INT,
  `migration_name` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `practises` (
  `id` INT,
  `unit_id` INT,
  `specialisation_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `races` (
  `id` INT,
  `name` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rarities` (
  `id` INT,
  `stars` INT,
  `max_level` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `specialisations` (
  `id` INT,
  `name` VARCHAR(64),
  `stats` VARCHAR(64),
  `team_pick_order` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `units` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `origin_id` INT,
  `race_id` INT,
  `job_id` INT,
  `gender_id` INT,
  `base_rarity_id` INT,
  `max_rarity_id` INT,
  `trust_master_reward` VARCHAR(64),
  `image` VARCHAR(64),
  `image_dir` VARCHAR(64),
  `hp` INT,
  `mp` INT,
  `atk` INT,
  `def` INT,
  `mag` INT,
  `spr` INT,
  `hits` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498616_ffbe') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498616_ffbe') AS relationships;
DROP DATABASE `db_498616_ffbe`;
UNINSTALL EXTENSION vsql_schematron;
