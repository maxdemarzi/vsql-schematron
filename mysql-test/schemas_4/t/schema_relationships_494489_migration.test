INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494489_migration
--echo #
CREATE DATABASE `db_494489_migration`;
USE `db_494489_migration`;

CREATE TABLE `Article` (
  `id` INT,
  `slug` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `body` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ArticleTags` (
  `articleId` INT,
  `tagId` INT,
  PRIMARY KEY (`articleId`, `tagId`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `body` VARCHAR(64),
  `articleId` INT,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `image` VARCHAR(64),
  `bio` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_UserFavorites` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_UserFollows` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494489_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494489_migration') AS relationships;
DROP DATABASE `db_494489_migration`;
UNINSTALL EXTENSION vsql_schematron;
