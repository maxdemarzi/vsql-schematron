INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 404235_init
--echo #
CREATE DATABASE `db_404235_init`;
USE `db_404235_init`;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `email` VARCHAR(255),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `categoryName` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `id` INT,
  `title` VARCHAR(255),
  `summary` VARCHAR(255),
  `content` VARCHAR(255),
  `status` VARCHAR(255),
  `createTime` INT,
  `deleted` VARCHAR(255),
  `category_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `content` VARCHAR(255),
  `ip` VARCHAR(255),
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `createTime` INT,
  `deleted` VARCHAR(255),
  `article_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_404235_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_404235_init') AS relationships;
DROP DATABASE `db_404235_init`;
UNINSTALL EXTENSION vsql_schematron;
