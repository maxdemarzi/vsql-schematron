INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 475746_20210331094454_more_osu
--echo #
CREATE DATABASE `db_475746_20210331094454_more_osu`;
USE `db_475746_20210331094454_more_osu`;

CREATE TABLE `osu_last_beatmaps` (
  `channel_id` INT,
  `beatmap` VARCHAR(64),
  `mode` INT,
  PRIMARY KEY (`channel_id`)
) CHARACTER SET latin1;

CREATE TABLE `osu_user_best_scores` (
  `beatmap_id` INT,
  `mode` INT,
  `user_id` INT,
  `mods` INT,
  `cached_at` DATETIME,
  `score` VARCHAR(64),
  PRIMARY KEY (`beatmap_id`, `mode`, `user_id`, `mods`)
) CHARACTER SET latin1;

CREATE TABLE `osu_cached_beatmaps` (
  `beatmap_id` INT,
  `mode` INT,
  `cached_at` DATETIME,
  `beatmap` VARCHAR(64),
  PRIMARY KEY (`beatmap_id`, `mode`)
) CHARACTER SET latin1;

CREATE TABLE `osu_cached_beatmapsets` (
  `beatmapset_id` INT,
  `beatmap_id` INT,
  `mode` INT,
  PRIMARY KEY (`beatmapset_id`, `beatmap_id`, `mode`)
) CHARACTER SET latin1;

CREATE TABLE `osu_cached_beatmap_contents` (
  `beatmap_id` INT,
  `cached_at` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`beatmap_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_475746_20210331094454_more_osu') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_475746_20210331094454_more_osu') AS relationships;
DROP DATABASE `db_475746_20210331094454_more_osu`;
UNINSTALL EXTENSION vsql_schematron;
