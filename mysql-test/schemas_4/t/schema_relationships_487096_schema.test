INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 487096_schema
--echo #
CREATE DATABASE `db_487096_schema`;
USE `db_487096_schema`;

CREATE TABLE `Ingredient` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Taco_Ingredients` (
  `taco` INT,
  `ingredient` VARCHAR(64),
  PRIMARY KEY (`taco`, `ingredient`)
) CHARACTER SET latin1;

CREATE TABLE `Taco_Order_Tacos` (
  `tacoOrder` INT,
  `taco` INT,
  PRIMARY KEY (`tacoOrder`, `taco`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_487096_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_487096_schema') AS relationships;
DROP DATABASE `db_487096_schema`;
UNINSTALL EXTENSION vsql_schematron;
