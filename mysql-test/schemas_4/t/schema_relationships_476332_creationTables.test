INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 476332_creationTables
--echo #
CREATE DATABASE `db_476332_creationTables`;
USE `db_476332_creationTables`;

CREATE TABLE `utilisateur` (
  `nom_utilisateur` VARCHAR(64),
  `mot_de_passe` VARCHAR(64),
  `nom` VARCHAR(64),
  `prenom` VARCHAR(64),
  `ville` VARCHAR(64),
  `nb_points` INT,
  `email` VARCHAR(64),
  PRIMARY KEY (`nom_utilisateur`)
) CHARACTER SET latin1;

CREATE TABLE `categorie` (
  `num_categorie` INT,
  `nom_categorie` VARCHAR(64),
  PRIMARY KEY (`num_categorie`)
) CHARACTER SET latin1;

CREATE TABLE `partage` (
  `num_partage` INT,
  `intitule` VARCHAR(64),
  `nb_max_personne` INT,
  `adresseRDV` VARCHAR(64),
  `dateRDV` DATETIME,
  `heure_deb` DATETIME,
  `heure_fin` DATETIME,
  `ville` VARCHAR(64),
  `description` VARCHAR(64),
  `commentaire_partage` VARCHAR(64),
  `places_dispo` INT,
  `nom_utilisateur` VARCHAR(64),
  `num_categorie` INT,
  PRIMARY KEY (`num_partage`)
) CHARACTER SET latin1;

CREATE TABLE `participer` (
  `num_partage` INT,
  `nom_utilisateur` VARCHAR(64),
  PRIMARY KEY (`num_partage`, `nom_utilisateur`)
) CHARACTER SET latin1;

CREATE TABLE `note` (
  `nom_utilisateur` VARCHAR(64),
  `num_partage` INT,
  `note` INT,
  `commentaire_note` VARCHAR(64),
  PRIMARY KEY (`num_partage`, `nom_utilisateur`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_476332_creationTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_476332_creationTables') AS relationships;
DROP DATABASE `db_476332_creationTables`;
UNINSTALL EXTENSION vsql_schematron;
