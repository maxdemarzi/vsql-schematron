INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439307_database
--echo #
CREATE DATABASE `db_439307_database`;
USE `db_439307_database`;

CREATE TABLE `Clientes` (
  `cpf` VARCHAR(64),
  `nome` VARCHAR(64),
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;

CREATE TABLE `Carros` (
  `placa` VARCHAR(64),
  `modelo` VARCHAR(64),
  `descricao` VARCHAR(64),
  PRIMARY KEY (`placa`)
) CHARACTER SET latin1;

CREATE TABLE `Aluguel` (
  `pagamento` VARCHAR(64),
  `data_lancamento` DATETIME,
  `cpfcliente` VARCHAR(64),
  `placaVeiculo` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439307_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439307_database') AS relationships;
DROP DATABASE `db_439307_database`;
UNINSTALL EXTENSION vsql_schematron;
