INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 453189_StudentFacultyInteraction%20Dump
--echo #
CREATE DATABASE `db_453189_StudentFacultyInteraction_20Dump`;
USE `db_453189_StudentFacultyInteraction_20Dump`;

CREATE TABLE `courseSubtopicLinks` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `subtopic` VARCHAR(64),
  `subtopicLink` VARCHAR(64),
  PRIMARY KEY (`courseCode`, `session`, `topic`, `subtopic`, `subtopicLink`)
) CHARACTER SET latin1;

CREATE TABLE `courseSubtopicRating` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `subtopic` VARCHAR(64),
  `enrollmentID` VARCHAR(64),
  `subtopicRating` INT,
  `subtopicRatingTimestamp` DATETIME,
  PRIMARY KEY (`courseCode`, `session`, `topic`, `subtopic`, `enrollmentID`)
) CHARACTER SET latin1;

CREATE TABLE `courseSubtopics` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `subtopic` VARCHAR(64),
  `subtopicStatus` VARCHAR(64),
  `subtopicStatusTimestamp` DATETIME,
  PRIMARY KEY (`courseCode`, `session`, `topic`, `subtopic`)
) CHARACTER SET latin1;

CREATE TABLE `courseTopicLinks` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `topicLink` VARCHAR(64),
  PRIMARY KEY (`courseCode`, `session`, `topic`, `topicLink`)
) CHARACTER SET latin1;

CREATE TABLE `courseTopicRating` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `enrollmentID` VARCHAR(64),
  `topicRating` INT,
  `topicRatingTimestamp` DATETIME,
  PRIMARY KEY (`courseCode`, `session`, `topic`, `enrollmentID`)
) CHARACTER SET latin1;

CREATE TABLE `courseTopics` (
  `courseCode` VARCHAR(64),
  `session` VARCHAR(64),
  `topic` VARCHAR(64),
  `topicStatus` VARCHAR(64),
  `topicStatusTimestamp` DATETIME,
  PRIMARY KEY (`courseCode`, `session`, `topic`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `courseCode` VARCHAR(64),
  `courseName` VARCHAR(64),
  `sem` INT,
  `session` VARCHAR(64),
  PRIMARY KEY (`courseCode`, `session`)
) CHARACTER SET latin1;

CREATE TABLE `faculty` (
  `employeeID` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `contact` VARCHAR(64),
  `researchArea` VARCHAR(64),
  PRIMARY KEY (`employeeID`)
) CHARACTER SET latin1;

CREATE TABLE `facultyCoursesConducting` (
  `employeeID` VARCHAR(64),
  `courseCode` VARCHAR(64),
  `sem` INT,
  `session` VARCHAR(64),
  PRIMARY KEY (`employeeID`, `courseCode`, `session`)
) CHARACTER SET latin1;

CREATE TABLE `hodCoursesIncharge` (
  `employeeID` VARCHAR(64),
  `courseCode` VARCHAR(64),
  `sem` INT,
  `session` VARCHAR(64),
  PRIMARY KEY (`employeeID`, `courseCode`, `session`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `enrollmentID` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`enrollmentID`)
) CHARACTER SET latin1;

CREATE TABLE `studentCoursesEnrolled` (
  `enrollmentID` VARCHAR(64),
  `courseCode` VARCHAR(64),
  `sem` INT,
  `session` VARCHAR(64),
  PRIMARY KEY (`enrollmentID`, `courseCode`, `session`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_453189_StudentFacultyInteraction_20Dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_453189_StudentFacultyInteraction_20Dump') AS relationships;
DROP DATABASE `db_453189_StudentFacultyInteraction_20Dump`;
UNINSTALL EXTENSION vsql_schematron;
