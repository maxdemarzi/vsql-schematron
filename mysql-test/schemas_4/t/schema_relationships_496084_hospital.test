INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 496084_hospital
--echo #
CREATE DATABASE `db_496084_hospital`;
USE `db_496084_hospital`;

CREATE TABLE `medico` (
  `id` INT,
  `nombre` VARCHAR(64),
  `departamento` VARCHAR(64),
  `especialidad` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `paciente` (
  `folio` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`folio`)
) CHARACTER SET latin1;

CREATE TABLE `examen` (
  `id` INT,
  `fecha` DATETIME,
  `tipo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `atiende` (
  `id_doc` VARCHAR(64),
  `diagnostico` VARCHAR(64),
  `folio` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_496084_hospital') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_496084_hospital') AS relationships;
DROP DATABASE `db_496084_hospital`;
UNINSTALL EXTENSION vsql_schematron;
