INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 430897_01.users
--echo #
CREATE DATABASE `db_430897_01_users`;
USE `db_430897_01_users`;

CREATE TABLE `users` (
  `user_id` INT,
  `full_name` VARCHAR(64),
  `graduating_year` INT,
  `graduating_semester` VARCHAR(64),
  `major` VARCHAR(64),
  `pw_hash` VARCHAR(64),
  `username` VARCHAR(64),
  `notes` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `role_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `role_assignments` (
  `user_id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_430897_01_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_430897_01_users') AS relationships;
DROP DATABASE `db_430897_01_users`;
UNINSTALL EXTENSION vsql_schematron;
