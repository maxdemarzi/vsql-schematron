INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 433192_db_changes
--echo #
CREATE DATABASE `db_433192_db_changes`;
USE `db_433192_db_changes`;

CREATE TABLE `mesh_state` (
  `id` INT,
  `gridid_state` VARCHAR(64),
  `name` VARCHAR(64),
  `pobtot` INT
) CHARACTER SET latin1;

CREATE TABLE `mesh_mun` (
  `id` INT,
  `state_id` INT,
  `gridid_state` VARCHAR(64),
  `gridid_mun` VARCHAR(64),
  `state_name` VARCHAR(64),
  `name` VARCHAR(64),
  `pobtot` INT
) CHARACTER SET latin1;

CREATE TABLE `mesh_ageb` (
  `id` INT,
  `state_id` INT,
  `gridid_state` VARCHAR(64),
  `mun_id` INT,
  `gridid_mun` VARCHAR(64),
  `gridid_ageb` VARCHAR(64),
  `state_name` VARCHAR(64),
  `municipality_name` VARCHAR(64),
  `pobtot` INT
) CHARACTER SET latin1;

CREATE TABLE `target_group_catalogue` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `target_group_population_state` (
  `id` INT,
  `target_group_id` INT,
  `state_id` INT,
  `population` INT
) CHARACTER SET latin1;

CREATE TABLE `target_group_population_mun` (
  `id` INT,
  `target_group_id` INT,
  `state_id` INT,
  `mun_id` INT,
  `population` INT
) CHARACTER SET latin1;

CREATE TABLE `target_group_population_ageb` (
  `id` INT,
  `target_group_id` INT,
  `state_id` INT,
  `mun_id` INT,
  `ageb_id` INT,
  `population` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_433192_db_changes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_433192_db_changes') AS relationships;
DROP DATABASE `db_433192_db_changes`;
UNINSTALL EXTENSION vsql_schematron;
