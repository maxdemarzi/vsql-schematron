INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 452201_0100_create_tables
--echo #
CREATE DATABASE `db_452201_0100_create_tables`;
USE `db_452201_0100_create_tables`;
CREATE TABLE `ABC_MAIL_AUTHORIZED_DOMAIN` (
  `mad_id` VARCHAR(50) NOT NULL,
  `cmp_id` VARCHAR(50),
  `atd_domain_name` VARCHAR(50),
  PRIMARY KEY (`mad_id`)
) CHARACTER SET latin1;
CREATE TABLE `ABC_MAIL_MESSAGE` (
  `elm_id` VARCHAR(50) NOT NULL,
  `cmp_id` VARCHAR(50),
  `blb_id_body` VARCHAR(50),
  `usr_id` VARCHAR(50),
  `elm_address` VARCHAR(50),
  `elm_name` VARCHAR(50),
  `elm_subject` VARCHAR(50),
  `elm_number_from` INT,
  `elm_number_to` INT,
  `elm_number_cc` INT,
  `elm_number_bcc` INT,
  `elm_inserted` TIMESTAMP NULL,
  `elm_picked_up` TIMESTAMP NULL,
  `elm_sent` TIMESTAMP NULL,
  PRIMARY KEY (`elm_id`)
) CHARACTER SET latin1;
CREATE TABLE `ABC_MAIL_MESSAGE_HEADER` (
  `emh_id` VARCHAR(50) NOT NULL,
  `cmp_id` VARCHAR(50),
  `blb_id` VARCHAR(50),
  `ehd_id` VARCHAR(50),
  `elm_id` VARCHAR(50),
  `usr_id` VARCHAR(50),
  `emh_address` VARCHAR(50),
  `emh_name` VARCHAR(50),
  `emh_value` VARCHAR(50),
  PRIMARY KEY (`emh_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_452201_0100_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_452201_0100_create_tables') AS relationships;
DROP DATABASE `db_452201_0100_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
