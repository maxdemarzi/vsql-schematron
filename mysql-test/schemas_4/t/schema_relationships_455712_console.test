INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455712_console
--echo #
CREATE DATABASE `db_455712_console`;
USE `db_455712_console`;
CREATE TABLE `student` (
  `Number` INT NOT NULL,
  `Name` CHAR(50),
  `Gender` CHAR(50),
  `Birth` DATE,
  `Major` CHAR(50),
  `Class` INT,
  PRIMARY KEY (`Number`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
  `Number` INT NOT NULL,
  `Name` CHAR(50),
  `Credit` DOUBLE,
  `Capacity` INT,
  PRIMARY KEY (`Number`)
) CHARACTER SET latin1;
CREATE TABLE `course_teacher` (
  `CourseNum` INT,
  `Teacher` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `course_choose` (
  `StudentNum` INT,
  `CourseNum` INT,
  `Teacher` CHAR(50),
  `Grade` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `Username` VARCHAR(50) NOT NULL,
  `Email` CHAR(50),
  `Homepage` CHAR(50),
  `Telephone` CHAR(50),
  `Address` CHAR(50),
  PRIMARY KEY (`Username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455712_console') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455712_console') AS relationships;
DROP DATABASE `db_455712_console`;
UNINSTALL EXTENSION vsql_schematron;
