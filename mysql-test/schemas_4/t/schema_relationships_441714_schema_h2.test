INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 441714_schema_h2
--echo #
CREATE DATABASE `db_441714_schema_h2`;
USE `db_441714_schema_h2`;

CREATE TABLE `SPRING_SESSION` (
  `PRIMARY_ID` VARCHAR(255),
  `SESSION_ID` VARCHAR(255),
  `CREATION_TIME` INT,
  `LAST_ACCESS_TIME` INT,
  `MAX_INACTIVE_INTERVAL` INT,
  `EXPIRY_TIME` INT,
  `PRINCIPAL_NAME` VARCHAR(255),
  PRIMARY KEY (`PRIMARY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SPRING_SESSION_ATTRIBUTES` (
  `SESSION_PRIMARY_ID` VARCHAR(255),
  `ATTRIBUTE_NAME` VARCHAR(255),
  `ATTRIBUTE_BYTES` VARCHAR(255),
  PRIMARY KEY (`SESSION_PRIMARY_ID`, `ATTRIBUTE_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `DEVICE` (
  `ID` INT,
  `TYP` VARCHAR(255),
  `LOCATION` VARCHAR(255),
  `EQUIPMENT` VARCHAR(255),
  `ENERGY` INT,
  `USED` VARCHAR(255),
  `PRINCIPAL` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_441714_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_441714_schema_h2') AS relationships;
DROP DATABASE `db_441714_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
