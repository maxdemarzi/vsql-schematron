INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 446529_creation
--echo #
CREATE DATABASE `db_446529_creation`;
USE `db_446529_creation`;

CREATE TABLE `DEPT` (
  `DEPTNO` DECIMAL(10,2),
  `DNAME` VARCHAR(64),
  `LOC` VARCHAR(64),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;

CREATE TABLE `EMP` (
  `EMPNO` DECIMAL(10,2),
  `ENAME` VARCHAR(64),
  `EFIRST` VARCHAR(64),
  `JOB` VARCHAR(64),
  `MGR` DECIMAL(10,2),
  `HIREDATE` DATETIME,
  `SAL` DECIMAL(10,2),
  `COMM` DECIMAL(10,2),
  `TEL` VARCHAR(64),
  `DEPTNO` DECIMAL(10,2),
  PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;

CREATE TABLE `DEPENDENTS` (
  `DNO` DECIMAL(10,2),
  `DNAME` VARCHAR(64),
  `DFIRST` VARCHAR(64),
  `EMPNO` DECIMAL(10,2),
  PRIMARY KEY (`DNO`, `EMPNO`)
) CHARACTER SET latin1;

CREATE TABLE `BONUS` (
  `ENAME` VARCHAR(64),
  `JOB` VARCHAR(64),
  `SAL` DECIMAL(10,2),
  `COMM` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `SALGRADE` (
  `GRADE` DECIMAL(10,2),
  `LOSAL` DECIMAL(10,2),
  `HISAL` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_446529_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_446529_creation') AS relationships;
DROP DATABASE `db_446529_creation`;
UNINSTALL EXTENSION vsql_schematron;
