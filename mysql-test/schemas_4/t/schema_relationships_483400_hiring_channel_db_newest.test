INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 483400_hiring_channel_db_newest
--echo #
CREATE DATABASE `db_483400_hiring_channel_db_newest`;
USE `db_483400_hiring_channel_db_newest`;

CREATE TABLE `history` (
  `user_id` INT,
  `corporate_id` INT,
  `rating` INT,
  `hire_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `type` (
  `type_id` INT,
  `type_name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `corporate_name` VARCHAR(255),
  `type_id` INT,
  `image` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `is_open` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_detail` (
  `user_id` INT,
  `description` VARCHAR(255),
  `field` VARCHAR(255),
  `skill` VARCHAR(255),
  `location` VARCHAR(255),
  `rating` INT,
  `total_project` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_483400_hiring_channel_db_newest') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_483400_hiring_channel_db_newest') AS relationships;
DROP DATABASE `db_483400_hiring_channel_db_newest`;
UNINSTALL EXTENSION vsql_schematron;
