INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 415724_gdi
--echo #
CREATE DATABASE `db_415724_gdi`;
USE `db_415724_gdi`;

CREATE TABLE `comments` (
  `id` INT,
  `userid` INT,
  `complainid` INT,
  `comment` VARCHAR(64),
  `username` VARCHAR(64),
  `admin` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `complains` (
  `id` INT,
  `userid` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `status` VARCHAR(64),
  `title` VARCHAR(64),
  `message` VARCHAR(64),
  `date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `userid` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `admin` VARCHAR(64),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_415724_gdi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_415724_gdi') AS relationships;
DROP DATABASE `db_415724_gdi`;
UNINSTALL EXTENSION vsql_schematron;
