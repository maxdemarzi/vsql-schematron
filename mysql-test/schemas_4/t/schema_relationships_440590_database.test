INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 440590_database
--echo #
CREATE DATABASE `db_440590_database`;
USE `db_440590_database`;

CREATE TABLE `questions` (
  `id` INT,
  `description` VARCHAR(64),
  `option_a` VARCHAR(64),
  `option_b` VARCHAR(64),
  `option_c` VARCHAR(64),
  `option_d` VARCHAR(64),
  `correct_option` VARCHAR(64),
  `difficulty` INT,
  `subject` INT,
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `difficulties` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `question_subjects` (
  `id` INT,
  `subject` VARCHAR(64),
  `is_general_subject` BOOL,
  `channel` VARCHAR(64),
  `subject_simplified` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_440590_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_440590_database') AS relationships;
DROP DATABASE `db_440590_database`;
UNINSTALL EXTENSION vsql_schematron;
