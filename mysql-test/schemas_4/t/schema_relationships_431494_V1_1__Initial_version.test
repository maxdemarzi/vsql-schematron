INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 431494_V1_1__Initial_version
--echo #
CREATE DATABASE `db_431494_V1_1__Initial_version`;
USE `db_431494_V1_1__Initial_version`;
CREATE TABLE `INNTEKTSMELDING` (
  `INNTEKTSMELDING_UUID` VARCHAR(50) NOT NULL,
  `AKTOR_ID` VARCHAR(50),
  `ORGNUMMER` VARCHAR(50),
  `SAK_ID` VARCHAR(50),
  `JOURNALPOST_ID` VARCHAR(50),
  `BEHANDLET` TIMESTAMP NULL,
  `ARBEIDSGIVER_PRIVAT` VARCHAR(50),
  PRIMARY KEY (`INNTEKTSMELDING_UUID`)
) CHARACTER SET latin1;
CREATE TABLE `ARBEIDSGIVERPERIODE` (
  `PERIODE_UUID` VARCHAR(50) NOT NULL,
  `INNTEKTSMELDING_UUID` VARCHAR(50),
  `FOM` DATE,
  `TOM` DATE,
  PRIMARY KEY (`PERIODE_UUID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_431494_V1_1__Initial_version') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_431494_V1_1__Initial_version') AS relationships;
DROP DATABASE `db_431494_V1_1__Initial_version`;
UNINSTALL EXTENSION vsql_schematron;
