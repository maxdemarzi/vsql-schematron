INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 445085_EventDAL
--echo #
CREATE DATABASE `db_445085_EventDAL`;
USE `db_445085_EventDAL`;

CREATE TABLE `UserDB` (
  `user_name` VARCHAR(64),
  `user_password` VARCHAR(64),
  `name_user` VARCHAR(64),
  `age` INT,
  `type_account` INT,
  `job` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` INT,
  PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;

CREATE TABLE `EventDB` (
  `event_id` INT,
  `event_name` VARCHAR(64),
  `address` VARCHAR(64),
  `description` VARCHAR(64),
  `event_time` VARCHAR(64),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

CREATE TABLE `EventDetailsDB` (
  `username` VARCHAR(64),
  `event_id` INT,
  `event_status` VARCHAR(64),
  PRIMARY KEY (`username`, `event_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_445085_EventDAL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_445085_EventDAL') AS relationships;
DROP DATABASE `db_445085_EventDAL`;
UNINSTALL EXTENSION vsql_schematron;
