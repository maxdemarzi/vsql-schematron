INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 490065_ttry
--echo #
CREATE DATABASE `db_490065_ttry`;
USE `db_490065_ttry`;
CREATE TABLE `user_id` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `passwd` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
  `id` INT NOT NULL,
  `word` VARCHAR(50),
  `n_id` INT,
  `time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_490065_ttry') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_490065_ttry') AS relationships;
DROP DATABASE `db_490065_ttry`;
UNINSTALL EXTENSION vsql_schematron;
