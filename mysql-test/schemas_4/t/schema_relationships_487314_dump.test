INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 487314_dump
--echo #
CREATE DATABASE `db_487314_dump`;
USE `db_487314_dump`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `gender` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `language` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogs` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `body` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ci_sessions` (
  `id` VARCHAR(50),
  `ip_address` VARCHAR(50),
  `timestamp` VARCHAR(50),
  `data` BLOB
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_487314_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_487314_dump') AS relationships;
DROP DATABASE `db_487314_dump`;
UNINSTALL EXTENSION vsql_schematron;
