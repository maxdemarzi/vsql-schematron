INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400367_migration
--echo #
CREATE DATABASE `db_400367_migration`;
USE `db_400367_migration`;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `images` VARCHAR(50),
  `caption` TEXT,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `profilePicture` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400367_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400367_migration') AS relationships;
DROP DATABASE `db_400367_migration`;
UNINSTALL EXTENSION vsql_schematron;
