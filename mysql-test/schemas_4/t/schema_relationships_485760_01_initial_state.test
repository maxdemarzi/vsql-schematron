INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485760_01-initial-state
--echo #
CREATE DATABASE `db_485760_01_initial_state`;
USE `db_485760_01_initial_state`;

CREATE TABLE `profiles` (
  `id` INT,
  `date_created` DATETIME,
  `date_updated` DATETIME,
  `username` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `profile_image_id` INT,
  `user_state` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `date_created` DATETIME,
  `date_updated` DATETIME,
  `public_id` INT,
  `content` VARCHAR(64),
  `owner_id` INT,
  `date_post_edited` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `date_created` DATETIME,
  `date_updated` DATETIME,
  `content` VARCHAR(64),
  `parent_post_id` INT,
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mediae` (
  `id` INT,
  `data_created` DATETIME,
  `date_updated` DATETIME,
  `post_id` INT,
  `public_id` VARCHAR(64),
  `media_type` INT,
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts` (
  `id` INT,
  `data_created` DATETIME,
  `date_updated` DATETIME,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `profile_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_liked_by_profiles` (
  `liked_posts_id` INT,
  `liking_profile_id` INT,
  PRIMARY KEY (`liked_posts_id`, `liking_profile_id`)
) CHARACTER SET latin1;

CREATE TABLE `profiles_following_profile` (
  `follower_id` INT,
  `following_id` INT,
  PRIMARY KEY (`follower_id`, `following_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485760_01_initial_state') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485760_01_initial_state') AS relationships;
DROP DATABASE `db_485760_01_initial_state`;
UNINSTALL EXTENSION vsql_schematron;
