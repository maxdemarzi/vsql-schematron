INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458617_TaskForce-DB
--echo #
CREATE DATABASE `db_458617_TaskForce_DB`;
USE `db_458617_TaskForce_DB`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `city_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profile` (
  `id` INT,
  `user_id` INT,
  `role` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `date_birthday` DATETIME,
  `biography` VARCHAR(64),
  `avatar` VARCHAR(64),
  `phone` VARCHAR(64),
  `skype` VARCHAR(64),
  `telegram` VARCHAR(64),
  `last_activity` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cities` (
  `id` INT,
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profile_category` (
  `profile_id` INT,
  `category_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `category_id` INT,
  `status_id` INT,
  `cost` INT,
  `customer_id` INT,
  `performer_id` INT,
  `city_id` INT,
  `geo_latitude` DECIMAL(10,2),
  `geo_longitude` DECIMAL(10,2),
  `date_limit` DATETIME,
  `date_published` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `statuses` (
  `id` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `path_files` (
  `task_id` INT,
  `path` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `task_id` INT,
  `user_id` INT,
  `message` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `task_id` INT,
  `value` INT,
  `comment` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `responses` (
  `id` INT,
  `task_id` INT,
  `performer_id` INT,
  `value` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `favorites` (
  `id` INT,
  `customer_id` INT,
  `performer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458617_TaskForce_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458617_TaskForce_DB') AS relationships;
DROP DATABASE `db_458617_TaskForce_DB`;
UNINSTALL EXTENSION vsql_schematron;
