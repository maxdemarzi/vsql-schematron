INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456271_PayrollManagementDatabase
--echo #
CREATE DATABASE `db_456271_PayrollManagementDatabase`;
USE `db_456271_PayrollManagementDatabase`;
CREATE TABLE `department` (
  `department_id` INT NOT NULL,
  `department_name` VARCHAR(50),
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `job` (
  `job_id` INT NOT NULL,
  `department_id` INT,
  `job_title` VARCHAR(50),
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `employee_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `phone` VARCHAR(50),
  `job_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `salary` (
  `payroll_id` INT NOT NULL,
  `employee_id` INT,
  `gross_salary` DECIMAL(10,2),
  PRIMARY KEY (`payroll_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456271_PayrollManagementDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456271_PayrollManagementDatabase') AS relationships;
DROP DATABASE `db_456271_PayrollManagementDatabase`;
UNINSTALL EXTENSION vsql_schematron;
