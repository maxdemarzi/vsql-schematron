INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472106_sql
--echo #
CREATE DATABASE `db_472106_sql`;
USE `db_472106_sql`;
CREATE TABLE `Books` (
  `ID` INT NOT NULL,
  `Title` VARCHAR(50),
  `Price` DECIMAL(10,2),
  `Author` VARCHAR(50),
  `IssuingCompany` VARCHAR(50),
  `DateofPublication` VARCHAR(50),
  `Dimensions` VARCHAR(50),
  `CoverType` VARCHAR(50),
  `NumberofPages` INT,
  `PublishingCompany` VARCHAR(50),
  `SKU` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
  `ID` INT NOT NULL,
  `Email` VARCHAR(50),
  `Password` VARCHAR(50),
  `Name` VARCHAR(50),
  `Address` VARCHAR(50),
  `Phone` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `ID` INT NOT NULL,
  `CustomerID` INT,
  `Date` DATETIME,
  `Status` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
  `BookID` INT NOT NULL,
  `OrderID` INT NOT NULL,
  `Amount` INT,
  `UnitPrice` DECIMAL(10,2),
  PRIMARY KEY (`BookID`, `OrderID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472106_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472106_sql') AS relationships;
DROP DATABASE `db_472106_sql`;
UNINSTALL EXTENSION vsql_schematron;
