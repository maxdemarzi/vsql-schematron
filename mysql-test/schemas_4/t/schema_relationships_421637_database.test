INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421637_database
--echo #
CREATE DATABASE `db_421637_database`;
USE `db_421637_database`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_in_project` (
  `user_id` INT,
  `project_id` INT,
  PRIMARY KEY (`user_id`, `project_id`)
) CHARACTER SET latin1;

CREATE TABLE `appointments` (
  `id` INT,
  `start_date` DATETIME,
  `finish_date` DATETIME,
  `user_id` INT,
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421637_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421637_database') AS relationships;
DROP DATABASE `db_421637_database`;
UNINSTALL EXTENSION vsql_schematron;
