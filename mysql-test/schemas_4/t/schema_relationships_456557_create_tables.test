INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456557_create-tables
--echo #
CREATE DATABASE `db_456557_create_tables`;
USE `db_456557_create_tables`;

CREATE TABLE `weeks` (
  `time_start` INT,
  `time_end` INT,
  PRIMARY KEY (`time_start`)
) CHARACTER SET latin1;

CREATE TABLE `assignments` (
  `id` INT,
  `week_id` INT,
  `time_due` INT,
  `course_id` VARCHAR(64),
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  `points` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `message_id` VARCHAR(64),
  `channel_id` VARCHAR(64),
  `week_id` INT,
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456557_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456557_create_tables') AS relationships;
DROP DATABASE `db_456557_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
