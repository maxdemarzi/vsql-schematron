INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497243_2
--echo #
CREATE DATABASE `db_497243_2`;
USE `db_497243_2`;

CREATE TABLE `benchmark` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `benchmarkArgument` (
  `benchmarkId` INT,
  `arg` VARCHAR(64),
  `idx` INT,
  PRIMARY KEY (`benchmarkId`, `arg`)
) CHARACTER SET latin1;

CREATE TABLE `compilerBenchmarkTask` (
  `id` INT,
  `priority` INT,
  `status` VARCHAR(64),
  `scalaVersionId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `requestFailedFields` (
  `compilerBenchmarkTaskId` INT,
  `previousStatus` VARCHAR(64),
  `message` VARCHAR(64),
  PRIMARY KEY (`compilerBenchmarkTaskId`)
) CHARACTER SET latin1;

CREATE TABLE `compilerBenchmarkTaskBenchmark` (
  `compilerBenchmarkTaskId` INT,
  `benchmarkId` INT,
  `idx` INT,
  PRIMARY KEY (`compilerBenchmarkTaskId`, `benchmarkId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497243_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497243_2') AS relationships;
DROP DATABASE `db_497243_2`;
UNINSTALL EXTENSION vsql_schematron;
