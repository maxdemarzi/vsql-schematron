INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 462025_dump
--echo #
CREATE DATABASE `db_462025_dump`;
USE `db_462025_dump`;

CREATE TABLE `neuron_users` (
  `u_id` INT,
  `u_email` VARCHAR(64),
  `u_username` VARCHAR(64),
  `u_password` VARCHAR(64),
  `u_resetPassword` INT,
  `u_emailVerified` INT
) CHARACTER SET latin1;

CREATE TABLE `neuron_users_deligated` (
  `ud_id` INT,
  `u_id` INT,
  `ud_type` VARCHAR(64),
  `ud_unique_id` VARCHAR(64),
  `ud_name` VARCHAR(64),
  `ud_firstname` VARCHAR(64),
  `ud_lastname` VARCHAR(64),
  `ud_access_token` VARCHAR(64),
  `ud_gender` VARCHAR(64),
  `ud_email` VARCHAR(64),
  `ud_birthday` DATETIME,
  `ud_locale` VARCHAR(64),
  `ud_avatar` VARCHAR(64),
  `ud_url` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` VARCHAR(64),
  `set_time` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_462025_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_462025_dump') AS relationships;
DROP DATABASE `db_462025_dump`;
UNINSTALL EXTENSION vsql_schematron;
