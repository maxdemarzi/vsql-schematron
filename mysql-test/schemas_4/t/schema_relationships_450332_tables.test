INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450332_tables
--echo #
CREATE DATABASE `db_450332_tables`;
USE `db_450332_tables`;

CREATE TABLE `client` (
  `id` INT,
  `row_change_time` DATETIME,
  `c_name` VARCHAR(255),
  `c_surname` VARCHAR(255),
  `dob` DATETIME,
  `e_mail` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `item_name` VARCHAR(255),
  `item_price` DECIMAL(10,2),
  `item_serial_nr` VARCHAR(255),
  `active` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bill` (
  `id` INT,
  `bill_created` DATETIME,
  `shop_code` VARCHAR(255),
  `field_hash` VARCHAR(255),
  `client_id` INT,
  `bill_sent` VARCHAR(255),
  `bill_number` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bill_item` (
  `id` INT,
  `item_name` VARCHAR(255),
  `item_qty` INT,
  `item_price` DECIMAL(10,2),
  `item_discount_value` DECIMAL(10,2),
  `item_id` INT,
  `bill_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450332_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450332_tables') AS relationships;
DROP DATABASE `db_450332_tables`;
UNINSTALL EXTENSION vsql_schematron;
