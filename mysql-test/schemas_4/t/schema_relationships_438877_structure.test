INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438877_structure
--echo #
CREATE DATABASE `db_438877_structure`;
USE `db_438877_structure`;

CREATE TABLE `table_one` (
  `table_two_id` INT,
  `col_one` INT,
  `col_two` INT,
  PRIMARY KEY (`col_one`, `col_two`)
) CHARACTER SET latin1;

CREATE TABLE `table_two` (
  `table_two_id` INT,
  `col_one` INT,
  `col_two` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438877_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438877_structure') AS relationships;
DROP DATABASE `db_438877_structure`;
UNINSTALL EXTENSION vsql_schematron;
