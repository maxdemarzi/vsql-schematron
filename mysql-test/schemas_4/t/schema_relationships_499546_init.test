INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499546_init
--echo #
CREATE DATABASE `db_499546_init`;
USE `db_499546_init`;

CREATE TABLE `metadata` (
  `wallet_id` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`wallet_id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `wallet_id` VARCHAR(64),
  `id` INT,
  `type` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`wallet_id`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `tags_encrypted` (
  `wallet_id` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `item_id` INT,
  PRIMARY KEY (`wallet_id`, `name`, `item_id`)
) CHARACTER SET latin1;

CREATE TABLE `tags_plaintext` (
  `wallet_id` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `item_id` INT,
  PRIMARY KEY (`wallet_id`, `name`, `item_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499546_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499546_init') AS relationships;
DROP DATABASE `db_499546_init`;
UNINSTALL EXTENSION vsql_schematron;
