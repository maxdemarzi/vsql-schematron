INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456702_db
--echo #
CREATE DATABASE `db_456702_db`;
USE `db_456702_db`;
CREATE TABLE `publisher` (
  `PUBLISHER_ID` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`PUBLISHER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `BOOK_ID` INT NOT NULL,
  `Title` VARCHAR(50),
  `Subtitle` VARCHAR(50),
  `PUBLISHER_ID` INT,
  PRIMARY KEY (`BOOK_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456702_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456702_db') AS relationships;
DROP DATABASE `db_456702_db`;
UNINSTALL EXTENSION vsql_schematron;
