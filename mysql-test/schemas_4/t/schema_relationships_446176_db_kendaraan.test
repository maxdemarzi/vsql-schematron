INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 446176_db_kendaraan
--echo #
CREATE DATABASE `db_446176_db_kendaraan`;
USE `db_446176_db_kendaraan`;
CREATE TABLE `auth_acl` (
  `ai` VARCHAR(50) NOT NULL,
  `action_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`ai`)
) CHARACTER SET latin1;
CREATE TABLE `auth_acl_actions` (
  `action_id` VARCHAR(50) NOT NULL,
  `action_code` VARCHAR(50),
  `action_desc` VARCHAR(50),
  `category_id` VARCHAR(50),
  PRIMARY KEY (`action_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_ci_sessions` (
  `id` VARCHAR(50) NOT NULL,
  `ip_address` VARCHAR(50),
  `timestamp` VARCHAR(50),
  `data` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ms_tipe` (
  `id_tipe` INT NOT NULL,
  `id_jenis` INT,
  `tipe` VARCHAR(50),
  PRIMARY KEY (`id_tipe`)
) CHARACTER SET latin1;
CREATE TABLE `sys_log_type` (
  `logtypeid` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `remarks` VARCHAR(50),
  `used_user_rating` TINYINT,
  `used_user_rating_weight` DECIMAL(10,2),
  PRIMARY KEY (`logtypeid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_446176_db_kendaraan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_446176_db_kendaraan') AS relationships;
DROP DATABASE `db_446176_db_kendaraan`;
UNINSTALL EXTENSION vsql_schematron;
