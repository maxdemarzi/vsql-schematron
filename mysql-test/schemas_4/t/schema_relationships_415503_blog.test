INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 415503_blog
--echo #
CREATE DATABASE `db_415503_blog`;
USE `db_415503_blog`;

CREATE TABLE `comment_aboutcomment` (
  `id` INT,
  `create_date` DATETIME,
  `content` VARCHAR(64),
  `author_id` INT,
  `parent_id` INT,
  `rep_to_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment_messagecomment` (
  `id` INT,
  `create_date` DATETIME,
  `content` VARCHAR(64),
  `author_id` INT,
  `parent_id` INT,
  `rep_to_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_session` (
  `session_key` VARCHAR(64),
  `session_data` VARCHAR(64),
  `expire_date` DATETIME,
  PRIMARY KEY (`session_key`)
) CHARACTER SET latin1;

CREATE TABLE `storm_carousel` (
  `id` INT,
  `number` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `img_url` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `storm_friendlink` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `link` VARCHAR(64),
  `logo` VARCHAR(64),
  `create_date` DATETIME,
  `is_active` INT,
  `is_show` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `storm_silian` (
  `id` INT,
  `badurl` VARCHAR(64),
  `remark` VARCHAR(64),
  `add_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_415503_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_415503_blog') AS relationships;
DROP DATABASE `db_415503_blog`;
UNINSTALL EXTENSION vsql_schematron;
