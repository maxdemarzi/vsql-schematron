INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 418343_initial_states
--echo #
CREATE DATABASE `db_418343_initial_states`;
USE `db_418343_initial_states`;

CREATE TABLE `coneg.dim_cadastrados` (
  `pesid` INT,
  `nome` VARCHAR(64),
  `email` VARCHAR(64),
  `telefone` VARCHAR(64),
  `notificado` BOOL,
  PRIMARY KEY (`pesid`)
) CHARACTER SET latin1;

CREATE TABLE `coneg.dim_status` (
  `id` INT,
  `mascara` BOOL,
  `cadastrado` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `coneg.fato_faces` (
  `tid` INT,
  `local` VARCHAR(64),
  `ts` DATETIME,
  `status` INT,
  `pessoa` INT,
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;

CREATE TABLE `coneg.user` (
  `id` INT,
  `username` VARCHAR(64),
  `password_hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_418343_initial_states') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_418343_initial_states') AS relationships;
DROP DATABASE `db_418343_initial_states`;
UNINSTALL EXTENSION vsql_schematron;
