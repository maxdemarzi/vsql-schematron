INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 407181_database
--echo #
CREATE DATABASE `db_407181_database`;
USE `db_407181_database`;
CREATE TABLE `type` (
  `IDType` INT NOT NULL,
  `nom` VARCHAR(50),
  PRIMARY KEY (`IDType`)
) CHARACTER SET latin1;
CREATE TABLE `info` (
  `IDInfo` INT NOT NULL,
  `IDtype` INT,
  `nombre` INT,
  `dateInfo` DATETIME,
  PRIMARY KEY (`IDInfo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_407181_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_407181_database') AS relationships;
DROP DATABASE `db_407181_database`;
UNINSTALL EXTENSION vsql_schematron;
