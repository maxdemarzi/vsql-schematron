INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498863_migration
--echo #
CREATE DATABASE `db_498863_migration`;
USE `db_498863_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Post` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `status` VARCHAR(64),
  `publishedDate` DATETIME,
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498863_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498863_migration') AS relationships;
DROP DATABASE `db_498863_migration`;
UNINSTALL EXTENSION vsql_schematron;
