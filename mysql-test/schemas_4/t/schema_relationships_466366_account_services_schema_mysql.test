INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 466366_account-services-schema-mysql
--echo #
CREATE DATABASE `db_466366_account_services_schema_mysql`;
USE `db_466366_account_services_schema_mysql`;

CREATE TABLE `account_table` (
  `id` INT,
  `uid` VARCHAR(64),
  `account_id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `currency_cd` VARCHAR(64),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_balance_table` (
  `id` INT,
  `account_id` VARCHAR(64),
  `account_balance` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `address_table` (
  `id` INT,
  `account_id` VARCHAR(64),
  `address_type` VARCHAR(64),
  `address_line_1` VARCHAR(64),
  `address_line_2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_466366_account_services_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_466366_account_services_schema_mysql') AS relationships;
DROP DATABASE `db_466366_account_services_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
