INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411239_V20200717133931__create_table
--echo #
CREATE DATABASE `db_411239_V20200717133931_create_table`;
USE `db_411239_V20200717133931_create_table`;

CREATE TABLE `eg_pgr_service_v2` (
  `id` VARCHAR(64),
  `tenantId` VARCHAR(64),
  `serviceCode` VARCHAR(64),
  `serviceRequestId` VARCHAR(64),
  `description` VARCHAR(64),
  `accountId` VARCHAR(64),
  `additionalDetails` VARCHAR(64),
  `applicationStatus` VARCHAR(64),
  `rating` INT,
  `source` VARCHAR(64),
  `createdby` VARCHAR(64),
  `createdtime` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodifiedtime` INT,
  PRIMARY KEY (`tenantId`, `serviceRequestId`)
) CHARACTER SET latin1;

CREATE TABLE `eg_pgr_address_v2` (
  `tenantId` VARCHAR(64),
  `id` VARCHAR(64),
  `parentid` VARCHAR(64),
  `doorno` VARCHAR(64),
  `plotno` VARCHAR(64),
  `buildingName` VARCHAR(64),
  `street` VARCHAR(64),
  `landmark` VARCHAR(64),
  `city` VARCHAR(64),
  `pincode` VARCHAR(64),
  `locality` VARCHAR(64),
  `district` VARCHAR(64),
  `region` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `createdby` VARCHAR(64),
  `createdtime` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodifiedtime` INT,
  `additionaldetails` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411239_V20200717133931_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411239_V20200717133931_create_table') AS relationships;
DROP DATABASE `db_411239_V20200717133931_create_table`;
UNINSTALL EXTENSION vsql_schematron;
