INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 463321_Foodfy
--echo #
CREATE DATABASE `db_463321_Foodfy`;
USE `db_463321_Foodfy`;

CREATE TABLE `chefs` (
  `id` INT,
  `name` VARCHAR(64),
  `file_id` INT,
  `created_at` DATETIME,
  `update_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipes` (
  `id` INT,
  `chef_id` INT,
  `title` VARCHAR(64),
  `ingredients` VARCHAR(64),
  `preparation` VARCHAR(64),
  `information` VARCHAR(64),
  `created_at` DATETIME,
  `update_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` INT,
  `name` VARCHAR(64),
  `path` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipes_files` (
  `id` INT,
  `recipe_id` INT,
  `file_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_463321_Foodfy') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_463321_Foodfy') AS relationships;
DROP DATABASE `db_463321_Foodfy`;
UNINSTALL EXTENSION vsql_schematron;
