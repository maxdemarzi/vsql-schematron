INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 466720_createTable
--echo #
CREATE DATABASE `db_466720_createTable`;
USE `db_466720_createTable`;

CREATE TABLE `chatting_message` (
  `id` INT,
  `chatting_type` INT,
  `group_id` INT,
  `is_group` INT,
  `message` VARCHAR(64),
  `receiver_user_id` VARCHAR(64),
  `sender_user_id` VARCHAR(64),
  `time` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_members` (
  `group_id` INT,
  `user_id` VARCHAR(64),
  PRIMARY KEY (`user_id`, `group_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` VARCHAR(64),
  `user_headIndex` INT,
  `user_name` VARCHAR(64),
  `user_password` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_friends` (
  `user_id` VARCHAR(64),
  `friend_id` VARCHAR(64),
  PRIMARY KEY (`user_id`, `friend_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_group` (
  `group_id` INT,
  `group_name` VARCHAR(64),
  `creater_id` VARCHAR(64),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_466720_createTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_466720_createTable') AS relationships;
DROP DATABASE `db_466720_createTable`;
UNINSTALL EXTENSION vsql_schematron;
