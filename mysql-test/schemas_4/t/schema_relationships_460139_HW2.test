INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 460139_HW2
--echo #
CREATE DATABASE `db_460139_HW2`;
USE `db_460139_HW2`;

CREATE TABLE `january` (
  `UNFLID` VARCHAR(64),
  `DAY_OF_MONTH` INT,
  `DAY_OF_WEEK` INT,
  `FL_DATE` VARCHAR(64),
  `OP_CARRIER_AIRLINE_ID` INT,
  `TAIL_NUM` VARCHAR(64),
  `OP_CARRIER_FL_NUM` INT,
  `ORIGIN_AIRPORT_ID` INT,
  `ORIGIN_CITY_NAME` VARCHAR(64),
  `ORIGIN_STATE_NM` VARCHAR(64),
  `DEST_CITY_NAME` VARCHAR(64),
  `DEST_STATE_NM` VARCHAR(64),
  `CRS_DEP_TIME` INT,
  PRIMARY KEY (`UNFLID`)
) CHARACTER SET latin1;

CREATE TABLE `candiv` (
  `UNFLID` VARCHAR(64),
  `CANCELLED` DECIMAL(10,2),
  `CANCELLATION_CODE` VARCHAR(64),
  `DIVERTED` DECIMAL(10,2),
  PRIMARY KEY (`UNFLID`)
) CHARACTER SET latin1;

CREATE TABLE `fsummary` (
  `UNFLID` VARCHAR(64),
  `CRS_ELAPSED_TIME` DECIMAL(10,2),
  `ACTUAL_ELAPSED_TIME` DECIMAL(10,2),
  `AIR_TIME` DECIMAL(10,2),
  `FLIGHTS` DECIMAL(10,2),
  `DISTANCE` DECIMAL(10,2),
  `DISTANCE_GROUP` INT,
  PRIMARY KEY (`UNFLID`)
) CHARACTER SET latin1;

CREATE TABLE `depperf` (
  `UNFLID` VARCHAR(64),
  `DEP_TIME` DECIMAL(10,2),
  `DEP_DELAY` DECIMAL(10,2),
  `DEP_DEL15` DECIMAL(10,2),
  `DEP_DELAY_GROUP` DECIMAL(10,2),
  PRIMARY KEY (`UNFLID`)
) CHARACTER SET latin1;

CREATE TABLE `arrperf` (
  `UNFLID` VARCHAR(64),
  `CRS_ARR_TIME` DECIMAL(10,2),
  `ARR_TIME` DECIMAL(10,2),
  `ARR_DELAY` DECIMAL(10,2),
  `ARR_DEL15` DECIMAL(10,2),
  `ARR_DELAY_GROUP` DECIMAL(10,2),
  PRIMARY KEY (`UNFLID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_460139_HW2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_460139_HW2') AS relationships;
DROP DATABASE `db_460139_HW2`;
UNINSTALL EXTENSION vsql_schematron;
