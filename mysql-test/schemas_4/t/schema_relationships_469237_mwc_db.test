INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 469237_mwc-db
--echo #
CREATE DATABASE `db_469237_mwc_db`;
USE `db_469237_mwc_db`;

CREATE TABLE `customer` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `licenseNo` VARCHAR(64),
  `contactNo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `driver` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `contactNo` VARCHAR(64),
  `licenseNo` VARCHAR(64),
  `salaryPerDay` DECIMAL(10,2),
  `statues` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `issue` (
  `id` VARCHAR(64),
  `date` DATETIME,
  `vehicleId` VARCHAR(64),
  `customerId` VARCHAR(64),
  `statues` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `issuedetail` (
  `issueId` VARCHAR(64),
  `driverId` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `owner` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `contactNo` VARCHAR(64),
  `address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `return` (
  `issueId` VARCHAR(64),
  `returnDate` DATETIME,
  `additionalDistance` INT,
  `damageCost` DECIMAL(10,2),
  `total` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `userName` VARCHAR(64),
  `password` VARCHAR(64),
  `address` VARCHAR(64),
  `contactNo` VARCHAR(64),
  PRIMARY KEY (`password`)
) CHARACTER SET latin1;

CREATE TABLE `vehicle` (
  `id` VARCHAR(64),
  `registerNo` VARCHAR(64),
  `categoryId` VARCHAR(64),
  `modelName` VARCHAR(64),
  `statues` VARCHAR(64),
  `ownerId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vehiclecategory` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `rentalForDay` DECIMAL(10,2),
  `rentalForKM` DECIMAL(10,2),
  `kilometerePerDay` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_469237_mwc_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_469237_mwc_db') AS relationships;
DROP DATABASE `db_469237_mwc_db`;
UNINSTALL EXTENSION vsql_schematron;
