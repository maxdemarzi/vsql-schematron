INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 413203_db2_spinner
--echo #
CREATE DATABASE `db_413203_db2_spinner`;
USE `db_413203_db2_spinner`;

CREATE TABLE `spinnerDB2.class` (
  `classId` INT,
  `className` VARCHAR(64),
  `hyperLink` VARCHAR(64),
  PRIMARY KEY (`classId`)
) CHARACTER SET latin1;

CREATE TABLE `spinnerDB2.person` (
  `personId` INT,
  `phoneNumber` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  `birthDate` DATETIME,
  PRIMARY KEY (`personId`, `phoneNumber`, `firstName`)
) CHARACTER SET latin1;

CREATE TABLE `spinnerDB2.personClass` (
  `classId` INT,
  `personId` INT,
  `type` VARCHAR(64),
  `numberOfValidRegistrations` INT
) CHARACTER SET latin1;

CREATE TABLE `spinnerDB2.events` (
  `eventId` INT,
  `classId` INT,
  `eventName` VARCHAR(64),
  `fromDate` DATETIME,
  `toDate` DATETIME,
  `lockTime` INT,
  `openDate` DATETIME,
  `maxCapacity` INT,
  `instructorId` INT,
  `address` VARCHAR(64),
  `comments` VARCHAR(64),
  `created` DATETIME,
  `lastUpdated` DATETIME,
  `status` VARCHAR(64),
  PRIMARY KEY (`eventId`, `classId`, `eventName`, `fromDate`)
) CHARACTER SET latin1;

CREATE TABLE `spinnerDB2.registration` (
  `classId` INT,
  `eventId` INT,
  `personId` INT,
  `status` VARCHAR(64),
  `lastUpdated` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_413203_db2_spinner') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_413203_db2_spinner') AS relationships;
DROP DATABASE `db_413203_db2_spinner`;
UNINSTALL EXTENSION vsql_schematron;
