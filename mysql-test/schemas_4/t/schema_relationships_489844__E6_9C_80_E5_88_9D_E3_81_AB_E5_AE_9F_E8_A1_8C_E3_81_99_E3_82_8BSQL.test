CREATE DATABASE `db_489844__E6_9C_80_E5_88_9D_E3_81_AB_E5_AE_9F_E8_A1_8C_E3_81_99`;
USE `db_489844__E6_9C_80_E5_88_9D_E3_81_AB_E5_AE_9F_E8_A1_8C_E3_81_99`;
CREATE TABLE `baggages` (
  `baggage_id` VARCHAR(50) NOT NULL,
  `tracking_number` VARCHAR(50),
  `baggage_status_id` INT,
  PRIMARY KEY (`baggage_id`)
) CHARACTER SET latin1;
CREATE TABLE `baggage_statuses` (
  `baggage_status_id` INT NOT NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`baggage_status_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
