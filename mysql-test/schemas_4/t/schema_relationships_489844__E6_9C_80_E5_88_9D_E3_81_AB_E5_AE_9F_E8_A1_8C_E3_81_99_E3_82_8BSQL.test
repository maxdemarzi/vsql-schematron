  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489844__E6_9C_80_E5_88_9D_E3_81_AB_E5_AE_9F_E8_A1_8C_E3_81_99') AS relationships;
DROP DATABASE `db_489844__E6_9C_80_E5_88_9D_E3_81_AB_E5_AE_9F_E8_A1_8C_E3_81_99`;
