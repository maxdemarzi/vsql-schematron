INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450180_2-Orders
--echo #
CREATE DATABASE `db_450180_2_Orders`;
USE `db_450180_2_Orders`;
CREATE TABLE `salesman` (
  `salesman_id` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `commission` DECIMAL(10,2),
  PRIMARY KEY (`salesman_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `customer_id` DECIMAL(10,2) NOT NULL,
  `customer_name` VARCHAR(50),
  `city` VARCHAR(50),
  `grade` DECIMAL(10,2),
  `salesman_id` DECIMAL(10,2),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `ord_no` DECIMAL(10,2) NOT NULL,
  `purchase_amt` DECIMAL(10,2),
  `ord_date` DATE,
  `customer_id` DECIMAL(10,2),
  `salesman_id` DECIMAL(10,2),
  PRIMARY KEY (`ord_no`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450180_2_Orders') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450180_2_Orders') AS relationships;
DROP DATABASE `db_450180_2_Orders`;
UNINSTALL EXTENSION vsql_schematron;
