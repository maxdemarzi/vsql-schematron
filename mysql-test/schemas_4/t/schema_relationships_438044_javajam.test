INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438044_javajam
--echo #
CREATE DATABASE `db_438044_javajam`;
USE `db_438044_javajam`;

CREATE TABLE `jobs` (
  `JobsId` INT,
  `Name` VARCHAR(255),
  `Email` VARCHAR(255),
  `Experience` VARCHAR(255),
  PRIMARY KEY (`JobsId`)
) CHARACTER SET latin1;

CREATE TABLE `musician` (
  `MusicianID` INT,
  `Name` VARCHAR(255),
  `Musician_Image_URL` VARCHAR(255),
  PRIMARY KEY (`MusicianID`)
) CHARACTER SET latin1;

CREATE TABLE `orderitems` (
  `ProductId` INT,
  `Qty` INT,
  `Price` DECIMAL(10,2),
  `OrderId` INT
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `Orderid` INT,
  `Name` VARCHAR(255),
  `Email` VARCHAR(255),
  `Address` VARCHAR(255),
  `City` VARCHAR(255),
  `State` VARCHAR(255),
  `Zip` VARCHAR(255),
  `Credit_Card` VARCHAR(255),
  `Month` VARCHAR(255),
  `Year` VARCHAR(255),
  PRIMARY KEY (`Orderid`)
) CHARACTER SET latin1;

CREATE TABLE `performance` (
  `PerformanceID` INT,
  `MusicianID` INT,
  `MonthYear` VARCHAR(255),
  `Description` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `ProductId` INT,
  `Name` VARCHAR(255),
  `Description` VARCHAR(255),
  `Product_Image_URL` VARCHAR(255),
  `Price` VARCHAR(255),
  PRIMARY KEY (`ProductId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438044_javajam') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438044_javajam') AS relationships;
DROP DATABASE `db_438044_javajam`;
UNINSTALL EXTENSION vsql_schematron;
