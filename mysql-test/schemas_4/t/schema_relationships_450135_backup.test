INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450135_backup
--echo #
CREATE DATABASE `db_450135_backup`;
USE `db_450135_backup`;
CREATE TABLE `J` (
  `JNO` VARCHAR(50) NOT NULL,
  `JNAME` CHAR(50),
  `CITY` CHAR(50),
  PRIMARY KEY (`JNO`)
) CHARACTER SET latin1;
CREATE TABLE `P` (
  `PNO` VARCHAR(50) NOT NULL,
  `PNAME` CHAR(50),
  `COLOR` CHAR(50),
  `WEIGHT` INT,
  PRIMARY KEY (`PNO`)
) CHARACTER SET latin1;
CREATE TABLE `SPJ` (
  `SNO` VARCHAR(50) NOT NULL,
  `PNO` VARCHAR(50) NOT NULL,
  `JNO` VARCHAR(50) NOT NULL,
  `QTY` INT,
  PRIMARY KEY (`SNO`, `PNO`, `JNO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450135_backup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450135_backup') AS relationships;
DROP DATABASE `db_450135_backup`;
UNINSTALL EXTENSION vsql_schematron;
