INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492898_v1
--echo #
CREATE DATABASE `db_492898_v1`;
USE `db_492898_v1`;
CREATE TABLE `events` (
  `id` VARCHAR(50) NOT NULL,
  `date` INT,
  `event` TEXT,
  `domain` TEXT,
  `url` TEXT,
  `session` TEXT,
  `ip` TEXT,
  `note` TEXT,
  `isMobile` TEXT,
  `isDesktop` TEXT,
  `isBot` TEXT,
  `browser` TEXT,
  `version` TEXT,
  `os` TEXT,
  `platform` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events_extra` (
  `event_id` TEXT,
  `key` TEXT,
  `value` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492898_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492898_v1') AS relationships;
DROP DATABASE `db_492898_v1`;
UNINSTALL EXTENSION vsql_schematron;
