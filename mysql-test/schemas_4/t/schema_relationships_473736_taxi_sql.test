INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473736_taxi-sql
--echo #
CREATE DATABASE `db_473736_taxi_sql`;
USE `db_473736_taxi_sql`;

CREATE TABLE `auto` (
  `id` INT,
  `mark` VARCHAR(64),
  `auto_number` VARCHAR(64),
  `auto_type` VARCHAR(64),
  `state` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `license` (
  `id` INT,
  `date_of_issue` VARCHAR(64),
  `place_of_issue` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `driver_taxi_info` (
  `id` INT,
  `driving_experience` DECIMAL(10,2),
  `rating_driver` DECIMAL(10,2),
  `license_id` INT,
  `auto_id` INT,
  `is_booked` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passenger_taxi_info` (
  `id` INT,
  `date_of_registration` VARCHAR(64),
  `taxi_trip_history_id` INT,
  `rating` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passenger` (
  `id` INT,
  `first_name` VARCHAR(64),
  `second_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `date_of_birth` VARCHAR(64),
  `passenger_taxi_info_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `driver` (
  `id` INT,
  `first_name` VARCHAR(64),
  `second_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `date_of_birth` VARCHAR(64),
  `driver_taxi_info_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473736_taxi_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473736_taxi_sql') AS relationships;
DROP DATABASE `db_473736_taxi_sql`;
UNINSTALL EXTENSION vsql_schematron;
