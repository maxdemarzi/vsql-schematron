INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 467082_schema
--echo #
CREATE DATABASE `db_467082_schema`;
USE `db_467082_schema`;

CREATE TABLE `authors` (
  `author_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `isbn` INT,
  `format` VARCHAR(64),
  `title` VARCHAR(64),
  `author_id` INT,
  PRIMARY KEY (`isbn`, `format`)
) CHARACTER SET latin1;

CREATE TABLE `awards` (
  `award_id` INT,
  `award_name` VARCHAR(64),
  PRIMARY KEY (`award_id`)
) CHARACTER SET latin1;

CREATE TABLE `book_awards` (
  `isbn` INT,
  `format` VARCHAR(64),
  `award_id` INT,
  PRIMARY KEY (`isbn`, `format`, `award_id`)
) CHARACTER SET latin1;

CREATE TABLE `author_awards` (
  `author_id` INT,
  `award_id` INT,
  PRIMARY KEY (`author_id`, `award_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_467082_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_467082_schema') AS relationships;
DROP DATABASE `db_467082_schema`;
UNINSTALL EXTENSION vsql_schematron;
