INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458335_blog
--echo #
CREATE DATABASE `db_458335_blog`;
USE `db_458335_blog`;
CREATE TABLE `articles` (
  `id` INT,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `body` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `categoryId` INT
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458335_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458335_blog') AS relationships;
DROP DATABASE `db_458335_blog`;
UNINSTALL EXTENSION vsql_schematron;
