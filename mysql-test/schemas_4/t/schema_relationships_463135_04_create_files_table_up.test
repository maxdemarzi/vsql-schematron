INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 463135_04.create_files_table.up
--echo #
CREATE DATABASE `db_463135_04_create_files_table_up`;
USE `db_463135_04_create_files_table_up`;

CREATE TABLE `ra_files` (
  `id` INT,
  `node_id` INT,
  `parent_id` INT,
  `job_id` INT,
  `dir` VARCHAR(64),
  `file` VARCHAR(64),
  `type` VARCHAR(64),
  `inserted_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ra_file_logs` (
  `id` INT,
  `node_id` INT,
  `file_id` INT,
  `source_user_id` INT,
  `type` VARCHAR(64),
  `data` VARCHAR(64),
  `inserted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_463135_04_create_files_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_463135_04_create_files_table_up') AS relationships;
DROP DATABASE `db_463135_04_create_files_table_up`;
UNINSTALL EXTENSION vsql_schematron;
