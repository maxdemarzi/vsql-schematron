  `eng_code` VARCHAR(64),
  `priority` INT,
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `street_prefixes` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
