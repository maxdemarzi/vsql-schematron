  `remember_token` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `initial_password` VARCHAR(64),
  `user_type_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user_permissions` (
  `id` INT,
  `user_id` INT,
