INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402784_crm
--echo #
CREATE DATABASE `db_402784_crm`;
USE `db_402784_crm`;

CREATE TABLE `companies` (
  `id` INT,
  `name` VARCHAR(64),
  `common_name` VARCHAR(64),
  `company_type_id` INT,
  `nip` VARCHAR(64),
  `regon` VARCHAR(64),
  `krs` VARCHAR(64),
  `street_prefix_id` INT,
  `street` VARCHAR(64),
  `house_number` VARCHAR(64),
  `apartment_number` VARCHAR(64),
  `zip_code` VARCHAR(64),
  `city` VARCHAR(64),
  `borough` VARCHAR(64),
  `county` VARCHAR(64),
  `voivodship` VARCHAR(64),
  `email` VARCHAR(64),
  `web_page` VARCHAR(64),
  `fax` VARCHAR(64),
  `coordinates_lat` DECIMAL(10,2),
  `coordinates_lng` DECIMAL(10,2),
  `coordinates_checked` INT,
  `google_map_place` VARCHAR(64),
  `parent_company_id` INT,
  `correspondence_street_prefix_id` INT,
  `correspondence_street` VARCHAR(64),
  `correspondence_house_number` VARCHAR(64),
  `correspondence_apartment_number` VARCHAR(64),
  `correspondence_zip_code` VARCHAR(64),
  `correspondence_city` VARCHAR(64),
  `correspondence_borough` VARCHAR(64),
  `correspondence_county` VARCHAR(64),
  `correspondence_voivodship` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company_comments` (
  `id` INT,
  `content` VARCHAR(64),
  `user_id` INT,
  `company_id` INT,
  `company_comment_type_id` INT,
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company_comment_types` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company_files` (
  `id` INT,
  `file` VARCHAR(64),
  `file_2` VARCHAR(64),
  `company_id` INT,
  `description` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company_types` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `languages` (
  `id` INT,
  `name` VARCHAR(64),
  `priority` INT,
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `people` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `distinction` VARCHAR(64),
  `sex_id` INT,
  `language_id` INT,
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `path` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `person_comments` (
  `id` INT,
  `content` VARCHAR(64),
  `user_id` INT,
  `person_id` INT,
  `person_comment_type_id` INT,
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `person_comment_types` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `positions` (
  `id` INT,
  `person_id` INT,
  `company_id` INT,
