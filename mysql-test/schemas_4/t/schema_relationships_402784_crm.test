  `phone` VARCHAR(64),
  `phone_2` VARCHAR(64),
  `phone_3` VARCHAR(64),
  `email` VARCHAR(64),
  `email_2` VARCHAR(64),
  `comment` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `position_tasks` (
  `id` INT,
