INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499484_labbench_9_1_mysql
--echo #
CREATE DATABASE `db_499484_labbench_9_1_mysql`;
USE `db_499484_labbench_9_1_mysql`;

CREATE TABLE `failure_reason` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `assembly` (
  `id` INT,
  `extraction_id` VARCHAR(255),
  `workflow` INT,
  `progress` VARCHAR(255),
  `consensus` VARCHAR(255),
  `params` VARCHAR(255),
  `coverage` DECIMAL(10,2),
  `disagreements` INT,
  `edits` VARCHAR(255),
  `reference_seq_id` INT,
  `confidence_scores` VARCHAR(255),
  `trim_params_fwd` VARCHAR(255),
  `trim_params_rev` VARCHAR(255),
  `other_processing_fwd` VARCHAR(255),
  `other_processing_rev` VARCHAR(255),
  `date` DATETIME,
  `submitted` INT,
  `editrecord` VARCHAR(255),
  `notes` VARCHAR(255),
  `technician` VARCHAR(255),
  `bin` VARCHAR(255),
  `ambiguities` INT,
  `failure_reason` INT,
  `failure_notes` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gelimages` (
  `id` INT,
  `name` VARCHAR(255),
  `plate` INT,
  `imageData` VARCHAR(255),
  `notes` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `properties` (
  `name` VARCHAR(255),
  `value` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `sequencing_result` (
  `reaction` INT,
  `assembly` INT,
  PRIMARY KEY (`reaction`, `assembly`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499484_labbench_9_1_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499484_labbench_9_1_mysql') AS relationships;
DROP DATABASE `db_499484_labbench_9_1_mysql`;
UNINSTALL EXTENSION vsql_schematron;
