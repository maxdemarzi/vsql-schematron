INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435762_datadump
--echo #
CREATE DATABASE `db_435762_datadump`;
USE `db_435762_datadump`;
CREATE TABLE `antonyms` (
  `id` INT NOT NULL,
  `word_id_1` INT,
  `word_id_2` INT,
  `score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_revisions` (
  `id` INT NOT NULL,
  `article_id` INT,
  `user_id` INT,
  `language_locale` VARCHAR(50),
  `revision_date` TIMESTAMP NULL,
  `name` VARCHAR(50),
  `content` VARCHAR(50),
  `revision_note` VARCHAR(50),
  `is_undone` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bans` (
  `id` INT NOT NULL,
  `user_id` INT,
  `untill` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classifications` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `short_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cognates` (
  `id` INT NOT NULL,
  `word_id_1` INT,
  `word_id_2` INT,
  `score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `columns` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `short_name` VARCHAR(50),
  `hidden_native_entry` VARCHAR(50),
  `hidden_native_entry_short` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `column_apply` (
  `id` INT NOT NULL,
  `column_id` INT,
  `mode_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435762_datadump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435762_datadump') AS relationships;
DROP DATABASE `db_435762_datadump`;
UNINSTALL EXTENSION vsql_schematron;
