INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478654_V0.1.4__create_action
--echo #
CREATE DATABASE `db_478654_V0_1_4__create_action`;
USE `db_478654_V0_1_4__create_action`;
CREATE TABLE `ACTION` (
  `id` VARCHAR(50) NOT NULL,
  `processor_id` VARCHAR(50),
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ACTION_PARAMETER` (
  `name` VARCHAR(50),
  `value` VARCHAR(50),
  `action_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478654_V0_1_4__create_action') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478654_V0_1_4__create_action') AS relationships;
DROP DATABASE `db_478654_V0_1_4__create_action`;
UNINSTALL EXTENSION vsql_schematron;
