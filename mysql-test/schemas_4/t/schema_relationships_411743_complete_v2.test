INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411743_complete_v2
--echo #
CREATE DATABASE `db_411743_complete_v2`;
USE `db_411743_complete_v2`;

CREATE TABLE `database_version` (
  `version` INT
) CHARACTER SET latin1;

CREATE TABLE `house` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `device` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `houseid` VARCHAR(255),
  `notify` INT,
  `muted_until` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sensor` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `deviceid` VARCHAR(255),
  `type` VARCHAR(255),
  `label` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sensor_data` (
  `id` VARCHAR(255),
  `dt` DATETIME,
  `value` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411743_complete_v2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411743_complete_v2') AS relationships;
DROP DATABASE `db_411743_complete_v2`;
UNINSTALL EXTENSION vsql_schematron;
