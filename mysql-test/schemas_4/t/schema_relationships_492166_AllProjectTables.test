INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492166_AllProjectTables
--echo #
CREATE DATABASE `db_492166_AllProjectTables`;
USE `db_492166_AllProjectTables`;

CREATE TABLE `account` (
  `Cust` INT,
  `AccountNo` INT,
  `AccountType` VARCHAR(64),
  `holder` VARCHAR(64),
  `Nominee` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `atm` (
  `Cust` INT,
  `ATMID` INT,
  `Amount` INT,
  `CardLimit` INT,
  `Type` VARCHAR(64),
  `CardNo` INT,
  `ExpDate` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `Cust` INT,
  `Aadhar` INT,
  `Address` VARCHAR(64),
  `Age` INT,
  `Pan` VARCHAR(64),
  `Mobile` INT,
  `DOB` VARCHAR(64),
  PRIMARY KEY (`Cust`)
) CHARACTER SET latin1;

CREATE TABLE `customer_logs` (
  `Cust` INT,
  `action` VARCHAR(64),
  PRIMARY KEY (`Cust`)
) CHARACTER SET latin1;

CREATE TABLE `fd` (
  `Cust` INT,
  `FDid` INT,
  `Tenure` INT,
  `Interest` INT,
  `PrincipalAmount` INT
) CHARACTER SET latin1;

CREATE TABLE `fundstransfer` (
  `Cust` INT,
  `TransferID` INT,
  `TypeOfTransfer` VARCHAR(64),
  `Amount` INT,
  `Beneficiary` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `insurance` (
  `Cust` INT,
  `InsuranceID` INT,
  `Tenure` INT,
  `Premium` INT,
  `Type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `loans` (
  `Cust` INT,
  `LoanID` INT,
  `Amount` INT,
  `Interest` INT,
  `Mortgage` VARCHAR(64),
  `Payments` INT,
  `Surity` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `lockerfacility` (
  `Cust` INT,
  `LockerID` INT,
  `TypeOfLocker` VARCHAR(64),
  `LockerNo` INT
) CHARACTER SET latin1;

CREATE TABLE `mutualfunds` (
  `Cust` INT,
  `AMFICode` VARCHAR(64),
  `InitialInvestment` INT,
  `Portfolio` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `rd` (
  `Cust` INT,
  `RDid` INT,
  `Term` INT,
  `Interest` INT,
  `Amount` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492166_AllProjectTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492166_AllProjectTables') AS relationships;
DROP DATABASE `db_492166_AllProjectTables`;
UNINSTALL EXTENSION vsql_schematron;
