INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 412272_create
--echo #
CREATE DATABASE `db_412272_create`;
USE `db_412272_create`;

CREATE TABLE `users` (
  `id` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `salt` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tenants` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `car_brands` (
  `id` INT,
  `name` VARCHAR(255),
  `about` VARCHAR(255),
  `tenant_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_412272_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_412272_create') AS relationships;
DROP DATABASE `db_412272_create`;
UNINSTALL EXTENSION vsql_schematron;
