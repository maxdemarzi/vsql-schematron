INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435873_db
--echo #
CREATE DATABASE `db_435873_db`;
USE `db_435873_db`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `name` VARCHAR(64),
  `price_usd` DECIMAL(10,2),
  `description` VARCHAR(64),
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `delivered_at` DATETIME,
  `cacelled_at` DATETIME,
  `opened_at` DATETIME,
  `accepted_at` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders_items` (
  `order_id` INT,
  `item_id` INT,
  PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;

CREATE TABLE `spots` (
  `id` INT,
  `label` VARCHAR(64),
  `is_free` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `spots_users` (
  `spot_id` INT,
  `user_id` INT,
  PRIMARY KEY (`spot_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435873_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435873_db') AS relationships;
DROP DATABASE `db_435873_db`;
UNINSTALL EXTENSION vsql_schematron;
