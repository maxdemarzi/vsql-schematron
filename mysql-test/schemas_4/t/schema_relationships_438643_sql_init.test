INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438643_sql_init
--echo #
CREATE DATABASE `db_438643_sql_init`;
USE `db_438643_sql_init`;

CREATE TABLE `Department` (
  `did` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`did`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `sid` DECIMAL(10,2),
  `name` VARCHAR(64),
  `birthplace` VARCHAR(64),
  `did` DECIMAL(10,2),
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `cid` DECIMAL(10,2),
  `title` VARCHAR(64),
  `credits` DECIMAL(10,2),
  `did` DECIMAL(10,2),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;

CREATE TABLE `Teacher` (
  `tid` DECIMAL(10,2),
  `name` VARCHAR(64),
  `placeOfBirth` VARCHAR(64),
  `did` DECIMAL(10,2),
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;

CREATE TABLE `Take` (
  `sid` DECIMAL(10,2),
  `cid` DECIMAL(10,2),
  `grade` DECIMAL(10,2),
  PRIMARY KEY (`sid`, `cid`)
) CHARACTER SET latin1;

CREATE TABLE `Teach` (
  `tid` DECIMAL(10,2),
  `cid` DECIMAL(10,2),
  PRIMARY KEY (`tid`, `cid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438643_sql_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438643_sql_init') AS relationships;
DROP DATABASE `db_438643_sql_init`;
UNINSTALL EXTENSION vsql_schematron;
