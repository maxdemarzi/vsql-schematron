INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 467888_karopapier
--echo #
CREATE DATABASE `db_467888_karopapier`;
USE `db_467888_karopapier`;
CREATE TABLE `user` (
  `id` INT,
  `name` TEXT,
  `passwordHash` TEXT,
  `isAdmin` INT
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `id` INT,
  `userId` INT,
  `token` TEXT,
  `lastAccess` INT
) CHARACTER SET latin1;
CREATE TABLE `map` (
  `id` INT,
  `publicIdentifier` TEXT,
  `name` TEXT,
  `isActive` INT,
  `width` INT,
  `height` INT
) CHARACTER SET latin1;
CREATE TABLE `mapEntry` (
  `mapId` INT,
  `userId` INT,
  `sessionId` INT,
  `ip` TEXT,
  `x` INT,
  `y` INT,
  `contentId` INT
) CHARACTER SET latin1;
CREATE TABLE `content` (
  `id` INT,
  `publicIdentifier` TEXT,
  `name` TEXT
) CHARACTER SET latin1;
CREATE TABLE `mapContent` (
  `mapId` INT,
  `contentId` INT,
  `groupNumber` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_467888_karopapier') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_467888_karopapier') AS relationships;
DROP DATABASE `db_467888_karopapier`;
UNINSTALL EXTENSION vsql_schematron;
