INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 475129_Exercises_Database_1
--echo #
CREATE DATABASE `db_475129_Exercises_Database_1`;
USE `db_475129_Exercises_Database_1`;

CREATE TABLE `Complexes` (
  `ComplexID` INT,
  `ComplexName` VARCHAR(64),
  PRIMARY KEY (`ComplexID`)
) CHARACTER SET latin1;

CREATE TABLE `Tenants` (
  `TenantID` INT,
  `TenantName` VARCHAR(64),
  PRIMARY KEY (`TenantID`)
) CHARACTER SET latin1;

CREATE TABLE `Buildings` (
  `BuildingID` INT,
  `ComplexID` INT,
  `BuildingName` VARCHAR(64),
  `Address` VARCHAR(64),
  PRIMARY KEY (`BuildingID`)
) CHARACTER SET latin1;

CREATE TABLE `Apartments` (
  `AptID` INT,
  `UnitNumber` VARCHAR(64),
  `BuildingID` INT,
  PRIMARY KEY (`AptID`)
) CHARACTER SET latin1;

CREATE TABLE `Requests` (
  `RequestID` INT,
  `Status` VARCHAR(64),
  `AptID` INT,
  `Description` VARCHAR(64),
  PRIMARY KEY (`RequestID`)
) CHARACTER SET latin1;

CREATE TABLE `AptTenants` (
  `TenantID` INT,
  `AptID` INT,
  PRIMARY KEY (`TenantID`, `AptID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_475129_Exercises_Database_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_475129_Exercises_Database_1') AS relationships;
DROP DATABASE `db_475129_Exercises_Database_1`;
UNINSTALL EXTENSION vsql_schematron;
