INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 460424_initial
--echo #
CREATE DATABASE `db_460424_initial`;
USE `db_460424_initial`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  `confirmed_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_460424_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_460424_initial') AS relationships;
DROP DATABASE `db_460424_initial`;
UNINSTALL EXTENSION vsql_schematron;
