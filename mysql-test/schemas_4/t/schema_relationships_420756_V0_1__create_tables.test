INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420756_V0.1__create_tables
--echo #
CREATE DATABASE `db_420756_V0_1__create_tables`;
USE `db_420756_V0_1__create_tables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `services` (
  `id` INT NOT NULL,
  `user_id` INT,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `status` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420756_V0_1__create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420756_V0_1__create_tables') AS relationships;
DROP DATABASE `db_420756_V0_1__create_tables`;
UNINSTALL EXTENSION vsql_schematron;
