INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 443914_script
--echo #
CREATE DATABASE `db_443914_script`;
USE `db_443914_script`;

CREATE TABLE `Cliente` (
  `cpf` VARCHAR(64),
  `rg` VARCHAR(64),
  `nome` VARCHAR(64),
  `profissao` VARCHAR(64),
  `empregador` VARCHAR(64),
  `rendimento` DECIMAL(10,2),
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;

CREATE TABLE `Endereco` (
  `cep` VARCHAR(64),
  `rua` VARCHAR(64),
  `estado` VARCHAR(64),
  `pais` VARCHAR(64),
  `cpf` VARCHAR(64),
  PRIMARY KEY (`cep`)
) CHARACTER SET latin1;

CREATE TABLE `Pedidos` (
  `codigo` INT,
  `status` VARCHAR(64),
  `cpfCliente` VARCHAR(64),
  `matriculaAutomovel` VARCHAR(64),
  `codigoAgente` VARCHAR(64),
  `dataInicial` DATETIME,
  `dataModificacao` DATETIME,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `Automoveis` (
  `matricula` VARCHAR(64),
  `ano` VARCHAR(64),
  `marca` VARCHAR(64),
  `modelo` VARCHAR(64),
  `placa` VARCHAR(64),
  `status` VARCHAR(64),
  `proprietario` VARCHAR(64),
  PRIMARY KEY (`matricula`)
) CHARACTER SET latin1;

CREATE TABLE `Agente` (
  `codigoAgente` VARCHAR(64),
  PRIMARY KEY (`codigoAgente`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_443914_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_443914_script') AS relationships;
DROP DATABASE `db_443914_script`;
UNINSTALL EXTENSION vsql_schematron;
