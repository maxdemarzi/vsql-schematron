INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428313_V1.0.0__init
--echo #
CREATE DATABASE `db_428313_V1_0_0__init`;
USE `db_428313_V1_0_0__init`;
CREATE TABLE `message_entity` (
  `id` BIGINT NOT NULL,
  `message_body` VARCHAR(50),
  `message_channel` VARCHAR(50),
  `message_recipient_name` VARCHAR(50),
  `message_recipient_email` VARCHAR(50),
  `message_recipient_phone_number` VARCHAR(50),
  `message_recipient_phone_id` VARCHAR(50),
  `message_schedule_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_entity` (
  `id` BIGINT NOT NULL,
  `chat_status` VARCHAR(50),
  `chat_date` TIMESTAMP NULL,
  `message_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428313_V1_0_0__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428313_V1_0_0__init') AS relationships;
DROP DATABASE `db_428313_V1_0_0__init`;
UNINSTALL EXTENSION vsql_schematron;
