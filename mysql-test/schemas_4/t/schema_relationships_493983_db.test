INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 493983_db
--echo #
CREATE DATABASE `db_493983_db`;
USE `db_493983_db`;

CREATE TABLE `group_authorities` (
  `group_id` INT,
  `authority` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `group_members` (
  `id` INT,
  `username` VARCHAR(255),
  `group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `groups` (
  `id` INT,
  `group_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `enabled` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_493983_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_493983_db') AS relationships;
DROP DATABASE `db_493983_db`;
UNINSTALL EXTENSION vsql_schematron;
