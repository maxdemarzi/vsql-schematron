INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438535_2019-03-06-1419_create_initial_schema
--echo #
CREATE DATABASE `db_438535_2019_03_06_1419_create_initial_schema`;
USE `db_438535_2019_03_06_1419_create_initial_schema`;

CREATE TABLE `record` (
  `id` INT,
  `aggregate_report_id` INT,
  `source_ip` VARCHAR(64),
  `count` INT,
  `disposition` VARCHAR(64),
  `dkim` VARCHAR(64),
  `spf` VARCHAR(64),
  `envelope_to` VARCHAR(64),
  `envelope_from` VARCHAR(64),
  `header_from` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dkim_auth_result` (
  `id` INT,
  `record_id` INT,
  `domain` VARCHAR(64),
  `selector` VARCHAR(64),
  `dkim_result` VARCHAR(64),
  `human_result` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `policy_override_reason` (
  `id` INT,
  `record_id` INT,
  `policy_override` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `spf_auth_result` (
  `id` INT,
  `record_id` INT,
  `domain` VARCHAR(64),
  `scope` VARCHAR(64),
  `spf_result` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438535_2019_03_06_1419_create_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438535_2019_03_06_1419_create_initial_schema') AS relationships;
DROP DATABASE `db_438535_2019_03_06_1419_create_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
