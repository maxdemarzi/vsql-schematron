INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 427542_migration
--echo #
CREATE DATABASE `db_427542_migration`;
USE `db_427542_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `firstName` TEXT,
  `lastName` TEXT,
  `email` TEXT,
  `password` TEXT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Notification` (
  `id` INT NOT NULL,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_427542_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_427542_migration') AS relationships;
DROP DATABASE `db_427542_migration`;
UNINSTALL EXTENSION vsql_schematron;
