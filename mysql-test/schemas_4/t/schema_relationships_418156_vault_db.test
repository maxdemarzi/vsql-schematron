INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 418156_vault_db
--echo #
CREATE DATABASE `db_418156_vault_db`;
USE `db_418156_vault_db`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `data` (
  `data_id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `message` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`data_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_418156_vault_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_418156_vault_db') AS relationships;
DROP DATABASE `db_418156_vault_db`;
UNINSTALL EXTENSION vsql_schematron;
