INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450785_db_siip3
--echo #
CREATE DATABASE `db_450785_db_siip3`;
USE `db_450785_db_siip3`;

CREATE TABLE `addresses` (
  `id` INT,
  `alias` VARCHAR(64),
  `address_1` VARCHAR(64),
  `address_2` VARCHAR(64),
  `zip` VARCHAR(64),
  `state_code` VARCHAR(64),
  `city` VARCHAR(64),
  `province_id` INT,
  `country_id` INT,
  `customer_id` INT,
  `status` INT,
  `phone` VARCHAR(64),
  `deleted_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `attributes` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `attribute_values` (
  `id` INT,
  `value` VARCHAR(64),
  `attribute_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `attribute_value_product_attribute` (
  `attribute_value_id` INT,
  `product_attribute_id` INT
) CHARACTER SET latin1;

CREATE TABLE `brands` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `cover` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `_lft` INT,
  `_rgt` INT,
  `parent_id` INT
) CHARACTER SET latin1;

CREATE TABLE `category_product` (
  `id` INT,
  `category_id` INT,
  `product_id` INT
) CHARACTER SET latin1;

CREATE TABLE `cities` (
  `name` VARCHAR(64),
  `state_code` VARCHAR(64),
  `province_id` INT
) CHARACTER SET latin1;

CREATE TABLE `countries` (
  `id` INT,
  `name` VARCHAR(64),
  `iso` VARCHAR(64),
  `iso3` VARCHAR(64),
  `numcode` INT,
  `phonecode` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `couriers` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `url` VARCHAR(64),
  `is_free` INT,
  `cost` DECIMAL(10,2),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `status` INT,
  `stripe_id` VARCHAR(64),
  `card_brand` VARCHAR(64),
  `card_last_four` VARCHAR(64),
  `trial_ends_at` DATETIME,
  `deleted_at` DATETIME,
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `status` INT,
  `deleted_at` DATETIME,
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `reference` VARCHAR(64),
  `courier_id` INT,
  `courier` VARCHAR(64),
  `customer_id` INT,
  `address_id` INT,
  `order_status_id` INT,
  `payment` VARCHAR(64),
  `discounts` DECIMAL(10,2),
  `total_products` DECIMAL(10,2),
  `total_shipping` DECIMAL(10,2),
  `tax` DECIMAL(10,2),
  `total` DECIMAL(10,2),
  `total_paid` DECIMAL(10,2),
  `invoice` VARCHAR(64),
  `label_url` VARCHAR(64),
  `tracking_number` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `order_product` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `product_attribute_id` INT,
  `quantity` INT,
  `product_name` VARCHAR(64),
  `product_sku` VARCHAR(64),
  `product_description` VARCHAR(64),
  `product_price` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `order_statuses` (
  `id` INT,
  `name` VARCHAR(64),
  `color` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission_user` (
  `permission_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `brand_id` INT,
  `sku` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `cover` VARCHAR(64),
  `quantity` INT,
  `price` DECIMAL(10,2),
  `sale_price` DECIMAL(10,2),
  `status` INT,
  `length` DECIMAL(10,2),
  `width` DECIMAL(10,2),
  `height` DECIMAL(10,2),
  `distance_unit` VARCHAR(64),
  `weight` DECIMAL(10,2),
  `mass_unit` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_attributes` (
  `id` INT,
  `quantity` INT,
  `price` DECIMAL(10,2),
  `sale_price` VARCHAR(64),
  `default` INT,
  `product_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `product_images` (
  `id` INT,
  `product_id` INT,
  `src` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `provinces` (
  `id` INT,
  `name` VARCHAR(64),
  `country_id` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `role_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `shoppingcart` (
  `identifier` VARCHAR(64),
  `instance` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`identifier`, `instance`)
) CHARACTER SET latin1;

CREATE TABLE `states` (
  `state` VARCHAR(64),
  `state_code` VARCHAR(64),
  `country_id` INT
) CHARACTER SET latin1;

CREATE TABLE `subscriptions` (
  `id` INT,
  `customer_id` INT,
  `name` VARCHAR(64),
  `stripe_id` VARCHAR(64),
  `stripe_plan` VARCHAR(64),
  `quantity` INT,
  `trial_ends_at` DATETIME,
  `ends_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450785_db_siip3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450785_db_siip3') AS relationships;
DROP DATABASE `db_450785_db_siip3`;
UNINSTALL EXTENSION vsql_schematron;
