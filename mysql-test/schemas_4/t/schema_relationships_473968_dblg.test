INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473968_dblg
--echo #
CREATE DATABASE `db_473968_dblg`;
USE `db_473968_dblg`;
CREATE TABLE `meta` (
  `mtime` INT,
  `title` TEXT,
  `template` TEXT,
  `lock` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entry` (
  `contents` TEXT,
  `title` TEXT,
  `userid` INT,
  `lang` TEXT,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  `image` TEXT,
  `ctime` INT,
  `mtime` INT,
  `flags` INT,
  `aside` TEXT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `name` TEXT,
  `email` TEXT,
  `lang` TEXT,
  `link` TEXT,
  `hash` TEXT,
  `cloudkey` TEXT,
  `cloudsecret` TEXT,
  `cloudpath` TEXT,
  `cloudname` TEXT,
  `flags` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sess` (
  `userid` INT,
  `cookie` INT,
  `ctime` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473968_dblg') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473968_dblg') AS relationships;
DROP DATABASE `db_473968_dblg`;
UNINSTALL EXTENSION vsql_schematron;
