INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425242_193%20Student%20Advisors
--echo #
CREATE DATABASE `db_425242_193_20Student_20Advisors`;
USE `db_425242_193_20Student_20Advisors`;
CREATE TABLE `advisor` (
  `uniqueid` DECIMAL(10,2) NOT NULL,
  `external_uid` VARCHAR(50),
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `acad_title` VARCHAR(50),
  `email` VARCHAR(50),
  `session_id` DECIMAL(10,2),
  `role_id` DECIMAL(10,2),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;
CREATE TABLE `student_advisor` (
  `student_id` DECIMAL(10,2) NOT NULL,
  `advisor_id` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`student_id`, `advisor_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425242_193_20Student_20Advisors') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425242_193_20Student_20Advisors') AS relationships;
DROP DATABASE `db_425242_193_20Student_20Advisors`;
UNINSTALL EXTENSION vsql_schematron;
