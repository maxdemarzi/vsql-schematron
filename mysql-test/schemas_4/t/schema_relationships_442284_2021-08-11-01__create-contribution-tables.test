INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 442284_2021-08-11-01__create-contribution-tables
--echo #
CREATE DATABASE `db_442284_2021_08_11_01__create_contribution_tables`;
USE `db_442284_2021_08_11_01__create_contribution_tables`;
CREATE TABLE `contribution` (
  `id` VARCHAR(50) NOT NULL,
  `central_server_id` VARCHAR(50),
  `status` SMALLINT,
  `complete_date` TIMESTAMP NULL,
  `records_total` BIGINT,
  `records_processed` BIGINT,
  `records_contributed` BIGINT,
  `records_updated` BIGINT,
  `records_decontributed` BIGINT,
  `created_by` VARCHAR(50),
  `created_date` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `last_modified_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contribution_error` (
  `id` VARCHAR(50) NOT NULL,
  `contribution_id` VARCHAR(50),
  `message` VARCHAR(50),
  `record_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_442284_2021_08_11_01__create_contribution_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_442284_2021_08_11_01__create_contribution_tables') AS relationships;
DROP DATABASE `db_442284_2021_08_11_01__create_contribution_tables`;
UNINSTALL EXTENSION vsql_schematron;
