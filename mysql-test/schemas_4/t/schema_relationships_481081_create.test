INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481081_create
--echo #
CREATE DATABASE `db_481081_create`;
USE `db_481081_create`;
CREATE TABLE `user` (
  `id` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorite` (
  `id` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `abv` DECIMAL(10,2),
  `image` VARCHAR(50),
  `description` VARCHAR(50),
  `tag` VARCHAR(50),
  `userId` MEDIUMINT,
  `date` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481081_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481081_create') AS relationships;
DROP DATABASE `db_481081_create`;
UNINSTALL EXTENSION vsql_schematron;
