INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481736_create_user_table
--echo #
CREATE DATABASE `db_481736_create_user_table`;
USE `db_481736_create_user_table`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_login` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_profiles` (
  `user_id` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `birth_date` DATE,
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip_code` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `biography` TEXT,
  `url` VARCHAR(50),
  `profession` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481736_create_user_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481736_create_user_table') AS relationships;
DROP DATABASE `db_481736_create_user_table`;
UNINSTALL EXTENSION vsql_schematron;
