INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434599_LMS_20DB_20Script
--echo #
CREATE DATABASE `db_434599_LMS_20DB_20Script`;
USE `db_434599_LMS_20DB_20Script`;

CREATE TABLE `users` (
  `username` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `region` VARCHAR(64),
  `district` VARCHAR(64),
  `street` VARCHAR(64),
  `ward` VARCHAR(64),
  `email` VARCHAR(64),
  `mobile_no` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `login` (
  `username` VARCHAR(64),
  `password` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `administrator` (
  `username` VARCHAR(64),
  `admin_ID` INT,
  `date_employed` DATETIME,
  PRIMARY KEY (`admin_ID`)
) CHARACTER SET latin1;

CREATE TABLE `librarian` (
  `username` VARCHAR(64),
  `librarian_ID` INT,
  `date_employed` DATETIME,
  PRIMARY KEY (`librarian_ID`)
) CHARACTER SET latin1;

CREATE TABLE `library_member` (
  `username` VARCHAR(64),
  `member_ID` INT,
  `date_registered` DATETIME,
  `expiry_date` DATETIME,
  PRIMARY KEY (`member_ID`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `book_id` INT,
  `book_title` VARCHAR(64),
  `author` VARCHAR(64),
  `book_availability` VARCHAR(64),
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `payment_id` INT,
  `amount` INT,
  `date_paid` DATETIME,
  `payment_purpose` VARCHAR(64),
  PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;

CREATE TABLE `admin_librarian` (
  `admin_id` INT,
  `librarian_id` INT,
  PRIMARY KEY (`admin_id`, `librarian_id`)
) CHARACTER SET latin1;

CREATE TABLE `librarian_member` (
  `member_id` INT,
  `librarian_id` INT,
  PRIMARY KEY (`member_id`, `librarian_id`)
) CHARACTER SET latin1;

CREATE TABLE `librarian_book` (
  `book_id` INT,
  `librarian_id` INT,
  PRIMARY KEY (`book_id`, `librarian_id`)
) CHARACTER SET latin1;

CREATE TABLE `member_payment` (
  `payment_id` INT,
  `member_id` INT,
  PRIMARY KEY (`payment_id`, `member_id`)
) CHARACTER SET latin1;

CREATE TABLE `member_book` (
  `member_id` INT,
  `book_id` INT,
  PRIMARY KEY (`member_id`, `book_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434599_LMS_20DB_20Script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434599_LMS_20DB_20Script') AS relationships;
DROP DATABASE `db_434599_LMS_20DB_20Script`;
UNINSTALL EXTENSION vsql_schematron;
