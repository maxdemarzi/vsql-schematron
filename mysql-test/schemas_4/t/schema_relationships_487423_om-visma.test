INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 487423_om-visma
--echo #
CREATE DATABASE `db_487423_om_visma`;
USE `db_487423_om_visma`;
CREATE TABLE `person` (
  `p_id` INT,
  `p_name` VARCHAR(50),
  `p_email` VARCHAR(50),
  `p_phone` VARCHAR(50),
  `p_code` INT
) CHARACTER SET latin1;
CREATE TABLE `visit` (
  `v_id` INT,
  `p_id` INT,
  `v_time` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_487423_om_visma') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_487423_om_visma') AS relationships;
DROP DATABASE `db_487423_om_visma`;
UNINSTALL EXTENSION vsql_schematron;
