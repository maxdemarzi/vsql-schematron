INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498968_groupomania
--echo #
CREATE DATABASE `db_498968_groupomania`;
USE `db_498968_groupomania`;

CREATE TABLE `comments` (
  `id` INT,
  `comment` VARCHAR(64),
  `postId` INT,
  `userId` INT,
  `createdAt` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `userId` INT,
  `title` VARCHAR(64),
  `message` VARCHAR(64),
  `media` VARCHAR(64),
  `createdAt` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `avatar` VARCHAR(64),
  `admin` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498968_groupomania') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498968_groupomania') AS relationships;
DROP DATABASE `db_498968_groupomania`;
UNINSTALL EXTENSION vsql_schematron;
