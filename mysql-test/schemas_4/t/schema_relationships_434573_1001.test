INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434573_1001
--echo #
CREATE DATABASE `db_434573_1001`;
USE `db_434573_1001`;

CREATE TABLE `xoo` (
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `yoo` (
  `a` INT,
  `b` VARCHAR(64),
  `c` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434573_1001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434573_1001') AS relationships;
DROP DATABASE `db_434573_1001`;
UNINSTALL EXTENSION vsql_schematron;
