INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449825_schema
--echo #
CREATE DATABASE `db_449825_schema`;
USE `db_449825_schema`;
CREATE TABLE `ROOM` (
  `ROOM_ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `ROOM_NUMBER` CHAR(50),
  `BED_INFO` CHAR(50),
  PRIMARY KEY (`ROOM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `GUEST` (
  `GUEST_ID` BIGINT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `EMAIL_ADDRESS` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  `COUNTRY` VARCHAR(50),
  `STATE` VARCHAR(50),
  `PHONE_NUMBER` VARCHAR(50),
  PRIMARY KEY (`GUEST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVATION` (
  `RESERVATION_ID` BIGINT NOT NULL,
  `ROOM_ID` BIGINT,
  `GUEST_ID` BIGINT,
  `RES_DATE` DATE,
  PRIMARY KEY (`RESERVATION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROFANITY` (
  `PROFANITY_ID` BIGINT NOT NULL,
  `WORD` VARCHAR(50),
  PRIMARY KEY (`PROFANITY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROFANITYSET` (
  `PROFANITYSET_ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`PROFANITYSET_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROFANITYSETWORDS` (
  `PROFANITYSETWORDS_ID` BIGINT NOT NULL,
  `PROFANITYSET_ID` BIGINT,
  `PROFANITY_ID` BIGINT,
  PRIMARY KEY (`PROFANITYSETWORDS_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449825_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449825_schema') AS relationships;
DROP DATABASE `db_449825_schema`;
UNINSTALL EXTENSION vsql_schematron;
