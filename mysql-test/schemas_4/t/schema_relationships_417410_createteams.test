INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417410_createteams
--echo #
CREATE DATABASE `db_417410_createteams`;
USE `db_417410_createteams`;
CREATE TABLE `RECLEAGUE.TEAMS` (
  `TEAM_ID` DECIMAL(10,2) NOT NULL,
  `TEAM_NAME` VARCHAR(50),
  `CAPTAIN` VARCHAR(50),
  PRIMARY KEY (`TEAM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RECLEAGUE.TEAM_MEMBERS` (
  `TEAM_ID` DECIMAL(10,2) NOT NULL,
  `MEMBER_NAME` VARCHAR(50) NOT NULL,
  `EMAIL` VARCHAR(50),
  PRIMARY KEY (`TEAM_ID`, `MEMBER_NAME`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417410_createteams') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417410_createteams') AS relationships;
DROP DATABASE `db_417410_createteams`;
UNINSTALL EXTENSION vsql_schematron;
