INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470547_schema
--echo #
CREATE DATABASE `db_470547_schema`;
USE `db_470547_schema`;

CREATE TABLE `artists` (
  `id` INT,
  `name` VARCHAR(255),
  `genre` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `albums` (
  `id` INT,
  `artist_id` INT,
  `title` VARCHAR(255),
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `songs` (
  `id` INT,
  `title` VARCHAR(255),
  `album_id` INT,
  `length` INT,
  `track_no` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlists` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlist_songs` (
  `song_id` INT,
  `playlist_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470547_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470547_schema') AS relationships;
DROP DATABASE `db_470547_schema`;
UNINSTALL EXTENSION vsql_schematron;
