INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 475562_schema-007
--echo #
CREATE DATABASE `db_475562_schema_007`;
USE `db_475562_schema_007`;

CREATE TABLE `DATA_SETS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `UPLOADER_EMAIL` VARCHAR(64),
  `EXP_CODE` VARCHAR(64),
  `EXP_PERM_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TIME_SERIES` (
  `ID` INT,
  `DASE_ID` VARCHAR(64),
  `ROW_INDEX` INT,
  `COLUMN_INDEX` INT,
  `VALUE_GROUP_ID` VARCHAR(64),
  `IDENTIFIER` VARCHAR(64),
  `IDENTIFIER_TYPE` VARCHAR(64),
  `IDENTIFIER_HUMAN_READABLE` VARCHAR(64),
  `BSB_ID` VARCHAR(64),
  `CONFIDENCE_LEVEL` VARCHAR(64),
  `CONTROLLED_GENE` VARCHAR(64),
  `NUMBER_OF_REPLICATES` INT,
  `EXPERIMENT_TYPE` VARCHAR(64),
  `CULTIVATION_METHOD` VARCHAR(64),
  `BIOLOGICAL_REPLICATES` VARCHAR(64),
  `TIME_POINT` INT,
  `TIME_POINT_TYPE` VARCHAR(64),
  `TECHNICAL_REPLICATES` VARCHAR(64),
  `CELL_LOCATION` VARCHAR(64),
  `DATA_SET_TYPE` VARCHAR(64),
  `VALUE_TYPE` VARCHAR(64),
  `UNIT` VARCHAR(64),
  `SCALE` VARCHAR(64),
  `BI_ID` VARCHAR(64),
  `CG` VARCHAR(64),
  `VALUE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHIP_CHIP_DATA` (
  `ID` INT,
  `DASE_ID` VARCHAR(64),
  `ROW_INDEX` INT,
  `BSU_IDENTIFIER` VARCHAR(64),
  `GENE_NAME` VARCHAR(64),
  `GENE_FUNCTION` VARCHAR(64),
  `ARRAY_DESIGN` VARCHAR(64),
  `MICROARRAY_ID` INT,
  `EXPERIMENT_TYPE` VARCHAR(64),
  `CULTIVATION_METHOD` VARCHAR(64),
  `BIOLOGICAL_REPLICATES` VARCHAR(64),
  `TECHNICAL_REPLICATES` VARCHAR(64),
  `CELL_LOCATION` VARCHAR(64),
  `GROWTH_PHASE` VARCHAR(64),
  `GENOTYPE` VARCHAR(64),
  `CHIP_PEAK_POSITION_VALUE` INT,
  `CHIP_PEAK_POSITION_SCALE` VARCHAR(64),
  `CHIP_LOCAL_HEIGHT_VALUE` DECIMAL(10,2),
  `CHIP_LOCAL_HEIGHT_SCALE` VARCHAR(64),
  `CHIP_SCORE_VALUE` DECIMAL(10,2),
  `CHIP_SCORE_SCALE` VARCHAR(64),
  `INTERGENIC` BOOL,
  `NEARBY_GENE_NAMES` VARCHAR(64),
  `NEARBY_GENE_IDS` VARCHAR(64),
  `DISTANCES_FROM_START` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EVENTS` (
  `LAST_SEEN_DELETION_EVENT_ID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_475562_schema_007') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_475562_schema_007') AS relationships;
DROP DATABASE `db_475562_schema_007`;
UNINSTALL EXTENSION vsql_schematron;
