INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411524_init_schema
--echo #
CREATE DATABASE `db_411524_init_schema`;
USE `db_411524_init_schema`;

CREATE TABLE `tbl_user` (
  `id` VARCHAR(255),
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email_address` VARCHAR(255),
  `addr_city` VARCHAR(255),
  `addr_state_prov` VARCHAR(255),
  `addr_zip_code` VARCHAR(255),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_account` (
  `id` VARCHAR(255),
  `user_name` VARCHAR(255),
  `access_code` VARCHAR(255),
  `user_id` VARCHAR(255),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_task` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `done` VARCHAR(255),
  `date_created` DATETIME,
  `next_task` VARCHAR(255),
  `parent_task` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_assignment` (
  `id` VARCHAR(255),
  `task_id` VARCHAR(255),
  `assignee_id` VARCHAR(255),
  `date_assigned` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411524_init_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411524_init_schema') AS relationships;
DROP DATABASE `db_411524_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
