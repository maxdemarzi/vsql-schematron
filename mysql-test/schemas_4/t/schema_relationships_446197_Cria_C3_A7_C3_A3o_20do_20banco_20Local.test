--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_446197_Cria_C3_A7_C3_A3o_20do_20banco_20Local') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_446197_Cria_C3_A7_C3_A3o_20do_20banco_20Local') AS relationships;
DROP DATABASE `db_446197_Cria_C3_A7_C3_A3o_20do_20banco_20Local`;
