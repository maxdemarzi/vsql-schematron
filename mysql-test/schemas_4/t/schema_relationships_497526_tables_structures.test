INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497526_tables_structures
--echo #
CREATE DATABASE `db_497526_tables_structures`;
USE `db_497526_tables_structures`;

CREATE TABLE `rpm_future_retail` (
  `future_retail_id` INT,
  `item` VARCHAR(64),
  `location` INT,
  `action_date` DATETIME,
  `selling_retail` DECIMAL(10,2),
  `selling_retail_currency` VARCHAR(64),
  `selling_uom` VARCHAR(64),
  PRIMARY KEY (`future_retail_id`)
) CHARACTER SET latin1;

CREATE TABLE `rpm_zone_future_retail` (
  `zone_future_retail_id` INT,
  `item` VARCHAR(64),
  `zone` INT,
  `action_date` DATETIME,
  `selling_retail` DECIMAL(10,2),
  `selling_retail_currency` VARCHAR(64),
  `selling_uom` VARCHAR(64),
  PRIMARY KEY (`zone_future_retail_id`)
) CHARACTER SET latin1;

CREATE TABLE `rpm_zone_location` (
  `zone_id` INT,
  `location` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497526_tables_structures') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497526_tables_structures') AS relationships;
DROP DATABASE `db_497526_tables_structures`;
UNINSTALL EXTENSION vsql_schematron;
