INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 467398_1-MySQLCreateTables
--echo #
CREATE DATABASE `db_467398_1_MySQLCreateTables`;
USE `db_467398_1_MySQLCreateTables`;
CREATE TABLE `User` (
  `id` BIGINT NOT NULL,
  `userName` VARCHAR(50),
  `password` VARCHAR(50),
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `role` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Province` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTestType` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTest` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `date` DATETIME,
  `price` DECIMAL(10,2),
  `maxParticipants` INT,
  `numParticipants` INT,
  `sportTestTypeId` BIGINT,
  `location` VARCHAR(50),
  `provinceId` BIGINT,
  `rating` DECIMAL(10,2),
  `numRatings` INT,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Inscription` (
  `id` BIGINT NOT NULL,
  `userId` BIGINT,
  `sportTestId` BIGINT,
  `cardNumber` VARCHAR(50),
  `reservationDate` DATETIME,
  `price` DECIMAL(10,2),
  `dorsal` INT,
  `dorsalCollected` BOOLEAN,
  `score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_467398_1_MySQLCreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_467398_1_MySQLCreateTables') AS relationships;
DROP DATABASE `db_467398_1_MySQLCreateTables`;
UNINSTALL EXTENSION vsql_schematron;
