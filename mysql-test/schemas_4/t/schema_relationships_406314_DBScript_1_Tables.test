INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 406314_DBScript_1_Tables
--echo #
CREATE DATABASE `db_406314_DBScript_1_Tables`;
USE `db_406314_DBScript_1_Tables`;
CREATE TABLE `PERSONS_TBL` (
  `PERSON_ID` INT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  PRIMARY KEY (`PERSON_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TELTYPES_TBL` (
  `TELTYPE_ID` INT NOT NULL,
  `TELTYPE_NAME` VARCHAR(50),
  PRIMARY KEY (`TELTYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TELEPHONES_TBL` (
  `TELEPHONE_ID` INT NOT NULL,
  `PERSON_ID` INT,
  `TELTYPE_ID` INT,
  `TEL_NUMBER` VARCHAR(50),
  PRIMARY KEY (`TELEPHONE_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_406314_DBScript_1_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_406314_DBScript_1_Tables') AS relationships;
DROP DATABASE `db_406314_DBScript_1_Tables`;
UNINSTALL EXTENSION vsql_schematron;
