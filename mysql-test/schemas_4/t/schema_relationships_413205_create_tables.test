INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 413205_create_tables
--echo #
CREATE DATABASE `db_413205_create_tables`;
USE `db_413205_create_tables`;

CREATE TABLE `account` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `card` (
  `id` INT,
  `card_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `game` (
  `id` INT,
  `status` VARCHAR(64),
  `weapon_id` INT,
  `suspect_id` INT,
  `room_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `player` (
  `id` INT,
  `account_id` INT,
  `game_id` INT,
  `number` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `player_card` (
  `player_id` INT,
  `card_id` INT
) CHARACTER SET latin1;

CREATE TABLE `move` (
  `id` INT,
  `player_id` INT,
  `number` INT,
  `location` INT,
  `weapon_id` INT,
  `suspect_id` INT,
  `room_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_413205_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_413205_create_tables') AS relationships;
DROP DATABASE `db_413205_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
