INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 462037_email_tb
--echo #
CREATE DATABASE `db_462037_email_tb`;
USE `db_462037_email_tb`;

CREATE TABLE `timeline_seq` (
  `num` INT
) CHARACTER SET latin1;

CREATE TABLE `history_seq` (
  `num` INT
) CHARACTER SET latin1;

CREATE TABLE `attachment` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `mimetype` VARCHAR(64),
  `filename` VARCHAR(64),
  `content` VARCHAR(64),
  `data_uri` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `mimetype` VARCHAR(64),
  `subject` VARCHAR(64),
  `snippet` VARCHAR(64),
  `content` VARCHAR(64),
  `body_uri` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `parent_id` VARCHAR(64),
  `thread_id` VARCHAR(64),
  `fwd` BOOL,
  `tags` VARCHAR(64),
  `message_id` VARCHAR(64),
  `sent_at` DATETIME,
  `received_at` DATETIME,
  `snoozed_at` DATETIME,
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipient` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `email_address` VARCHAR(64),
  `display_name` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `label` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `type` VARCHAR(64),
  `name` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `filter` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `name` VARCHAR(64),
  `criteria` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email_attachment` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `email_id` VARCHAR(64),
  `attachment_id` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email_recipient` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `email_id` VARCHAR(64),
  `recipient_id` VARCHAR(64),
  `type` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email_label` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `email_id` VARCHAR(64),
  `label_id` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `filter_label` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `filter_id` VARCHAR(64),
  `label_id` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `filter_recipient` (
  `id` VARCHAR(64),
  `owner` VARCHAR(64),
  `filter_id` VARCHAR(64),
  `recipient_id` VARCHAR(64),
  `type` VARCHAR(64),
  `timeline_id` INT,
  `history_id` INT,
  `deleted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `un_deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_462037_email_tb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_462037_email_tb') AS relationships;
DROP DATABASE `db_462037_email_tb`;
UNINSTALL EXTENSION vsql_schematron;
