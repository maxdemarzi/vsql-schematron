INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438450_V1_0_3_init_tables
--echo #
CREATE DATABASE `db_438450_V1_0_3_init_tables`;
USE `db_438450_V1_0_3_init_tables`;

CREATE TABLE `execution_types` (
  `execution_code` VARCHAR(255),
  `execution_name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`execution_code`)
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `task_id` VARCHAR(255),
  `task_name` VARCHAR(255),
  `task_type` VARCHAR(255),
  `due_date_time` DATETIME,
  `state` VARCHAR(255),
  `task_system` VARCHAR(255),
  `security_classification` VARCHAR(255),
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `notes` VARCHAR(255),
  `major_priority` INT,
  `minor_priority` INT,
  `assignee` VARCHAR(255),
  `auto_assigned` VARCHAR(255),
  `execution_type_code` VARCHAR(255),
  `work_type` VARCHAR(255),
  `role_category` VARCHAR(255),
  `has_warnings` VARCHAR(255),
  `assignment_expiry` DATETIME,
  `case_id` VARCHAR(255),
  `case_type_id` VARCHAR(255),
  `case_category` VARCHAR(255),
  `case_name` VARCHAR(255),
  `jurisdiction` VARCHAR(255),
  `region` VARCHAR(255),
  `region_name` VARCHAR(255),
  `location` VARCHAR(255),
  `location_name` VARCHAR(255),
  `business_context` VARCHAR(255),
  `termination_reason` VARCHAR(255),
  `created` DATETIME,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;

CREATE TABLE `task_roles` (
  `task_role_id` VARCHAR(255),
  `role_name` VARCHAR(255),
  `read` VARCHAR(255),
  `own` VARCHAR(255),
  `execute` VARCHAR(255),
  `manage` VARCHAR(255),
  `cancel` VARCHAR(255),
  `refer` VARCHAR(255),
  `authorizations` VARCHAR(255),
  `assignment_priority` INT,
  `auto_assignable` VARCHAR(255),
  `role_category` VARCHAR(255),
  `task_id` VARCHAR(255),
  `created` DATETIME,
  PRIMARY KEY (`task_role_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438450_V1_0_3_init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438450_V1_0_3_init_tables') AS relationships;
DROP DATABASE `db_438450_V1_0_3_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
