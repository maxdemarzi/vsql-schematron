INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 490269_vancouvertoothpaste
--echo #
CREATE DATABASE `db_490269_vancouvertoothpaste`;
USE `db_490269_vancouvertoothpaste`;
CREATE TABLE `locations` (
  `LocationID` INT NOT NULL,
  `StoreID` INT,
  `StreetAddress` VARCHAR(50),
  `Neighborhood` VARCHAR(50),
  `City` VARCHAR(50),
  `Province` VARCHAR(50),
  `Latitude` INT,
  `Longitude` INT,
  `Elevation` INT,
  PRIMARY KEY (`LocationID`)
) CHARACTER SET latin1;
CREATE TABLE `price` (
  `ProductID` INT,
  `Items` INT,
  `Size` INT,
  `LDRP` INT,
  `LDSP` INT,
  `SDMSP` INT,
  `SDMRP` INT,
  `TTRP` INT,
  `TTSP` INT,
  `BLFRP` INT,
  `BLFSP` INT,
  `SOFRP` INT,
  `SOFSP` INT,
  `CostcoRP` INT,
  `RexallRP` INT,
  `RexallSP` INT,
  `NMRP` INT,
  `NMSP` INT
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `ProductID` INT NOT NULL,
  `Brand` VARCHAR(50),
  `Subbrand` VARCHAR(50),
  `ProductName` VARCHAR(50),
  `Whitening` INT,
  `CavityProtection` INT,
  `Sensitivity` INT,
  `RapidRelief` INT,
  `GingivitisPrevention` INT,
  `GumCare` INT,
  `FreshensBreath` INT,
  `EnamelProtection` INT,
  `ReducesTartar` INT,
  `StainRemoval` INT,
  `RemovesPlaque` INT,
  `Fluoride` INT,
  `AcidErosion` INT,
  `Remineralization` INT,
  `SugarFree` INT,
  `GlutenFree` INT,
  `ProductDescription` TEXT,
  `URL` VARCHAR(50),
  PRIMARY KEY (`ProductID`)
) CHARACTER SET latin1;
CREATE TABLE `stores` (
  `StoreID` INT NOT NULL,
  `StoreName` VARCHAR(50),
  `Company` VARCHAR(50),
  `RewardsProgram` VARCHAR(50),
  PRIMARY KEY (`StoreID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_490269_vancouvertoothpaste') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_490269_vancouvertoothpaste') AS relationships;
DROP DATABASE `db_490269_vancouvertoothpaste`;
UNINSTALL EXTENSION vsql_schematron;
