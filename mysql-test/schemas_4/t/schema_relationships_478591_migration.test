INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478591_migration
--echo #
CREATE DATABASE `db_478591_migration`;
USE `db_478591_migration`;
CREATE TABLE `Account` (
  `id` INT NOT NULL,
  `email` TEXT,
  `first_name` TEXT,
  `last_name` TEXT,
  `password` TEXT,
  `is_verified` BOOLEAN,
  `avatar` TEXT,
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Manager` (
  `id` INT NOT NULL,
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478591_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478591_migration') AS relationships;
DROP DATABASE `db_478591_migration`;
UNINSTALL EXTENSION vsql_schematron;
