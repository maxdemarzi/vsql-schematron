INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 403531_data
--echo #
CREATE DATABASE `db_403531_data`;
USE `db_403531_data`;

CREATE TABLE `GroupHosts` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Hosts` (
  `id` INT,
  `name` VARCHAR(64),
  `ip` VARCHAR(64),
  `ghid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_403531_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_403531_data') AS relationships;
DROP DATABASE `db_403531_data`;
UNINSTALL EXTENSION vsql_schematron;
