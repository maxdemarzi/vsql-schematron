INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420948_ashtutor
--echo #
CREATE DATABASE `db_420948_ashtutor`;
USE `db_420948_ashtutor`;

CREATE TABLE `comments` (
  `commentID` INT,
  `author` INT,
  `dateCreated` DATETIME,
  `label` VARCHAR(64),
  `vidID` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `userID` INT,
  `fName` VARCHAR(64),
  `lName` VARCHAR(64),
  `email` VARCHAR(64),
  `pwd` VARCHAR(64),
  `phone` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `video` (
  `vidId` INT,
  `author` INT,
  `dateCreated` DATETIME,
  `vidTopic` VARCHAR(64),
  `numViews` INT,
  `rating` DECIMAL(10,2),
  `approved` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420948_ashtutor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420948_ashtutor') AS relationships;
DROP DATABASE `db_420948_ashtutor`;
UNINSTALL EXTENSION vsql_schematron;
