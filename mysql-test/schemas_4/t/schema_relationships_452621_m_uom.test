INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 452621_m_uom
--echo #
CREATE DATABASE `db_452621_m_uom`;
USE `db_452621_m_uom`;

CREATE TABLE `m_uom` (
  `uom_id` INT,
  `uom_name` VARCHAR(64),
  `uom_code` VARCHAR(64),
  PRIMARY KEY (`uom_id`)
) CHARACTER SET latin1;

CREATE TABLE `m_uom_conversion` (
  `conversion_id` INT,
  `conversion_name` VARCHAR(64),
  `uom_basic_id` INT,
  PRIMARY KEY (`conversion_id`)
) CHARACTER SET latin1;

CREATE TABLE `m_uom_conversion_tree` (
  `conversion_id` INT,
  `uom_source_id` INT,
  `uom_target_id` INT,
  `conversion_amount` INT,
  PRIMARY KEY (`conversion_id`, `uom_source_id`, `uom_target_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_452621_m_uom') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_452621_m_uom') AS relationships;
DROP DATABASE `db_452621_m_uom`;
UNINSTALL EXTENSION vsql_schematron;
