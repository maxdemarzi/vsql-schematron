INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456015_V003__criar_tabelas_pedido_e_itens_do_pedido
--echo #
CREATE DATABASE `db_456015_V003__criar_tabelas_pedido_e_itens_do_pedido`;
USE `db_456015_V003__criar_tabelas_pedido_e_itens_do_pedido`;
CREATE TABLE `pedido` (
  `id` BIGINT NOT NULL,
  `data_pedido` DATE,
  `id_cliente` BIGINT,
  `tipo_pagamento` VARCHAR(50),
  `forma_pagamento` VARCHAR(50),
  `parcelas` INT,
  `data_pagamento` DATE,
  `valor_subtotal` DECIMAL(10,2),
  `valor_frete` DECIMAL(10,2),
  `valor_total` DECIMAL(10,2),
  `status` VARCHAR(50),
  `dias_entrega` INT,
  `data_separacao` DATE,
  `data_transporte` DATE,
  `data_entrega` DATE,
  `cep` CHAR(50),
  `logradouro` VARCHAR(50),
  `numero` VARCHAR(50),
  `complemento` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `uf` CHAR(50),
  `referencia` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `itens_pedido` (
  `id` BIGINT NOT NULL,
  `id_pedido` BIGINT,
  `id_produto` BIGINT,
  `quantidade` INT,
  `valor_unitario` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456015_V003__criar_tabelas_pedido_e_itens_do_pedido') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456015_V003__criar_tabelas_pedido_e_itens_do_pedido') AS relationships;
DROP DATABASE `db_456015_V003__criar_tabelas_pedido_e_itens_do_pedido`;
UNINSTALL EXTENSION vsql_schematron;
