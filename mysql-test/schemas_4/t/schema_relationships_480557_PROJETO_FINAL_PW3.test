INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480557_PROJETO_FINAL_PW3
--echo #
CREATE DATABASE `db_480557_PROJETO_FINAL_PW3`;
USE `db_480557_PROJETO_FINAL_PW3`;
CREATE TABLE `Usuario` (
  `idUsuario` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `userName` VARCHAR(50),
  `senha` VARCHAR(50),
  `tipo` VARCHAR(50),
  `ativo` BOOLEAN,
  `cpf` VARCHAR(50),
  PRIMARY KEY (`idUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `Produto` (
  `idProduto` INT NOT NULL,
  `descricao` VARCHAR(50),
  `preco` DOUBLE,
  PRIMARY KEY (`idProduto`)
) CHARACTER SET latin1;
CREATE TABLE `Estoque` (
  `idProduto` INT,
  `quantidade` INT
) CHARACTER SET latin1;
CREATE TABLE `Venda` (
  `idVenda` INT NOT NULL,
  `idProdutoVendido` INT,
  `quantidade` INT,
  `precoUnitario` DOUBLE,
  `precoFinal` DOUBLE,
  `dataVenda` DATE,
  `cpf` VARCHAR(50),
  PRIMARY KEY (`idVenda`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480557_PROJETO_FINAL_PW3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480557_PROJETO_FINAL_PW3') AS relationships;
DROP DATABASE `db_480557_PROJETO_FINAL_PW3`;
UNINSTALL EXTENSION vsql_schematron;
