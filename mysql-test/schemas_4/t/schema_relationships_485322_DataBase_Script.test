INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485322_DataBase_Script
--echo #
CREATE DATABASE `db_485322_DataBase_Script`;
USE `db_485322_DataBase_Script`;
CREATE TABLE `clientes` (
  `id` INT,
  `nomeFantasia` VARCHAR(50),
  `razaoSocial` VARCHAR(50),
  `Cnpj` VARCHAR(50),
  `updated_at` DATETIME,
  `created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `enderecos` (
  `id` INT NOT NULL,
  `ClienteId` INT,
  `logradouro` VARCHAR(50),
  `bairro` VARCHAR(50),
  `numero` VARCHAR(50),
  `Cep` VARCHAR(50),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485322_DataBase_Script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485322_DataBase_Script') AS relationships;
DROP DATABASE `db_485322_DataBase_Script`;
UNINSTALL EXTENSION vsql_schematron;
