INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438397_schema
--echo #
CREATE DATABASE `db_438397_schema`;
USE `db_438397_schema`;

CREATE TABLE `card_types` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `membership_type` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `memberships` (
  `id` INT,
  `description` VARCHAR(64),
  `type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rental_category` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rentals` (
  `id` INT,
  `title` VARCHAR(64),
  `created` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `member_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `access` (
  `id` INT,
  `password` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cards` (
  `id` INT,
  `user_id` INT,
  `type_id` INT,
  `number` VARCHAR(64),
  `expiration` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `loyalty` (
  `id` INT,
  `points` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rental_status` (
  `id` INT,
  `created` INT,
  `updated` INT,
  `status` INT,
  `user_id` INT,
  `rental_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438397_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438397_schema') AS relationships;
DROP DATABASE `db_438397_schema`;
UNINSTALL EXTENSION vsql_schematron;
