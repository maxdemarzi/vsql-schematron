INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405228_migration
--echo #
CREATE DATABASE `db_405228_migration`;
USE `db_405228_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `avatar` VARCHAR(64),
  `role` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `RecipeCategory` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Recipe` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `ingredients` VARCHAR(64),
  `directions` VARCHAR(64),
  `serves` INT,
  `prepTime` INT,
  `cookingTime` INT,
  `imageUrl` VARCHAR(64),
  `source` VARCHAR(64),
  `tags` VARCHAR(64),
  `recipeCuisineId` VARCHAR(64),
  `recipeCourseId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_RecipeToUser` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405228_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405228_migration') AS relationships;
DROP DATABASE `db_405228_migration`;
UNINSTALL EXTENSION vsql_schematron;
