INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473366_schema
--echo #
CREATE DATABASE `db_473366_schema`;
USE `db_473366_schema`;

CREATE TABLE `users` (
  `user_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `role_id` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `articles` (
  `article_id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `timestamp` VARCHAR(64),
  `is_published` INT,
  PRIMARY KEY (`article_id`)
) CHARACTER SET latin1;

CREATE TABLE `authors_articles` (
  `user_id` INT,
  `article_id` INT,
  PRIMARY KEY (`user_id`, `article_id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `comment_id` INT,
  `comment` VARCHAR(64),
  `article_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473366_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473366_schema') AS relationships;
DROP DATABASE `db_473366_schema`;
UNINSTALL EXTENSION vsql_schematron;
