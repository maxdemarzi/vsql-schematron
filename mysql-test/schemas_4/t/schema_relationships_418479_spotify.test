INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 418479_spotify
--echo #
CREATE DATABASE `db_418479_spotify`;
USE `db_418479_spotify`;

CREATE TABLE `album` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `album_type` VARCHAR(64),
  `release_date` DATETIME,
  `genres` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `album_track` (
  `album_id` VARCHAR(64),
  `track_id` VARCHAR(64),
  PRIMARY KEY (`album_id`, `track_id`)
) CHARACTER SET latin1;

CREATE TABLE `artist` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlist` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `playlist_track` (
  `playlist_id` VARCHAR(64),
  `track_id` VARCHAR(64),
  `added_at` DATETIME,
  `added_by` VARCHAR(64),
  PRIMARY KEY (`playlist_id`, `track_id`)
) CHARACTER SET latin1;

CREATE TABLE `track` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `track_artist` (
  `track_id` VARCHAR(64),
  `artist_id` VARCHAR(64),
  PRIMARY KEY (`track_id`, `artist_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_418479_spotify') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_418479_spotify') AS relationships;
DROP DATABASE `db_418479_spotify`;
UNINSTALL EXTENSION vsql_schematron;
