INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 406239_Megaclima
--echo #
CREATE DATABASE `db_406239_Megaclima`;
USE `db_406239_Megaclima`;
CREATE TABLE `cliente` (
  `ID_CLIENTE` INT NOT NULL,
  `NOMBRE` VARCHAR(50),
  `RUT` INT,
  `DIRECCIÓN` VARCHAR(50),
  `TELEFONO` INT,
  `EMAIL` VARCHAR(50),
  `ciudad` VARCHAR(50),
  PRIMARY KEY (`ID_CLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `detalle` (
  `ID_DETALLE` INT NOT NULL,
  `ID_SERVICIO` INT,
  `ID_PEDIDO` INT,
  `FECHA` DATE,
  PRIMARY KEY (`ID_DETALLE`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `ID_PEDIDO` INT NOT NULL,
  `FECHA` DATE,
  `ESTADO` VARCHAR(50),
  `ID_CLIENTE` INT,
  `CANTIDAD` INT,
  PRIMARY KEY (`ID_PEDIDO`)
) CHARACTER SET latin1;
CREATE TABLE `servicio` (
  `ID_SERVICIO` INT NOT NULL,
  `SERVICIO` VARCHAR(50),
  `VALOR` INT,
  PRIMARY KEY (`ID_SERVICIO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_406239_Megaclima') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_406239_Megaclima') AS relationships;
DROP DATABASE `db_406239_Megaclima`;
UNINSTALL EXTENSION vsql_schematron;
