INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 448672_knowledge_checklist
--echo #
CREATE DATABASE `db_448672_knowledge_checklist`;
USE `db_448672_knowledge_checklist`;

CREATE TABLE `students` (
  `id` INT,
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mentors` (
  `id` INT,
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `region` (
  `id` INT,
  `location` VARCHAR(64),
  `stud_id` INT,
  `ment_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `techskills` (
  `id` INT,
  `lessons` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `learningobjectives` (
  `id` INT,
  `objectives` VARCHAR(64),
  `lesson_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `competencylevel` (
  `id` INT,
  `competency` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mappingskills` (
  `id` INT,
  `stud_id` INT,
  `obj_id` INT,
  `comp_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_448672_knowledge_checklist') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_448672_knowledge_checklist') AS relationships;
DROP DATABASE `db_448672_knowledge_checklist`;
UNINSTALL EXTENSION vsql_schematron;
