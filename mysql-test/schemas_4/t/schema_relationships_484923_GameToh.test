INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 484923_GameToh
--echo #
CREATE DATABASE `db_484923_GameToh`;
USE `db_484923_GameToh`;

CREATE TABLE `aboutus` (
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `categoryId` INT,
  `categoryName` VARCHAR(64),
  PRIMARY KEY (`categoryId`)
) CHARACTER SET latin1;

CREATE TABLE `contactus` (
  `msgId` INT,
  `customerId` INT,
  `subject` VARCHAR(64),
  `date` DATETIME,
  `time` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `country` (
  `countryCode` INT,
  `countryName` VARCHAR(64),
  PRIMARY KEY (`countryCode`)
) CHARACTER SET latin1;

CREATE TABLE `credentials` (
  `adminName` VARCHAR(64),
  `passkey` VARCHAR(64),
  PRIMARY KEY (`adminName`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `customerId` INT,
  `contact` VARCHAR(64),
  `fullName` VARCHAR(64),
  `city` VARCHAR(64),
  `bio` VARCHAR(64),
  `twitterHandle` VARCHAR(64),
  `website` VARCHAR(64),
  `email` VARCHAR(64),
  `creationDate` DATETIME,
  PRIMARY KEY (`customerId`)
) CHARACTER SET latin1;

CREATE TABLE `deliverers` (
  `deliverer_id` INT,
  `contact` VARCHAR(64),
  `profile_photo` VARCHAR(64),
  `email` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `city` VARCHAR(64),
  `bio` VARCHAR(64),
  `gender` VARCHAR(64),
  PRIMARY KEY (`deliverer_id`)
) CHARACTER SET latin1;

CREATE TABLE `forfoodies` (
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `forrestaurants` (
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `itemId` INT,
  `itemName` VARCHAR(64),
  `restaurantId` INT,
  `photo` VARCHAR(64),
  `price` INT,
  `categoryId` INT,
  `cuisineId` INT,
  `itemStatus` INT,
  `rating` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `ordersummary` (
  `productName` VARCHAR(64),
  `customerId` INT,
  `orderId` INT,
  `delivererId` INT,
  `restaurantId` INT,
  `quantity` INT,
  `price` INT,
  `dateOfOrder` DATETIME,
  `timeOfOrder` DATETIME,
  PRIMARY KEY (`orderId`)
) CHARACTER SET latin1;

CREATE TABLE `restaurants` (
  `restaurantId` INT,
  `contact` VARCHAR(64),
  `nm` VARCHAR(64),
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `rstate` VARCHAR(64),
  `verified` INT,
  `std` VARCHAR(64),
  `request` DATETIME,
  PRIMARY KEY (`restaurantId`)
) CHARACTER SET latin1;

CREATE TABLE `team` (
  `memberId` INT,
  `memberName` VARCHAR(64),
  `contactNumber` VARCHAR(64),
  `email` VARCHAR(64),
  `profileImage` VARCHAR(64),
  PRIMARY KEY (`memberId`)
) CHARACTER SET latin1;

CREATE TABLE `userprivilages` (
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_484923_GameToh') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_484923_GameToh') AS relationships;
DROP DATABASE `db_484923_GameToh`;
UNINSTALL EXTENSION vsql_schematron;
