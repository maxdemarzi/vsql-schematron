INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 452178_create_tables
--echo #
CREATE DATABASE `db_452178_create_tables`;
USE `db_452178_create_tables`;
CREATE TABLE `publications` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `title` VARCHAR(50),
  `type` VARCHAR(50),
  `number` VARCHAR(50),
  `is_ignored` BOOLEAN,
  `is_revoked` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `versioned_docs` (
  `id` INT NOT NULL,
  `pub_id` INT,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `number` VARCHAR(50),
  `filename` VARCHAR(50),
  `doc_location` VARCHAR(50),
  `batch_timestamp` TIMESTAMP NULL,
  `publication_date` TIMESTAMP NULL,
  `json_metadata` VARCHAR(50),
  `version_hash` VARCHAR(50),
  `md5_hash` VARCHAR(50),
  `is_ignored` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pipeline_jobs` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `started_ts` TIMESTAMP NULL,
  `finished_ts` TIMESTAMP NULL,
  `sigkill_sent_ts` TIMESTAMP NULL,
  `pid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `crawler_status` (
  `id` INT NOT NULL,
  `crawler_name` VARCHAR(50),
  `status` VARCHAR(50),
  `datetime` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_452178_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_452178_create_tables') AS relationships;
DROP DATABASE `db_452178_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
