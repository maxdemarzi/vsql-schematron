INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449975_init
--echo #
CREATE DATABASE `db_449975_init`;
USE `db_449975_init`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
  `user_role_id` INT NOT NULL,
  `user_id` INT,
  `role` VARCHAR(50),
  PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449975_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449975_init') AS relationships;
DROP DATABASE `db_449975_init`;
UNINSTALL EXTENSION vsql_schematron;
