INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 463919_migration
--echo #
CREATE DATABASE `db_463919_migration`;
USE `db_463919_migration`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `username` TEXT,
  `google_id` TEXT,
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
  `id` VARCHAR(50) NOT NULL,
  `bio` VARCHAR(50),
  `avatar` TEXT,
  `user_id` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_463919_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_463919_migration') AS relationships;
DROP DATABASE `db_463919_migration`;
UNINSTALL EXTENSION vsql_schematron;
