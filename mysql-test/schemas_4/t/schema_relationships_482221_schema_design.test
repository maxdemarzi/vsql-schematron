INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 482221_schema_design
--echo #
CREATE DATABASE `db_482221_schema_design`;
USE `db_482221_schema_design`;
CREATE TABLE `user_account` (
  `username` VARCHAR(50) NOT NULL,
  `pwd` VARCHAR(50),
  `profile_pic` TEXT,
  `bio` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `post_id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `title` VARCHAR(50),
  `content` TEXT,
  `post_time` TIMESTAMP NULL,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `liked` (
  `username` VARCHAR(50),
  `post_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `follow` (
  `this_username` VARCHAR(50),
  `following_username` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_482221_schema_design') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_482221_schema_design') AS relationships;
DROP DATABASE `db_482221_schema_design`;
UNINSTALL EXTENSION vsql_schematron;
