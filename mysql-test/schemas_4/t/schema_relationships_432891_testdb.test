INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 432891_testdb
--echo #
CREATE DATABASE `db_432891_testdb`;
USE `db_432891_testdb`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `role` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guestbook` (
  `id` VARCHAR(50) NOT NULL,
  `userId` VARCHAR(50),
  `comment` VARCHAR(50),
  `approved` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_432891_testdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_432891_testdb') AS relationships;
DROP DATABASE `db_432891_testdb`;
UNINSTALL EXTENSION vsql_schematron;
