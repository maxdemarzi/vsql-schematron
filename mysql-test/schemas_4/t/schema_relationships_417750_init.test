INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417750_init
--echo #
CREATE DATABASE `db_417750_init`;
USE `db_417750_init`;
CREATE TABLE `settings` (
  `id` INT NOT NULL,
  `leagueid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lobby` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `password` TEXT,
  `settings_id` INT,
  `status` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `steam-id` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lobby_user` (
  `id` BIGINT NOT NULL,
  `lobby_id` BIGINT,
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bot` (
  `id` INT NOT NULL,
  `steam_name` TEXT,
  `steam_user` TEXT,
  `steam_pass` TEXT,
  `steam_guard_code` TEXT,
  `two_factor_code` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417750_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417750_init') AS relationships;
DROP DATABASE `db_417750_init`;
UNINSTALL EXTENSION vsql_schematron;
