INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410082_script
--echo #
CREATE DATABASE `db_410082_script`;
USE `db_410082_script`;
CREATE TABLE `users` (
  `code` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `tag` VARCHAR(50),
  `userID` VARCHAR(50),
  `time` DATETIME,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `commands` (
  `code` VARCHAR(50) NOT NULL,
  `command` VARCHAR(50),
  `authorCode` VARCHAR(50),
  `channel` VARCHAR(50),
  `server` VARCHAR(50),
  `time` DATETIME,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410082_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410082_script') AS relationships;
DROP DATABASE `db_410082_script`;
UNINSTALL EXTENSION vsql_schematron;
