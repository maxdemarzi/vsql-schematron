INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 430247_xhorna14_xpatri00
--echo #
CREATE DATABASE `db_430247_xhorna14_xpatri00`;
USE `db_430247_xhorna14_xpatri00`;

CREATE TABLE `PIVO` (
  `ID` INT,
  `NAZOV` VARCHAR(255),
  `FARBA_SRM` DECIMAL(10,2),
  `KVASENIE` VARCHAR(255),
  `TYP` VARCHAR(255),
  `OBSAH_ALKOHOLU` DECIMAL(10,2),
  `DATUM_VYROBY` DATETIME,
  `HODNOTENIE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DISTRIBUCE` (
  `ID` INT,
  `MNOZSTVO` INT,
  `FORMA` VARCHAR(255),
  `PIVO_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HOSPODA` (
  `ID` INT,
  `NAZOV` VARCHAR(255),
  `ADRESA` VARCHAR(255),
  `HODNOTENIE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PIVOVAR` (
  `ID` INT,
  `NAZOV` VARCHAR(255),
  `ADRESA` VARCHAR(255),
  `ZNACKA` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `UZIVATEL` (
  `LOGIN` VARCHAR(255),
  `MENO` VARCHAR(255),
  `PRIEZVISKO` VARCHAR(255),
  `MAIL` VARCHAR(255),
  `VEK` DECIMAL(10,2),
  `REKORD` INT,
  `SLADEK_ID` INT,
  PRIMARY KEY (`LOGIN`)
) CHARACTER SET latin1;

CREATE TABLE `SLADEK` (
  `ID` INT,
  `ZAMESTNANIE` VARCHAR(255),
  `DRUH` VARCHAR(255),
  `PIVOVAR_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `SLAD` (
  `ID` INT,
  `FARBA` VARCHAR(255),
  `PUVOD` VARCHAR(255),
  `EXKTRAKT` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `KVASNICE` (
  `ID` INT,
  `SKUPENSTVO` VARCHAR(255),
  `DRUH` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHMEL` (
  `ID` INT,
  `AROMA` VARCHAR(255),
  `HORKOST` DECIMAL(10,2),
  `PUVOD` VARCHAR(255),
  `POMER_KYSELIN` DECIMAL(10,2),
  `DATUM_ZBERU` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PREDAJNA` (
  `ID` INT,
  `NAZOV` VARCHAR(255),
  `VLASTNIK` VARCHAR(255),
  `ADRESA` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ZMLUVA` (
  `ID` INT,
  `OD` DATETIME,
  `DO` DATETIME,
  `ZLAVA` INT,
  `PIVOVAR_ID` INT,
  `HOSPODA_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ODBER_PREDAJNE` (
  `DISTR_ID` INT,
  `PREDAJNA_ID` INT,
  PRIMARY KEY (`DISTR_ID`, `PREDAJNA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ODBER_HOSPODA` (
  `DISTR_ID` INT,
  `HOSPODA_ID` INT,
  PRIMARY KEY (`DISTR_ID`, `HOSPODA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `VARI` (
  `PIVO_ID` INT,
  `SLADEK_ID` INT,
  PRIMARY KEY (`PIVO_ID`, `SLADEK_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SLEDUJE` (
  `UZIVATEL_ID` VARCHAR(255),
  `PIVOVAR_ID` INT,
  PRIMARY KEY (`UZIVATEL_ID`, `PIVOVAR_ID`)
) CHARACTER SET latin1;

CREATE TABLE `HODNOTI_HOSPODA` (
  `UZIVATEL_ID` VARCHAR(255),
  `HOSPODA_ID` INT,
  `HODNOTENIE` INT,
  PRIMARY KEY (`UZIVATEL_ID`, `HOSPODA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `HODNOTI_PIVO` (
  `UZIVATEL_ID` VARCHAR(255),
  `PIVO_ID` INT,
  `HODNOTENIE` INT,
  PRIMARY KEY (`UZIVATEL_ID`, `PIVO_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DODAVA_KVASNICE` (
  `PREDAJNA_ID` INT,
  `KVASNICE_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PREDAJNA_ID`, `KVASNICE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DODAVA_SLAD` (
  `PREDAJNA_ID` INT,
  `SLAD_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PREDAJNA_ID`, `SLAD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DODAVA_CHMEL` (
  `PREDAJNA_ID` INT,
  `CHMEL_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PREDAJNA_ID`, `CHMEL_ID`)
) CHARACTER SET latin1;

CREATE TABLE `VYROBENEZ_KVASNICE` (
  `PIVO_ID` INT,
  `KVASNICE_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PIVO_ID`, `KVASNICE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `VYROBENEZ_SLAD` (
  `PIVO_ID` INT,
  `SLAD_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PIVO_ID`, `SLAD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `VYROBENEZ_CHMEL` (
  `PIVO_ID` INT,
  `CHMEL_ID` INT,
  `MNOZSTVO` INT,
  PRIMARY KEY (`PIVO_ID`, `CHMEL_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_430247_xhorna14_xpatri00') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_430247_xhorna14_xpatri00') AS relationships;
DROP DATABASE `db_430247_xhorna14_xpatri00`;
UNINSTALL EXTENSION vsql_schematron;
