INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464943_constructor
--echo #
CREATE DATABASE `db_464943_constructor`;
USE `db_464943_constructor`;

CREATE TABLE `Students` (
  `PIN` INT,
  `Name` VARCHAR(64),
  `Address` VARCHAR(64),
  PRIMARY KEY (`PIN`)
) CHARACTER SET latin1;

CREATE TABLE `Courses` (
  `Name` VARCHAR(64),
  `Year` INT,
  `Semester` VARCHAR(64),
  `Teacher` VARCHAR(64),
  PRIMARY KEY (`Name`, `Year`, `Semester`)
) CHARACTER SET latin1;

CREATE TABLE `Registrations` (
  `PIN` INT,
  `CourseName` VARCHAR(64),
  `CourseYear` INT,
  `CourseSemester` VARCHAR(64),
  `Grade` DECIMAL(10,2),
  PRIMARY KEY (`PIN`, `CourseName`, `CourseYear`, `CourseSemester`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464943_constructor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464943_constructor') AS relationships;
DROP DATABASE `db_464943_constructor`;
UNINSTALL EXTENSION vsql_schematron;
