INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 459247_schema
--echo #
CREATE DATABASE `db_459247_schema`;
USE `db_459247_schema`;

CREATE TABLE `main` (
  `id` INT,
  `date` DATETIME,
  `wpm` INT,
  `book_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `name` VARCHAR(64),
  `author` VARCHAR(64),
  `thresh_lines` INT,
  `thresh_pages` INT,
  `wpp` INT,
  `wpl` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_459247_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_459247_schema') AS relationships;
DROP DATABASE `db_459247_schema`;
UNINSTALL EXTENSION vsql_schematron;
