INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 440886_unnamed-1629966348864
--echo #
CREATE DATABASE `db_440886_unnamed_1629966348864`;
USE `db_440886_unnamed_1629966348864`;
CREATE TABLE `JOB_LIST_TABLE` (
  `SEQ_ID_JOB` DOUBLE,
  `SEQ_ID_MEMBER` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `JOB_TABLE` (
  `JOB_NAME` TEXT,
  `SEQ_ID_JOB` DOUBLE NOT NULL,
  PRIMARY KEY (`SEQ_ID_JOB`)
) CHARACTER SET latin1;
CREATE TABLE `MEMBER_TABLE` (
  `MEMBER_NAME` TEXT,
  `SEQ_ID_MEMBER` DOUBLE NOT NULL,
  `SEQ_ID_JOB` DOUBLE,
  PRIMARY KEY (`SEQ_ID_MEMBER`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_440886_unnamed_1629966348864') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_440886_unnamed_1629966348864') AS relationships;
DROP DATABASE `db_440886_unnamed_1629966348864`;
UNINSTALL EXTENSION vsql_schematron;
