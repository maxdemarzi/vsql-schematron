INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 474555_coleccion_bga
--echo #
CREATE DATABASE `db_474555_coleccion_bga`;
USE `db_474555_coleccion_bga`;
CREATE TABLE `obra` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `date` DATE,
  `format` VARCHAR(50),
  `medium` VARCHAR(50),
  `file` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `referente` (
  `id` INT,
  `title` VARCHAR(50),
  `date` DATE,
  `publisher` VARCHAR(50),
  `archivo` VARCHAR(50),
  `obra_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_474555_coleccion_bga') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_474555_coleccion_bga') AS relationships;
DROP DATABASE `db_474555_coleccion_bga`;
UNINSTALL EXTENSION vsql_schematron;
