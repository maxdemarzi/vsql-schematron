INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 404254_schema
--echo #
CREATE DATABASE `db_404254_schema`;
USE `db_404254_schema`;
CREATE TABLE `kagaribi_player` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kagaribi_ranking` (
  `player_id` VARCHAR(50) NOT NULL,
  `score` INT,
  `time` DATETIME NOT NULL,
  PRIMARY KEY (`player_id`, `time`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_404254_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_404254_schema') AS relationships;
DROP DATABASE `db_404254_schema`;
UNINSTALL EXTENSION vsql_schematron;
