INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470307_starting_schema
--echo #
CREATE DATABASE `db_470307_starting_schema`;
USE `db_470307_starting_schema`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `device` VARCHAR(255),
  `current_zone_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zones` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `fk_user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `text` VARCHAR(255),
  `fk_message_type_id` INT,
  `fk_zone_id` INT,
  `fk_user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message_types` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470307_starting_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470307_starting_schema') AS relationships;
DROP DATABASE `db_470307_starting_schema`;
UNINSTALL EXTENSION vsql_schematron;
