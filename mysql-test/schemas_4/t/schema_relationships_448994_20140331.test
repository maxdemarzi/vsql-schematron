INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 448994_20140331
--echo #
CREATE DATABASE `db_448994_20140331`;
USE `db_448994_20140331`;
CREATE TABLE `contaapagar` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  `data_prevista` DATETIME,
  `valor` VARCHAR(50),
  `status` VARCHAR(50),
  `data_pagamento` DATETIME,
  `conta_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contaapagar_adiantamento` (
  `id` BIGINT NOT NULL,
  `contaapagar_id` INT,
  `adiantamento_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contaapagar_compra` (
  `id` INT NOT NULL,
  `contaapagar_id` INT,
  `compra_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_448994_20140331') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_448994_20140331') AS relationships;
DROP DATABASE `db_448994_20140331`;
UNINSTALL EXTENSION vsql_schematron;
