INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400511_barefoot
--echo #
CREATE DATABASE `db_400511_barefoot`;
USE `db_400511_barefoot`;

CREATE TABLE `bookmarks` (
  `id` INT,
  `user_id` INT,
  `post_id` INT
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `icon` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `user_id` INT,
  `post_id` INT,
  `comment` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `reading_time` INT,
  `youtube_url` VARCHAR(64),
  `category_id` INT,
  `image` VARCHAR(64),
  `body` VARCHAR(64),
  `is_published` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_likes` (
  `id` INT,
  `user_id` INT,
  `post_id` INT,
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `posts_tags` (
  `id` INT,
  `post_id` INT,
  `tag_id` INT,
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `socials` (
  `id` INT,
  `user_id` INT,
  `facebook` VARCHAR(64),
  `instagram` VARCHAR(64),
  `twitter` VARCHAR(64),
  `youtube` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `verified` INT,
  `token` VARCHAR(64),
  `password` VARCHAR(64),
  `profile_image` VARCHAR(64),
  `banner_title` VARCHAR(64),
  `banner_image` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400511_barefoot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400511_barefoot') AS relationships;
DROP DATABASE `db_400511_barefoot`;
UNINSTALL EXTENSION vsql_schematron;
