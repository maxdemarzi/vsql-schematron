INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 479949_database
--echo #
CREATE DATABASE `db_479949_database`;
USE `db_479949_database`;

CREATE TABLE `centrosMedicos` (
  `IDcentroMedico` INT,
  `nombreCentroMedico` VARCHAR(64),
  `numeroDeSerie` VARCHAR(64),
  `codigoAcceso` VARCHAR(64),
  `ciudad` VARCHAR(64),
  `imagenLogo` VARCHAR(64),
  `fechaUnion` DATETIME,
  PRIMARY KEY (`IDcentroMedico`)
) CHARACTER SET latin1;

CREATE TABLE `usuarios` (
  `IDuser` INT,
  `vacunadoPor` VARCHAR(64),
  `nombreUser` VARCHAR(64),
  `tipoIdentificacion` VARCHAR(64),
  `numeroIdentificacion` VARCHAR(64),
  `imagenUser` VARCHAR(64),
  `tipoVacuna` VARCHAR(64),
  `dosis` VARCHAR(64),
  `fechaUnion` DATETIME,
  `correo` VARCHAR(64),
  PRIMARY KEY (`IDuser`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_479949_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_479949_database') AS relationships;
DROP DATABASE `db_479949_database`;
UNINSTALL EXTENSION vsql_schematron;
