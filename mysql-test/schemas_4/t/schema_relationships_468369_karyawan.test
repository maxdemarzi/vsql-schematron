INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 468369_karyawan
--echo #
CREATE DATABASE `db_468369_karyawan`;
USE `db_468369_karyawan`;
CREATE TABLE `user` (
  `id` VARCHAR(50),
  `name` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `is_active` BOOLEAN
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `role_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `role_name` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_468369_karyawan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_468369_karyawan') AS relationships;
DROP DATABASE `db_468369_karyawan`;
UNINSTALL EXTENSION vsql_schematron;
