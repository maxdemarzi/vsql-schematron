INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494102_estrutura
--echo #
CREATE DATABASE `db_494102_estrutura`;
USE `db_494102_estrutura`;

CREATE TABLE `clientes` (
  `codCli` INT,
  `nome` VARCHAR(64),
  `endereco` VARCHAR(64),
  `estado` VARCHAR(64),
  PRIMARY KEY (`codCli`)
) CHARACTER SET latin1;

CREATE TABLE `pneus` (
  `codPneu` INT,
  `descricao` VARCHAR(64),
  `medidas` VARCHAR(64),
  `preco` DECIMAL(10,2),
  `ativo` VARCHAR(64),
  PRIMARY KEY (`codPneu`)
) CHARACTER SET latin1;

CREATE TABLE `notaFiscal` (
  `numero` VARCHAR(64),
  `serie` VARCHAR(64),
  `codCli` INT,
  `data` DATETIME,
  `cancelada` VARCHAR(64),
  PRIMARY KEY (`numero`, `serie`)
) CHARACTER SET latin1;

CREATE TABLE `itens` (
  `numero` VARCHAR(64),
  `serie` VARCHAR(64),
  `item` INT,
  `codPneu` INT,
  `qtde` INT,
  `preco` DECIMAL(10,2),
  PRIMARY KEY (`item`, `numero`, `serie`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494102_estrutura') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494102_estrutura') AS relationships;
DROP DATABASE `db_494102_estrutura`;
UNINSTALL EXTENSION vsql_schematron;
