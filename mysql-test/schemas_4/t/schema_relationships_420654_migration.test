INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420654_migration
--echo #
CREATE DATABASE `db_420654_migration`;
USE `db_420654_migration`;

CREATE TABLE `Comment` (
  `id` VARCHAR(64),
  `userId` VARCHAR(64),
  `postId` VARCHAR(64),
  `content` VARCHAR(64),
  `likes` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420654_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420654_migration') AS relationships;
DROP DATABASE `db_420654_migration`;
UNINSTALL EXTENSION vsql_schematron;
