INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 461301_Z_lawpoint_database
--echo #
CREATE DATABASE `db_461301_Z_lawpoint_database`;
USE `db_461301_Z_lawpoint_database`;

CREATE TABLE `abouts` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `img` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bgimgs` (
  `id` INT,
  `about_img` VARCHAR(64),
  `service_img` VARCHAR(64),
  `portfolio_img` VARCHAR(64),
  `contact_img` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `img` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `footers` (
  `id` INT,
  `title1` VARCHAR(64),
  `title2` VARCHAR(64),
  `title3` VARCHAR(64),
  `description` VARCHAR(64),
  `office` VARCHAR(64),
  `email` VARCHAR(64),
  `hours` VARCHAR(64),
  `img` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `logos` (
  `id` INT,
  `logo` VARCHAR(64),
  `seo_des` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `missions` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `img` VARCHAR(64),
  `p1` VARCHAR(64),
  `p2` VARCHAR(64),
  `p3` VARCHAR(64),
  `p4` VARCHAR(64),
  `p5` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `portfoliocategories` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `portfoliopages` (
  `id` INT,
  `long_title` VARCHAR(64),
  `short_title` VARCHAR(64),
  `category_id` INT,
  `website` VARCHAR(64),
  `client` VARCHAR(64),
  `short_description` VARCHAR(64),
  `description1` VARCHAR(64),
  `description2` VARCHAR(64),
  `img` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `portfolios` (
  `id` INT,
  `img` VARCHAR(64),
  `title` VARCHAR(64),
  `portfoliocategory_id` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `services` (
  `id` INT,
  `img` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sliders` (
  `id` INT,
  `img` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  `fb_link` VARCHAR(64),
  `tw_link` VARCHAR(64),
  `in_link` VARCHAR(64),
  `img` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `topbars` (
  `id` INT,
  `phone` VARCHAR(64),
  `news` VARCHAR(64),
  `footer_des` VARCHAR(64),
  `fb_link` VARCHAR(64),
  `tw_link` VARCHAR(64),
  `in_link` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `visions` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `img` VARCHAR(64),
  `p1` VARCHAR(64),
  `p2` VARCHAR(64),
  `p3` VARCHAR(64),
  `p4` VARCHAR(64),
  `p5` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `welcomes` (
  `id` INT,
  `title` VARCHAR(64),
  `sub_title` VARCHAR(64),
  `description` VARCHAR(64),
  `img` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `p1` VARCHAR(64),
  `p2` VARCHAR(64),
  `p3` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_461301_Z_lawpoint_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_461301_Z_lawpoint_database') AS relationships;
DROP DATABASE `db_461301_Z_lawpoint_database`;
UNINSTALL EXTENSION vsql_schematron;
