INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428748_People%20Table
--echo #
CREATE DATABASE `db_428748_People_20Table`;
USE `db_428748_People_20Table`;
CREATE TABLE `people` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `DOB` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `amount` DECIMAL(10,2),
  `person_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428748_People_20Table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428748_People_20Table') AS relationships;
DROP DATABASE `db_428748_People_20Table`;
UNINSTALL EXTENSION vsql_schematron;
