INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 486876_3-Movies
--echo #
CREATE DATABASE `db_486876_3_Movies`;
USE `db_486876_3_Movies`;

CREATE TABLE `actor` (
  `act_id` DECIMAL(10,2),
  `act_name` VARCHAR(64),
  `act_gender` VARCHAR(64),
  PRIMARY KEY (`act_id`)
) CHARACTER SET latin1;

CREATE TABLE `director` (
  `dir_id` DECIMAL(10,2),
  `dir_name` VARCHAR(64),
  `dir_phone` DECIMAL(10,2),
  PRIMARY KEY (`dir_id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `mov_id` DECIMAL(10,2),
  `mov_title` VARCHAR(64),
  `mov_year` DECIMAL(10,2),
  `mov_lang` VARCHAR(64),
  `dir_id` DECIMAL(10,2),
  PRIMARY KEY (`mov_id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_cast` (
  `act_id` DECIMAL(10,2),
  `mov_id` DECIMAL(10,2),
  `role` VARCHAR(64),
  PRIMARY KEY (`mov_id`, `act_id`)
) CHARACTER SET latin1;

CREATE TABLE `rating` (
  `mov_id` DECIMAL(10,2),
  `rev_stars` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_486876_3_Movies') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_486876_3_Movies') AS relationships;
DROP DATABASE `db_486876_3_Movies`;
UNINSTALL EXTENSION vsql_schematron;
