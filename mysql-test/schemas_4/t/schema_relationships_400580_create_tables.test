INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400580_create_tables
--echo #
CREATE DATABASE `db_400580_create_tables`;
USE `db_400580_create_tables`;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `title` TEXT,
  `year` INT,
  `director` TEXT,
  `banner_url` TEXT,
  `trailer_url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stars` (
  `id` INT NOT NULL,
  `first_name` TEXT,
  `last_name` TEXT,
  `dob` DATE,
  `photo_url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stars_in_movies` (
  `star_id` INT,
  `movie_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400580_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400580_create_tables') AS relationships;
DROP DATABASE `db_400580_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
