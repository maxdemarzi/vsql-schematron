INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 445346_schema
--echo #
CREATE DATABASE `db_445346_schema`;
USE `db_445346_schema`;

CREATE TABLE `raw_data` (
  `id` INT,
  `ts` DECIMAL(10,2),
  `remote_addr` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `invalid_data` (
  `id` INT,
  `error` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `planner_metrics` (
  `id` INT,
  `ts` DECIMAL(10,2),
  `remote_addr` VARCHAR(64),
  `hostname` VARCHAR(64),
  `domain` VARCHAR(64),
  `version` VARCHAR(64),
  `wf_uuid` VARCHAR(64),
  `root_wf_uuid` VARCHAR(64),
  `start_time` DECIMAL(10,2),
  `end_time` DECIMAL(10,2),
  `duration` DECIMAL(10,2),
  `exitcode` INT,
  `compute_tasks` INT,
  `dax_tasks` INT,
  `dag_tasks` INT,
  `total_tasks` INT,
  `chmod_jobs` INT,
  `inter_tx_jobs` INT,
  `compute_jobs` INT,
  `cleanup_jobs` INT,
  `dax_jobs` INT,
  `dag_jobs` INT,
  `so_tx_jobs` INT,
  `si_tx_jobs` INT,
  `create_dir_jobs` INT,
  `clustered_jobs` INT,
  `reg_jobs` INT,
  `total_jobs` INT,
  `dax_input_files` INT,
  `dax_inter_files` INT,
  `dax_output_files` INT,
  `dax_total_files` INT,
  `data_config` VARCHAR(64),
  `application` VARCHAR(64),
  `uses_pmc` BOOL,
  `planner_args` VARCHAR(64),
  `deleted_tasks` INT,
  `dax_api` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `planner_errors` (
  `id` INT,
  `hash` VARCHAR(64),
  `error` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `downloads` (
  `id` INT,
  `ts` DECIMAL(10,2),
  `remote_addr` VARCHAR(64),
  `hostname` VARCHAR(64),
  `domain` VARCHAR(64),
  `version` VARCHAR(64),
  `filename` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `organization` VARCHAR(64),
  `app_domain` VARCHAR(64),
  `app_description` VARCHAR(64),
  `howheard` VARCHAR(64),
  `howhelp` VARCHAR(64),
  `oldfeatures` VARCHAR(64),
  `newfeatures` VARCHAR(64),
  `sub_users` BOOL,
  `sub_announce` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dagman_metrics` (
  `id` INT,
  `ts` DECIMAL(10,2),
  `remote_addr` VARCHAR(64),
  `hostname` VARCHAR(64),
  `domain` VARCHAR(64),
  `version` VARCHAR(64),
  `wf_uuid` VARCHAR(64),
  `root_wf_uuid` VARCHAR(64),
  `start_time` DECIMAL(10,2),
  `end_time` DECIMAL(10,2),
  `duration` DECIMAL(10,2),
  `exitcode` INT,
  `dagman_id` VARCHAR(64),
  `parent_dagman_id` VARCHAR(64),
  `jobs` INT,
  `jobs_failed` INT,
  `jobs_succeeded` INT,
  `dag_jobs` INT,
  `dag_jobs_failed` INT,
  `dag_jobs_succeeded` INT,
  `dag_status` INT,
  `planner` VARCHAR(64),
  `planner_version` VARCHAR(64),
  `rescue_dag_number` INT,
  `total_job_time` DECIMAL(10,2),
  `total_jobs` INT,
  `total_jobs_run` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `ip` VARCHAR(64),
  `country_code` VARCHAR(64),
  `country_name` VARCHAR(64),
  `region_code` VARCHAR(64),
  `region_name` VARCHAR(64),
  `city` VARCHAR(64),
  `zip_code` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `metro_code` VARCHAR(64),
  PRIMARY KEY (`ip`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_445346_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_445346_schema') AS relationships;
DROP DATABASE `db_445346_schema`;
UNINSTALL EXTENSION vsql_schematron;
