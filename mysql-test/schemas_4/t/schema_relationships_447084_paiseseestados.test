INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447084_paiseseestados
--echo #
CREATE DATABASE `db_447084_paiseseestados`;
USE `db_447084_paiseseestados`;
CREATE TABLE `Paises` (
  `Id` VARCHAR(50) NOT NULL,
  `Nome` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Estados` (
  `Id` VARCHAR(50) NOT NULL,
  `Nome` VARCHAR(50),
  `PaisId` CHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447084_paiseseestados') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447084_paiseseestados') AS relationships;
DROP DATABASE `db_447084_paiseseestados`;
UNINSTALL EXTENSION vsql_schematron;
