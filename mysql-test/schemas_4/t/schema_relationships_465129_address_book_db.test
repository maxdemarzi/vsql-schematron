INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 465129_address_book_db
--echo #
CREATE DATABASE `db_465129_address_book_db`;
USE `db_465129_address_book_db`;
CREATE TABLE `address_book_tbl` (
  `user_id` INT,
  `name` TEXT,
  `firstname` TEXT,
  `email` VARCHAR(50),
  `street` TEXT,
  `zip_code` VARCHAR(50),
  `city_id` INT
) CHARACTER SET latin1;
CREATE TABLE `cities_tbl` (
  `city_id` INT NOT NULL,
  `city` TEXT,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_465129_address_book_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_465129_address_book_db') AS relationships;
DROP DATABASE `db_465129_address_book_db`;
UNINSTALL EXTENSION vsql_schematron;
