INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488924_techstra_db
--echo #
CREATE DATABASE `db_488924_techstra_db`;
USE `db_488924_techstra_db`;
CREATE TABLE `post` (
  `post_id` INT,
  `post_title` VARCHAR(50),
  `post_description` VARCHAR(50),
  `post_photo` VARCHAR(50),
  `user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT,
  `user_firstname` VARCHAR(50),
  `user_lastname` VARCHAR(50),
  `user_username` VARCHAR(50),
  `user_password` VARCHAR(50),
  `user_email` VARCHAR(50),
  `user_code` VARCHAR(50),
  `user_verification` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `userinfo` (
  `userinfo_id` INT,
  `userinfo_firstname` VARCHAR(50),
  `userinfo_lastname` VARCHAR(50),
  `userinfo_bio` VARCHAR(50),
  `userinfo_image` VARCHAR(50),
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488924_techstra_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488924_techstra_db') AS relationships;
DROP DATABASE `db_488924_techstra_db`;
UNINSTALL EXTENSION vsql_schematron;
