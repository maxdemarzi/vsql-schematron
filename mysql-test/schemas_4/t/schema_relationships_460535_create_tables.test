INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 460535_create_tables
--echo #
CREATE DATABASE `db_460535_create_tables`;
USE `db_460535_create_tables`;

CREATE TABLE `angajat` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `curs_valutar` (
  `id` INT,
  `created` DATETIME,
  `currency_code` VARCHAR(64),
  `exchange_rate` DECIMAL(10,2),
  `exponent` INT,
  `created_on` DATETIME,
  `currency` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dictionar_valute` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `valuta` (
  `id` INT,
  `code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `numerar` (
  `id` INT,
  `created` DATETIME,
  `sum` INT,
  `user` VARCHAR(64),
  `currency_id` INT,
  `created_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schimb_valutar` (
  `id` INT,
  `valuta_id` INT,
  `change_rate` VARCHAR(64),
  `given_sum` DECIMAL(10,2),
  `sent_sum` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_460535_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_460535_create_tables') AS relationships;
DROP DATABASE `db_460535_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
