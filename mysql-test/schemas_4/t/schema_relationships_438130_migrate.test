INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438130_migrate
--echo #
CREATE DATABASE `db_438130_migrate`;
USE `db_438130_migrate`;

CREATE TABLE `User` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Individual` (
  `username` VARCHAR(64),
  `displayName` VARCHAR(64),
  `balance` INT,
  `isAdmin` BOOL,
  `passwordHash` VARCHAR(64),
  `passwordSalt` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `RealEstate` (
  `name` VARCHAR(64),
  `expireTime` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `House` (
  `houseId` VARCHAR(64),
  `ownerId` VARCHAR(64),
  `area` INT,
  `imageUrl` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `description` VARCHAR(64),
  `buildingType` VARCHAR(64),
  `dealType` VARCHAR(64),
  `priceBase` INT,
  `priceRent` INT,
  `priceSell` INT,
  `toDelete` BOOL,
  PRIMARY KEY (`houseId`, `ownerId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438130_migrate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438130_migrate') AS relationships;
DROP DATABASE `db_438130_migrate`;
UNINSTALL EXTENSION vsql_schematron;
