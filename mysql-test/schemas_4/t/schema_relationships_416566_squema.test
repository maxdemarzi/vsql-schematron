INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 416566_squema
--echo #
CREATE DATABASE `db_416566_squema`;
USE `db_416566_squema`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `nome` TEXT,
  `nome_loja` TEXT,
  `email` TEXT,
  `senha` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `nome` TEXT,
  `estoque` TEXT,
  `categoria` TEXT,
  `preco` INT,
  `descricao` TEXT,
  `imagem` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_416566_squema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_416566_squema') AS relationships;
DROP DATABASE `db_416566_squema`;
UNINSTALL EXTENSION vsql_schematron;
