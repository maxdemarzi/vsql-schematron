INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473133_schema
--echo #
CREATE DATABASE `db_473133_schema`;
USE `db_473133_schema`;
CREATE TABLE `item` (
  `id` INT NOT NULL,
  `owner_id` VARCHAR(50),
  `price` INT,
  `place` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player` (
  `id` VARCHAR(50) NOT NULL,
  `credits` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` INT NOT NULL,
  `player_id` VARCHAR(50),
  `created` DATETIME,
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473133_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473133_schema') AS relationships;
DROP DATABASE `db_473133_schema`;
UNINSTALL EXTENSION vsql_schematron;
