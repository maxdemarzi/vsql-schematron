INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 483620_database
--echo #
CREATE DATABASE `db_483620_database`;
USE `db_483620_database`;

CREATE TABLE `BLOCK` (
  `GENKEY` VARCHAR(64),
  `NAME` VARCHAR(64),
  `DISC` VARCHAR(64),
  PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;

CREATE TABLE `POST` (
  `GENKEY` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `BLOCK_GK` VARCHAR(64),
  `AUTHOR_GK` VARCHAR(64),
  PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;

CREATE TABLE `REPLY` (
  `GENKEY` VARCHAR(64),
  `POST_GK` VARCHAR(64),
  `LEVEL` INT,
  `AUTHOR_GK` VARCHAR(64),
  `COMMENT` VARCHAR(64),
  `REPLY_TO_GK` VARCHAR(64),
  PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;

CREATE TABLE `USER` (
  `GENKEY` VARCHAR(64),
  `USERNAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `PHONE` INT,
  `EMAIL` VARCHAR(64),
  `QQ` INT,
  PRIMARY KEY (`GENKEY`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_483620_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_483620_database') AS relationships;
DROP DATABASE `db_483620_database`;
UNINSTALL EXTENSION vsql_schematron;
