INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435789_er_completo
--echo #
CREATE DATABASE `db_435789_er_completo`;
USE `db_435789_er_completo`;

CREATE TABLE `db_locashow.menu` (
  `id` INT,
  `nome` VARCHAR(255),
  `link` VARCHAR(255),
  `icone` VARCHAR(255),
  `ordem` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `db_locashow.grupo` (
  `id` INT,
  `nome` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `db_locashow.usuario_grupo` (
  `id` INT,
  `usuario_id` INT,
  `grupo_id` INT,
  PRIMARY KEY (`id`, `usuario_id`, `grupo_id`)
) CHARACTER SET latin1;

CREATE TABLE `db_locashow.grupo_menu` (
  `id` INT,
  `grupo_id` INT,
  `menu_id` INT,
  PRIMARY KEY (`id`, `grupo_id`, `menu_id`)
) CHARACTER SET latin1;

CREATE TABLE `db_locashow.log_acesso` (
  `id` INT,
  `usuario_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`, `usuario_id`)
) CHARACTER SET latin1;

CREATE TABLE `db_locashow.boleto_cliente` (
  `id` INT,
  `contrato_id` INT,
  `cliente_id` INT,
  `valor` DECIMAL(10,2),
  `dt_vencimento` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435789_er_completo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435789_er_completo') AS relationships;
DROP DATABASE `db_435789_er_completo`;
UNINSTALL EXTENSION vsql_schematron;
