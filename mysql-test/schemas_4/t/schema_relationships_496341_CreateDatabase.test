INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 496341_CreateDatabase
--echo #
CREATE DATABASE `db_496341_CreateDatabase`;
USE `db_496341_CreateDatabase`;
CREATE TABLE `Application` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Version` VARCHAR(50),
  `FilePath` VARCHAR(50),
  `State` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Tenant` (
  `Id` INT NOT NULL,
  `ApplicationId` INT,
  `Name` VARCHAR(50),
  `UpperScaleLimit` INT,
  `ScalingFactor` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_496341_CreateDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_496341_CreateDatabase') AS relationships;
DROP DATABASE `db_496341_CreateDatabase`;
UNINSTALL EXTENSION vsql_schematron;
