INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402360_Exercicio%2003
--echo #
CREATE DATABASE `db_402360_Exercicio_2003`;
USE `db_402360_Exercicio_2003`;
CREATE TABLE `tb_categoria` (
  `id_categoria` INT NOT NULL,
  `tipo_categoria` VARCHAR(50),
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `tb_produto` (
  `id_produto` INT NOT NULL,
  `nome` VARCHAR(50),
  `data_fabricacao` DATE,
  `data_validade` DATE,
  `preco` DOUBLE,
  `quantidade` INT,
  `laboratorio` VARCHAR(50),
  `fk_categoria` INT,
  PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402360_Exercicio_2003') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402360_Exercicio_2003') AS relationships;
DROP DATABASE `db_402360_Exercicio_2003`;
UNINSTALL EXTENSION vsql_schematron;
