INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 477872_atividade8
--echo #
CREATE DATABASE `db_477872_atividade8`;
USE `db_477872_atividade8`;
CREATE TABLE `fornecedor` (
  `cod_for` INT NOT NULL,
  `nome` VARCHAR(50),
  `uf` VARCHAR(50),
  PRIMARY KEY (`cod_for`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `codigo` INT NOT NULL,
  `nome` VARCHAR(50),
  `estoque` INT,
  `valor` INT,
  `cod_for` INT,
  `desct` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_477872_atividade8') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_477872_atividade8') AS relationships;
DROP DATABASE `db_477872_atividade8`;
UNINSTALL EXTENSION vsql_schematron;
