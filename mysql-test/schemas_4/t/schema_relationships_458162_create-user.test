INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458162_create-user
--echo #
CREATE DATABASE `db_458162_create_user`;
USE `db_458162_create_user`;
CREATE TABLE `user` (
  `userid` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `roleid` INT NOT NULL,
  `userid` INT,
  `rolename` VARCHAR(50),
  PRIMARY KEY (`roleid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458162_create_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458162_create_user') AS relationships;
DROP DATABASE `db_458162_create_user`;
UNINSTALL EXTENSION vsql_schematron;
