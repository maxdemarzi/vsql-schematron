INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425181_V1.0.0__init_schemas
--echo #
CREATE DATABASE `db_425181_V1_0_0__init_schemas`;
USE `db_425181_V1_0_0__init_schemas`;
CREATE TABLE `authorities` (
  `id` BIGINT NOT NULL,
  `authority` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `enabled` BOOLEAN,
  `password` VARCHAR(50),
  `status` INT,
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_authorities` (
  `user_id` BIGINT NOT NULL,
  `authority_id` BIGINT NOT NULL,
  PRIMARY KEY (`user_id`, `authority_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425181_V1_0_0__init_schemas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425181_V1_0_0__init_schemas') AS relationships;
DROP DATABASE `db_425181_V1_0_0__init_schemas`;
UNINSTALL EXTENSION vsql_schematron;
