INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444388_cdkshop
--echo #
CREATE DATABASE `db_444388_cdkshop`;
USE `db_444388_cdkshop`;
CREATE TABLE `game_info` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `price` SMALLINT,
  `category` VARCHAR(50),
  `pic_path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stock` (
  `cdk` VARCHAR(50) NOT NULL,
  `game_id` CHAR(50),
  PRIMARY KEY (`cdk`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444388_cdkshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444388_cdkshop') AS relationships;
DROP DATABASE `db_444388_cdkshop`;
UNINSTALL EXTENSION vsql_schematron;
