INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 419569_schema
--echo #
CREATE DATABASE `db_419569_schema`;
USE `db_419569_schema`;

CREATE TABLE `employee` (
  `id` INT,
  `department_id` INT,
  `name` VARCHAR(64),
  `position` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `company` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `id` INT,
  `head_id` INT,
  `company_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_419569_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_419569_schema') AS relationships;
DROP DATABASE `db_419569_schema`;
UNINSTALL EXTENSION vsql_schematron;
