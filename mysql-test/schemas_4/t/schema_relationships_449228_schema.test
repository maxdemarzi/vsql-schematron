INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449228_schema
--echo #
CREATE DATABASE `db_449228_schema`;
USE `db_449228_schema`;

CREATE TABLE `User` (
  `UID` INT,
  `Username` VARCHAR(64),
  `Salt` VARCHAR(64),
  `Password` VARCHAR(64),
  PRIMARY KEY (`UID`)
) CHARACTER SET latin1;

CREATE TABLE `List` (
  `LID` INT,
  `UID` INT,
  `Listname` VARCHAR(64),
  PRIMARY KEY (`LID`)
) CHARACTER SET latin1;

CREATE TABLE `Element` (
  `ELD` INT,
  `LID` INT,
  `Title` VARCHAR(64),
  `StartDate` DATETIME,
  `DeadLine` DATETIME,
  `Status` BOOL,
  PRIMARY KEY (`ELD`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449228_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449228_schema') AS relationships;
DROP DATABASE `db_449228_schema`;
UNINSTALL EXTENSION vsql_schematron;
