INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 493166_createTable
--echo #
CREATE DATABASE `db_493166_createTable`;
USE `db_493166_createTable`;

CREATE TABLE `3_task.Master` (
  `id` INT,
  `name` VARCHAR(64),
  `isWork` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `3_task.Work` (
  `id` INT,
  `nameOfService` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `3_task.Place` (
  `id` INT,
  `name` VARCHAR(64),
  `isBusy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `3_task.Order` (
  `id` INT,
  `id_service` INT,
  `id_master` INT,
  `id_place` INT,
  `status` VARCHAR(64),
  `orderDate` DATETIME,
  `plannedStartDate` DATETIME,
  `completionDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_493166_createTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_493166_createTable') AS relationships;
DROP DATABASE `db_493166_createTable`;
UNINSTALL EXTENSION vsql_schematron;
