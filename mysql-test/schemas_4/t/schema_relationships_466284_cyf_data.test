INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 466284_cyf-data
--echo #
CREATE DATABASE `db_466284_cyf_data`;
USE `db_466284_cyf_data`;

CREATE TABLE `region` (
  `id` INT,
  `location` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `roles_id` INT,
  `region_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `token` VARCHAR(64),
  `users_id` INT,
  `creation_date` DATETIME,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

CREATE TABLE `techskills` (
  `id` INT,
  `lessons` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `learningobjectives` (
  `id` INT,
  `objectives` VARCHAR(64),
  `lesson_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `competencylevels` (
  `id` INT,
  `competency` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mappingskills` (
  `id` INT,
  `users_id` INT,
  `obj_id` INT,
  `comp_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_466284_cyf_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_466284_cyf_data') AS relationships;
DROP DATABASE `db_466284_cyf_data`;
UNINSTALL EXTENSION vsql_schematron;
