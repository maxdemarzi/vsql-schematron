INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 416794_estructuras
--echo #
CREATE DATABASE `db_416794_estructuras`;
USE `db_416794_estructuras`;

CREATE TABLE `estructuras` (
  `id` DECIMAL(10,2),
  `dependencia_id` DECIMAL(10,2),
  `director_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_416794_estructuras') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_416794_estructuras') AS relationships;
DROP DATABASE `db_416794_estructuras`;
UNINSTALL EXTENSION vsql_schematron;
