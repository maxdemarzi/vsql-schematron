INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458095_DDL
--echo #
CREATE DATABASE `db_458095_DDL`;
USE `db_458095_DDL`;

CREATE TABLE `user` (
  `ID` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `education` VARCHAR(64),
  `create_time` DATETIME,
  `num_post` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `classification` (
  `name` VARCHAR(64),
  `discussion` INT,
  `num_comment` INT,
  `last_article_time` DATETIME,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `serial_num` INT,
  `author` VARCHAR(64),
  `class` VARCHAR(64),
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `post_time` DATETIME,
  PRIMARY KEY (`serial_num`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `serial_num` INT,
  `userID` VARCHAR(64),
  `article_num` INT,
  `comment_time` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`serial_num`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458095_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458095_DDL') AS relationships;
DROP DATABASE `db_458095_DDL`;
UNINSTALL EXTENSION vsql_schematron;
