INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478999_Banco
--echo #
CREATE DATABASE `db_478999_Banco`;
USE `db_478999_Banco`;

CREATE TABLE `Pessoa` (
  `id` INT,
  `tipo` VARCHAR(64),
  `matricula` VARCHAR(64),
  `nome` VARCHAR(64),
  `sexo` VARCHAR(64),
  `nascimento` DATETIME,
  `cpf` VARCHAR(64),
  `rg` VARCHAR(64),
  `telefone` VARCHAR(64),
  `cep` VARCHAR(64),
  `logradouro` VARCHAR(64),
  `numero` INT,
  `complemento` VARCHAR(64),
  `bairro` VARCHAR(64),
  `cidade` VARCHAR(64),
  `uf` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Usuario` (
  `id` INT,
  `matricula` VARCHAR(64),
  `login` VARCHAR(64),
  `senha` VARCHAR(64),
  `email` VARCHAR(64),
  `perguntaSecreta` VARCHAR(64),
  `respostaSecreta` VARCHAR(64),
  `Pessoa_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `NovosAlunos` (
  `id` INT,
  `data` DATETIME,
  `Aluno_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `NovosInstrutores` (
  `id` INT,
  `data` DATETIME,
  `Instrutor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `estado` (
  `ID` INT,
  `nome` VARCHAR(64),
  `sigla` VARCHAR(64),
  `regiao` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `cidade` (
  `id` INT,
  `nome` VARCHAR(64),
  `uf` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478999_Banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478999_Banco') AS relationships;
DROP DATABASE `db_478999_Banco`;
UNINSTALL EXTENSION vsql_schematron;
