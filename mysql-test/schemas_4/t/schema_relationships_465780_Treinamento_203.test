INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 465780_Treinamento%203
--echo #
CREATE DATABASE `db_465780_Treinamento_203`;
USE `db_465780_Treinamento_203`;

CREATE TABLE `EMPR` (
  `MATR` VARCHAR(64),
  `NOME` VARCHAR(64),
  `SOBRENOME` VARCHAR(64),
  `DEPT` VARCHAR(64),
  `FONE` VARCHAR(64),
  `DINADIM` DATETIME,
  `CARGO` VARCHAR(64),
  `NIVELED` INT,
  `SEXO` VARCHAR(64),
  `DATANAS` DATETIME,
  `SALARIO` DECIMAL(10,2),
  `BONUS` DECIMAL(10,2),
  `COMIS` DECIMAL(10,2),
  PRIMARY KEY (`MATR`)
) CHARACTER SET latin1;

CREATE TABLE `DEPT` (
  `DCODIGO` VARCHAR(64),
  `DNOME` VARCHAR(64),
  `GERENTE` VARCHAR(64),
  `DSUPER` VARCHAR(64),
  PRIMARY KEY (`DCODIGO`)
) CHARACTER SET latin1;

CREATE TABLE `PROJETO` (
  `PCODIGO` VARCHAR(64),
  `PNOME` VARCHAR(64),
  `DCODIGO` VARCHAR(64),
  `RESP` VARCHAR(64),
  `EQUIPE` INT,
  `DATAINI` DATETIME,
  `DATAFIM` DATETIME,
  `PSUPER` VARCHAR(64),
  PRIMARY KEY (`PCODIGO`)
) CHARACTER SET latin1;

CREATE TABLE `TrabalhaEM` (
  `MATR` VARCHAR(64),
  `PCODIGO` VARCHAR(64),
  `HORASALOCACAO` INT,
  PRIMARY KEY (`MATR`, `PCODIGO`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_465780_Treinamento_203') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_465780_Treinamento_203') AS relationships;
DROP DATABASE `db_465780_Treinamento_203`;
UNINSTALL EXTENSION vsql_schematron;
