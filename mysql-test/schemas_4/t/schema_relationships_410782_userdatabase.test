INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410782_userdatabase
--echo #
CREATE DATABASE `db_410782_userdatabase`;
USE `db_410782_userdatabase`;
CREATE TABLE `chatUser` (
  `id` INT NOT NULL,
  `userName` TEXT,
  `tgID` INT,
  `pingAllowed` TINYINT,
  `MarkovAskAllowed` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aliases` (
  `id` INT NOT NULL,
  `name` TEXT,
  `userID` INT,
  `changeDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `warning` (
  `id` INT NOT NULL,
  `userID` INT,
  `warningText` TEXT,
  `warnDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410782_userdatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410782_userdatabase') AS relationships;
DROP DATABASE `db_410782_userdatabase`;
UNINSTALL EXTENSION vsql_schematron;
