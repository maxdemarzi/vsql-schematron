INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 459566_databasename_SQL-SCHEMA
--echo #
CREATE DATABASE `db_459566_databasename_SQL_SCHEMA`;
USE `db_459566_databasename_SQL_SCHEMA`;
CREATE TABLE `contacts` (
  `index` INT,
  `realName` TEXT,
  `category` TEXT,
  `uniqueid` INT NOT NULL,
  `mod_time` TEXT,
  `mod_date` TEXT,
  `imageURL` TEXT,
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;
CREATE TABLE `numbers` (
  `index` INT,
  `realName` TEXT,
  `nid` TEXT,
  `number` TEXT,
  `type` TEXT,
  `prio` TEXT,
  `id` TEXT,
  `quickdial` TEXT,
  `uniqueid` INT
) CHARACTER SET latin1;
CREATE TABLE `emails` (
  `index` TEXT,
  `realName` TEXT,
  `email` TEXT,
  `classifier` TEXT,
  `uniqueid` INT
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `index` INT,
  `realName` TEXT,
  `aid` TEXT,
  `pobox` TEXT,
  `ext` TEXT,
  `street` TEXT,
  `locality` TEXT,
  `region` TEXT,
  `code` TEXT,
  `country` TEXT,
  `label` TEXT,
  `type` TEXT,
  `prio` TEXT,
  `id` TEXT,
  `uniqueid` INT
) CHARACTER SET latin1;
CREATE TABLE `birthday` (
  `index` INT,
  `realName` TEXT,
  `bday` TIMESTAMP NULL,
  `uniqueid` INT
) CHARACTER SET latin1;
CREATE TABLE `note` (
  `index` INT,
  `realName` TEXT,
  `note` TEXT,
  `uniqueid` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_459566_databasename_SQL_SCHEMA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_459566_databasename_SQL_SCHEMA') AS relationships;
DROP DATABASE `db_459566_databasename_SQL_SCHEMA`;
UNINSTALL EXTENSION vsql_schematron;
