INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 490756_base
--echo #
CREATE DATABASE `db_490756_base`;
USE `db_490756_base`;

CREATE TABLE `Etudiant` (
  `numETU` VARCHAR(64),
  `nom` VARCHAR(64),
  `pwd` VARCHAR(64),
  `dateNaissance` DATETIME,
  PRIMARY KEY (`numETU`)
) CHARACTER SET latin1;

CREATE TABLE `MENU` (
  `dateMenu` DATETIME,
  PRIMARY KEY (`dateMenu`)
) CHARACTER SET latin1;

CREATE TABLE `MenuPLAT` (
  `menu` DATETIME,
  `idPlat` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_490756_base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_490756_base') AS relationships;
DROP DATABASE `db_490756_base`;
UNINSTALL EXTENSION vsql_schematron;
