INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 463336_db
--echo #
CREATE DATABASE `db_463336_db`;
USE `db_463336_db`;

CREATE TABLE `family` (
  `fam_id` VARCHAR(255),
  `fam_name` VARCHAR(255),
  `image` VARCHAR(255),
  PRIMARY KEY (`fam_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` VARCHAR(255),
  `fam_id` VARCHAR(255),
  `user_name` VARCHAR(255),
  `user_email` VARCHAR(255),
  `user_password` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `pro_id` VARCHAR(255),
  `fam_id` VARCHAR(255),
  `user_id` VARCHAR(255),
  `requsted_by` VARCHAR(255),
  `product_name` VARCHAR(255),
  `requsted_at` VARCHAR(255),
  PRIMARY KEY (`pro_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_463336_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_463336_db') AS relationships;
DROP DATABASE `db_463336_db`;
UNINSTALL EXTENSION vsql_schematron;
