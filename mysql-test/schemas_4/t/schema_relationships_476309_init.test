INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 476309_init
--echo #
CREATE DATABASE `db_476309_init`;
USE `db_476309_init`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `user_name` TEXT,
  `pass_word` TEXT,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` INT NOT NULL,
  `name` TEXT,
  `author` TEXT,
  `publisher` TEXT,
  `total_page` INT,
  `published_date` TIMESTAMP NULL,
  `price` BIGINT,
  `stock` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `users_id` BIGINT,
  `books_id` BIGINT,
  `quantity` INT,
  `shipping_details` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_476309_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_476309_init') AS relationships;
DROP DATABASE `db_476309_init`;
UNINSTALL EXTENSION vsql_schematron;
