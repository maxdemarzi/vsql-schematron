INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 443578_study_buddies.ddl
--echo #
CREATE DATABASE `db_443578_study_buddies_ddl`;
USE `db_443578_study_buddies_ddl`;

CREATE TABLE `users` (
  `user_id` INT,
  `google_id` VARCHAR(64),
  `username` VARCHAR(64),
  `date_of_birth` DATETIME,
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `zip` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `location_id` INT,
  `places_id` VARCHAR(64),
  `name` VARCHAR(64),
  `cost` VARCHAR(64),
  `business_type` VARCHAR(64),
  `average_rating` DECIMAL(10,2),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;

CREATE TABLE `saved_locations` (
  `saved_location_id` INT,
  `user_id` INT,
  `location_id` INT,
  `nickname` VARCHAR(64),
  PRIMARY KEY (`saved_location_id`)
) CHARACTER SET latin1;

CREATE TABLE `reservations` (
  `reservation_id` INT,
  `user_id` INT,
  `location_id` INT,
  `status` VARCHAR(64),
  `group_size` INT,
  `duration_minutes` INT,
  `date_time` DATETIME,
  `name` VARCHAR(64),
  PRIMARY KEY (`reservation_id`)
) CHARACTER SET latin1;

CREATE TABLE `ratings` (
  `rating_id` INT,
  `user_id` INT,
  `location_id` INT,
  `rating` INT,
  `comment` VARCHAR(64),
  `cost` VARCHAR(64),
  PRIMARY KEY (`rating_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_443578_study_buddies_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_443578_study_buddies_ddl') AS relationships;
DROP DATABASE `db_443578_study_buddies_ddl`;
UNINSTALL EXTENSION vsql_schematron;
