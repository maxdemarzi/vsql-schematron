INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 462302_db
--echo #
CREATE DATABASE `db_462302_db`;
USE `db_462302_db`;
CREATE TABLE `urls` (
  `id_url` INT NOT NULL,
  `url` VARCHAR(50),
  PRIMARY KEY (`id_url`)
) CHARACTER SET latin1;
CREATE TABLE `words` (
  `id_word` INT NOT NULL,
  `word` VARCHAR(50),
  PRIMARY KEY (`id_word`)
) CHARACTER SET latin1;
CREATE TABLE `word_location` (
  `id_word_location` INT NOT NULL,
  `id_url` INT,
  `id_word` INT,
  `location_page` INT,
  PRIMARY KEY (`id_word_location`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_462302_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_462302_db') AS relationships;
DROP DATABASE `db_462302_db`;
UNINSTALL EXTENSION vsql_schematron;
