INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458011_cyf
--echo #
CREATE DATABASE `db_458011_cyf`;
USE `db_458011_cyf`;

CREATE TABLE `comments` (
  `id` INT,
  `comment` VARCHAR(64),
  `postId` INT,
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `createdBy` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_profile` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `hobbies` VARCHAR(64),
  `is_married` INT,
  `school` VARCHAR(64),
  `skills` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458011_cyf') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458011_cyf') AS relationships;
DROP DATABASE `db_458011_cyf`;
UNINSTALL EXTENSION vsql_schematron;
