INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426798_up
--echo #
CREATE DATABASE `db_426798_up`;
USE `db_426798_up`;

CREATE TABLE `secret_keys` (
  `id` INT,
  `secret_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `secrets` (
  `id` INT,
  `key_id` INT,
  `hash` VARCHAR(64),
  `nonce` VARCHAR(64),
  `secret` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426798_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426798_up') AS relationships;
DROP DATABASE `db_426798_up`;
UNINSTALL EXTENSION vsql_schematron;
