  PRIMARY KEY (`doctype_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.doc` (
  `doc_id` INT,
  `doctype` INT,
  `reference` INT,
  `parent` INT,
  `reference2` INT,
  PRIMARY KEY (`doc_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.string` (
  `string_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`string_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.integer` (
