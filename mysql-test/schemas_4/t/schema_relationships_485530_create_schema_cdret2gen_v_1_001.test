  PRIMARY KEY (`string_u_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.translate_id` (
  `this_id` INT,
  `extra_id` INT,
  `db_id` INT,
  PRIMARY KEY (`this_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.code` (
  `code_id` INT,
  `code` INT,
  PRIMARY KEY (`code_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.uuid` (
  `uuid_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`uuid_id`)
) CHARACTER SET latin1;

