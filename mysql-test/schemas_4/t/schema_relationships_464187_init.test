INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464187_init
--echo #
CREATE DATABASE `db_464187_init`;
USE `db_464187_init`;

CREATE TABLE `tasks` (
  `id` INT,
  `detail` VARCHAR(64),
  `isAvailable` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `counts` (
  `id` INT,
  `count` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464187_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464187_init') AS relationships;
DROP DATABASE `db_464187_init`;
UNINSTALL EXTENSION vsql_schematron;
