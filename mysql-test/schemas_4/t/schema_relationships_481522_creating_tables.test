INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481522_creating_tables
--echo #
CREATE DATABASE `db_481522_creating_tables`;
USE `db_481522_creating_tables`;
CREATE TABLE `department` (
  `Dep_Name` VARCHAR(50),
  `Dep_Number` INT NOT NULL,
  `Manager_SSN` CHAR(50),
  `Manager_start_date` CHAR(50),
  PRIMARY KEY (`Dep_Number`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `Emp_Name` VARCHAR(50),
  `SSN` VARCHAR(50) NOT NULL,
  `SSN_Bdate` VARCHAR(50),
  `address` VARCHAR(50),
  `gender` CHAR(50),
  `Salary` DOUBLE,
  `Super_SSN` VARCHAR(50),
  PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481522_creating_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481522_creating_tables') AS relationships;
DROP DATABASE `db_481522_creating_tables`;
UNINSTALL EXTENSION vsql_schematron;
