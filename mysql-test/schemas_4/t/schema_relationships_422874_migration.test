INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 422874_migration
--echo #
CREATE DATABASE `db_422874_migration`;
USE `db_422874_migration`;

CREATE TABLE `comments` (
  `id` VARCHAR(64),
  `message` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `taskId` VARCHAR(64),
  `authorId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `accessibility` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `owner` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sections` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `order` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `projectId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `dueDate` DATETIME,
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `sectionId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  `reset_token` VARCHAR(64),
  `reset_token_expires` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_422874_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_422874_migration') AS relationships;
DROP DATABASE `db_422874_migration`;
UNINSTALL EXTENSION vsql_schematron;
