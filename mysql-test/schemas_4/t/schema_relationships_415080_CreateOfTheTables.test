INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 415080_CreateOfTheTables
--echo #
CREATE DATABASE `db_415080_CreateOfTheTables`;
USE `db_415080_CreateOfTheTables`;

CREATE TABLE `GALAXIAS` (
  `COD_ID` DECIMAL(10,2),
  `NOME` VARCHAR(64),
  `SIGNIFICADO` VARCHAR(64),
  `DIAMETRO` DECIMAL(10,2),
  `OBSERVACAO` VARCHAR(64),
  `AGLOMERADO` DECIMAL(10,2),
  `IMAGEM` VARCHAR(64),
  PRIMARY KEY (`COD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONSTELACOES` (
  `COD_ID` DECIMAL(10,2),
  `NOME` VARCHAR(64),
  `SIGNIFICADO` VARCHAR(64),
  `AREA` VARCHAR(64),
  `GALAXIA` DECIMAL(10,2),
  PRIMARY KEY (`COD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ESTRELAS` (
  `COD_ID` DECIMAL(10,2),
  `NOME` VARCHAR(64),
  `CATEGORIA` VARCHAR(64),
  `MASSA` VARCHAR(64),
  `ANCENSAO` VARCHAR(64),
  `DECLINACAO` VARCHAR(64),
  `MAG_APARENTE` VARCHAR(64),
  `MAG_ABSOLUTA` VARCHAR(64),
  `DISTANCIA` VARCHAR(64),
  `CLASSIFICACAO` VARCHAR(64),
  `LUMINOSIDADE` VARCHAR(64),
  `CONSTELACAO` DECIMAL(10,2),
  `IMAGEM` VARCHAR(64),
  PRIMARY KEY (`COD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PLANETAS` (
  `COD_ID` DECIMAL(10,2),
  `NOME` VARCHAR(64),
  `CATEGORIA` VARCHAR(64),
  `SATELITES` DECIMAL(10,2),
  `MASSA` VARCHAR(64),
  `GRAVIDADE_SUPERFICIAL` VARCHAR(64),
  `ANO_DESCOBERTA` DECIMAL(10,2),
  `ORBITA_ESTELAR` DECIMAL(10,2),
  `IMAGEM` VARCHAR(64),
  PRIMARY KEY (`COD_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_415080_CreateOfTheTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_415080_CreateOfTheTables') AS relationships;
DROP DATABASE `db_415080_CreateOfTheTables`;
UNINSTALL EXTENSION vsql_schematron;
