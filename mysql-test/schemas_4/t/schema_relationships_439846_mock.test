INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439846_mock
--echo #
CREATE DATABASE `db_439846_mock`;
USE `db_439846_mock`;

CREATE TABLE `Emp` (
  `Emp_name` VARCHAR(64),
  `City` VARCHAR(64),
  `EmpId` INT,
  PRIMARY KEY (`Emp_name`)
) CHARACTER SET latin1;

CREATE TABLE `Emp_salary` (
  `Emp_name` VARCHAR(64),
  `Deptname` VARCHAR(64),
  `Salary` INT
) CHARACTER SET latin1;

CREATE TABLE `Emp_Details` (
  `EMPNO` INT,
  `ENAME` VARCHAR(64),
  `JOB` VARCHAR(64),
  `HIREDATE` DATETIME,
  `SAL` INT,
  `DEPTNO` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439846_mock') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439846_mock') AS relationships;
DROP DATABASE `db_439846_mock`;
UNINSTALL EXTENSION vsql_schematron;
