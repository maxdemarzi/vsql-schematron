INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 486654_wg_task
--echo #
CREATE DATABASE `db_486654_wg_task`;
USE `db_486654_wg_task`;
CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(50),
  `price` VARCHAR(50),
  `description` TEXT,
  `created_at` DATE,
  `updated_at` DATE,
  `add_by_user` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email_id` VARCHAR(50),
  `password` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `updated_on` TIMESTAMP NULL,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_486654_wg_task') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_486654_wg_task') AS relationships;
DROP DATABASE `db_486654_wg_task`;
UNINSTALL EXTENSION vsql_schematron;
