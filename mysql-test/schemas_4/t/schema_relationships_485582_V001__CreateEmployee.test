INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485582_V001__CreateEmployee
--echo #
CREATE DATABASE `db_485582_V001__CreateEmployee`;
USE `db_485582_V001__CreateEmployee`;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485582_V001__CreateEmployee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485582_V001__CreateEmployee') AS relationships;
DROP DATABASE `db_485582_V001__CreateEmployee`;
UNINSTALL EXTENSION vsql_schematron;
