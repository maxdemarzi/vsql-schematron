INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 440154_db
--echo #
CREATE DATABASE `db_440154_db`;
USE `db_440154_db`;
CREATE TABLE `teacher` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `teacher_id` VARCHAR(50),
  `subject` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_submission` (
  `project_id` INT,
  `student_id` INT,
  `report_pdf` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_440154_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_440154_db') AS relationships;
DROP DATABASE `db_440154_db`;
UNINSTALL EXTENSION vsql_schematron;
