INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 479498_V0__create_tables
--echo #
CREATE DATABASE `db_479498_V0__create_tables`;
USE `db_479498_V0__create_tables`;
CREATE TABLE `reviews` (
  `id` VARCHAR(50) NOT NULL,
  `location_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `name` VARCHAR(50),
  `image` VARCHAR(50),
  `overall_rating` INT,
  `description` TEXT,
  `enabled` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  `description` TEXT,
  `url` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50),
  `ip` BLOB,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_479498_V0__create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_479498_V0__create_tables') AS relationships;
DROP DATABASE `db_479498_V0__create_tables`;
UNINSTALL EXTENSION vsql_schematron;
