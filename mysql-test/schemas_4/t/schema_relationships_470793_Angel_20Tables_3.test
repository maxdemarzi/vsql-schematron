INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470793_Angel%20Tables_3
--echo #
CREATE DATABASE `db_470793_Angel_20Tables_3`;
USE `db_470793_Angel_20Tables_3`;
CREATE TABLE `Shipping` (
  `Ship_ID` INT NOT NULL,
  `Tracking_number` INT,
  `Shipping_date` DATE,
  `Shipping_company` VARCHAR(50),
  `Address_ID` INT,
  PRIMARY KEY (`Ship_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `Order_ID` INT NOT NULL,
  `Customer_ID` INT,
  `Guitar_ID` INT,
  `Payment_ID` INT,
  PRIMARY KEY (`Order_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Guitars` (
  `Guitar_ID` INT NOT NULL,
  `Finish_ID` INT,
  `Body_ID` INT,
  `Neck_ID` INT,
  `Finger_ID` INT,
  `Pickup_ID` INT,
  `Tuner_ID` INT,
  `Bridge_ID` INT,
  PRIMARY KEY (`Guitar_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Payments` (
  `Payment_ID` INT NOT NULL,
  `Payment_Type` VARCHAR(50),
  `Payment_Number` INT,
  `Verification_code` INT,
  `Expiration_ID` DATE,
  `Address_ID` INT,
  `Customer_id` INT,
  PRIMARY KEY (`Payment_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470793_Angel_20Tables_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470793_Angel_20Tables_3') AS relationships;
DROP DATABASE `db_470793_Angel_20Tables_3`;
UNINSTALL EXTENSION vsql_schematron;
