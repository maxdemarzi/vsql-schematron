INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447412_databaseConfig
--echo #
CREATE DATABASE `db_447412_databaseConfig`;
USE `db_447412_databaseConfig`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answers` (
  `id` INT,
  `text` VARCHAR(64),
  `created_at` DATETIME,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `tagname` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posttag` (
  `post_id` INT,
  `tag_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`post_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447412_databaseConfig') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447412_databaseConfig') AS relationships;
DROP DATABASE `db_447412_databaseConfig`;
UNINSTALL EXTENSION vsql_schematron;
