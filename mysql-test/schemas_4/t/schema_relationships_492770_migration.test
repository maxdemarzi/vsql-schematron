INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492770_migration
--echo #
CREATE DATABASE `db_492770_migration`;
USE `db_492770_migration`;
CREATE TABLE `Team` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  `teamsetId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Teamset` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `new_User` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  `email` TEXT,
  `hashedPassword` TEXT,
  `role` TEXT,
  `teamId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492770_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492770_migration') AS relationships;
DROP DATABASE `db_492770_migration`;
UNINSTALL EXTENSION vsql_schematron;
