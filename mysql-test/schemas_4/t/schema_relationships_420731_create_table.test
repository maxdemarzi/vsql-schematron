INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420731_create_table
--echo #
CREATE DATABASE `db_420731_create_table`;
USE `db_420731_create_table`;

CREATE TABLE `user` (
  `user_id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password_hash` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `post_id` INT,
  `author_id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `create_time` DATETIME,
  `update_time` DATETIME,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `comment_id` INT,
  `author_id` INT,
  `post_id` INT,
  `content` VARCHAR(64),
  `create_time` DATETIME,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

CREATE TABLE `follow` (
  `follower_id` INT,
  `followed_id` INT,
  `follow_time` DATETIME,
  PRIMARY KEY (`follower_id`, `followed_id`)
) CHARACTER SET latin1;

CREATE TABLE `postlike` (
  `author_id` INT,
  `post_id` INT,
  `like_status` INT,
  `create_time` DATETIME,
  PRIMARY KEY (`author_id`, `post_id`)
) CHARACTER SET latin1;

CREATE TABLE `collection` (
  `author_id` INT,
  `post_id` INT,
  `create_time` DATETIME,
  PRIMARY KEY (`author_id`, `post_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420731_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420731_create_table') AS relationships;
DROP DATABASE `db_420731_create_table`;
UNINSTALL EXTENSION vsql_schematron;
