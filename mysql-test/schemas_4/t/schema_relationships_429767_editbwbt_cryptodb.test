) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `media_file` VARCHAR(64),
  `tags` VARCHAR(64),
  `keyword_id` INT,
  `vote` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `protection_shop_tokens` (
  `id` INT,
  `user_id` INT,
  `number` VARCHAR(64),
