  `cancel_url` VARCHAR(64),
  `success_url_title` VARCHAR(64),
  `cancel_url_title` VARCHAR(64),
  `shop_url` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `protection_validations` (
  `id` INT,
  `user_id` INT,
