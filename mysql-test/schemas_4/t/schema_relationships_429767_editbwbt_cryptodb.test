CREATE DATABASE `db_429767_editbwbt_cryptodb`;
USE `db_429767_editbwbt_cryptodb`;

CREATE TABLE `comment_onpost` (
  `id` INT,
  `post_id` INT,
  `user_id` INT,
  `comment` VARCHAR(64),
  `vote` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forums_tb` (
  `id` INT,
  `user_id` INT,
  `question` VARCHAR(64),
  `answer` VARCHAR(64),
  `vote` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `keywords_tb` (
  `id` INT,
  `name` VARCHAR(64),
  `user_id` INT,
  `is_crypto` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pages` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
