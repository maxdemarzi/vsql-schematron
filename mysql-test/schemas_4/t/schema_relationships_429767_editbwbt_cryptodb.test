  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `unique_id` VARCHAR(64),
  `password` VARCHAR(64),
  `active` INT,
  `confirmation_code` VARCHAR(64),
  `confirmed` INT,
  `remember_token` VARCHAR(64),
  `email_verified_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
