INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 465306_h2
--echo #
CREATE DATABASE `db_465306_h2`;
USE `db_465306_h2`;
CREATE TABLE `IDN_SECRET_TYPE` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `IDN_SECRET` (
  `ID` VARCHAR(50) NOT NULL,
  `TENANT_ID` INT,
  `SECRET_NAME` VARCHAR(50),
  `SECRET_VALUE` VARCHAR(50),
  `CREATED_TIME` TIMESTAMP NULL,
  `LAST_MODIFIED` TIMESTAMP NULL,
  `TYPE_ID` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_465306_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_465306_h2') AS relationships;
DROP DATABASE `db_465306_h2`;
UNINSTALL EXTENSION vsql_schematron;
