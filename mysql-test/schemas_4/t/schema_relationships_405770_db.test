INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405770_db
--echo #
CREATE DATABASE `db_405770_db`;
USE `db_405770_db`;

CREATE TABLE `xingyu_semester` (
  `id` INT,
  `name` VARCHAR(64),
  `start_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `xingyu_group` (
  `id` INT,
  `name` VARCHAR(64),
  `semester_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `xingyu_student` (
  `id` INT,
  `name` VARCHAR(64),
  `wechat_nickname` VARCHAR(64),
  `wechat_openid` VARCHAR(64),
  `school` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `xingyu_activity` (
  `id` INT,
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `institution` VARCHAR(64),
  `time` DATETIME,
  `special` BOOL,
  `group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `xingyu_student_activity` (
  `id` INT,
  `student_id` INT,
  `activity_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `xingyu_student_group` (
  `id` INT,
  `student_id` INT,
  `group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405770_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405770_db') AS relationships;
DROP DATABASE `db_405770_db`;
UNINSTALL EXTENSION vsql_schematron;
