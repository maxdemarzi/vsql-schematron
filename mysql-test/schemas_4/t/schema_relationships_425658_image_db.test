INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425658_image_db
--echo #
CREATE DATABASE `db_425658_image_db`;
USE `db_425658_image_db`;

CREATE TABLE `img_types` (
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `name` VARCHAR(64),
  `imagetype` VARCHAR(64),
  `width` INT,
  `height` INT,
  `image` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `imgname` VARCHAR(64),
  `rnk` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`imgname`, `rnk`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425658_image_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425658_image_db') AS relationships;
DROP DATABASE `db_425658_image_db`;
UNINSTALL EXTENSION vsql_schematron;
