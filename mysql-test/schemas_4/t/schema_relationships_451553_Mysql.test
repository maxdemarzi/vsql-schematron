INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 451553_Mysql
--echo #
CREATE DATABASE `db_451553_Mysql`;
USE `db_451553_Mysql`;
CREATE TABLE `servers` (
  `id` INT NOT NULL,
  `ip` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cpus` (
  `id` INT NOT NULL,
  `server_id` INT,
  `percent` DOUBLE,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mems` (
  `id` INT NOT NULL,
  `server_id` INT,
  `free` INT,
  `used` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nets` (
  `id` INT NOT NULL,
  `server_id` INT,
  `rx` INT,
  `tx` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_451553_Mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_451553_Mysql') AS relationships;
DROP DATABASE `db_451553_Mysql`;
UNINSTALL EXTENSION vsql_schematron;
