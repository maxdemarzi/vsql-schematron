INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 463098_add_access_control
--echo #
CREATE DATABASE `db_463098_add_access_control`;
USE `db_463098_add_access_control`;

CREATE TABLE `users` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `enabled` BOOL,
  `is_ldap_account` BOOL,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `authorities` (
  `username` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `name` VARCHAR(64),
  `external_id` VARCHAR(64),
  `description` VARCHAR(64),
  `parent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project_role` (
  `project_id` INT,
  `username` VARCHAR(64),
  `role` INT,
  PRIMARY KEY (`project_id`, `username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_463098_add_access_control') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_463098_add_access_control') AS relationships;
DROP DATABASE `db_463098_add_access_control`;
UNINSTALL EXTENSION vsql_schematron;
