INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 467477_0002_mailer-template.postgres
--echo #
CREATE DATABASE `db_467477_0002_mailer_template_postgres`;
USE `db_467477_0002_mailer_template_postgres`;

CREATE TABLE `mailer_template` (
  `id` VARCHAR(64),
  `version` VARCHAR(64),
  `space_id` VARCHAR(64),
  `is_active` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `title` VARCHAR(64),
  `language` VARCHAR(64),
  `body_html` VARCHAR(64),
  `body_text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mailer_template_stream` (
  `id` VARCHAR(64),
  `template_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `key` VARCHAR(64),
  `payload` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_467477_0002_mailer_template_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_467477_0002_mailer_template_postgres') AS relationships;
DROP DATABASE `db_467477_0002_mailer_template_postgres`;
UNINSTALL EXTENSION vsql_schematron;
