INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 407602_Aula06
--echo #
CREATE DATABASE `db_407602_Aula06`;
USE `db_407602_Aula06`;

CREATE TABLE `tblfaculdades` (
  `facid` INT,
  `facnome` VARCHAR(64),
  `facsigla` VARCHAR(64),
  PRIMARY KEY (`facid`)
) CHARACTER SET latin1;

CREATE TABLE `tblcursos` (
  `curid` INT,
  `curnome` VARCHAR(64),
  `cursigla` VARCHAR(64),
  `curarea` VARCHAR(64),
  PRIMARY KEY (`curid`)
) CHARACTER SET latin1;

CREATE TABLE `tblcursosfaculdades` (
  `curid` INT,
  `facid` INT,
  PRIMARY KEY (`curid`, `facid`)
) CHARACTER SET latin1;

CREATE TABLE `tblprofissoes` (
  `profid` INT,
  `profnome` VARCHAR(64),
  PRIMARY KEY (`profid`)
) CHARACTER SET latin1;

CREATE TABLE `tblalunos` (
  `aluid` INT,
  `alura` VARCHAR(64),
  `alunome` VARCHAR(64),
  `alucpf` DECIMAL(10,2),
  `aludatanascimento` DATETIME,
  `alupeso` DECIMAL(10,2),
  `profid` INT,
  `curid` INT,
  PRIMARY KEY (`aluid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_407602_Aula06') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_407602_Aula06') AS relationships;
DROP DATABASE `db_407602_Aula06`;
UNINSTALL EXTENSION vsql_schematron;
