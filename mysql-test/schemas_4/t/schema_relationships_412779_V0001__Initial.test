INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 412779_V0001__Initial
--echo #
CREATE DATABASE `db_412779_V0001__Initial`;
USE `db_412779_V0001__Initial`;
CREATE TABLE `PERSON` (
  `ID` VARCHAR(50) NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `AGE` INT,
  `CREATED` TIMESTAMP NULL,
  `UPDATED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EVENT` (
  `ID` VARCHAR(50) NOT NULL,
  `PERSON_ID` VARCHAR(50),
  `TITLE` VARCHAR(50),
  `DESCRIPTION` TEXT,
  `CREATED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_412779_V0001__Initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_412779_V0001__Initial') AS relationships;
DROP DATABASE `db_412779_V0001__Initial`;
UNINSTALL EXTENSION vsql_schematron;
