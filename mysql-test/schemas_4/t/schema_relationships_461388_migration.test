INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 461388_migration
--echo #
CREATE DATABASE `db_461388_migration`;
USE `db_461388_migration`;
CREATE TABLE `View` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Page` (
  `id` INT NOT NULL,
  `name` TEXT,
  `count` INT,
  `view_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_461388_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_461388_migration') AS relationships;
DROP DATABASE `db_461388_migration`;
UNINSTALL EXTENSION vsql_schematron;
