INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485661_database
--echo #
CREATE DATABASE `db_485661_database`;
USE `db_485661_database`;

CREATE TABLE `user` (
  `user_id` INT,
  `name` VARCHAR(64),
  `phoneNumber` VARCHAR(64),
  `user_name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `application` (
  `app_id` INT,
  `name` VARCHAR(64),
  `kind` VARCHAR(64),
  `price` DECIMAL(10,2),
  `description` VARCHAR(64),
  `publisher` VARCHAR(64),
  `datepublish` DATETIME,
  `size` DECIMAL(10,2),
  `ratings` VARCHAR(64),
  PRIMARY KEY (`app_id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `payment_id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `money` DECIMAL(10,2),
  PRIMARY KEY (`payment_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `bill` (
  `bill_id` INT,
  `app_id` INT,
  `user_id` INT,
  `payment_id` INT,
  `unitprice` DECIMAL(10,2),
  `datacreate` DATETIME,
  PRIMARY KEY (`bill_id`)
) CHARACTER SET latin1;

CREATE TABLE `appbougth` (
  `user_id` INT,
  `app_id` INT,
  PRIMARY KEY (`user_id`, `app_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485661_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485661_database') AS relationships;
DROP DATABASE `db_485661_database`;
UNINSTALL EXTENSION vsql_schematron;
