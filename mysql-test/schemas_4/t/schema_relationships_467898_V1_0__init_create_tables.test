INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 467898_V1_0__init_create_tables
--echo #
CREATE DATABASE `db_467898_V1_0__init_create_tables`;
USE `db_467898_V1_0__init_create_tables`;
CREATE TABLE `user_entity` (
  `user_uuid` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `ip` VARCHAR(50),
  `creation_date` DATETIME,
  `last_login_date` DATETIME,
  `version` INT,
  `active` BOOLEAN,
  PRIMARY KEY (`user_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `tag_entity` (
  `tag_uuid` VARCHAR(50) NOT NULL,
  `version` INT,
  `tag_name` VARCHAR(50),
  `creation_date` DATETIME,
  `modify_date` DATETIME,
  PRIMARY KEY (`tag_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `product_entity` (
  `product_uuid` VARCHAR(50) NOT NULL,
  `version` INT,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `creation_date` DATETIME,
  `modify_date` DATETIME,
  `active` BOOLEAN,
  `number_of_downloads` BIGINT,
  `preview_image` BLOB,
  `product_item` BLOB,
  `user_uuid` VARCHAR(50),
  `tag_uuid` VARCHAR(50),
  PRIMARY KEY (`product_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `rating_entity` (
  `rating_uuid` VARCHAR(50) NOT NULL,
  `version` INT,
  `rating_description` VARCHAR(50),
  `rating_as_number` INT,
  `creation_date` DATETIME,
  `modify_date` DATETIME,
  `active` BOOLEAN,
  `user_uuid` VARCHAR(50),
  `product_uuid` VARCHAR(50),
  PRIMARY KEY (`rating_uuid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_467898_V1_0__init_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_467898_V1_0__init_create_tables') AS relationships;
DROP DATABASE `db_467898_V1_0__init_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
