INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 446350_createdbmodal
--echo #
CREATE DATABASE `db_446350_createdbmodal`;
USE `db_446350_createdbmodal`;
CREATE TABLE `approles` (
  `role_id` INT NOT NULL,
  `role_common_name` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `userrolemapping` (
  `user_id` BIGINT NOT NULL,
  `role_id` BIGINT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_446350_createdbmodal') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_446350_createdbmodal') AS relationships;
DROP DATABASE `db_446350_createdbmodal`;
UNINSTALL EXTENSION vsql_schematron;
