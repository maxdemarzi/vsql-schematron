INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 457382_null
--echo #
CREATE DATABASE `db_457382_null`;
USE `db_457382_null`;

CREATE TABLE `Account` (
  `id` INT,
  `Email` VARCHAR(64),
  `Name` VARCHAR(64),
  `Password` VARCHAR(64),
  `Userrole` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sheet1` (
  `id` INT,
  `IntField` INT,
  `DateField` DATETIME,
  `Text` VARCHAR(64),
  `DecimalField` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sheet1User` (
  `id` INT,
  `Userid` INT,
  `Sheet1Id` INT,
  `UserYN` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sheet2` (
  `id` INT,
  `DateField` DATETIME,
  `IntegerField` INT,
  `Text` VARCHAR(64),
  `DecimalField` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_457382_null') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_457382_null') AS relationships;
DROP DATABASE `db_457382_null`;
UNINSTALL EXTENSION vsql_schematron;
