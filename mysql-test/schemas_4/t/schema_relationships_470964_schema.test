INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470964_schema
--echo #
CREATE DATABASE `db_470964_schema`;
USE `db_470964_schema`;
CREATE TABLE `userPosts` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `userLogins` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470964_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470964_schema') AS relationships;
DROP DATABASE `db_470964_schema`;
UNINSTALL EXTENSION vsql_schematron;
