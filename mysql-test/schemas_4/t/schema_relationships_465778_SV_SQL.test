INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 465778_SV_SQL
--echo #
CREATE DATABASE `db_465778_SV_SQL`;
USE `db_465778_SV_SQL`;

CREATE TABLE `Applications` (
  `Code_Application` VARCHAR(64),
  `LIBELLE` VARCHAR(64),
  `TYPE` VARCHAR(64),
  PRIMARY KEY (`Code_Application`)
) CHARACTER SET latin1;

CREATE TABLE `Correspondant` (
  `Id_RH` VARCHAR(64),
  `NOM` VARCHAR(64),
  `PRENOM` VARCHAR(64),
  `FONCTION` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `TELEPHONE` INT,
  `ROLE` VARCHAR(64),
  PRIMARY KEY (`Id_RH`)
) CHARACTER SET latin1;

CREATE TABLE `Autoriser` (
  `Code_Application` VARCHAR(64),
  `ID` INT,
  PRIMARY KEY (`Code_Application`, `ID`)
) CHARACTER SET latin1;

CREATE TABLE `Appartenir` (
  `Id_RH` VARCHAR(64),
  `Code_Application` VARCHAR(64),
  PRIMARY KEY (`Id_RH`, `Code_Application`)
) CHARACTER SET latin1;

CREATE TABLE `CONVERTIR` (
  `Id` INT,
  `Id_SV_SUIVI` INT,
  `id_SV_Statistiques` INT,
  PRIMARY KEY (`Id`, `Id_SV_SUIVI`, `id_SV_Statistiques`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_465778_SV_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_465778_SV_SQL') AS relationships;
DROP DATABASE `db_465778_SV_SQL`;
UNINSTALL EXTENSION vsql_schematron;
