INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458756_laravel-app
--echo #
CREATE DATABASE `db_458756_laravel_app`;
USE `db_458756_laravel_app`;

CREATE TABLE `connections` (
  `id` INT,
  `user_id` INT,
  `connection_id` INT,
  `is_connected` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `technologies` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458756_laravel_app') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458756_laravel_app') AS relationships;
DROP DATABASE `db_458756_laravel_app`;
UNINSTALL EXTENSION vsql_schematron;
