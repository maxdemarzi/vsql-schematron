INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405128_migration
--echo #
CREATE DATABASE `db_405128_migration`;
USE `db_405128_migration`;

CREATE TABLE `BookInfo` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `historyBookCount` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Book` (
  `id` VARCHAR(64),
  `infoId` VARCHAR(64),
  `thumbnailPage` INT,
  `number` VARCHAR(64),
  `pageCount` INT,
  `thumbnailById` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Genre` (
  `name` VARCHAR(64),
  `isInvisible` BOOL,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `BookInfosToGenres` (
  `infoId` VARCHAR(64),
  `genreName` VARCHAR(64),
  PRIMARY KEY (`infoId`, `genreName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405128_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405128_migration') AS relationships;
DROP DATABASE `db_405128_migration`;
UNINSTALL EXTENSION vsql_schematron;
