INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 432556_All_Tables
--echo #
CREATE DATABASE `db_432556_All_Tables`;
USE `db_432556_All_Tables`;

CREATE TABLE `beers` (
  `id` INT,
  `brewery_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `image` VARCHAR(64),
  `abv` DECIMAL(10,2),
  `beer_type` INT,
  `gluten_free` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `breweries` (
  `id` INT,
  `name` VARCHAR(64),
  `address1` VARCHAR(64),
  `address2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip_code` VARCHAR(64),
  `country` VARCHAR(64),
  `longitude` DECIMAL(10,2),
  `latitude` DECIMAL(10,2),
  `phone` VARCHAR(64),
  `website` VARCHAR(64),
  `history` VARCHAR(64),
  `image` VARCHAR(64),
  `food_id` INT,
  `active` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `review_type` INT,
  `target_id` INT,
  `user_id` INT,
  `review_title` VARCHAR(64),
  `review_body` VARCHAR(64),
  `review_caps` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `operation_hours` (
  `brewery_id` INT,
  `day` INT,
  `open` DATETIME,
  `close` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `beer_type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `food` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `review_type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `favorite_breweries` (
  `user_id` INT,
  `brewery_id` INT,
  PRIMARY KEY (`user_id`, `brewery_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_432556_All_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_432556_All_Tables') AS relationships;
DROP DATABASE `db_432556_All_Tables`;
UNINSTALL EXTENSION vsql_schematron;
