INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450157_01-create
--echo #
CREATE DATABASE `db_450157_01_create`;
USE `db_450157_01_create`;
CREATE TABLE `regions` (
  `region_id` INT NOT NULL,
  `region_name` CHAR(50),
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `country_id` VARCHAR(50) NOT NULL,
  `country_name` CHAR(50),
  `region_id` INT,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `location_id` INT NOT NULL,
  `street_address` CHAR(50),
  `postal_code` CHAR(50),
  `city` CHAR(50),
  `state_province` CHAR(50),
  `country_id` CHAR(50),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
  `department_id` INT NOT NULL,
  `department_name` CHAR(50),
  `location_id` INT,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
  `job_id` INT NOT NULL,
  `job_title` CHAR(50),
  `min_salary` DECIMAL(10,2),
  `max_salary` DECIMAL(10,2),
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `employee_id` INT NOT NULL,
  `first_name` CHAR(50),
  `last_name` CHAR(50),
  `email` CHAR(50),
  `phone_number` CHAR(50),
  `hire_date` DATE,
  `job_id` INT,
  `salary` DECIMAL(10,2),
  `manager_id` INT,
  `department_id` INT,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `dependents` (
  `dependent_id` INT NOT NULL,
  `first_name` CHAR(50),
  `last_name` CHAR(50),
  `relationship` CHAR(50),
  `employee_id` INT,
  PRIMARY KEY (`dependent_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450157_01_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450157_01_create') AS relationships;
DROP DATABASE `db_450157_01_create`;
UNINSTALL EXTENSION vsql_schematron;
