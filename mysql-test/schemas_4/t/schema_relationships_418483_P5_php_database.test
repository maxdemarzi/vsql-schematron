INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 418483_P5_php_database
--echo #
CREATE DATABASE `db_418483_P5_php_database`;
USE `db_418483_P5_php_database`;

CREATE TABLE `comment` (
  `id` INT,
  `author` VARCHAR(64),
  `comment` VARCHAR(64),
  `valid` INT,
  `date_create` VARCHAR(64),
  `post_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `date_create` DATETIME,
  `user_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_type` (
  `id` INT,
  `user_type` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_418483_P5_php_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_418483_P5_php_database') AS relationships;
DROP DATABASE `db_418483_P5_php_database`;
UNINSTALL EXTENSION vsql_schematron;
