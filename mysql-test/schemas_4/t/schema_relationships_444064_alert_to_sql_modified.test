INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444064_alert_to_sql_modified
--echo #
CREATE DATABASE `db_444064_alert_to_sql_modified`;
USE `db_444064_alert_to_sql_modified`;
CREATE TABLE `icu_info` (
  `icu_Id` INT NOT NULL,
  `layout` VARCHAR(50),
  `icu_Maximum_Capacity` INT,
  PRIMARY KEY (`icu_Id`)
) CHARACTER SET latin1;
CREATE TABLE `device_info` (
  `device_Id` INT NOT NULL,
  `spo2` INT,
  `bpm` INT,
  `resp_Rate` INT,
  PRIMARY KEY (`device_Id`)
) CHARACTER SET latin1;
CREATE TABLE `bed_info` (
  `bed_Id` INT NOT NULL,
  `device_Id` INT,
  `icu_Id` INT,
  `bed_Status` BOOLEAN,
  PRIMARY KEY (`bed_Id`)
) CHARACTER SET latin1;
CREATE TABLE `alert_info` (
  `alert_Id` INT NOT NULL,
  `bed_Id` INT,
  `error_Message` VARCHAR(50),
  PRIMARY KEY (`alert_Id`)
) CHARACTER SET latin1;
CREATE TABLE `patient_info` (
  `patient_Id` INT NOT NULL,
  `name` VARCHAR(50),
  `age` INT,
  `bed_Id` INT,
  PRIMARY KEY (`patient_Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444064_alert_to_sql_modified') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444064_alert_to_sql_modified') AS relationships;
DROP DATABASE `db_444064_alert_to_sql_modified`;
UNINSTALL EXTENSION vsql_schematron;
