INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 490299_schema-h2
--echo #
CREATE DATABASE `db_490299_schema_h2`;
USE `db_490299_schema_h2`;
CREATE TABLE `CUSTOMER` (
  `ID` BIGINT NOT NULL,
  `VER` INT,
  `TM` DATETIME,
  `ACTIVE_AFTER` DATETIME,
  `ACTIVE_UNTIL` DATETIME,
  `LOGIN` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER_ACCOUNT` (
  `ID` BIGINT NOT NULL,
  `VER` INT,
  `TM` DATETIME,
  `CURRENCY` CHAR(50),
  `BALANCE` INT,
  `ID_CUSTOMER` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_490299_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_490299_schema_h2') AS relationships;
DROP DATABASE `db_490299_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
