INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449993_grimm
--echo #
CREATE DATABASE `db_449993_grimm`;
USE `db_449993_grimm`;

CREATE TABLE `activity` (
  `id` INT,
  `title` VARCHAR(64),
  `start_time` DATETIME,
  `location` VARCHAR(64),
  `end_time` DATETIME,
  `content` VARCHAR(64),
  `notice` VARCHAR(64),
  `others` VARCHAR(64),
  `admin_raiser` INT,
  `user_raiser` VARCHAR(64),
  `approver` INT,
  `assignee` VARCHAR(64),
  `published` INT,
  `tag_ids` VARCHAR(64),
  `volunteer_capacity` INT,
  `vision_impaired_capacity` INT,
  `volunteer_job_title` VARCHAR(64),
  `volunteer_job_content` VARCHAR(64),
  `activity_fee` INT,
  `sign_in_radius` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pickup_pair` (
  `activity_id` INT,
  `offer` VARCHAR(64),
  `need` VARCHAR(64),
  `time` DATETIME,
  `location` VARCHAR(64),
  PRIMARY KEY (`offer`, `need`)
) CHARACTER SET latin1;

CREATE TABLE `activity_participant` (
  `activity_id` INT,
  `participant_openid` VARCHAR(64),
  `interested` INT,
  `share` INT,
  `thumbs_up` INT,
  `certificated` INT,
  `certificate_date` DATETIME,
  `paper_certificate` INT,
  PRIMARY KEY (`activity_id`, `participant_openid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449993_grimm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449993_grimm') AS relationships;
DROP DATABASE `db_449993_grimm`;
UNINSTALL EXTENSION vsql_schematron;
