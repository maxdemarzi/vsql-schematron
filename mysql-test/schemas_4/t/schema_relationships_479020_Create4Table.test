INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 479020_Create4Table
--echo #
CREATE DATABASE `db_479020_Create4Table`;
USE `db_479020_Create4Table`;

CREATE TABLE `loginTable` (
  `UserId` VARCHAR(64),
  `Pswd` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`UserId`)
) CHARACTER SET latin1;

CREATE TABLE `bookTable` (
  `ISBN` VARCHAR(64),
  `BookName` VARCHAR(64),
  `Publisher` VARCHAR(64),
  `Author` VARCHAR(64),
  `CollectionNum` INT,
  `CanBorrowNum` INT,
  `CanBorrow` VARCHAR(64),
  PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;

CREATE TABLE `readerTable` (
  `ReaderId` VARCHAR(64),
  `ReaderName` VARCHAR(64),
  `Sex` VARCHAR(64),
  `JobTitle` VARCHAR(64),
  `CanBorrowNum` INT,
  `BorrowedNum` INT,
  `Department` VARCHAR(64),
  `PhoneNumber` VARCHAR(64),
  PRIMARY KEY (`ReaderId`)
) CHARACTER SET latin1;

CREATE TABLE `borrowTable` (
  `ReaderId` VARCHAR(64),
  `ISBN` VARCHAR(64),
  `BorrowedDate` VARCHAR(64),
  `BorrowPeriod` INT,
  `ReturnDate` VARCHAR(64),
  `Fine` INT,
  PRIMARY KEY (`ReaderId`, `ISBN`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_479020_Create4Table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_479020_Create4Table') AS relationships;
DROP DATABASE `db_479020_Create4Table`;
UNINSTALL EXTENSION vsql_schematron;
