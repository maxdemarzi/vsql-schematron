INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456945_V1_ddl
--echo #
CREATE DATABASE `db_456945_V1_ddl`;
USE `db_456945_V1_ddl`;

CREATE TABLE `user` (
  `usr_id` INT,
  `usr_username` VARCHAR(255),
  `usr_name` VARCHAR(255),
  `usr_password` VARCHAR(255),
  PRIMARY KEY (`usr_id`)
) CHARACTER SET latin1;

CREATE TABLE `folder` (
  `fol_id` INT,
  `fol_name` VARCHAR(255),
  `fol_usr_id` INT,
  PRIMARY KEY (`fol_id`)
) CHARACTER SET latin1;

CREATE TABLE `task` (
  `tak_id` INT,
  `tak_order` INT,
  `tak_text` VARCHAR(255),
  `tak_done` VARCHAR(255),
  `tak_fol_id` INT,
  PRIMARY KEY (`tak_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456945_V1_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456945_V1_ddl') AS relationships;
DROP DATABASE `db_456945_V1_ddl`;
UNINSTALL EXTENSION vsql_schematron;
