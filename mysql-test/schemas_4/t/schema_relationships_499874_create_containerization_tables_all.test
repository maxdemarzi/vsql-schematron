INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499874_create.containerization-tables-all
--echo #
CREATE DATABASE `db_499874_create_containerization_tables_all`;
USE `db_499874_create_containerization_tables_all`;

CREATE TABLE `image_types` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `active` BOOL,
  `deployable` VARCHAR(64),
  `created_on` DATETIME,
  `created_by` VARCHAR(64),
  `modified_on` DATETIME,
  `modified_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_versions` (
  `id` INT,
  `path` VARCHAR(64),
  `description` VARCHAR(64),
  `version` VARCHAR(64),
  `type_id` INT,
  `state` VARCHAR(64),
  `release_tag` VARCHAR(64),
  `created_on` DATETIME,
  `created_by` VARCHAR(64),
  `modified_on` DATETIME,
  `modified_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_ownerships` (
  `id` INT,
  `type_id` INT,
  `owner` VARCHAR(64),
  `role` VARCHAR(64),
  `created_on` DATETIME,
  `created_by` VARCHAR(64),
  `modified_on` DATETIME,
  `modified_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_rampup_plan` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `type_id` INT,
  `active` BOOL,
  `created_on` DATETIME,
  `created_by` VARCHAR(64),
  `modified_on` DATETIME,
  `modified_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_rampup` (
  `id` INT,
  `plan_id` INT,
  `version_id` INT,
  `rampup_percentage` INT,
  `stability_tag` VARCHAR(64),
  `created_on` DATETIME,
  `created_by` VARCHAR(64),
  `modified_on` DATETIME,
  `modified_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `version_set` (
  `id` INT,
  `md5` VARCHAR(64),
  `json` VARCHAR(64),
  `created_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499874_create_containerization_tables_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499874_create_containerization_tables_all') AS relationships;
DROP DATABASE `db_499874_create_containerization_tables_all`;
UNINSTALL EXTENSION vsql_schematron;
