INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439968_QuickDBD-export
--echo #
CREATE DATABASE `db_439968_QuickDBD_export`;
USE `db_439968_QuickDBD_export`;

CREATE TABLE `card_holder` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `credit_card` (
  `cardholder_id` INT,
  `card` VARCHAR(64),
  PRIMARY KEY (`cardholder_id`)
) CHARACTER SET latin1;

CREATE TABLE `merchant_category` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `merchant` (
  `id` INT,
  `name` VARCHAR(64),
  `id_merchant_category` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `date` DATETIME,
  `amount` DECIMAL(10,2),
  `card` VARCHAR(64),
  `id_merchant` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439968_QuickDBD_export') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439968_QuickDBD_export') AS relationships;
DROP DATABASE `db_439968_QuickDBD_export`;
UNINSTALL EXTENSION vsql_schematron;
