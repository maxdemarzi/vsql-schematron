INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 476560_sql_script
--echo #
CREATE DATABASE `db_476560_sql_script`;
USE `db_476560_sql_script`;

CREATE TABLE `student` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `provider` (
  `id` INT,
  `name` VARCHAR(64),
  `operatorCode` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contact` (
  `contact` VARCHAR(64),
  `student_id` INT,
  `provider_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_476560_sql_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_476560_sql_script') AS relationships;
DROP DATABASE `db_476560_sql_script`;
UNINSTALL EXTENSION vsql_schematron;
