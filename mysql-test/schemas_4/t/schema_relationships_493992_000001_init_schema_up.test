INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 493992_000001_init_schema.up
--echo #
CREATE DATABASE `db_493992_000001_init_schema_up`;
USE `db_493992_000001_init_schema_up`;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `owner` VARCHAR(50),
  `balance` DECIMAL(10,2),
  `currency` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
  `id` INT NOT NULL,
  `account_id` BIGINT,
  `amount` DECIMAL(10,2),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transfers` (
  `id` INT NOT NULL,
  `from_account_id` BIGINT,
  `to_account_id` BIGINT,
  `amount` DECIMAL(10,2),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_493992_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_493992_000001_init_schema_up') AS relationships;
DROP DATABASE `db_493992_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
