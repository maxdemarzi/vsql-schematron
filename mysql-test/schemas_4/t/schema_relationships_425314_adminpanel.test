INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425314_adminpanel
--echo #
CREATE DATABASE `db_425314_adminpanel`;
USE `db_425314_adminpanel`;

CREATE TABLE `blogs` (
  `id` INT,
  `name` VARCHAR(64),
  `publish_datetime` DATETIME,
  `featured_image` VARCHAR(64),
  `content` VARCHAR(64),
  `meta_title` VARCHAR(64),
  `cannonical_link` VARCHAR(64),
  `slug` VARCHAR(64),
  `meta_description` VARCHAR(64),
  `meta_keywords` VARCHAR(64),
  `status` VARCHAR(64),
  `created_by` INT,
  `updated_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_categories` (
  `id` INT,
  `name` VARCHAR(64),
  `status` INT,
  `created_by` INT,
  `updated_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_map_categories` (
  `id` INT,
  `blog_id` INT,
  `category_id` INT
) CHARACTER SET latin1;

CREATE TABLE `blog_map_tags` (
  `id` INT,
  `blog_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

CREATE TABLE `blog_tags` (
  `id` INT,
  `name` VARCHAR(64),
  `status` INT,
  `created_by` INT,
  `updated_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `body` VARCHAR(64),
  `created_by` INT,
  `commentable_id` INT,
  `commentable_type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `companies` (
  `id` INT,
  `title` VARCHAR(64),
  `company_slug` VARCHAR(64),
  `website` VARCHAR(64),
  `address` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `description` VARCHAR(64),
  `status` INT,
  `created_by` INT,
  `updated_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `faqs` (
  `id` INT,
