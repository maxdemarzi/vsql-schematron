  `linkedin` VARCHAR(64),
  `twitter` VARCHAR(64),
  `google` VARCHAR(64),
  `copyright_text` VARCHAR(64),
  `footer_text` VARCHAR(64),
  `terms` VARCHAR(64),
  `disclaimer` VARCHAR(64),
  `google_analytics` VARCHAR(64),
  `home_video1` VARCHAR(64),
  `home_video2` VARCHAR(64),
  `home_video3` VARCHAR(64),
  `home_video4` VARCHAR(64),
  `explanation1` VARCHAR(64),
  `explanation2` VARCHAR(64),
  `explanation3` VARCHAR(64),
  `explanation4` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `social_logins` (
  `id` INT,
  `user_id` INT,
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `token` VARCHAR(64),
  `avatar` VARCHAR(64),
