INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 483392_001_add_careerguide_users
--echo #
CREATE DATABASE `db_483392_001_add_careerguide_users`;
USE `db_483392_001_add_careerguide_users`;

CREATE TABLE `pontoonapps_careerguide.users` (
  `id` INT,
  `pontoon_user_id` INT,
  `guest_name` VARCHAR(64),
  `date_created` DATETIME,
  `date_modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pontoonapps_careerguide.likes` (
  `user_id` INT,
  `job_id` INT,
  `type` VARCHAR(64),
  `time_stamp` DATETIME,
  PRIMARY KEY (`user_id`, `job_id`)
) CHARACTER SET latin1;

CREATE TABLE `pontoonapps_careerguide.shortlists` (
  `user_id` INT,
  `job_id` INT,
  `time_stamp` DATETIME,
  PRIMARY KEY (`user_id`, `job_id`)
) CHARACTER SET latin1;

CREATE TABLE `pontoonapps_careerguide.answers` (
  `user_id` INT,
  `question_id` INT,
  `option_number` INT,
  `time_stamp` DATETIME,
  PRIMARY KEY (`user_id`, `question_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_483392_001_add_careerguide_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_483392_001_add_careerguide_users') AS relationships;
DROP DATABASE `db_483392_001_add_careerguide_users`;
UNINSTALL EXTENSION vsql_schematron;
