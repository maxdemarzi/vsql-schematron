INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 441345_school1
--echo #
CREATE DATABASE `db_441345_school1`;
USE `db_441345_school1`;

CREATE TABLE `classe` (
  `id` INT,
  `code` VARCHAR(64),
  `id_filiere` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `etudiant` (
  `id` INT,
  `nom` VARCHAR(64),
  `prenom` VARCHAR(64),
  `ville` VARCHAR(64),
  `sexe` VARCHAR(64),
  `id_classe` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `filiere` (
  `id` INT,
  `libelle` VARCHAR(64),
  `code` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `login` (
  `id` INT,
  `usename` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_441345_school1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_441345_school1') AS relationships;
DROP DATABASE `db_441345_school1`;
UNINSTALL EXTENSION vsql_schematron;
