CREATE TABLE `user_types` (
  `id` INT,
  `title` VARCHAR(64),
  `name` VARCHAR(64),
  `level` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464037_sql_export') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464037_sql_export') AS relationships;
DROP DATABASE `db_464037_sql_export`;
UNINSTALL EXTENSION vsql_schematron;
