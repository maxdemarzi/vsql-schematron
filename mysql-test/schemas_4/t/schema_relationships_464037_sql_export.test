  `session` VARCHAR(64),
  `house` VARCHAR(64),
  `age` INT,
  `year_admitted` VARCHAR(64),
  `grad` INT,
  `grad_date` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `id` INT,
