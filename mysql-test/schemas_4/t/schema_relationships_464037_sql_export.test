  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `time_slots` (
  `id` INT,
  `ttr_id` INT,
  `hour_from` INT,
  `min_from` VARCHAR(64),
  `meridian_from` VARCHAR(64),
  `hour_to` INT,
  `min_to` VARCHAR(64),
  `meridian_to` VARCHAR(64),
  `time_from` VARCHAR(64),
  `time_to` VARCHAR(64),
  `timestamp_from` VARCHAR(64),
  `timestamp_to` VARCHAR(64),
  `full` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `time_tables` (
  `id` INT,
  `ttr_id` INT,
