INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464037_sql_export
--echo #
CREATE DATABASE `db_464037_sql_export`;
USE `db_464037_sql_export`;

CREATE TABLE `blood_groups` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `name` VARCHAR(64),
  `my_class_id` INT,
  `description` VARCHAR(64),
  `author` VARCHAR(64),
  `book_type` VARCHAR(64),
  `url` VARCHAR(64),
  `location` VARCHAR(64),
  `total_copies` INT,
  `issued_copies` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `book_requests` (
  `id` INT,
  `book_id` INT,
  `user_id` INT,
  `start_date` VARCHAR(64),
  `end_date` VARCHAR(64),
  `returned` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `class_types` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dorms` (
