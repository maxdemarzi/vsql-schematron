  `subject_id` INT,
  `exam_date` VARCHAR(64),
  `timestamp_from` VARCHAR(64),
  `timestamp_to` VARCHAR(64),
  `day` VARCHAR(64),
  `day_num` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `time_table_records` (
  `id` INT,
  `name` VARCHAR(64),
  `my_class_id` INT,
  `exam_id` INT,
  `year` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `code` VARCHAR(64),
  `username` VARCHAR(64),
  `user_type` VARCHAR(64),
  `dob` VARCHAR(64),
  `gender` VARCHAR(64),
  `photo` VARCHAR(64),
  `phone` VARCHAR(64),
  `phone2` VARCHAR(64),
  `bg_id` INT,
  `state_id` INT,
  `lga_id` INT,
  `nal_id` INT,
  `address` VARCHAR(64),
