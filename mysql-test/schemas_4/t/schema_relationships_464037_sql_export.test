  `section_id` INT,
  `total` INT,
  `ave` VARCHAR(64),
  `class_ave` VARCHAR(64),
  `pos` INT,
  `af` VARCHAR(64),
  `ps` VARCHAR(64),
  `p_comment` VARCHAR(64),
  `t_comment` VARCHAR(64),
  `year` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `grades` (
  `id` INT,
  `name` VARCHAR(64),
  `class_type_id` INT,
