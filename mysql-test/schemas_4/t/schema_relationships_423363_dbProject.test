INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 423363_dbProject
--echo #
CREATE DATABASE `db_423363_dbProject`;
USE `db_423363_dbProject`;

CREATE TABLE `Artist` (
  `Artist_id` INT,
  `Artist_name` VARCHAR(64),
  `contact_number` INT,
  PRIMARY KEY (`Artist_id`)
) CHARACTER SET latin1;

CREATE TABLE `Art` (
  `Art_id` INT,
  `Artist_id` INT,
  `Art_name` VARCHAR(64),
  PRIMARY KEY (`Art_id`)
) CHARACTER SET latin1;

CREATE TABLE `Gallery` (
  `Gallery_id` INT,
  `Gallery_name` VARCHAR(64),
  `Location` VARCHAR(64),
  PRIMARY KEY (`Gallery_id`)
) CHARACTER SET latin1;

CREATE TABLE `Art_Gallery` (
  `Art_Gallery_id` INT,
  `Art_id` INT,
  `Gallery_id` INT,
  `Date` DATETIME,
  PRIMARY KEY (`Art_Gallery_id`)
) CHARACTER SET latin1;

CREATE TABLE `Employee` (
  `Employee_id` INT,
  `Employee_name` VARCHAR(64),
  `contact_number` INT,
  PRIMARY KEY (`Employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `Customer_id` INT,
  `Customer_name` VARCHAR(64),
  `Contact_number` INT,
  PRIMARY KEY (`Customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `Order_id` INT,
  `Art_id` INT,
  `Customer_id` INT,
  `Employee_id` INT,
  `Price` DECIMAL(10,2),
  PRIMARY KEY (`Order_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_423363_dbProject') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_423363_dbProject') AS relationships;
DROP DATABASE `db_423363_dbProject`;
UNINSTALL EXTENSION vsql_schematron;
