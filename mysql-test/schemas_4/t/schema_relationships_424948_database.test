INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 424948_database
--echo #
CREATE DATABASE `db_424948_database`;
USE `db_424948_database`;

CREATE TABLE `Server` (
  `ServerID` VARCHAR(255),
  `ServerName` VARCHAR(255),
  `MemberCount` INT,
  `ServerPrefix` VARCHAR(255),
  `ServerLastUpdated` VARCHAR(255),
  PRIMARY KEY (`ServerID`)
) CHARACTER SET latin1;

CREATE TABLE `ServerRoles` (
  `RoleID` VARCHAR(255),
  `ServerID` VARCHAR(255),
  `Online` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `DiscordUser` (
  `UserID` VARCHAR(255),
  `UserName` VARCHAR(255),
  `UserDiscriminator` VARCHAR(255),
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;

CREATE TABLE `ServerDiscordUser` (
  `ServerDiscordUserID` INT,
  `DCUserID` VARCHAR(255),
  `DCServerID` VARCHAR(255),
  PRIMARY KEY (`ServerDiscordUserID`)
) CHARACTER SET latin1;

CREATE TABLE `ServerPluginSystem` (
  `ServerPluginSystem` INT,
  `Online` VARCHAR(255),
  `DCServerID` VARCHAR(255),
  PRIMARY KEY (`ServerPluginSystem`)
) CHARACTER SET latin1;

CREATE TABLE `ServerWelcomeSystem` (
  `ServerWelcomeSystemID` INT,
  `Online` VARCHAR(255),
  `DCServerID` VARCHAR(255),
  `WTCID` VARCHAR(255),
  PRIMARY KEY (`ServerWelcomeSystemID`)
) CHARACTER SET latin1;

CREATE TABLE `ServerSuggestionSystem` (
  `ServerSuggestionSystemID` INT,
  `Online` VARCHAR(255),
  `DCServerID` VARCHAR(255),
  `ITCID` VARCHAR(255),
  `PTCID` VARCHAR(255),
  PRIMARY KEY (`ServerSuggestionSystemID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_424948_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_424948_database') AS relationships;
DROP DATABASE `db_424948_database`;
UNINSTALL EXTENSION vsql_schematron;
