INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470088_database
--echo #
CREATE DATABASE `db_470088_database`;
USE `db_470088_database`;
CREATE TABLE `authors` (
  `id` BIGINT NOT NULL,
  `news_id` BIGINT,
  `author_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` BIGINT NOT NULL,
  `news_id` BIGINT,
  `category_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` BIGINT NOT NULL,
  `news_id` BIGINT,
  `author` VARCHAR(50),
  `content` TEXT,
  `datetime` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
  `id` BIGINT NOT NULL,
  `news_id` BIGINT,
  `image_url` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `id` BIGINT NOT NULL,
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `datetime` VARCHAR(50),
  `content_type` VARCHAR(50),
  `regional` VARCHAR(50),
  `text` TEXT,
  `scraped_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` BIGINT NOT NULL,
  `news_id` BIGINT,
  `tag_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470088_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470088_database') AS relationships;
DROP DATABASE `db_470088_database`;
UNINSTALL EXTENSION vsql_schematron;
