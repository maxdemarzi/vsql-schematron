INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447350_beta.16-sql-update
--echo #
CREATE DATABASE `db_447350_beta_16_sql_update`;
USE `db_447350_beta_16_sql_update`;

CREATE TABLE `skills_groups` (
  `id` INT,
  `key` VARCHAR(64),
  `label` VARCHAR(64),
  `description` VARCHAR(64),
  `sort` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `skills_skill_group_relation` (
  `id` INT,
  `skill_id` INT,
  `group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447350_beta_16_sql_update') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447350_beta_16_sql_update') AS relationships;
DROP DATABASE `db_447350_beta_16_sql_update`;
UNINSTALL EXTENSION vsql_schematron;
