INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449864_create
--echo #
CREATE DATABASE `db_449864_create`;
USE `db_449864_create`;

CREATE TABLE `poll` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `owner_id` VARCHAR(255),
  `expires` DATETIME,
  `close` DATETIME,
  `write_ins` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `candidate` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `poll_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ballot` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `timestamp` DATETIME,
  `owner_id` VARCHAR(255),
  `poll_id` VARCHAR(255),
  PRIMARY KEY (`id`, `poll_id`)
) CHARACTER SET latin1;

CREATE TABLE `ranking` (
  `ballot_id` VARCHAR(255),
  `poll_id` VARCHAR(255),
  `candidate_id` INT,
  `ranking` INT,
  PRIMARY KEY (`ballot_id`, `poll_id`, `candidate_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449864_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449864_create') AS relationships;
DROP DATABASE `db_449864_create`;
UNINSTALL EXTENSION vsql_schematron;
