INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 437932_migration
--echo #
CREATE DATABASE `db_437932_migration`;
USE `db_437932_migration`;

CREATE TABLE `ClientUser` (
  `id` INT,
  `username` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `AccessToken` (
  `id` INT,
  `client_user_id` INT,
  `active` BOOL,
  `valid_until` DATETIME,
  `access_token` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Guild` (
  `id` INT,
  `name` VARCHAR(64),
  `is_joined` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `GuildSettings` (
  `id` INT,
  `prefix` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_GuildToUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_437932_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_437932_migration') AS relationships;
DROP DATABASE `db_437932_migration`;
UNINSTALL EXTENSION vsql_schematron;
