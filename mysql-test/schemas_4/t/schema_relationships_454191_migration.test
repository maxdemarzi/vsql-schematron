INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 454191_migration
--echo #
CREATE DATABASE `db_454191_migration`;
USE `db_454191_migration`;

CREATE TABLE `Rider` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `nationality` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tour` (
  `id` INT,
  `year` INT,
  `gcWinnerId` INT,
  `komWinnerId` INT,
  `pointsWinnerId` INT,
  `intSprintWinnerId` INT,
  `youngRiderWinnerId` INT,
  `combinationWinnerId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_454191_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_454191_migration') AS relationships;
DROP DATABASE `db_454191_migration`;
UNINSTALL EXTENSION vsql_schematron;
