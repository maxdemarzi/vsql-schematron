INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 484239_create_table
--echo #
CREATE DATABASE `db_484239_create_table`;
USE `db_484239_create_table`;

CREATE TABLE `movies` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `year` INT,
  `director` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stars` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `birthYear` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stars_in_movies` (
  `starId` VARCHAR(64),
  `movieId` VARCHAR(64),
  PRIMARY KEY (`starId`, `movieId`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres_in_movies` (
  `genreId` INT,
  `movieId` VARCHAR(64),
  PRIMARY KEY (`genreId`, `movieId`)
) CHARACTER SET latin1;

CREATE TABLE `creditcards` (
  `id` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `expiration` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `ccId` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `customerId` INT,
  `movieId` VARCHAR(64),
  `saleDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ratings` (
  `movieId` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `numVotes` INT,
  PRIMARY KEY (`movieId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_484239_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_484239_create_table') AS relationships;
DROP DATABASE `db_484239_create_table`;
UNINSTALL EXTENSION vsql_schematron;
