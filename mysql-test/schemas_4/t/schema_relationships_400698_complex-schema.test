INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400698_complex-schema
--echo #
CREATE DATABASE `db_400698_complex_schema`;
USE `db_400698_complex_schema`;
CREATE TABLE `session_ids` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `command_names` (
  `id` INT NOT NULL,
  `command` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
  `id` INT NOT NULL,
  `ppid` INT,
  `status_code` INT,
  `history_id` INT,
  `session_id` INT,
  `server_id` TEXT,
  `username` TEXT,
  `created_at` TIMESTAMP NULL,
  `command_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400698_complex_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400698_complex_schema') AS relationships;
DROP DATABASE `db_400698_complex_schema`;
UNINSTALL EXTENSION vsql_schematron;
