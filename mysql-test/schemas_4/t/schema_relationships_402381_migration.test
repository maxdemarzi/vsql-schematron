INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402381_migration
--echo #
CREATE DATABASE `db_402381_migration`;
USE `db_402381_migration`;

CREATE TABLE `Project` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `companyId` VARCHAR(64),
  `code` VARCHAR(64),
  `taxation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Company` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `logoUrl` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `weeklyBasis` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `companyId` VARCHAR(64),
  `jobId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Job` (
  `id` VARCHAR(64),
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Record` (
  `id` VARCHAR(64),
  `userId` VARCHAR(64),
  `projectId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `date` DATETIME,
  `timeslot` DATETIME,
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ProjectToUser` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402381_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402381_migration') AS relationships;
DROP DATABASE `db_402381_migration`;
UNINSTALL EXTENSION vsql_schematron;
