INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449941_000001_initial.up
--echo #
CREATE DATABASE `db_449941_000001_initial_up`;
USE `db_449941_000001_initial_up`;

CREATE TABLE `users` (
  `id` INT,
  `phone_number` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `channels` (
  `id` INT,
  `creator_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `channel_members` (
  `channel_id` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`channel_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `channel_permissions` (
  `channel_id` INT,
  `user_id` INT,
  `permission` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`channel_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `origin_id` INT,
  `dst_id` INT,
  `parent_id` INT,
  `body` VARCHAR(64),
  `state` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449941_000001_initial_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449941_000001_initial_up') AS relationships;
DROP DATABASE `db_449941_000001_initial_up`;
UNINSTALL EXTENSION vsql_schematron;
