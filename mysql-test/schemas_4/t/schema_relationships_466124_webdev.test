INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 466124_webdev
--echo #
CREATE DATABASE `db_466124_webdev`;
USE `db_466124_webdev`;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `id` INT,
  `user_id` INT,
  `post_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `title` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_466124_webdev') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_466124_webdev') AS relationships;
DROP DATABASE `db_466124_webdev`;
UNINSTALL EXTENSION vsql_schematron;
