INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428397_schema
--echo #
CREATE DATABASE `db_428397_schema`;
USE `db_428397_schema`;
CREATE TABLE `Dati_utente` (
  `Utente_id` INT NOT NULL,
  `Nome` TEXT,
  `Email` TEXT,
  `Password` TEXT,
  `Conferma` INT,
  `Confermato_il` TEXT,
  PRIMARY KEY (`Utente_id`)
) CHARACTER SET latin1;
CREATE TABLE `Artista` (
  `Artista_id` INT NOT NULL,
  `artista` TEXT,
  PRIMARY KEY (`Artista_id`)
) CHARACTER SET latin1;
CREATE TABLE `Album` (
  `Album_id` INT NOT NULL,
  `Artista_id` INT,
  `album` TEXT,
  PRIMARY KEY (`Album_id`)
) CHARACTER SET latin1;
CREATE TABLE `Genere` (
  `Genere_id` INT NOT NULL,
  `genere` TEXT,
  PRIMARY KEY (`Genere_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428397_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428397_schema') AS relationships;
DROP DATABASE `db_428397_schema`;
UNINSTALL EXTENSION vsql_schematron;
