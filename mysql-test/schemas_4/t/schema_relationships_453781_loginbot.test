INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 453781_loginbot
--echo #
CREATE DATABASE `db_453781_loginbot`;
USE `db_453781_loginbot`;
CREATE TABLE `admin` (
  `idadmin` INT,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `idlevel` INT
) CHARACTER SET latin1;
CREATE TABLE `level_akses` (
  `idlevel` INT NOT NULL,
  `levelname` VARCHAR(50),
  PRIMARY KEY (`idlevel`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_453781_loginbot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_453781_loginbot') AS relationships;
DROP DATABASE `db_453781_loginbot`;
UNINSTALL EXTENSION vsql_schematron;
