INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 431613_V1__Create_candles
--echo #
CREATE DATABASE `db_431613_V1_Create_candles`;
USE `db_431613_V1_Create_candles`;

CREATE TABLE `timeframes` (
  `id` INT,
  `unit` VARCHAR(64),
  `value` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exchanges` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `coins` (
  `id` INT,
  `symbol` VARCHAR(64),
  `name` VARCHAR(64),
  `decimals` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pairs` (
  `id` INT,
  `base_id` INT,
  `quote_id` INT,
  `exchange_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `candles` (
  `id` INT,
  `date` DATETIME,
  `timeframe_id` INT,
  `pair_id` INT,
  `low` INT,
  `high` INT,
  `open` INT,
  `close` INT,
  `volume` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_431613_V1_Create_candles') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_431613_V1_Create_candles') AS relationships;
DROP DATABASE `db_431613_V1_Create_candles`;
UNINSTALL EXTENSION vsql_schematron;
