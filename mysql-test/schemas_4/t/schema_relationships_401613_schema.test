INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 401613_schema
--echo #
CREATE DATABASE `db_401613_schema`;
USE `db_401613_schema`;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `datebirth` DATE,
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `district` VARCHAR(50),
  `zipcode` VARCHAR(50),
  `celphone` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  `quantity` INT,
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `datebuy` DATE,
  `idcustomer` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `itensorders` (
  `id` INT NOT NULL,
  `idorder` INT,
  `idproduct` INT,
  `quantity` INT,
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_401613_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_401613_schema') AS relationships;
DROP DATABASE `db_401613_schema`;
UNINSTALL EXTENSION vsql_schematron;
