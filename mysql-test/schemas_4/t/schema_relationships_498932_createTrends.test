INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498932_createTrends
--echo #
CREATE DATABASE `db_498932_createTrends`;
USE `db_498932_createTrends`;

CREATE TABLE `Downloaded` (
  `id` INT,
  `device_name` VARCHAR(64),
  `wurfl_id` VARCHAR(64),
  `marketing_name` VARCHAR(64),
  `brand_name` VARCHAR(64),
  `model_name` VARCHAR(64),
  `real_height` DECIMAL(10,2),
  `real_width` DECIMAL(10,2),
  `reso_height` INT,
  `reso_width` INT,
  `who` VARCHAR(64),
  `when_started` DATETIME,
  `region` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Devices` (
  `id` INT,
  `device_name` VARCHAR(64),
  `wurfl_id` VARCHAR(64),
  `marketing_name` VARCHAR(64),
  `brand_name` VARCHAR(64),
  `model_name` VARCHAR(64),
  `real_height` DECIMAL(10,2),
  `real_width` DECIMAL(10,2),
  `real_size` DECIMAL(10,2),
  `reso_height` INT,
  `reso_width` INT,
  `reso_size` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Trends` (
  `id` INT,
  `device_name` VARCHAR(64),
  `region` VARCHAR(64),
  `month` INT,
  `year` INT,
  `value` DECIMAL(10,2),
  `error_margin` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498932_createTrends') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498932_createTrends') AS relationships;
DROP DATABASE `db_498932_createTrends`;
UNINSTALL EXTENSION vsql_schematron;
