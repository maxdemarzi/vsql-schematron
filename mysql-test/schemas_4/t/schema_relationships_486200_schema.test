INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 486200_schema
--echo #
CREATE DATABASE `db_486200_schema`;
USE `db_486200_schema`;

CREATE TABLE `employee` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `job_id` INT,
  `leader_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `subtitle` VARCHAR(255),
  `rate` DECIMAL(10,2),
  `branch_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_486200_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_486200_schema') AS relationships;
DROP DATABASE `db_486200_schema`;
UNINSTALL EXTENSION vsql_schematron;
