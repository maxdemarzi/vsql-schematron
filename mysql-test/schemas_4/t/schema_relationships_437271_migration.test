INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 437271_migration
--echo #
CREATE DATABASE `db_437271_migration`;
USE `db_437271_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(255),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Profile` (
  `id` VARCHAR(255),
  `bio` VARCHAR(255),
  `userId` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SupportSettings` (
  `id` VARCHAR(255),
  `userName` VARCHAR(255),
  `chat` VARCHAR(255),
  `createAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_437271_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_437271_migration') AS relationships;
DROP DATABASE `db_437271_migration`;
UNINSTALL EXTENSION vsql_schematron;
