INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 433281_schema
--echo #
CREATE DATABASE `db_433281_schema`;
USE `db_433281_schema`;
CREATE TABLE `podcast` (
  `id` INT NOT NULL,
  `src` TEXT,
  `url` TEXT,
  `title` TEXT,
  `image` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `episode` (
  `id` INT NOT NULL,
  `guid` TEXT,
  `title` TEXT,
  `src` TEXT,
  `progress` INT,
  `duration` INT,
  `publication` INT,
  `image` TEXT,
  `position` INT,
  `notes` TEXT,
  `podcast` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `name` VARCHAR(50) NOT NULL,
  `password` TEXT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_433281_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_433281_schema') AS relationships;
DROP DATABASE `db_433281_schema`;
UNINSTALL EXTENSION vsql_schematron;
