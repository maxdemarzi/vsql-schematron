INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458932_localhost
--echo #
CREATE DATABASE `db_458932_localhost`;
USE `db_458932_localhost`;

CREATE TABLE `kelas` (
  `id_kelas` INT,
  `kelas` INT,
  `wali_kelas` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `login` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `version` VARCHAR(64),
  `class` VARCHAR(64),
  `group` VARCHAR(64),
  `namespace` VARCHAR(64),
  `time` INT,
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `siswa` (
  `id` INT,
  `nama` VARCHAR(64),
  `nisn` INT,
  `umur` INT,
  `kelas` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458932_localhost') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458932_localhost') AS relationships;
DROP DATABASE `db_458932_localhost`;
UNINSTALL EXTENSION vsql_schematron;
