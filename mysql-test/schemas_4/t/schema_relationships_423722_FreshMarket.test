INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 423722_FreshMarket
--echo #
CREATE DATABASE `db_423722_FreshMarket`;
USE `db_423722_FreshMarket`;
CREATE TABLE `orders` (
  `ordersID` VARCHAR(50) NOT NULL,
  `ordertime` DATETIME,
  `total` DECIMAL(10,2),
  `state` SMALLINT,
  `userID` INT,
  `address` VARCHAR(50),
  PRIMARY KEY (`ordersID`)
) CHARACTER SET latin1;
CREATE TABLE `orderitem` (
  `orderitemID` VARCHAR(50) NOT NULL,
  `count` INT,
  `subtotal` DECIMAL(10,2),
  `ordersID` CHAR(50),
  `commodityID` INT,
  PRIMARY KEY (`orderitemID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_423722_FreshMarket') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_423722_FreshMarket') AS relationships;
DROP DATABASE `db_423722_FreshMarket`;
UNINSTALL EXTENSION vsql_schematron;
