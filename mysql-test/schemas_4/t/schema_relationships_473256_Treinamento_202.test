INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473256_Treinamento%202
--echo #
CREATE DATABASE `db_473256_Treinamento_202`;
USE `db_473256_Treinamento_202`;

CREATE TABLE `disciplina` (
  `CodDisc` INT,
  `NomeD` VARCHAR(64),
  `Carga_H` INT,
  PRIMARY KEY (`CodDisc`)
) CHARACTER SET latin1;

CREATE TABLE `Prof` (
  `CodProf` INT,
  `NomeP` VARCHAR(64),
  `Cargo` VARCHAR(64),
  `Salario` DECIMAL(10,2),
  PRIMARY KEY (`CodProf`)
) CHARACTER SET latin1;

CREATE TABLE `Depto` (
  `CodDepto` INT,
  `NomeDepto` VARCHAR(64),
  PRIMARY KEY (`CodDepto`)
) CHARACTER SET latin1;

CREATE TABLE `Aluno` (
  `Mat` INT,
  `NomeA` VARCHAR(64),
  `Curso` VARCHAR(64),
  `Turma` VARCHAR(64),
  `CodDepto` INT,
  `Data_Nasc` DATETIME,
  PRIMARY KEY (`Mat`)
) CHARACTER SET latin1;

CREATE TABLE `Prof_Disc` (
  `CodProf` INT,
  `CodDisc` INT,
  `CodDepto` INT,
  PRIMARY KEY (`CodProf`, `CodDisc`)
) CHARACTER SET latin1;

CREATE TABLE `Aluno_Paga` (
  `Mat` INT,
  `CodDisc` INT,
  `CodProf` INT,
  `Data` DATETIME,
  PRIMARY KEY (`Mat`, `CodDisc`, `CodProf`, `Data`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473256_Treinamento_202') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473256_Treinamento_202') AS relationships;
DROP DATABASE `db_473256_Treinamento_202`;
UNINSTALL EXTENSION vsql_schematron;
