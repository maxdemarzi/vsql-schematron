INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455768_schema
--echo #
CREATE DATABASE `db_455768_schema`;
USE `db_455768_schema`;

CREATE TABLE `INGREDIENT` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `TYPE` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `TACO` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `CREATED_AT` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `TACO_INGREDIENTS` (
  `TACO_ID` VARCHAR(64),
  `INGREDIENT_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `TACO_ORDER` (
  `ID` INT,
  `RECIPIENT_NAME` VARCHAR(64),
  `RECIPIENT_STREET` VARCHAR(64),
  `RECIPIENT_CITY` VARCHAR(64),
  `RECIPIENT_STATE` VARCHAR(64),
  `RECIPIENT_ZIP` VARCHAR(64),
  `CREDIT_CARD_NUMBER` VARCHAR(64),
  `CREDIT_CARD_EXPIRATION_DATE` VARCHAR(64),
  `CREDIT_CARD_VALIDATION_VALUE` VARCHAR(64),
  `PLACED_AT` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `TACO_ORDER_TACOS` (
  `ORDER_ID` INT,
  `TACO_ID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455768_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455768_schema') AS relationships;
DROP DATABASE `db_455768_schema`;
UNINSTALL EXTENSION vsql_schematron;
