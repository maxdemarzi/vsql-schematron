INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 416057_website_ci
--echo #
CREATE DATABASE `db_416057_website_ci`;
USE `db_416057_website_ci`;

CREATE TABLE `agenda` (
  `agenda_id` INT,
  `agenda_nama` VARCHAR(255),
  `agenda_tanggal` DATETIME,
  `agenda_deskripsi` VARCHAR(255),
  `agenda_mulai` DATETIME,
  `agenda_selesai` DATETIME,
  `agenda_tempat` VARCHAR(255),
  `agenda_waktu` VARCHAR(255),
  `agenda_author` VARCHAR(255),
  PRIMARY KEY (`agenda_id`)
) CHARACTER SET latin1;

CREATE TABLE `album` (
  `album_id` INT,
  `album_nama` VARCHAR(255),
  `album_slug` VARCHAR(255),
  `album_tanggal` DATETIME,
  PRIMARY KEY (`album_id`)
) CHARACTER SET latin1;

CREATE TABLE `artikel` (
  `artikel_id` INT,
  `artikel_tanggal` DATETIME,
  `artikel_judul` VARCHAR(255),
  `artikel_slug` VARCHAR(255),
  `artikel_konten` VARCHAR(255),
  `artikel_sampul` VARCHAR(255),
  `artikel_author` INT,
  `artikel_kategori` INT,
  `artikel_status` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `galeri` (
  `galeri_id` INT,
  `galeri_judul` VARCHAR(255),
  `galeri_tanggal` DATETIME,
  `galeri_gambar` VARCHAR(255),
  `galeri_album_id` INT,
  `galeri_author` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `jabatan` (
  `jabatan_id` INT,
  `jabatan_nama` VARCHAR(255),
  PRIMARY KEY (`jabatan_id`)
) CHARACTER SET latin1;

CREATE TABLE `jurusan` (
  `jurusan_id` INT,
  `jurusan_nama` VARCHAR(255),
  PRIMARY KEY (`jurusan_id`)
) CHARACTER SET latin1;

CREATE TABLE `kategori` (
  `kategori_id` INT,
  `kategori_nama` VARCHAR(255),
  `kategori_slug` VARCHAR(255),
  PRIMARY KEY (`kategori_id`)
) CHARACTER SET latin1;

CREATE TABLE `kelas` (
  `kelas_id` INT,
  `kelas_nama` VARCHAR(255),
  PRIMARY KEY (`kelas_id`)
) CHARACTER SET latin1;

CREATE TABLE `pengaturan` (
  `nama` VARCHAR(255),
  `deskripsi` VARCHAR(255),
  `logo` VARCHAR(255),
  `link_facebook` VARCHAR(255),
  `link_twitter` VARCHAR(255),
  `link_instagram` VARCHAR(255),
  `link_whatsapp` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `pengguna` (
  `pengguna_id` INT,
  `pengguna_nama` VARCHAR(255),
  `pengguna_email` VARCHAR(255),
  `pengguna_username` VARCHAR(255),
  `pengguna_password` VARCHAR(255),
  `pengguna_level` VARCHAR(255),
  `pengguna_status` INT,
  PRIMARY KEY (`pengguna_id`)
) CHARACTER SET latin1;

CREATE TABLE `pengumuman` (
  `pengumuman_id` INT,
  `pengumuman_judul` VARCHAR(255),
  `pengumuman_deskripsi` VARCHAR(255),
  `pengumuman_tanggal` DATETIME,
  `tanggal_mulai` DATETIME,
  `tanggal_selesai` DATETIME,
  `pengumuman_author` VARCHAR(255),
  PRIMARY KEY (`pengumuman_id`)
) CHARACTER SET latin1;

CREATE TABLE `siswa` (
  `siswa_id` INT,
  `siswa_nis` VARCHAR(255),
  `siswa_nama` VARCHAR(255),
  `siswa_jenis_kelamin` VARCHAR(255),
  `siswa_jabatan_id` INT,
  `siswa_kelas_id` INT,
  `siswa_jurusan_id` INT,
  `status` VARCHAR(255),
  `siswa_photo` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_416057_website_ci') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_416057_website_ci') AS relationships;
DROP DATABASE `db_416057_website_ci`;
UNINSTALL EXTENSION vsql_schematron;
