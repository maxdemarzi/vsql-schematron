INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411070_Bank_Schema
--echo #
CREATE DATABASE `db_411070_Bank_Schema`;
USE `db_411070_Bank_Schema`;

CREATE TABLE `Bank` (
  `Bank_Code` INT,
  `Bank_Name` VARCHAR(255),
  `Bank_Address` VARCHAR(255),
  PRIMARY KEY (`Bank_Code`)
) CHARACTER SET latin1;

CREATE TABLE `Client` (
  `Client_ID` INT,
  `Client_Name` VARCHAR(255),
  `Client_Phone` INT,
  `Client_Address` VARCHAR(255),
  PRIMARY KEY (`Client_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Account` (
  `Account_Number` INT,
  `Account_Type` VARCHAR(255),
  `Account_Deposit` INT,
  PRIMARY KEY (`Account_Number`)
) CHARACTER SET latin1;

CREATE TABLE `Branch` (
  `Branch_ID` INT,
  `Branch_Address` VARCHAR(255),
  PRIMARY KEY (`Branch_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Loan` (
  `Loan_ID` INT,
  `Loan_Type` VARCHAR(255),
  `Loan_Credit` INT,
  PRIMARY KEY (`Loan_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Has_Branch` (
  `Bank_Code` INT,
  `Branch_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `Has_Account` (
  `Account_Number` INT,
  `Client_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `Manages_Account` (
  `Branch_ID` INT,
  `Account_Number` INT
) CHARACTER SET latin1;

CREATE TABLE `Has_Loan` (
  `Client_ID` INT,
  `Loan_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `Manages_Loan` (
  `Branch_ID` INT,
  `Loan_ID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411070_Bank_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411070_Bank_Schema') AS relationships;
DROP DATABASE `db_411070_Bank_Schema`;
UNINSTALL EXTENSION vsql_schematron;
