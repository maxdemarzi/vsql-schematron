INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470695_up
--echo #
CREATE DATABASE `db_470695_up`;
USE `db_470695_up`;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `post_id` INT,
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `followings` (
  `user_id` INT,
  `post_id` INT,
  `email_notifications` VARCHAR(64),
  PRIMARY KEY (`user_id`, `post_id`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `comment_id` INT,
  `user_id` INT,
  PRIMARY KEY (`comment_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470695_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470695_up') AS relationships;
DROP DATABASE `db_470695_up`;
UNINSTALL EXTENSION vsql_schematron;
