INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497285_os-helpdesk_postgres_create
--echo #
CREATE DATABASE `db_497285_os_helpdesk_postgres_create`;
USE `db_497285_os_helpdesk_postgres_create`;
CREATE TABLE `UserTable` (
  `UserID` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `cohortID` INT,
  `usertypeID` INT,
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `TicketTable` (
  `TicketID` INT NOT NULL,
  `UserID` INT,
  `CategoryID` INT,
  `ProblemStatement` TEXT,
  `ExpectedBehavior` TEXT,
  `TriedSolution` TEXT,
  `SuspectedIssue` TEXT,
  `ZoomLink` TEXT,
  `status` TEXT,
  `response` TEXT,
  `responderID` INT,
  `created_at` TIMESTAMP NULL,
  `resolved_at` TIMESTAMP NULL,
  `image_links` TEXT,
  PRIMARY KEY (`TicketID`)
) CHARACTER SET latin1;
CREATE TABLE `Categories` (
  `CategoryID` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`CategoryID`)
) CHARACTER SET latin1;
CREATE TABLE `UserType` (
  `UserTypeID` INT NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`UserTypeID`)
) CHARACTER SET latin1;
CREATE TABLE `CohortTable` (
  `CohortID` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`CohortID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497285_os_helpdesk_postgres_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497285_os_helpdesk_postgres_create') AS relationships;
DROP DATABASE `db_497285_os_helpdesk_postgres_create`;
UNINSTALL EXTENSION vsql_schematron;
