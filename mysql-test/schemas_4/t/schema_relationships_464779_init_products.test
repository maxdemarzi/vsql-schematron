INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464779_init_products
--echo #
CREATE DATABASE `db_464779_init_products`;
USE `db_464779_init_products`;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `slogan` VARCHAR(64),
  `description` VARCHAR(64),
  `category` VARCHAR(64),
  `default_price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `features` (
  `id` INT,
  `product_id` INT,
  `feature` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `styles` (
  `style_id` INT,
  `product_id` INT,
  `name` VARCHAR(64),
  `sale_price` VARCHAR(64),
  `original_price` VARCHAR(64),
  `default_style` VARCHAR(64),
  PRIMARY KEY (`style_id`)
) CHARACTER SET latin1;

CREATE TABLE `skus` (
  `id` INT,
  `styleId` INT,
  `size` VARCHAR(64),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `photos` (
  `id` INT,
  `styleId` INT,
  `url` VARCHAR(64),
  `thumbnail_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `related` (
  `id` INT,
  `current_product_id` INT,
  `related_product_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464779_init_products') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464779_init_products') AS relationships;
DROP DATABASE `db_464779_init_products`;
UNINSTALL EXTENSION vsql_schematron;
