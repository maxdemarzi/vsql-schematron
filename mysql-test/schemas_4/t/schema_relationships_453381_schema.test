INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 453381_schema
--echo #
CREATE DATABASE `db_453381_schema`;
USE `db_453381_schema`;

CREATE TABLE `node` (
  `node_id` INT,
  `properties` VARCHAR(64),
  PRIMARY KEY (`node_id`)
) CHARACTER SET latin1;

CREATE TABLE `edge` (
  `edge_id` INT,
  `source_id` INT,
  `target_id` INT,
  `properties` VARCHAR(64),
  PRIMARY KEY (`edge_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_453381_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_453381_schema') AS relationships;
DROP DATABASE `db_453381_schema`;
UNINSTALL EXTENSION vsql_schematron;
