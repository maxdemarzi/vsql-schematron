INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 441925_schema
--echo #
CREATE DATABASE `db_441925_schema`;
USE `db_441925_schema`;
CREATE TABLE `currency` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `abbr` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bank_account` (
  `id` INT,
  `owner_name` VARCHAR(50),
  `balance` DECIMAL(10,2),
  `blocked_amount` DECIMAL(10,2),
  `currency_id` INT
) CHARACTER SET latin1;
CREATE TABLE `transaction_status` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
  `id` INT,
  `from_account_id` BIGINT,
  `to_account_id` BIGINT,
  `amount` DECIMAL(10,2),
  `currency_id` INT,
  `creation_date` TIMESTAMP NULL,
  `update_date` TIMESTAMP NULL,
  `status_id` INT,
  `failMessage` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_441925_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_441925_schema') AS relationships;
DROP DATABASE `db_441925_schema`;
UNINSTALL EXTENSION vsql_schematron;
