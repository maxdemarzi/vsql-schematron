INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426223_bank_schema
--echo #
CREATE DATABASE `db_426223_bank_schema`;
USE `db_426223_bank_schema`;

CREATE TABLE `customer` (
  `customer_name` VARCHAR(64),
  `customer_street` VARCHAR(64),
  `customer_city` VARCHAR(64),
  PRIMARY KEY (`customer_name`)
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `branch_name` VARCHAR(64),
  `branch_city` VARCHAR(64),
  `assets` DECIMAL(10,2),
  PRIMARY KEY (`branch_name`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `account_number` VARCHAR(64),
  `branch_name` VARCHAR(64),
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`account_number`)
) CHARACTER SET latin1;

CREATE TABLE `depositor` (
  `customer_name` VARCHAR(64),
  `account_number` VARCHAR(64),
  PRIMARY KEY (`customer_name`, `account_number`)
) CHARACTER SET latin1;

CREATE TABLE `loan` (
  `loan_number` VARCHAR(64),
  `branch_name` VARCHAR(64),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`loan_number`)
) CHARACTER SET latin1;

CREATE TABLE `borrower` (
  `customer_name` VARCHAR(64),
  `loan_number` VARCHAR(64),
  PRIMARY KEY (`customer_name`, `loan_number`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426223_bank_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426223_bank_schema') AS relationships;
DROP DATABASE `db_426223_bank_schema`;
UNINSTALL EXTENSION vsql_schematron;
