INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 419037_schema
--echo #
CREATE DATABASE `db_419037_schema`;
USE `db_419037_schema`;
CREATE TABLE `public.users` (
  `id` INT NOT NULL,
  `uname` VARCHAR(50),
  `bday` TIMESTAMP NULL,
  `age` INT,
  `country` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.users_follows` (
  `user_id_1` INT NOT NULL,
  `user_id_2` INT NOT NULL,
  PRIMARY KEY (`user_id_1`, `user_id_2`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_419037_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_419037_schema') AS relationships;
DROP DATABASE `db_419037_schema`;
UNINSTALL EXTENSION vsql_schematron;
