INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 404245_V0.2.0_01__article_table
--echo #
CREATE DATABASE `db_404245_V0_2_0_01__article_table`;
USE `db_404245_V0_2_0_01__article_table`;
CREATE TABLE `article` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entity` (
  `entity_value` VARCHAR(50) NOT NULL,
  `entity_value_raw` VARCHAR(50),
  `entity_type` VARCHAR(50),
  PRIMARY KEY (`entity_value`)
) CHARACTER SET latin1;
CREATE TABLE `entity_score` (
  `id` VARCHAR(50),
  `entity_value` VARCHAR(50),
  `average_score` INT,
  `number_of_mentions` INT,
  `weight` INT,
  `article_id` VARCHAR(50),
  `document_score_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_404245_V0_2_0_01__article_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_404245_V0_2_0_01__article_table') AS relationships;
DROP DATABASE `db_404245_V0_2_0_01__article_table`;
UNINSTALL EXTENSION vsql_schematron;
