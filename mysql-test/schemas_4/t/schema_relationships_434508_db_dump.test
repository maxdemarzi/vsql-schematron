INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434508_db_dump
--echo #
CREATE DATABASE `db_434508_db_dump`;
USE `db_434508_db_dump`;

CREATE TABLE `Chill` (
  `version` INT
) CHARACTER SET latin1;

CREATE TABLE `Query` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Template` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Node` (
  `id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `template` INT,
  `query` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Node_Node` (
  `node_id` INT,
  `target_node_id` INT
) CHARACTER SET latin1;

CREATE TABLE `Route` (
  `id` INT,
  `path` VARCHAR(64),
  `node_id` INT,
  `weight` INT,
  `method` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434508_db_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434508_db_dump') AS relationships;
DROP DATABASE `db_434508_db_dump`;
UNINSTALL EXTENSION vsql_schematron;
