INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 432506_Pratica2
--echo #
CREATE DATABASE `db_432506_Pratica2`;
USE `db_432506_Pratica2`;
CREATE TABLE `ENDERECO` (
  `END_COD` DECIMAL(10,2) NOT NULL,
  `END_ENDERECO` VARCHAR(50),
  PRIMARY KEY (`END_COD`)
) CHARACTER SET latin1;
CREATE TABLE `ENDERECO_FUNCIONARIO` (
  `ENF_COD_FUNC` DECIMAL(10,2) NOT NULL,
  `ENF_COD_END` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`ENF_COD_FUNC`, `ENF_COD_END`)
) CHARACTER SET latin1;
CREATE TABLE `PARENTESCO` (
  `PAR_COD` DECIMAL(10,2) NOT NULL,
  `PAR_DESCR` VARCHAR(50),
  PRIMARY KEY (`PAR_COD`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_432506_Pratica2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_432506_Pratica2') AS relationships;
DROP DATABASE `db_432506_Pratica2`;
UNINSTALL EXTENSION vsql_schematron;
