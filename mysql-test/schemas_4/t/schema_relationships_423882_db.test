INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 423882_db
--echo #
CREATE DATABASE `db_423882_db`;
USE `db_423882_db`;

CREATE TABLE `public.aoi` (
  `id` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `public.scene` (
  `id` INT,
  `aoi_id` VARCHAR(64),
  `status` VARCHAR(64),
  `message` VARCHAR(64),
  `source_id` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.tile` (
  `id` INT,
  `scene_id` INT,
  `status` VARCHAR(64),
  `message` VARCHAR(64),
  `prev` INT,
  `ref` INT,
  `source_id` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_423882_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_423882_db') AS relationships;
DROP DATABASE `db_423882_db`;
UNINSTALL EXTENSION vsql_schematron;
