INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473610_schema
--echo #
CREATE DATABASE `db_473610_schema`;
USE `db_473610_schema`;
CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(50) NOT NULL,
  `ProductVersion` CHAR(50),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `file_size` INT,
  `file_type` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `claims` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `document_id` VARCHAR(50),
  `service_area_created_by` TEXT,
  `user_created_by` TEXT,
  `api_created_by` TEXT,
  `retention_expires_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473610_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473610_schema') AS relationships;
DROP DATABASE `db_473610_schema`;
UNINSTALL EXTENSION vsql_schematron;
