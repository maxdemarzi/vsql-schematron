INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472570_test.schema.ddl
--echo #
CREATE DATABASE `db_472570_test_schema_ddl`;
USE `db_472570_test_schema_ddl`;
CREATE TABLE `account` (
  `id` DECIMAL(10,2) NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `DOB` DATE,
  `house_number` INT,
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  `SSN` VARCHAR(50),
  `SACCNT` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` DECIMAL(10,2) NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `DOB` DATE,
  `house_number` INT,
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  `SSN` VARCHAR(50),
  `SACCNT` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders1` (
  `order_id` DECIMAL(10,2) NOT NULL,
  `account_id` DECIMAL(10,2) NOT NULL,
  `product_id` DECIMAL(10,2),
  `created_date` TIMESTAMP NULL,
  `total_price` DECIMAL(10,2),
  PRIMARY KEY (`order_id`, `account_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472570_test_schema_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472570_test_schema_ddl') AS relationships;
DROP DATABASE `db_472570_test_schema_ddl`;
UNINSTALL EXTENSION vsql_schematron;
