INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 474544_schema
--echo #
CREATE DATABASE `db_474544_schema`;
USE `db_474544_schema`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(255),
  `name` VARCHAR(255),
  `lastname` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `is_active` VARCHAR(255),
  `is_admin` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `team` (
  `id` INT,
  `name` VARCHAR(255),
  `is_favorite` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `alumn` (
  `id` INT,
  `image` VARCHAR(255),
  `name` VARCHAR(255),
  `lastname` VARCHAR(255),
  `email` VARCHAR(255),
  `address` VARCHAR(255),
  `phone` VARCHAR(255),
  `c1_fullname` VARCHAR(255),
  `c1_address` VARCHAR(255),
  `c1_phone` VARCHAR(255),
  `c1_note` VARCHAR(255),
  `c2_fullname` VARCHAR(255),
  `c2_address` VARCHAR(255),
  `c2_phone` VARCHAR(255),
  `c2_note` VARCHAR(255),
  `is_active` VARCHAR(255),
  `created_at` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `alumn_team` (
  `id` INT,
  `alumn_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `assistance` (
  `id` INT,
  `kind_id` INT,
  `date_at` DATETIME,
  `alumn_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `behavior` (
  `id` INT,
  `kind_id` INT,
  `date_at` DATETIME,
  `alumn_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `block` (
  `id` INT,
  `name` VARCHAR(255),
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `calification` (
  `id` INT,
  `val` DECIMAL(10,2),
  `alumn_id` INT,
  `block_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_474544_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_474544_schema') AS relationships;
DROP DATABASE `db_474544_schema`;
UNINSTALL EXTENSION vsql_schematron;
