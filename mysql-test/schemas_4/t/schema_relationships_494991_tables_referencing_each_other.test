INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494991_tables_referencing_each_other
--echo #
CREATE DATABASE `db_494991_tables_referencing_each_other`;
USE `db_494991_tables_referencing_each_other`;
CREATE TABLE `test_table_1` (
  `id` BIGINT NOT NULL,
  `table_2_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_table_2` (
  `id` BIGINT NOT NULL,
  `table_1_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494991_tables_referencing_each_other') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494991_tables_referencing_each_other') AS relationships;
DROP DATABASE `db_494991_tables_referencing_each_other`;
UNINSTALL EXTENSION vsql_schematron;
