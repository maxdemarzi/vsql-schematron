INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 406845_example
--echo #
CREATE DATABASE `db_406845_example`;
USE `db_406845_example`;

CREATE TABLE `example1` (
  `primarykey` INT,
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `example2` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_406845_example') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_406845_example') AS relationships;
DROP DATABASE `db_406845_example`;
UNINSTALL EXTENSION vsql_schematron;
