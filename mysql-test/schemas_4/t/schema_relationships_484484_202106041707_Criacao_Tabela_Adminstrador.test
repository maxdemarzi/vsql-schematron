INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 484484_202106041707_Criacao_Tabela_Adminstrador
--echo #
CREATE DATABASE `db_484484_202106041707_Criacao_Tabela_Adminstrador`;
USE `db_484484_202106041707_Criacao_Tabela_Adminstrador`;
CREATE TABLE `administrador` (
  `idadministrador` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`idadministrador`)
) CHARACTER SET latin1;
CREATE TABLE `experienciaprofissional` (
  `idexperienciaprofissional` INT,
  `idusuario` INT,
  `inicio` DATE,
  `fim` DATE,
  `empresa` VARCHAR(50),
  `descricao` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `formacaoacademica` (
  `idformacaoAcademica` INT,
  `idusuario` INT,
  `inicio` DATE,
  `fim` DATE,
  `descricao` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `outrasformacoes` (
  `idoutrasformacoes` INT,
  `idusuario` INT,
  `inicio` DATE,
  `fim` DATE,
  `descricao` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `idusuario` INT,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `dataNascimento` DATE,
  `email` VARCHAR(50),
  `senha` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_484484_202106041707_Criacao_Tabela_Adminstrador') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_484484_202106041707_Criacao_Tabela_Adminstrador') AS relationships;
DROP DATABASE `db_484484_202106041707_Criacao_Tabela_Adminstrador`;
UNINSTALL EXTENSION vsql_schematron;
