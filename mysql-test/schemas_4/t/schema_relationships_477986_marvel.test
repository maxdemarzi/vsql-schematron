INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 477986_marvel
--echo #
CREATE DATABASE `db_477986_marvel`;
USE `db_477986_marvel`;

CREATE TABLE `attitude` (
  `park_id` INT,
  `user_id` INT,
  `attitude_rate` INT,
  `attitude_back` INT,
  `attitude_worth` INT,
  PRIMARY KEY (`user_id`, `park_id`)
) CHARACTER SET latin1;

CREATE TABLE `footprints` (
  `footprint_id` INT,
  `user_id` INT,
  `park_id` INT,
  `date_visited` DATETIME,
  `user_story` VARCHAR(64),
  `is_public` VARCHAR(64),
  `created_on` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `footprint_images` (
  `footprint_id` INT,
  `image_id` INT,
  `image_src` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `gallery` (
  `id` INT,
  `park_id` INT,
  `name` VARCHAR(64),
  `src` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nav_header` (
  `id` INT,
  `path` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `park` (
  `id` INT,
  `google_place_id` VARCHAR(64),
  `name` VARCHAR(64),
  `banner` VARCHAR(64),
  `description` VARCHAR(64),
  `address` VARCHAR(64),
  `province` VARCHAR(64),
  `province_code` VARCHAR(64),
  `country` VARCHAR(64),
  `country_code` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `latitude` VARCHAR(64),
  `longitude` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `website` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `role_id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `user_name` VARCHAR(64),
  `user_password` VARCHAR(64),
  `user_email` VARCHAR(64),
  `user_reg` DATETIME,
  `google_id` VARCHAR(64),
  `accept_term` INT,
  `role_id` INT,
  `user_status` INT,
  `email_valid` VARCHAR(64),
  `email_subscribed` INT,
  `activation_code` VARCHAR(64),
  `activation_date` DATETIME,
  `forget_token` VARCHAR(64),
  `cookie_token` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_details` (
  `user_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `date_of_birth` DATETIME,
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `province` VARCHAR(64),
  `nationality` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `last_trip` VARCHAR(64),
  `next_trip` VARCHAR(64),
  `favourite_places` VARCHAR(64),
  `joined_on` DATETIME,
  `image_src` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `wishlist` (
  `wish_id` INT,
  `user_id` INT,
  `park_id` INT,
  `added_on` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_477986_marvel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_477986_marvel') AS relationships;
DROP DATABASE `db_477986_marvel`;
UNINSTALL EXTENSION vsql_schematron;
