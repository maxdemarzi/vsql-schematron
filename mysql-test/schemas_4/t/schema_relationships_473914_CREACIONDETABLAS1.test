INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473914_CREACIONDETABLAS1
--echo #
CREATE DATABASE `db_473914_CREACIONDETABLAS1`;
USE `db_473914_CREACIONDETABLAS1`;

CREATE TABLE `ORDEN` (
  `ID` DECIMAL(10,2),
  `IDPROD` DECIMAL(10,2),
  `COSTOTOTAL` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CLIENTES` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `MESA` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CLIENTESFRECUENTES` (
  `ID` DECIMAL(10,2),
  `PASSWORD` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PRODUCTOSSIMILARES` (
  `ID_PRODUCTO1` DECIMAL(10,2),
  `ID_PRODUCTO2` DECIMAL(10,2),
  PRIMARY KEY (`ID_PRODUCTO1`, `ID_PRODUCTO2`)
) CHARACTER SET latin1;

CREATE TABLE `INGREDIENTESSIMILARES` (
  `ID_INGREDIENTE1` DECIMAL(10,2),
  `ID_INGREDIENTE2` DECIMAL(10,2),
  PRIMARY KEY (`ID_INGREDIENTE1`, `ID_INGREDIENTE2`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473914_CREACIONDETABLAS1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473914_CREACIONDETABLAS1') AS relationships;
DROP DATABASE `db_473914_CREACIONDETABLAS1`;
UNINSTALL EXTENSION vsql_schematron;
