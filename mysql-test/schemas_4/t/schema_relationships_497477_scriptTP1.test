INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497477_scriptTP1
--echo #
CREATE DATABASE `db_497477_scriptTP1`;
USE `db_497477_scriptTP1`;
CREATE TABLE `Etudiant` (
  `num` INT NOT NULL,
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `anniversaire` VARCHAR(50),
  `niveau` VARCHAR(50),
  `groupe` DECIMAL(10,2),
  `departement` VARCHAR(50),
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `Cours` (
  `num` VARCHAR(50) NOT NULL,
  `intitule` VARCHAR(50),
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `moyenneNotation` (
  `moyenne` DECIMAL(10,2),
  `numEtud` INT NOT NULL,
  `numCours` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`numEtud`, `numCours`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497477_scriptTP1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497477_scriptTP1') AS relationships;
DROP DATABASE `db_497477_scriptTP1`;
UNINSTALL EXTENSION vsql_schematron;
