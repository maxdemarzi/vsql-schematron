INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 483320_mariadb_app
--echo #
CREATE DATABASE `db_483320_mariadb_app`;
USE `db_483320_mariadb_app`;
CREATE TABLE `risks.calcClasses` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `risks.calcModels` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `class_id` VARCHAR(50),
  `archive` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_483320_mariadb_app') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_483320_mariadb_app') AS relationships;
DROP DATABASE `db_483320_mariadb_app`;
UNINSTALL EXTENSION vsql_schematron;
