INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 416385_moneybagbd
--echo #
CREATE DATABASE `db_416385_moneybagbd`;
USE `db_416385_moneybagbd`;

CREATE TABLE `categories` (
  `id` INT,
  `parent_id` INT,
  `order` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `data_rows` (
  `id` INT,
  `data_type_id` INT,
  `field` VARCHAR(64),
  `type` VARCHAR(64),
  `display_name` VARCHAR(64),
  `required` INT,
  `browse` INT,
  `read` INT,
  `edit` INT,
  `add` INT,
  `delete` INT,
  `details` VARCHAR(64),
  `order` INT
) CHARACTER SET latin1;

CREATE TABLE `data_types` (
  `id` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `display_name_singular` VARCHAR(64),
  `display_name_plural` VARCHAR(64),
  `icon` VARCHAR(64),
  `model_name` VARCHAR(64),
  `policy_name` VARCHAR(64),
  `controller` VARCHAR(64),
  `description` VARCHAR(64),
  `generate_permissions` INT,
  `server_side` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `faqs` (
  `id` INT,
  `question` VARCHAR(64),
  `answer` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `homes` (
  `id` INT,
  `moto_title` VARCHAR(64),
  `moto_details` VARCHAR(64),
  `about_us` VARCHAR(64),
  `address` VARCHAR(64),
  `support_email` VARCHAR(64),
  `support_phone` VARCHAR(64),
  `helpline` VARCHAR(64),
  `max_order` VARCHAR(64),
  `min_order` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `menu_items` (
  `id` INT,
  `menu_id` INT,
  `title` VARCHAR(64),
  `url` VARCHAR(64),
  `target` VARCHAR(64),
  `icon_class` VARCHAR(64),
  `color` VARCHAR(64),
  `parent_id` INT,
  `order` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `route` VARCHAR(64),
  `parameters` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `title` VARCHAR(64),
  `details` VARCHAR(64),
  `reply` VARCHAR(64),
  `from` INT,
  `to` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notices` (
  `id` INT,
  `title` VARCHAR(64),
  `details` VARCHAR(64),
  `type` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pages` (
  `id` INT,
  `author_id` INT,
  `title` VARCHAR(64),
  `excerpt` VARCHAR(64),
  `body` VARCHAR(64),
  `image` VARCHAR(64),
  `slug` VARCHAR(64),
  `meta_description` VARCHAR(64),
  `meta_keywords` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `key` VARCHAR(64),
  `table_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `permission_group_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission_groups` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `author_id` INT,
  `category_id` INT,
  `title` VARCHAR(64),
  `seo_title` VARCHAR(64),
  `excerpt` VARCHAR(64),
  `body` VARCHAR(64),
  `image` VARCHAR(64),
  `slug` VARCHAR(64),
  `meta_description` VARCHAR(64),
  `meta_keywords` VARCHAR(64),
  `status` VARCHAR(64),
  `featured` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `rates` (
  `id` INT,
  `image` VARCHAR(64),
  `curency_name` VARCHAR(64),
  `ammount_type` VARCHAR(64),
  `buy` DECIMAL(10,2),
  `sell` DECIMAL(10,2),
  `reserved` DECIMAL(10,2),
  `account_info` VARCHAR(64),
  `is_active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `referral_withdraws` (
  `id` INT,
  `user_id` INT,
  `withdraw` DECIMAL(10,2),
  `payment_method` VARCHAR(64),
  `account_no` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `key` VARCHAR(64),
  `display_name` VARCHAR(64),
  `value` VARCHAR(64),
  `details` VARCHAR(64),
  `type` VARCHAR(64),
  `order` INT,
  `group` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `testimonials` (
  `id` INT,
  `transection_id` INT,
  `image` VARCHAR(64),
  `client_name` VARCHAR(64),
  `title` VARCHAR(64),
  `details` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `translations` (
  `id` INT,
  `table_name` VARCHAR(64),
  `column_name` VARCHAR(64),
  `foreign_key` INT,
  `locale` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `avatar` VARCHAR(64),
  `role_id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `mobile_1` DECIMAL(10,2),
  `mobile_2` DECIMAL(10,2),
  `address` VARCHAR(64),
  `nid` DECIMAL(10,2),
  `nid_first_page` VARCHAR(64),
  `nid_second_page` VARCHAR(64),
  `city` VARCHAR(64),
  `gender` VARCHAR(64),
  `affiliate_id` VARCHAR(64),
  `referred_by` VARCHAR(64),
  `current_referral_amount` DECIMAL(10,2),
  `password` VARCHAR(64),
  `confirmed` INT,
  `confirmation_code` VARCHAR(64),
  `is_verified` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_416385_moneybagbd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_416385_moneybagbd') AS relationships;
DROP DATABASE `db_416385_moneybagbd`;
UNINSTALL EXTENSION vsql_schematron;
