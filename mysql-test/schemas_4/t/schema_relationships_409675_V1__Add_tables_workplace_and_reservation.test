INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409675_V1__Add_tables_workplace_and_reservation
--echo #
CREATE DATABASE `db_409675_V1__Add_tables_workplace_and_reservation`;
USE `db_409675_V1__Add_tables_workplace_and_reservation`;
CREATE TABLE `workplace` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `map_id` VARCHAR(50),
  `x` INT,
  `y` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reservation` (
  `id` BIGINT NOT NULL,
  `end_date` DATE,
  `start_date` DATE,
  `username` VARCHAR(50),
  `workplace_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409675_V1__Add_tables_workplace_and_reservation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409675_V1__Add_tables_workplace_and_reservation') AS relationships;
DROP DATABASE `db_409675_V1__Add_tables_workplace_and_reservation`;
UNINSTALL EXTENSION vsql_schematron;
