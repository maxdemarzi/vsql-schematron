INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 496780_V32__generic_group
--echo #
CREATE DATABASE `db_496780_V32__generic_group`;
USE `db_496780_V32__generic_group`;
CREATE TABLE `generic_group` (
  `id` VARCHAR(50) NOT NULL,
  `community_id` VARCHAR(50),
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `generic_group_membership` (
  `id` VARCHAR(50) NOT NULL,
  `generic_group_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `member_since` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_496780_V32__generic_group') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_496780_V32__generic_group') AS relationships;
DROP DATABASE `db_496780_V32__generic_group`;
UNINSTALL EXTENSION vsql_schematron;
