INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428880_rec_bdd
--echo #
CREATE DATABASE `db_428880_rec_bdd`;
USE `db_428880_rec_bdd`;

CREATE TABLE `critics` (
  `critic_id` INT,
  `critic_creator` INT,
  `critic_title` VARCHAR(64),
  `critic_content` VARCHAR(64),
  `critic_createdate` DATETIME,
  `critic_img` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `role_id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `user_name` VARCHAR(64),
  `user_firstname` VARCHAR(64),
  `user_mail` VARCHAR(64),
  `user_pwd` VARCHAR(64),
  `user_avatar` VARCHAR(64),
  `user_role` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428880_rec_bdd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428880_rec_bdd') AS relationships;
DROP DATABASE `db_428880_rec_bdd`;
UNINSTALL EXTENSION vsql_schematron;
