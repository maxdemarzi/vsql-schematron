INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 490781_V008_Create_Rules_Rulesets_Tables
--echo #
CREATE DATABASE `db_490781_V008_Create_Rules_Rulesets_Tables`;
USE `db_490781_V008_Create_Rules_Rulesets_Tables`;

CREATE TABLE `rules` (
  `rule_id` INT,
  `author` INT,
  `name` VARCHAR(255),
  `message` VARCHAR(255),
  `external_url` VARCHAR(255),
  `priority` INT,
  PRIMARY KEY (`rule_id`)
) CHARACTER SET latin1;

CREATE TABLE `rulesets` (
  `ruleset_id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`ruleset_id`)
) CHARACTER SET latin1;

CREATE TABLE `ruleset_ruleset` (
  `ruleset_id` INT,
  `inherited_ruleset_id` INT,
  PRIMARY KEY (`ruleset_id`, `inherited_ruleset_id`)
) CHARACTER SET latin1;

CREATE TABLE `rule_ruleset` (
  `ruleset_id` INT,
  `rule_id` INT,
  PRIMARY KEY (`ruleset_id`, `rule_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_490781_V008_Create_Rules_Rulesets_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_490781_V008_Create_Rules_Rulesets_Tables') AS relationships;
DROP DATABASE `db_490781_V008_Create_Rules_Rulesets_Tables`;
UNINSTALL EXTENSION vsql_schematron;
