INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426953_V001__Create_PMD_Rules
--echo #
CREATE DATABASE `db_426953_V001__Create_PMD_Rules`;
USE `db_426953_V001__Create_PMD_Rules`;
CREATE TABLE `pmd_rules` (
  `rule_id` BIGINT NOT NULL,
  `parser_language` VARCHAR(50),
  `rule_class` VARCHAR(50),
  `description` BLOB,
  PRIMARY KEY (`rule_id`)
) CHARACTER SET latin1;
CREATE TABLE `pmd_properties` (
  `property_id` BIGINT NOT NULL,
  `rule_id` BIGINT,
  `property_name` VARCHAR(50),
  `property_value` BLOB,
  PRIMARY KEY (`property_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426953_V001__Create_PMD_Rules') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426953_V001__Create_PMD_Rules') AS relationships;
DROP DATABASE `db_426953_V001__Create_PMD_Rules`;
UNINSTALL EXTENSION vsql_schematron;
