INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 453228_db_create
--echo #
CREATE DATABASE `db_453228_db_create`;
USE `db_453228_db_create`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  `role` CHAR(50),
  `password` CHAR(50),
  `active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_453228_db_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_453228_db_create') AS relationships;
DROP DATABASE `db_453228_db_create`;
UNINSTALL EXTENSION vsql_schematron;
