INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 433238_schema
--echo #
CREATE DATABASE `db_433238_schema`;
USE `db_433238_schema`;

CREATE TABLE `guilds` (
  `guild_id` INT,
  `prefix` VARCHAR(64),
  `clear_spam` VARCHAR(64),
  `event_role_id` INT,
  `event_delete_role_id` INT,
  PRIMARY KEY (`guild_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `bungie_id` INT,
  `bliz_id` INT,
  `xbox_id` INT,
  `psn_id` INT,
  `bungie_name` VARCHAR(64),
  `bliz_name` VARCHAR(64),
  `xbox_name` VARCHAR(64),
  `psn_name` VARCHAR(64),
  `platform` INT,
  `access_token` VARCHAR(64),
  `refresh_token` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `guild_id` INT,
  `start_time` DATETIME,
  `timezone` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `max_members` INT,
  `user_id` INT,
  PRIMARY KEY (`guild_id`, `title`)
) CHARACTER SET latin1;

CREATE TABLE `user_event` (
  `user_id` INT,
  `guild_id` INT,
  `title` VARCHAR(64),
  `attending` INT,
  `last_updated` DATETIME,
  PRIMARY KEY (`user_id`, `guild_id`, `title`)
) CHARACTER SET latin1;

CREATE TABLE `roster` (
  `user_id` INT,
  `guild_id` INT,
  `role` VARCHAR(64),
  `timezone` VARCHAR(64),
  PRIMARY KEY (`user_id`, `guild_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_433238_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_433238_schema') AS relationships;
DROP DATABASE `db_433238_schema`;
UNINSTALL EXTENSION vsql_schematron;
