INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439832_migration
--echo #
CREATE DATABASE `db_439832_migration`;
USE `db_439832_migration`;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `published` BOOLEAN,
  `author_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
  `id` INT NOT NULL,
  `bio` TEXT,
  `user_id` INT,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439832_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439832_migration') AS relationships;
DROP DATABASE `db_439832_migration`;
UNINSTALL EXTENSION vsql_schematron;
