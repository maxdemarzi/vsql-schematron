INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 401713_banco
--echo #
CREATE DATABASE `db_401713_banco`;
USE `db_401713_banco`;

CREATE TABLE `Compra` (
  `lote` INT,
  `idVacina` INT,
  `custo` INT,
  `dataCompra` DATETIME,
  `fabricacao` DATETIME,
  `validade` DATETIME,
  PRIMARY KEY (`lote`)
) CHARACTER SET latin1;

CREATE TABLE `Estoque` (
  `idVacina` INT,
  `vacAplicadas` INT,
  `vacDescartadas` INT,
  `dosesTotal` INT,
  PRIMARY KEY (`idVacina`)
) CHARACTER SET latin1;

CREATE TABLE `Historico` (
  `idVacinaGeral` INT,
  `idFaixaEtaria` INT,
  `idAno` INT,
  `idPessoa` INT,
  `idUnidadeSaude` INT,
  `data` DATETIME,
  `doseAtual` INT,
  `idVacina` INT,
  PRIMARY KEY (`idVacinaGeral`, `idFaixaEtaria`, `idAno`, `idPessoa`)
) CHARACTER SET latin1;

CREATE TABLE `Vacina_Doenca` (
  `idVacina` INT,
  `idDoenca` INT,
  `idVacinaGeral` INT,
  PRIMARY KEY (`idVacina`, `idDoenca`, `idVacinaGeral`)
) CHARACTER SET latin1;

CREATE TABLE `Vacinacao` (
  `idVacinaGeral` INT,
  `idFaixaEtaria` INT,
  `idAno` INT,
  PRIMARY KEY (`idVacinaGeral`, `idFaixaEtaria`, `idAno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_401713_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_401713_banco') AS relationships;
DROP DATABASE `db_401713_banco`;
UNINSTALL EXTENSION vsql_schematron;
