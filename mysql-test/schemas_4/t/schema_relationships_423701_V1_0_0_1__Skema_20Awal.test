INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 423701_V1.0.0.1__Skema%20Awal
--echo #
CREATE DATABASE `db_423701_V1_0_0_1__Skema_20Awal`;
USE `db_423701_V1_0_0_1__Skema_20Awal`;
CREATE TABLE `t_location` (
  `id` VARCHAR(50) NOT NULL,
  `city` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_employee` (
  `emp_id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `date_of_birth` DATE,
  `nationality` VARCHAR(50),
  `marital_status` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `hired_date` DATE,
  `suspend_date` DATE,
  `division` VARCHAR(50),
  `grade` VARCHAR(50),
  `sub_division` VARCHAR(50),
  `status` VARCHAR(50),
  `photo` TEXT,
  `loc_id` VARCHAR(50),
  PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_423701_V1_0_0_1__Skema_20Awal') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_423701_V1_0_0_1__Skema_20Awal') AS relationships;
DROP DATABASE `db_423701_V1_0_0_1__Skema_20Awal`;
UNINSTALL EXTENSION vsql_schematron;
