INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 430320_setup-script
--echo #
CREATE DATABASE `db_430320_setup_script`;
USE `db_430320_setup_script`;

CREATE TABLE `UserLogin` (
  `Id` INT,
  `Username` VARCHAR(64),
  `ValidationKey` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `UserApiKeys` (
  `Id` INT,
  `UserId` INT,
  `ApiKey` VARCHAR(64),
  `EncryptionKey` VARCHAR(64),
  `KeyName` VARCHAR(64),
  `Expires` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `TmpState` (
  `KeyId` INT,
  `System` VARCHAR(64),
  `State` VARCHAR(64),
  `Key` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `UserTokens` (
  `Id` INT,
  `KeyId` INT,
  `System` VARCHAR(64),
  `Expires` INT,
  `AccessTokenObj` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_430320_setup_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_430320_setup_script') AS relationships;
DROP DATABASE `db_430320_setup_script`;
UNINSTALL EXTENSION vsql_schematron;
