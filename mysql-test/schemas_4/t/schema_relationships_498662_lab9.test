INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498662_lab9
--echo #
CREATE DATABASE `db_498662_lab9`;
USE `db_498662_lab9`;
CREATE TABLE `courses` (
  `crn` VARCHAR(50) NOT NULL,
  `prefix` VARCHAR(50),
  `num` SMALLINT,
  `title` VARCHAR(50),
  PRIMARY KEY (`crn`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `RIN` VARCHAR(50) NOT NULL,
  `RCSID` CHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `alias` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`RIN`)
) CHARACTER SET latin1;
CREATE TABLE `grades` (
  `id` INT NOT NULL,
  `crn` VARCHAR(50),
  `RIN` VARCHAR(50),
  `grade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498662_lab9') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498662_lab9') AS relationships;
DROP DATABASE `db_498662_lab9`;
UNINSTALL EXTENSION vsql_schematron;
