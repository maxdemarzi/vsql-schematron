INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 445400_import
--echo #
CREATE DATABASE `db_445400_import`;
USE `db_445400_import`;

CREATE TABLE `persons` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pets` (
  `id` INT,
  `name` VARCHAR(64),
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` INT,
  `name` VARCHAR(64),
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `message` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person_post` (
  `id` INT,
  `person_id` VARCHAR(64),
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_445400_import') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_445400_import') AS relationships;
DROP DATABASE `db_445400_import`;
UNINSTALL EXTENSION vsql_schematron;
