INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 429709_20210127110454_initial
--echo #
CREATE DATABASE `db_429709_20210127110454_initial`;
USE `db_429709_20210127110454_initial`;
CREATE TABLE `frontend` (
  `id` BIGINT NOT NULL,
  `url` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scope` (
  `id` BIGINT NOT NULL,
  `scope` TEXT,
  `frontend_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_429709_20210127110454_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_429709_20210127110454_initial') AS relationships;
DROP DATABASE `db_429709_20210127110454_initial`;
UNINSTALL EXTENSION vsql_schematron;
