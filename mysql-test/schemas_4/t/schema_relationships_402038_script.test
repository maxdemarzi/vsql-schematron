INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402038_script
--echo #
CREATE DATABASE `db_402038_script`;
USE `db_402038_script`;
CREATE TABLE `Users` (
  `Id` VARCHAR(50) NOT NULL,
  `Nom` VARCHAR(50),
  `Prenom` VARCHAR(50),
  `Username` VARCHAR(50),
  `Mdp` VARCHAR(50),
  `Groupe` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Regions` (
  `Region` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Region`)
) CHARACTER SET latin1;
CREATE TABLE `News` (
  `Idnew` VARCHAR(50) NOT NULL,
  `Iduser` VARCHAR(50),
  `Region` VARCHAR(50),
  `Title` VARCHAR(50),
  `Label` TEXT,
  `Image` TEXT,
  `Dateajout` DATE,
  PRIMARY KEY (`Idnew`)
) CHARACTER SET latin1;
CREATE TABLE `Cas` (
  `Idcas` VARCHAR(50) NOT NULL,
  `Iduser` VARCHAR(50),
  `Region` VARCHAR(50),
  `Deaths` INT,
  `Date` DATE,
  `Title` VARCHAR(50),
  `Newcases` INT,
  `Healed` INT,
  PRIMARY KEY (`Idcas`)
) CHARACTER SET latin1;
CREATE TABLE `OtherNews` (
  `Idother` VARCHAR(50) NOT NULL,
  `Iduser` VARCHAR(50),
  `Region` VARCHAR(50),
  `label` TEXT,
  `lien` TEXT,
  `etat` INT,
  PRIMARY KEY (`Idother`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402038_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402038_script') AS relationships;
DROP DATABASE `db_402038_script`;
UNINSTALL EXTENSION vsql_schematron;
