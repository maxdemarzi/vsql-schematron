INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 495050_create_db
--echo #
CREATE DATABASE `db_495050_create_db`;
USE `db_495050_create_db`;
CREATE TABLE `films` (
  `film_id` INT NOT NULL,
  `film_name` VARCHAR(50),
  `film_desc` VARCHAR(50),
  PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_shows` (
  `show_id` INT NOT NULL,
  `film_id` INT,
  `start_time` DATETIME,
  `end_time` DATETIME,
  `price` INT,
  `is_active` BOOLEAN,
  PRIMARY KEY (`show_id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
  `booking_id` INT NOT NULL,
  `show_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone_number` VARCHAR(50),
  PRIMARY KEY (`booking_id`)
) CHARACTER SET latin1;
CREATE TABLE `booked_places` (
  `booking_id` INT NOT NULL,
  `place_number` INT NOT NULL,
  PRIMARY KEY (`booking_id`, `place_number`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_495050_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_495050_create_db') AS relationships;
DROP DATABASE `db_495050_create_db`;
UNINSTALL EXTENSION vsql_schematron;
