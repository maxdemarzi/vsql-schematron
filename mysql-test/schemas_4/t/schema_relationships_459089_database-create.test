INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 459089_database-create
--echo #
CREATE DATABASE `db_459089_database_create`;
USE `db_459089_database_create`;
CREATE TABLE `epw.user` (
  `iduser` BIGINT NOT NULL,
  `login` CHAR(50),
  `passwordhash` CHAR(50),
  `datetimeconfirmate` TIMESTAMP NULL,
  `datetimecreate` TIMESTAMP NULL,
  `datetimeupdate` TIMESTAMP NULL,
  `registerhash` CHAR(50),
  `idfile` INT,
  PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `epw.dothour` (
  `iduser` BIGINT NOT NULL,
  `DATE` DATE NOT NULL,
  `hour` TIME NOT NULL,
  PRIMARY KEY (`iduser`, `DATE`, `hour`)
) CHARACTER SET latin1;
CREATE TABLE `epw.parameter` (
  `codparameter` INT NOT NULL,
  `description` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`codparameter`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_459089_database_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_459089_database_create') AS relationships;
DROP DATABASE `db_459089_database_create`;
UNINSTALL EXTENSION vsql_schematron;
