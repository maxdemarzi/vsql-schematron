INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 471915_blog
--echo #
CREATE DATABASE `db_471915_blog`;
USE `db_471915_blog`;

CREATE TABLE `category` (
  `id` INT,
  `parentId` INT,
  `title` VARCHAR(64),
  `metaTitle` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post_category` (
  `postId` INT,
  `categoryId` INT,
  PRIMARY KEY (`postId`, `categoryId`)
) CHARACTER SET latin1;

CREATE TABLE `post_comment` (
  `id` INT,
  `postId` INT,
  `parentId` INT,
  `title` VARCHAR(64),
  `published` INT,
  `createdAt` DATETIME,
  `publishedAt` DATETIME,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post_tag` (
  `postId` INT,
  `tagId` INT,
  PRIMARY KEY (`postId`, `tagId`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `title` VARCHAR(64),
  `metaTitle` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_471915_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_471915_blog') AS relationships;
DROP DATABASE `db_471915_blog`;
UNINSTALL EXTENSION vsql_schematron;
