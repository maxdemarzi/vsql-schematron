INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402909_account
--echo #
CREATE DATABASE `db_402909_account`;
USE `db_402909_account`;
CREATE TABLE `account` (
  `account_id` INT NOT NULL,
  `account_type_id` INT,
  `parent_account_id` INT,
  `account_code` TEXT,
  `account_name` TEXT,
  `active_flag` CHAR(50),
  `audit_user_id` INT,
  `audit_ts` INT,
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402909_account') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402909_account') AS relationships;
DROP DATABASE `db_402909_account`;
UNINSTALL EXTENSION vsql_schematron;
