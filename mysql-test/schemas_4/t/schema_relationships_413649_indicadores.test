INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 413649_indicadores
--echo #
CREATE DATABASE `db_413649_indicadores`;
USE `db_413649_indicadores`;
CREATE TABLE `indicador` (
  `id_indicador` INT,
  `tipo_indicador` INT,
  `valor` DOUBLE,
  `fecha` DATE
) CHARACTER SET latin1;
CREATE TABLE `tipo_indicador` (
  `id_tipo` INT NOT NULL,
  `cod_mindicador` VARCHAR(50),
  `unidad_medida` VARCHAR(50),
  `descripcion` VARCHAR(50),
  PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_413649_indicadores') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_413649_indicadores') AS relationships;
DROP DATABASE `db_413649_indicadores`;
UNINSTALL EXTENSION vsql_schematron;
