INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492245_schema
--echo #
CREATE DATABASE `db_492245_schema`;
USE `db_492245_schema`;

CREATE TABLE `banner` (
  `id` INT,
  `project_id` INT,
  `image_url` VARCHAR(255),
  `image_text` VARCHAR(255),
  `banner_url` VARCHAR(255),
  `text_font` VARCHAR(255),
  `text_color` VARCHAR(255),
  `font_size` INT,
  `additional_info` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `banner_position` (
  `id` INT,
  `banner_id` INT,
  `position_index` INT,
  `delay` INT,
  `show_label` INT,
  `x_position` INT,
  `y_position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `project_id` INT,
  `client_text` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_banner` (
  `id` INT,
  `banner_id` INT,
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `name` VARCHAR(255),
  `url` VARCHAR(255),
  `header` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492245_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492245_schema') AS relationships;
DROP DATABASE `db_492245_schema`;
UNINSTALL EXTENSION vsql_schematron;
