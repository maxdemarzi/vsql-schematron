INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 403014_dump
--echo #
CREATE DATABASE `db_403014_dump`;
USE `db_403014_dump`;

CREATE TABLE `pop` (
  `sock_id` VARCHAR(255),
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `price` DECIMAL(10,2),
  `count` INT,
  `image_url_1` VARCHAR(255),
  `image_url_2` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `tag_id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `pop_tag` (
  `pop_id` VARCHAR(255),
  `tag_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_403014_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_403014_dump') AS relationships;
DROP DATABASE `db_403014_dump`;
UNINSTALL EXTENSION vsql_schematron;
