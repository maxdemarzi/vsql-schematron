INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449345_schema
--echo #
CREATE DATABASE `db_449345_schema`;
USE `db_449345_schema`;

CREATE TABLE `account_classification` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `id` INT,
  `title` VARCHAR(64),
  `account_number` VARCHAR(64),
  `classification` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_category` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_classification` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_status` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `amount` DECIMAL(10,2),
  `date_occurred` DATETIME,
  `image` VARCHAR(64),
  `notes` VARCHAR(64),
  `account_from` INT,
  `account_to` INT,
  `category` INT,
  `classification` INT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute` (
  `id` INT,
  `date_created` DATETIME,
  `date_updated` DATETIME,
  `title` VARCHAR(64),
  `value` VARCHAR(64),
  `transaction` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449345_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449345_schema') AS relationships;
DROP DATABASE `db_449345_schema`;
UNINSTALL EXTENSION vsql_schematron;
