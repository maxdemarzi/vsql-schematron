INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470239_db_init
--echo #
CREATE DATABASE `db_470239_db_init`;
USE `db_470239_db_init`;

CREATE TABLE `pagerank` (
  `website_id` INT,
  `website_str` VARCHAR(255),
  `rank` DECIMAL(10,2),
  PRIMARY KEY (`website_id`)
) CHARACTER SET latin1;

CREATE TABLE `connections` (
  `out_website_id` INT,
  `in_website_id` INT,
  PRIMARY KEY (`out_website_id`, `in_website_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470239_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470239_db_init') AS relationships;
DROP DATABASE `db_470239_db_init`;
UNINSTALL EXTENSION vsql_schematron;
