INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 430853_migration
--echo #
CREATE DATABASE `db_430853_migration`;
USE `db_430853_migration`;

CREATE TABLE `Organization` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UseClass` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Satellite` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Composition` (
  `id` INT,
  `colors` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `satelliteId` INT,
  `campaignId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Point` (
  `id` INT,
  `latitude` VARCHAR(64),
  `longitude` VARCHAR(64),
  `info` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `campaignId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Image` (
  `id` INT,
  `date` DATETIME,
  `url` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `satelliteId` INT,
  `campaignId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Campaign` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `country` VARCHAR(64),
  `numInspectors` INT,
  `typePeriod` VARCHAR(64),
  `status` VARCHAR(64),
  `initialDate` DATETIME,
  `finalDate` DATETIME,
  `publish` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `organizationId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UsersOnCampaigns` (
  `userId` INT,
  `campaignId` INT,
  `typeUserInCampaign` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`userId`, `campaignId`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `geeKey` VARCHAR(64),
  `password` VARCHAR(64),
  `typeUser` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `terms` BOOL,
  `picture` VARCHAR(64),
  `active` BOOL,
  `language` VARCHAR(64),
  `theme` VARCHAR(64),
  `organizationId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_CampaignToUseClass` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_430853_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_430853_migration') AS relationships;
DROP DATABASE `db_430853_migration`;
UNINSTALL EXTENSION vsql_schematron;
