INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472391_db
--echo #
CREATE DATABASE `db_472391_db`;
USE `db_472391_db`;
CREATE TABLE `player` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `code` VARCHAR(50),
  `last` INT,
  `medals` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player_country` (
  `player_id` INT,
  `country_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472391_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472391_db') AS relationships;
DROP DATABASE `db_472391_db`;
UNINSTALL EXTENSION vsql_schematron;
