INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444221_V001__INIT_DATABASE
--echo #
CREATE DATABASE `db_444221_V001_INIT_DATABASE`;
USE `db_444221_V001_INIT_DATABASE`;

CREATE TABLE `PERSON` (
  `ID` INT,
  `EMAIL` VARCHAR(64),
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TODO` (
  `ID` INT,
  `DESCRIPTION` VARCHAR(64),
  `DUE_DATE` DATETIME,
  `PRIORITY` INT,
  `STATUS` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `OWNER_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `NOTE` (
  `ID` INT,
  `CONTENT` VARCHAR(64),
  `TODO_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSON_OWNED_TODOS` (
  `PERSON_ID` INT,
  `OWNED_TODOS_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `REMINDER` (
  `ID` INT,
  `DUE_DATE` DATETIME,
  `TODO_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TODO_COLLABORATION` (
  `TODO_ID` INT,
  `COLLABORATOR_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `TODO_COLLABORATION_REQUEST` (
  `ID` INT,
  `COLLABORATOR_ID` INT,
  `TODO_ID` INT,
  `TOKEN` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444221_V001_INIT_DATABASE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444221_V001_INIT_DATABASE') AS relationships;
DROP DATABASE `db_444221_V001_INIT_DATABASE`;
UNINSTALL EXTENSION vsql_schematron;
