INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488058_up
--echo #
CREATE DATABASE `db_488058_up`;
USE `db_488058_up`;

CREATE TABLE `authors` (
  `id` INT,
  `author_name` VARCHAR(64),
  `birth_date` DATETIME,
  `picture` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `publishers` (
  `id` INT,
  `publisher_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `titles` (
  `id` INT,
  `publisher_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `author_titles` (
  `id` INT,
  `author_id` INT,
  `title_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `distributions` (
  `id` INT,
  `distribution_name` VARCHAR(64),
  `publisher_id` INT,
  `title_id` INT,
  `page_count` INT,
  `max_pos` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `email_verified` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `readers` (
  `id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reader_distributions` (
  `id` INT,
  `user_id` INT,
  `distribution_id` INT,
  `last_pos` INT,
  `last_read` DATETIME,
  `finished_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488058_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488058_up') AS relationships;
DROP DATABASE `db_488058_up`;
UNINSTALL EXTENSION vsql_schematron;
