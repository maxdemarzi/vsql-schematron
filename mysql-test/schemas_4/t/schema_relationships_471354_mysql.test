INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 471354_mysql
--echo #
CREATE DATABASE `db_471354_mysql`;
USE `db_471354_mysql`;

CREATE TABLE `user` (
  `id` VARCHAR(64),
  `passwd` VARCHAR(64),
  `nickname` VARCHAR(64),
  PRIMARY KEY (`nickname`)
) CHARACTER SET latin1;

CREATE TABLE `statistic` (
  `nickname` VARCHAR(64),
  `win` INT,
  `lose` INT,
  PRIMARY KEY (`nickname`)
) CHARACTER SET latin1;

CREATE TABLE `preventOverlapLogin` (
  `nickname` VARCHAR(64),
  PRIMARY KEY (`nickname`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_471354_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_471354_mysql') AS relationships;
DROP DATABASE `db_471354_mysql`;
UNINSTALL EXTENSION vsql_schematron;
