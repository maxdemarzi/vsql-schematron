INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 406253_V2__sharea
--echo #
CREATE DATABASE `db_406253_V2__sharea`;
USE `db_406253_V2__sharea`;
CREATE TABLE `shareas` (
  `id` VARCHAR(50) NOT NULL,
  `creator_id` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `medias` (
  `id` VARCHAR(50) NOT NULL,
  `sharea_id` VARCHAR(50),
  `creator_id` VARCHAR(50),
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `content` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media_like` (
  `id` VARCHAR(50) NOT NULL,
  `media_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_406253_V2__sharea') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_406253_V2__sharea') AS relationships;
DROP DATABASE `db_406253_V2__sharea`;
UNINSTALL EXTENSION vsql_schematron;
