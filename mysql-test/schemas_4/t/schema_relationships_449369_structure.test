INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449369_structure
--echo #
CREATE DATABASE `db_449369_structure`;
USE `db_449369_structure`;

CREATE TABLE `Category` (
  `categoryid` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`categoryid`)
) CHARACTER SET latin1;

CREATE TABLE `Subcategory` (
  `subcategoryid` INT,
  `name` VARCHAR(64),
  `categoryid` INT,
  PRIMARY KEY (`subcategoryid`)
) CHARACTER SET latin1;

CREATE TABLE `Item` (
  `itemid` INT,
  `name` VARCHAR(64),
  `image` VARCHAR(64),
  `subcategoryid` INT,
  PRIMARY KEY (`itemid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449369_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449369_structure') AS relationships;
DROP DATABASE `db_449369_structure`;
UNINSTALL EXTENSION vsql_schematron;
