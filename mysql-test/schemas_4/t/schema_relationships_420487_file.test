INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420487_file
--echo #
CREATE DATABASE `db_420487_file`;
USE `db_420487_file`;
CREATE TABLE `Borrower` (
  `Rollin` INT NOT NULL,
  `Name` VARCHAR(50),
  `DateofIssue` DATE,
  `NameofBook` VARCHAR(50),
  `Status` VARCHAR(50),
  PRIMARY KEY (`Rollin`)
) CHARACTER SET latin1;
CREATE TABLE `fine` (
  `Rollin` INT,
  `Date` DATE,
  `Amt` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420487_file') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420487_file') AS relationships;
DROP DATABASE `db_420487_file`;
UNINSTALL EXTENSION vsql_schematron;
