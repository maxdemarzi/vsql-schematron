INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426939_oswa_inv
--echo #
CREATE DATABASE `db_426939_oswa_inv`;
USE `db_426939_oswa_inv`;

CREATE TABLE `AssetType` (
  `id` INT,
  `Type` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `media` (
  `id` INT,
  `file_name` VARCHAR(255),
  `file_type` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Assets` (
  `id` INT,
  `Assetname` VARCHAR(255),
  `description` VARCHAR(255),
  `purpose` VARCHAR(255),
  `owner` VARCHAR(255),
  `financial_value` INT,
  `location` VARCHAR(255),
  `date` DATETIME,
  `returns` VARCHAR(255),
  `dateOfReturn` DATETIME,
  `status` VARCHAR(255),
  `comments` VARCHAR(255),
  `assettype_id` INT,
  `media_id` INT
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `Assetid` INT,
  `qty` INT,
  `price` DECIMAL(10,2),
  `date` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426939_oswa_inv') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426939_oswa_inv') AS relationships;
DROP DATABASE `db_426939_oswa_inv`;
UNINSTALL EXTENSION vsql_schematron;
