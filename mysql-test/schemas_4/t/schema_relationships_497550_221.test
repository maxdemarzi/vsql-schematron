INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497550_221
--echo #
CREATE DATABASE `db_497550_221`;
USE `db_497550_221`;
CREATE TABLE `passports` (
  `passport_id` INT NOT NULL,
  `passport_number` CHAR(50),
  PRIMARY KEY (`passport_id`)
) CHARACTER SET latin1;
CREATE TABLE `persons` (
  `person_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `passport_id` INT,
  PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497550_221') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497550_221') AS relationships;
DROP DATABASE `db_497550_221`;
UNINSTALL EXTENSION vsql_schematron;
