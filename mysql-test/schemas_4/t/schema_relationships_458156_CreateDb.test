INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458156_CreateDb
--echo #
CREATE DATABASE `db_458156_CreateDb`;
USE `db_458156_CreateDb`;

CREATE TABLE `rack` (
  `IdRack` INT,
  `Gisement` VARCHAR(64),
  `PosRack` VARCHAR(64),
  PRIMARY KEY (`IdRack`)
) CHARACTER SET latin1;

CREATE TABLE `clients` (
  `IdClient` INT,
  `NomClient` VARCHAR(64),
  PRIMARY KEY (`IdClient`)
) CHARACTER SET latin1;

CREATE TABLE `mesure` (
  `IdMesure` INT,
  `Unite` VARCHAR(64),
  PRIMARY KEY (`IdMesure`)
) CHARACTER SET latin1;

CREATE TABLE `produit` (
  `IdProduit` VARCHAR(64),
  `Nom` VARCHAR(64),
  `MesureId` INT,
  `ImgProduit` VARCHAR(64),
  PRIMARY KEY (`IdProduit`)
) CHARACTER SET latin1;

CREATE TABLE `suivicommande` (
  `IdCommande` INT,
  `ClientId` INT,
  `DescriptionCmd` VARCHAR(64),
  `DateSortie` DATETIME,
  PRIMARY KEY (`IdCommande`)
) CHARACTER SET latin1;

CREATE TABLE `geocommande` (
  `RackId` INT,
  `CommandeId` INT,
  `DateEntre` DATETIME,
  PRIMARY KEY (`RackId`, `CommandeId`)
) CHARACTER SET latin1;

CREATE TABLE `stock` (
  `RackId` INT,
  `ProduitId` VARCHAR(64),
  `Quantite` DECIMAL(10,2),
  PRIMARY KEY (`RackId`, `ProduitId`)
) CHARACTER SET latin1;

CREATE TABLE `sortiestock` (
  `ProduitId` VARCHAR(64),
  `Quantite` DECIMAL(10,2),
  `DateSortie` DATETIME,
  PRIMARY KEY (`ProduitId`, `DateSortie`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458156_CreateDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458156_CreateDb') AS relationships;
DROP DATABASE `db_458156_CreateDb`;
UNINSTALL EXTENSION vsql_schematron;
