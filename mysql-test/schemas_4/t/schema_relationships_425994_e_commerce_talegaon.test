  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `address_id` INT,
  `seller_id` INT,
  `status` VARCHAR(64),
  `type` VARCHAR(64),
  `pay_mode` VARCHAR(64),
  `order_track_status` VARCHAR(64),
  `description` VARCHAR(64),
  `end_date` DATETIME,
  `rate` INT,
  `rate_comment` VARCHAR(64),
  `rate_mail_sent` INT,
