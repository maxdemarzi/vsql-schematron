  `name_on_card` VARCHAR(64),
  `cardnum` VARCHAR(64),
  `payuMoneyId` VARCHAR(64),
  `discount` VARCHAR(64),
  `net_amount_debit` VARCHAR(64),
  `created_at` DATETIME,
