  `rate_val` INT,
  `rate_count` INT,
  `role` VARCHAR(64),
  `type` VARCHAR(64),
  `verified` VARCHAR(64),
  `preferences` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `disabled_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user_points` (
  `id` INT,
  `user_id` INT,
  `action_type_id` INT,
  `source_id` INT,
  `points` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `virtual_products` (
  `id` INT,
