) CHARACTER SET latin1;

CREATE TABLE `type_preferences` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `nickname` VARCHAR(64),
  `password` VARCHAR(64),
  `pic_url` VARCHAR(64),
  `language` VARCHAR(64),
  `mobile_phone` VARCHAR(64),
  `pincode_id` INT,
  `area` VARCHAR(64),
  `work_phone` VARCHAR(64),
  `website` VARCHAR(64),
  `twitter` VARCHAR(64),
  `facebook` VARCHAR(64),
  `description` VARCHAR(64),
