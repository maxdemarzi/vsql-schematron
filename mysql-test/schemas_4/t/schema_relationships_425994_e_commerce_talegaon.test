INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425994_e-commerce-talegaon
--echo #
CREATE DATABASE `db_425994_e_commerce_talegaon`;
USE `db_425994_e_commerce_talegaon`;

CREATE TABLE `action_types` (
  `id` INT,
  `source_type` VARCHAR(64),
  `action` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` INT,
  `user_id` INT,
  `default` INT,
  `line1` VARCHAR(64),
  `line2` VARCHAR(64),
  `phone` VARCHAR(64),
  `name_contact` VARCHAR(64),
  `zipcode` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `state` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `businesses` (
  `user_id` INT,
  `business_name` VARCHAR(64),
  `creation_date` DATETIME,
  `local_phone` VARCHAR(64),
  `rate_val` INT,
  `rate_count` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `category_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `icon` VARCHAR(64),
  `image` VARCHAR(64),
  `status` INT,
  `type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `cities` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `action_type_id` INT,
  `source_id` INT,
  `user_id` INT,
  `comment` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company` (
  `id` INT,
  `email` VARCHAR(64),
  `contact_email` VARCHAR(64),
  `sales_email` VARCHAR(64),
  `support_email` VARCHAR(64),
  `status` VARCHAR(64),
  `name` VARCHAR(64),
  `website_name` VARCHAR(64),
  `slogan` VARCHAR(64),
  `logo` VARCHAR(64),
  `theme` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `cell_phone` VARCHAR(64),
  `address` VARCHAR(64),
  `state` VARCHAR(64),
  `city` VARCHAR(64),
  `zip_code` VARCHAR(64),
  `website` VARCHAR(64),
  `twitter` VARCHAR(64),
  `facebook` VARCHAR(64),
  `google_plus` VARCHAR(64),
  `facebook_app_id` VARCHAR(64),
  `description` VARCHAR(64),
  `keywords` VARCHAR(64),
  `about_us` VARCHAR(64),
  `refund_policy` VARCHAR(64),
  `privacy_policy` VARCHAR(64),
  `terms_of_service` VARCHAR(64),
  `google_maps_key_api` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `company_features` (
  `id` INT,
  `company_id` INT,
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `configuration` (
  `id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `freeproducts` (
  `id` INT,
  `user_id` INT,
  `description` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `participation_cost` INT,
  `min_participants` INT,
  `max_participants` INT,
  `max_participations_per_user` INT,
  `draw_number` INT,
  `draw_date` DATETIME,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
