CREATE DATABASE `db_454866_ScriptCreateDB`;
USE `db_454866_ScriptCreateDB`;
CREATE TABLE `USUARIO` (
  `ID` INT NOT NULL,
  `CPF` BIGINT,
  `NOME` VARCHAR(50),
  `TELEFONE` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `SENHA` VARCHAR(50),
  `NASCIMENTO` TIMESTAMP NULL,
  `ADMIN` BOOLEAN,
  `FUNCIONARIO` BOOLEAN,
  `CIDADE` VARCHAR(50),
  `UF` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HORARIOTRABALHO` (
  `ID` INT NOT NULL,
  `HORAENTRADA` TIMESTAMP NULL,
  `HORASAIDA` TIMESTAMP NULL,
  `USUARIO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ATRACAOCATEG` (
  `ID` INT NOT NULL,
  `DESCRICAO` VARCHAR(50),
  `SITUACAO` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ATRACAO` (
  `ID` INT NOT NULL,
  `DESCRICAO` VARCHAR(50),
  `CAPACIDADE` INT,
  `ATRACAOCATEG` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TIPOPAGAMENTO` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FINANCEIRO` (
  `ID` INT NOT NULL,
  `VALORTOTAL` VARCHAR(50),
  `VALORPAGO` VARCHAR(50),
  `DATA` TIMESTAMP NULL,
  `SITUACAO` VARCHAR(50),
  `TIPOPAGAMENTO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `INGRESSO` (
  `ID` INT NOT NULL,
  `VALOR` DOUBLE,
  `DESCRICAO` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VENDINGRESSO` (
  `ID` INT NOT NULL,
  `DATA` TIMESTAMP NULL,
  `VALIDADE` TIMESTAMP NULL,
  `VALORTOTAL` DOUBLE,
  `QUANTIDADE` INT,
  `INGRESSO` INT,
  `USUARIO` INT,
  `FINANCEIRO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PARQUE` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  `CNPJ` VARCHAR(50),
  `HRABERTURA` TIMESTAMP NULL,
  `HRFECHADO` TIMESTAMP NULL,
  `CIDADE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOJACATEG` (
  `ID` INT NOT NULL,
  `DESCRICAO` VARCHAR(50),
  `SITUACAO` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOJA` (
  `ID` INT NOT NULL,
  `CNPJ` VARCHAR(50),
  `NOME` VARCHAR(50),
  `LOJACATEG_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTOCATEG` (
  `ID` INT NOT NULL,
  `DESCRICAO` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTO` (
  `ID` INT NOT NULL,
  `DESCRICAO` VARCHAR(50),
  `MARCA` VARCHAR(50),
  `LOJA_ID` INT,
  `PRODUTOCATEG_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VENDA` (
  `ID` INT NOT NULL,
  `DATA` VARCHAR(50),
  `USUARIO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VENDITEM` (
  `ID` INT NOT NULL,
  `VALORUNIT` DOUBLE,
  `QUANTIDADE` DOUBLE,
  `PRODUTO` INT,
  `USUARIO` INT,
  `VENDA` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOG` (
  `ID` INT NOT NULL,
  `TIPO` VARCHAR(50),
  `TABELA` VARCHAR(50),
  `COMANDO` VARCHAR(50),
  `IP` VARCHAR(50),
  `DATA` TIMESTAMP NULL,
  `USUARIO` INT,
  `VALORNOVO` VARCHAR(50),
  `VALORANT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_454866_ScriptCreateDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_454866_ScriptCreateDB') AS relationships;
DROP DATABASE `db_454866_ScriptCreateDB`;
