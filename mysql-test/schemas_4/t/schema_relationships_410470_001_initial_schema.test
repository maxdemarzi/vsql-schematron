INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410470_001_initial_schema
--echo #
CREATE DATABASE `db_410470_001_initial_schema`;
USE `db_410470_001_initial_schema`;

CREATE TABLE `settings` (
  `id` INT,
  `category` VARCHAR(255),
  `key` VARCHAR(255),
  `value` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `id` INT,
  `slug` VARCHAR(255),
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` INT,
  `title` VARCHAR(255),
  `year` INT,
  `tagline` VARCHAR(255),
  `overview` VARCHAR(255),
  `released` VARCHAR(255),
  `runtime` INT,
  `rating` DECIMAL(10,2),
  `slug` VARCHAR(255),
  `trakt_id` INT,
  `imdb_id` VARCHAR(255),
  `tmdb_id` INT,
  `image_filename` VARCHAR(255),
  `has_watched` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_to_genre` (
  `genre_id` INT,
  `movie_id` INT
) CHARACTER SET latin1;

CREATE TABLE `shows` (
  `id` INT,
  `title` VARCHAR(255),
  `year` INT,
  `overview` VARCHAR(255),
  `first_aired` INT,
  `runtime` INT,
  `network` VARCHAR(255),
  `status` VARCHAR(255),
  `rating` DECIMAL(10,2),
  `updated_at` INT,
  `slug` VARCHAR(255),
  `trakt_id` INT,
  `tvdb_id` INT,
  `imdb_id` VARCHAR(255),
  `tmdb_id` INT,
  `tvrage_id` INT,
  `image_filename` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `show_seasons` (
  `id` INT,
  `show_id` INT,
  `season_number` INT,
  `rating` DECIMAL(10,2),
  `episode_count` INT,
  `aired_episodes` INT,
  `title` VARCHAR(255),
  `overview` VARCHAR(255),
  `first_aired` INT,
  `trakt_id` INT,
  `tvdb_id` INT,
  `tmdb_id` INT,
  `tvrage_id` INT,
  `locked` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `show_season_episodes` (
  `id` INT,
  `show_id` INT,
  `season_id` INT,
  `season_number` INT,
  `episode_number` INT,
  `title` VARCHAR(255),
  `overview` VARCHAR(255),
  `rating` DECIMAL(10,2),
  `first_aired` INT,
  `updated_at` INT,
  `runtime` INT,
  `trakt_id` INT,
  `tvdb_id` INT,
  `imdb_id` VARCHAR(255),
  `tmdb_id` INT,
  `tvrage_id` INT,
  `watched` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` INT,
  `directory_setting_id` INT,
  `subpath` VARCHAR(255),
  `filename` VARCHAR(255),
  `mediatype` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `file_to_episode` (
  `file_id` INT,
  `show_id` INT,
  `season_id` INT,
  `episode_id` INT
) CHARACTER SET latin1;

CREATE TABLE `file_to_movie` (
  `file_id` INT,
  `movie_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410470_001_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410470_001_initial_schema') AS relationships;
DROP DATABASE `db_410470_001_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
