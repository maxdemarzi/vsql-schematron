INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439599_major_cities
--echo #
CREATE DATABASE `db_439599_major_cities`;
USE `db_439599_major_cities`;
CREATE TABLE `us_states` (
  `state_code` VARCHAR(50) NOT NULL,
  `state_name` VARCHAR(50),
  PRIMARY KEY (`state_code`)
) CHARACTER SET latin1;
CREATE TABLE `us_cities` (
  `city_id` INT NOT NULL,
  `state_code` CHAR(50),
  `city` VARCHAR(50),
  `county` VARCHAR(50),
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439599_major_cities') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439599_major_cities') AS relationships;
DROP DATABASE `db_439599_major_cities`;
UNINSTALL EXTENSION vsql_schematron;
