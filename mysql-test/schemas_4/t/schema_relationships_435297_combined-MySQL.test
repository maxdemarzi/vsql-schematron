INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435297_combined-MySQL
--echo #
CREATE DATABASE `db_435297_combined_MySQL`;
USE `db_435297_combined_MySQL`;
CREATE TABLE `umq_conversations` (
  `id` INT NOT NULL,
  `status` INT,
  `service_id` INT,
  `far_service_id` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `umq_messages` (
  `id` INT NOT NULL,
  `status` INT,
  `conversation_id` INT,
  `service_id` INT,
  `queue_id` INT,
  `message_type` VARCHAR(50),
  `message_body` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435297_combined_MySQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435297_combined_MySQL') AS relationships;
DROP DATABASE `db_435297_combined_MySQL`;
UNINSTALL EXTENSION vsql_schematron;
