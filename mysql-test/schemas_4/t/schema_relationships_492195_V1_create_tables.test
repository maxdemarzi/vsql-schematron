INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492195_V1_create_tables
--echo #
CREATE DATABASE `db_492195_V1_create_tables`;
USE `db_492195_V1_create_tables`;

CREATE TABLE `promo` (
  `id` VARCHAR(64),
  `allowed_claims_total` INT,
  `allowed_claims_per_account` INT,
  `claims` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `promo_claim` (
  `claim_number` INT,
  `promo_id` VARCHAR(64),
  PRIMARY KEY (`claim_number`)
) CHARACTER SET latin1;

CREATE TABLE `account_claim` (
  `promo_id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `claims` INT,
  PRIMARY KEY (`promo_id`, `account_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492195_V1_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492195_V1_create_tables') AS relationships;
DROP DATABASE `db_492195_V1_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
