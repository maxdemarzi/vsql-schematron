INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 489566_Residencias_BD
--echo #
CREATE DATABASE `db_489566_Residencias_BD`;
USE `db_489566_Residencias_BD`;

CREATE TABLE `rs_catalog_video` (
  `RSC_ARTISTA` VARCHAR(64),
  `RSC_CANCION` VARCHAR(64),
  `RSC_ENLACE` VARCHAR(64),
  `RSC_EMOCION` VARCHAR(64),
  `RSC_DURACION` INT
) CHARACTER SET latin1;

CREATE TABLE `rs_user` (
  `RS_ID` INT,
  `RS_USERNAME` VARCHAR(64),
  `RS_NAME` VARCHAR(64),
  `RS_LASNAME` VARCHAR(64),
  `RS_ISADMIN` BOOL,
  `RS_PASSWORD` VARCHAR(64),
  `RS_EMAIL` VARCHAR(64),
  PRIMARY KEY (`RS_ID`)
) CHARACTER SET latin1;

CREATE TABLE `rs_datospersona` (
  `RSD_ID` INT,
  `RSD_NAME` VARCHAR(64),
  `RSD_LASTNAME` VARCHAR(64),
  `RSD_AGE` INT,
  `RSD_EMAIL` VARCHAR(64),
  `RSD_OCCUPATION` VARCHAR(64),
  `RSD_GENDER` VARCHAR(64),
  `RSD_PHOTO` VARCHAR(64),
  `RSD_DATE` DATETIME,
  `RSD_USERID` INT,
  PRIMARY KEY (`RSD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `rs_prueba` (
  `RSP_ID` INT,
  `RSP_LECTURA` VARCHAR(64),
  `RSP_FECHA` DATETIME,
  `RSP_PERSONA_ID` INT,
  `nombre_video` VARCHAR(64),
  `duracion_prueba` INT,
  `RSP_EMOCION` VARCHAR(64),
  `RPS_USER_ID` INT,
  PRIMARY KEY (`RSP_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_489566_Residencias_BD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489566_Residencias_BD') AS relationships;
DROP DATABASE `db_489566_Residencias_BD`;
UNINSTALL EXTENSION vsql_schematron;
