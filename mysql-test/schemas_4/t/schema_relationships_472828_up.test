INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472828_up
--echo #
CREATE DATABASE `db_472828_up`;
USE `db_472828_up`;
CREATE TABLE `categories` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `parent_id` CHAR(50),
  `is_leaf` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472828_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472828_up') AS relationships;
DROP DATABASE `db_472828_up`;
UNINSTALL EXTENSION vsql_schematron;
