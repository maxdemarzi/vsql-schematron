INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 442765_schema
--echo #
CREATE DATABASE `db_442765_schema`;
USE `db_442765_schema`;

CREATE TABLE `codegen.author` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `codegen.book` (
  `isbn_number` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`isbn_number`)
) CHARACTER SET latin1;

CREATE TABLE `codegen.book_author` (
  `isbn_number` VARCHAR(64),
  `author_id` INT,
  PRIMARY KEY (`isbn_number`, `author_id`)
) CHARACTER SET latin1;

CREATE TABLE `codegen.preference` (
  `author_id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`author_id`, `name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_442765_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_442765_schema') AS relationships;
DROP DATABASE `db_442765_schema`;
UNINSTALL EXTENSION vsql_schematron;
