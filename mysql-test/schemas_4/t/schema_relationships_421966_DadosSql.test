INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421966_DadosSql
--echo #
CREATE DATABASE `db_421966_DadosSql`;
USE `db_421966_DadosSql`;

CREATE TABLE `articles` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `body` VARCHAR(64),
  `published` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articles_tags` (
  `article_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `title` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421966_DadosSql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421966_DadosSql') AS relationships;
DROP DATABASE `db_421966_DadosSql`;
UNINSTALL EXTENSION vsql_schematron;
