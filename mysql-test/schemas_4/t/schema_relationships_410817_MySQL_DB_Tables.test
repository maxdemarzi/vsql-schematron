INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410817_MySQL_DB_Tables
--echo #
CREATE DATABASE `db_410817_MySQL_DB_Tables`;
USE `db_410817_MySQL_DB_Tables`;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `name` VARCHAR(64),
  `cid` INT,
  `description` VARCHAR(64),
  `stock` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `class` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cl2ca` (
  `id` INT,
  `cid` INT,
  `clid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410817_MySQL_DB_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410817_MySQL_DB_Tables') AS relationships;
DROP DATABASE `db_410817_MySQL_DB_Tables`;
UNINSTALL EXTENSION vsql_schematron;
