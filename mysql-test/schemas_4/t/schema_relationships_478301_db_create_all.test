INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478301_db_create_all
--echo #
CREATE DATABASE `db_478301_db_create_all`;
USE `db_478301_db_create_all`;

CREATE TABLE `address` (
  `id` INT,
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contact` (
  `id` INT,
  `contact` VARCHAR(64),
  `type` VARCHAR(64),
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(64),
  `doc_number` VARCHAR(64),
  `status` INT,
  `registered` DATETIME,
  `billing_address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `id` INT,
  `message` VARCHAR(64),
  `fecha` DATETIME,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478301_db_create_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478301_db_create_all') AS relationships;
DROP DATABASE `db_478301_db_create_all`;
UNINSTALL EXTENSION vsql_schematron;
