INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 407995_tables
--echo #
CREATE DATABASE `db_407995_tables`;
USE `db_407995_tables`;

CREATE TABLE `user` (
  `id` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `phone` VARCHAR(64),
  `birth` DATETIME,
  `survey` VARCHAR(64),
  `auth` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `pno` INT,
  `uid` VARCHAR(64),
  `cafeno` INT,
  `contents` VARCHAR(64),
  `image` VARCHAR(64),
  `taste` VARCHAR(64),
  `mood` VARCHAR(64),
  `clean` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`pno`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `cno` INT,
  `contents` VARCHAR(64),
  `pno` INT,
  `uid` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`cno`)
) CHARACTER SET latin1;

CREATE TABLE `like` (
  `lno` INT,
  `cafeno` INT,
  `uid` VARCHAR(64),
  PRIMARY KEY (`lno`)
) CHARACTER SET latin1;

CREATE TABLE `stamp` (
  `sno` INT,
  `cafeno` INT,
  `uid` VARCHAR(64),
  PRIMARY KEY (`sno`)
) CHARACTER SET latin1;

CREATE TABLE `follow` (
  `fno` INT,
  `uid` VARCHAR(64),
  `followingid` VARCHAR(64),
  PRIMARY KEY (`fno`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `mno` INT,
  `cafeno` INT,
  `item` VARCHAR(64),
  `price` INT,
  PRIMARY KEY (`mno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_407995_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_407995_tables') AS relationships;
DROP DATABASE `db_407995_tables`;
UNINSTALL EXTENSION vsql_schematron;
