INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499314_h2
--echo #
CREATE DATABASE `db_499314_h2`;
USE `db_499314_h2`;

CREATE TABLE `regions` (
  `region_id` INT,
  `region_name` VARCHAR(64),
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;

CREATE TABLE `countries` (
  `country_id` VARCHAR(64),
  `country_name` VARCHAR(64),
  `region_id` INT,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `location_id` INT,
  `address` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `country_id` VARCHAR(64),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;

CREATE TABLE `warehouses` (
  `warehouse_id` INT,
  `warehouse_name` VARCHAR(64),
  `location_id` INT,
  PRIMARY KEY (`warehouse_id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `employee_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `hire_date` DATETIME,
  `manager_id` INT,
  `job_title` VARCHAR(64),
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `product_categories` (
  `category_id` INT,
  `category_name` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `product_id` INT,
  `product_name` VARCHAR(64),
  `description` VARCHAR(64),
  `standard_cost` DECIMAL(10,2),
  `list_price` DECIMAL(10,2),
  `category_id` INT,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `customer_id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `website` VARCHAR(64),
  `credit_limit` DECIMAL(10,2),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `contact_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `customer_id` INT,
  PRIMARY KEY (`contact_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `customer_id` INT,
  `status` VARCHAR(64),
  `salesman_id` INT,
  `order_date` DATETIME,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_items` (
  `order_id` INT,
  `item_id` INT,
  `product_id` INT,
  `quantity` DECIMAL(10,2),
  `unit_price` DECIMAL(10,2),
  PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;

CREATE TABLE `inventories` (
  `product_id` INT,
  `warehouse_id` INT,
  `quantity` DECIMAL(10,2),
  PRIMARY KEY (`product_id`, `warehouse_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499314_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499314_h2') AS relationships;
DROP DATABASE `db_499314_h2`;
UNINSTALL EXTENSION vsql_schematron;
