INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417677_R__Create_search
--echo #
CREATE DATABASE `db_417677_R_Create_search`;
USE `db_417677_R_Create_search`;

CREATE TABLE `simple_search` (
  `id` INT,
  `fedora_id` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  `content_size` INT,
  `mime_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `simple_search_transactions` (
  `id` INT,
  `fedora_id` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  `content_size` INT,
  `mime_type` VARCHAR(64),
  `transaction_id` VARCHAR(64),
  `operation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `search_rdf_type` (
  `id` INT,
  `rdf_type_uri` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `search_resource_rdf_type` (
  `resource_id` INT,
  `rdf_type_id` INT,
  PRIMARY KEY (`resource_id`, `rdf_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `search_resource_rdf_type_transactions` (
  `fedora_id` VARCHAR(64),
  `rdf_type_uri` VARCHAR(64),
  `transaction_id` VARCHAR(64),
  PRIMARY KEY (`fedora_id`, `rdf_type_uri`, `transaction_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417677_R_Create_search') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417677_R_Create_search') AS relationships;
DROP DATABASE `db_417677_R_Create_search`;
UNINSTALL EXTENSION vsql_schematron;
