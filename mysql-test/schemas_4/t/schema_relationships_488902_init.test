INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488902_init
--echo #
CREATE DATABASE `db_488902_init`;
USE `db_488902_init`;
CREATE TABLE `role` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `descn` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `status` INT,
  `descn` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` BIGINT NOT NULL,
  `role_id` BIGINT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488902_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488902_init') AS relationships;
DROP DATABASE `db_488902_init`;
UNINSTALL EXTENSION vsql_schematron;
