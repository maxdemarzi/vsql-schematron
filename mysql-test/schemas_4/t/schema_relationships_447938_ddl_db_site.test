INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447938_ddl_db_site
--echo #
CREATE DATABASE `db_447938_ddl_db_site`;
USE `db_447938_ddl_db_site`;
CREATE TABLE `tb_tipoComida` (
  `id_tipoComida` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id_tipoComida`)
) CHARACTER SET latin1;
CREATE TABLE `tb_prato` (
  `id_prato` INT NOT NULL,
  `nomePrato` VARCHAR(50),
  `descricaoPrato` VARCHAR(50),
  `precoP` DOUBLE,
  `precoM` DOUBLE,
  `precoG` DOUBLE,
  `tipoComida_id` INT,
  PRIMARY KEY (`id_prato`)
) CHARACTER SET latin1;
CREATE TABLE `tb_login` (
  `id_login` INT NOT NULL,
  `email` VARCHAR(50),
  `nomeLogin` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`id_login`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447938_ddl_db_site') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447938_ddl_db_site') AS relationships;
DROP DATABASE `db_447938_ddl_db_site`;
UNINSTALL EXTENSION vsql_schematron;
