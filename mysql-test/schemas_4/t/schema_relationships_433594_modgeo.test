INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 433594_modgeo
--echo #
CREATE DATABASE `db_433594_modgeo`;
USE `db_433594_modgeo`;

CREATE TABLE `empresa` (
  `id_empresa` INT,
  `nmEmpresa` VARCHAR(255),
  `nrCnpj` VARCHAR(255),
  `nmCidadeOrigem` VARCHAR(255),
  `nmEmail` VARCHAR(255),
  `nrTelefone` VARCHAR(255),
  `dtInclusao` DATETIME,
  PRIMARY KEY (`id_empresa`)
) CHARACTER SET latin1;

CREATE TABLE `nome_sondagem` (
  `id_sondagem` INT,
  `nmSondagem` VARCHAR(255),
  `nmResponsavel` VARCHAR(255),
  `dtInicio` DATETIME,
  `dtTermino` DATETIME,
  `nrCoord_x` DECIMAL(10,2),
  `nrCoord_y` DECIMAL(10,2),
  `nrCota` DECIMAL(10,2),
  `nrDirecao` VARCHAR(255),
  `nrProfundidade` DECIMAL(10,2),
  `nrInclinacao` DECIMAL(10,2),
  `nrGeoreferenciamento` DECIMAL(10,2),
  `txtComentario` VARCHAR(255),
  `dtInclusao` DATETIME,
  PRIMARY KEY (`id_sondagem`)
) CHARACTER SET latin1;

CREATE TABLE `parametros_sondagem` (
  `id_parametros_sondagem` INT,
  `nrAlteracao` INT,
  `nrConsistencia` INT,
  `nrFraturamento` INT,
  `nrRqd` INT,
  `id_sondagem` INT
) CHARACTER SET latin1;

CREATE TABLE `tipo_ocorrencia_sondagem` (
  `id_tipo_ocorrencia_sondagem` INT,
  `nrProfundidadeMin` DECIMAL(10,2),
  `nrProfundidadeMax` DECIMAL(10,2),
  `nmTipoRocha` VARCHAR(255),
  `id_sondagem` INT,
  `nmHachuras` VARCHAR(255),
  `nmCor` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_433594_modgeo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_433594_modgeo') AS relationships;
DROP DATABASE `db_433594_modgeo`;
UNINSTALL EXTENSION vsql_schematron;
