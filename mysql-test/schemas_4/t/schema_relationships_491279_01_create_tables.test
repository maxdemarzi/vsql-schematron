INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 491279_01_create_tables
--echo #
CREATE DATABASE `db_491279_01_create_tables`;
USE `db_491279_01_create_tables`;

CREATE TABLE `employer` (
  `id` INT,
  `name` VARCHAR(64),
  `vacation_days` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employer_working_time` (
  `id` INT,
  `employer_id` INT,
  `description` VARCHAR(64),
  `working_time` INT,
  `working_break` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employer_time_account` (
  `employer_id` INT,
  `time_account` INT,
  PRIMARY KEY (`employer_id`)
) CHARACTER SET latin1;

CREATE TABLE `working_times` (
  `id` INT,
  `employer_id` INT,
  `employer_working_time_id` INT,
  `date` DATETIME,
  `mode` VARCHAR(64),
  `begin_timestamp` INT,
  `end_timestamp` INT,
  `break` INT,
  `delta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_491279_01_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_491279_01_create_tables') AS relationships;
DROP DATABASE `db_491279_01_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
