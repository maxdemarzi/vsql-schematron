INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 433928_db_version_six
--echo #
CREATE DATABASE `db_433928_db_version_six`;
USE `db_433928_db_version_six`;
CREATE TABLE `transport.transaction_type` (
  `transaction_type_id` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`transaction_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `transport.transaction` (
  `transaction_id` INT NOT NULL,
  `current_funds` DECIMAL(10,2),
  `spent_funds` DECIMAL(10,2),
  `date` DATETIME,
  `fk_transaction_type_id` INT,
  `fk_user_id` INT,
  PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_433928_db_version_six') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_433928_db_version_six') AS relationships;
DROP DATABASE `db_433928_db_version_six`;
UNINSTALL EXTENSION vsql_schematron;
