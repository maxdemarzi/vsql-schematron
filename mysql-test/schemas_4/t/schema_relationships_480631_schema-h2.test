INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480631_schema-h2
--echo #
CREATE DATABASE `db_480631_schema_h2`;
USE `db_480631_schema_h2`;
CREATE TABLE `ACCOUNT` (
  `ID` BIGINT NOT NULL,
  `APPLE_IN_BASKET` INT,
  `APPLE_IN_TREE` INT,
  `EMAIL` VARCHAR(50),
  `LAST_LOGIN` TIMESTAMP NULL,
  `PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HABIT` (
  `ID` BIGINT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  `NAME` VARCHAR(50),
  `ACCOUNT_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HABIT_EXECUTION_DATE` (
  `ID` BIGINT NOT NULL,
  `DATE` TIMESTAMP NULL,
  `HABIT_ID` BIGINT,
  `ACCOUNT_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480631_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480631_schema_h2') AS relationships;
DROP DATABASE `db_480631_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
