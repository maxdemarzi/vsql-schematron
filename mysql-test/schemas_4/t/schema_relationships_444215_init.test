INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444215_init
--echo #
CREATE DATABASE `db_444215_init`;
USE `db_444215_init`;

CREATE TABLE `exercises` (
  `exercise_name` VARCHAR(64),
  `exercise_link` VARCHAR(64),
  PRIMARY KEY (`exercise_name`)
) CHARACTER SET latin1;

CREATE TABLE `exercise_aliases` (
  `exercise_alias` VARCHAR(64),
  `exercise_name` VARCHAR(64),
  PRIMARY KEY (`exercise_alias`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `user_name` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_reps` (
  `user_id` INT,
  `exercise_name` VARCHAR(64),
  `reps` INT,
  PRIMARY KEY (`user_id`, `exercise_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444215_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444215_init') AS relationships;
DROP DATABASE `db_444215_init`;
UNINSTALL EXTENSION vsql_schematron;
