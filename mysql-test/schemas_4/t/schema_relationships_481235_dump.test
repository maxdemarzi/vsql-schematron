INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481235_dump
--echo #
CREATE DATABASE `db_481235_dump`;
USE `db_481235_dump`;

CREATE TABLE `company` (
  `idcompany` INT,
  `name` VARCHAR(64),
  `company_office_code` VARCHAR(64),
  PRIMARY KEY (`idcompany`)
) CHARACTER SET latin1;

CREATE TABLE `cycles_employee` (
  `idemployee1` INT,
  `idemployee2` VARCHAR(64),
  `name` VARCHAR(64),
  `team_id1` INT,
  `team_id2` VARCHAR(64),
  PRIMARY KEY (`idemployee1`, `idemployee2`)
) CHARACTER SET latin1;

CREATE TABLE `cycles_product` (
  `idproduct` INT,
  `name` VARCHAR(64),
  `owner_id1` INT,
  `owner_id2` VARCHAR(64),
  PRIMARY KEY (`idproduct`)
) CHARACTER SET latin1;

CREATE TABLE `cycles_team` (
  `idteam1` INT,
  `idteam2` VARCHAR(64),
  `name` VARCHAR(64),
  `product_id` INT,
  PRIMARY KEY (`idteam1`, `idteam2`)
) CHARACTER SET latin1;

CREATE TABLE `persone_has_car` (
  `persone_idpersone` INT,
  `car_idcar` INT,
  PRIMARY KEY (`persone_idpersone`, `car_idcar`)
) CHARACTER SET latin1;

CREATE TABLE `persone_has_house` (
  `persone_idpersone` INT,
  `house_idhouse` INT,
  PRIMARY KEY (`persone_idpersone`, `house_idhouse`)
) CHARACTER SET latin1;

CREATE TABLE `ucycles_department` (
  `iddepartment` INT,
  `name` VARCHAR(64),
  `head_employee_no` VARCHAR(64),
  PRIMARY KEY (`iddepartment`)
) CHARACTER SET latin1;

CREATE TABLE `ucycles_software` (
  `idsoftware` INT,
  `name` VARCHAR(64),
  `department_id` INT,
  PRIMARY KEY (`idsoftware`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481235_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481235_dump') AS relationships;
DROP DATABASE `db_481235_dump`;
UNINSTALL EXTENSION vsql_schematron;
