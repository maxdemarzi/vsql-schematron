INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 428905_tutorial
--echo #
CREATE DATABASE `db_428905_tutorial`;
USE `db_428905_tutorial`;

CREATE TABLE `person` (
  `id` INT,
  `name` VARCHAR(64),
  `date_of_birth` DATETIME,
  `height` INT
) CHARACTER SET latin1;

CREATE TABLE `reliability` (
  `person` INT,
  `score` DECIMAL(10,2),
  PRIMARY KEY (`person`)
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `id` INT,
  `name` VARCHAR(64),
  `area` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sightings` (
  `time` DATETIME,
  `person` INT,
  `room` INT,
  `witness` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_428905_tutorial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_428905_tutorial') AS relationships;
DROP DATABASE `db_428905_tutorial`;
UNINSTALL EXTENSION vsql_schematron;
