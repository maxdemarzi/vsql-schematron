INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488044_migration
--echo #
CREATE DATABASE `db_488044_migration`;
USE `db_488044_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `password` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `content` TEXT,
  `author_id` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Review` (
  `id` VARCHAR(50) NOT NULL,
  `content` TEXT,
  `post_id` TEXT,
  `author_id` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488044_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488044_migration') AS relationships;
DROP DATABASE `db_488044_migration`;
UNINSTALL EXTENSION vsql_schematron;
