INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 407292_02-notices
--echo #
CREATE DATABASE `db_407292_02_notices`;
USE `db_407292_02_notices`;
CREATE TABLE `pins` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notices` (
  `id` INT NOT NULL,
  `title` TEXT,
  `content` TEXT,
  `language` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pin_notices` (
  `notice_id` INT NOT NULL,
  `pin_id` INT NOT NULL,
  PRIMARY KEY (`notice_id`, `pin_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_407292_02_notices') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_407292_02_notices') AS relationships;
DROP DATABASE `db_407292_02_notices`;
UNINSTALL EXTENSION vsql_schematron;
