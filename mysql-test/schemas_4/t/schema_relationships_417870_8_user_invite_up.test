INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417870_8_user_invite.up
--echo #
CREATE DATABASE `db_417870_8_user_invite_up`;
USE `db_417870_8_user_invite_up`;
CREATE TABLE `invite_keys` (
  `id` VARCHAR(50) NOT NULL,
  `generated_by` VARCHAR(50),
  `generated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pending_activations` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `invite_key` VARCHAR(50),
  `type` VARCHAR(50),
  `time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417870_8_user_invite_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417870_8_user_invite_up') AS relationships;
DROP DATABASE `db_417870_8_user_invite_up`;
UNINSTALL EXTENSION vsql_schematron;
