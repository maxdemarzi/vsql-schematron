INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492259_urlshortener
--echo #
CREATE DATABASE `db_492259_urlshortener`;
USE `db_492259_urlshortener`;
CREATE TABLE `stats` (
  `id` INT,
  `url_id` INT,
  `clickdate` TIMESTAMP NULL,
  `ip` VARCHAR(50),
  `referer` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `urls` (
  `id` INT,
  `url` VARCHAR(50),
  `segment` VARCHAR(50),
  `datetime_added` TIMESTAMP NULL,
  `ip` VARCHAR(50),
  `num_of_clicks` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492259_urlshortener') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492259_urlshortener') AS relationships;
DROP DATABASE `db_492259_urlshortener`;
UNINSTALL EXTENSION vsql_schematron;
