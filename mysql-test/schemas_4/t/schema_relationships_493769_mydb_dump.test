INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 493769_mydb_dump
--echo #
CREATE DATABASE `db_493769_mydb_dump`;
USE `db_493769_mydb_dump`;
CREATE TABLE `genres` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `numberInStock` INT,
  `dailyRentalRate` INT,
  `genres_id` INT NOT NULL,
  PRIMARY KEY (`id`, `genres_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_493769_mydb_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_493769_mydb_dump') AS relationships;
DROP DATABASE `db_493769_mydb_dump`;
UNINSTALL EXTENSION vsql_schematron;
