INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420255_schema
--echo #
CREATE DATABASE `db_420255_schema`;
USE `db_420255_schema`;
CREATE TABLE `user_t` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `key` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `session_id` VARCHAR(50) NOT NULL,
  `jwt_token` VARCHAR(50),
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `revoked` BOOLEAN,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `passwords` (
  `id` INT NOT NULL,
  `user_id` INT,
  `password` VARCHAR(50),
  `category` TEXT,
  `site` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `server_encryption_key` (
  `server_key` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `server_auth_key` (
  `auth_server_key` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420255_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420255_schema') AS relationships;
DROP DATABASE `db_420255_schema`;
UNINSTALL EXTENSION vsql_schematron;
