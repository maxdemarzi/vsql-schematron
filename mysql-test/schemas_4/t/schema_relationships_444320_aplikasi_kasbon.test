INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444320_aplikasi_kasbon
--echo #
CREATE DATABASE `db_444320_aplikasi_kasbon`;
USE `db_444320_aplikasi_kasbon`;

CREATE TABLE `m_pegawai` (
  `nip` VARCHAR(64),
  `nama` VARCHAR(64),
  `jabatan` VARCHAR(64),
  `no_hp1` VARCHAR(64),
  `no_hp2` VARCHAR(64),
  PRIMARY KEY (`nip`)
) CHARACTER SET latin1;

CREATE TABLE `saldo_kasbon` (
  `id_saldo_kasbon` INT,
  `nip` VARCHAR(64),
  `saldo` DECIMAL(10,2),
  PRIMARY KEY (`id_saldo_kasbon`)
) CHARACTER SET latin1;

CREATE TABLE `sec_permission` (
  `id_permission` INT,
  `permission_name` VARCHAR(64),
  PRIMARY KEY (`id_permission`)
) CHARACTER SET latin1;

CREATE TABLE `sec_role` (
  `id_role` INT,
  `rolename` VARCHAR(64),
  PRIMARY KEY (`id_role`)
) CHARACTER SET latin1;

CREATE TABLE `sec_role_has_sec_permission` (
  `sec_role_id_role` INT,
  `sec_permission_id_permission` INT,
  PRIMARY KEY (`sec_role_id_role`, `sec_permission_id_permission`)
) CHARACTER SET latin1;

CREATE TABLE `sec_user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `nip` VARCHAR(64),
  `id_role` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `t_pembayaran_kasbon` (
  `id_pembayaran_kasbon` INT,
  `tgl_pembayaran` DATETIME,
  `nip` VARCHAR(64),
  `nilai` DECIMAL(10,2),
  `keterangan` VARCHAR(64),
  `created_by` VARCHAR(64),
  `id_pengajuan_kasbon` INT,
  PRIMARY KEY (`id_pembayaran_kasbon`)
) CHARACTER SET latin1;

CREATE TABLE `t_pencairan_kasbon` (
  `id_pencairan_kasbon` INT,
  `id_pengajuan_kasbon` INT,
  `tgl_pencairan` DATETIME,
  `nilai` DECIMAL(10,2),
  `keterangan` VARCHAR(64),
  `created_by` VARCHAR(64),
  PRIMARY KEY (`id_pencairan_kasbon`)
) CHARACTER SET latin1;

CREATE TABLE `t_pengajuan_kasbon` (
  `id_pengajuan_kasbon` INT,
  `tgl_pengajuan` DATETIME,
  `nip` VARCHAR(64),
  `nilai` DECIMAL(10,2),
  `keterangan` VARCHAR(64),
  `is_approve` INT,
  `approve_date` DATETIME,
  `approved_by` VARCHAR(64),
  `created_by` VARCHAR(64),
  PRIMARY KEY (`id_pengajuan_kasbon`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444320_aplikasi_kasbon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444320_aplikasi_kasbon') AS relationships;
DROP DATABASE `db_444320_aplikasi_kasbon`;
UNINSTALL EXTENSION vsql_schematron;
