INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450382_data
--echo #
CREATE DATABASE `db_450382_data`;
USE `db_450382_data`;

CREATE TABLE `users` (
  `user_id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `authorities` (
  `role_id` INT,
  `username` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450382_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450382_data') AS relationships;
DROP DATABASE `db_450382_data`;
UNINSTALL EXTENSION vsql_schematron;
