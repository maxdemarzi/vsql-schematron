INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478853_V1.0__Description
--echo #
CREATE DATABASE `db_478853_V1_0__Description`;
USE `db_478853_V1_0__Description`;
CREATE TABLE `oauth_client_details` (
  `client_id` VARCHAR(50) NOT NULL,
  `client_secret` VARCHAR(50),
  `resource_ids` VARCHAR(50),
  `scope` VARCHAR(50),
  `authorized_grant_types` VARCHAR(50),
  `web_server_redirect_uri` VARCHAR(50),
  `authorities` VARCHAR(50),
  `access_token_validity` INT,
  `refresh_token_validity` INT,
  `additional_information` VARCHAR(50),
  `autoapprove` VARCHAR(50),
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `nombre_usuario` VARCHAR(50),
  `contrasena` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id_rol` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `usuario_rol` (
  `id_rol` INT,
  `id_usuario` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478853_V1_0__Description') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478853_V1_0__Description') AS relationships;
DROP DATABASE `db_478853_V1_0__Description`;
UNINSTALL EXTENSION vsql_schematron;
