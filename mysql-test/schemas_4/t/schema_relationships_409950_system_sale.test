INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409950_system_sale
--echo #
CREATE DATABASE `db_409950_system_sale`;
USE `db_409950_system_sale`;

CREATE TABLE `type_product` (
  `id` INT,
  `description` VARCHAR(64),
  `percentage_imposed` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `id_type` INT,
  `description` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sale` (
  `id` INT,
  `total_imposed` DECIMAL(10,2),
  `total_sale` DECIMAL(10,2),
  `total_pay` DECIMAL(10,2),
  `date_register` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `itens_sale` (
  `id` INT,
  `id_sale` INT,
  `id_product` INT,
  `description` VARCHAR(64),
  `amount` INT,
  `price_uni` DECIMAL(10,2),
  `percentage_imposed` DECIMAL(10,2),
  `total_pay` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409950_system_sale') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409950_system_sale') AS relationships;
DROP DATABASE `db_409950_system_sale`;
UNINSTALL EXTENSION vsql_schematron;
