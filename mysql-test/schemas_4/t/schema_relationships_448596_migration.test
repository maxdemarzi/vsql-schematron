INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 448596_migration
--echo #
CREATE DATABASE `db_448596_migration`;
USE `db_448596_migration`;

CREATE TABLE `users` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `image` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `id` INT,
  `content` VARCHAR(64),
  `authorId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mentions` (
  `id` INT,
  `mentionedUsername` VARCHAR(64),
  `noteId` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_448596_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_448596_migration') AS relationships;
DROP DATABASE `db_448596_migration`;
UNINSTALL EXTENSION vsql_schematron;
