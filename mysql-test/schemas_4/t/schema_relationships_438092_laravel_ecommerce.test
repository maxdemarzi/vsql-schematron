INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 438092_laravel_ecommerce
--echo #
CREATE DATABASE `db_438092_laravel_ecommerce`;
USE `db_438092_laravel_ecommerce`;

CREATE TABLE `addresses` (
  `id` INT,
  `area` VARCHAR(255),
  `city` VARCHAR(255),
  `zip` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `admins` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(255),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(255),
  `image_name` VARCHAR(255),
  `description` VARCHAR(255),
  `colors` VARCHAR(255),
  `price` INT,
  `discount` INT,
  `tag` VARCHAR(255),
  `category_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `user_id` INT,
  `product_id` VARCHAR(255),
  `order_status` VARCHAR(255),
  `price` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `full_name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `phone` VARCHAR(255),
  `prev_password` VARCHAR(255),
  `address_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_438092_laravel_ecommerce') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_438092_laravel_ecommerce') AS relationships;
DROP DATABASE `db_438092_laravel_ecommerce`;
UNINSTALL EXTENSION vsql_schematron;
