INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 404546_schema
--echo #
CREATE DATABASE `db_404546_schema`;
USE `db_404546_schema`;
CREATE TABLE `customers` (
  `id` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `product_id` VARCHAR(50) NOT NULL,
  `product_name` CHAR(50),
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` VARCHAR(50) NOT NULL,
  `customer_id` VARCHAR(50),
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_products` (
  `id` VARCHAR(50) NOT NULL,
  `order_id` VARCHAR(50),
  `product_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_404546_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_404546_schema') AS relationships;
DROP DATABASE `db_404546_schema`;
UNINSTALL EXTENSION vsql_schematron;
