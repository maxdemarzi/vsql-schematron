INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 477226_1--0.0.1--account-auth
--echo #
CREATE DATABASE `db_477226_1_0_0_1_account_auth`;
USE `db_477226_1_0_0_1_account_auth`;

CREATE TABLE `account` (
  `id` INT,
  `created_by_account` INT,
  `modified_by_account` INT,
  `date_created` DATETIME,
  `date_modified` DATETIME,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_477226_1_0_0_1_account_auth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_477226_1_0_0_1_account_auth') AS relationships;
DROP DATABASE `db_477226_1_0_0_1_account_auth`;
UNINSTALL EXTENSION vsql_schematron;
