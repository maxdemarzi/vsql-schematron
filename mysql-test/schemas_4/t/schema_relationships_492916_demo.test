INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492916_demo
--echo #
CREATE DATABASE `db_492916_demo`;
USE `db_492916_demo`;
CREATE TABLE `ADDRESS` (
  `ID` INT NOT NULL,
  `COUNTRY` VARCHAR(50),
  `CITY` VARCHAR(50),
  `STREET` VARCHAR(50),
  `NUMBER` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMPANY` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `ADDRESS_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
  `ID` INT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `ADDRESS_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `CATEGORY` VARCHAR(50),
  `COMPANY_ID` INT,
  `PRICE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PURCHASE` (
  `ID` INT NOT NULL,
  `TIME` DATETIME,
  `CUSTOMER_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PURCHASED_ITEMS` (
  `PURCHASE_ID` INT,
  `PRODUCT_ID` INT,
  `QUANTITY` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492916_demo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492916_demo') AS relationships;
DROP DATABASE `db_492916_demo`;
UNINSTALL EXTENSION vsql_schematron;
