INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439322_Challenge2_Jacky
--echo #
CREATE DATABASE `db_439322_Challenge2_Jacky`;
USE `db_439322_Challenge2_Jacky`;
CREATE TABLE `Products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
  `id` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `CardNumber` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `id` INT NOT NULL,
  `product_id` INT,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439322_Challenge2_Jacky') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439322_Challenge2_Jacky') AS relationships;
DROP DATABASE `db_439322_Challenge2_Jacky`;
UNINSTALL EXTENSION vsql_schematron;
