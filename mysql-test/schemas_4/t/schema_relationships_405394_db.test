INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405394_db
--echo #
CREATE DATABASE `db_405394_db`;
USE `db_405394_db`;
CREATE TABLE `barang` (
  `id_barang` VARCHAR(50),
  `id_penjual` VARCHAR(50),
  `nama_barang` VARCHAR(50),
  `kategori` VARCHAR(50),
  `deskripsi` VARCHAR(50),
  `harga` DOUBLE,
  `foto` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `migration` VARCHAR(50),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penjual` (
  `id_penjual` VARCHAR(50),
  `username` VARCHAR(50),
  `nama` VARCHAR(50),
  `nomor_hp` VARCHAR(50),
  `email` VARCHAR(50),
  `email_verified_at` TIMESTAMP NULL,
  `password` VARCHAR(50),
  `token` VARCHAR(50),
  `remember_token` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405394_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405394_db') AS relationships;
DROP DATABASE `db_405394_db`;
UNINSTALL EXTENSION vsql_schematron;
