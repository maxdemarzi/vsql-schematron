INSTALL EXTENSION vsql_schematron;
#
# Test vsql_schema_cache_ready function
#
CREATE DATABASE test_db;
USE test_db;
CREATE TABLE customers (
id INT PRIMARY KEY,
first_name VARCHAR(50),
last_name VARCHAR(50)
);
CREATE TABLE orders (
id INT PRIMARY KEY,
customer_id INT,
order_date DATE,
amount DECIMAL(10,2)
);
SELECT vsql_schema_cache_ready('test_db') AS cache_ready;
cache_ready
1
#
# Cleanup
#
UNINSTALL EXTENSION vsql_schematron;
DROP DATABASE test_db;
