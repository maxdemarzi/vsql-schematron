INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 095136_CREATE_DATABASE_POSTGRESQL
#
CREATE DATABASE `db_095136_CREATE_DATABASE_POSTGRESQL`;
USE `db_095136_CREATE_DATABASE_POSTGRESQL`;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`user_name` VARCHAR(50),
`user_url_photo` VARCHAR(50),
`email` VARCHAR(50),
`user_password` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_checks` (
`id_daily_check` INT NOT NULL,
`weight` INT,
`waist_lenght` INT,
`date_check` DATE,
`water_glasses` INT,
`calories_count` INT,
`user_id` INT,
PRIMARY KEY (`id_daily_check`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`recipe_id` INT NOT NULL,
`calories` INT,
`url_photo` VARCHAR(50),
PRIMARY KEY (`recipe_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_checks_recipes` (
`dcr_id` INT NOT NULL,
`id_daily_check` INT,
`recipe_id` INT,
PRIMARY KEY (`dcr_id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
`steps_id` INT NOT NULL,
`order_no` INT,
`description_step` TEXT,
`recipe_id` INT,
PRIMARY KEY (`steps_id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`ingredient_id` INT NOT NULL,
`ingredient_name` VARCHAR(50),
`total_calories` INT,
`measure` VARCHAR(50),
`grams_per_measure` VARCHAR(50),
PRIMARY KEY (`ingredient_id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_ingredients` (
`ri_id` INT NOT NULL,
`recipe_id` INT,
`ingredient_id` INT,
PRIMARY KEY (`ri_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_095136_CREATE_DATABASE_POSTGRESQL') AS relationships;
