CREATE DATABASE `db_633190_create`;
USE `db_633190_create`;
CREATE TABLE `oauth2_access_tokens` (
`access_token` VARCHAR(50) NOT NULL,
`client_id` VARCHAR(50),
`expires_at` DATETIME,
`scopes` TEXT,
`resource_owner_id` VARCHAR(50),
`resource_owner_type` VARCHAR(50),
PRIMARY KEY (`access_token`)
) CHARACTER SET latin1;
CREATE TABLE `oauth2_clients` (
`client_id` VARCHAR(50) NOT NULL,
`client_secret` VARCHAR(50),
`redirect_uris` TEXT,
`allowed_grant_types` TEXT,
PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `oauth2_refresh_tokens` (
`refresh_token` VARCHAR(50) NOT NULL,
`associated_access_token` VARCHAR(50),
`expires_at` DATETIME,
`revoked_at` DATETIME,
PRIMARY KEY (`refresh_token`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_633190_create') AS relationships;
