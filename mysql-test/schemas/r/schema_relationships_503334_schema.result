INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 503334_schema
#
CREATE DATABASE `db_503334_schema`;
USE `db_503334_schema`;
CREATE TABLE `department` (
`department_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_503334_schema') AS relationships;
relationships
Database: db_503334_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> roles.role_id
[Implied]  roles.department_id -> department.department_id

DROP DATABASE `db_503334_schema`;
UNINSTALL EXTENSION vsql_schematron;
