INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 530489_000006-create-stories-table
#
CREATE DATABASE `db_530489_000006_create_stories_table`;
USE `db_530489_000006_create_stories_table`;
CREATE TABLE `stories` (
`id` INT NOT NULL,
`active` BOOLEAN,
`copyright` SMALLINT,
`library_id` INT,
`name` TEXT,
`notes` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authors_stories` (
`id` INT NOT NULL,
`author_id` INT,
`story_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series_stories` (
`id` INT NOT NULL,
`series_id` INT,
`story_id` INT,
`ordinal` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `volumes_stories` (
`id` INT NOT NULL,
`volume_id` INT,
`story_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_530489_000006_create_stories_table') AS relationships;
