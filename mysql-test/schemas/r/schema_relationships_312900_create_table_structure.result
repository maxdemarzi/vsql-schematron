CREATE DATABASE `db_312900_create_table_structure`;
USE `db_312900_create_table_structure`;
CREATE TABLE `Ingredient` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`is_admin` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Recipe` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`preptime_minutes` INT,
`difficulty` INT,
`instruction` TEXT,
`created_at` DATETIME,
`creator_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Favourite` (
`id` INT NOT NULL,
`user_id` INT,
`recipe_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
`id` INT NOT NULL,
`user_id` INT,
`recipe_id` INT,
`value` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `RecipeIngredient` (
`id` INT NOT NULL,
`ingredient_id` INT,
`recipe_id` INT,
`amount` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
