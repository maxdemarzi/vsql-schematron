CREATE DATABASE `db_665136_database`;
USE `db_665136_database`;
CREATE TABLE `movies` (
`id` INT NOT NULL,
`title` TEXT,
`url` TEXT,
`imdb_code` TEXT,
`title_long` TEXT,
`slug` TEXT,
`year` INT,
`rating` DOUBLE,
`runtime` INT,
`summary` TEXT,
`yt_trailer_code` TEXT,
`language` TEXT,
`mpa_rating` TEXT,
`background_image` TEXT,
`background_image_original` TEXT,
`small_cover_image` TEXT,
`medium_cover_image` TEXT,
`large_cover_image` TEXT,
`date_uploaded` TEXT,
`date_uploaded_unix` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_genre` (
`record_id` INT NOT NULL,
`movie_id` INT,
`genre` TEXT,
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_665136_database') AS relationships;
