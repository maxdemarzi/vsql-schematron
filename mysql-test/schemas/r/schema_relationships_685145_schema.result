INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 685145_schema
#
CREATE DATABASE `db_685145_schema`;
USE `db_685145_schema`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`category` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`payment_date` DATETIME,
`ship_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_product` (
`order_id` INT NOT NULL,
`product_id` INT NOT NULL,
`quantity` SMALLINT,
`price` DECIMAL(10,2),
PRIMARY KEY (`order_id`, `product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_685145_schema') AS relationships;
relationships
Database: db_685145_schema

Table Connections:
------------------
[Implied]  order_product.order_id -> orders.id
[Implied]  order_product.product_id -> products.id

DROP DATABASE `db_685145_schema`;
UNINSTALL EXTENSION vsql_schematron;
