INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 299165_V1_0_0__Initial
#
CREATE DATABASE `db_299165_V1_0_0__Initial`;
USE `db_299165_V1_0_0__Initial`;
CREATE TABLE `rooms` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`INFO` TEXT,
`MAX_CAPACITY` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `patient` (
`ID` INT NOT NULL,
`HASHED_PASSWORD` VARCHAR(50),
`PERSONAL_ID` VARCHAR(50),
`NAME` VARCHAR(50),
`PHONE` VARCHAR(50),
`ROOM_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `health_records` (
`ID` INT NOT NULL,
`CREATED_ON` TIMESTAMP NULL,
`PATIENT_ID` INT,
`TEMPERATURE` DECIMAL(10,2),
`COUGH` BOOLEAN,
`HEADACHE` BOOLEAN,
`THROAT_ACHE` BOOLEAN,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_299165_V1_0_0__Initial') AS relationships;
relationships
Database: db_299165_V1_0_0__Initial

Table Connections:
------------------
[Implied]  health_records.PATIENT_ID -> patient.ID
[Implied]  patient.ROOM_ID -> rooms.ID

DROP DATABASE `db_299165_V1_0_0__Initial`;
UNINSTALL EXTENSION vsql_schematron;
