INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 580440_db
#
CREATE DATABASE `db_580440_db`;
USE `db_580440_db`;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`user_name` VARCHAR(50),
`email` VARCHAR(50),
`passwd` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`post_id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`body` VARCHAR(50),
`posttime` TIMESTAMP NULL,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_580440_db') AS relationships;
relationships
