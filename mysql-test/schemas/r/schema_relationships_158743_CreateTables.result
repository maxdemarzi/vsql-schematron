CREATE DATABASE `db_158743_CreateTables`;
USE `db_158743_CreateTables`;
CREATE TABLE `fire` (
`id` INT NOT NULL,
`burned_area` DOUBLE,
`location_id` BIGINT,
`indexes_id` BIGINT,
`meteorological_conditions_id` BIGINT,
`time_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `time` (
`id` INT NOT NULL,
`day_week` VARCHAR(50),
`weekend` BOOLEAN,
`month` VARCHAR(50),
`season` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `indexes` (
`id` INT NOT NULL,
`ffmc` DOUBLE,
`dmc` DOUBLE,
`dc` DOUBLE,
`isi` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `meteorological_conditions` (
`id` INT NOT NULL,
`relative_humidity` DOUBLE,
`wind_speed` DOUBLE,
`accumulated_precipitation` DOUBLE,
`temperature` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
`id` INT NOT NULL,
`location_x` INT,
`location_y` INT,
`locationnswe` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
