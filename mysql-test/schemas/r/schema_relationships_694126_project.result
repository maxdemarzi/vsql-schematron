INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 694126_project
#
CREATE DATABASE `db_694126_project`;
USE `db_694126_project`;
CREATE TABLE `category` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `films` (
`id` INT NOT NULL,
`preview` TEXT,
`name` VARCHAR(50),
`description` TEXT,
`season` INT,
`seria` INT,
`place` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`title` VARCHAR(50),
`description` TEXT,
`text` TEXT,
`photo` TEXT,
`idCategory` INT,
`timestamp` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`admin` INT,
`sub` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_694126_project') AS relationships;
