INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 583750_script
#
CREATE DATABASE `db_583750_script`;
USE `db_583750_script`;
CREATE TABLE `clients` (
`id` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`phoneNumber` VARCHAR(50),
`address` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`zip` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`account_type` VARCHAR(50),
`balance` DECIMAL(10,2),
`client_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_583750_script') AS relationships;
