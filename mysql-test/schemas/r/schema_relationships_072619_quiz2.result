INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 072619_quiz2
#
CREATE DATABASE `db_072619_quiz2`;
USE `db_072619_quiz2`;
CREATE TABLE `Student` (
`zid` VARCHAR(50) NOT NULL,
`name` TEXT,
`age` INT,
PRIMARY KEY (`zid`)
) CHARACTER SET latin1;
CREATE TABLE `Class` (
`code` INT NOT NULL,
`name` TEXT,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Enrolment` (
`student` VARCHAR(50) NOT NULL,
`class` INT NOT NULL,
`mark` INT,
PRIMARY KEY (`student`, `class`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_072619_quiz2') AS relationships;
