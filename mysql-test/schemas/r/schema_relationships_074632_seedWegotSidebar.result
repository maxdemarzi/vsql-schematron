USE `db_074632_seedWegotSidebar`;
CREATE TABLE `places` (
`place_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`formatted_address` VARCHAR(50),
`international_phone_number` VARCHAR(50),
`website` TEXT,
`url` TEXT,
`open_now` BOOLEAN,
`lat` DOUBLE,
`lon` DOUBLE,
PRIMARY KEY (`place_id`)
) CHARACTER SET latin1;
CREATE TABLE `openhours` (
`place_id` VARCHAR(50),
`openday` INT,
`opentime` INT,
`closeday` INT,
`closetime` INT,
`weekday_text` VARCHAR(50)
) CHARACTER SET latin1;
