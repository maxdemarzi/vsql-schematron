`estoquemax` INT,
`preco` INT,
`descricao` VARCHAR(50),
`quantidade` INT,
`imagem` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `fornecedores` (
`idFornecedor` INT,
`nome` VARCHAR(50),
`telefone` VARCHAR(50),
`endereço` VARCHAR(50),
`bairro` VARCHAR(50),
`cidade` VARCHAR(50),
`pais` VARCHAR(50)
) CHARACTER SET latin1;
