INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 401613_schema
#
CREATE DATABASE `db_401613_schema`;
USE `db_401613_schema`;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`datebirth` DATE,
`address` VARCHAR(50),
`city` VARCHAR(50),
`district` VARCHAR(50),
`zipcode` VARCHAR(50),
`celphone` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`description` VARCHAR(50),
`quantity` INT,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`datebuy` DATE,
`idcustomer` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `itensorders` (
`id` INT NOT NULL,
`idorder` INT,
`idproduct` INT,
`quantity` INT,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_401613_schema') AS relationships;
relationships
Database: db_401613_schema

Table Connections:
