CREATE DATABASE `db_635051_Section3`;
USE `db_635051_Section3`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT NOT NULL,
`url` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`photo_id` INT,
`user_id` INT,
`contents` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_635051_Section3') AS relationships;
