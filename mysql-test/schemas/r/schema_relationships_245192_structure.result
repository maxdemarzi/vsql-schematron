CREATE DATABASE `db_245192_structure`;
USE `db_245192_structure`;
CREATE TABLE `ar_internal_metadata` (
`key` VARCHAR(50) NOT NULL,
`value` CHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `plays` (
`id` INT NOT NULL,
`track_id` INT,
`played_at` TIMESTAMP NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schema_migrations` (
`version` VARCHAR(50) NOT NULL,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `tracks` (
`id` INT NOT NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`identity` CHAR(50),
`provider` CHAR(50),
`response` VARCHAR(50),
`sha1` CHAR(50),
`name` CHAR(50),
`artist` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_245192_structure') AS relationships;
