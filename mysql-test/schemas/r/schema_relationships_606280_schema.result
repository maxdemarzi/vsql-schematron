INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 606280_schema
#
CREATE DATABASE `db_606280_schema`;
USE `db_606280_schema`;
CREATE TABLE `location` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `checkin` (
`id` VARCHAR(50) NOT NULL,
`location_id` VARCHAR(50),
`user_id` VARCHAR(50),
`time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_606280_schema') AS relationships;
