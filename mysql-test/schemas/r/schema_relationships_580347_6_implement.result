INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 580347_6_implement
#
CREATE DATABASE `db_580347_6_implement`;
USE `db_580347_6_implement`;
CREATE TABLE `races` (
`race_id` INT NOT NULL,
`race_name` VARCHAR(50),
`race_start` DATETIME,
PRIMARY KEY (`race_id`)
) CHARACTER SET latin1;
CREATE TABLE `horses` (
`horse_name` VARCHAR(50) NOT NULL,
PRIMARY KEY (`horse_name`)
) CHARACTER SET latin1;
CREATE TABLE `bets` (
`bet_id` INT NOT NULL,
`bet_amount` SMALLINT,
`race_id` INT,
PRIMARY KEY (`bet_id`)
) CHARACTER SET latin1;
CREATE TABLE `run` (
`race_id` INT,
`horse_name` VARCHAR(50),
`race_horse_number` TINYINT,
`race_horse_rank` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `selected` (
`bet_id` INT,
`horse_name` VARCHAR(50),
`bet_horse_placement` TINYINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_580347_6_implement') AS relationships;
relationships
Database: db_580347_6_implement

Table Connections:
------------------
[Implied]  bets.race_id -> races.race_id
[Implied]  run.horse_name -> horses.horse_name
[Implied]  run.race_id -> races.race_id
