CREATE TABLE `coupon` (
`id` INT NOT NULL,
`code` VARCHAR(50),
`expiry_date` DATETIME,
`availability_count` INT,
`product_id` VARCHAR(50),
`promo_type` VARCHAR(50),
`discount_fixed` DECIMAL(10,2),
`discount_variable` DECIMAL(10,2),
`valid` BOOLEAN,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
`id` INT NOT NULL,
`coupon_id` INT,
`client_id` INT,
`status` VARCHAR(50),
`created_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
