INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 509882_sql-schema
#
CREATE DATABASE `db_509882_sql_schema`;
USE `db_509882_sql_schema`;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_items` (
`id` INT NOT NULL,
`orders_id` INT,
`items_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`cost` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_509882_sql_schema') AS relationships;
relationships
Database: db_509882_sql_schema

Table Connections:
------------------
[Implied]  orders.customer_id -> customers.id
[Implied]  orders_items.items_id -> items.id
[Implied]  orders_items.orders_id -> orders.id

DROP DATABASE `db_509882_sql_schema`;
UNINSTALL EXTENSION vsql_schematron;
