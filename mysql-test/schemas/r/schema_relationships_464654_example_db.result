CREATE DATABASE `db_464654_example_db`;
USE `db_464654_example_db`;
CREATE TABLE `person` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`salary` DECIMAL(10,2),
`status` TINYINT,
`created_at` DATETIME,
`created_by` INT,
`updated_at` DATETIME,
`updated_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`person_id` INT,
`status` TINYINT,
`created_at` DATETIME,
`created_by` INT,
`updated_at` DATETIME,
`updated_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_464654_example_db') AS relationships;
