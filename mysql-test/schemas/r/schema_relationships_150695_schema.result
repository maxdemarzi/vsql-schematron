INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 150695_schema
#
CREATE DATABASE `db_150695_schema`;
USE `db_150695_schema`;
CREATE TABLE `owners` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`address` VARCHAR(50),
`city` VARCHAR(50),
`telephone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rewardpoints` (
`id` VARCHAR(50) NOT NULL,
`owner_id` VARCHAR(50),
`points` INT,
`rewardpoint_date` DATE,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `egifts` (
`id` VARCHAR(50) NOT NULL,
`owner_id` VARCHAR(50),
`egift_id` VARCHAR(50),
`value` INT,
`issued_date` DATE,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_150695_schema') AS relationships;
relationships
