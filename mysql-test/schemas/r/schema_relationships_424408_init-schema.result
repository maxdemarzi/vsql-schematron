CREATE DATABASE `db_424408_init_schema`;
USE `db_424408_init_schema`;
CREATE TABLE `tbl_task` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`completed` BOOLEAN,
`date_created` TIMESTAMP NULL,
`next_task` VARCHAR(50),
`parent_task` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_424408_init_schema') AS relationships;
