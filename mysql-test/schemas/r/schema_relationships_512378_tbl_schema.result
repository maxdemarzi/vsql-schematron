CREATE DATABASE `db_512378_tbl_schema`;
USE `db_512378_tbl_schema`;
CREATE TABLE `tbl_info` (
`id` INT NOT NULL,
`title` TEXT,
`info` TEXT,
`user` TEXT,
`time_added` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_tag` (
`id` INT NOT NULL,
`tag` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_info_tag_ref` (
`id` INT NOT NULL,
`info_id` INT,
`tag_id` INT,
`time_added` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
