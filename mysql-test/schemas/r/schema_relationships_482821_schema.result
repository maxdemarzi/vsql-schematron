INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 482821_schema
#
CREATE DATABASE `db_482821_schema`;
USE `db_482821_schema`;
CREATE TABLE `libraries` (
`id` INT NOT NULL,
`name` TEXT,
`path` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artists` (
`id` INT NOT NULL,
`name` TEXT,
`dirname` TEXT,
`library` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `albums` (
`id` INT NOT NULL,
`name` TEXT,
`artist` INT,
`dirname` TEXT,
`library` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs` (
`id` INT NOT NULL,
`name` TEXT,
`number` INT,
`artist` INT,
`album` INT,
`path` TEXT,
`library` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db_version` (
`version` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_482821_schema') AS relationships;
relationships
Database: db_482821_schema

Table Connections:
------------------
[Implied]  albums.artist -> artists.id
[Implied]  albums.library -> libraries.id
[Implied]  artists.library -> libraries.id
[Implied]  songs.album -> albums.id
[Implied]  songs.artist -> artists.id
[Implied]  songs.library -> libraries.id

DROP DATABASE `db_482821_schema`;
UNINSTALL EXTENSION vsql_schematron;
