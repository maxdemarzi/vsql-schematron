CREATE DATABASE `db_287394_hpai`;
USE `db_287394_hpai`;
CREATE TABLE `t_barang` (
`kode_barang` INT NOT NULL,
`nama_barang` VARCHAR(50),
`harga_barang` VARCHAR(50),
`jenis_barang` VARCHAR(50),
`jumlah_barang` INT,
PRIMARY KEY (`kode_barang`)
) CHARACTER SET latin1;
CREATE TABLE `t_transaksi` (
`id_transaksi` INT,
`t_namaBarang` VARCHAR(50),
`t_transaksi` DATE,
`jumlah` INT,
`kode_barang` INT
) CHARACTER SET latin1;
CREATE TABLE `t_user` (
`id_user` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
