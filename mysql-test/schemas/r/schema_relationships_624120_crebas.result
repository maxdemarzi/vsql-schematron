INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 624120_crebas
#
CREATE DATABASE `db_624120_crebas`;
USE `db_624120_crebas`;
CREATE TABLE `userr` (
`userID` INT NOT NULL,
`userName` VARCHAR(50),
`userPass` VARCHAR(50),
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`custID` VARCHAR(50) NOT NULL,
`userID` INT,
`custName` VARCHAR(50),
`address` VARCHAR(50),
`zip` INT,
`email` VARCHAR(50),
`modTime` DATETIME,
PRIMARY KEY (`custID`)
) CHARACTER SET latin1;
CREATE TABLE `emp` (
`empID` VARCHAR(50) NOT NULL,
`userID` INT,
`empName` VARCHAR(50),
`modTime` DATETIME,
PRIMARY KEY (`empID`)
) CHARACTER SET latin1;
CREATE TABLE `dist` (
`distID` VARCHAR(50) NOT NULL,
`orderID` CHAR(50),
`empID` CHAR(50),
`userID` INT,
`distTime` DATE,
`unit` INT,
`modTime` DATETIME,
PRIMARY KEY (`distID`)
) CHARACTER SET latin1;
CREATE TABLE `recv` (
`recvID` VARCHAR(50) NOT NULL,
`orderID` CHAR(50),
`userID` INT,
`empID` CHAR(50),
`recvTime` DATE,
`modTime` DATETIME,
PRIMARY KEY (`recvID`)
) CHARACTER SET latin1;
CREATE TABLE `questionnaires` (
`questionnarieID` VARCHAR(50) NOT NULL,
`orderID` CHAR(50),
`recvID` CHAR(50),
`analyID` CHAR(50),
`userID` INT,
`distID` CHAR(50),
`fillTime` DATE,
`title` VARCHAR(50),
`filler` VARCHAR(50),
`analyResult` TEXT,
`modTime` DATETIME,
`questionTitle` TEXT,
`answer` TEXT,
PRIMARY KEY (`questionnarieID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_624120_crebas') AS relationships;
relationships
