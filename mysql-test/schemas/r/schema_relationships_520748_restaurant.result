INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 520748_restaurant
#
CREATE DATABASE `db_520748_restaurant`;
USE `db_520748_restaurant`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`image_url` VARCHAR(50),
`place_id` VARCHAR(50),
`formatted_address` VARCHAR(50),
`formatted_phone_number` VARCHAR(50),
`website` VARCHAR(50),
`weekday_text` VARCHAR(50),
`price_level` VARCHAR(50),
`rating` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorites` (
`id` INT NOT NULL,
`user_id` INT,
`restaurants_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_520748_restaurant') AS relationships;
relationships
Database: db_520748_restaurant

