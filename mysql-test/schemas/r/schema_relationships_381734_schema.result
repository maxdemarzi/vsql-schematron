INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 381734_schema
#
CREATE DATABASE `db_381734_schema`;
USE `db_381734_schema`;
CREATE TABLE `character` (
`id` BIGINT NOT NULL,
`idDiscord` BIGINT,
`name` VARCHAR(50),
`background` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `equipment` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`attack` INT,
`defense` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `equipmentCharacter` (
`characterId` BIGINT,
`equipmentId` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_381734_schema') AS relationships;
relationships
Database: db_381734_schema

