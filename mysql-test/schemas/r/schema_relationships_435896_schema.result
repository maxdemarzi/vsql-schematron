INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 435896_schema
#
CREATE DATABASE `db_435896_schema`;
USE `db_435896_schema`;
CREATE TABLE `CUSTOMERS` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`age` INT,
`phone_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
`id` INT NOT NULL,
`date` DATETIME,
`customer_id` INT,
`product_name` VARCHAR(50),
`amount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_435896_schema') AS relationships;
