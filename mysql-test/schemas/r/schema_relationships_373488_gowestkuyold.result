CREATE DATABASE `db_373488_gowestkuyold`;
USE `db_373488_gowestkuyold`;
CREATE TABLE `sepeda` (
`id` INT NOT NULL,
`nama` VARCHAR(50),
`qty` INT,
`harga` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sewa` (
`id` INT,
`trxno` VARCHAR(50),
`tgl_sewa` TIMESTAMP NULL,
`duedays` INT,
`pelanggan` VARCHAR(50),
`nohp` VARCHAR(50),
`alamat` VARCHAR(50),
`sepeda_id` INT,
`total` INT,
`tgl_kembali` TIMESTAMP NULL,
`denda` INT,
`isback` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`nama` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`alamat` VARCHAR(50),
`nohp` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
