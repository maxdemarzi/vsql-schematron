CREATE DATABASE `db_231196_crud_ci4`;
USE `db_231196_crud_ci4`;
CREATE TABLE `books` (
`id` VARCHAR(50),
`status_id` VARCHAR(50),
`title` VARCHAR(50),
`author` VARCHAR(50),
`description` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` VARCHAR(50) NOT NULL,
`version` VARCHAR(50),
`class` TEXT,
`group` VARCHAR(50),
`namespace` VARCHAR(50),
`time` INT,
`batch` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
`id` VARCHAR(50) NOT NULL,
`status` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
