CREATE DATABASE `db_487775_create_db`;
USE `db_487775_create_db`;
CREATE TABLE `planet` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`mass` DECIMAL(10,2),
`diameter` DECIMAL(10,2),
`density` DECIMAL(10,2),
`gravity` DECIMAL(10,2),
`escape_velocity` DECIMAL(10,2),
`rotation_period` DECIMAL(10,2),
`length_of_day` DECIMAL(10,2),
`distance_from_sun` DECIMAL(10,2),
`perihelion` DECIMAL(10,2),
`aphelion` DECIMAL(10,2),
`orbital_period` DECIMAL(10,2),
`orbital_velocity` DECIMAL(10,2),
`orbital_inclination` DECIMAL(10,2),
`orbital_eccentricity` DECIMAL(10,2),
`obliquity_to_orbit` DECIMAL(10,2),
`mean_temperature` DECIMAL(10,2),
`surface_pressure` DECIMAL(10,2),
`number_of_moons` INT,
`has_ring_system` BOOLEAN,
`has_global_magnetic_field` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `satellite` (
`id` INT NOT NULL,
`planet_id` INT,
`name` VARCHAR(50),
`gm` DECIMAL(10,2),
`radius` DECIMAL(10,2),
`density` DECIMAL(10,2),
`magnitude` DECIMAL(10,2),
`albedo` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_487775_create_db') AS relationships;
