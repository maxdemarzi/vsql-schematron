INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 609071_solvee_update_db
#
CREATE DATABASE `db_609071_solvee_update_db`;
USE `db_609071_solvee_update_db`;
CREATE TABLE `districts` (
`id` VARCHAR(50) NOT NULL,
`regency_id` CHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `failed_jobs` (
`id` VARCHAR(50) NOT NULL,
`connection` TEXT,
`queue` TEXT,
`payload` VARCHAR(50),
`exception` VARCHAR(50),
`failed_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` VARCHAR(50) NOT NULL,
`migration` VARCHAR(50),
`batch` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(50),
`token` VARCHAR(50),
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `provinces` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `regencies` (
`id` VARCHAR(50) NOT NULL,
`province_id` CHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `villages` (
`id` VARCHAR(50) NOT NULL,
`district_id` CHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_609071_solvee_update_db') AS relationships;
relationships
Database: db_609071_solvee_update_db

Table Connections:
