CREATE DATABASE `db_155391_db`;
USE `db_155391_db`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(50),
`ip` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `links` (
`token` INT,
`nickname` VARCHAR(50),
`message` VARCHAR(50),
`ip` TEXT,
`user_id` INT,
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_155391_db') AS relationships;
