INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 213828_weblog
#
CREATE DATABASE `db_213828_weblog`;
USE `db_213828_weblog`;
CREATE TABLE `Hosts` (
`id` INT NOT NULL,
`ipaddr` VARCHAR(50),
`hostname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
`id` INT NOT NULL,
`host` INT,
`complete` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Accesses` (
`session` INT NOT NULL,
`seq` INT NOT NULL,
`course` INT,
`page` VARCHAR(50),
`params` VARCHAR(50),
`accTime` TIMESTAMP NULL,
`nbytes` INT,
PRIMARY KEY (`session`, `seq`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_213828_weblog') AS relationships;
relationships
Database: db_213828_weblog

