INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 183057_db
#
CREATE DATABASE `db_183057_db`;
USE `db_183057_db`;
CREATE TABLE `Usuario` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`descripcion` VARCHAR(50),
`correo` VARCHAR(50),
`contrasenia` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Categoria` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Evento` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`ubicacion` VARCHAR(50),
`descripcion` VARCHAR(50),
`fecha` DATETIME,
`categoriaId` INT,
`usuarioId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_183057_db') AS relationships;
relationships
