[Implied]  item.brand_id -> brands.brand_id
[Implied]  item.type_id -> types.type_id
[Implied]  item.user_id -> user.user_id
[Implied]  user_messages.message_id -> message.message_id
[Implied]  user_messages.other_user_id -> user.user_id
[Implied]  user_messages.user_id -> user.user_id

DROP DATABASE `db_110381_estore`;
UNINSTALL EXTENSION vsql_schematron;
