CREATE DATABASE `db_186519_schema`;
USE `db_186519_schema`;
CREATE TABLE `notes` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`note` TEXT,
`creation_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hashtags` (
`id` BIGINT NOT NULL,
`note_id` BIGINT,
`hashtag` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_186519_schema') AS relationships;
