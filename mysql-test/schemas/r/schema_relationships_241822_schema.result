INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 241822_schema
#
CREATE DATABASE `db_241822_schema`;
USE `db_241822_schema`;
CREATE TABLE `Stocks` (
`id` VARCHAR(50) NOT NULL,
`ticker_symbol` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Votes` (
`stock_id` VARCHAR(50),
`date` DATE,
`voter` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
`stock_id` VARCHAR(50),
`date` DATE,
`comment` VARCHAR(50),
`commenter` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_241822_schema') AS relationships;
relationships
