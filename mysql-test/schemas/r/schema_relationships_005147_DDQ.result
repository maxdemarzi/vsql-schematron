INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005147_DDQ
#
CREATE DATABASE `db_005147_DDQ`;
USE `db_005147_DDQ`;
CREATE TABLE `groups` (
`group_id` INT NOT NULL,
`group_name` VARCHAR(50),
`group_discount` DECIMAL(10,2),
PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`group_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `alpacas` (
`alpaca_id` INT NOT NULL,
`alpaca_name` VARCHAR(50),
`age` INT,
`breed` VARCHAR(50),
PRIMARY KEY (`alpaca_id`)
) CHARACTER SET latin1;
CREATE TABLE `experiences` (
`experience_id` INT NOT NULL,
`experience_name` VARCHAR(50),
`experience_price` DECIMAL(10,2),
PRIMARY KEY (`experience_id`)
) CHARACTER SET latin1;
CREATE TABLE `experiences_alpacas` (
`ea_id` INT NOT NULL,
`experience_id` INT,
`alpaca_id` INT,
PRIMARY KEY (`ea_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT NOT NULL,
`customer_id` INT,
`ea_id` INT,
`ticket_quantity` INT,
`order_date` DATE,
`order_subtotal` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005147_DDQ') AS relationships;
relationships
Database: db_005147_DDQ

Table Connections:
------------------
[Implied]  customers.group_id -> groups.group_id
[Implied]  experiences_alpacas.alpaca_id -> alpacas.alpaca_id
[Implied]  experiences_alpacas.experience_id -> experiences.experience_id
[Implied]  orders.customer_id -> customers.customer_id
[Implied]  orders.ea_id -> experiences_alpacas.ea_id

DROP DATABASE `db_005147_DDQ`;
UNINSTALL EXTENSION vsql_schematron;
