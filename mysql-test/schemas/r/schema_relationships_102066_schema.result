INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 102066_schema
#
CREATE DATABASE `db_102066_schema`;
USE `db_102066_schema`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`price` INT,
`description` TEXT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cartItem` (
`id` INT NOT NULL,
`quantity` INT,
`productId` INT,
`orderId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_102066_schema') AS relationships;
relationships
Database: db_102066_schema

Table Connections:
