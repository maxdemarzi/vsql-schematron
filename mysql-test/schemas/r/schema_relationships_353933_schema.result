INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 353933_schema
#
CREATE DATABASE `db_353933_schema`;
USE `db_353933_schema`;
CREATE TABLE `accountNumberDim` (
`id` INT NOT NULL,
`account_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dimDate` (
`date_key` INT NOT NULL,
`date` DATE,
`year` SMALLINT,
`quarter` TINYINT,
`month` TINYINT,
`day` TINYINT,
`week` TINYINT,
`is_weekend` TINYINT,
`is_holiday` TINYINT,
PRIMARY KEY (`date_key`)
) CHARACTER SET latin1;
CREATE TABLE `trxAmountFact` (
`date` INT,
`account_number_id` INT,
`withdrawal_amount` DECIMAL(10,2),
`deposit_amount` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_353933_schema') AS relationships;
