CREATE DATABASE `db_136853_5_edits_up`;
USE `db_136853_5_edits_up`;
CREATE TABLE `edits` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`operation` VARCHAR(50),
`target_type` VARCHAR(50),
`data` VARCHAR(50),
`votes` INT,
`status` VARCHAR(50),
`applied` BOOLEAN,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `edit_comments` (
`id` VARCHAR(50) NOT NULL,
`edit_id` VARCHAR(50),
`user_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`text` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `performer_edits` (
`edit_id` VARCHAR(50),
`performer_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `studio_edits` (
`edit_id` VARCHAR(50),
`studio_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tag_edits` (
`edit_id` VARCHAR(50),
`tag_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `scene_edits` (
`edit_id` VARCHAR(50),
`scene_id` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_136853_5_edits_up') AS relationships;
