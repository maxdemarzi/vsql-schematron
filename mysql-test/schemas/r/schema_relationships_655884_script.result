) CHARACTER SET latin1;
CREATE TABLE `livro` (
`id` INT NOT NULL,
`isbn` VARCHAR(50),
`titulo` VARCHAR(50),
`genero` VARCHAR(50),
`sinopse` VARCHAR(50),
`idAutor` INT,
`idEditora` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
