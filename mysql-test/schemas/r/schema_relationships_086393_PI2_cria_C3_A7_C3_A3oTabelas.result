CREATE TABLE `Pacientes` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`cpf` VARCHAR(50),
`telefone` VARCHAR(50),
`endereco` VARCHAR(50),
`dataNascimento` DATE,
`senha` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Medicos` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`especialidade` VARCHAR(50),
`CRM` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Agenda` (
`id` INT NOT NULL,
`horario` TIME,
`dia` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Agenda_Medico` (
`id` INT NOT NULL,
`idMedico` INT,
`idAgenda` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consulta_paciente` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`medico` VARCHAR(50),
`especialidade` VARCHAR(50),
`horario` TIME,
`dia` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
