`jabatan` VARCHAR(50),
`foto` VARCHAR(50),
`gtk` INT,
`status` INT,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id_gtk`)
) CHARACTER SET latin1;
CREATE TABLE `tb_kurikulum` (
`id_kurikulum` INT NOT NULL,
`kalemik` VARCHAR(50),
