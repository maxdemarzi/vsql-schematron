`alamat` TEXT,
`email` VARCHAR(50),
`telepon` VARCHAR(50),
`head_img` VARCHAR(50),
PRIMARY KEY (`id_setting`)
) CHARACTER SET latin1;
CREATE TABLE `tb_strukturvisimisi` (
`id_strukturvisimisi` INT NOT NULL,
`visi` TEXT,
`misi` TEXT,
`struktur_organisasi` VARCHAR(50),
PRIMARY KEY (`id_strukturvisimisi`)
) CHARACTER SET latin1;
CREATE TABLE `tb_users` (
`id_user` INT NOT NULL,
`username` VARCHAR(50),
