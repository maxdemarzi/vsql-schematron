INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 530293_queries
#
CREATE DATABASE `db_530293_queries`;
USE `db_530293_queries`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progress` (
`id` INT NOT NULL,
`user_id` INT,
`progress_type_id` INT,
`company` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
`comments` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progress_types` (
`id` INT NOT NULL,
`type_name` VARCHAR(50),
`type_points` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_groups` (
`user_id` INT,
`group_id` INT
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`ssid` INT NOT NULL,
`user_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`ssid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_530293_queries') AS relationships;
relationships
Database: db_530293_queries

Table Connections:
------------------
[Implied]  progress.progress_type_id -> progress_types.id
[Implied]  progress.user_id -> users.id
[Implied]  sessions.user_id -> users.id
[Implied]  user_groups.group_id -> groups.id
[Implied]  user_groups.user_id -> users.id

DROP DATABASE `db_530293_queries`;
UNINSTALL EXTENSION vsql_schematron;
