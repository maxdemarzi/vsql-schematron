INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002151_create
#
CREATE DATABASE `db_002151_create`;
USE `db_002151_create`;
CREATE TABLE `towns` (
`town_id` INT NOT NULL,
`town_name` VARCHAR(50),
PRIMARY KEY (`town_id`)
) CHARACTER SET latin1;
CREATE TABLE `airports` (
`airport_id` INT NOT NULL,
`airport_name` VARCHAR(50),
`town_id` INT,
PRIMARY KEY (`airport_id`)
) CHARACTER SET latin1;
CREATE TABLE `airlines` (
`airline_id` INT NOT NULL,
`airline_name` VARCHAR(50),
`nationality` VARCHAR(50),
`rating` INT,
PRIMARY KEY (`airline_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`date_of_birth` DATE,
`gender` VARCHAR(50),
`home_town_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `flights` (
`flight_id` INT NOT NULL,
`departure_time` DATETIME,
`arrival_time` DATETIME,
`status` VARCHAR(50),
`origin_airport_id` INT,
`destination_airport_id` INT,
`airline_id` INT,
PRIMARY KEY (`flight_id`)
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
`ticket_id` INT NOT NULL,
`price` DECIMAL(10,2),
`class` VARCHAR(50),
`seat` VARCHAR(50),
`customer_id` INT,
`flight_id` INT,
PRIMARY KEY (`ticket_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002151_create') AS relationships;
relationships
Database: db_002151_create

