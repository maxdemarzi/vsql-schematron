INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 357186_db_setup
#
CREATE DATABASE `db_357186_db_setup`;
USE `db_357186_db_setup`;
CREATE TABLE `User` (
`user_id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATE,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Categoria` (
`categoria_id` INT NOT NULL,
`user_id` INT,
`titulo` VARCHAR(50),
`descricao` VARCHAR(50),
`cor` VARCHAR(50),
PRIMARY KEY (`categoria_id`)
) CHARACTER SET latin1;
CREATE TABLE `Paciente` (
`paciente_id` INT NOT NULL,
`user_id` INT,
`categoria_id` INT,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`created_at` DATE,
PRIMARY KEY (`paciente_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_357186_db_setup') AS relationships;
relationships
