INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 589862_banco-Integradora
#
CREATE DATABASE `db_589862_banco_Integradora`;
USE `db_589862_banco_Integradora`;
CREATE TABLE `cliente` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`cpf` VARCHAR(50),
`dataNascimento` DATE,
`email` VARCHAR(50),
`telefone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`cpf` VARCHAR(50),
`cargo` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quarto` (
`id` INT NOT NULL,
`tipo` VARCHAR(50),
`valor` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reserva` (
`id` INT NOT NULL,
`id_funcionario` INT,
`id_cliente` INT,
`id_quarto` INT,
`valor` DECIMAL(10,2),
`data` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_589862_banco_Integradora') AS relationships;
relationships
Database: db_589862_banco_Integradora

Table Connections:
------------------
[Implied]  reserva.id_cliente -> cliente.id
[Implied]  reserva.id_funcionario -> funcionario.id
[Implied]  reserva.id_quarto -> quarto.id

DROP DATABASE `db_589862_banco_Integradora`;
UNINSTALL EXTENSION vsql_schematron;
