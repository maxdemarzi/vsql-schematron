CREATE TABLE `preference` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`key` VARCHAR(50),
`description` TEXT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_preferences` (
`user_id` BIGINT NOT NULL,
`preference_id` INT NOT NULL,
`value` VARCHAR(50),
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
PRIMARY KEY (`user_id`, `preference_id`)
) CHARACTER SET latin1;
