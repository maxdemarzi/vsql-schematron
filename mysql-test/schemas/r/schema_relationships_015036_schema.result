INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 015036_schema
#
CREATE DATABASE `db_015036_schema`;
USE `db_015036_schema`;
CREATE TABLE `vets` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialties` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vet_specialties` (
`vet_id` VARCHAR(50),
`specialty_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `types` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owners` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`address` VARCHAR(50),
`city` VARCHAR(50),
`telephone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`birth_date` DATE,
`type_id` VARCHAR(50),
`owner_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
`id` VARCHAR(50) NOT NULL,
`pet_id` VARCHAR(50),
`visit_date` DATE,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_015036_schema') AS relationships;
relationships
Database: db_015036_schema

Table Connections:
------------------
[Implied]  pets.owner_id -> owners.id
[Implied]  pets.type_id -> types.id
[Implied]  vet_specialties.specialty_id -> specialties.id
[Implied]  vet_specialties.vet_id -> vets.id
[Implied]  visits.pet_id -> pets.id

DROP DATABASE `db_015036_schema`;
UNINSTALL EXTENSION vsql_schematron;
