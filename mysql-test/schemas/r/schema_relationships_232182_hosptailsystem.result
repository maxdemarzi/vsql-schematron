INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 232182_hosptailsystem
#
CREATE DATABASE `db_232182_hosptailsystem`;
USE `db_232182_hosptailsystem`;
CREATE TABLE `Specialty` (
`SpatialyId` INT NOT NULL,
`SpatialyName` VARCHAR(50),
PRIMARY KEY (`SpatialyId`)
) CHARACTER SET latin1;
CREATE TABLE `Doctor` (
`DoctorId` INT NOT NULL,
`Name` VARCHAR(50),
`Phone` VARCHAR(50),
`SpatialyId` INT,
PRIMARY KEY (`DoctorId`)
) CHARACTER SET latin1;
CREATE TABLE `Patient` (
`PatientId` INT NOT NULL,
`Name` VARCHAR(50),
`Phone` VARCHAR(50),
`Email` VARCHAR(50),
`Address` VARCHAR(50),
`AddedDate` DATE,
`DoctorId` INT,
PRIMARY KEY (`PatientId`)
) CHARACTER SET latin1;
CREATE TABLE `Allergy` (
`AllergyId` INT NOT NULL,
`AllergyName` VARCHAR(50),
PRIMARY KEY (`AllergyId`)
) CHARACTER SET latin1;
CREATE TABLE `PatientAllergy` (
`AllergyId` INT,
`PatientId` INT
) CHARACTER SET latin1;
CREATE TABLE `Appointment` (
`AppointmentId` INT NOT NULL,
`DoctorId_FK` INT,
`PatientID_KF` INT,
`AppointmentDate` DATE,
`BloodPressure` INT,
`Weight` DOUBLE,
`TreatmentNotes` VARCHAR(50),
PRIMARY KEY (`AppointmentId`)
) CHARACTER SET latin1;
CREATE TABLE `Medicine` (
`MedicineId` INT NOT NULL,
`MedicineName` VARCHAR(50),
PRIMARY KEY (`MedicineId`)
) CHARACTER SET latin1;
CREATE TABLE `PatientMedicine` (
`MedicineId` INT,
`AppointmentId` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_232182_hosptailsystem') AS relationships;
relationships
Database: db_232182_hosptailsystem

Table Connections:
------------------
[Implied]  Appointment.DoctorId_FK -> Doctor.DoctorId
[Implied]  Appointment.PatientID_KF -> Patient.PatientId
[Implied]  Doctor.SpatialyId -> Specialty.SpatialyId
[Implied]  Patient.DoctorId -> Doctor.DoctorId
[Implied]  PatientAllergy.AllergyId -> Allergy.AllergyId
[Implied]  PatientAllergy.PatientId -> Patient.PatientId
[Implied]  PatientMedicine.AppointmentId -> Appointment.AppointmentId
[Implied]  PatientMedicine.MedicineId -> Medicine.MedicineId

DROP DATABASE `db_232182_hosptailsystem`;
UNINSTALL EXTENSION vsql_schematron;
