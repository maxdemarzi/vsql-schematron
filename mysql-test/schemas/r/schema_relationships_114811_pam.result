INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 114811_pam
#
CREATE DATABASE `db_114811_pam`;
USE `db_114811_pam`;
CREATE TABLE `Constant` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`category` VARCHAR(50),
`to_replace` TINYINT,
`valor` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Class` (
`id` VARCHAR(50) NOT NULL,
`class` VARCHAR(50),
`path` VARCHAR(50),
`parameters` VARCHAR(50),
`abstract` VARCHAR(50),
`extends` VARCHAR(50),
`detail` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Property` (
`id` VARCHAR(50) NOT NULL,
`property` VARCHAR(50),
`visibility` VARCHAR(50),
`value_type` VARCHAR(50),
`static` VARCHAR(50),
`class_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Method` (
`id` VARCHAR(50) NOT NULL,
`method` VARCHAR(50),
`visibility` VARCHAR(50),
`parameters` VARCHAR(50),
`return` VARCHAR(50),
`static` VARCHAR(50),
`class_id` VARCHAR(50),
`detail` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_114811_pam') AS relationships;
relationships
