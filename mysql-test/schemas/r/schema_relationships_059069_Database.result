INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 059069_Database
#
CREATE DATABASE `db_059069_Database`;
USE `db_059069_Database`;
CREATE TABLE `Department` (
`ID` INT NOT NULL,
`Name` TEXT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`ID` INT NOT NULL,
`FullName` VARCHAR(50),
`Email` VARCHAR(50),
`Password` VARCHAR(50),
`PhoneNumber` VARCHAR(50),
`Role` VARCHAR(50),
`Wage` DOUBLE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UserDepartment` (
`ID` INT NOT NULL,
`DepartmentID` INT,
`UserID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Cancellation` (
`ID` INT NOT NULL,
`Date` DATE,
`State` VARCHAR(50),
`Subject` TEXT,
`Message` TEXT,
`UserID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Shift` (
`ID` INT NOT NULL,
`Availability` BOOLEAN,
`ShiftDate` DATE,
`StartTime` VARCHAR(50),
`EndTime` VARCHAR(50),
`ShiftType` VARCHAR(50),
`Attended` TINYINT,
`Cancelled` TINYINT,
`AssignedUserID` INT,
`DepartmentID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Availability` (
`ID` INT NOT NULL,
`UserID` INT,
`Available` VARCHAR(50),
`Days` VARCHAR(50),
`IsWeekly` INT,
`IsMonthly` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Image` (
`ID` INT NOT NULL,
`UserID` INT,
`UrlPath` TEXT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Stock` (
`ID` INT NOT NULL,
`Name` TEXT,
`Amount` INT,
`Price` DOUBLE,
`Availability` BOOLEAN,
`DepartmentID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Notification` (
`ID` INT NOT NULL,
`Message` TEXT,
`UserID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_059069_Database') AS relationships;
relationships
