CREATE DATABASE `db_218522_V1_0_0__initial_schema`;
USE `db_218522_V1_0_0__initial_schema`;
CREATE TABLE `brand` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `catalog_item` (
`id` VARCHAR(50) NOT NULL,
`available_stock` INT,
`description` VARCHAR(50),
`name` VARCHAR(50),
`picture_file_name` VARCHAR(50),
`price` DOUBLE,
`brand_id` VARCHAR(50),
`category_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_218522_V1_0_0__initial_schema') AS relationships;
