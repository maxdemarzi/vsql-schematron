INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 006402_init
#
CREATE DATABASE `db_006402_init`;
USE `db_006402_init`;
CREATE TABLE `category` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`location1_id` INT,
`location2_id` INT,
`nickname` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`location_id` INT,
`category_id` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`content` TEXT,
`view_count` INT,
`price` INT,
`seller_id` INT,
`state` VARCHAR(50),
`thumbnail` VARCHAR(50),
`interest_count` INT,
`chatroom_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `interest` (
`id` INT NOT NULL,
`post_id` INT,
`user_id` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`id` INT NOT NULL,
`url` VARCHAR(50),
`post_id` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chatRoom` (
`id` INT NOT NULL,
`post_id` INT,
`seller_id` INT,
`buyer_id` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`last_text` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chat` (
`id` INT NOT NULL,
`room_id` INT,
`text` TEXT,
`user_id` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chatJoined` (
`id` INT NOT NULL,
`room_id` INT,
`user_id` INT,
`unread_count` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_006402_init') AS relationships;
