CREATE DATABASE `db_690079_sql_tutorial`;
USE `db_690079_sql_tutorial`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`species` VARCHAR(50),
`age` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`user_id` INT,
`message` VARCHAR(50),
`posted` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_690079_sql_tutorial') AS relationships;
