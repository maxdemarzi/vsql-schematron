INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 333614_schema
#
CREATE DATABASE `db_333614_schema`;
USE `db_333614_schema`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`slogan` VARCHAR(50),
`description` TEXT,
`category` VARCHAR(50),
`default_price` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `features` (
`id` INT NOT NULL,
`product_id` INT,
`feature` VARCHAR(50),
`value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
`id` INT NOT NULL,
`productId` INT,
`name` VARCHAR(50),
`sale_price` VARCHAR(50),
`original_price` INT,
`default_style` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT NOT NULL,
`styleId` INT,
`url` VARCHAR(50),
`thumbnail_url` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skus` (
`id` INT NOT NULL,
`styleId` INT,
`size` VARCHAR(50),
`quantity` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `related` (
`id` INT NOT NULL,
`current_product_id` INT,
`related_product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_333614_schema') AS relationships;
relationships
Database: db_333614_schema

Table Connections:
------------------
[Implied]  features.product_id -> products.id
[Implied]  photos.styleId -> styles.id
[Implied]  related.current_product_id -> products.id
[Implied]  related.related_product_id -> products.id
[Implied]  skus.styleId -> styles.id
[Implied]  styles.productId -> products.id

DROP DATABASE `db_333614_schema`;
UNINSTALL EXTENSION vsql_schematron;
