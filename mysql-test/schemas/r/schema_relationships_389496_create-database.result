) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`authorId` VARCHAR(50),
`slug` VARCHAR(50),
`content` TEXT,
`createdDateTime` DATETIME,
`publishedDateTime` DATETIME,
`publishedYear` INT,
`publishedMonth` INT,
`postStatusId` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
