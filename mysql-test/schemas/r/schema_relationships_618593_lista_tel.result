CREATE DATABASE `db_618593_lista_tel`;
USE `db_618593_lista_tel`;
CREATE TABLE `segmento` (
`idsegmento` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`idsegmento`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`idusuario` INT NOT NULL,
`email` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`idusuario`)
) CHARACTER SET latin1;
CREATE TABLE `comercio` (
`idcomercio` INT NOT NULL,
`nome_fantasia` VARCHAR(50),
`nome_responsavel` VARCHAR(50),
`telefone` VARCHAR(50),
`instagram` VARCHAR(50),
`facebook` VARCHAR(50),
`aprovado` TINYINT,
`ranking` DOUBLE,
`rua` VARCHAR(50),
`numero` VARCHAR(50),
`complemento` VARCHAR(50),
`CEP` VARCHAR(50),
`site` VARCHAR(50),
`imagem` VARCHAR(50),
`bairro` VARCHAR(50),
`observacao` TEXT,
`usuario_idusuario` INT,
`segmento_idsegmento` INT,
PRIMARY KEY (`idcomercio`)
) CHARACTER SET latin1;
CREATE TABLE `funcionamento` (
`idfuncionamento` INT NOT NULL,
`comercio_idcomercio` INT,
`dia_semana` INT,
`abertura` VARCHAR(50),
`fechamento` VARCHAR(50),
PRIMARY KEY (`idfuncionamento`)
) CHARACTER SET latin1;
CREATE TABLE `sistema` (
`idsistema` INT NOT NULL,
`Titulo_head` VARCHAR(50),
`Titulo_menu` VARCHAR(50),
`Cidade` VARCHAR(50),
PRIMARY KEY (`idsistema`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_618593_lista_tel') AS relationships;
