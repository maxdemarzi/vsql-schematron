CREATE DATABASE `db_367498_srez`;
USE `db_367498_srez`;
CREATE TABLE `category` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(50) NOT NULL,
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `request` (
`id` INT,
`status` VARCHAR(50),
`name` VARCHAR(50),
`before_img` VARCHAR(50),
`after_img` VARCHAR(50),
`why_not` TEXT,
`category_id` INT,
`created_at` DATETIME,
`created_by` INT,
`updated_by` INT
) CHARACTER SET latin1;
