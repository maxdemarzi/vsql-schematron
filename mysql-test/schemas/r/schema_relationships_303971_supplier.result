INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 303971_supplier
#
CREATE DATABASE `db_303971_supplier`;
USE `db_303971_supplier`;
CREATE TABLE `suppliers` (
`sno` INT NOT NULL,
`sname` VARCHAR(50),
`city` VARCHAR(50),
PRIMARY KEY (`sno`)
) CHARACTER SET latin1;
CREATE TABLE `parts` (
`pno` INT NOT NULL,
`pname` VARCHAR(50),
`price` DOUBLE,
PRIMARY KEY (`pno`)
) CHARACTER SET latin1;
CREATE TABLE `supplies` (
`sno` INT,
`pno` INT,
`quantity` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_303971_supplier') AS relationships;
relationships
Database: db_303971_supplier

