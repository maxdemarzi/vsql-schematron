INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 081742_db_schema_pgsql
#
CREATE DATABASE `db_081742_db_schema_pgsql`;
USE `db_081742_db_schema_pgsql`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`created` TIMESTAMP NULL,
`modified` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`slug` VARCHAR(50),
`body` TEXT,
`published` BOOLEAN,
`created` TIMESTAMP NULL,
`modified` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`created` TIMESTAMP NULL,
`modified` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_tags` (
`article_id` INT NOT NULL,
`tag_id` INT NOT NULL,
PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_081742_db_schema_pgsql') AS relationships;
relationships
Database: db_081742_db_schema_pgsql

Table Connections:
------------------
[Implied]  articles.user_id -> users.id
[Implied]  articles_tags.article_id -> articles.id
[Implied]  articles_tags.tag_id -> tags.id

DROP DATABASE `db_081742_db_schema_pgsql`;
