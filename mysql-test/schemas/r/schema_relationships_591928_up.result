INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 591928_up
#
CREATE DATABASE `db_591928_up`;
USE `db_591928_up`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`uuid` BLOB,
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organisations` (
`id` INT NOT NULL,
`uuid` BLOB,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `crates` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`organisation_id` INT,
`readme` TEXT,
`description` VARCHAR(50),
`repository` VARCHAR(50),
`homepage` VARCHAR(50),
`documentation` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_ssh_keys` (
`id` INT NOT NULL,
`uuid` BLOB,
`name` VARCHAR(50),
`user_id` INT,
`ssh_key` BLOB,
`created_at` DATETIME,
`last_used_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_591928_up') AS relationships;
