USE `db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario`;
CREATE TABLE `JOGADOR` (
`IDJOGADOR` INT NOT NULL,
`NOME` VARCHAR(50),
PRIMARY KEY (`IDJOGADOR`)
) CHARACTER SET latin1;
CREATE TABLE `TIMES` (
`IDTIME` INT NOT NULL,
`NOME` VARCHAR(50),
`ID_JOGADOR` INT,
PRIMARY KEY (`IDTIME`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
`IDCLIENTE` INT NOT NULL,
`NOME` VARCHAR(50),
PRIMARY KEY (`IDCLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `TELEFONE` (
`IDTELEFONE` INT,
`TIPO` CHAR(50),
`NUMERO` VARCHAR(50),
`ID_CLIENTE` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario') AS relationships;
