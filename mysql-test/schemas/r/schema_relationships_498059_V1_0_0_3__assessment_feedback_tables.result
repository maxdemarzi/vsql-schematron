CREATE TABLE `assessment` (
`id` INT NOT NULL,
`target_user_id` INT,
`assesment_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feedback` (
`id` INT NOT NULL,
`user_id` INT,
`assessment_id` INT,
`feedback_date` DATETIME,
`score` DECIMAL(10,2),
`comment` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
