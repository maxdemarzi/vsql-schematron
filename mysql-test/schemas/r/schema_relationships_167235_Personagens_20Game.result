CREATE TABLE `tb_classe` (
`id` BIGINT NOT NULL,
`classe` VARCHAR(50),
`descricao` VARCHAR(50),
`genero` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_personagem` (
`id` BIGINT NOT NULL,
`nome` VARCHAR(50),
`ataque` INT,
`defesa` INT,
`classe_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
