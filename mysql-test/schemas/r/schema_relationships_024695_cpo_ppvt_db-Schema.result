CREATE DATABASE `db_024695_cpo_ppvt_db_Schema`;
USE `db_024695_cpo_ppvt_db_Schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_pets` (
`id` INT NOT NULL,
`petname` VARCHAR(50),
`pet_license_no` TEXT,
`license_exp_date` DATE,
`breed` TEXT,
`dob` DATE,
`pet_photo` TEXT,
`pet_license_file` TEXT,
`date_created` DATE,
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet_vaccines` (
`id` INT NOT NULL,
`veterinarian` VARCHAR(50),
`vaccine_name` VARCHAR(50),
`date_of_vaccine` DATE,
`vaccine_exp_date` DATE,
`vaccine_license_file` VARCHAR(50),
`user_id` INT,
`pet_id` INT,
`date_created` DATE,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_024695_cpo_ppvt_db_Schema') AS relationships;
relationships
