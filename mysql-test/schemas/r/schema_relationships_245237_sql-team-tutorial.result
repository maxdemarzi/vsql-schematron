INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 245237_sql-team-tutorial
#
CREATE DATABASE `db_245237_sql_team_tutorial`;
USE `db_245237_sql_team_tutorial`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`age` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`user_id` INT,
`message` VARCHAR(50),
`posted` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_245237_sql_team_tutorial') AS relationships;
