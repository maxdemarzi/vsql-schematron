INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 250555_initdb
#
CREATE DATABASE `db_250555_initdb`;
USE `db_250555_initdb`;
CREATE TABLE `iot.users` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`refresh_token` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `iot.microcontrollers` (
`username` VARCHAR(50),
`ip` VARCHAR(50) NOT NULL,
`measure` VARCHAR(50) NOT NULL,
`sensor` VARCHAR(50),
PRIMARY KEY (`ip`, `measure`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_250555_initdb') AS relationships;
