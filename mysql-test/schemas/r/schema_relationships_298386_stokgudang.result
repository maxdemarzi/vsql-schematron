CREATE DATABASE `db_298386_stokgudang`;
USE `db_298386_stokgudang`;
CREATE TABLE `barang` (
`ID_barang` INT,
`nama_barang` VARCHAR(50),
`jenis_barang` VARCHAR(50),
`harga_barang` INT,
`stok_barang` INT,
`ID_gudang` INT
) CHARACTER SET latin1;
CREATE TABLE `gudang` (
`ID_gudang` INT NOT NULL,
`nama_gudang` VARCHAR(50),
`alamat_gudang` VARCHAR(50),
PRIMARY KEY (`ID_gudang`)
) CHARACTER SET latin1;
CREATE TABLE `pegawai` (
`ID_pegawai` INT,
`nama_pegawai` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`ID_gudang` INT
) CHARACTER SET latin1;
