CREATE DATABASE `db_032718_create`;
USE `db_032718_create`;
CREATE TABLE `payload` (
`id` INT NOT NULL,
`event` VARCHAR(50),
`payload_item_name` TEXT,
`payload_item_url` TEXT,
`payload_created_at` VARCHAR(50),
`created_at` DATETIME,
`downloaded` INT,
`downloaded_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `downloads` (
`id` INT NOT NULL,
`payload_id` INT,
`file_size` VARCHAR(50),
`status_code` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `uploads` (
`id` INT NOT NULL,
`download_id` INT,
`drive_id` TEXT,
`drive_name` TEXT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
