CREATE DATABASE `db_262955_install`;
USE `db_262955_install`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`password` VARCHAR(50),
`created_on` DATETIME,
`updated_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emloyees` (
`id` INT NOT NULL,
`user_id` INT,
`organization_name` VARCHAR(50),
`state_id` INT,
`created_on` DATETIME,
`updated_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_262955_install') AS relationships;
