INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 038438_SQLBefehle
#
CREATE DATABASE `db_038438_SQLBefehle`;
USE `db_038438_SQLBefehle`;
CREATE TABLE `categories` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
`id` VARCHAR(50) NOT NULL,
`a` VARCHAR(50),
`b` VARCHAR(50),
`c` VARCHAR(50),
`d` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`id` VARCHAR(50) NOT NULL,
`question` VARCHAR(50),
`difficulty` INT,
`answer_id` VARCHAR(50),
`solution` INT,
`category_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_038438_SQLBefehle') AS relationships;
