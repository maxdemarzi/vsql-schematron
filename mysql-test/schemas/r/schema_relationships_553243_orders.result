INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 553243_orders
#
CREATE DATABASE `db_553243_orders`;
USE `db_553243_orders`;
CREATE TABLE `SALESMAN` (
`SALESMAN_ID` INT NOT NULL,
`NAME` VARCHAR(50),
`CITY` VARCHAR(50),
`COMMISSION` INT,
PRIMARY KEY (`SALESMAN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`CUSTOMER_ID` INT NOT NULL,
`CUST_NAME` VARCHAR(50),
`CITY` VARCHAR(50),
`GRADE` INT,
`SALESMAN_ID` INT,
PRIMARY KEY (`CUSTOMER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
`ORD_NO` INT NOT NULL,
`PURCHASE_AMT` INT,
`ORD_DATE` DATE,
`CUSTOMER_ID` INT,
`SALESMAN_ID` INT,
PRIMARY KEY (`ORD_NO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_553243_orders') AS relationships;
relationships
Database: db_553243_orders

Table Connections:
