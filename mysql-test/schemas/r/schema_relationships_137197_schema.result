INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 137197_schema
#
CREATE DATABASE `db_137197_schema`;
USE `db_137197_schema`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`category` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`given_name` VARCHAR(50),
`family_name` VARCHAR(50),
`email` VARCHAR(50),
`password` TEXT,
`register_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`customer_id` INT,
`payment_date` DATETIME,
`ship_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_id` INT NOT NULL,
`product_id` INT NOT NULL,
`quantity` SMALLINT,
`price` DECIMAL(10,2),
PRIMARY KEY (`order_id`, `product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_137197_schema') AS relationships;
relationships
Database: db_137197_schema

Table Connections:
------------------
[Implied]  order_items.order_id -> orders.id
[Implied]  order_items.product_id -> products.id
[Implied]  orders.customer_id -> customers.id

DROP DATABASE `db_137197_schema`;
UNINSTALL EXTENSION vsql_schematron;
