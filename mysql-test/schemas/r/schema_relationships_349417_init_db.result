INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 349417_init_db
#
CREATE DATABASE `db_349417_init_db`;
USE `db_349417_init_db`;
CREATE TABLE `SpatialEntity` (
`id` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`geometry` VARCHAR(50),
`validFrom` DATE,
`validTo` DATE,
`entityType` VARCHAR(50),
`color` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Picture` (
`id` DECIMAL(10,2) NOT NULL,
`description` VARCHAR(50),
`pictureType` VARCHAR(50),
`createdAt` DATE,
`spatialEntityId` DECIMAL(10,2),
`img` VARCHAR(50),
`img_si` VARCHAR(50),
`img_ac` VARCHAR(50),
`img_ch` VARCHAR(50),
`img_pc` VARCHAR(50),
`img_tx` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Description` (
`id` DECIMAL(10,2) NOT NULL,
`description` VARCHAR(50),
`validFrom` DATE,
`validTo` DATE,
`spatialEntityId` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BlindMapResult` (
`id` DECIMAL(10,2) NOT NULL,
`person` VARCHAR(50),
`points` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_349417_init_db') AS relationships;
