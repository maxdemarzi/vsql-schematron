`func_departamento` VARCHAR(50),
`func_status` BOOLEAN,
`func_loja_id` INT,
PRIMARY KEY (`func_id`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
`cli_id` INT NOT NULL,
`cli_nome` VARCHAR(50),
`cli_cpf` VARCHAR(50),
`cli_email` VARCHAR(50),
PRIMARY KEY (`cli_id`)
) CHARACTER SET latin1;
