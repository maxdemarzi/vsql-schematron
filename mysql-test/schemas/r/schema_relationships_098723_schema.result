CREATE DATABASE `db_098723_schema`;
USE `db_098723_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activityType` (
`id` INT NOT NULL,
`activityType` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activity` (
`id` INT NOT NULL,
`inputUser` INT,
`activityType` INT,
`activityDescription` TEXT,
`activityLengthSec` INT,
`entryDatetime` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_098723_schema') AS relationships;
