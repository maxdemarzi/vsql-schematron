INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 524558_booking_system
#
CREATE DATABASE `db_524558_booking_system`;
USE `db_524558_booking_system`;
CREATE TABLE `categories` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`slug` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(50),
`slug` VARCHAR(50),
`image` VARCHAR(50),
`price` DOUBLE,
`description` TEXT,
`category_id` INT
) CHARACTER SET latin1;
CREATE TABLE `reservations` (
`id` INT,
`transaction_id` VARCHAR(50),
`date_time` DATETIME,
`no_of_people` INT,
`contact_number` VARCHAR(50),
`status` VARCHAR(50),
`user_id` INT,
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`token` VARCHAR(50),
`active` TINYINT,
`is_admin` TINYINT,
`is_product_manager` TINYINT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_524558_booking_system') AS relationships;
relationships
Database: db_524558_booking_system

Table Connections:
------------------
[Implied]  products.category_id -> categories.id
[Implied]  reservations.user_id -> users.id

DROP DATABASE `db_524558_booking_system`;
UNINSTALL EXTENSION vsql_schematron;
