INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 232334_schema
#
CREATE DATABASE `db_232334_schema`;
USE `db_232334_schema`;
CREATE TABLE `USERS` (
`userid` INT NOT NULL,
`username` VARCHAR(50),
`salt` VARCHAR(50),
`password` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `NOTES` (
`noteid` INT NOT NULL,
`notetitle` VARCHAR(50),
`notedescription` VARCHAR(50),
`userid` INT,
PRIMARY KEY (`noteid`)
) CHARACTER SET latin1;
CREATE TABLE `FILES` (
`fileid` INT NOT NULL,
`filename` VARCHAR(50),
`contenttype` VARCHAR(50),
`filesize` VARCHAR(50),
`filedata` BLOB,
`userid` INT,
PRIMARY KEY (`fileid`)
) CHARACTER SET latin1;
CREATE TABLE `CREDENTIALS` (
`credentialid` INT NOT NULL,
`url` VARCHAR(50),
`username` VARCHAR(50),
`key` VARCHAR(50),
`password` VARCHAR(50),
`userid` INT,
PRIMARY KEY (`credentialid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_232334_schema') AS relationships;
relationships
Database: db_232334_schema

Table Connections:
------------------
[Implied]  CREDENTIALS.userid -> USERS.userid
[Implied]  FILES.userid -> USERS.userid
[Implied]  NOTES.userid -> USERS.userid

DROP DATABASE `db_232334_schema`;
UNINSTALL EXTENSION vsql_schematron;
