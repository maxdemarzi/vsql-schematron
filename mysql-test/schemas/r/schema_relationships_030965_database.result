INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 030965_database
#
CREATE DATABASE `db_030965_database`;
USE `db_030965_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`role` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`description` TEXT,
`image` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`remember_token` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`user_id` INT,
`number_account` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`currency` VARCHAR(50),
`amount` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_030965_database') AS relationships;
relationships
