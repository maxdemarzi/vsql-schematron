) CHARACTER SET latin1;
CREATE TABLE `benutzer` (
`idrfid` INT NOT NULL,
`name` VARCHAR(50),
`vorname` VARCHAR(50),
`guthaben` DOUBLE,
`isAdmin` INT,
`chipid` BIGINT,
PRIMARY KEY (`idrfid`)
) CHARACTER SET latin1;
CREATE TABLE `kauefe` (
`id` INT NOT NULL,
`Datum` DATE,
`benutzer_idrfid` INT,
`Ware_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
