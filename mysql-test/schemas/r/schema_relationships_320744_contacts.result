INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 320744_contacts
#
CREATE DATABASE `db_320744_contacts`;
USE `db_320744_contacts`;
CREATE TABLE `contacts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`active` TINYINT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phones` (
`id` INT NOT NULL,
`contacts_id` INT,
`phone` VARCHAR(50),
`phone_type` INT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone_types` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_320744_contacts') AS relationships;
relationships
