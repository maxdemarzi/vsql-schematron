CREATE DATABASE `db_543564_cocktail`;
USE `db_543564_cocktail`;
CREATE TABLE `cocktail` (
`cocktail_id` INT NOT NULL,
`name` TEXT,
`instructions` TEXT,
`author` TEXT,
PRIMARY KEY (`cocktail_id`)
) CHARACTER SET latin1;
CREATE TABLE `ingridients` (
`ingredient_id` INT NOT NULL,
`name` TEXT,
`size` TEXT,
`cocktail` INT,
PRIMARY KEY (`ingredient_id`)
) CHARACTER SET latin1;
CREATE TABLE `suggested_spirits` (
`spirits_id` INT NOT NULL,
`name` TEXT,
`cocktail` INT,
PRIMARY KEY (`spirits_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_543564_cocktail') AS relationships;
