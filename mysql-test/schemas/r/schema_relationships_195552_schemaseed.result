INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 195552_schemaseed
#
CREATE DATABASE `db_195552_schemaseed`;
USE `db_195552_schemaseed`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` VARCHAR(50),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_195552_schemaseed') AS relationships;
relationships
Database: db_195552_schemaseed

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_195552_schemaseed`;
UNINSTALL EXTENSION vsql_schematron;
