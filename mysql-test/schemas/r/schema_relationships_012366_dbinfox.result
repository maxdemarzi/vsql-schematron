`defeito` VARCHAR(50),
`servico` VARCHAR(50),
`tecnico` VARCHAR(50),
`valor` DECIMAL(10,2),
`idcli` INT
) CHARACTER SET latin1;
CREATE TABLE `tbusuarios` (
`iduser` INT,
`usuario` VARCHAR(50),
`fone` VARCHAR(50),
`login` VARCHAR(50),
`senha` VARCHAR(50),
`perfil` VARCHAR(50)
) CHARACTER SET latin1;
