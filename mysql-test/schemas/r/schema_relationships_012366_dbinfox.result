CREATE TABLE `tbclientes` (
`idcli` INT NOT NULL,
`nomecli` VARCHAR(50),
`endcli` VARCHAR(50),
`fonecli` VARCHAR(50),
`emailcli` VARCHAR(50),
PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
