INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 266683_adventure
#
CREATE DATABASE `db_266683_adventure`;
USE `db_266683_adventure`;
CREATE TABLE `account` (
`uname` VARCHAR(50) NOT NULL,
`email` VARCHAR(50),
`full_name` VARCHAR(50),
`birth_date` DATE,
`pword` VARCHAR(50),
`is_admin` BOOLEAN,
`pic` BLOB,
PRIMARY KEY (`uname`)
) CHARACTER SET latin1;
CREATE TABLE `board` (
`board_title` VARCHAR(50) NOT NULL,
PRIMARY KEY (`board_title`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`post_id` INT NOT NULL,
`post_title` VARCHAR(50),
`post_body` VARCHAR(50),
`uname` VARCHAR(50),
`board_title` VARCHAR(50),
`post_time` DATETIME,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`uname` VARCHAR(50),
`comment_id` INT NOT NULL,
`comment_body` VARCHAR(50),
`post_id` INT,
`comment_time` DATETIME,
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_266683_adventure') AS relationships;
relationships
Database: db_266683_adventure

