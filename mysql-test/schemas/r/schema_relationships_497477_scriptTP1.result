CREATE TABLE `Etudiant` (
`num` INT NOT NULL,
`nom` VARCHAR(50),
`prenom` VARCHAR(50),
`anniversaire` VARCHAR(50),
`niveau` VARCHAR(50),
`groupe` DECIMAL(10,2),
`departement` VARCHAR(50),
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `Cours` (
`num` VARCHAR(50) NOT NULL,
`intitule` VARCHAR(50),
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `moyenneNotation` (
`moyenne` DECIMAL(10,2),
`numEtud` INT NOT NULL,
`numCours` VARCHAR(50) NOT NULL,
PRIMARY KEY (`numEtud`, `numCours`)
) CHARACTER SET latin1;
