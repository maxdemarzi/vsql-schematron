INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 471128_schema
#
CREATE DATABASE `db_471128_schema`;
USE `db_471128_schema`;
CREATE TABLE `addresses` (
`id` INT NOT NULL,
`country` VARCHAR(50),
`city` VARCHAR(50),
`postcode` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`description` VARCHAR(50),
`address_id` INT,
`organization_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_471128_schema') AS relationships;
