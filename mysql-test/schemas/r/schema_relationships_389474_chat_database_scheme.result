CREATE DATABASE `db_389474_chat_database_scheme`;
USE `db_389474_chat_database_scheme`;
CREATE TABLE `USERS` (
`user_id` BIGINT NOT NULL,
`nick_name` VARCHAR(50),
`date_of_create` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `MESSAGES` (
`message_id` BIGINT NOT NULL,
`text` VARCHAR(50),
`date_of_send` DATETIME,
`user_id` BIGINT,
PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_389474_chat_database_scheme') AS relationships;
