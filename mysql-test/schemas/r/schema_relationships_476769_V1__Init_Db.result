CREATE DATABASE `db_476769_V1__Init_Db`;
USE `db_476769_V1__Init_Db`;
CREATE TABLE `company` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`label` VARCHAR(50),
`price` DECIMAL(10,2),
`featured` BOOLEAN,
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`id` INT NOT NULL,
`mimetype` VARCHAR(50),
`data` VARCHAR(50),
`product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `packet` (
`id` INT NOT NULL,
`location` VARCHAR(50),
`size` VARCHAR(50),
`weight` INT,
`barcode` VARCHAR(50),
`product_id` INT,
`order_eid` VARCHAR(50),
`shipment_eid` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_476769_V1__Init_Db') AS relationships;
