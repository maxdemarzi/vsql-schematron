CREATE DATABASE `db_136208_sql_survey_final`;
USE `db_136208_sql_survey_final`;
CREATE TABLE `question` (
`id` INT NOT NULL,
`project_id` INT,
`test_name` VARCHAR(50),
`question` TEXT,
`answer` CHAR(50),
`response1` TEXT,
`response2` TEXT,
`response3` TEXT,
`response4` TEXT,
`response5` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
`question_id` INT NOT NULL,
`student_id` INT NOT NULL,
`answer` CHAR(50),
PRIMARY KEY (`question_id`, `student_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_136208_sql_survey_final') AS relationships;
