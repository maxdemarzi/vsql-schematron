INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 263438_init
#
CREATE DATABASE `db_263438_init`;
USE `db_263438_init`;
CREATE TABLE `image_index` (
`img_id` VARCHAR(50) NOT NULL,
`filename` VARCHAR(50),
`width` INT,
`height` INT,
PRIMARY KEY (`img_id`)
) CHARACTER SET latin1;
CREATE TABLE `image_data` (
`img_data_id` VARCHAR(50) NOT NULL,
`img_id` VARCHAR(50),
`order_x` INT,
`order_y` INT,
`actual_width` INT,
`actual_height` INT,
`width` INT,
`height` INT,
`img_data` BLOB,
PRIMARY KEY (`img_data_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_263438_init') AS relationships;
relationships
