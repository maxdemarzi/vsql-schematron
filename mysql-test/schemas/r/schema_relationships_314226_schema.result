INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 314226_schema
#
CREATE DATABASE `db_314226_schema`;
USE `db_314226_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`password` TEXT,
`role` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`id` INT NOT NULL,
`question` TEXT,
`content` TEXT,
`authorName` TEXT,
`categories` TEXT,
`datePosted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
`id` INT NOT NULL,
`questionId` INT,
`content` TEXT,
`role` TEXT,
`authorName` TEXT,
`datePosted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_314226_schema') AS relationships;
relationships
