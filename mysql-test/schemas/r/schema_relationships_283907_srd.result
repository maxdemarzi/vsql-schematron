INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 283907_srd
#
CREATE DATABASE `db_283907_srd`;
USE `db_283907_srd`;
CREATE TABLE `languages` (
`languages_id` INT NOT NULL,
`name` VARCHAR(50),
`number` DOUBLE,
`repository_id` INT,
PRIMARY KEY (`languages_id`)
) CHARACTER SET latin1;
CREATE TABLE `repository` (
`repository_id` INT NOT NULL,
`name` VARCHAR(50),
`url` VARCHAR(50),
`description` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`repository_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`name` VARCHAR(50),
`location` VARCHAR(50),
`company` VARCHAR(50),
`email` VARCHAR(50),
`bio` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_283907_srd') AS relationships;
