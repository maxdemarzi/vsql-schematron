INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 688180_desa
#
CREATE DATABASE `db_688180_desa`;
USE `db_688180_desa`;
CREATE TABLE `berita` (
`id_berita` INT NOT NULL,
`judul` VARCHAR(50),
`keterangan` TEXT,
`tanggal` DATE,
`foto_berita` VARCHAR(50),
PRIMARY KEY (`id_berita`)
) CHARACTER SET latin1;
CREATE TABLE `galeri` (
`id_galeri` INT NOT NULL,
`keterangan` VARCHAR(50),
`tanggal` DATE,
`foto` VARCHAR(50),
PRIMARY KEY (`id_galeri`)
) CHARACTER SET latin1;
CREATE TABLE `pegawai` (
`id_pegawai` INT,
`id_penduduk` INT,
`jabatan` VARCHAR(50),
`no_hp` VARCHAR(50),
`foto` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `penduduk` (
`id_penduduk` INT NOT NULL,
`NIK` VARCHAR(50),
`no_KK` VARCHAR(50),
`nama` VARCHAR(50),
`tempat_lahir` VARCHAR(50),
`tanggal_lahir` DATE,
`agama` VARCHAR(50),
`status_perkawinan` VARCHAR(50),
`pekerjaan` VARCHAR(50),
`gol_darah` VARCHAR(50),
`jenis_kelamin` VARCHAR(50),
`alamat` VARCHAR(50),
`RT` VARCHAR(50),
`RW` VARCHAR(50),
`desa` VARCHAR(50),
`Kecamatan` VARCHAR(50),
`foto` VARCHAR(50),
`password` VARCHAR(50),
`hak_akses` VARCHAR(50),
PRIMARY KEY (`id_penduduk`)
) CHARACTER SET latin1;
CREATE TABLE `pengaduan` (
`id_pengaduan` INT,
`id_penduduk` INT,
`jenis_pengaduan` VARCHAR(50),
`tanggal` DATE,
`alasan` TEXT,
`keterangan` TEXT,
`bukti` VARCHAR(50),
`status` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_688180_desa') AS relationships;
relationships
