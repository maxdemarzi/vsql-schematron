USE `db_072603_1`;
CREATE TABLE `users` (
`user_id` VARCHAR(50) NOT NULL,
`name` TEXT,
`last_name` TEXT,
`email` VARCHAR(50),
`password` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_logs` (
`user_log_id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`message` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`user_log_id`)
) CHARACTER SET latin1;
