INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 113732_Database
#
CREATE DATABASE `db_113732_Database`;
USE `db_113732_Database`;
CREATE TABLE `KHACHHANG` (
`MAKH` INT NOT NULL,
`HOTEN` VARCHAR(50),
`SOCMND` CHAR(50),
`NGAYDEN` DATE,
`MAPHONG` CHAR(50),
`TinhTrangTT` VARCHAR(50),
PRIMARY KEY (`MAKH`)
) CHARACTER SET latin1;
CREATE TABLE `PHONG` (
`MAPHONG` VARCHAR(50) NOT NULL,
`SOGIUONG` INT,
`DONGIA` INT,
`TINHTRANG` VARCHAR(50),
PRIMARY KEY (`MAPHONG`)
) CHARACTER SET latin1;
CREATE TABLE `THONGKEGIAODICH` (
`MAGD` INT NOT NULL,
`MAKH` INT,
`MAPHONG` CHAR(50),
`NGAYDEN` DATETIME,
`NGAYDI` DATE,
`SOTIENDATHANHTOAN` INT,
PRIMARY KEY (`MAGD`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
`TaiKhoan` VARCHAR(50),
`MatKhau` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_113732_Database') AS relationships;
relationships
