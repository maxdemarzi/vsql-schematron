INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 093349_vr-collaboration-room-db-dev
#
CREATE DATABASE `db_093349_vr_collaboration_room_db_dev`;
USE `db_093349_vr_collaboration_room_db_dev`;
CREATE TABLE `User` (
`userID` INT NOT NULL,
`username` VARCHAR(50),
`userEmail` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `Model` (
`modelID` INT NOT NULL,
`uploaded` BLOB,
`dateUploaded` DATE,
`name` VARCHAR(50),
`userID` INT,
PRIMARY KEY (`modelID`)
) CHARACTER SET latin1;
CREATE TABLE `Server` (
`serverID` INT NOT NULL,
`hostIP` VARCHAR(50),
`hostPort` INT,
`isAllocated` VARCHAR(50),
PRIMARY KEY (`serverID`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`sessionID` INT NOT NULL,
`sessionName` VARCHAR(50),
`mapName` VARCHAR(50),
`maxParticipants` INT,
`serverID` INT,
`hostUserID` INT,
`participantCount` INT,
PRIMARY KEY (`sessionID`)
) CHARACTER SET latin1;
CREATE TABLE `Invited_Participant` (
`userID` INT,
`sessionID` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_093349_vr_collaboration_room_db_dev') AS relationships;
relationships
Database: db_093349_vr_collaboration_room_db_dev

Table Connections:
