CREATE DATABASE `db_541197_database`;
USE `db_541197_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`rol` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`content` TEXT,
`priority` VARCHAR(50),
`hours` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_541197_database') AS relationships;
