INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 576885_citask
#
CREATE DATABASE `db_576885_citask`;
USE `db_576885_citask`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`dept` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sub_department` (
`id` INT,
`id_dept` INT,
`sub_dept` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`email` VARCHAR(50),
`pwd` VARCHAR(50),
`profile` TEXT,
`dept` VARCHAR(50),
`subdept` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_576885_citask') AS relationships;
