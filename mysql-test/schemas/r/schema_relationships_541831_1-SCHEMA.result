INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 541831_1-SCHEMA
#
CREATE DATABASE `db_541831_1_SCHEMA`;
USE `db_541831_1_SCHEMA`;
CREATE TABLE `company` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `computer` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`introduced` TIMESTAMP NULL,
`discontinued` TIMESTAMP NULL,
`company_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`login` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`role` VARCHAR(50),
`active` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_541831_1_SCHEMA') AS relationships;
relationships
