CREATE TABLE `job` (
`id` VARCHAR(50) NOT NULL,
`type` VARCHAR(50),
`payload` VARCHAR(50),
`parameter` VARCHAR(50),
`status` VARCHAR(50),
`attempt` VARCHAR(50),
`activeState` VARCHAR(50),
`updated` DATETIME,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jobHistory` (
`id` VARCHAR(50) NOT NULL,
`jobId` VARCHAR(50),
`message` VARCHAR(50),
`additionalData` VARCHAR(50),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
