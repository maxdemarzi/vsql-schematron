CREATE DATABASE `db_445718_db_SistemaComletoOS`;
USE `db_445718_db_SistemaComletoOS`;
CREATE TABLE `tbusuarios` (
`iduser` INT NOT NULL,
`usuario` VARCHAR(50),
`fone` VARCHAR(50),
`login` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `tbclientes` (
`idcli` INT NOT NULL,
`nomecli` VARCHAR(50),
`endcli` VARCHAR(50),
`fonecli` VARCHAR(50),
`emailcli` VARCHAR(50),
PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
`os` INT NOT NULL,
`data_os` TIMESTAMP NULL,
`equipamento` VARCHAR(50),
`defeito` VARCHAR(50),
`servico` VARCHAR(50),
`tecnico` VARCHAR(50),
`valor` DECIMAL(10,2),
`idcli` INT,
PRIMARY KEY (`os`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_445718_db_SistemaComletoOS') AS relationships;
