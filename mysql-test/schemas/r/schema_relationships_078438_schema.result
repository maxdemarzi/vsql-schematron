CREATE TABLE `PERSON` (
`PERSON_ID` BIGINT NOT NULL,
`FIRST_NAME` VARCHAR(50),
`LAST_NAME` VARCHAR(50),
`EMAIL_ADDRESS` VARCHAR(50),
PRIMARY KEY (`PERSON_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
`ITEM_ID` BIGINT NOT NULL,
`NAME` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`MANUFACTURER` VARCHAR(50),
`MODEL` VARCHAR(50),
`QUANTITY` INT,
`PERSON_ID` BIGINT,
PRIMARY KEY (`ITEM_ID`)
) CHARACTER SET latin1;
