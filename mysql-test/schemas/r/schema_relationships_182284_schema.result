INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 182284_schema
#
CREATE DATABASE `db_182284_schema`;
USE `db_182284_schema`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`linkedid` VARCHAR(50),
`serializedprofile` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`phone` VARCHAR(50),
`postal_address` VARCHAR(50),
`favourite` BOOLEAN,
`created_at` TIMESTAMP NULL,
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_182284_schema') AS relationships;
relationships
