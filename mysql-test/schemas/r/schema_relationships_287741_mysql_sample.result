INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 287741_mysql_sample
#
CREATE DATABASE `db_287741_mysql_sample`;
USE `db_287741_mysql_sample`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`uuid` VARCHAR(50),
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_keys` (
`id` INT NOT NULL,
`token_type` VARCHAR(50),
`token` VARCHAR(50),
`refresh_token` VARCHAR(50),
`user_id` INT,
`expires_at` DATETIME,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signature_keys` (
`id` INT NOT NULL,
`signature_key` VARCHAR(50),
`user_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `infos` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`category` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_287741_mysql_sample') AS relationships;
relationships
