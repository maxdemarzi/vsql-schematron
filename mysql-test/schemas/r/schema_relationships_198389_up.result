INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 198389_up
#
CREATE DATABASE `db_198389_up`;
USE `db_198389_up`;
CREATE TABLE `galleries` (
`id` INT NOT NULL,
`kind` INT,
`name` TEXT,
`description` TEXT,
`uuid` BLOB,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resources` (
`id` INT NOT NULL,
`filepath` TEXT,
`kind` INT,
`mime` TEXT,
`uuid` BLOB,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gallery_items` (
`id` INT NOT NULL,
`gallery` INT,
`resource` INT,
`kind` INT,
`name` TEXT,
`description` TEXT,
`uuid` BLOB,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_198389_up') AS relationships;
