CREATE DATABASE `db_531350_database`;
USE `db_531350_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`importance` VARCHAR(50),
`description` TEXT,
`completed` BOOLEAN,
`userid` INT,
`created_time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_531350_database') AS relationships;
