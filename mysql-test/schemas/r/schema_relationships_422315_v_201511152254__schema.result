CREATE DATABASE `db_422315_v_201511152254__schema`;
USE `db_422315_v_201511152254__schema`;
CREATE TABLE `comment` (
`id` BIGINT NOT NULL,
`content` VARCHAR(50),
`at` DATETIME,
`post_id` BIGINT,
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` BIGINT NOT NULL,
`body` VARCHAR(50),
`subject` VARCHAR(50),
`at` DATETIME,
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tags` (
`post_id` BIGINT,
`tags` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`email` VARCHAR(50),
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
