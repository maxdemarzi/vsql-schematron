CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`name` TEXT,
`email` TEXT,
`hashed_password` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lists` (
`id` BIGINT NOT NULL,
`name` TEXT,
`user_id` BIGINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` BIGINT NOT NULL,
`name` TEXT,
`source` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `list_items` (
`id` BIGINT NOT NULL,
`quantity` BIGINT,
`collected` BOOLEAN,
`list_id` BIGINT,
`item_id` BIGINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
