INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 052304_init
#
CREATE DATABASE `db_052304_init`;
USE `db_052304_init`;
CREATE TABLE `user` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `remind` (
`remind_id` INT NOT NULL,
`user_id` INT,
`description` VARCHAR(50),
`priority` INT,
`remind_time` DATETIME,
`complete_flag` BOOLEAN,
PRIMARY KEY (`remind_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_052304_init') AS relationships;
