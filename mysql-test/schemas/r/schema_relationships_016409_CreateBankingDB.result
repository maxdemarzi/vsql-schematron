CREATE TABLE `business` (
`INCORP_DATE` DATE,
`NAME` VARCHAR(50),
`STATE_ID` VARCHAR(50),
`CUST_ID` INT NOT NULL,
PRIMARY KEY (`CUST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `individual` (
`BIRTH_DATE` DATE,
`FIRST_NAME` VARCHAR(50),
`LAST_NAME` VARCHAR(50),
`CUST_ID` INT NOT NULL,
PRIMARY KEY (`CUST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`PRODUCT_CD` VARCHAR(50) NOT NULL,
`DATE_OFFERED` DATE,
`DATE_RETIRED` DATE,
`NAME` VARCHAR(50),
`PRODUCT_TYPE_CD` VARCHAR(50),
PRIMARY KEY (`PRODUCT_CD`)
) CHARACTER SET latin1;
CREATE TABLE `product_type` (
`PRODUCT_TYPE_CD` VARCHAR(50) NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`PRODUCT_TYPE_CD`)
) CHARACTER SET latin1;
