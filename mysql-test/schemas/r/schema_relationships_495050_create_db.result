INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 495050_create_db
#
CREATE DATABASE `db_495050_create_db`;
USE `db_495050_create_db`;
CREATE TABLE `films` (
`film_id` INT NOT NULL,
`film_name` VARCHAR(50),
`film_desc` VARCHAR(50),
PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_shows` (
`show_id` INT NOT NULL,
`film_id` INT,
`start_time` DATETIME,
`end_time` DATETIME,
`price` INT,
`is_active` BOOLEAN,
PRIMARY KEY (`show_id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
`booking_id` INT NOT NULL,
`show_id` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`booking_id`)
) CHARACTER SET latin1;
CREATE TABLE `booked_places` (
`booking_id` INT NOT NULL,
`place_number` INT NOT NULL,
PRIMARY KEY (`booking_id`, `place_number`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_495050_create_db') AS relationships;
relationships
