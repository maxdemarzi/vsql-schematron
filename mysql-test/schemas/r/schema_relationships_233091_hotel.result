INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 233091_hotel
#
CREATE DATABASE `db_233091_hotel`;
USE `db_233091_hotel`;
CREATE TABLE `booking` (
`id_boking` INT,
`id_kamar` INT,
`nama_customer` VARCHAR(50),
`no_telp` VARCHAR(50),
`tgl_in` DATETIME,
`tgl_out` DATETIME,
`pembayaran` VARCHAR(50),
`status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `fasilitas` (
`id_fasilitas` INT NOT NULL,
`fasilitas` VARCHAR(50),
PRIMARY KEY (`id_fasilitas`)
) CHARACTER SET latin1;
CREATE TABLE `kamar` (
`id_kamar` INT,
`id_fasilitas` INT,
`stok` INT,
`jenis_kamar` VARCHAR(50),
`harga` INT
) CHARACTER SET latin1;
CREATE TABLE `login` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_233091_hotel') AS relationships;
