CREATE DATABASE `db_202352_db_script`;
USE `db_202352_db_script`;
CREATE TABLE `user` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `todo_item` (
`id` INT NOT NULL,
`text` VARCHAR(50),
`priority` VARCHAR(50),
`status` VARCHAR(50),
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_202352_db_script') AS relationships;
