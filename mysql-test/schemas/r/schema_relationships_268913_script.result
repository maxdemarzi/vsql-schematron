INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 268913_script
#
CREATE DATABASE `db_268913_script`;
USE `db_268913_script`;
CREATE TABLE `proveedor` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`direccion` VARCHAR(50),
`telefono` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cliente` (
`cedula` VARCHAR(50) NOT NULL,
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`telefono` VARCHAR(50),
`direccion` VARCHAR(50),
`correoe` VARCHAR(50),
PRIMARY KEY (`cedula`)
) CHARACTER SET latin1;
CREATE TABLE `producto` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`descripcion` VARCHAR(50),
`precio_compra` DOUBLE,
`precio_venta` DOUBLE,
`cantidad` INT,
`cantidad_minima_stock` INT,
`proveedor_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `factura_producto` (
`factura_id` INT NOT NULL,
`producto_id` INT NOT NULL,
`cantidad` INT,
PRIMARY KEY (`factura_id`, `producto_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_268913_script') AS relationships;
relationships
Database: db_268913_script

