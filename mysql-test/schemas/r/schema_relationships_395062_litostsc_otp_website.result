INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 395062_litostsc_otp_website
#
CREATE DATABASE `db_395062_litostsc_otp_website`;
USE `db_395062_litostsc_otp_website`;
CREATE TABLE `medication` (
`Id` INT,
`medication_name` VARCHAR(50),
`dosage` VARCHAR(50),
`user_id` INT,
`once_day` VARCHAR(50),
`once_month` VARCHAR(50),
`meal` TINYINT,
`once_date` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `times` (
`Id` INT,
`medication_id` INT,
`time` TIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`Id` INT NOT NULL,
`phone_number` VARCHAR(50),
`password` VARCHAR(50),
`UTC_val` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `week` (
`Id` INT,
`medication_id` INT,
`week` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_395062_litostsc_otp_website') AS relationships;
relationships
