`last_name` TEXT,
`password_hash` TEXT,
`created_date` TIMESTAMP NULL,
`updated_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` BIGINT NOT NULL,
`name` TEXT,
`type` TEXT,
`created_date` TIMESTAMP NULL,
`updated_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `memberships` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`account_id` BIGINT,
`role` TEXT,
`created_date` TIMESTAMP NULL,
`updated_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `invalidated_tokens` (
`id` BIGINT NOT NULL,
`value` TEXT,
`user_id` BIGINT,
`created_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
