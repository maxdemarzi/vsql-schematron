INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 141724_data
#
CREATE DATABASE `db_141724_data`;
USE `db_141724_data`;
CREATE TABLE `Customer` (
`email` VARCHAR(50) NOT NULL,
`firstName` CHAR(50),
`lastName` CHAR(50),
PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
`eID` INT NOT NULL,
`firstName` CHAR(50),
`lastName` CHAR(50),
PRIMARY KEY (`eID`)
) CHARACTER SET latin1;
CREATE TABLE `Process_Purchase_Membership` (
`mID` INT NOT NULL,
`cost` DOUBLE,
`email` CHAR(50),
`purchaseDate` DATE,
`confirmationNum` INT,
`eID` INT,
PRIMARY KEY (`mID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_141724_data') AS relationships;
relationships
