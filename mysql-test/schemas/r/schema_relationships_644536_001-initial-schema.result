INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 644536_001-initial-schema
#
CREATE DATABASE `db_644536_001_initial_schema`;
USE `db_644536_001_initial_schema`;
CREATE TABLE `Sensor` (
`name` VARCHAR(50) NOT NULL,
`firstonline` TEXT,
`lastonline` TEXT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `Reading` (
`id` INT NOT NULL,
`sensorname` TEXT,
`temperature` DECIMAL(10,2),
`pressure` DECIMAL(10,2),
`humidity` DECIMAL(10,2),
`timestamp` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_644536_001_initial_schema') AS relationships;
