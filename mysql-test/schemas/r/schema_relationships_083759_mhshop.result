INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 083759_mhshop
#
CREATE DATABASE `db_083759_mhshop`;
USE `db_083759_mhshop`;
CREATE TABLE `admin-customer` (
`id` INT NOT NULL,
`password` VARCHAR(50),
`is_admin` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categroy` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`image_url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`name` VARCHAR(50),
`type` VARCHAR(50),
`price` DOUBLE,
`image` VARCHAR(50),
`categroy_id` INT,
`discount` DOUBLE
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_083759_mhshop') AS relationships;
relationships
