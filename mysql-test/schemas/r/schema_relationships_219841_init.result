CREATE DATABASE `db_219841_init`;
USE `db_219841_init`;
CREATE TABLE `messages` (
`id` INT NOT NULL,
`text` VARCHAR(50),
`contact_number` VARCHAR(50),
`media` VARCHAR(50),
`conversation_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conversations` (
`id` INT NOT NULL,
`started_at` DATETIME,
`finished_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_219841_init') AS relationships;
