) CHARACTER SET latin1;
CREATE TABLE `rpt.payout_state` (
`id` BIGINT NOT NULL,
`event_id` BIGINT,
`event_created_at` TIMESTAMP NULL,
`payout_id` CHAR(50),
`ext_payout_id` CHAR(50),
`status` VARCHAR(50),
`cancel_details` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
