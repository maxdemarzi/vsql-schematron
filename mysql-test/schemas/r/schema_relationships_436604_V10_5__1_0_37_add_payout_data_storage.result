`created_at` TIMESTAMP NULL,
`amount` BIGINT,
`fee` BIGINT,
`currency_code` CHAR(50),
`type` VARCHAR(50),
`wallet_id` CHAR(50),
`summary` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rpt.payout_account` (
`ext_payout_id` BIGINT NOT NULL,
