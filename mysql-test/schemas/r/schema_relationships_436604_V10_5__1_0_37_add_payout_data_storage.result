`registered_address` CHAR(50),
`registered_number` CHAR(50),
`bank_iban` CHAR(50),
`bank_number` CHAR(50),
`bank_address` CHAR(50),
`bank_bic` CHAR(50),
`bank_aba_rtn` CHAR(50),
`bank_country_code` CHAR(50),
PRIMARY KEY (`ext_payout_id`)
) CHARACTER SET latin1;
CREATE TABLE `rpt.payout_international_account` (
`ext_payout_id` BIGINT NOT NULL,
