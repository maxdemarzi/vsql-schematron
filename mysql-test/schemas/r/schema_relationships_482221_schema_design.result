INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 482221_schema_design
#
CREATE DATABASE `db_482221_schema_design`;
USE `db_482221_schema_design`;
CREATE TABLE `user_account` (
`username` VARCHAR(50) NOT NULL,
`pwd` VARCHAR(50),
`profile_pic` TEXT,
`bio` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`post_id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`title` VARCHAR(50),
`content` TEXT,
`post_time` TIMESTAMP NULL,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `liked` (
`username` VARCHAR(50),
`post_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `follow` (
`this_username` VARCHAR(50),
`following_username` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_482221_schema_design') AS relationships;
relationships
Database: db_482221_schema_design

Table Connections:
------------------
[Implied]  follow.following_username -> user_account.username
[Implied]  follow.this_username -> user_account.username
[Implied]  liked.post_id -> post.post_id
[Implied]  liked.username -> user_account.username
[Implied]  post.username -> user_account.username

DROP DATABASE `db_482221_schema_design`;
UNINSTALL EXTENSION vsql_schematron;
