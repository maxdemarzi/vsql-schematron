INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 296206_initDB
#
CREATE DATABASE `db_296206_initDB`;
USE `db_296206_initDB`;
CREATE TABLE `Schedules` (
`scheduleID` INT NOT NULL,
`schedule_name` VARCHAR(50),
`schedule_description` VARCHAR(50),
PRIMARY KEY (`scheduleID`)
) CHARACTER SET latin1;
CREATE TABLE `Transitions` (
`transitionID` INT NOT NULL,
`scheduleID` INT,
`transition_offset` INT,
`transition_state` VARCHAR(50),
PRIMARY KEY (`transitionID`)
) CHARACTER SET latin1;
CREATE TABLE `Sensors` (
`sensorID` INT NOT NULL,
`sensor_name` VARCHAR(50),
`sensor_description` VARCHAR(50),
`sensor_value` INT,
`sensor_readtime` TIMESTAMP NULL,
PRIMARY KEY (`sensorID`)
) CHARACTER SET latin1;
CREATE TABLE `Channels` (
`channelID` INT NOT NULL,
`channel_name` VARCHAR(50),
`channel_description` VARCHAR(50),
`scheduleID` INT,
`sensorID` INT,
`channel_enabled` VARCHAR(50),
`channel_state` VARCHAR(50),
PRIMARY KEY (`channelID`)
) CHARACTER SET latin1;
CREATE TABLE `TokenQ` (
`tokenID` INT NOT NULL,
`token` VARCHAR(50),
`type` VARCHAR(50),
`value` INT,
PRIMARY KEY (`tokenID`)
) CHARACTER SET latin1;
CREATE TABLE `commandQ` (
`commandID` INT NOT NULL,
`command` VARCHAR(50),
PRIMARY KEY (`commandID`)
) CHARACTER SET latin1;
CREATE TABLE `KeyWords` (
`keywordID` INT NOT NULL,
`keyword` VARCHAR(50),
`description` VARCHAR(50),
`keycode` INT,
PRIMARY KEY (`keywordID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_296206_initDB') AS relationships;
relationships
Database: db_296206_initDB

Table Connections:
