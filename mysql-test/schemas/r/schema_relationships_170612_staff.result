) CHARACTER SET latin1;
CREATE TABLE `objects_to_groups_acl` (
`id` INT NOT NULL,
`objectid` INT,
`groupid` INT,
`permit` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `settings` (
`id` INT NOT NULL,
`name` TEXT,
`value` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
