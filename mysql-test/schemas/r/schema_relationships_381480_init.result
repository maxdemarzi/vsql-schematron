INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 381480_init
#
CREATE DATABASE `db_381480_init`;
USE `db_381480_init`;
CREATE TABLE `stock` (
`id` INT NOT NULL,
`symbol` TEXT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ohlc_data` (
`id` INT NOT NULL,
`dt` TIMESTAMP NULL,
`stock_id` INT,
`open` DECIMAL(10,2),
`high` DECIMAL(10,2),
`low` DECIMAL(10,2),
`close` DECIMAL(10,2),
`volume` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tick_data` (
`id` INT NOT NULL,
`dt` TIMESTAMP NULL,
`stock_id` INT,
`bid` DECIMAL(10,2),
`ask` DECIMAL(10,2),
`ltp` DECIMAL(10,2),
`ltv` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_381480_init') AS relationships;
relationships
Database: db_381480_init

Table Connections:
------------------
[Implied]  ohlc_data.stock_id -> stock.id
[Implied]  tick_data.stock_id -> stock.id

DROP DATABASE `db_381480_init`;
UNINSTALL EXTENSION vsql_schematron;
