INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 606812_petclinic_db
#
CREATE DATABASE `db_606812_petclinic_db`;
USE `db_606812_petclinic_db`;
CREATE TABLE `owners` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`address` VARCHAR(50),
`city` VARCHAR(50),
`telephone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`birth_date` DATE,
`type_id` VARCHAR(50),
`owner_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialties` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `types` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`enabled` TINYINT,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `vets` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
`id` VARCHAR(50) NOT NULL,
`pet_id` VARCHAR(50),
`visit_date` DATE,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_606812_petclinic_db') AS relationships;
relationships
Database: db_606812_petclinic_db

Table Connections:
------------------
[Implied]  pets.owner_id -> owners.id
[Implied]  pets.type_id -> types.id
[Implied]  visits.pet_id -> pets.id

DROP DATABASE `db_606812_petclinic_db`;
UNINSTALL EXTENSION vsql_schematron;
