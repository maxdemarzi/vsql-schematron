INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 092563_territorial_hierarchy
#
CREATE DATABASE `db_092563_territorial_hierarchy`;
USE `db_092563_territorial_hierarchy`;
CREATE TABLE `District` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Municipality` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`district` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Town` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`municipality` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_092563_territorial_hierarchy') AS relationships;
relationships
Database: db_092563_territorial_hierarchy

Table Connections:
------------------
[Implied]  Municipality.district -> District.id
[Implied]  Town.municipality -> Municipality.id

DROP DATABASE `db_092563_territorial_hierarchy`;
UNINSTALL EXTENSION vsql_schematron;
