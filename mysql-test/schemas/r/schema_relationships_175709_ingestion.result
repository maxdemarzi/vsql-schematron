CREATE DATABASE `db_175709_ingestion`;
USE `db_175709_ingestion`;
CREATE TABLE `subreddits` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`post_id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`date` DATE,
`subreddit` CHAR(50),
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_175709_ingestion') AS relationships;
