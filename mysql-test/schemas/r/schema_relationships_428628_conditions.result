CREATE DATABASE `db_428628_conditions`;
USE `db_428628_conditions`;
CREATE TABLE `locations` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`environment` VARCHAR(50),
`device` VARCHAR(50),
`sensor_type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conditions` (
`time` TIMESTAMP NULL,
`location_id` INT,
`temperature` DOUBLE,
`humidity` DOUBLE
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_428628_conditions') AS relationships;
