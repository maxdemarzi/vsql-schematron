INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 662255_lab2
#
CREATE DATABASE `db_662255_lab2`;
USE `db_662255_lab2`;
CREATE TABLE `actor` (
`ACTID` INT NOT NULL,
`ANAME` VARCHAR(50),
`SEX` VARCHAR(50),
`BYEAR` INT,
PRIMARY KEY (`ACTID`)
) CHARACTER SET latin1;
CREATE TABLE `film` (
`FID` INT NOT NULL,
`FNAME` VARCHAR(50),
`FTYPE` VARCHAR(50),
`DNAME` VARCHAR(50),
`FLENGTH` INT,
`IS3D` VARCHAR(50),
`GRADE` INT,
PRIMARY KEY (`FID`)
) CHARACTER SET latin1;
CREATE TABLE `showt` (
`FID` INT NOT NULL,
`TID` INT NOT NULL,
`PRICEC` INT,
`SYEAR` INT,
`SMONTH` INT,
PRIMARY KEY (`FID`, `TID`)
) CHARACTER SET latin1;
CREATE TABLE `theater` (
`TID` INT NOT NULL,
`TNAME` VARCHAR(50),
`TAREA` VARCHAR(50),
`ADDRESS` VARCHAR(50),
PRIMARY KEY (`TID`)
) CHARACTER SET latin1;
CREATE TABLE `test` (
`a` INT,
`b` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_662255_lab2') AS relationships;
