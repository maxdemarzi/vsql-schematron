INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 377482_tvshows
#
CREATE DATABASE `db_377482_tvshows`;
USE `db_377482_tvshows`;
CREATE TABLE `reviewers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`released_year` INT,
`genre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT NOT NULL,
`rating` DECIMAL(10,2),
`series_id` INT,
`reviewers_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_377482_tvshows') AS relationships;
relationships
