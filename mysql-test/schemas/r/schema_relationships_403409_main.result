INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 403409_main
#
CREATE DATABASE `db_403409_main`;
USE `db_403409_main`;
CREATE TABLE `case` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`token` INT,
`token_path` VARCHAR(50),
`content_type` VARCHAR(50),
`query` TEXT,
`body` TEXT,
`extra` VARCHAR(50),
`expect` TEXT,
`interface_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `env` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`base_url` VARCHAR(50),
`desc` TEXT,
`base_header` TEXT,
`db_host` VARCHAR(50),
`db_port` VARCHAR(50),
`db_name` VARCHAR(50),
`db_charset` VARCHAR(50),
`db_user` VARCHAR(50),
`db_passwd` VARCHAR(50),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `interface` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`desc` TEXT,
`path` VARCHAR(50),
`standard` VARCHAR(50),
`method` VARCHAR(50),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`desc` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `report` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`data` TEXT,
`start` VARCHAR(50),
`end` VARCHAR(50),
`tasks_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`is_timer` INT,
`cron` VARCHAR(50),
`env_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task_case` (
`task_id` INT,
`case_id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`avatar` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_403409_main') AS relationships;
