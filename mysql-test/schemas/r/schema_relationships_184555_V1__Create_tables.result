CREATE DATABASE `db_184555_V1__Create_tables`;
USE `db_184555_V1__Create_tables`;
CREATE TABLE `AUTHOR` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ADDRESS` (
`id` INT NOT NULL,
`country` VARCHAR(50),
`town` VARCHAR(50),
`street_and_building` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`publisher_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK_AUTHOR` (
`book_id` INT,
`author_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_184555_V1__Create_tables') AS relationships;
