CREATE DATABASE `db_552639_dbsetup`;
USE `db_552639_dbsetup`;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`senha` VARCHAR(50),
`nome` VARCHAR(50),
`isAdmin` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peca` (
`id` INT NOT NULL,
`tipo` VARCHAR(50),
`modelo` VARCHAR(50),
`marca` VARCHAR(50),
`fabricante` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorito` (
`id` INT NOT NULL,
`idUsuario` INT,
`idPeca` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `loja` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
