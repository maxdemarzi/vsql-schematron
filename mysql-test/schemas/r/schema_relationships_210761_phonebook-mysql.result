INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 210761_phonebook-mysql
#
CREATE DATABASE `db_210761_phonebook_mysql`;
USE `db_210761_phonebook_mysql`;
CREATE TABLE `contact` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
`contact_id` VARCHAR(50) NOT NULL,
`number` VARCHAR(50) NOT NULL,
`carrier` VARCHAR(50),
PRIMARY KEY (`contact_id`, `number`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_210761_phonebook_mysql') AS relationships;
relationships
