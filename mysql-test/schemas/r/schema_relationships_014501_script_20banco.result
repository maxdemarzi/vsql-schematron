INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 014501_script%20banco
#
CREATE DATABASE `db_014501_script_20banco`;
USE `db_014501_script_20banco`;
CREATE TABLE `BANCO` (
`CNPJ` BIGINT NOT NULL,
PRIMARY KEY (`CNPJ`)
) CHARACTER SET latin1;
CREATE TABLE `AGENCIA` (
`nAgencia` INT NOT NULL,
`nomeAgencia` VARCHAR(50),
`endereco` VARCHAR(50),
`UF` CHAR(50),
`cidade` VARCHAR(50),
`telefone` BIGINT,
`CNPJ` BIGINT,
PRIMARY KEY (`nAgencia`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
`codCliente` INT NOT NULL,
`nome` VARCHAR(50),
`endereco` VARCHAR(50),
`cidade` VARCHAR(50),
`UF` CHAR(50),
`telefone` BIGINT,
`CPF` BIGINT,
`RG` BIGINT,
PRIMARY KEY (`codCliente`)
) CHARACTER SET latin1;
CREATE TABLE `CONTA` (
`nConta` INT NOT NULL,
`tipoConta` VARCHAR(50),
`saldoConta` BIGINT,
`nAgencia` INT,
`codCliente` INT,
PRIMARY KEY (`nConta`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_014501_script_20banco') AS relationships;
relationships
Database: db_014501_script_20banco

Table Connections:
