INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 438318_script
#
CREATE DATABASE `db_438318_script`;
USE `db_438318_script`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`money` INT,
`life` INT,
`last_login` DATE,
`login_reward` INT,
`got_reward` TINYINT,
`active` INT,
`token` VARCHAR(50),
`winP` INT,
`loseP` INT,
`rankP` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reset` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`token` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
`id` INT NOT NULL,
`winner` INT,
`loser` INT,
`moment` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_438318_script') AS relationships;
