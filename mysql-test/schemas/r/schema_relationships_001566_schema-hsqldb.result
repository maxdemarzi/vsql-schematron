INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 001566_schema-hsqldb
#
CREATE DATABASE `db_001566_schema_hsqldb`;
USE `db_001566_schema_hsqldb`;
CREATE TABLE `T_CATEGORY` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `T_PRODUCT` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`category_fk` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `T_ITEM` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`unitCost` DOUBLE,
`product_fk` BIGINT,
`imagePath` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_001566_schema_hsqldb') AS relationships;
relationships
Database: db_001566_schema_hsqldb

Table Connections:
------------------
[Implied]  T_ITEM.product_fk -> T_PRODUCT.id
[Implied]  T_PRODUCT.category_fk -> T_CATEGORY.id

DROP DATABASE `db_001566_schema_hsqldb`;
UNINSTALL EXTENSION vsql_schematron;
