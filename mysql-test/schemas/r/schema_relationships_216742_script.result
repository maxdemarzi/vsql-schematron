INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 216742_script
#
CREATE DATABASE `db_216742_script`;
USE `db_216742_script`;
CREATE TABLE `CLASS` (
`CLASSID` VARCHAR(50) NOT NULL,
`CLASSNAME` VARCHAR(50),
`REGTIME` DATETIME,
`SPECIALTY` VARCHAR(50),
`REMARK` VARCHAR(50),
PRIMARY KEY (`CLASSID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
`USERID` VARCHAR(50) NOT NULL,
`USERNAME` VARCHAR(50),
`PASSWORD` VARCHAR(50),
`SEX` VARCHAR(50),
`BIRTHDAY` DATE,
`REGTIME` DATETIME,
`SPECIALTY` VARCHAR(50),
`REMARK` VARCHAR(50),
PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT_CLASS` (
`USERID` VARCHAR(50) NOT NULL,
`CLASSID` VARCHAR(50) NOT NULL,
`REGTIME` DATETIME,
`GRADE` DOUBLE,
PRIMARY KEY (`USERID`, `CLASSID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_216742_script') AS relationships;
