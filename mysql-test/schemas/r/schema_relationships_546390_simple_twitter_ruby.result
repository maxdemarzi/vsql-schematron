INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 546390_simple_twitter_ruby
#
CREATE DATABASE `db_546390_simple_twitter_ruby`;
USE `db_546390_simple_twitter_ruby`;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`user_id` INT,
`post_id` INT,
`text` VARCHAR(50),
`attachment_path` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments_hashtags` (
`id` INT NOT NULL,
`comment_id` INT,
`hashtag_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hashtags` (
`id` INT NOT NULL,
`text` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`user_id` INT,
`text` VARCHAR(50),
`attachment_path` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts_hashtags` (
`id` INT NOT NULL,
`post_id` INT,
`hashtag_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_546390_simple_twitter_ruby') AS relationships;
relationships
Database: db_546390_simple_twitter_ruby

Table Connections:
