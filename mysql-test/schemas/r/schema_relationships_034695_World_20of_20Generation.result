CREATE DATABASE `db_034695_World_20of_20Generation`;
USE `db_034695_World_20of_20Generation`;
CREATE TABLE `tb_class` (
`id_cla` INT NOT NULL,
`apelido` VARCHAR(50),
`Tipo` VARCHAR(50),
`magia` INT,
`arma` VARCHAR(50),
`sabedoria` INT,
PRIMARY KEY (`id_cla`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pers` (
`id_pers` INT NOT NULL,
`nome` VARCHAR(50),
`fraqueza` VARCHAR(50),
`poder_ataque` INT,
`id_cla` INT,
PRIMARY KEY (`id_pers`)
) CHARACTER SET latin1;
