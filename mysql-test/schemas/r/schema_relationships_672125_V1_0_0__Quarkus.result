INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 672125_V1.0.0__Quarkus
#
CREATE DATABASE `db_672125_V1_0_0__Quarkus`;
USE `db_672125_V1_0_0__Quarkus`;
CREATE TABLE `CUSTOMER` (
`SSN` VARCHAR(50) NOT NULL,
`FIRSTNAME` VARCHAR(50),
`LASTNAME` VARCHAR(50),
`PHONE` VARCHAR(50),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `ADDRESS` (
`SSN` CHAR(50),
`ST_ADDRESS` VARCHAR(50),
`APT_NUMBER` VARCHAR(50),
`CITY` VARCHAR(50),
`STATE` VARCHAR(50),
`ZIPCODE` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNT` (
`ACCOUNT_ID` INT NOT NULL,
`SSN` CHAR(50),
`STATUS` CHAR(50),
`TYPE` CHAR(50),
`DATEOPENED` TIMESTAMP NULL,
`DATECLOSED` TIMESTAMP NULL,
PRIMARY KEY (`ACCOUNT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT` (
`ID` INT NOT NULL,
`SYMBOL` VARCHAR(50),
`COMPANY_NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HOLDINGS` (
`TRANSACTION_ID` INT NOT NULL,
`ACCOUNT_ID` INT,
`PRODUCT_ID` INT,
`PURCHASE_DATE` TIMESTAMP NULL,
`SHARES_COUNT` INT,
PRIMARY KEY (`TRANSACTION_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_672125_V1_0_0__Quarkus') AS relationships;
relationships
Database: db_672125_V1_0_0__Quarkus

Table Connections:
------------------
[Implied]  ACCOUNT.SSN -> CUSTOMER.SSN
[Implied]  ADDRESS.SSN -> CUSTOMER.SSN
[Implied]  HOLDINGS.ACCOUNT_ID -> ACCOUNT.ACCOUNT_ID
[Implied]  HOLDINGS.PRODUCT_ID -> PRODUCT.ID

DROP DATABASE `db_672125_V1_0_0__Quarkus`;
