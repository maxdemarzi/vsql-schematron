CREATE DATABASE `db_221974_populate`;
USE `db_221974_populate`;
CREATE TABLE `PERSON` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`AGE` DECIMAL(10,2),
`IQ` DECIMAL(10,2),
`BIRTHDAY` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON_FIELDS` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`VALUE` VARCHAR(50),
`PERSON_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPTY` (
`NAME` VARCHAR(50),
`VALUE` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `TYPES` (
`ID` INT NOT NULL,
`TIMESTAMP_TYPE` TIMESTAMP NULL,
`DATETIME_TYPE` VARCHAR(50),
`DATE_TYPE` DATE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_221974_populate') AS relationships;
