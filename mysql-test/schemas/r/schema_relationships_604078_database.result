CREATE DATABASE `db_604078_database`;
USE `db_604078_database`;
CREATE TABLE `chefs` (
`id` INT NOT NULL,
`name` TEXT,
`avatar_url` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`id` INT NOT NULL,
`chef_id` INT,
`image` TEXT,
`title` TEXT,
`ingredients` VARCHAR(50),
`preparations` VARCHAR(50),
`information` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_604078_database') AS relationships;
