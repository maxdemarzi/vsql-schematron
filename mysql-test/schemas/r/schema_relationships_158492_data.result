INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 158492_data
#
CREATE DATABASE `db_158492_data`;
USE `db_158492_data`;
CREATE TABLE `account` (
`account_id` BIGINT NOT NULL,
`email` VARCHAR(50),
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `contents` (
`contents_id` BIGINT NOT NULL,
`create_at` DATETIME,
`description` VARCHAR(50),
`full_address` VARCHAR(50),
`lat` DOUBLE,
`lng` DOUBLE,
`picture` VARCHAR(50),
`tag` VARCHAR(50),
`title` VARCHAR(50),
`update_at` DATETIME,
`account_id` BIGINT,
PRIMARY KEY (`contents_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_158492_data') AS relationships;
