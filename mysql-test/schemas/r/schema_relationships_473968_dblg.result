`cloudsecret` TEXT,
`cloudpath` TEXT,
`cloudname` TEXT,
`flags` INT,
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sess` (
`userid` INT,
`cookie` INT,
`ctime` INT,
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
