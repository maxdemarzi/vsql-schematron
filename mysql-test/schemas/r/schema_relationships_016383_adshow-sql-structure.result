INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 016383_adshow-sql-structure
#
CREATE DATABASE `db_016383_adshow_sql_structure`;
USE `db_016383_adshow_sql_structure`;
CREATE TABLE `department` (
`ID` VARCHAR(50) NOT NULL,
`department` VARCHAR(50),
`title` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `playlist` (
`ID` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`active` VARCHAR(50),
`departmentIDfk` VARCHAR(50),
`global` VARCHAR(50),
`screenOrientation` TINYINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `screen` (
`ID` VARCHAR(50) NOT NULL,
`location` VARCHAR(50),
`orientation` TINYINT,
`departmentIDfk` VARCHAR(50),
`pcName` VARCHAR(50),
`playlistIDfk` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `slide` (
`ID` VARCHAR(50) NOT NULL,
`active` VARCHAR(50),
`title` VARCHAR(50),
`text` TEXT,
`playtime` VARCHAR(50),
`templateName` VARCHAR(50),
`playlistID` VARCHAR(50),
`imageURL` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
`markdownEnabled` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`ID` VARCHAR(50) NOT NULL,
`sNumber` VARCHAR(50),
`departmentIDfk` VARCHAR(50),
`permission` VARCHAR(50),
`firstname` TEXT,
`lastname` TEXT,
`owner` VARCHAR(50),
`global` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_016383_adshow_sql_structure') AS relationships;
relationships
Database: db_016383_adshow_sql_structure

Table Connections:
------------------
[Implied]  playlist.departmentIDfk -> department.ID
[Implied]  screen.departmentIDfk -> department.ID
[Implied]  screen.playlistIDfk -> playlist.ID
[Implied]  slide.playlistID -> playlist.ID
[Implied]  user.departmentIDfk -> department.ID

DROP DATABASE `db_016383_adshow_sql_structure`;
UNINSTALL EXTENSION vsql_schematron;
