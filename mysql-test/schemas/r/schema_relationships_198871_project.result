CREATE TABLE `THEATER_COMPANY` (
`theater_company_id` DECIMAL(10,2) NOT NULL,
`hall_capacity` DECIMAL(10,2),
`name_company` VARCHAR(50),
`budget` DOUBLE,
`city` VARCHAR(50),
`balance` DOUBLE,
PRIMARY KEY (`theater_company_id`)
) CHARACTER SET latin1;
CREATE TABLE `CREATIONS` (
`creation_id` DECIMAL(10,2) NOT NULL,
`creation_cost` DOUBLE,
`promotion_creations` DOUBLE,
`theater_company_id` DECIMAL(10,2),
PRIMARY KEY (`creation_id`)
) CHARACTER SET latin1;
