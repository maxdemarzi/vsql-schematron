INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 052339_external_user_db
#
CREATE DATABASE `db_052339_external_user_db`;
USE `db_052339_external_user_db`;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`employee_name` VARCHAR(50),
`email` VARCHAR(50),
`postal` VARCHAR(50),
`profile_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`role_name` VARCHAR(50),
`role_description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_roles` (
`id` INT NOT NULL,
`role_id` INT,
`emp_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_052339_external_user_db') AS relationships;
relationships
