) CHARACTER SET latin1;
CREATE TABLE `Room` (
`id` INT NOT NULL,
`name` TEXT,
`description` TEXT,
`ownerId` INT,
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Message` (
`id` INT NOT NULL,
`roomId` INT,
`userId` INT,
`text` TEXT,
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
