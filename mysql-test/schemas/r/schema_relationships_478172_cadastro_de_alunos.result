INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 478172_cadastro_de_alunos
#
CREATE DATABASE `db_478172_cadastro_de_alunos`;
USE `db_478172_cadastro_de_alunos`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`ativo` VARCHAR(50),
`nome` VARCHAR(50),
`email` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `curso` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `periodo` (
`id` INT NOT NULL,
`periodo` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
`id` INT NOT NULL,
`cep` INT,
`uf` VARCHAR(50),
`cidade` VARCHAR(50),
`bairro` VARCHAR(50),
`rua` VARCHAR(50),
`numero` INT,
`complemento` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `info_alunos` (
`matricula` INT NOT NULL,
`cpf` VARCHAR(50),
`nome` VARCHAR(50),
`sexo` VARCHAR(50),
`data_nasc` DATE,
`email` VARCHAR(50),
`curso_id` INT,
`periodo_id` INT,
`endereco_id` INT,
PRIMARY KEY (`matricula`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_478172_cadastro_de_alunos') AS relationships;
relationships
Database: db_478172_cadastro_de_alunos

