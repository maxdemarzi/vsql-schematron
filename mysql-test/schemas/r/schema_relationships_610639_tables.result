INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 610639_tables
#
CREATE DATABASE `db_610639_tables`;
USE `db_610639_tables`;
CREATE TABLE `families` (
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`pass` VARCHAR(50),
`nickname` VARCHAR(50),
`family_id` INT,
`is_head` BOOLEAN,
`can_add` BOOLEAN,
`can_reserve` BOOLEAN,
`can_delete` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`id` VARCHAR(50) NOT NULL,
`user_id` INT,
`last_use` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT NOT NULL,
`title` CHAR(50),
`description` CHAR(50),
`category` INT,
`family_id` INT,
`added_id` INT,
`reserved_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_610639_tables') AS relationships;
