CREATE DATABASE `db_251555_main`;
USE `db_251555_main`;
CREATE TABLE `student_info` (
`std_id` INT NOT NULL,
`f_name` VARCHAR(50),
`l_name` VARCHAR(50),
`birth_date` DATE,
`sex` VARCHAR(50),
`majorCode` INT,
PRIMARY KEY (`std_id`)
) CHARACTER SET latin1;
CREATE TABLE `majorList` (
`majorCode` INT NOT NULL,
`majorName` VARCHAR(50),
PRIMARY KEY (`majorCode`)
) CHARACTER SET latin1;
CREATE TABLE `instructor_info` (
`ins_id` INT NOT NULL,
`f_name` VARCHAR(50),
`l_name` VARCHAR(50),
PRIMARY KEY (`ins_id`)
) CHARACTER SET latin1;
