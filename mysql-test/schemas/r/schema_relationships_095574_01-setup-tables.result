INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 095574_01-setup-tables
#
CREATE DATABASE `db_095574_01_setup_tables`;
USE `db_095574_01_setup_tables`;
CREATE TABLE `employees` (
`employee_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`phone_number` VARCHAR(50),
`hire_date` DATE,
`job_id` INT,
`salary` DECIMAL(10,2),
`manager_id` INT,
`department_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `dependents` (
`dependent_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`relationship` VARCHAR(50),
`employee_id` INT,
PRIMARY KEY (`dependent_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_095574_01_setup_tables') AS relationships;
relationships
