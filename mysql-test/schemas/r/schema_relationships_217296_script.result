INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 217296_script
#
CREATE DATABASE `db_217296_script`;
USE `db_217296_script`;
CREATE TABLE `perfis` (
`id_perfil` INT NOT NULL,
`perfil` VARCHAR(50),
PRIMARY KEY (`id_perfil`)
) CHARACTER SET latin1;
CREATE TABLE `equipamentos` (
`id_equipamento` INT NOT NULL,
`equipamento` VARCHAR(50),
`imagem` VARCHAR(50),
`descricao` VARCHAR(50),
`ativo` INT,
`data` DATETIME,
PRIMARY KEY (`id_equipamento`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
`id_usuario` INT NOT NULL,
`senha` VARCHAR(50),
`fk_id_perfil` INT,
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `comentarios` (
`id_comentario` INT NOT NULL,
`comentario` VARCHAR(50),
`data` DATETIME,
`fk_id_equipamento` INT,
`fk_id_perfil` INT,
PRIMARY KEY (`id_comentario`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_217296_script') AS relationships;
relationships
Database: db_217296_script

Table Connections:
------------------
[Implied]  comentarios.fk_id_equipamento -> equipamentos.id_equipamento
[Implied]  comentarios.fk_id_perfil -> perfis.id_perfil
