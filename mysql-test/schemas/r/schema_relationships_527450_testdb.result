INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 527450_testdb
#
CREATE DATABASE `db_527450_testdb`;
USE `db_527450_testdb`;
CREATE TABLE `messages` (
`id` INT,
`user_id` INT,
`report` TEXT,
`status` VARCHAR(50),
`dateadd` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`auth_key` VARCHAR(50),
`name` CHAR(50),
`email` CHAR(50),
`password` CHAR(50),
`role` VARCHAR(50),
`dateadd` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_527450_testdb') AS relationships;
