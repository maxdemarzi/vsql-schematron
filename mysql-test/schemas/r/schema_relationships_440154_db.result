INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 440154_db
#
CREATE DATABASE `db_440154_db`;
USE `db_440154_db`;
CREATE TABLE `teacher` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`teacher_id` VARCHAR(50),
`subject` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_submission` (
`project_id` INT,
`student_id` INT,
`report_pdf` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_440154_db') AS relationships;
