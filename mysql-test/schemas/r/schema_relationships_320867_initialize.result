INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 320867_initialize
#
CREATE DATABASE `db_320867_initialize`;
USE `db_320867_initialize`;
CREATE TABLE `foodCategory` (
`id` INT NOT NULL,
`food_cat_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` INT NOT NULL,
`course_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredient` (
`id` INT NOT NULL,
`ingredient_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurement` (
`id` INT NOT NULL,
`measurement_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
`id` INT NOT NULL,
`course_id` INT,
`food_cat_id` INT,
`recipe_name` VARCHAR(50),
`recipe_desc` VARCHAR(50),
`prep_time` TIME,
`cook_time` TIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quantity` (
`id` INT NOT NULL,
`recipe_id` INT,
`ingredient_id` INT,
`measurement_id` INT,
`ingredient_quantity` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
`id` INT NOT NULL,
`recipe_id` INT,
`step_number` INT,
`step_description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_320867_initialize') AS relationships;
relationships
Database: db_320867_initialize

Table Connections:
