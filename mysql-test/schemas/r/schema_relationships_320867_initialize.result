[Implied]  quantity.ingredient_id -> ingredient.id
[Implied]  quantity.measurement_id -> measurement.id
[Implied]  quantity.recipe_id -> recipe.id
[Implied]  recipe.course_id -> course.id
[Implied]  recipe.food_cat_id -> foodCategory.id
[Implied]  steps.recipe_id -> recipe.id

DROP DATABASE `db_320867_initialize`;
UNINSTALL EXTENSION vsql_schematron;
