INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 037616_db_create
#
CREATE DATABASE `db_037616_db_create`;
USE `db_037616_db_create`;
CREATE TABLE `BRANDS` (
`BRAND_ID` DECIMAL(10,2) NOT NULL,
`NAME` VARCHAR(50),
`STATE` DECIMAL(10,2),
PRIMARY KEY (`BRAND_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRICES` (
`PRICES_ID` INT NOT NULL,
`BRAND_ID` DECIMAL(10,2),
`START_DATE` DATE,
`END_DATE` DATE,
`PRICE_LIST_ID` DECIMAL(10,2),
`PRODUCT_ID` DECIMAL(10,2),
`PRIORITY` DECIMAL(10,2),
`PRICE` DECIMAL(10,2),
`CURR` VARCHAR(50),
PRIMARY KEY (`PRICES_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRICES_LIST` (
`PRICE_LIST_ID` DECIMAL(10,2) NOT NULL,
`PRODUCT_ID` DECIMAL(10,2),
`STATE` DECIMAL(10,2),
PRIMARY KEY (`PRICE_LIST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCTS` (
`PRODUCT_ID` DECIMAL(10,2) NOT NULL,
`NAME` VARCHAR(50),
`TYPE_ID` VARCHAR(50),
`STATE` DECIMAL(10,2),
PRIMARY KEY (`PRODUCT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TYPE_PRODUCTS` (
`TYPE_ID` VARCHAR(50) NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`TYPE_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_037616_db_create') AS relationships;
relationships
