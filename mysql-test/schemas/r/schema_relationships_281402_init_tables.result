INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 281402_init_tables
#
CREATE DATABASE `db_281402_init_tables`;
USE `db_281402_init_tables`;
CREATE TABLE `transmissions` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `engines` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bodies` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT NOT NULL,
`transmission_id` INT,
`engine_id` INT,
`body_id` INT,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_281402_init_tables') AS relationships;
relationships
Database: db_281402_init_tables

Table Connections:
