[Implied]  cars.body_id -> bodies.id
[Implied]  cars.engine_id -> engines.id
[Implied]  cars.transmission_id -> transmissions.id

DROP DATABASE `db_281402_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
