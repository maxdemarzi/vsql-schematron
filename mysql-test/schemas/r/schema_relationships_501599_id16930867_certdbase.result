`signatory2` VARCHAR(50),
`signatory3` VARCHAR(50),
`department` VARCHAR(50),
`title` VARCHAR(50),
`description` VARCHAR(50),
`recognition` VARCHAR(50),
`presentationline` VARCHAR(50),
`logo1` VARCHAR(50),
`logo2` VARCHAR(50),
`logo3` VARCHAR(50),
`expdate` DATE
) CHARACTER SET latin1;
CREATE TABLE `organizers` (
`id` INT NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `participants` (
`pid` INT NOT NULL,
`eventid` INT,
`name` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
