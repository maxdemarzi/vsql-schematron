INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 076367_sqlite-seed
#
CREATE DATABASE `db_076367_sqlite_seed`;
USE `db_076367_sqlite_seed`;
CREATE TABLE `agency` (
`name` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` VARCHAR(50) NOT NULL,
`tripId` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`phone` VARCHAR(50),
`IDNumber` INT,
`email` VARCHAR(50),
`willTravel` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trip` (
`id` VARCHAR(50) NOT NULL,
`departureDate` DATETIME,
`estimatedArrivalDate` DATETIME,
`agencyId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_076367_sqlite_seed') AS relationships;
relationships
Database: db_076367_sqlite_seed

Table Connections:
