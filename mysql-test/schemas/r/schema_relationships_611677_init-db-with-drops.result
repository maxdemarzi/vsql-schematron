CREATE TABLE `abiyan.Tag` (
`name` VARCHAR(50) NOT NULL,
`latitude` VARCHAR(50),
`longitude` VARCHAR(50),
`creationDate` VARCHAR(50),
`lastUpdate` VARCHAR(50),
`phone` VARCHAR(50),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `abiyan.Vote` (
`plus` INT,
`minus` INT,
`tag` VARCHAR(50),
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `abiyan.Item` (
`category` VARCHAR(50),
`type` VARCHAR(50),
`price` VARCHAR(50),
`creationDate` VARCHAR(50),
`lastUpdate` VARCHAR(50),
`numberInStock` VARCHAR(50),
`tag` VARCHAR(50),
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
