INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 218227_script
#
CREATE DATABASE `db_218227_script`;
USE `db_218227_script`;
CREATE TABLE `EVENTS` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`ACTIVITY` VARCHAR(50),
`TYPE` INT,
`MAXPPL` INT,
`MINPPL` INT,
`ATMPPL` INT,
`OWNER` VARCHAR(50),
`APP` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PARTICIPANTS` (
`PARTICIPANT_ID` VARCHAR(50) NOT NULL,
`EVENTS_ID` INT NOT NULL,
`APP` VARCHAR(50),
PRIMARY KEY (`PARTICIPANT_ID`, `EVENTS_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_218227_script') AS relationships;
