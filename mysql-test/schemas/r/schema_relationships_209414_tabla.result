INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 209414_tabla
#
CREATE DATABASE `db_209414_tabla`;
USE `db_209414_tabla`;
CREATE TABLE `clases` (
`cod` DECIMAL(10,2) NOT NULL,
`nombre` VARCHAR(50),
`ingresos` DECIMAL(10,2),
`num_pob` DECIMAL(10,2),
PRIMARY KEY (`cod`)
) CHARACTER SET latin1;
CREATE TABLE `personajes` (
`id` VARCHAR(50) NOT NULL,
`nombre` VARCHAR(50),
`fechanac` DATE,
`cp` VARCHAR(50),
`sexo` VARCHAR(50),
`patrimonio` DECIMAL(10,2),
`clase` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_209414_tabla') AS relationships;
relationships
