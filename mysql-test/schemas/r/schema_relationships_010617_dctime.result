USE `db_010617_dctime`;
CREATE TABLE `game` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`translated_name` VARCHAR(50),
`cover_image` VARCHAR(50),
`pitctures` VARCHAR(50),
`platform` VARCHAR(50),
`release_date` DATE,
`tag` VARCHAR(50),
`official_website` VARCHAR(50),
`developer` VARCHAR(50),
`publisher` VARCHAR(50),
`description` VARCHAR(50),
`number_of_judges` BIGINT,
`total_score` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_topic_related` (
`game_id` BIGINT NOT NULL,
`topic_id` BIGINT NOT NULL,
PRIMARY KEY (`game_id`, `topic_id`)
) CHARACTER SET latin1;
