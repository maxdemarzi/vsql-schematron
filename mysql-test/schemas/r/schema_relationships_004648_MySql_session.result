CREATE DATABASE `db_004648_MySql_session`;
USE `db_004648_MySql_session`;
CREATE TABLE `posts` (
`userId` VARCHAR(50),
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`postId` VARCHAR(50),
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_004648_MySql_session') AS relationships;
