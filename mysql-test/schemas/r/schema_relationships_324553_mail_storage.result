INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 324553_mail_storage
#
CREATE DATABASE `db_324553_mail_storage`;
USE `db_324553_mail_storage`;
CREATE TABLE `mail_storage` (
`id` INT NOT NULL,
`sender` VARCHAR(50),
`subject` VARCHAR(50),
`receiver` VARCHAR(50),
`cc` VARCHAR(50),
`bcc` VARCHAR(50),
`rawText` TEXT,
`html` TEXT,
`deliveryTime` TIMESTAMP NULL,
`tag` VARCHAR(50),
`creationTime` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mail_storage_attachment` (
`id` INT NOT NULL,
`mail_Id` BIGINT,
`name` VARCHAR(50),
`mime_type` VARCHAR(50),
`data` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_324553_mail_storage') AS relationships;
