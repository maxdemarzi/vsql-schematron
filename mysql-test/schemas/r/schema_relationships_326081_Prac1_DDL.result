INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 326081_Prac1_DDL
#
CREATE DATABASE `db_326081_Prac1_DDL`;
USE `db_326081_Prac1_DDL`;
CREATE TABLE `고객` (
`고객아이디` VARCHAR(50) NOT NULL,
`고객이름` VARCHAR(50),
`나이` INT,
`등급` VARCHAR(50),
`직업` VARCHAR(50),
`적립금` INT,
PRIMARY KEY (`고객아이디`)
) CHARACTER SET latin1;
CREATE TABLE `제품` (
`제품번호` VARCHAR(50) NOT NULL,
`제품명` VARCHAR(50),
`재고량` INT,
`단가` INT,
`제조업체` VARCHAR(50),
PRIMARY KEY (`제품번호`)
) CHARACTER SET latin1;
CREATE TABLE `주문` (
`주문번호` VARCHAR(50) NOT NULL,
`주문고객` VARCHAR(50),
`주문제품` CHAR(50),
`수량` INT,
`배송지` VARCHAR(50),
`주문일자` DATE,
PRIMARY KEY (`주문번호`)
) CHARACTER SET latin1;
CREATE TABLE `배송업체` (
`업체번호` VARCHAR(50) NOT NULL,
`업체병` VARCHAR(50),
`주소` VARCHAR(50),
`전화번호` VARCHAR(50),
PRIMARY KEY (`업체번호`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_326081_Prac1_DDL') AS relationships;
relationships
