CREATE DATABASE `db_522338_schema`;
USE `db_522338_schema`;
CREATE TABLE `lambda` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`runtime` VARCHAR(50),
`source` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `execution` (
`id` VARCHAR(50) NOT NULL,
`lambda_id` VARCHAR(50),
`arguments` VARCHAR(50),
`result` VARCHAR(50),
`log` TEXT,
`status` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_522338_schema') AS relationships;
