CREATE DATABASE `db_001983_create_db`;
USE `db_001983_create_db`;
CREATE TABLE `users` (
`id` INT,
`firstname` TEXT,
`lastname` TEXT,
`email` TEXT,
`share_email` BOOLEAN,
`password` TEXT,
`password_lost` TEXT,
`phone` TEXT,
`share_phone` BOOLEAN,
`has_whatsapp` BOOLEAN,
`theme` TEXT,
`role` TEXT,
`notif_new_event` BOOLEAN,
`notif_event_change` BOOLEAN,
`notif_tomorrow_events` BOOLEAN,
`wing` TEXT,
`presentation` TEXT,
`creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`title` TEXT,
`start_date` TEXT,
`end_date` TEXT,
`time` TEXT,
`description` TEXT,
`location` TEXT,
`gps` TEXT,
`gps_location` TEXT,
`category` TEXT,
`color` TEXT,
`whatsapp_link` TEXT,
`creator_id` INT,
`creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events_registrations` (
`id` INT,
`event_id` INT,
`user_id` INT,
`interest` INT,
`lastupdate_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT,
`comment` TEXT,
`author_id` INT,
`event_id` INT,
`creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events_notifications_blocklist` (
`event_id` INT,
`user_id` INT
) CHARACTER SET latin1;
