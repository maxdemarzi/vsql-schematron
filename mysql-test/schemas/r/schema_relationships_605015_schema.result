INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 605015_schema
#
CREATE DATABASE `db_605015_schema`;
USE `db_605015_schema`;
CREATE TABLE `Warehouses` (
`Code` INT NOT NULL,
`Location` TEXT,
`Capacity` INT,
PRIMARY KEY (`Code`)
) CHARACTER SET latin1;
CREATE TABLE `Boxes` (
`Code` VARCHAR(50) NOT NULL,
`Contents` TEXT,
`Value` DOUBLE,
`Warehouse` INT,
PRIMARY KEY (`Code`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605015_schema') AS relationships;
