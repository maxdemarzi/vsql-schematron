CREATE DATABASE `db_649411_base`;
USE `db_649411_base`;
CREATE TABLE `amb_sender` (
`senderID` INT NOT NULL,
`senderName` VARCHAR(50),
`senderAddress` VARCHAR(50),
`senderPassword` VARCHAR(50),
`salt` VARCHAR(50),
PRIMARY KEY (`senderID`)
) CHARACTER SET latin1;
CREATE TABLE `amb_outgoing` (
`messageID` INT NOT NULL,
`recipient` VARCHAR(50),
`subject` VARCHAR(50),
`body` TEXT,
`sendDate` TIMESTAMP NULL,
PRIMARY KEY (`messageID`)
) CHARACTER SET latin1;
CREATE TABLE `amb_attachment` (
`attachmentID` INT NOT NULL,
`messageID` INT,
`fileURL` VARCHAR(50),
PRIMARY KEY (`attachmentID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_649411_base') AS relationships;
