INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 569899_01.Table%20Design
#
CREATE DATABASE `db_569899_01_Table_20Design`;
USE `db_569899_01_Table_20Design`;
CREATE TABLE `planets` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spaceports` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`planet_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spaceships` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`manufacturer` VARCHAR(50),
`light_speed_rate` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `journeys` (
`id` INT NOT NULL,
`journey_start` DATETIME,
`journey_end` DATETIME,
`purpose` VARCHAR(50),
`destination_spaceport_id` INT,
`spaceship_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_569899_01_Table_20Design') AS relationships;
relationships
Database: db_569899_01_Table_20Design

Table Connections:
------------------
[Implied]  journeys.destination_spaceport_id -> spaceports.id
[Implied]  journeys.spaceship_id -> spaceships.id
[Implied]  spaceports.planet_id -> planets.id

DROP DATABASE `db_569899_01_Table_20Design`;
UNINSTALL EXTENSION vsql_schematron;
