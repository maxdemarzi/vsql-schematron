INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 214440_tables
#
CREATE DATABASE `db_214440_tables`;
USE `db_214440_tables`;
CREATE TABLE `game_sessions` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
`owner_id` INT,
`selected_time_offset` DOUBLE,
`selected_time_duration` DOUBLE,
`selected_time_timezone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_roles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`icon` VARCHAR(50),
`session_id` INT,
`parent_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_rules` (
`id` INT NOT NULL,
`rule_operator` VARCHAR(50),
`rule_value` INT,
`session_id` INT,
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signups` (
`id` INT NOT NULL,
`anonymous_name` VARCHAR(50),
`session_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signup_times` (
`id` INT NOT NULL,
`timezone` VARCHAR(50),
`offset` DOUBLE,
`duration` DOUBLE,
`signup_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signup_roles` (
`id` INT NOT NULL,
`weight` INT,
`signup_id` INT,
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_invites` (
`id` INT NOT NULL,
`key` VARCHAR(50),
`session_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_214440_tables') AS relationships;
