`author_id` INT,
`title` VARCHAR(50),
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`article_id` INT,
`author_id` INT,
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
