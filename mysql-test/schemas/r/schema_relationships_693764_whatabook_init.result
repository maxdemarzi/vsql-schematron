) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`details` VARCHAR(50),
`author` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `store` (
`id` INT NOT NULL,
`locale` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
