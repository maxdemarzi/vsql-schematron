CREATE TABLE `user` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlist` (
`id` INT NOT NULL,
`user_id` INT,
