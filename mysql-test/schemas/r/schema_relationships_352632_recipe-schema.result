INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 352632_recipe-schema
#
CREATE DATABASE `db_352632_recipe_schema`;
USE `db_352632_recipe_schema`;
CREATE TABLE `material` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
`id` VARCHAR(50) NOT NULL,
`material_one` VARCHAR(50),
`material_two` VARCHAR(50),
`material_three` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_352632_recipe_schema') AS relationships;
relationships
