INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 215162_schema
#
CREATE DATABASE `db_215162_schema`;
USE `db_215162_schema`;
CREATE TABLE `region` (
`index` INT,
`region_id` INT NOT NULL,
`country` TEXT,
`province` TEXT,
`Region` TEXT,
PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
`index` INT,
`region_id` INT,
`Lat` DECIMAL(10,2),
`Lng` DECIMAL(10,2),
`max_temp` DECIMAL(10,2),
`min_temp` DECIMAL(10,2),
`Temp` DECIMAL(10,2),
`Humidity` DECIMAL(10,2),
`diurnal_range` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `wine` (
`index` INT,
`region_id` INT,
`variety` TEXT,
`points` INT,
`price` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_215162_schema') AS relationships;
relationships
Database: db_215162_schema

Table Connections:
------------------
[Implied]  weather.region_id -> region.region_id
[Implied]  wine.region_id -> region.region_id

DROP DATABASE `db_215162_schema`;
UNINSTALL EXTENSION vsql_schematron;
