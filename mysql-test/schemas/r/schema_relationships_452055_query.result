INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 452055_query
#
CREATE DATABASE `db_452055_query`;
USE `db_452055_query`;
CREATE TABLE `Author` (
`ID` INT NOT NULL,
`Name` VARCHAR(50),
`Description` TEXT,
`Email` VARCHAR(50),
`Image` VARCHAR(50),
`CreatedAt` TIMESTAMP NULL,
`UpdatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`ID` INT NOT NULL,
`Name` VARCHAR(50),
`Description` TEXT,
`CreatedAt` TIMESTAMP NULL,
`UpdatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Book` (
`ID` INT NOT NULL,
`AuthorID` INT,
`Quantity` INT,
`Name` VARCHAR(50),
`CategoryID` INT,
`Pages` VARCHAR(50),
`RATE` DECIMAL(10,2),
`Price` VARCHAR(50),
`Image` VARCHAR(50),
`Published` VARCHAR(50),
`Sale` VARCHAR(50),
`PublishedDate` VARCHAR(50),
`Description` TEXT,
`Language` VARCHAR(50),
`UpdatedAt` TIMESTAMP NULL,
`CreatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_452055_query') AS relationships;
