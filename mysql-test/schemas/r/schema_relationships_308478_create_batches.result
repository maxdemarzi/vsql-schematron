CREATE DATABASE `db_308478_create_batches`;
USE `db_308478_create_batches`;
CREATE TABLE `trainers` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trainer_batches` (
`trainer_id` INT,
`batch_id` INT,
`start_date` DATE,
`end_date` DATE,
`role` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `batches` (
`id` INT NOT NULL,
`start_date` DATE,
`end_date` DATE,
`name` VARCHAR(50),
`training_track` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `associate_batches` (
`associate_id` INT,
`batch_id` INT,
`start_date` DATE,
`end_date` DATE,
`training_status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `associates` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_308478_create_batches') AS relationships;
