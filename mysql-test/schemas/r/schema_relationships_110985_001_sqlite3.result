CREATE DATABASE `db_110985_001_sqlite3`;
USE `db_110985_001_sqlite3`;
CREATE TABLE `config_buckets` (
`id` VARCHAR(50) NOT NULL,
`version` CHAR(50),
`slug` CHAR(50),
`title` CHAR(50),
`description` TEXT,
`host_id` CHAR(50),
`access` CHAR(50),
`schema` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_published` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `config_variables` (
`id` VARCHAR(50) NOT NULL,
`version` CHAR(50),
`bucket_id` CHAR(50),
`name` CHAR(50),
`description` TEXT,
`value` VARCHAR(50),
`is_locked` BOOLEAN,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_110985_001_sqlite3') AS relationships;
