INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 175631_EPS
#
CREATE DATABASE `db_175631_EPS`;
USE `db_175631_EPS`;
CREATE TABLE `Affiliate` (
`affiliate_id` INT NOT NULL,
`first_name` TEXT,
`last_name` TEXT,
`address` TEXT,
`phone` TEXT,
`email` TEXT,
`city` TEXT,
`birth_date` DECIMAL(10,2),
`affiliation_date` DECIMAL(10,2),
`vaccinated` BOOLEAN,
`disaffiliation_date` DECIMAL(10,2),
PRIMARY KEY (`affiliate_id`)
) CHARACTER SET latin1;
CREATE TABLE `VaccineLot` (
`vaccine_lot_id` INT NOT NULL,
`manufacturer` TEXT,
`vaccine_type` TEXT,
`amount` DECIMAL(10,2),
`used_amount` DECIMAL(10,2),
`dose` DECIMAL(10,2),
`temperature` DECIMAL(10,2),
`effectiveness` DECIMAL(10,2),
`protection_time` DECIMAL(10,2),
`expiration_date` DECIMAL(10,2),
`image_url` TEXT,
PRIMARY KEY (`vaccine_lot_id`)
) CHARACTER SET latin1;
CREATE TABLE `VaccinationPlan` (
`vaccination_plan_id` INT NOT NULL,
`minimum_age` DECIMAL(10,2),
`maximum_age` DECIMAL(10,2),
`start_date` DECIMAL(10,2),
`end_date` DECIMAL(10,2),
PRIMARY KEY (`vaccination_plan_id`)
) CHARACTER SET latin1;
CREATE TABLE `VaccinationSchedule` (
`vaccination_schedule_id` INT NOT NULL,
`date_time` DECIMAL(10,2),
`affiliate_id` DECIMAL(10,2),
`vaccine_lot_id` DECIMAL(10,2),
`vaccination_plan_id` DECIMAL(10,2),
PRIMARY KEY (`vaccination_schedule_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_175631_EPS') AS relationships;
relationships
Database: db_175631_EPS

Table Connections:
------------------
[Implied]  VaccinationSchedule.affiliate_id -> Affiliate.affiliate_id
[Implied]  VaccinationSchedule.vaccination_plan_id -> VaccinationPlan.vaccination_plan_id
[Implied]  VaccinationSchedule.vaccine_lot_id -> VaccineLot.vaccine_lot_id

DROP DATABASE `db_175631_EPS`;
UNINSTALL EXTENSION vsql_schematron;
