CREATE DATABASE `db_318846_1_structure`;
USE `db_318846_1_structure`;
CREATE TABLE `USERS` (
`ID` BIGINT NOT NULL,
`USERNAME` VARCHAR(50),
`PASSWORD` BLOB,
`TYPE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USERS_DATA_APPROVAL` (
`ID` BIGINT NOT NULL,
`USER_ID` BIGINT,
`APPROVAL_DATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHRASES` (
`ID` BIGINT NOT NULL,
`USER_ID` BIGINT,
`LANGUAGE` VARCHAR(50),
`PHRASE` TEXT,
`STATE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_318846_1_structure') AS relationships;
