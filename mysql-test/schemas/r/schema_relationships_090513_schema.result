INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 090513_schema
#
CREATE DATABASE `db_090513_schema`;
USE `db_090513_schema`;
CREATE TABLE `USER` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`EMAIL` VARCHAR(50),
`PASSWORD` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ADVERTISEMENT` (
`ID` INT NOT NULL,
`CREATE_DATE` DATE,
`TITLE` VARCHAR(50),
`TEXT` VARCHAR(50),
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_090513_schema') AS relationships;
