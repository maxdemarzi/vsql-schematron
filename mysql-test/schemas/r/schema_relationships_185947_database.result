CREATE DATABASE `db_185947_database`;
USE `db_185947_database`;
CREATE TABLE `rol` (
`id_rol` INT NOT NULL,
`nombre` VARCHAR(50),
`estado` INT,
PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`salt` VARCHAR(50),
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`direccion` VARCHAR(50),
`email` VARCHAR(50),
`estado` INT,
`rol_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_185947_database') AS relationships;
