INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 540552_jarsproject
#
CREATE DATABASE `db_540552_jarsproject`;
USE `db_540552_jarsproject`;
CREATE TABLE `post` (
`post_id` INT,
`post_title` VARCHAR(50),
`post_description` VARCHAR(50),
`post_photo` VARCHAR(50),
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT,
`user_username` VARCHAR(50),
`user_password` VARCHAR(50),
`user_email` VARCHAR(50),
`user_code` VARCHAR(50),
`user_verification` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `userinfo` (
`userinfo_id` INT,
`userinfo_firstname` VARCHAR(50),
`userinfo_lastname` VARCHAR(50),
`userinfo_bio` VARCHAR(50),
`userinfo_image` VARCHAR(50),
`user_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_540552_jarsproject') AS relationships;
relationships
