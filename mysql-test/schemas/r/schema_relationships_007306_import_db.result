) CHARACTER SET latin1;
CREATE TABLE `actors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `castings` (
`movie_id` INT,
`actor_id` INT,
`ord` INT
) CHARACTER SET latin1;
