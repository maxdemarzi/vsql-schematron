INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 665512_create-tables
#
CREATE DATABASE `db_665512_create_tables`;
USE `db_665512_create_tables`;
CREATE TABLE `countries` (
`CODE` VARCHAR(50) NOT NULL,
`DESCR` VARCHAR(50),
PRIMARY KEY (`CODE`)
) CHARACTER SET latin1;
CREATE TABLE `continents` (
`CODE` VARCHAR(50) NOT NULL,
`DESCR` VARCHAR(50),
PRIMARY KEY (`CODE`)
) CHARACTER SET latin1;
CREATE TABLE `airports` (
`ID` INT NOT NULL,
`IATA` CHAR(50),
`ICAO` CHAR(50),
`CITY` VARCHAR(50),
`DESCR` VARCHAR(50),
`REGION` VARCHAR(50),
`COUNTRY` CHAR(50),
`RUNWAYS` INT,
`LONGEST` INT,
`ALTITUDE` INT,
`CONTINENT` CHAR(50),
`LAT` DOUBLE,
`LON` DOUBLE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `routes` (
`SRC` INT NOT NULL,
`DEST` INT NOT NULL,
`DIST` INT,
PRIMARY KEY (`SRC`, `DEST`)
) CHARACTER SET latin1;
CREATE TABLE `iroutes` (
`SRC` VARCHAR(50) NOT NULL,
`DEST` VARCHAR(50) NOT NULL,
`DIST` INT,
PRIMARY KEY (`SRC`, `DEST`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_665512_create_tables') AS relationships;
relationships
