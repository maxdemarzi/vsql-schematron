CREATE DATABASE `db_055548_django_djsapo_schema`;
USE `db_055548_django_djsapo_schema`;
CREATE TABLE `core_alert` (
`id` INT NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`relationship` VARCHAR(50),
`description` VARCHAR(50),
`course` VARCHAR(50),
`interaction` VARCHAR(50),
`outcome` VARCHAR(50),
`created_by_id` INT,
`parent_id` INT,
`student_id` INT,
`updated_by_id` INT,
`interaction_date` DATE,
`interaction_details` VARCHAR(50),
`interaction_type` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `core_annotation` (
`id` INT NOT NULL,
`created_at` DATETIME,
`body` VARCHAR(50),
`status` TINYINT,
`alert_id` INT,
`created_by_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `core_document` (
`id` INT NOT NULL,
`created_at` DATETIME,
`name` VARCHAR(50),
`phile` VARCHAR(50),
`alert_id` INT,
`created_by_id` INT,
`updated_at` DATETIME,
`updated_by_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `django_admin_log` (
`id` INT NOT NULL,
`action_time` DATETIME,
`object_id` VARCHAR(50),
`object_repr` VARCHAR(50),
`action_flag` VARCHAR(50),
`change_message` VARCHAR(50),
`content_type_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `django_migrations` (
`id` INT NOT NULL,
`app` VARCHAR(50),
`name` VARCHAR(50),
`applied` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `django_session` (
`session_key` VARCHAR(50) NOT NULL,
`session_data` VARCHAR(50),
`expire_date` DATETIME,
PRIMARY KEY (`session_key`)
) CHARACTER SET latin1;
