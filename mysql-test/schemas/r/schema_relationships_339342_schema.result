INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 339342_schema
#
CREATE DATABASE `db_339342_schema`;
USE `db_339342_schema`;
CREATE TABLE `CUSTOMER` (
`CUSTOMERID` INT NOT NULL,
`CUSTOMERNAME` VARCHAR(50),
PRIMARY KEY (`CUSTOMERID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
`ITEMID` INT NOT NULL,
`ITEMDESC` VARCHAR(50),
`PRICE` DOUBLE,
PRIMARY KEY (`ITEMID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERDETAIL` (
`ORDERID` INT NOT NULL,
`CUSTOMERID` INT,
`ITEMID` INT,
`QUANTITY` INT,
PRIMARY KEY (`ORDERID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_339342_schema') AS relationships;
