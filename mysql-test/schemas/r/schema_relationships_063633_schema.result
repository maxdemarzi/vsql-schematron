INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 063633_schema
#
CREATE DATABASE `db_063633_schema`;
USE `db_063633_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`lastLogin` INT,
`isActive` TINYINT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shops` (
`id` INT NOT NULL,
`userId` INT,
`name` VARCHAR(50),
`isActive` TINYINT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopAddress` (
`id` INT NOT NULL,
`shopId` INT,
`address` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`country` VARCHAR(50),
`postalCode` INT,
`isActive` TINYINT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`shopId` INT,
`name` VARCHAR(50),
`label` VARCHAR(50),
`labelColor` VARCHAR(50),
`amount` INT,
`remStock` INT,
`totalStock` INT,
`isActive` TINYINT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sells` (
`id` INT NOT NULL,
`shopId` INT,
`skus` VARCHAR(50),
`description` VARCHAR(50),
`amount` INT,
`isPaid` TINYINT,
`due` INT,
`isActive` TINYINT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sellProductList` (
`id` INT NOT NULL,
`sellId` INT,
`productId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_063633_schema') AS relationships;
relationships
Database: db_063633_schema

Table Connections:
------------------
[Implied]  products.shopId -> shops.id
[Implied]  sellProductList.productId -> products.id
[Implied]  sellProductList.sellId -> sells.id
[Implied]  sells.shopId -> shops.id
[Implied]  shopAddress.shopId -> shops.id
[Implied]  shops.userId -> users.id

DROP DATABASE `db_063633_schema`;
UNINSTALL EXTENSION vsql_schematron;
