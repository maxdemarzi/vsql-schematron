INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 498662_lab9
#
CREATE DATABASE `db_498662_lab9`;
USE `db_498662_lab9`;
CREATE TABLE `courses` (
`crn` VARCHAR(50) NOT NULL,
`prefix` VARCHAR(50),
`num` SMALLINT,
`title` VARCHAR(50),
PRIMARY KEY (`crn`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`RIN` VARCHAR(50) NOT NULL,
`RCSID` CHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`alias` VARCHAR(50),
`phone` VARCHAR(50),
PRIMARY KEY (`RIN`)
) CHARACTER SET latin1;
CREATE TABLE `grades` (
`id` INT NOT NULL,
`crn` VARCHAR(50),
`RIN` VARCHAR(50),
`grade` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_498662_lab9') AS relationships;
