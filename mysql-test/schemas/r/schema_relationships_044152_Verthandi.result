INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 044152_Verthandi
#
CREATE DATABASE `db_044152_Verthandi`;
USE `db_044152_Verthandi`;
CREATE TABLE `midia` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`tipo` INT,
`autor` INT,
`status` VARCHAR(50),
`datatermino` DATE,
`avaliacao` VARCHAR(50),
`nota` INT,
`usuario` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipo` (
`idTipo` INT NOT NULL,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`usuario` INT,
PRIMARY KEY (`idTipo`)
) CHARACTER SET latin1;
CREATE TABLE `autor` (
`idAutor` INT NOT NULL,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`tipo` VARCHAR(50),
`usuario` INT,
PRIMARY KEY (`idAutor`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_044152_Verthandi') AS relationships;
relationships
