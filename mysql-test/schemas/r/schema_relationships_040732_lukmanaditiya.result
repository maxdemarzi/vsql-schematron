`meta_title` VARCHAR(50),
`meta_description` TEXT,
`meta_keyword` TEXT,
`photo` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lagu` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`seo_title` VARCHAR(50),
`content` TEXT,
`photo` VARCHAR(50),
`is_active` CHAR(50),
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menus` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`url` VARCHAR(50),
`icon` VARCHAR(50),
`is_active` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `opening` (
`id` INT NOT NULL,
`content` TEXT,
`photo` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`seo_title` VARCHAR(50),
`content` TEXT,
`photo` VARCHAR(50),
`is_active` CHAR(50),
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submenus` (
`id` INT,
`menu_id` INT,
`sub_title` VARCHAR(50),
`sub_url` VARCHAR(50),
`is_active` CHAR(50)
