INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 172238_db-schema
#
CREATE DATABASE `db_172238_db_schema`;
USE `db_172238_db_schema`;
CREATE TABLE `users` (
`user_name` VARCHAR(50) NOT NULL,
`full_name` VARCHAR(50),
`email_address` VARCHAR(50),
PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` VARCHAR(50),
`user_name` VARCHAR(50),
`submit_date` TIMESTAMP NULL,
`content` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172238_db_schema') AS relationships;
