CREATE DATABASE `db_195927_00_struct`;
USE `db_195927_00_struct`;
CREATE TABLE `CONFIG` (
`ID` INT NOT NULL,
`LIBELLE` VARCHAR(50),
`VALEUR` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLE` (
`ID` INT NOT NULL,
`LIBELLE` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UTILISATEUR` (
`ID` INT NOT NULL,
`NOM` VARCHAR(50),
`PRENOM` VARCHAR(50),
`LOGIN` VARCHAR(50),
`PASSWORD` VARCHAR(50),
`ID_ROLE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACTIVITE` (
`ID` INT NOT NULL,
`NOM` VARCHAR(50),
`LIEU` VARCHAR(50),
`SHORT_DESCRIPTION` TEXT,
`DESCRIPTION` TEXT,
`ID_UTILISATEUR` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMMENTAIRE` (
`ID` INT NOT NULL,
`TEXTE` TEXT,
`ID_ACTIVITE` INT,
`ID_UTILISATEUR` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHOTO` (
`ID` INT NOT NULL,
`CHEMIN` VARCHAR(50),
`ID_ACTIVITE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
