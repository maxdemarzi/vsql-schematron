INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 547686_database
#
CREATE DATABASE `db_547686_database`;
USE `db_547686_database`;
CREATE TABLE `AuthTokens` (
`AuthID` INT,
`Selector` CHAR(50),
`Token` CHAR(50),
`UserID` TINYINT,
`Expires` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Temps` (
`Time` TIMESTAMP NULL,
`Temp1` DOUBLE,
`Temp2` DOUBLE,
`Average` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `TempSettings` (
`TempSettingsID` TINYINT NOT NULL,
`Low` TINYINT,
`High` TINYINT,
PRIMARY KEY (`TempSettingsID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`UserID` TINYINT NOT NULL,
`Username` VARCHAR(50),
`Password` BLOB,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`Email` VARCHAR(50),
PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_547686_database') AS relationships;
