CREATE DATABASE `db_081255_V2019_07_20_19_00_14__schema_users`;
USE `db_081255_V2019_07_20_19_00_14__schema_users`;
CREATE TABLE `AUTH_ROLES` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_PRIVILEGES` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`created_by` VARCHAR(50),
`created_date` TIMESTAMP NULL,
`last_update_by` VARCHAR(50),
`last_update_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_AUTHORITIES` (
`id` VARCHAR(50) NOT NULL,
`privilege_id` VARCHAR(50),
`role_id` INT,
`created_by` VARCHAR(50),
`created_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_USER_PRIVILEGES` (
`id` VARCHAR(50) NOT NULL,
`privilege_id` VARCHAR(50),
`user_id` DECIMAL(10,2),
`created_by` VARCHAR(50),
`created_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_081255_V2019_07_20_19_00_14__schema_users') AS relationships;
