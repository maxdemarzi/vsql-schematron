INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 394941_initdb
#
CREATE DATABASE `db_394941_initdb`;
USE `db_394941_initdb`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`weight` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products_on_hand` (
`product_id` INT NOT NULL,
`quantity` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `geom` (
`id` INT NOT NULL,
`g` VARCHAR(50),
`h` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`created` VARCHAR(50),
`product` VARCHAR(50),
`qty` INT,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_394941_initdb') AS relationships;
