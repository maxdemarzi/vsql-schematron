CREATE DATABASE `db_265685_create_tables`;
USE `db_265685_create_tables`;
CREATE TABLE `tweets` (
`id` VARCHAR(50) NOT NULL,
`text` TEXT,
`url` TEXT,
`datetime` TEXT,
`created_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`icon_url` TEXT,
`user_url` TEXT,
`created_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets_x_users` (
`tweet_id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50) NOT NULL,
`omukae_done` INT,
`created_at` INT,
PRIMARY KEY (`tweet_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `scrape_histories` (
`completed` INT,
`created_at` INT
) CHARACTER SET latin1;
