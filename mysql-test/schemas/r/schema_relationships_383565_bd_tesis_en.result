CREATE DATABASE `db_383565_bd_tesis_en`;
USE `db_383565_bd_tesis_en`;
CREATE TABLE `categories` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `districts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`role` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`telephone` VARCHAR(50),
`address` TEXT,
`image` TEXT,
`points` INT,
`state` VARCHAR(50),
`district_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`remember_token` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants` (
`id` INT NOT NULL,
`category_id` INT,
`district_id` INT,
`name` VARCHAR(50),
`slogan` TEXT,
`address` TEXT,
`assessment` INT,
`points` INT,
`image` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
`card_id` INT NOT NULL,
`num_card` VARCHAR(50),
`user_id` INT,
`month` INT,
`year` INT,
`cvc` INT,
`owner` VARCHAR(50),
`country` CHAR(50),
`cod_postal` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`card_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`restaurant_id` INT,
`user_id` INT,
`date` DATE,
`hour` TIME,
`n_people` INT,
`oca_special` TEXT,
`cod_promo` CHAR(50),
`state` VARCHAR(50),
`total` DECIMAL(10,2),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorites` (
`favorite_id` INT,
`user_id` INT,
`restaurant_id` INT,
`state` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `dishes` (
`id` INT NOT NULL,
`restaurant_id` INT,
`name` TEXT,
`description` TEXT,
`price` DECIMAL(10,2),
`time` INT,
`image` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menus` (
`id` INT NOT NULL,
`dish_id` INT,
`date` DATE,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `details_orders` (
`detail_id` INT NOT NULL,
`order_id` INT,
`dish_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`detail_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_383565_bd_tesis_en') AS relationships;
