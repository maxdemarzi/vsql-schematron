CREATE DATABASE `db_688685_assignment6`;
USE `db_688685_assignment6`;
CREATE TABLE `Branch` (
`branchNo` VARCHAR(50) NOT NULL,
`street` VARCHAR(50),
`city` VARCHAR(50),
`state` CHAR(50),
`zip` VARCHAR(50),
PRIMARY KEY (`branchNo`)
) CHARACTER SET latin1;
CREATE TABLE `DVD` (
`catalogNo` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`category` VARCHAR(50),
`dailyRent` DOUBLE,
PRIMARY KEY (`catalogNo`)
) CHARACTER SET latin1;
CREATE TABLE `Rental` (
`branchNo` VARCHAR(50) NOT NULL,
`catalogNo` VARCHAR(50) NOT NULL,
`yearMonth` VARCHAR(50) NOT NULL,
`days` INT,
PRIMARY KEY (`branchNo`, `catalogNo`, `yearMonth`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_688685_assignment6') AS relationships;
