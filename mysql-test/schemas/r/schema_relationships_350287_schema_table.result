INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 350287_schema_table
#
CREATE DATABASE `db_350287_schema_table`;
USE `db_350287_schema_table`;
CREATE TABLE `user` (
`id` INT,
`pseudo` TEXT,
`email` TEXT,
`tel` TEXT,
`nom` TEXT,
`prenom` TEXT,
`paypal` TEXT,
`password` TEXT,
`disabled` INT
) CHARACTER SET latin1;
CREATE TABLE `artwork` (
`id` INT,
`filename` TEXT,
`price` DECIMAL(10,2),
`available` INT
) CHARACTER SET latin1;
CREATE TABLE `block` (
`id` INT,
`index` INT,
`previous_hash` TEXT,
`data` TEXT,
`timestamp` DECIMAL(10,2),
`hash` TEXT,
`nonce` DECIMAL(10,2),
`id_artwork` DECIMAL(10,2),
`id_user_creator` DECIMAL(10,2),
`id_user_owner` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_350287_schema_table') AS relationships;
relationships
Database: db_350287_schema_table

Table Connections:
------------------
[Implied]  block.id_artwork -> artwork.id
[Implied]  block.id_user_creator -> user.id
[Implied]  block.id_user_owner -> user.id

DROP DATABASE `db_350287_schema_table`;
UNINSTALL EXTENSION vsql_schematron;
