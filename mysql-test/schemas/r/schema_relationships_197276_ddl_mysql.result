[Implied]  Alunos.IdUsuario -> Usuarios.Id
[Implied]  AlunosAulas.IdAluno -> Alunos.Id
[Implied]  AlunosAulas.IdAula -> Aulas.Id
[Implied]  Arquivos.IdAula -> Aulas.Id
[Implied]  Arquivos.IdUsuario -> Usuarios.Id
[Implied]  Aulas.IdProfessor -> Professores.Id
[Implied]  Professores.IdUsuario -> Usuarios.Id

DROP DATABASE `db_197276_ddl_mysql`;
UNINSTALL EXTENSION vsql_schematron;
