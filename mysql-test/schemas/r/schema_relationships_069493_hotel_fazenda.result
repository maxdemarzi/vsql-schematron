INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 069493_hotel_fazenda
#
CREATE DATABASE `db_069493_hotel_fazenda`;
USE `db_069493_hotel_fazenda`;
CREATE TABLE `cliente` (
`cod_cli` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
`rg` CHAR(50),
`bairro` VARCHAR(50),
`cidade` VARCHAR(50),
`estado` CHAR(50),
`cep` CHAR(50),
`dataNascimento` DATE,
PRIMARY KEY (`cod_cli`)
) CHARACTER SET latin1;
CREATE TABLE `chale` (
`cod_chale` VARCHAR(50) NOT NULL,
`localizacao` VARCHAR(50),
`capacidade` INT,
`valorAltaEstacao` DECIMAL(10,2),
`valorBaixaEstacao` DECIMAL(10,2),
PRIMARY KEY (`cod_chale`)
) CHARACTER SET latin1;
CREATE TABLE `hospedagem` (
`cod_hosp` VARCHAR(50) NOT NULL,
`codChale` CHAR(50),
`estado` CHAR(50),
`dataInicio` DATE,
`dataFim` DATE,
`qtdPessoas` INT,
`desconto` DECIMAL(10,2),
`valorFinal` DECIMAL(10,2),
PRIMARY KEY (`cod_hosp`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_069493_hotel_fazenda') AS relationships;
relationships
Database: db_069493_hotel_fazenda

