CREATE DATABASE `db_467398_1_MySQLCreateTables`;
USE `db_467398_1_MySQLCreateTables`;
CREATE TABLE `User` (
`id` BIGINT NOT NULL,
`userName` VARCHAR(50),
`password` VARCHAR(50),
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`role` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Province` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTestType` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTest` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`date` DATETIME,
`price` DECIMAL(10,2),
`maxParticipants` INT,
`numParticipants` INT,
`sportTestTypeId` BIGINT,
`location` VARCHAR(50),
`provinceId` BIGINT,
`rating` DECIMAL(10,2),
`numRatings` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Inscription` (
`id` BIGINT NOT NULL,
`userId` BIGINT,
`sportTestId` BIGINT,
`cardNumber` VARCHAR(50),
`reservationDate` DATETIME,
`price` DECIMAL(10,2),
`dorsal` INT,
`dorsalCollected` BOOLEAN,
`score` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
