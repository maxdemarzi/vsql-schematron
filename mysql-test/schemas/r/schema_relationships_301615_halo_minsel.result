CREATE DATABASE `db_301615_halo_minsel`;
USE `db_301615_halo_minsel`;
CREATE TABLE `admin_hm` (
`id_admin` VARCHAR(50) NOT NULL,
`nama_admin` VARCHAR(50),
`password_admin` VARCHAR(50),
PRIMARY KEY (`id_admin`)
) CHARACTER SET latin1;
CREATE TABLE `laporan_hm` (
`id` INT,
`id_user` INT,
`isi_laporan` VARCHAR(50),
`tgl_laporan` VARCHAR(50),
`status_laporan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` VARCHAR(50) NOT NULL,
`version` VARCHAR(50),
`class` VARCHAR(50),
`group` VARCHAR(50),
`namespace` VARCHAR(50),
`time` INT,
`batch` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT NOT NULL,
`nik_user` VARCHAR(50),
`name_user` VARCHAR(50),
`email_user` VARCHAR(50),
`password_user` VARCHAR(50),
`nomor_user` VARCHAR(50),
`address_user` VARCHAR(50),
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_301615_halo_minsel') AS relationships;
