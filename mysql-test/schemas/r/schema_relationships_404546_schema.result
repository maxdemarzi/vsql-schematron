INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 404546_schema
#
CREATE DATABASE `db_404546_schema`;
USE `db_404546_schema`;
CREATE TABLE `customers` (
`id` VARCHAR(50) NOT NULL,
`name` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`product_id` VARCHAR(50) NOT NULL,
`product_name` CHAR(50),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` VARCHAR(50) NOT NULL,
`customer_id` VARCHAR(50),
`date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_products` (
`id` VARCHAR(50) NOT NULL,
`order_id` VARCHAR(50),
`product_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_404546_schema') AS relationships;
relationships
Database: db_404546_schema

Table Connections:
------------------
[Implied]  orders.customer_id -> customers.id
[Implied]  orders_products.order_id -> orders.id
[Implied]  orders_products.product_id -> products.product_id

DROP DATABASE `db_404546_schema`;
UNINSTALL EXTENSION vsql_schematron;
