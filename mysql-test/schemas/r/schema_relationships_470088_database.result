INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 470088_database
#
CREATE DATABASE `db_470088_database`;
USE `db_470088_database`;
CREATE TABLE `authors` (
`id` BIGINT NOT NULL,
`news_id` BIGINT,
`author_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` BIGINT NOT NULL,
`news_id` BIGINT,
`category_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` BIGINT NOT NULL,
`news_id` BIGINT,
`author` VARCHAR(50),
`content` TEXT,
`datetime` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`id` BIGINT NOT NULL,
`news_id` BIGINT,
`image_url` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` BIGINT NOT NULL,
`title` VARCHAR(50),
`url` VARCHAR(50),
`datetime` VARCHAR(50),
`content_type` VARCHAR(50),
`regional` VARCHAR(50),
`text` TEXT,
`scraped_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` BIGINT NOT NULL,
`news_id` BIGINT,
`tag_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_470088_database') AS relationships;
relationships
Database: db_470088_database

Table Connections:
------------------
[Implied]  authors.news_id -> news.id
[Implied]  categories.news_id -> news.id
[Implied]  comments.news_id -> news.id
[Implied]  images.news_id -> news.id
[Implied]  tags.news_id -> news.id

DROP DATABASE `db_470088_database`;
UNINSTALL EXTENSION vsql_schematron;
