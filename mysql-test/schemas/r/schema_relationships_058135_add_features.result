CREATE TABLE `feature` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`feature_type` VARCHAR(50),
`post_personality` SMALLINT,
`creation_date` DATE,
`comments` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature_link` (
`id` INT NOT NULL,
`feature_id` INT,
`model_id` INT,
`archetype_id` INT,
`personality_id` INT,
`interface_name` VARCHAR(50),
`creation_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
