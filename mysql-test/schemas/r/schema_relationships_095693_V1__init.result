INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 095693_V1__init
#
CREATE DATABASE `db_095693_V1__init`;
USE `db_095693_V1__init`;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`user_name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`billing_address` VARCHAR(50),
`billing_province` VARCHAR(50),
`billing_country` VARCHAR(50),
`phone_number` VARCHAR(50),
`zip` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` BIGINT NOT NULL,
`title` VARCHAR(50),
`author` VARCHAR(50),
`account_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chapter` (
`id` BIGINT NOT NULL,
`title` VARCHAR(50),
`book_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercise` (
`id` BIGINT NOT NULL,
`chapter_id` BIGINT,
`exercise` VARCHAR(50),
`answer` INT,
`question` VARCHAR(50),
`one` VARCHAR(50),
`two` VARCHAR(50),
`three` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_095693_V1__init') AS relationships;
relationships
Database: db_095693_V1__init

Table Connections:
------------------
[Implied]  account.user_id -> user.id
[Implied]  book.account_id -> account.id
[Implied]  chapter.book_id -> book.id
[Implied]  exercise.chapter_id -> chapter.id

DROP DATABASE `db_095693_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
