CREATE DATABASE `db_426665_DataBaseSQL`;
USE `db_426665_DataBaseSQL`;
CREATE TABLE `Users` (
`user_id` VARCHAR(50) NOT NULL,
`user_email` VARCHAR(50),
`user_password` VARCHAR(50),
`user_point` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Submit` (
`user_id` VARCHAR(50),
`question_id` INT,
`submit_time` TIME,
`type` VARCHAR(50),
`codeName` VARCHAR(50) NOT NULL,
`result` VARCHAR(50),
`time` INT,
`ram` INT,
PRIMARY KEY (`codeName`)
) CHARACTER SET latin1;
CREATE TABLE `TestData` (
`question_id` INT,
`test_data` VARCHAR(50),
`result_data` VARCHAR(50)
) CHARACTER SET latin1;
