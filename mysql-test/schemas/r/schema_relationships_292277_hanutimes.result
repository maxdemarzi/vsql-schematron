INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 292277_hanutimes
#
CREATE DATABASE `db_292277_hanutimes`;
USE `db_292277_hanutimes`;
CREATE TABLE `category` (
`id` INT NOT NULL,
`category` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` INT NOT NULL,
`title` TEXT,
`short_intro` TEXT,
`content` TEXT,
`created_date` DATE,
`pic` VARCHAR(50),
`author` VARCHAR(50),
`cat_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`id` INT NOT NULL,
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tagnews` (
`id` INT NOT NULL,
`tag_id` INT,
`news_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT NOT NULL,
`name` TEXT,
`comment` TEXT,
`news_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_292277_hanutimes') AS relationships;
relationships
Database: db_292277_hanutimes

Table Connections:
------------------
[Implied]  comment.news_id -> news.id
[Implied]  news.cat_id -> category.id
[Implied]  tagnews.news_id -> news.id
[Implied]  tagnews.tag_id -> tag.id

DROP DATABASE `db_292277_hanutimes`;
UNINSTALL EXTENSION vsql_schematron;
