INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 145723_foro
#
CREATE DATABASE `db_145723_foro`;
USE `db_145723_foro`;
CREATE TABLE `users` (
`name_user` VARCHAR(50) NOT NULL,
`pass` VARCHAR(50),
`email` VARCHAR(50),
`nombre` VARCHAR(50),
`puntos` INT,
`estado` BOOLEAN,
`rango` VARCHAR(50),
`apellido` VARCHAR(50),
`fecha` DATETIME,
`img_perfil` VARCHAR(50),
`img_portada` VARCHAR(50),
PRIMARY KEY (`name_user`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`url` VARCHAR(50) NOT NULL,
`titulo` VARCHAR(50),
`cuerpo` VARCHAR(50),
`fecha` DATETIME,
`user` VARCHAR(50),
PRIMARY KEY (`url`)
) CHARACTER SET latin1;
CREATE TABLE `comentario` (
`id_comet` INT NOT NULL,
`url` VARCHAR(50),
`fecha` DATETIME,
`user` VARCHAR(50),
`contenido` VARCHAR(50),
PRIMARY KEY (`id_comet`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_145723_foro') AS relationships;
relationships
Database: db_145723_foro

Table Connections:
------------------
[Implied]  comentario.url -> post.url
[Implied]  comentario.user -> users.name_user
[Implied]  post.user -> users.name_user

DROP DATABASE `db_145723_foro`;
UNINSTALL EXTENSION vsql_schematron;
