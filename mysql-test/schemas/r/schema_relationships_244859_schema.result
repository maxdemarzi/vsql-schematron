INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 244859_schema
#
CREATE DATABASE `db_244859_schema`;
USE `db_244859_schema`;
CREATE TABLE `admins` (
`adminid` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`adminid`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
`roomid` INT NOT NULL,
`name` VARCHAR(50),
`adminid` INT,
PRIMARY KEY (`roomid`)
) CHARACTER SET latin1;
CREATE TABLE `participants` (
`participantid` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`participantid`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`messageid` INT NOT NULL,
`time` TEXT,
`messagebody` TEXT,
`roomid` INT,
`participantid` INT,
PRIMARY KEY (`messageid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_244859_schema') AS relationships;
