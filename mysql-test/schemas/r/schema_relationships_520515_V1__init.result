INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 520515_V1__init
#
CREATE DATABASE `db_520515_V1__init`;
USE `db_520515_V1__init`;
CREATE TABLE `empresa` (
`id_empresa` BIGINT NOT NULL,
`cnpj` VARCHAR(50),
`data_atualizacao` TIMESTAMP NULL,
`data_criacao` TIMESTAMP NULL,
`razao_social` VARCHAR(50),
PRIMARY KEY (`id_empresa`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
`id_funcionario` BIGINT NOT NULL,
`cpf` VARCHAR(50),
`data_atualizacao` TIMESTAMP NULL,
`data_criacao` TIMESTAMP NULL,
`email` VARCHAR(50),
`nome` VARCHAR(50),
`perfil` VARCHAR(50),
`qtd_horas_almoco` DOUBLE,
`qtd_horas_trabalho_dia` DOUBLE,
`senha` VARCHAR(50),
`valor_hora` DECIMAL(10,2),
`id_empresa` INT,
PRIMARY KEY (`id_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `lancamento` (
`id_lancamento` BIGINT NOT NULL,
`data` TIMESTAMP NULL,
`data_atualizacao` TIMESTAMP NULL,
`data_criacao` TIMESTAMP NULL,
`descricao` VARCHAR(50),
`localizacao` VARCHAR(50),
`tipo` VARCHAR(50),
`id_funcionario` INT,
PRIMARY KEY (`id_lancamento`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_520515_V1__init') AS relationships;
