CREATE DATABASE `db_571134_Untitled_mysql_create`;
USE `db_571134_Untitled_mysql_create`;
CREATE TABLE `tb_pacientes` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`telefone` VARCHAR(50),
`data_nascimento` DATE,
`convenio` VARCHAR(50),
`diagnostico` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_medicos` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`telefone` VARCHAR(50),
`crm` VARCHAR(50),
`especialidade` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_agenda` (
`id` INT NOT NULL,
`data` DATE,
`hora` TIME,
`id_medico` INT,
`sala` VARCHAR(50),
`id_paciente` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
