INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 582102_schema
#
CREATE DATABASE `db_582102_schema`;
USE `db_582102_schema`;
CREATE TABLE `accident_type` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accident` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`text` VARCHAR(50),
`address` VARCHAR(50),
`accident_type_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accident_rule` (
`accident_id` INT NOT NULL,
`rule_id` INT NOT NULL,
PRIMARY KEY (`accident_id`, `rule_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_582102_schema') AS relationships;
relationships
