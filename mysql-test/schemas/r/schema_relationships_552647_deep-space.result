INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 552647_deep-space
#
CREATE DATABASE `db_552647_deep_space`;
USE `db_552647_deep_space`;
CREATE TABLE `teams` (
`id` INT NOT NULL,
`number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `matches` (
`team_number` INT,
`type` TEXT,
`match_number` INT,
`alliance` TINYINT,
`cargo_tracker_id` INT,
`hatch_tracker_id` INT,
`associated_team` INT,
`tech_fouls` INT,
`fouls` INT,
`yellow_card` TINYINT,
`red_card` TINYINT,
`estopped` TINYINT,
`borked` TINYINT,
`ranking_points` INT,
`foul_points` INT,
`bonus_points` INT,
`helps_hab_climb` TINYINT,
`start_hab_level` SMALLINT,
`end_hab_level` SMALLINT,
`crosses_start_line` TINYINT,
`left_rocket_assembled` TINYINT,
`right_rocket_assembled` TINYINT,
`hab_ranking_point` TINYINT,
`rocket_ranking_point` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `cargo_trackers` (
`id` INT NOT NULL,
`dropped_auto` INT,
`dropped_teleop` INT,
`ship_auto` INT,
`ship_teleop` INT,
`rocket_auto` INT,
`rocket_teleop` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hatch_trackers` (
`id` INT NOT NULL,
`dropped_auto` INT,
`dropped_teleop` INT,
`ship_auto` INT,
`ship_teleop` INT,
`rocket_auto` INT,
`rocket_teleop` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_552647_deep_space') AS relationships;
relationships
Database: db_552647_deep_space

Table Connections:
------------------
[Implied]  matches.associated_team -> teams.id
[Implied]  matches.cargo_tracker_id -> cargo_trackers.id
[Implied]  matches.hatch_tracker_id -> hatch_trackers.id

DROP DATABASE `db_552647_deep_space`;
UNINSTALL EXTENSION vsql_schematron;
