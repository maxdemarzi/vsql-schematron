CREATE DATABASE `db_288762_zoo`;
USE `db_288762_zoo`;
CREATE TABLE `caretakers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`middle_name` VARCHAR(50),
`last_name` VARCHAR(50),
`date_of_birth` DATE,
`address_id` INT,
`phone_id` INT,
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`id` INT NOT NULL,
`house_no` VARCHAR(50),
`street` VARCHAR(50),
`landmark` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`country` VARCHAR(50),
`zipcode` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `animals` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`age` INT,
`date_of_birth` DATE,
`cageid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
