INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 284378_schema
#
CREATE DATABASE `db_284378_schema`;
USE `db_284378_schema`;
CREATE TABLE `msp_company` (
`company_recid` INT NOT NULL,
`company_id` CHAR(50),
`company_name` CHAR(50),
`phone_number` CHAR(50),
`contact_first_name` CHAR(50),
`contact_last_name` CHAR(50),
`username` CHAR(50),
`password` CHAR(50),
PRIMARY KEY (`company_recid`)
) CHARACTER SET latin1;
CREATE TABLE `msp_device` (
`device_recid` INT NOT NULL,
`device_id` CHAR(50),
`manufacturer` CHAR(50),
`description` CHAR(50),
`device_type` CHAR(50),
`mac_address` CHAR(50),
`ip_address` CHAR(50),
`site_recid` INT,
PRIMARY KEY (`device_recid`)
) CHARACTER SET latin1;
CREATE TABLE `msp_site` (
`site_recid` INT NOT NULL,
`company_recid` INT,
`description` CHAR(50),
`address1` CHAR(50),
`address2` CHAR(50),
`city` CHAR(50),
`province` CHAR(50),
`postal_code` CHAR(50),
`latitude` CHAR(50),
`longitude` CHAR(50),
PRIMARY KEY (`site_recid`)
) CHARACTER SET latin1;
CREATE TABLE `msp_ping` (
`ping_recid` INT NOT NULL,
`device_recid` INT,
`ip_address` CHAR(50),
`ms_response` INT,
`responded` BOOLEAN,
`datetime` TIMESTAMP NULL,
PRIMARY KEY (`ping_recid`)
) CHARACTER SET latin1;
CREATE TABLE `msp_ping_30` (
`ping_30_recid` INT NOT NULL,
`device_recid` INT,
`ip_address` CHAR(50),
`ms_response` INT,
`response_count` DECIMAL(10,2),
`datetime` TIMESTAMP NULL,
PRIMARY KEY (`ping_30_recid`)
) CHARACTER SET latin1;
CREATE TABLE `msp_ping_60` (
`ping_60_recid` INT NOT NULL,
`device_recid` INT,
`ip_address` CHAR(50),
`ms_response` INT,
`response_count` DECIMAL(10,2),
`datetime` TIMESTAMP NULL,
PRIMARY KEY (`ping_60_recid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_284378_schema') AS relationships;
