`QUERY_HASH` BIGINT NOT NULL,
`TIME_PERSIST` TIMESTAMP NULL,
PRIMARY KEY (`QUERY_HASH`)
) CHARACTER SET latin1;
CREATE TABLE `WEB_RESULT` (
`ID` INT NOT NULL,
`TITLE` VARCHAR(50),
`URL` VARCHAR(50),
`DISPLAY_URL` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`QUERY_HASH` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SCORING_RESULT` (
`TAGS_HASH` BIGINT NOT NULL,
`WEB_RESULT_ID` INT NOT NULL,
`SCORE` INT,
PRIMARY KEY (`TAGS_HASH`, `WEB_RESULT_ID`)
) CHARACTER SET latin1;
