CREATE DATABASE `db_237509_migration`;
USE `db_237509_migration`;
CREATE TABLE `Product` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`price` INT,
`image` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
`id` VARCHAR(50) NOT NULL,
`email` TEXT,
`subtotal` INT,
`tax` INT,
`total` INT,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderItem` (
`id` VARCHAR(50) NOT NULL,
`price` INT,
`orderId` TEXT,
`productId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_237509_migration') AS relationships;
