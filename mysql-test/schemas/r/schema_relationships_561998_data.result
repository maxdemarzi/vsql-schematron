INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 561998_data
#
CREATE DATABASE `db_561998_data`;
USE `db_561998_data`;
CREATE TABLE `STUDY_GROUP` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(50),
`STUDY_GROUP_ID` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `GRADE` (
`ID` DECIMAL(10,2),
`COURSE` VARCHAR(50),
`GRADE` VARCHAR(50),
`STUDENT_ID` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_561998_data') AS relationships;
relationships
Database: db_561998_data

Table Connections:
------------------
[Implied]  GRADE.STUDENT_ID -> STUDENT.ID
[Implied]  STUDENT.STUDY_GROUP_ID -> STUDY_GROUP.ID

DROP DATABASE `db_561998_data`;
UNINSTALL EXTENSION vsql_schematron;
