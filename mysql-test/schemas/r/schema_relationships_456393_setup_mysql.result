) CHARACTER SET latin1;
CREATE TABLE `sourceips` (
`sourceipID` INT NOT NULL,
`sourceip` VARCHAR(50),
PRIMARY KEY (`sourceipID`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
`jobID` INT NOT NULL,
`jobName` VARCHAR(50),
`active` TINYINT,
