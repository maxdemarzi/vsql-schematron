CREATE TABLE `People` (
`id` VARCHAR(50) NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`card_number` INT,
`adress` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
`id` VARCHAR(50) NOT NULL,
`book_name` VARCHAR(50),
`writer` VARCHAR(50),
`resume` TEXT,
`created_date` VARCHAR(50),
`category` VARCHAR(50),
`borrowed` VARCHAR(50),
`people_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
