CREATE DATABASE `db_027553_migration`;
USE `db_027553_migration`;
CREATE TABLE `User` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`name` TEXT,
`email` TEXT,
`hashedPassword` TEXT,
`role` TEXT,
`picture` TEXT,
`organizationId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`expiresAt` TIMESTAMP NULL,
`handle` TEXT,
`hashedSessionToken` TEXT,
`antiCSRFToken` TEXT,
`publicData` TEXT,
`privateData` TEXT,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Organization` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`domain` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Token` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`hashedToken` TEXT,
`type` VARCHAR(50),
`expiresAt` TIMESTAMP NULL,
`sentTo` TEXT,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`description` TEXT,
`dueDate` TIMESTAMP NULL,
`completedAt` TIMESTAMP NULL,
`assignedUserId` INT,
`creatorId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
