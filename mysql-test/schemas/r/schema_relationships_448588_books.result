INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 448588_books
#
CREATE DATABASE `db_448588_books`;
USE `db_448588_books`;
CREATE TABLE `book_copies` (
`id` INT NOT NULL,
`library_branch_id` INT,
`no_of_copies` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `library_branches` (
`id` INT NOT NULL,
`library_branch_name` VARCHAR(50),
`address` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_lendings` (
`id` VARCHAR(50) NOT NULL,
`library_branch_id` INT,
`card_no` VARCHAR(50),
`date_out` DATE,
`due_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_448588_books') AS relationships;
relationships
