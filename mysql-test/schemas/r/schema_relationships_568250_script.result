INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 568250_script
#
CREATE DATABASE `db_568250_script`;
USE `db_568250_script`;
CREATE TABLE `AUTOR` (
`AUTID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`AUTID`)
) CHARACTER SET latin1;
CREATE TABLE `WYDAWCA` (
`WYDID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`WYDID`)
) CHARACTER SET latin1;
CREATE TABLE `POZYCJE` (
`ISBN` VARCHAR(50) NOT NULL,
`AUTID` INT,
`TYTUL` VARCHAR(50),
`WYDID` INT,
`ROK` INT,
`CENA` DOUBLE,
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_568250_script') AS relationships;
relationships
