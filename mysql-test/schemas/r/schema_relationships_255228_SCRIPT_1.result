INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 255228_SCRIPT_1
#
CREATE DATABASE `db_255228_SCRIPT_1`;
USE `db_255228_SCRIPT_1`;
CREATE TABLE `DEPARTMENT` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHIEF` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`SALARY` INT,
`DEPARTMENT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`SALARY` INT,
`DEPARTMENT_ID` INT,
`CHIEF_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_255228_SCRIPT_1') AS relationships;
relationships
