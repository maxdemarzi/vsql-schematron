INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 103347_init
#
CREATE DATABASE `db_103347_init`;
USE `db_103347_init`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` TEXT,
`price` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory` (
`product_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`customer_id` INT,
`order_date` DATE,
`pending` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_details` (
`order_id` INT,
`product_id` INT,
`quantity` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_103347_init') AS relationships;
relationships
Database: db_103347_init

Table Connections:
------------------
[Implied]  inventory.product_id -> products.id
[Implied]  order_details.order_id -> orders.id
[Implied]  order_details.product_id -> products.id

DROP DATABASE `db_103347_init`;
UNINSTALL EXTENSION vsql_schematron;
