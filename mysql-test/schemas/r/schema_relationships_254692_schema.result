INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 254692_schema
#
CREATE DATABASE `db_254692_schema`;
USE `db_254692_schema`;
CREATE TABLE `show` (
`id` INT NOT NULL,
`artist_id` INT,
`venue_id` INT,
`start_time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `venue` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`address` VARCHAR(50),
`phone` VARCHAR(50),
`genre` VARCHAR(50),
`facebook_link` VARCHAR(50),
`image_link` VARCHAR(50),
`website_link` VARCHAR(50),
`seeking_talent` BOOLEAN,
`seeking_description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`address` VARCHAR(50),
`phone` VARCHAR(50),
`genre` VARCHAR(50),
`facebook_link` VARCHAR(50),
`image_link` VARCHAR(50),
`website_link` VARCHAR(50),
`seeking_venue` BOOLEAN,
`seeking_description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_254692_schema') AS relationships;
relationships
