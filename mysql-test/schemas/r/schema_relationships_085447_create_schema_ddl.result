INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 085447_create_schema_ddl
#
CREATE DATABASE `db_085447_create_schema_ddl`;
USE `db_085447_create_schema_ddl`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`logged_in_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `topics` (
`id` INT NOT NULL,
`topic` VARCHAR(50),
`description` VARCHAR(50),
`topic_created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`user_id` INT,
`topic_id` INT,
`title` VARCHAR(50),
`url` VARCHAR(50),
`post` TEXT,
`post_created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`user_id` INT,
`post_id` INT,
`comment` TEXT,
`parent_comment_id` INT,
`comment_created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`id` INT NOT NULL,
`user_id` INT,
`post_id` INT,
`vote` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_085447_create_schema_ddl') AS relationships;
relationships
Database: db_085447_create_schema_ddl

Table Connections:
------------------
[Implied]  comments.parent_comment_id -> comments.id
[Implied]  comments.post_id -> posts.id
[Implied]  comments.user_id -> users.id
[Implied]  posts.topic_id -> topics.id
[Implied]  posts.user_id -> users.id
[Implied]  votes.post_id -> posts.id
[Implied]  votes.user_id -> users.id

DROP DATABASE `db_085447_create_schema_ddl`;
UNINSTALL EXTENSION vsql_schematron;
