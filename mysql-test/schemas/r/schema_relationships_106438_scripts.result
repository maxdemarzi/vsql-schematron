INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 106438_scripts
#
CREATE DATABASE `db_106438_scripts`;
USE `db_106438_scripts`;
CREATE TABLE `courses` (
`cod` INT NOT NULL,
`coursename` VARCHAR(50),
`ch` VARCHAR(50),
`typecourse` VARCHAR(50),
`created_at` DATE,
PRIMARY KEY (`cod`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`cod` INT NOT NULL,
`name` VARCHAR(50),
`cpf` VARCHAR(50),
`email` VARCHAR(50),
`fone` VARCHAR(50),
`cep` VARCHAR(50),
`address` VARCHAR(50),
`addressnumber` VARCHAR(50),
`neighborhood` VARCHAR(50),
`uf` VARCHAR(50),
`state` VARCHAR(50),
`city` VARCHAR(50),
`course_cod` INT,
`created_at` DATE,
PRIMARY KEY (`cod`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_106438_scripts') AS relationships;
