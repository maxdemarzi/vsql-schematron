INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 066566_modelagem
#
CREATE DATABASE `db_066566_modelagem`;
USE `db_066566_modelagem`;
CREATE TABLE `curso` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`carga_horaria` INT,
`id_instituicao` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `municipio` (
`id` INT NOT NULL,
`nm_municipio` VARCHAR(50),
`cod_mun` INT,
`qt_popula` VARCHAR(50),
`area_mun` VARCHAR(50),
`coord` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`usuario` VARCHAR(50),
`senha` VARCHAR(50),
`id_aluno` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aluno` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`sobrenome` VARCHAR(50),
`endereco` VARCHAR(50),
`bairro` VARCHAR(50),
`contato` VARCHAR(50),
`sexo` VARCHAR(50),
`data_nascimento` DATE,
`uf` CHAR(50),
`id_municipio` INT,
`id_curso` INT,
`id_instituicao` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instituicao` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`site` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_066566_modelagem') AS relationships;
relationships
Database: db_066566_modelagem

Table Connections:
