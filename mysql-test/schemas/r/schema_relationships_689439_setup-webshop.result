[Implied]  OrderRow.order_id -> Order.id
[Implied]  OrderRow.product_id -> Product.id
[Implied]  Prod2Cat.category_id -> ProdCategory.id
[Implied]  Prod2Cat.product_id -> Product.id

DROP DATABASE `db_689439_setup_webshop`;
