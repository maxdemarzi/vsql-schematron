INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 510623_database
#
CREATE DATABASE `db_510623_database`;
USE `db_510623_database`;
CREATE TABLE `author` (
`author_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`book_id` INT NOT NULL,
`title` VARCHAR(50),
`filename` VARCHAR(50),
`author_id` INT,
PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_rates` (
`rate_id` INT NOT NULL,
`book_id` INT,
`rate` INT,
PRIMARY KEY (`rate_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`role` VARCHAR(50),
`display_name` VARCHAR(50),
`points` INT,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_510623_database') AS relationships;
relationships
