INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 318118_MediaSearch.Schema
#
CREATE DATABASE `db_318118_MediaSearch_Schema`;
USE `db_318118_MediaSearch_Schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`user_name` VARCHAR(50),
`user_email` VARCHAR(50),
`user_password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media` (
`id` INT NOT NULL,
`media_name` VARCHAR(50),
`media_type` VARCHAR(50),
`media_artist` VARCHAR(50),
`media_location` VARCHAR(50),
`media_rating` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_318118_MediaSearch_Schema') AS relationships;
