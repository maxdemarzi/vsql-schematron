CREATE DATABASE `db_555936_db`;
USE `db_555936_db`;
CREATE TABLE `users` (
`idUser` INT NOT NULL,
`nome` VARCHAR(50),
`local` VARCHAR(50),
PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`idPost` INT NOT NULL,
`texto` VARCHAR(50),
`imagem` BLOB,
`idUser` INT,
PRIMARY KEY (`idPost`)
) CHARACTER SET latin1;
CREATE TABLE `parceirias` (
`idParceiro` INT NOT NULL,
`nome` VARCHAR(50),
`texto` VARCHAR(50),
`image` BLOB,
`telefone` VARCHAR(50),
PRIMARY KEY (`idParceiro`)
) CHARACTER SET latin1;
CREATE TABLE `avisos` (
`idavisos` INT NOT NULL,
`titulo` VARCHAR(50),
`texto` VARCHAR(50),
`image` BLOB,
PRIMARY KEY (`idavisos`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_555936_db') AS relationships;
