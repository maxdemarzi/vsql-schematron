`start` INT,
`end` INT,
`status` TEXT,
`extra` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Step` (
`id` INT NOT NULL,
`build_id` INT,
`description` TEXT,
`start` INT,
`end` INT,
`status` TEXT,
`output` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
