`nif` VARCHAR(50) NOT NULL,
`nombre` VARCHAR(50),
`apellidos` VARCHAR(50),
`administrador` TINYINT,
`contraseña` VARCHAR(50),
PRIMARY KEY (`nif`)
) CHARACTER SET latin1;
CREATE TABLE `fichaje` (
`nif` VARCHAR(50),
`horaEntrada` DATETIME,
`horaSalida` DATETIME,
`finalizar` TINYINT
) CHARACTER SET latin1;
