CREATE DATABASE `db_605043_infaq_ci4`;
USE `db_605043_infaq_ci4`;
CREATE TABLE `infaqq` (
`id_infaq` INT,
`nama` VARCHAR(50),
`email` VARCHAR(50),
`no_telp` INT,
`jumlah` VARCHAR(50),
`id_pembayaran` INT
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` VARCHAR(50) NOT NULL,
`version` VARCHAR(50),
`class` VARCHAR(50),
`group` VARCHAR(50),
`namespace` VARCHAR(50),
`time` INT,
`batch` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pembayaran` (
`id_pembayaran` INT NOT NULL,
`metode` VARCHAR(50),
`norek` VARCHAR(50),
`logo` VARCHAR(50),
PRIMARY KEY (`id_pembayaran`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605043_infaq_ci4') AS relationships;
