INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 048326_bank_accenture
#
CREATE DATABASE `db_048326_bank_accenture`;
USE `db_048326_bank_accenture`;
CREATE TABLE `agency` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`address` VARCHAR(50),
`phone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `current_account` (
`id` INT NOT NULL,
`number` VARCHAR(50),
`balance` DECIMAL(10,2),
`fk_idAgency` INT,
`fk_idClient` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `extract` (
`idExtract` INT NOT NULL,
`moveDate` DATETIME,
`operation` VARCHAR(50),
`value` DECIMAL(10,2),
`fk_idCurrentAccount` INT,
PRIMARY KEY (`idExtract`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_048326_bank_accenture') AS relationships;
relationships
Database: db_048326_bank_accenture

Table Connections:
------------------
[Implied]  current_account.fk_idAgency -> agency.id
[Implied]  extract.fk_idCurrentAccount -> current_account.id

DROP DATABASE `db_048326_bank_accenture`;
