INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 449114_efinance
#
CREATE DATABASE `db_449114_efinance`;
USE `db_449114_efinance`;
CREATE TABLE `laporan` (
`id_laporan` INT NOT NULL,
`email` VARCHAR(50),
`username` VARCHAR(50),
`judul` VARCHAR(50),
`isi` TEXT,
PRIMARY KEY (`id_laporan`)
) CHARACTER SET latin1;
CREATE TABLE `pemasukan` (
`id_pemasukan` INT,
`tgl_pemasukan` DATE,
`jumlah` INT,
`keterangan` TEXT,
`id_user` INT
) CHARACTER SET latin1;
CREATE TABLE `pengeluaran` (
`id_pengeluaran` INT,
`tgl_pengeluaran` DATE,
`jumlah` INT,
`keterangan` TEXT,
`id_user` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT,
`nama` VARCHAR(50),
`email` VARCHAR(50),
`noHP` VARCHAR(50),
`username` VARCHAR(50),
`pass` VARCHAR(50),
`type` VARCHAR(50),
`status` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_449114_efinance') AS relationships;
relationships
