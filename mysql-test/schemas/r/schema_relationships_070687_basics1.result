CREATE DATABASE `db_070687_basics1`;
USE `db_070687_basics1`;
CREATE TABLE `person` (
`person_id` VARCHAR(50) NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`gender` VARCHAR(50),
`birth_date` DATE,
`street` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`country` VARCHAR(50),
`postal_code` VARCHAR(50),
PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
CREATE TABLE `favorite_food` (
`person_id` VARCHAR(50) NOT NULL,
`food` VARCHAR(50) NOT NULL,
PRIMARY KEY (`person_id`, `food`)
) CHARACTER SET latin1;
CREATE TABLE `string_tbl` (
`char_fld` CHAR(50),
`vchar_fld` VARCHAR(50),
`text_fld` TEXT
) CHARACTER SET latin1;
