`IField` VARCHAR(50),
`IValue` VARCHAR(50),
`IIcon` INT,
`IID` INT,
`ReportID` INT
) CHARACTER SET latin1;
CREATE TABLE `NextID` (
`TableName` VARCHAR(50) NOT NULL,
`NextID` INT,
PRIMARY KEY (`TableName`)
) CHARACTER SET latin1;
