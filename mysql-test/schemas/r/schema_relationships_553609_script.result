CREATE DATABASE `db_553609_script`;
USE `db_553609_script`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`unitary_value` DECIMAL(10,2),
`qtd_stock` INT,
`creation_date` DATETIME,
`update_date` DATETIME,
`exclusion_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` INT NOT NULL,
`product_id` INT,
`sale_value` DECIMAL(10,2),
`date_sale` DATETIME,
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_553609_script') AS relationships;
