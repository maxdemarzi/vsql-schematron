INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 651725_AssignmentCinemaSystem
#
CREATE DATABASE `db_651725_AssignmentCinemaSystem`;
USE `db_651725_AssignmentCinemaSystem`;
CREATE TABLE `Film` (
`Film_ID` DECIMAL(10,2) NOT NULL,
`Release_Date` DATE,
`Film_Name` VARCHAR(50),
`Priority_Rating` DECIMAL(10,2),
`FIlm_Rating` VARCHAR(50),
`Film_Duration` DECIMAL(10,2),
`Start_Showing` TIMESTAMP NULL,
`End_Showing` TIMESTAMP NULL,
PRIMARY KEY (`Film_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Screen` (
`Screen_No` DECIMAL(10,2) NOT NULL,
`Capacity` DECIMAL(10,2),
`Prem_Capacity` DECIMAL(10,2),
PRIMARY KEY (`Screen_No`)
) CHARACTER SET latin1;
CREATE TABLE `Showing` (
`Showing_ID` DECIMAL(10,2) NOT NULL,
`Screen_No` DECIMAL(10,2),
`Film_ID` DECIMAL(10,2),
`Start_Time` TIMESTAMP NULL,
PRIMARY KEY (`Showing_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Booking` (
`Booking_ID` DECIMAL(10,2) NOT NULL,
`Amount_ppl` DECIMAL(10,2),
`Card_No` DECIMAL(10,2),
`Name` VARCHAR(50),
PRIMARY KEY (`Booking_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Ticket` (
`Ticket_ID` DECIMAL(10,2) NOT NULL,
`Booking_ID` DECIMAL(10,2),
`Showing_ID` DECIMAL(10,2),
`Premium` DECIMAL(10,2),
`Sold` DECIMAL(10,2),
`Seat_No` DECIMAL(10,2),
PRIMARY KEY (`Ticket_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_651725_AssignmentCinemaSystem') AS relationships;
relationships
Database: db_651725_AssignmentCinemaSystem

