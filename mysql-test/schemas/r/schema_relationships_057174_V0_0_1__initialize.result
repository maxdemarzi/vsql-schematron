CREATE TABLE `Greeting` (
`id` VARCHAR(50) NOT NULL,
`referenceId` VARCHAR(50),
`text` VARCHAR(50),
`version` VARCHAR(50),
`createdBy` VARCHAR(50),
`createdAt` DATETIME,
`updatedBy` VARCHAR(50),
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`id` VARCHAR(50) NOT NULL,
`referenceId` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`enabled` VARCHAR(50),
`credentialsexpired` VARCHAR(50),
`expired` VARCHAR(50),
`locked` VARCHAR(50),
`version` VARCHAR(50),
`createdBy` VARCHAR(50),
`createdAt` DATETIME,
`updatedBy` VARCHAR(50),
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Role` (
`id` VARCHAR(50) NOT NULL,
`code` VARCHAR(50),
`label` VARCHAR(50),
`ordinal` VARCHAR(50),
`effectiveAt` DATETIME,
`expiresAt` DATETIME,
`createdAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AccountRole` (
`accountId` VARCHAR(50) NOT NULL,
`roleId` VARCHAR(50) NOT NULL,
PRIMARY KEY (`accountId`, `roleId`)
) CHARACTER SET latin1;
