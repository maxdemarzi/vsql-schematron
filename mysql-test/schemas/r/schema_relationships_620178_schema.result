INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 620178_schema
#
CREATE DATABASE `db_620178_schema`;
USE `db_620178_schema`;
CREATE TABLE `companies` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`tin` VARCHAR(50),
`address` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`birth_date` DATE,
`email` VARCHAR(50),
`company_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_620178_schema') AS relationships;
