INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 474806_Tables
#
CREATE DATABASE `db_474806_Tables`;
USE `db_474806_Tables`;
CREATE TABLE `PEOPLES` (
`ID` VARCHAR(50) NOT NULL,
`NAME` VARCHAR(50),
`PHONE_NUMBER` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOKS` (
`ID` VARCHAR(50) NOT NULL,
`NAME` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOKS_RENTALS` (
`ID` VARCHAR(50) NOT NULL,
`BOOK_ID` VARCHAR(50),
`PEOPLE_ID` VARCHAR(50),
`RENTED_DATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_474806_Tables') AS relationships;
relationships
