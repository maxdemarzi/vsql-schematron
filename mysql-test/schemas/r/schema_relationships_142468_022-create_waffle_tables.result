CREATE DATABASE `db_142468_022_create_waffle_tables`;
USE `db_142468_022_create_waffle_tables`;
CREATE TABLE `waffle_flag_groups` (
`id` INT NOT NULL,
`flag_id` INT,
`group_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `waffle_flag_users` (
`id` INT NOT NULL,
`flag_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `waffle_flag` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`everyone` BOOLEAN,
`percent` DECIMAL(10,2),
`testing` BOOLEAN,
`superusers` BOOLEAN,
`staff` BOOLEAN,
`authenticated` BOOLEAN,
`rollout` BOOLEAN,
`note` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `waffle_switch` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`active` BOOLEAN,
`note` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `waffle_sample` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`percent` DECIMAL(10,2),
`note` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_142468_022_create_waffle_tables') AS relationships;
