CREATE DATABASE `db_389642_schema`;
USE `db_389642_schema`;
CREATE TABLE `SENSORS` (
`Id` INT NOT NULL,
`Unit` TEXT,
`Description` TEXT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `DATA` (
`Id` INT NOT NULL,
`Epoch` INT,
`Value` DOUBLE,
`Sensor` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_389642_schema') AS relationships;
