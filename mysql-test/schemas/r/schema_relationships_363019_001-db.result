CREATE DATABASE `db_363019_001_db`;
USE `db_363019_001_db`;
CREATE TABLE `Province` (
`id` VARCHAR(50) NOT NULL,
`nameEn` TEXT,
`nameFr` TEXT,
`sourceLink` TEXT,
`sourceEn` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Holiday` (
`id` INT NOT NULL,
`date` TEXT,
`nameEn` TEXT,
`nameFr` TEXT,
`federal` BOOLEAN,
`firstOccurence` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProvinceHoliday` (
`id` INT NOT NULL,
`provinceId` CHAR(50),
`holidayId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_363019_001_db') AS relationships;
