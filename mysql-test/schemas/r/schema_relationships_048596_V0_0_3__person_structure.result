INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 048596_V0_0_3__person_structure
#
CREATE DATABASE `db_048596_V0_0_3__person_structure`;
USE `db_048596_V0_0_3__person_structure`;
CREATE TABLE `geo` (
`id` BIGINT NOT NULL,
`created_by` VARCHAR(50),
`created_date` DATETIME,
`last_modified_by` VARCHAR(50),
`last_modified_date` DATETIME,
`lat` VARCHAR(50),
`lng` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` BIGINT NOT NULL,
`created_by` VARCHAR(50),
`created_date` DATETIME,
`last_modified_by` VARCHAR(50),
`last_modified_date` DATETIME,
`city` VARCHAR(50),
`street` VARCHAR(50),
`suite` VARCHAR(50),
`zipcode` VARCHAR(50),
`geo_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` BIGINT NOT NULL,
`created_by` VARCHAR(50),
`created_date` DATETIME,
`last_modified_by` VARCHAR(50),
`last_modified_date` DATETIME,
`age` INT,
`dob` DATE,
`email_primary` VARCHAR(50),
`email_secondary` VARCHAR(50),
`gender` VARCHAR(50),
`is_adult` VARCHAR(50),
`name` VARCHAR(50),
`password` VARCHAR(50),
`phone` BIGINT,
`username` VARCHAR(50),
`address_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_048596_V0_0_3__person_structure') AS relationships;
relationships
