CREATE DATABASE `db_150341_DbSupportMySqlIT_create`;
USE `db_150341_DbSupportMySqlIT_create`;
CREATE TABLE `Customer` (
`ID` INT NOT NULL,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`Street` VARCHAR(50),
`City` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
`ID` INT NOT NULL,
`CustomerID` INT,
`Total` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`ID` INT NOT NULL,
`Name` VARCHAR(50),
`Price` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`ID` INT NOT NULL,
`InvoiceID` INT,
`Item` INT,
`ProductID` INT,
`Quantity` INT,
`Cost` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
