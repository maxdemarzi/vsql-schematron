INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 232297_users
#
CREATE DATABASE `db_232297_users`;
USE `db_232297_users`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`login` VARCHAR(50),
`password` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`last_login` TIMESTAMP NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`id` INT NOT NULL,
`user_id` INT,
`amount` INT,
`payed` BOOLEAN,
`created_at` TIMESTAMP NULL,
`payed_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_232297_users') AS relationships;
