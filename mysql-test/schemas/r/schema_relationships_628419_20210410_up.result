CREATE DATABASE `db_628419_20210410_up`;
USE `db_628419_20210410_up`;
CREATE TABLE `projects` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`title` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`closed` TIMESTAMP NULL,
`title` TEXT,
`body` TEXT,
`state` TEXT,
`metadata` TEXT,
`project_id` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`body` TEXT,
`issue_id` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
