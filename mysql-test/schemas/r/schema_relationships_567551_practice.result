INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 567551_practice
#
CREATE DATABASE `db_567551_practice`;
USE `db_567551_practice`;
CREATE TABLE `customer` (
`customerid` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`location` VARCHAR(50),
PRIMARY KEY (`customerid`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`productid` VARCHAR(50) NOT NULL,
`productname` VARCHAR(50),
`unitprice` DECIMAL(10,2),
`category` VARCHAR(50),
`provider` VARCHAR(50),
PRIMARY KEY (`productid`)
) CHARACTER SET latin1;
CREATE TABLE `purcase` (
`customerid` VARCHAR(50),
`productid` VARCHAR(50),
`quantity` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_567551_practice') AS relationships;
relationships
Database: db_567551_practice

