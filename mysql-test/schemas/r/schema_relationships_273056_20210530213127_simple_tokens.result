INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 273056_20210530213127_simple_tokens
#
CREATE DATABASE `db_273056_20210530213127_simple_tokens`;
USE `db_273056_20210530213127_simple_tokens`;
CREATE TABLE `shares` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schemas` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`share_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`schema_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`id` VARCHAR(50) NOT NULL,
`token` TEXT,
`expires_at` TIMESTAMP NULL,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens_for_tables` (
`id` VARCHAR(50) NOT NULL,
`token_id` VARCHAR(50),
`table_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_273056_20210530213127_simple_tokens') AS relationships;
relationships
Database: db_273056_20210530213127_simple_tokens

Table Connections:
