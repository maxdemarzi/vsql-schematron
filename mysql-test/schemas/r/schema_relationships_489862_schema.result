CREATE DATABASE `db_489862_schema`;
USE `db_489862_schema`;
CREATE TABLE `runs` (
`id` INT NOT NULL,
`createdAt` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
`id` INT NOT NULL,
`name` TEXT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `violations` (
`id` INT NOT NULL,
`resource_id` TEXT,
`resource_type` TEXT,
`run_id` INT,
`rule_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_489862_schema') AS relationships;
