CREATE DATABASE `db_383074_migration`;
USE `db_383074_migration`;
CREATE TABLE `Deck` (
`id` VARCHAR(50) NOT NULL,
`authorId` VARCHAR(50),
`title` TEXT,
`description` TEXT,
`visibility` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Card` (
`id` VARCHAR(50) NOT NULL,
`position` INT,
`frontText` TEXT,
`backText` TEXT,
`deckId` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`username` TEXT,
`password` TEXT,
`check` VARCHAR(50),
`active` BOOLEAN,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `RevokedTokens` (
`jti` VARCHAR(50) NOT NULL,
`exp` INT,
PRIMARY KEY (`jti`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_383074_migration') AS relationships;
