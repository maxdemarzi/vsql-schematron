INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 060318_tables
#
CREATE DATABASE `db_060318_tables`;
USE `db_060318_tables`;
CREATE TABLE `Cats` (
`Id` INT NOT NULL,
`WoolColor` DOUBLE,
`EyeColor` DOUBLE,
`Coloration` DOUBLE,
`TailLength` DOUBLE,
`WoolLength` DOUBLE,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `SystemUsers` (
`Id` INT NOT NULL,
`Login` VARCHAR(50),
`Password` VARCHAR(50),
`FullName` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `EvaluatedCats` (
`Id` INT NOT NULL,
`UserId` INT,
`CatId` INT,
`Grade` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
`Id` INT NOT NULL,
`UserId` INT,
`Token` VARCHAR(50),
`Data` TEXT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_060318_tables') AS relationships;
relationships
Database: db_060318_tables

Table Connections:
------------------
[Implied]  EvaluatedCats.CatId -> Cats.Id
[Implied]  EvaluatedCats.UserId -> SystemUsers.Id
[Implied]  Sessions.UserId -> SystemUsers.Id

DROP DATABASE `db_060318_tables`;
UNINSTALL EXTENSION vsql_schematron;
