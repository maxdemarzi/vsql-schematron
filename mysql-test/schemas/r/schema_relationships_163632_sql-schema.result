[Implied]  orders.customer_id -> customers.customer_id
[Implied]  orders_items.item_id -> items.item_id
[Implied]  orders_items.order_id -> orders.order_id

DROP DATABASE `db_163632_sql_schema`;
UNINSTALL EXTENSION vsql_schematron;
