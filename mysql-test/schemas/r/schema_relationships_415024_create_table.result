CREATE TABLE `employee` (
`id` INT NOT NULL,
`name` CHAR(50),
`office` CHAR(50),
`age` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`name` CHAR(50),
`author` CHAR(50),
`publisher` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `record` (
`book_id` INT NOT NULL,
`employee_id` INT NOT NULL,
`time` DATE,
PRIMARY KEY (`book_id`, `employee_id`)
) CHARACTER SET latin1;
