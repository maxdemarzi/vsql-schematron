INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 161020_schema
#
CREATE DATABASE `db_161020_schema`;
USE `db_161020_schema`;
CREATE TABLE `Users` (
`uid` INT NOT NULL,
`username` VARCHAR(50),
`created` TIMESTAMP NULL,
`password` VARCHAR(50),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `Blog` (
`bid` INT NOT NULL,
`author_id` INT,
`title` VARCHAR(50),
`visible` BOOLEAN,
`created` TIMESTAMP NULL,
`posted` TIMESTAMP NULL,
PRIMARY KEY (`bid`)
) CHARACTER SET latin1;
CREATE TABLE `Content` (
`tid` INT NOT NULL,
`bid` INT,
`author_id` INT,
`content` VARCHAR(50),
`created` TIMESTAMP NULL,
PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_161020_schema') AS relationships;
relationships
Database: db_161020_schema

Table Connections:
------------------
[Implied]  Blog.author_id -> Users.uid
[Implied]  Content.author_id -> Users.uid
[Implied]  Content.bid -> Blog.bid

DROP DATABASE `db_161020_schema`;
UNINSTALL EXTENSION vsql_schematron;
