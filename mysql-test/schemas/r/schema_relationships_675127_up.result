CREATE DATABASE `db_675127_up`;
USE `db_675127_up`;
CREATE TABLE `Label` (
`id` INT NOT NULL,
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tiling` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TilingLabel` (
`id` INT NOT NULL,
`tiling_id` INT,
`label_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Polygon` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PolygonLabel` (
`id` INT NOT NULL,
`polygon_id` INT,
`label_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Point` (
`id` INT NOT NULL,
`x` DOUBLE,
`y` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PolygonPoint` (
`id` INT NOT NULL,
`polygon_id` INT,
`point_id` INT,
`sequence` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_675127_up') AS relationships;
