CREATE DATABASE `db_606759_009_address_master_mysql`;
USE `db_606759_009_address_master_mysql`;
CREATE TABLE `cx_addresses` (
`address_id` VARCHAR(50) NOT NULL,
`building_number` VARCHAR(50),
`street` VARCHAR(50),
`attention` VARCHAR(50),
`apartment` VARCHAR(50),
`postal_box` VARCHAR(50),
`line2` VARCHAR(50),
`line3` VARCHAR(50),
`city` VARCHAR(50),
`spc_abbrev` VARCHAR(50),
`postal_code` VARCHAR(50),
`country` CHAR(50),
`county` VARCHAR(50),
`maidenhead` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
`osm_id` INT,
`last_validated` DATETIME,
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `cx_emails` (
`email_id` INT NOT NULL,
`email_user` VARCHAR(50),
`email_domain` VARCHAR(50),
`last_validated` DATETIME,
`bounce_count` INT,
PRIMARY KEY (`email_id`)
) CHARACTER SET latin1;
CREATE TABLE `cx_phone_types` (
`phone_type_id` INT NOT NULL,
`phone_type_description` VARCHAR(50),
PRIMARY KEY (`phone_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `cx_phones` (
`phone_id` INT NOT NULL,
`phone_type_id` INT,
`phone_number` VARCHAR(50),
PRIMARY KEY (`phone_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_606759_009_address_master_mysql') AS relationships;
