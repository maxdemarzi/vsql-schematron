CREATE TABLE `articles` (
`id` BIGINT NOT NULL,
`original_lang_id` BIGINT,
`author_id` BIGINT,
`approved` BOOLEAN,
`approver_id` BIGINT,
`approved_date` TIMESTAMP NULL,
`published` BOOLEAN,
`publisher_id` BIGINT,
`published_date` TIMESTAMP NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
`source_title` TEXT,
`source_url` TEXT,
`source_author_name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_translations` (
`id` BIGINT NOT NULL,
`title` TEXT,
`short_description` TEXT,
`image_url` TEXT,
`article_id` BIGINT,
`lang_id` BIGINT,
`author_id` BIGINT,
`approved` BOOLEAN,
`approver_id` BIGINT,
`approved_date` TIMESTAMP NULL,
`published` BOOLEAN,
`publisher_id` BIGINT,
`published_date` TIMESTAMP NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_translation_versions` (
`id` BIGINT NOT NULL,
`article_translation_id` BIGINT,
`text` TEXT,
`author_id` BIGINT,
`approved` BOOLEAN,
`approver_id` BIGINT,
`approved_date` TIMESTAMP NULL,
`published` BOOLEAN,
`publisher_id` BIGINT,
`published_date` TIMESTAMP NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
