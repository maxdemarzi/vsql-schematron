CREATE DATABASE `db_212996_tables`;
USE `db_212996_tables`;
CREATE TABLE `User` (
`user_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` CHAR(50),
`join_date` DATETIME,
`last_login_date` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`item_id` INT NOT NULL,
`user_id` CHAR(50),
`post_date` DATETIME,
`body` VARCHAR(50),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_212996_tables') AS relationships;
