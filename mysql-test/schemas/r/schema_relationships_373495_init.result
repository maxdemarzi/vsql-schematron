CREATE DATABASE `db_373495_init`;
USE `db_373495_init`;
CREATE TABLE `user_i` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`avatar` VARCHAR(50),
`created_on` TIMESTAMP NULL,
`theme` VARCHAR(50),
`last_login` TIMESTAMP NULL,
`password_reset_token` TEXT,
`currency_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currency` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`country` VARCHAR(50),
`symbol` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
