CREATE DATABASE `db_503378_mutualismo_operario`;
USE `db_503378_mutualismo_operario`;
CREATE TABLE `socios` (
`id_socio` INT NOT NULL,
`nome_socio` VARCHAR(50),
`sexo_socio` VARCHAR(50),
`profissao_socio` VARCHAR(50),
`tipo_profissao_socio` VARCHAR(50),
`imigrante_socio` VARCHAR(50),
`elite_socio` VARCHAR(50),
`data_entrada` DATE,
`data_saida` DATE,
`observacao` VARCHAR(50),
PRIMARY KEY (`id_socio`)
) CHARACTER SET latin1;
CREATE TABLE `conta_corrente` (
`id_conta` INT NOT NULL,
`deve` INT,
`haver` INT,
`data_pagamento` DATE,
`total_servicos` INT,
`todos_servicos` VARCHAR(50),
`complemento` VARCHAR(50),
`id_socio` INT,
PRIMARY KEY (`id_conta`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_503378_mutualismo_operario') AS relationships;
