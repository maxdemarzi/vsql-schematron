CREATE DATABASE `db_450943_define_db`;
USE `db_450943_define_db`;
CREATE TABLE `products` (
`id` INT NOT NULL,
`title` TEXT,
`img` TEXT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibits` (
`id` INT NOT NULL,
`venue` TEXT,
`theme` TEXT,
`start_date` TEXT,
`end_date` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `displays` (
`id` INT NOT NULL,
`product_id` INT,
`exhibit_id` INT,
`price` INT,
`date_sold` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_450943_define_db') AS relationships;
