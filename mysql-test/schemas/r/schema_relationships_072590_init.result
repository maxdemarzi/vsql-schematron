INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 072590_init
#
CREATE DATABASE `db_072590_init`;
USE `db_072590_init`;
CREATE TABLE `accounts` (
`id` INT,
`document_number` VARCHAR(50),
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `operations` (
`id` INT,
`description` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` INT,
`account_id` INT,
`operation_id` INT,
`amount` DOUBLE,
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_072590_init') AS relationships;
relationships
Database: db_072590_init

