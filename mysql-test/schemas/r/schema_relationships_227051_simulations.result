INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 227051_simulations
#
CREATE DATABASE `db_227051_simulations`;
USE `db_227051_simulations`;
CREATE TABLE `Simulations` (
`SIMID` VARCHAR(50) NOT NULL,
`FullName` TEXT,
`Shortname` TEXT,
`Executable` TEXT,
`Output` TEXT,
`Configuration` BLOB,
`ExecutionPrefix` TEXT,
`ExecutionHostFile` TEXT,
PRIMARY KEY (`SIMID`)
) CHARACTER SET latin1;
CREATE TABLE `Instances` (
`IID` VARCHAR(50) NOT NULL,
`SIMID` TEXT,
`Status` TEXT,
PRIMARY KEY (`IID`)
) CHARACTER SET latin1;
CREATE TABLE `Data` (
`DIID` INT NOT NULL,
`IID` TEXT,
`Source` TEXT,
PRIMARY KEY (`DIID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_227051_simulations') AS relationships;
relationships
Database: db_227051_simulations

