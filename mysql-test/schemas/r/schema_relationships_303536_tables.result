CREATE DATABASE `db_303536_tables`;
USE `db_303536_tables`;
CREATE TABLE `t_users` (
`user_id` INT NOT NULL,
`user_name_first` TEXT,
`user_name_last` TEXT,
`user_phone` TEXT,
`user_dni` TEXT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_users_locations` (
`location_id` INT NOT NULL,
`user_id` INT,
`location_address` TEXT,
`location_city` TEXT,
`location_country` TEXT,
`location_zip` TEXT,
PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_users_records` (
`record_id` INT NOT NULL,
`user_id` INT,
`record_title` TEXT,
`record_year` TEXT,
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_303536_tables') AS relationships;
