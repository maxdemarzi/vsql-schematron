INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 456469_bd_facturacion
#
CREATE DATABASE `db_456469_bd_facturacion`;
USE `db_456469_bd_facturacion`;
CREATE TABLE `cliente` (
`codCliente` INT NOT NULL,
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`direccion` VARCHAR(50),
PRIMARY KEY (`codCliente`)
) CHARACTER SET latin1;
CREATE TABLE `detallefactura` (
`codDetalle` INT NOT NULL,
`codFactura` INT,
`codProducto` INT,
`codBarra` VARCHAR(50),
`nombreProducto` VARCHAR(50),
`cantidad` INT,
`precioVenta` DECIMAL(10,2),
`total` DECIMAL(10,2),
PRIMARY KEY (`codDetalle`)
) CHARACTER SET latin1;
CREATE TABLE `factura` (
`codFactura` INT NOT NULL,
`numeroFactura` VARCHAR(50),
`codVendedor` INT,
`codCliente` INT,
`totalVenta` DECIMAL(10,2),
`fechaRegistro` TIMESTAMP NULL,
PRIMARY KEY (`codFactura`)
) CHARACTER SET latin1;
CREATE TABLE `producto` (
`codProducto` INT NOT NULL,
`nombreProducto` VARCHAR(50),
`precioVenta` DECIMAL(10,2),
`stockMinimo` INT,
`stockActual` INT,
`codBarra` VARCHAR(50),
PRIMARY KEY (`codProducto`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`codUsuario` INT NOT NULL,
`nombreUsuario` VARCHAR(50),
`password` VARCHAR(50),
`codVendedor` INT,
PRIMARY KEY (`codUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `vendedor` (
`codVendedor` INT NOT NULL,
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`cid` VARCHAR(50),
`celular` VARCHAR(50),
`direccion` VARCHAR(50),
PRIMARY KEY (`codVendedor`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_456469_bd_facturacion') AS relationships;
relationships
Database: db_456469_bd_facturacion

Table Connections:
------------------
[Implied]  detallefactura.codFactura -> factura.codFactura
[Implied]  detallefactura.codProducto -> producto.codProducto
[Implied]  factura.codCliente -> cliente.codCliente
[Implied]  factura.codVendedor -> vendedor.codVendedor
[Implied]  usuario.codVendedor -> vendedor.codVendedor

DROP DATABASE `db_456469_bd_facturacion`;
UNINSTALL EXTENSION vsql_schematron;
