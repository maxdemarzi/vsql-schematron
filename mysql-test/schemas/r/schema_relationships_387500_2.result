) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
`fid` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
`did` VARCHAR(50),
`salario` DECIMAL(10,2),
PRIMARY KEY (`fid`)
) CHARACTER SET latin1;
