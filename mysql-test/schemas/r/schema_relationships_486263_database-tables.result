CREATE DATABASE `db_486263_database_tables`;
USE `db_486263_database_tables`;
CREATE TABLE `access-points` (
`id` INT NOT NULL,
`name` TEXT,
`location` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client-data` (
`client` TEXT,
`client-manufacturer` TEXT,
