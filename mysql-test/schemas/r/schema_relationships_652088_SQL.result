CREATE DATABASE `db_652088_SQL`;
USE `db_652088_SQL`;
CREATE TABLE `podcasts` (
`id` INT NOT NULL,
`created` TIMESTAMP NULL,
`number` VARCHAR(50),
`title` VARCHAR(50),
`description` TEXT,
`cover` VARCHAR(50),
`duration` VARCHAR(50),
`duration_type` CHAR(50),
`link` VARCHAR(50),
`mp3` VARCHAR(50),
`published` VARCHAR(50),
`podcast` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT NOT NULL,
`created` TIMESTAMP NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `podcast_categories` (
`podcast_id` INT,
`category_id` INT,
`created` TIMESTAMP NULL
) CHARACTER SET latin1;
