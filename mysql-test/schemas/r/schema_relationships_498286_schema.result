INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 498286_schema
#
CREATE DATABASE `db_498286_schema`;
USE `db_498286_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_498286_schema') AS relationships;
relationships
Database: db_498286_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> employee_role.id
[Implied]  employee_role.department_id -> department.id

DROP DATABASE `db_498286_schema`;
UNINSTALL EXTENSION vsql_schematron;
