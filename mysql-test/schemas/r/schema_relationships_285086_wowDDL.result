INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 285086_wowDDL
#
CREATE DATABASE `db_285086_wowDDL`;
USE `db_285086_wowDDL`;
CREATE TABLE `users` (
`userId` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`userName` VARCHAR(50),
`nickname` VARCHAR(50),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `userword` (
`saveId` DECIMAL(10,2) NOT NULL,
`userId` VARCHAR(50),
`word` VARCHAR(50),
PRIMARY KEY (`saveId`)
) CHARACTER SET latin1;
CREATE TABLE `community` (
`postId` DECIMAL(10,2) NOT NULL,
`userId` VARCHAR(50),
`word` VARCHAR(50),
`thumbsUp` DECIMAL(10,2),
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_285086_wowDDL') AS relationships;
