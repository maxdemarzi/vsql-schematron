CREATE TABLE `asset` (
`id` VARCHAR(50) NOT NULL,
`color_others` VARCHAR(50),
`color_primary` VARCHAR(50),
`context` VARCHAR(50),
`created` DATETIME,
`eol` DATETIME,
`file_size` BIGINT,
`lqip` VARCHAR(50),
`original_filename` VARCHAR(50),
`reference_hash` VARCHAR(50),
`reference_url` VARCHAR(50),
`resolution_height` INT,
`resolution_width` INT,
`system_ref_id` VARCHAR(50),
`type` VARCHAR(50),
`url_path` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `asset_keyvalue_pair` (
`asset_id` VARCHAR(50) NOT NULL,
`field_value` VARCHAR(50),
`field_key` VARCHAR(50) NOT NULL,
PRIMARY KEY (`asset_id`, `field_key`)
) CHARACTER SET latin1;
