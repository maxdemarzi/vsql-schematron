INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 374073_schema
#
CREATE DATABASE `db_374073_schema`;
USE `db_374073_schema`;
CREATE TABLE `locations` (
`id` INT NOT NULL,
`search_query` VARCHAR(50),
`formatted_query` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weathers` (
`id` INT NOT NULL,
`forecast` VARCHAR(50),
`time` VARCHAR(50),
`created_at` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT NOT NULL,
`link` VARCHAR(50),
`name` VARCHAR(50),
`event_date` VARCHAR(50),
`summary` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`overview` VARCHAR(50),
`average_votes` VARCHAR(50),
`total_votes` VARCHAR(50),
`image_url` VARCHAR(50),
`popularity` VARCHAR(50),
`released_on` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `yelps` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`image_url` VARCHAR(50),
`price` VARCHAR(50),
`rating` VARCHAR(50),
`url` VARCHAR(50),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trails` (
`name` VARCHAR(50),
`location` VARCHAR(50),
`length` VARCHAR(50),
`stars` VARCHAR(50),
`star_votes` VARCHAR(50),
`summary` VARCHAR(50),
`trail_url` VARCHAR(50),
`conditions` VARCHAR(50),
`condition_date` VARCHAR(50),
`condition_time` VARCHAR(50),
`location_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_374073_schema') AS relationships;
relationships
Database: db_374073_schema

