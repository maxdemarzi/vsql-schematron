CREATE DATABASE `db_636691_model`;
USE `db_636691_model`;
CREATE TABLE `elector` (
`elecId` INT NOT NULL,
`elecIp` TEXT,
PRIMARY KEY (`elecId`)
) CHARACTER SET latin1;
CREATE TABLE `alternative` (
`altId` INT NOT NULL,
`altName` TEXT,
`altDescription` TEXT,
`altIcon` TEXT,
PRIMARY KEY (`altId`)
) CHARACTER SET latin1;
CREATE TABLE `ranking` (
`elecId` INT NOT NULL,
`altId` INT NOT NULL,
`rankMin` INT,
`rankMax` INT,
PRIMARY KEY (`elecId`, `altId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_636691_model') AS relationships;
