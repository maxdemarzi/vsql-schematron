INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 229959_schema
#
CREATE DATABASE `db_229959_schema`;
USE `db_229959_schema`;
CREATE TABLE `groups` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`group_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercises` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `solutions` (
`created_at` DATETIME,
`updated_at` DATETIME,
`content` TEXT,
`exercise_id` INT NOT NULL,
`user_id` INT NOT NULL,
PRIMARY KEY (`user_id`, `exercise_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_229959_schema') AS relationships;
relationships
Database: db_229959_schema

Table Connections:
------------------
[Implied]  solutions.exercise_id -> exercises.id
[Implied]  solutions.user_id -> users.id
[Implied]  users.group_id -> groups.id

DROP DATABASE `db_229959_schema`;
UNINSTALL EXTENSION vsql_schematron;
