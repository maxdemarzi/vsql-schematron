CREATE DATABASE `db_565316_init_sqlite`;
USE `db_565316_init_sqlite`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`password` TEXT,
`createdAt` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currencies` (
`id` INT NOT NULL,
`userId` INT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currencyValues` (
`id` INT NOT NULL,
`snapshotId` INT,
`currencyId` INT,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `assets` (
`id` INT NOT NULL,
`snapshotId` INT,
`name` TEXT,
`amount` DOUBLE,
`currencyId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_565316_init_sqlite') AS relationships;
