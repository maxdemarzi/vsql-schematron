`last_modified_by` VARCHAR(50),
`deleted` TIMESTAMP NULL,
`deleted_by` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `version_type` (
`id` INT NOT NULL,
`type` VARCHAR(50),
