`last_modified_by` VARCHAR(50),
`deleted` TIMESTAMP NULL,
`deleted_by` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature_version` (
`id` INT NOT NULL,
`created_by` VARCHAR(50),
`version_id` INT,
`feature_id` INT,
`created` TIMESTAMP NULL,
`last_modified` TIMESTAMP NULL,
`last_modified_by` VARCHAR(50),
`deleted` TIMESTAMP NULL,
`deleted_by` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
