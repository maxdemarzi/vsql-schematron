CREATE DATABASE `db_380817_postgres`;
USE `db_380817_postgres`;
CREATE TABLE `project` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`created_by` VARCHAR(50),
`created` TIMESTAMP NULL,
`last_modified` TIMESTAMP NULL,
`last_modified_by` VARCHAR(50),
`deleted` TIMESTAMP NULL,
`deleted_by` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `environment` (
`id` INT NOT NULL,
`project_id` INT,
`name` VARCHAR(50),
`key` VARCHAR(50),
`description` VARCHAR(50),
`created_by` VARCHAR(50),
`created` TIMESTAMP NULL,
`last_modified` TIMESTAMP NULL,
`last_modified_by` VARCHAR(50),
`deleted` TIMESTAMP NULL,
`deleted_by` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature` (
`id` INT NOT NULL,
`project_id` INT,
`environment_id` INT,
`name` VARCHAR(50),
`key` VARCHAR(50),
`description` VARCHAR(50),
`created_by` VARCHAR(50),
`created` TIMESTAMP NULL,
