CREATE DATABASE `db_396778_db`;
USE `db_396778_db`;
CREATE TABLE `ticker` (
`id` INT NOT NULL,
`ticker` VARCHAR(50),
`created_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ticker_data` (
`id` INT NOT NULL,
`rank` INT,
`close` DECIMAL(10,2),
`dollar_change` DECIMAL(10,2),
`percent_change` DECIMAL(10,2),
`volume` INT,
`tsi` DECIMAL(10,2),
`ticker_id` INT,
`created_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_396778_db') AS relationships;
