CREATE DATABASE `db_333837_schema`;
USE `db_333837_schema`;
CREATE TABLE `person` (
`id` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` DECIMAL(10,2) NOT NULL,
`person_id` DECIMAL(10,2),
`address` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_333837_schema') AS relationships;
