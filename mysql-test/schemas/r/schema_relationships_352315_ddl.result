INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 352315_ddl
#
CREATE DATABASE `db_352315_ddl`;
USE `db_352315_ddl`;
CREATE TABLE `book` (
`id` BIGINT NOT NULL,
`author` VARCHAR(50),
`title` VARCHAR(50),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `review` (
`id` BIGINT NOT NULL,
`fk_book` BIGINT,
`comment_body` VARCHAR(50),
`comment_date` DATE,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_352315_ddl') AS relationships;
