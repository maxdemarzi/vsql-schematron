CREATE DATABASE `db_546453_database`;
USE `db_546453_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`role` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`remember_token` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`description` VARCHAR(50),
`price` VARCHAR(50),
`status` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_546453_database') AS relationships;
