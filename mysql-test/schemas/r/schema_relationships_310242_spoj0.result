INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 310242_spoj0
#
CREATE DATABASE `db_310242_spoj0`;
USE `db_310242_spoj0`;
CREATE TABLE `problems` (
`problem_id` INT NOT NULL,
`contest_id` INT,
`letter` CHAR(50),
`name` CHAR(50),
`time_limit` INT,
`about` TEXT,
PRIMARY KEY (`problem_id`)
) CHARACTER SET latin1;
CREATE TABLE `runs` (
`run_id` INT NOT NULL,
`problem_id` INT,
`user_id` INT,
`submit_time` DATETIME,
`language` CHAR(50),
`source_code` VARCHAR(50),
`source_name` CHAR(50),
`about` TEXT,
`status` CHAR(50),
`log` TEXT,
PRIMARY KEY (`run_id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`new_id` INT NOT NULL,
`new_time` DATETIME,
`file` CHAR(50),
`topic` CHAR(50),
`content` TEXT,
PRIMARY KEY (`new_id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`question_id` INT NOT NULL,
`problem_id` INT,
`user_id` INT,
`question_time` DATETIME,
`content` TEXT,
`status` CHAR(50),
`answer_time` DATETIME,
`answer_content` TEXT,
PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_310242_spoj0') AS relationships;
relationships
