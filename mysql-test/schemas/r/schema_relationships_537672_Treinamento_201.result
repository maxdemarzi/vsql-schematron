CREATE TABLE `FORNECEDOR` (
`CodFornec` INT NOT NULL,
`NomeFornec` CHAR(50),
`Cidade` CHAR(50),
PRIMARY KEY (`CodFornec`)
) CHARACTER SET latin1;
CREATE TABLE `PECA` (
`CodPeca` INT NOT NULL,
`NomePeca` CHAR(50),
`Peso` DECIMAL(10,2),
`Cor` CHAR(50),
PRIMARY KEY (`CodPeca`)
) CHARACTER SET latin1;
CREATE TABLE `FORNECE` (
`CodPeca` INT NOT NULL,
`CodFornec` INT NOT NULL,
`Qtde` INT,
PRIMARY KEY (`CodPeca`, `CodFornec`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
`num_pedido` INT NOT NULL,
`prazo_entrega` INT,
`codigo_cliente` INT,
`codigo_vendedor` INT,
PRIMARY KEY (`num_pedido`)
) CHARACTER SET latin1;
