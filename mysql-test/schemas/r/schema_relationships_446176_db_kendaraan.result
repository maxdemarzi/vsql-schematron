CREATE DATABASE `db_446176_db_kendaraan`;
USE `db_446176_db_kendaraan`;
CREATE TABLE `auth_acl` (
`ai` VARCHAR(50) NOT NULL,
`action_id` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`ai`)
) CHARACTER SET latin1;
CREATE TABLE `auth_acl_actions` (
`action_id` VARCHAR(50) NOT NULL,
`action_code` VARCHAR(50),
`action_desc` VARCHAR(50),
`category_id` VARCHAR(50),
PRIMARY KEY (`action_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_ci_sessions` (
`id` VARCHAR(50) NOT NULL,
`ip_address` VARCHAR(50),
`timestamp` VARCHAR(50),
`data` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ms_tipe` (
`id_tipe` INT NOT NULL,
`id_jenis` INT,
`tipe` VARCHAR(50),
PRIMARY KEY (`id_tipe`)
) CHARACTER SET latin1;
CREATE TABLE `sys_log_type` (
`logtypeid` BIGINT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
`remarks` VARCHAR(50),
`used_user_rating` TINYINT,
`used_user_rating_weight` DECIMAL(10,2),
PRIMARY KEY (`logtypeid`)
) CHARACTER SET latin1;
