INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 093495_classified_ads_schema
#
CREATE DATABASE `db_093495_classified_ads_schema`;
USE `db_093495_classified_ads_schema`;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
`id` INT NOT NULL,
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT NOT NULL,
`ad_id` INT,
`image_url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ads_tags` (
`id` INT NOT NULL,
`ad_id` INT,
`tag_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_093495_classified_ads_schema') AS relationships;
