INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 518295_schema
#
CREATE DATABASE `db_518295_schema`;
USE `db_518295_schema`;
CREATE TABLE `license` (
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lend` (
`license_id` INT,
`book_id` INT,
`returned` TINYINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_518295_schema') AS relationships;
