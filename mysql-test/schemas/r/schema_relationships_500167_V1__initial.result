INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 500167_V1__initial
#
CREATE DATABASE `db_500167_V1__initial`;
USE `db_500167_V1__initial`;
CREATE TABLE `application` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`contact` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `interface` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`type` VARCHAR(50),
`application_id` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `version` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`version` VARCHAR(50),
`description` VARCHAR(50),
`content` TEXT,
`interface_id` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_500167_V1__initial') AS relationships;
