INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 298085_schema
#
CREATE DATABASE `db_298085_schema`;
USE `db_298085_schema`;
CREATE TABLE `device` (
`ip` CHAR(50),
`mac` VARCHAR(50) NOT NULL,
`name` TEXT,
`status` TEXT,
`quota` DECIMAL(10,2),
`bandwidth` DECIMAL(10,2),
`period` DECIMAL(10,2),
`quota_unit` CHAR(50),
`bandwidth_unit` CHAR(50),
`period_unit` CHAR(50),
PRIMARY KEY (`mac`)
) CHARACTER SET latin1;
CREATE TABLE `period` (
`start_time` TIMESTAMP NULL,
`end_time` TIMESTAMP NULL,
`mac` CHAR(50),
`passed_bytes` DECIMAL(10,2),
`dropped_bytes` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_298085_schema') AS relationships;
relationships
Database: db_298085_schema

