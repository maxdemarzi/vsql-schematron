INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 276138_Initial-Table
#
CREATE DATABASE `db_276138_Initial_Table`;
USE `db_276138_Initial_Table`;
CREATE TABLE `student` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`lastname` VARCHAR(50),
`information_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` VARCHAR(50) NOT NULL,
`address1` VARCHAR(50),
`address2` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `information` (
`id` VARCHAR(50) NOT NULL,
`email` VARCHAR(50),
`phone` INT,
`address_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`code` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instructor` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`lastname` VARCHAR(50),
`information_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_276138_Initial_Table') AS relationships;
relationships
