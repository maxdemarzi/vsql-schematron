INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 000533_userAuth
#
CREATE DATABASE `db_000533_userAuth`;
USE `db_000533_userAuth`;
CREATE TABLE `compositions` (
`id` CHAR(50),
`iduser` CHAR(50),
`public` TINYINT,
`name` VARCHAR(50),
`duration` SMALLINT,
`bpm` SMALLINT,
`beatsPerMeasure` TINYINT,
`stepsPerBeat` TINYINT,
`data` VARCHAR(50),
`created` DATETIME,
`updated` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `passwordForgotten` (
`id` INT,
`email` VARCHAR(50),
`code` CHAR(50),
`expire` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `thingsNotVerified` (
`id` INT,
`iduser` CHAR(50),
`data` VARCHAR(50),
`code` VARCHAR(50),
`expire` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` CHAR(50),
`email` VARCHAR(50),
`emailchecked` TINYINT,
`emailpublic` TINYINT,
`pass` CHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`username` VARCHAR(50),
`avatar` VARCHAR(50),
`created` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_000533_userAuth') AS relationships;
relationships
Database: db_000533_userAuth

Table Connections:
------------------
[Implied]  compositions.iduser -> users.id
[Implied]  thingsNotVerified.iduser -> users.id

DROP DATABASE `db_000533_userAuth`;
UNINSTALL EXTENSION vsql_schematron;
