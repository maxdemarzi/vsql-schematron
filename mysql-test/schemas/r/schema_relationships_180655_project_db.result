INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 180655_project_db
#
CREATE DATABASE `db_180655_project_db`;
USE `db_180655_project_db`;
CREATE TABLE `et_poa` (
`user_id` INT NOT NULL,
`resourceServerId` VARCHAR(50),
`metadata` VARCHAR(50),
`clientId` VARCHAR(50),
`password` TEXT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `et_categories` (
`category_id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `et_transactions` (
`transaction_id` INT NOT NULL,
`category_id` INT,
`user_id` INT,
`amount` DECIMAL(10,2),
`note` VARCHAR(50),
`transaction_date` BIGINT,
PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_180655_project_db') AS relationships;
