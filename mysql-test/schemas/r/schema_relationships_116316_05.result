) CHARACTER SET latin1;
CREATE TABLE `youtube_user_tokens` (
`youtube_user_token_id` INT NOT NULL,
`youtube_user_id` INT,
`token` TEXT,
`refresh_token` TEXT,
`expires` TIMESTAMP NULL,
`created` TIMESTAMP NULL,
`expired` TIMESTAMP NULL,
PRIMARY KEY (`youtube_user_token_id`)
) CHARACTER SET latin1;
