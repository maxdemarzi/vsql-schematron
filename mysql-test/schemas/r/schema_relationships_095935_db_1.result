CREATE DATABASE `db_095935_db_1`;
USE `db_095935_db_1`;
CREATE TABLE `BUKU` (
`ID_BUKU` INT NOT NULL,
`ID_JENIS_BUKU` INT,
`NAMA_BUKU` VARCHAR(50),
`PENGARANG_BUKU` VARCHAR(50),
`PENERBIT_BUKU` VARCHAR(50),
`HARGA_BUKU` INT,
PRIMARY KEY (`ID_BUKU`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`ID_CUSTOMER` INT NOT NULL,
`NAMA_CUSTOMER` VARCHAR(50),
`ALAMAT_CUSTOMER` VARCHAR(50),
`NO_HP_CUSTOMER` VARCHAR(50),
`USERNAME_CUSTOMER` VARCHAR(50),
`EMAIL_CUSTOMER` VARCHAR(50),
`PASSWORD_CUSTOMER` VARCHAR(50),
PRIMARY KEY (`ID_CUSTOMER`)
) CHARACTER SET latin1;
CREATE TABLE `DETAIL_TRANSAKSI` (
`ID_DETAIL_TRANSAKSI` INT NOT NULL,
`ID_TRANSAKSI` INT,
`ID_BUKU` INT,
`BANYAK_PEMBELIAN` INT,
`TOTAL_PEMBELIAN` INT,
PRIMARY KEY (`ID_DETAIL_TRANSAKSI`)
) CHARACTER SET latin1;
CREATE TABLE `JENIS_BUKU` (
`ID_JENIS_BUKU` INT NOT NULL,
`JENIS_BUKU` VARCHAR(50),
PRIMARY KEY (`ID_JENIS_BUKU`)
) CHARACTER SET latin1;
CREATE TABLE `JENIS_PEMBAYARAN` (
`ID_JENIS_PEMBAYARAN` INT NOT NULL,
`JENIS_PEMBAYARAN` VARCHAR(50),
PRIMARY KEY (`ID_JENIS_PEMBAYARAN`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSAKSI` (
`ID_TRANSAKSI` INT NOT NULL,
`ID_JENIS_PEMBAYARAN` INT,
`ID_CUSTOMER` INT,
`TANGGAL_TRANSAKSI` TIMESTAMP NULL,
`TOTAL_TRANSAKSI` INT,
PRIMARY KEY (`ID_TRANSAKSI`)
) CHARACTER SET latin1;
