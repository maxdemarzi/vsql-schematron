USE `db_409130_database`;
CREATE TABLE `dbfastparking.tblcliente` (
`idcliente` INT NOT NULL,
`placacarro` VARCHAR(50),
`data` DATE,
`nomecliente` VARCHAR(50),
`horaentrada` TIME,
`horasaida` TIME,
`comprovante` TEXT,
`tblclientecol` VARCHAR(50),
`statuscliente` TINYINT,
`idpreco` INT,
PRIMARY KEY (`idcliente`)
) CHARACTER SET latin1;
CREATE TABLE `dbfastparking.tblpreco` (
`idpreco` INT NOT NULL,
`valor` VARCHAR(50),
`hora` VARCHAR(50),
PRIMARY KEY (`idpreco`)
) CHARACTER SET latin1;
CREATE TABLE `dbfastparking.tblvaga` (
`idvaga` INT NOT NULL,
`numerovagas` INT,
`blocos` VARCHAR(50),
PRIMARY KEY (`idvaga`)
) CHARACTER SET latin1;
