INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 246551_query
#
CREATE DATABASE `db_246551_query`;
USE `db_246551_query`;
CREATE TABLE `Roles` (
`ID` INT NOT NULL,
`Name` VARCHAR(50),
`CreatedAt` TIMESTAMP NULL,
`UpdatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`ID` INT NOT NULL,
`Username` VARCHAR(50),
`Password` VARCHAR(50),
`RoleID` INT,
`AccessToken` VARCHAR(50),
`ExpireAt` TIMESTAMP NULL,
`CreatedAt` TIMESTAMP NULL,
`UpdatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`ID` INT NOT NULL,
`AccountID` INT,
`Firstname` VARCHAR(50),
`Lastname` VARCHAR(50),
`Address1` VARCHAR(50),
`Address2` VARCHAR(50),
`CompanyName` VARCHAR(50),
`PhoneNumber1` VARCHAR(50),
`PhoneNumber2` VARCHAR(50),
`Country` VARCHAR(50),
`Email` VARCHAR(50),
`Image` VARCHAR(50),
`Facebook` VARCHAR(50),
`LinkedIn` VARCHAR(50),
`Instagram` VARCHAR(50),
`CreatedAt` TIMESTAMP NULL,
`UpdatedAt` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_246551_query') AS relationships;
