INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 498410_init
#
CREATE DATABASE `db_498410_init`;
USE `db_498410_init`;
CREATE TABLE `members` (
`id` INT NOT NULL,
`email` TEXT,
`fullname` VARCHAR(50),
`active` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `attendances` (
`day` DATE NOT NULL,
`id` INT NOT NULL,
PRIMARY KEY (`day`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `bringer` (
`day` DATE NOT NULL,
`id` INT NOT NULL,
PRIMARY KEY (`day`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `app_state` (
`dummy` INT NOT NULL,
`attendance_primed_until` DATE,
PRIMARY KEY (`dummy`)
) CHARACTER SET latin1;
CREATE TABLE `migratus` (
`id` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_498410_init') AS relationships;
relationships
