INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 442140_schema
#
CREATE DATABASE `db_442140_schema`;
USE `db_442140_schema`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `loans` (
`id` BIGINT NOT NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
`total` DOUBLE,
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_442140_schema') AS relationships;
