`Tracking_number` INT,
`Shipping_date` DATE,
`Shipping_company` VARCHAR(50),
`Address_ID` INT,
PRIMARY KEY (`Ship_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`Order_ID` INT NOT NULL,
`Customer_ID` INT,
`Guitar_ID` INT,
`Payment_ID` INT,
PRIMARY KEY (`Order_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Guitars` (
`Guitar_ID` INT NOT NULL,
`Finish_ID` INT,
`Body_ID` INT,
`Neck_ID` INT,
`Finger_ID` INT,
`Pickup_ID` INT,
`Tuner_ID` INT,
`Bridge_ID` INT,
PRIMARY KEY (`Guitar_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Payments` (
`Payment_ID` INT NOT NULL,
`Payment_Type` VARCHAR(50),
`Payment_Number` INT,
`Verification_code` INT,
`Expiration_ID` DATE,
`Address_ID` INT,
`Customer_id` INT,
PRIMARY KEY (`Payment_ID`)
) CHARACTER SET latin1;
