CREATE DATABASE `db_656539_V1__create_bot_tables`;
USE `db_656539_V1__create_bot_tables`;
CREATE TABLE `GUILDS` (
`ID` BIGINT NOT NULL,
`ACTIVE` BOOLEAN,
`NAME` TEXT,
`REGION` TEXT,
`CREATED_ON` DATETIME,
`LAST_ACTIVE_ON` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SETTINGS` (
`ID` BIGINT NOT NULL,
`AUTOSAVE` BOOLEAN,
`PREFIX` TEXT,
`DEFAULTTEXTCHANNEL` BIGINT,
`VOLUME` DECIMAL(10,2),
`GUILD` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ALIASES` (
`ID` INT NOT NULL,
`NAME` TEXT,
`ALIAS` TEXT,
`SETTINGS` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHANNELS` (
`ID` BIGINT NOT NULL,
`NAME` TEXT,
`AUTORECORD` INT,
`AUTOSTOP` INT,
`SETTINGS` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RECORDINGS` (
`ID` BIGINT NOT NULL,
`CHANNEL` BIGINT,
`SIZE` BIGINT,
`CREATED_ON` DATETIME,
`MODIFIED_ON` DATETIME,
`URL` TEXT,
`GUILD` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_656539_V1__create_bot_tables') AS relationships;
