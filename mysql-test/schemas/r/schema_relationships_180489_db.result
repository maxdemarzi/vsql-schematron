INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 180489_db
#
CREATE DATABASE `db_180489_db`;
USE `db_180489_db`;
CREATE TABLE `commands` (
`id` INT NOT NULL,
`device_id` INT,
`target_name` VARCHAR(50),
`function_name` VARCHAR(50),
`ir_command` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `devices` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`devtype` INT,
`host` VARCHAR(50),
`mac_address` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_180489_db') AS relationships;
relationships
