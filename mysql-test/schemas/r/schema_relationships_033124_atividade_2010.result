CREATE DATABASE `db_033124_atividade_2010`;
USE `db_033124_atividade_2010`;
CREATE TABLE `fornecedor` (
`codigo_fornecedor` INT NOT NULL,
`nome` CHAR(50),
`uf` CHAR(50),
PRIMARY KEY (`codigo_fornecedor`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
`codigo` INT NOT NULL,
`nome_produto` CHAR(50),
`estoque` INT,
`valor` INT,
`codigo_fornecedor` INT,
`desconto` INT,
PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_033124_atividade_2010') AS relationships;
