INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 346277_MyImages
#
CREATE DATABASE `db_346277_MyImages`;
USE `db_346277_MyImages`;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`apelido` VARCHAR(50),
`nome` VARCHAR(50),
`email` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `imagem` (
`id_imagem` INT NOT NULL,
`id_usuario` INT,
`imagem` VARCHAR(50),
`titulo` VARCHAR(50),
`descricao` VARCHAR(50),
`autor` VARCHAR(50),
`datahorapost` VARCHAR(50),
PRIMARY KEY (`id_imagem`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_346277_MyImages') AS relationships;
relationships
