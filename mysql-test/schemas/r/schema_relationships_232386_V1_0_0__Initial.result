CREATE TABLE `Users` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`active` BOOLEAN,
`birthDate` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Adventurers` (
`id` BIGINT NOT NULL,
`userId` BIGINT,
`avatar` VARCHAR(50),
`name` VARCHAR(50),
`title` VARCHAR(50),
`level` SMALLINT,
`currentExperience` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
