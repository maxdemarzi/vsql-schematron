INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 450135_backup
#
CREATE DATABASE `db_450135_backup`;
USE `db_450135_backup`;
CREATE TABLE `J` (
`JNO` VARCHAR(50) NOT NULL,
`JNAME` CHAR(50),
`CITY` CHAR(50),
PRIMARY KEY (`JNO`)
) CHARACTER SET latin1;
CREATE TABLE `P` (
`PNO` VARCHAR(50) NOT NULL,
`PNAME` CHAR(50),
`COLOR` CHAR(50),
`WEIGHT` INT,
PRIMARY KEY (`PNO`)
) CHARACTER SET latin1;
CREATE TABLE `SPJ` (
`SNO` VARCHAR(50) NOT NULL,
`PNO` VARCHAR(50) NOT NULL,
`JNO` VARCHAR(50) NOT NULL,
`QTY` INT,
PRIMARY KEY (`SNO`, `PNO`, `JNO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_450135_backup') AS relationships;
relationships
Database: db_450135_backup

Table Connections:
------------------
[Implied]  SPJ.JNO -> J.JNO
[Implied]  SPJ.PNO -> P.PNO

DROP DATABASE `db_450135_backup`;
UNINSTALL EXTENSION vsql_schematron;
