CREATE DATABASE `db_470964_schema`;
USE `db_470964_schema`;
CREATE TABLE `userPosts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `userLogins` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`post_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_470964_schema') AS relationships;
