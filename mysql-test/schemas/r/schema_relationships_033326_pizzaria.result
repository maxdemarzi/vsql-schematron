) CHARACTER SET latin1;
CREATE TABLE `tb_pizza` (
`id` INT NOT NULL,
`Nome` VARCHAR(50),
`Refri` VARCHAR(50),
`Preço` DECIMAL(10,2),
`Pagamento` VARCHAR(50),
`categoria_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
