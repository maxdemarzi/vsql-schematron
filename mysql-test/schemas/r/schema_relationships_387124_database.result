CREATE DATABASE `db_387124_database`;
USE `db_387124_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `videos` (
`id` INT,
`user_id` INT,
`title` VARCHAR(50),
`description` TEXT,
`url` VARCHAR(50),
`status` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_387124_database') AS relationships;
