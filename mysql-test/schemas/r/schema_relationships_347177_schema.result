INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 347177_schema
#
CREATE DATABASE `db_347177_schema`;
USE `db_347177_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `work_role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_347177_schema') AS relationships;
relationships
Database: db_347177_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> work_role.id
[Implied]  work_role.department_id -> department.id

DROP DATABASE `db_347177_schema`;
UNINSTALL EXTENSION vsql_schematron;
