INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 309420_schema
#
CREATE DATABASE `db_309420_schema`;
USE `db_309420_schema`;
CREATE TABLE `department` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` VARCHAR(50),
`manager_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_309420_schema') AS relationships;
relationships
Database: db_309420_schema

Table Connections:
