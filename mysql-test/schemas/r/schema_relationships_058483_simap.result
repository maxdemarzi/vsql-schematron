INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 058483_simap
#
CREATE DATABASE `db_058483_simap`;
USE `db_058483_simap`;
CREATE TABLE `jumlah_pkh` (
`id` INT,
`idKecamatan` INT,
`bulan` VARCHAR(50),
`tahun` TEXT,
`jumlah` INT
) CHARACTER SET latin1;
CREATE TABLE `kecamatan` (
`id` INT NOT NULL,
`nama` VARCHAR(50),
`geojson` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kelurahan` (
`id` INT,
`idKecamatan` INT,
`nama` VARCHAR(50),
`geojson` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `perhitungan` (
`id` INT,
`idJumlah_pkh` INT,
`nilai_sem` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`image` VARCHAR(50),
`status` VARCHAR(50),
`level_user` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_058483_simap') AS relationships;
relationships
