INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 588504_up
#
CREATE DATABASE `db_588504_up`;
USE `db_588504_up`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` TEXT,
`password` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `api_keys` (
`key` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `pastes` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`visibility` SMALLINT,
`author_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `deletion_keys` (
`key` VARCHAR(50) NOT NULL,
`paste_id` VARCHAR(50),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` VARCHAR(50) NOT NULL,
`paste_id` VARCHAR(50),
`name` TEXT,
`is_binary` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588504_up') AS relationships;
relationships
Database: db_588504_up

