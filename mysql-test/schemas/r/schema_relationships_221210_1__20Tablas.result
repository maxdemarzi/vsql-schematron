CREATE DATABASE `db_221210_1__20Tablas`;
USE `db_221210_1__20Tablas`;
CREATE TABLE `PERMISO_TIPOS` (
`id_tipo` DECIMAL(10,2) NOT NULL,
`tipo` VARCHAR(50),
`dias` DECIMAL(10,2),
`descripcion` VARCHAR(50),
`estado_tipo` DECIMAL(10,2),
PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
CREATE TABLE `PERMISO_MOTIVOS` (
`id_motivo` DECIMAL(10,2) NOT NULL,
`motivo` VARCHAR(50),
PRIMARY KEY (`id_motivo`)
) CHARACTER SET latin1;
CREATE TABLE `PERMISO_ESTADOS` (
`id_estado` DECIMAL(10,2) NOT NULL,
`estado` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id_estado`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO_PERFILES` (
`id_perfil` DECIMAL(10,2) NOT NULL,
`perfil` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id_perfil`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO_CARGOS` (
`id_cargo` DECIMAL(10,2) NOT NULL,
`cargo` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id_cargo`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO_DEPARTAMENTOS` (
`id_departamento` DECIMAL(10,2) NOT NULL,
`departamento` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id_departamento`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIOS` (
`rut` DECIMAL(10,2) NOT NULL,
`digito_verificador` VARCHAR(50),
`clave` VARCHAR(50),
`nombres` VARCHAR(50),
`apellido_paterno` VARCHAR(50),
`apellido_materno` VARCHAR(50),
`direccion` VARCHAR(50),
`comuna` VARCHAR(50),
`telefono` DECIMAL(10,2),
`email` VARCHAR(50),
`dd_legales` DECIMAL(10,2),
`dd_administrativos` DECIMAL(10,2),
`fecha_contrato` TIMESTAMP NULL,
`id_perfil` DECIMAL(10,2),
`id_cargo` DECIMAL(10,2),
`id_departamento` DECIMAL(10,2),
PRIMARY KEY (`rut`)
) CHARACTER SET latin1;
CREATE TABLE `PERMISOS` (
`id_permiso` DECIMAL(10,2) NOT NULL,
`fecha_creacion` TIMESTAMP NULL,
`rut` DECIMAL(10,2),
PRIMARY KEY (`id_permiso`)
) CHARACTER SET latin1;
CREATE TABLE `DETALLES_PERMISO` (
`id_detalle` DECIMAL(10,2) NOT NULL,
`fecha_resolucion` TIMESTAMP NULL,
`fecha_desde` TIMESTAMP NULL,
`fecha_hasta` TIMESTAMP NULL,
`nombre_archivo` VARCHAR(50),
`dias` DECIMAL(10,2),
`id_permiso` DECIMAL(10,2),
`id_motivo` DECIMAL(10,2),
`id_tipo` DECIMAL(10,2),
`id_estado` DECIMAL(10,2),
PRIMARY KEY (`id_detalle`)
) CHARACTER SET latin1;
