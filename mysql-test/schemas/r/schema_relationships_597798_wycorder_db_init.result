`fatigue` SMALLINT,
`aches` SMALLINT,
`taste_loss` SMALLINT,
`congestion` SMALLINT,
`nausea_vomit_diarrhea` SMALLINT,
`infectious_contact` SMALLINT,
`temperature` SMALLINT,
PRIMARY KEY (`reading_id`)
) CHARACTER SET latin1;
