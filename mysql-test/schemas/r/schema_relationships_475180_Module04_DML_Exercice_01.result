`JOB` VARCHAR(50),
`MGR` INT,
`DATE_EMBAUCHE` DATE,
`SALAIRE` DOUBLE,
`COMMISSION` DOUBLE,
`NO_SERVICE` INT,
PRIMARY KEY (`NO_EMPLOYE`)
) CHARACTER SET latin1;
