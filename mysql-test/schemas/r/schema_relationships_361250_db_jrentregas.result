`id` INT,
`code` VARCHAR(50),
`local` VARCHAR(50),
`userId` INT,
`createdAt` DATETIME,
`updatedAt` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
