`length` BIGINT,
`sha256` VARCHAR(50),
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `license` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`provider` VARCHAR(50),
`issued` DATETIME,
`updated` DATETIME,
`rights_print` INT,
`rights_copy` INT,
`rights_start` DATETIME,
`rights_end` DATETIME,
`content_fk` VARCHAR(50),
`lsd_status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
