CREATE DATABASE `db_315839_employeedbschema`;
USE `db_315839_employeedbschema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_315839_employeedbschema') AS relationships;
