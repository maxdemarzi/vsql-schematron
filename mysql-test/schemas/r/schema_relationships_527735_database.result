INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 527735_database
#
CREATE DATABASE `db_527735_database`;
USE `db_527735_database`;
CREATE TABLE `users` (
`userId` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`transactionId` INT NOT NULL,
`fromUserId` INT,
`toUserId` INT,
`amount` INT,
`account` VARCHAR(50),
`note` VARCHAR(50),
`date` TIMESTAMP NULL,
PRIMARY KEY (`transactionId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_527735_database') AS relationships;
relationships
