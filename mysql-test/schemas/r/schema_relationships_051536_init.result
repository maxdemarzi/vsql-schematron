INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 051536_init
#
CREATE DATABASE `db_051536_init`;
USE `db_051536_init`;
CREATE TABLE `FoodCategory` (
`Id` INT NOT NULL,
`Name` VARCHAR(50),
`Description` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Food` (
`Id` INT NOT NULL,
`CategoryId` INT,
`Name` VARCHAR(50),
`Price` DECIMAL(10,2),
`Description` VARCHAR(50),
`Picture` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`account` VARCHAR(50),
`password` VARCHAR(50),
`age` INT,
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_051536_init') AS relationships;
