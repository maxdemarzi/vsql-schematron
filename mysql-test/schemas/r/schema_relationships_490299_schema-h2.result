CREATE DATABASE `db_490299_schema_h2`;
USE `db_490299_schema_h2`;
CREATE TABLE `CUSTOMER` (
`ID` BIGINT NOT NULL,
`VER` INT,
`TM` DATETIME,
`ACTIVE_AFTER` DATETIME,
`ACTIVE_UNTIL` DATETIME,
`LOGIN` VARCHAR(50),
`PASSWORD` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER_ACCOUNT` (
`ID` BIGINT NOT NULL,
`VER` INT,
`TM` DATETIME,
`CURRENCY` CHAR(50),
`BALANCE` INT,
`ID_CUSTOMER` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
