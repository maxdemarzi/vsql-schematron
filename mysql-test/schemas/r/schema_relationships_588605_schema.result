CREATE DATABASE `db_588605_schema`;
USE `db_588605_schema`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` TEXT,
`password` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `device` (
`id` INT NOT NULL,
`author_id` INT,
`access_token` TEXT,
`name` TEXT,
`description` TEXT,
`state` INT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588605_schema') AS relationships;
