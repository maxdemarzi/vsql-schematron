INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 382210_EMPRESA
#
CREATE DATABASE `db_382210_EMPRESA`;
USE `db_382210_EMPRESA`;
CREATE TABLE `DEPTO` (
`DEPTNO` INT NOT NULL,
`DNOME` VARCHAR(50),
PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
`EMPNO` INT NOT NULL,
`ENOME` VARCHAR(50),
`ESAL` DECIMAL(10,2),
`EDATADM` DATE,
`EFUNCAO` CHAR(50),
`DEPTNO` INT,
PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `FONES_EMP` (
`EMPNO` INT NOT NULL,
`EFONE` VARCHAR(50) NOT NULL,
PRIMARY KEY (`EMPNO`, `EFONE`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_382210_EMPRESA') AS relationships;
relationships
Database: db_382210_EMPRESA

