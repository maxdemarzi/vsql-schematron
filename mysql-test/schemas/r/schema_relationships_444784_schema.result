INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 444784_schema
#
CREATE DATABASE `db_444784_schema`;
USE `db_444784_schema`;
CREATE TABLE `contact` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`birth_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact_tel_detail` (
`id` INT NOT NULL,
`contact_id` INT,
`tel_type` VARCHAR(50),
`tel_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_444784_schema') AS relationships;
