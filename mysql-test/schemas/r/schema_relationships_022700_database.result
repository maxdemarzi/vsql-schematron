CREATE TABLE `Owner` (
`OwnerId` VARCHAR(50) NOT NULL,
`Name` VARCHAR(50),
`DateOfBirth` DATE,
`Address` VARCHAR(50),
PRIMARY KEY (`OwnerId`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`AccountId` VARCHAR(50) NOT NULL,
`DateCreated` DATE,
`AccountType` VARCHAR(50),
`OwnerId` CHAR(50),
PRIMARY KEY (`AccountId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_022700_database') AS relationships;
