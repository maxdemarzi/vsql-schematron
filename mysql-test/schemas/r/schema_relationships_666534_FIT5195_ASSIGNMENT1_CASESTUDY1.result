CREATE DATABASE `db_666534_FIT5195_ASSIGNMENT1_CASESTUDY1`;
USE `db_666534_FIT5195_ASSIGNMENT1_CASESTUDY1`;
CREATE TABLE `PATIENT` (
`patient_id` DECIMAL(10,2) NOT NULL,
`patient_name` VARCHAR(50),
`patient_age` DECIMAL(10,2),
`patient_ph_no` DECIMAL(10,2),
`patient_address` VARCHAR(50),
`patient_nationality` VARCHAR(50),
`patient_emergency_contact` DECIMAL(10,2),
PRIMARY KEY (`patient_id`)
) CHARACTER SET latin1;
CREATE TABLE `DOCTOR` (
`staff_id` DECIMAL(10,2) NOT NULL,
`staff_name` VARCHAR(50),
`staff_ph_no` DECIMAL(10,2),
PRIMARY KEY (`staff_id`)
) CHARACTER SET latin1;
CREATE TABLE `CLINIC` (
`hospital_id` DECIMAL(10,2) NOT NULL,
`hospital_name` VARCHAR(50),
`hospital_address` VARCHAR(50),
`suburb` VARCHAR(50),
`postcode` DECIMAL(10,2),
PRIMARY KEY (`hospital_id`)
) CHARACTER SET latin1;
CREATE TABLE `SERVICE` (
`service_id` DECIMAL(10,2) NOT NULL,
`staff_id` DECIMAL(10,2),
`hospital_id` DECIMAL(10,2),
`service_name` VARCHAR(50),
`service_cost` DECIMAL(10,2),
PRIMARY KEY (`service_id`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT` (
`assignment_id` DECIMAL(10,2) NOT NULL,
`patient_id` DECIMAL(10,2),
`patient_service_start_date` DATE,
`patient_service_end_date` DATE,
`service_id` DECIMAL(10,2),
PRIMARY KEY (`assignment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_666534_FIT5195_ASSIGNMENT1_CASESTUDY1') AS relationships;
relationships
