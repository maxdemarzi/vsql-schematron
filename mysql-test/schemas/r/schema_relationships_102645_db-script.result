CREATE DATABASE `db_102645_db_script`;
USE `db_102645_db_script`;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rewards` (
`id` INT NOT NULL,
`createdDate` DATE,
`amount` DECIMAL(10,2),
`description` VARCHAR(50),
`payeeName` VARCHAR(50),
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_102645_db_script') AS relationships;
