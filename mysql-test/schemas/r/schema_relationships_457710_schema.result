INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 457710_schema
#
CREATE DATABASE `db_457710_schema`;
USE `db_457710_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` INT,
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_457710_schema') AS relationships;
relationships
Database: db_457710_schema

Table Connections:
