INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 386170_schema
#
CREATE DATABASE `db_386170_schema`;
USE `db_386170_schema`;
CREATE TABLE `ubication` (
`idUbication` INT NOT NULL,
`ref_id` VARCHAR(50),
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`idUbication`)
) CHARACTER SET latin1;
CREATE TABLE `unidad` (
`idUnidad` INT NOT NULL,
`idUbication` INT,
`code` VARCHAR(50),
`name` VARCHAR(50),
`description` VARCHAR(50),
`photo` VARCHAR(50),
`ubication` VARCHAR(50),
PRIMARY KEY (`idUnidad`)
) CHARACTER SET latin1;
CREATE TABLE `services` (
`idService` INT NOT NULL,
`name` VARCHAR(50),
`price` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`idService`)
) CHARACTER SET latin1;
CREATE TABLE `depa` (
`idDepa` INT NOT NULL,
`idUnidad` INT,
`flat` VARCHAR(50),
`number` VARCHAR(50),
`description` VARCHAR(50),
`photo` VARCHAR(50),
`area` VARCHAR(50),
`qr_code` VARCHAR(50),
`canon` INT,
`currency` VARCHAR(50),
`is_avaliable` BOOLEAN,
PRIMARY KEY (`idDepa`)
) CHARACTER SET latin1;
CREATE TABLE `services_depa` (
`idServiceDp` INT NOT NULL,
`idDepa` INT,
`idService` INT,
`description` VARCHAR(50),
PRIMARY KEY (`idServiceDp`)
) CHARACTER SET latin1;
CREATE TABLE `type_id` (
`idType` INT NOT NULL,
`type` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`idType`)
) CHARACTER SET latin1;
CREATE TABLE `smart_depa` (
`idSmartDp` INT NOT NULL,
`idDepa` INT,
`document_id` VARCHAR(50),
`start_date` VARCHAR(50),
`final_date` VARCHAR(50),
`score` INT,
`description` VARCHAR(50),
PRIMARY KEY (`idSmartDp`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_386170_schema') AS relationships;
relationships
Database: db_386170_schema

Table Connections:
------------------
[Implied]  depa.idUnidad -> unidad.idUnidad
[Implied]  services_depa.idDepa -> depa.idDepa
[Implied]  services_depa.idService -> services.idService
[Implied]  smart_depa.idDepa -> depa.idDepa
[Implied]  unidad.idUbication -> ubication.idUbication

DROP DATABASE `db_386170_schema`;
UNINSTALL EXTENSION vsql_schematron;
