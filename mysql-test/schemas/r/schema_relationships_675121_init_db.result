INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 675121_init_db
#
CREATE DATABASE `db_675121_init_db`;
USE `db_675121_init_db`;
CREATE TABLE `admin` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file` (
`id` INT NOT NULL,
`subject` VARCHAR(50),
`type` VARCHAR(50),
`name` VARCHAR(50),
`description` VARCHAR(50),
`download_count` INT,
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
`id` INT NOT NULL,
`type` VARCHAR(50),
`nick` VARCHAR(50),
`contact` VARCHAR(50),
`title` VARCHAR(50),
`content` VARCHAR(50),
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reply` (
`id` INT NOT NULL,
`message_id` INT,
`admin_id` INT,
`user_id` INT,
`content` VARCHAR(50),
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `score` (
`id` INT NOT NULL,
`student_number` INT,
`exam_id` INT,
`chinese` DECIMAL(10,2),
`chinese_rank` INT,
`math` DECIMAL(10,2),
`math_rank` INT,
`english` DECIMAL(10,2),
`english_rank` INT,
`physics` DECIMAL(10,2),
`physics_rank` INT,
`chemistry` DECIMAL(10,2),
`chemistry_rank` INT,
`biologic` DECIMAL(10,2),
`biologic_rank` INT,
`politics` DECIMAL(10,2),
`politics_rank` INT,
`history` DECIMAL(10,2),
`history_rank` INT,
`geography` DECIMAL(10,2),
`geography_rank` INT,
`physical` DECIMAL(10,2),
`physical_rank` INT,
`experiment` DECIMAL(10,2),
`experiment_rank` INT,
`score1` DECIMAL(10,2),
`score1_rank` INT,
`score2` DECIMAL(10,2),
`score2_rank` INT,
`total` DECIMAL(10,2),
`total_rank` INT,
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `carousel` (
`id` INT NOT NULL,
`img_url` VARCHAR(50),
`link_url` VARCHAR(50),
`order` INT,
`alt_text` VARCHAR(50),
`enabled` TINYINT,
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `semester` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`number` INT,
`year` SMALLINT,
`creation_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_675121_init_db') AS relationships;
