INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 228839_schema
#
CREATE DATABASE `db_228839_schema`;
USE `db_228839_schema`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`department` INT,
`salary` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_228839_schema') AS relationships;
relationships
