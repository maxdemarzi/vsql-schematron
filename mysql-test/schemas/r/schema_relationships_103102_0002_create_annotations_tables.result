`org_id` VARCHAR(50),
`name` TEXT,
`description` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `annotations` (
`id` VARCHAR(50) NOT NULL,
`org_id` VARCHAR(50),
`stream_id` VARCHAR(50),
`summary` TEXT,
`message` TEXT,
`stickers` TEXT,
`duration` TEXT,
`lower` TIMESTAMP NULL,
`upper` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
