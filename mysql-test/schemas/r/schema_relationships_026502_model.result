CREATE DATABASE `db_026502_model`;
USE `db_026502_model`;
CREATE TABLE `recetas` (
`id` INT NOT NULL,
`descripcion` VARCHAR(50),
`foto` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pasos_recetas` (
`id` INT NOT NULL,
`descripcion` VARCHAR(50),
`receta` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipos` (
`id` INT NOT NULL,
`descripcion` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipos_recetas` (
`id` INT NOT NULL,
`receta` INT,
`tipo` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredientes` (
`id` INT NOT NULL,
`descripcion` VARCHAR(50),
`foto` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredientes_recetas` (
`id` INT NOT NULL,
`receta` INT,
`cantidad` VARCHAR(50),
`ingrediente` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_026502_model') AS relationships;
