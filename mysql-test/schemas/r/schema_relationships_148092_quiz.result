) CHARACTER SET latin1;
CREATE TABLE `pergunta` (
`id` INT NOT NULL,
`texto` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resposta` (
`id` INT,
`texto` TEXT,
`status` TINYINT,
`idpergunta` INT
) CHARACTER SET latin1;
