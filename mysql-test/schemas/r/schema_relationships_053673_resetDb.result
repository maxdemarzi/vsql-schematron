INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 053673_resetDb
#
CREATE DATABASE `db_053673_resetDb`;
USE `db_053673_resetDb`;
CREATE TABLE `gqscrape.user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gqscrape.question` (
`id` INT NOT NULL,
`text` VARCHAR(50),
`thumbs` INT,
`gold` VARCHAR(50),
`user_id` INT,
`date` VARCHAR(50),
`scrape_time` VARCHAR(50),
`num_answers` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gqscrape.answer` (
`id` INT NOT NULL,
`text` VARCHAR(50),
`thumbs` INT,
`gold` VARCHAR(50),
`date` VARCHAR(50),
`scrape_time` VARCHAR(50),
`user_id` INT,
`question_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_053673_resetDb') AS relationships;
relationships
