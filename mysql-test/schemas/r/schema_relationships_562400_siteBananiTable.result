CREATE DATABASE `db_562400_siteBananiTable`;
USE `db_562400_siteBananiTable`;
CREATE TABLE `menu1` (
`m_id` INT NOT NULL,
`m_name` VARCHAR(50),
`price` DECIMAL(10,2),
`m_type` VARCHAR(50),
PRIMARY KEY (`m_id`)
) CHARACTER SET latin1;
CREATE TABLE `branch1` (
`b_id` INT NOT NULL,
`b_name` VARCHAR(50),
`b_address` VARCHAR(50),
PRIMARY KEY (`b_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer1` (
`c_id` INT NOT NULL,
`c_name` VARCHAR(50),
`c_address` VARCHAR(50),
`c_phone` DECIMAL(10,2),
`c_type` VARCHAR(50),
`b_id` INT,
PRIMARY KEY (`c_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders1` (
`o_id` INT NOT NULL,
`o_date` DATE,
`o_quantity` INT,
`o_type` VARCHAR(50),
`c_id` INT,
`m_id` INT,
`b_id` INT,
PRIMARY KEY (`o_id`)
) CHARACTER SET latin1;
CREATE TABLE `booking1` (
`RID` INT NOT NULL,
`duration` VARCHAR(50),
`RDate` DATE,
`RTime` VARCHAR(50),
`RType` VARCHAR(50),
`c_id` INT,
PRIMARY KEY (`RID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_562400_siteBananiTable') AS relationships;
