CREATE DATABASE `db_217681_hurshot`;
USE `db_217681_hurshot`;
CREATE TABLE `markers` (
`id` INT NOT NULL,
`secret` VARCHAR(50),
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
`descr` TEXT,
`pic` VARCHAR(50),
`points` INT,
`is_enabled` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `marklog` (
`id` INT NOT NULL,
`marker_id` INT,
`auth` VARCHAR(50),
`ts` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_217681_hurshot') AS relationships;
