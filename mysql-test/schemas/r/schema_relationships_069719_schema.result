INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 069719_schema
#
CREATE DATABASE `db_069719_schema`;
USE `db_069719_schema`;
CREATE TABLE `AUTHOR` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`COUNTRY` VARCHAR(50),
`BIRTHDATE` DATE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`COUNTRY` VARCHAR(50),
`BIRTHDATE` DATE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`AUTHOR_ID` INT,
`PUBLISHER_ID` INT,
`NAME` VARCHAR(50),
`CONTENT` VARCHAR(50),
`PRICE` INT,
`PUBLISHED_AT` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `COUNTRY` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`POPULATION` VARCHAR(50),
`LAND_AREA` VARCHAR(50),
`DENSITY` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_069719_schema') AS relationships;
relationships
Database: db_069719_schema

Table Connections:
