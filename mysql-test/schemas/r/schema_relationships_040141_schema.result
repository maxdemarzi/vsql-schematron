INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 040141_schema
#
CREATE DATABASE `db_040141_schema`;
USE `db_040141_schema`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `empl_roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`empl_role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_040141_schema') AS relationships;
relationships
Database: db_040141_schema

Table Connections:
------------------
[Implied]  empl_roles.department_id -> departments.id
[Implied]  employees.empl_role_id -> empl_roles.id
[Implied]  employees.manager_id -> employees.id

DROP DATABASE `db_040141_schema`;
UNINSTALL EXTENSION vsql_schematron;
