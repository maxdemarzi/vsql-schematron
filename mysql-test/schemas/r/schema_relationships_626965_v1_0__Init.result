CREATE DATABASE `db_626965_v1_0__Init`;
USE `db_626965_v1_0__Init`;
CREATE TABLE `product` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart` (
`id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart_line` (
`id` INT NOT NULL,
`shopping_cart_id` VARCHAR(50) NOT NULL,
`product_id` VARCHAR(50),
`amount` INT,
PRIMARY KEY (`shopping_cart_id`, `id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_626965_v1_0__Init') AS relationships;
