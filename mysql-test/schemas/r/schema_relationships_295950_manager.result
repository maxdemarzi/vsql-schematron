INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 295950_manager
#
CREATE DATABASE `db_295950_manager`;
USE `db_295950_manager`;
CREATE TABLE `tb_transacao` (
`cd_transacao` INT NOT NULL,
`vl_transacao` DOUBLE,
`dt_transacao` DATE,
`st_transacao` VARCHAR(50),
`ds_transacao` VARCHAR(50),
`id_forma` INT,
`id_categoria` INT,
`id_usuario` INT,
PRIMARY KEY (`cd_transacao`)
) CHARACTER SET latin1;
CREATE TABLE `tb_forma` (
`cd_forma` INT NOT NULL,
`ds_forma` VARCHAR(50),
PRIMARY KEY (`cd_forma`)
) CHARACTER SET latin1;
CREATE TABLE `tb_categoria` (
`cd_categoria` INT NOT NULL,
`nm_categoria` VARCHAR(50),
PRIMARY KEY (`cd_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `tb_usuario` (
`cd_usuario` INT NOT NULL,
`nm_usuario` VARCHAR(50),
`ds_login` VARCHAR(50),
`ds_senha` VARCHAR(50),
PRIMARY KEY (`cd_usuario`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_295950_manager') AS relationships;
relationships
