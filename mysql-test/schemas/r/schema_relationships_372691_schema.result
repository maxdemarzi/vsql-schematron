INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 372691_schema
#
CREATE DATABASE `db_372691_schema`;
USE `db_372691_schema`;
CREATE TABLE `users` (
`userid` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`admin_access` BOOLEAN,
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `admin_users` (
`adminid` INT NOT NULL,
`admin_password` VARCHAR(50),
`userid` INT,
PRIMARY KEY (`adminid`)
) CHARACTER SET latin1;
CREATE TABLE `auction_items` (
`id` INT NOT NULL,
`item` VARCHAR(50),
`value` DECIMAL(10,2),
`category` VARCHAR(50),
`bid` DECIMAL(10,2),
`topBidder` VARCHAR(50),
`closed` BOOLEAN,
`userid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_372691_schema') AS relationships;
relationships
