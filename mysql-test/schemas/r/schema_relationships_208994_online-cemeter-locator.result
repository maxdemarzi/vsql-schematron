INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 208994_online-cemeter-locator
#
CREATE DATABASE `db_208994_online_cemeter_locator`;
USE `db_208994_online_cemeter_locator`;
CREATE TABLE `cemetery` (
`id` INT,
`user_id` INT,
`title` VARCHAR(50),
`street` VARCHAR(50),
`zip` VARCHAR(50),
`longitude` VARCHAR(50),
`latitude` VARCHAR(50),
`phone` VARCHAR(50),
`image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `obituary` (
`id` INT,
`user_id` INT,
`person_name` VARCHAR(50),
`dates` TEXT,
`prayers` TEXT,
`image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`pwd_reset_token` VARCHAR(50),
`user_status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_208994_online_cemeter_locator') AS relationships;
relationships
Database: db_208994_online_cemeter_locator

Table Connections:
------------------
[Implied]  cemetery.user_id -> user.id
[Implied]  obituary.user_id -> user.id

DROP DATABASE `db_208994_online_cemeter_locator`;
