INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 220234_seed
#
CREATE DATABASE `db_220234_seed`;
USE `db_220234_seed`;
CREATE TABLE `tbl_channels` (
`id` VARCHAR(50) NOT NULL,
`guild` VARCHAR(50),
`category` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_users` (
`id` BIGINT NOT NULL,
`user_id` VARCHAR(50),
`channel_id` VARCHAR(50),
`nick` VARCHAR(50),
`valor_sujo` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_220234_seed') AS relationships;
relationships
