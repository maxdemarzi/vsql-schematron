CREATE DATABASE `db_352098_sqlscript`;
USE `db_352098_sqlscript`;
CREATE TABLE `town` (
`town_id` INT NOT NULL,
`silver` INT,
`iron` INT,
`wood` INT,
`spearman` INT,
`townhall` INT,
`barrack` INT,
`raidinghut` INT,
`woodcutter` INT,
`ironmine` INT,
`farm` INT,
`x` INT,
`y` INT,
`townname` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`town_id`)
) CHARACTER SET latin1;
CREATE TABLE `attack` (
`attack_id` INT NOT NULL,
`attackerTown` INT,
`defenderTown` INT,
`eta` INT,
PRIMARY KEY (`attack_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_352098_sqlscript') AS relationships;
