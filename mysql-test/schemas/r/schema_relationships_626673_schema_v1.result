CREATE TABLE `COURSE` (
`ID` INT NOT NULL,
`CODE` VARCHAR(50),
`LEVEL` INT,
`TERM` VARCHAR(50),
`ACADEMIC_YEAR` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE_ATTR` (
`ID` INT NOT NULL,
`COURSE_ID` INT,
`ATTR_NAME` VARCHAR(50),
`ATTR_VALUE` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT` (
`ID` INT NOT NULL,
`COURSE_ID` INT,
`NAME` VARCHAR(50),
`DUE_DATE` DATE,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ATTR` (
`ID` INT NOT NULL,
`ASSIGNMENT_ID` INT,
`ATTR_NAME` VARCHAR(50),
`ATTR_VALUE` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ENROLLMENT` (
`ID` INT NOT NULL,
`ASSIGNMENT_ID` INT,
`USER_ID` VARCHAR(50),
`PINNED` BOOLEAN,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMMENT` (
`ID` INT NOT NULL,
`CREATED` DATETIME,
`SOURCE_TYPE` VARCHAR(50),
`SOURCE_ITEM_ID` INT,
`AUTHOR_ID` VARCHAR(50),
`CONTENT` VARCHAR(50),
`LAST_EDITED` DATETIME,
`UPVOTE_COUNT` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VOTE` (
`ID` INT NOT NULL,
`SOURCE_TYPE` VARCHAR(50),
`SOURCE_ITEM_ID` INT,
`AUTHOR_ID` VARCHAR(50),
`ACTION` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
