CREATE DATABASE `db_293831_schema`;
USE `db_293831_schema`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` TEXT,
`password` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT NOT NULL,
`author_id` INT,
`created` TIMESTAMP NULL,
`title` TEXT,
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publication` (
`id` INT NOT NULL,
`type` TEXT,
`author_block` TEXT,
`title` TEXT,
`journal` TEXT,
`year` TEXT,
`doi` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_293831_schema') AS relationships;
