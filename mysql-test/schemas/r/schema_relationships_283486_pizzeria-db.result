INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 283486_pizzeria-db
#
CREATE DATABASE `db_283486_pizzeria_db`;
USE `db_283486_pizzeria_db`;
CREATE TABLE `pizzas` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pizza_ingredient` (
`id` INT NOT NULL,
`pizza_id` INT,
`ingredient_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`order_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
`id` INT NOT NULL,
`pizza_id` INT,
`order_id` INT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_283486_pizzeria_db') AS relationships;
relationships
Database: db_283486_pizzeria_db

Table Connections:
------------------
[Implied]  order_item.order_id -> orders.id
[Implied]  order_item.pizza_id -> pizzas.id
[Implied]  pizza_ingredient.ingredient_id -> ingredients.id
[Implied]  pizza_ingredient.pizza_id -> pizzas.id

DROP DATABASE `db_283486_pizzeria_db`;
UNINSTALL EXTENSION vsql_schematron;
