INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 257474_1
#
CREATE DATABASE `db_257474_1`;
USE `db_257474_1`;
CREATE TABLE `location` (
`address` VARCHAR(50) NOT NULL,
`label` VARCHAR(50),
PRIMARY KEY (`address`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`locationAddress` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measuredPhenomenon` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`unit` VARCHAR(50),
`aggregationStrategy` VARCHAR(50),
`sensorId` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_257474_1') AS relationships;
relationships
