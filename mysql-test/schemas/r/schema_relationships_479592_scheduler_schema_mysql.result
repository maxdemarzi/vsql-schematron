CREATE DATABASE `db_479592_scheduler_schema_mysql`;
USE `db_479592_scheduler_schema_mysql`;
CREATE TABLE `SCHEDULER_CONFIGURATION` (
`id` BIGINT NOT NULL,
`application_name` VARCHAR(50),
`job_name` VARCHAR(50),
`configuration_status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SCHEDULER_CONFIGURATION_VALUE` (
`id` BIGINT NOT NULL,
`scheduler_configuration_id` BIGINT,
`type` VARCHAR(50),
`value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SCHEDULER_EXECUTION` (
`id` BIGINT NOT NULL,
`scheduler_configuration_id` BIGINT,
`next_fire_time` TIMESTAMP NULL,
`execution_count` INT,
`state` INT,
`last_update` TIMESTAMP NULL,
`next_retry` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
