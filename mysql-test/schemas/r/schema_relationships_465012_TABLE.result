INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 465012_TABLE
#
CREATE DATABASE `db_465012_TABLE`;
USE `db_465012_TABLE`;
CREATE TABLE `USER` (
`ID` INT NOT NULL,
`FIRST_NAME` VARCHAR(50),
`LAST_NAME` VARCHAR(50),
`EMAIL` VARCHAR(50),
`PHONE` VARCHAR(50),
`PASSWORD` VARCHAR(50),
`ADDRESS` VARCHAR(50),
`TYPE` CHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Payment` (
`PaymentID` INT
) CHARACTER SET latin1;
CREATE TABLE `Card` (
`CardID` INT,
`Card_Number` INT,
`CVC` INT,
`Expiry` DATE
) CHARACTER SET latin1;
CREATE TABLE `RoomType` (
`RoomTypeID` INT NOT NULL,
`CostPerDay` DOUBLE,
`NumBeds` INT,
`Suite` VARCHAR(50),
`Description` VARCHAR(50),
PRIMARY KEY (`RoomTypeID`)
) CHARACTER SET latin1;
CREATE TABLE `Room` (
`RoomID` INT NOT NULL,
`RoomTypeID` INT,
PRIMARY KEY (`RoomID`)
) CHARACTER SET latin1;
CREATE TABLE `Booking` (
`BookingID` INT NOT NULL,
`UserID` INT,
`RoomID` INT,
`Starting_Date` DATE,
`Ending_Date` DATE,
`Status` VARCHAR(50),
`Paid` BOOLEAN,
`Total_Cost` DOUBLE,
PRIMARY KEY (`BookingID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_465012_TABLE') AS relationships;
relationships
