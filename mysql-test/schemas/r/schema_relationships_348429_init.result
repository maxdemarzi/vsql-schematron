[Implied]  document_issue.document_id -> document.document_id
[Implied]  document_issue.subscriber_id -> subscriber.subscriber_id
[Implied]  shelf.rack_id -> rack.rack_id
[Implied]  subscriber.department_id -> department.department_id

DROP DATABASE `db_348429_init`;
UNINSTALL EXTENSION vsql_schematron;
