INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 400353_database
#
CREATE DATABASE `db_400353_database`;
USE `db_400353_database`;
CREATE TABLE `public.dim_card` (
`id_card` INT NOT NULL,
`card` VARCHAR(50),
PRIMARY KEY (`id_card`)
) CHARACTER SET latin1;
CREATE TABLE `public.dim_country` (
`id_country` INT NOT NULL,
`country` VARCHAR(50),
PRIMARY KEY (`id_country`)
) CHARACTER SET latin1;
CREATE TABLE `public.dim_date_sale` (
`id_date_sale` INT NOT NULL,
`date_sale` DATE,
PRIMARY KEY (`id_date_sale`)
) CHARACTER SET latin1;
CREATE TABLE `public.dim_gender` (
`id_gender` INT NOT NULL,
`gender` VARCHAR(50),
PRIMARY KEY (`id_gender`)
) CHARACTER SET latin1;
CREATE TABLE `public.dim_job_title` (
`id_job_title` INT NOT NULL,
`job_title` VARCHAR(50),
PRIMARY KEY (`id_job_title`)
) CHARACTER SET latin1;
CREATE TABLE `public.fact_table` (
`id_date_sale` INT,
`id_card` INT,
`id_gender` INT,
`id_job_title` INT,
`id_country` INT,
`min_sale_paid` DECIMAL(10,2),
`max_sale_paid` DECIMAL(10,2),
`count_sale_paid` DECIMAL(10,2),
`sum_sale_paid` DECIMAL(10,2),
`avg_sale_paid` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_400353_database') AS relationships;
