PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BatchFile` (
`ID` INT NOT NULL,
`Name` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BatchFilePlugin` (
`ID` INT NOT NULL,
`BatchFileID` INT,
`PluginID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
