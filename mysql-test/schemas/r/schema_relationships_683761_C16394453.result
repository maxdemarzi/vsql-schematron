CREATE DATABASE `db_683761_C16394453`;
USE `db_683761_C16394453`;
CREATE TABLE `Client` (
`clientID` DECIMAL(10,2) NOT NULL,
`fullName` VARCHAR(50),
`emailAdr` VARCHAR(50),
PRIMARY KEY (`clientID`)
) CHARACTER SET latin1;
CREATE TABLE `Designer` (
`designerID` DECIMAL(10,2) NOT NULL,
`fullName` VARCHAR(50),
`emailAdr` VARCHAR(50),
`dRateofPay` DECIMAL(10,2),
PRIMARY KEY (`designerID`)
) CHARACTER SET latin1;
CREATE TABLE `Specification` (
`specID` DECIMAL(10,2) NOT NULL,
`specDesc` VARCHAR(50),
`specCommission` DECIMAL(10,2),
`clientID` DECIMAL(10,2),
`designerID` DECIMAL(10,2),
`designHrsWorked` DECIMAL(10,2),
`specDate` DATE,
PRIMARY KEY (`specID`)
) CHARACTER SET latin1;
CREATE TABLE `ProdType` (
`prodCat` CHAR(50),
`catDesc` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`prodID` DECIMAL(10,2),
`prodDescription` VARCHAR(50),
`prodUnitPrice` DECIMAL(10,2),
`prodQtyInStock` DECIMAL(10,2),
`prodCat` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SpecProd` (
`specID` DECIMAL(10,2),
`prodID` VARCHAR(50),
`qtyUsed` DECIMAL(10,2)
) CHARACTER SET latin1;
