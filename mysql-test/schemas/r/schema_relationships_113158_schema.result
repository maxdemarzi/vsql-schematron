INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 113158_schema
#
CREATE DATABASE `db_113158_schema`;
USE `db_113158_schema`;
CREATE TABLE `iso` (
`id` INT NOT NULL,
`name` TEXT,
`status` TEXT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conductor` (
`id` INT NOT NULL,
`name` TEXT,
`url` TEXT,
`auth_key` TEXT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quickstart` (
`id` INT NOT NULL,
`conductor_name` TEXT,
`router_name` TEXT,
`node_name` TEXT,
`asset_id` TEXT,
`config` TEXT,
`description` TEXT,
`default_quickstart` INT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `node` (
`id` INT NOT NULL,
`identifier` TEXT,
`quickstart_id` INT,
`iso_id` TEXT,
`status` TEXT,
`validation_report` TEXT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_113158_schema') AS relationships;
