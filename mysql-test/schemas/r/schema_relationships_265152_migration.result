`body` TEXT,
`value` INT,
`author` TEXT,
`active` BOOLEAN,
`finish` BOOLEAN,
`createdAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Plan` (
`id` INT NOT NULL,
`ideaId` INT,
`owner` TEXT,
`plannedStart` DATETIME,
`plannedEnd` DATETIME,
`progress` INT,
`finish` BOOLEAN,
`createdAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
`id` INT NOT NULL,
`planId` INT,
`type` TEXT,
`owner` TEXT,
`Requiredby` DATETIME,
`status` TEXT,
`Start` DATETIME,
`Finish` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
