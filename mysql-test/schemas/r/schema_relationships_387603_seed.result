INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 387603_seed
#
CREATE DATABASE `db_387603_seed`;
USE `db_387603_seed`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`manager_id` INT,
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_387603_seed') AS relationships;
relationships
Database: db_387603_seed

Table Connections:
