CREATE DATABASE `db_195135_postgres`;
USE `db_195135_postgres`;
CREATE TABLE `divisions` (
`id` INT NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stormtroopers` (
`id` INT NOT NULL,
`name` TEXT,
`nickname` TEXT,
`id_patent` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stormtrooper_division` (
`id_stormtrooper` INT,
`id_division` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_195135_postgres') AS relationships;
