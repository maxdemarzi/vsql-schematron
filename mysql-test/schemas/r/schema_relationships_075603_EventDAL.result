INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 075603_EventDAL
#
CREATE DATABASE `db_075603_EventDAL`;
USE `db_075603_EventDAL`;
CREATE TABLE `EventDB` (
`event_id` INT NOT NULL,
`event_name` VARCHAR(50),
`address` VARCHAR(50),
`description` VARCHAR(50),
`event_time` VARCHAR(50),
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `UserDB` (
`user_id` INT NOT NULL,
`user_name` VARCHAR(50),
`user_password` VARCHAR(50),
`name_user` VARCHAR(50),
`age` INT,
`type_account` INT,
`job` VARCHAR(50),
`address` VARCHAR(50),
`email` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `EventDetailsDB` (
`user_id` INT NOT NULL,
`event_id` INT NOT NULL,
`event_status` VARCHAR(50),
PRIMARY KEY (`user_id`, `event_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_075603_EventDAL') AS relationships;
relationships
Database: db_075603_EventDAL

Table Connections:
------------------
[Implied]  EventDetailsDB.event_id -> EventDB.event_id
[Implied]  EventDetailsDB.user_id -> UserDB.user_id

DROP DATABASE `db_075603_EventDAL`;
