INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 057916_database
#
CREATE DATABASE `db_057916_database`;
USE `db_057916_database`;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`nombre_usuario` VARCHAR(50),
`correo` VARCHAR(50),
`imagen` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT NOT NULL,
`usuario_id` INT,
`titulo` VARCHAR(50),
`texto` TEXT,
`pdf` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_057916_database') AS relationships;
relationships
