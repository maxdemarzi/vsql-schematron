INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 230495_db
#
CREATE DATABASE `db_230495_db`;
USE `db_230495_db`;
CREATE TABLE `USERINFO` (
`userId` DECIMAL(10,2) NOT NULL,
`userName` VARCHAR(50),
`userPassword` VARCHAR(50),
`headImage` BLOB,
`email` VARCHAR(50),
`sex` DECIMAL(10,2),
`age` DECIMAL(10,2),
`state` DECIMAL(10,2),
`isOnline` DECIMAL(10,2),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `SONGS` (
`songId` DECIMAL(10,2) NOT NULL,
`songName` VARCHAR(50),
`duration` DECIMAL(10,2),
`albumName` VARCHAR(50),
`singerName` VARCHAR(50),
`songUrl` VARCHAR(50),
`imageUrl` VARCHAR(50),
`lyricUrl` VARCHAR(50),
PRIMARY KEY (`songId`)
) CHARACTER SET latin1;
CREATE TABLE `SONGRANKLIST` (
`srlId` DECIMAL(10,2) NOT NULL,
`songId` DECIMAL(10,2),
`playNumber` DECIMAL(10,2),
PRIMARY KEY (`srlId`)
) CHARACTER SET latin1;
CREATE TABLE `SONGSHEET` (
`ssid` DECIMAL(10,2) NOT NULL,
`ssname` VARCHAR(50),
`songId` DECIMAL(10,2),
`userId` DECIMAL(10,2),
`state` DECIMAL(10,2),
PRIMARY KEY (`ssid`)
) CHARACTER SET latin1;
CREATE TABLE `COLLECTIONSONGSHEET` (
`cssid` DECIMAL(10,2) NOT NULL,
`cssname` VARCHAR(50),
`songId` DECIMAL(10,2),
`userId` DECIMAL(10,2),
`state` DECIMAL(10,2),
PRIMARY KEY (`cssid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_230495_db') AS relationships;
relationships
