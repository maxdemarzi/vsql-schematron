INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 428357_boat
#
CREATE DATABASE `db_428357_boat`;
USE `db_428357_boat`;
CREATE TABLE `Sailors` (
`sid` DECIMAL(10,2) NOT NULL,
`s_name` VARCHAR(50),
`rating` DECIMAL(10,2),
`age` DECIMAL(10,2),
PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `Boats` (
`bid` DECIMAL(10,2) NOT NULL,
`bname` VARCHAR(50),
`color` VARCHAR(50),
PRIMARY KEY (`bid`)
) CHARACTER SET latin1;
CREATE TABLE `Reserves` (
`sid` DECIMAL(10,2) NOT NULL,
`bid` DECIMAL(10,2) NOT NULL,
`day` DECIMAL(10,2) NOT NULL,
PRIMARY KEY (`sid`, `bid`, `day`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_428357_boat') AS relationships;
relationships
Database: db_428357_boat

Table Connections:
------------------
[Implied]  Reserves.bid -> Boats.bid
[Implied]  Reserves.sid -> Sailors.sid

DROP DATABASE `db_428357_boat`;
UNINSTALL EXTENSION vsql_schematron;
