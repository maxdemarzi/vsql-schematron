INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 099299_database
#
CREATE DATABASE `db_099299_database`;
USE `db_099299_database`;
CREATE TABLE `recipes` (
`id` INT NOT NULL,
`chef_id` INT,
`title` TEXT,
`ingredients` VARCHAR(50),
`preparation` VARCHAR(50),
`information` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT NOT NULL,
`name` TEXT,
`path` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_files` (
`id` INT NOT NULL,
`recipe_id` INT,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_099299_database') AS relationships;
relationships
