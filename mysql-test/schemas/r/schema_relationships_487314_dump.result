CREATE DATABASE `db_487314_dump`;
USE `db_487314_dump`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`gender` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`phone` VARCHAR(50),
`language` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogs` (
`id` INT NOT NULL,
`user_id` INT,
`title` VARCHAR(50),
`body` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ci_sessions` (
`id` VARCHAR(50),
`ip_address` VARCHAR(50),
`timestamp` VARCHAR(50),
`data` BLOB
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_487314_dump') AS relationships;
