INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 435900_script
#
CREATE DATABASE `db_435900_script`;
USE `db_435900_script`;
CREATE TABLE `tipo_user` (
`id_tipo` INT NOT NULL,
`tipo_user` VARCHAR(50),
PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id_user` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`telefone` VARCHAR(50),
`cpf` VARCHAR(50),
`senha` TEXT,
`ativo` INT,
`id_tipo` INT,
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `fornecedor` (
`id_forn` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`cnpj` VARCHAR(50),
`telefone` VARCHAR(50),
`ativo` INT,
PRIMARY KEY (`id_forn`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
`id_end` INT NOT NULL,
`estado` VARCHAR(50),
`cidade` VARCHAR(50),
`rua` VARCHAR(50),
`numero` INT,
`cep` VARCHAR(50),
`id_forn` INT,
PRIMARY KEY (`id_end`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_435900_script') AS relationships;
relationships
Database: db_435900_script

Table Connections:
------------------
[Implied]  endereco.id_forn -> fornecedor.id_forn
[Implied]  usuario.id_tipo -> tipo_user.id_tipo

DROP DATABASE `db_435900_script`;
UNINSTALL EXTENSION vsql_schematron;
