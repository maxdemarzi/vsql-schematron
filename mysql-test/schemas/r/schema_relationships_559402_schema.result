INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 559402_schema
#
CREATE DATABASE `db_559402_schema`;
USE `db_559402_schema`;
CREATE TABLE `policy` (
`id` BIGINT NOT NULL,
`kind` VARCHAR(50),
`name` VARCHAR(50),
`version` VARCHAR(50),
`description` TEXT,
`disabled` BOOLEAN,
`definition` BLOB,
`generated` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `policy_dependency` (
`policy_id` BIGINT NOT NULL,
`dependency_id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`policy_id`, `dependency_id`)
) CHARACTER SET latin1;
CREATE TABLE `policy_revision` (
`revision_id` INT NOT NULL,
`action` VARCHAR(50),
`id` BIGINT,
`kind` VARCHAR(50),
`name` VARCHAR(50),
`version` VARCHAR(50),
`description` TEXT,
`disabled` BOOLEAN,
`definition` BLOB,
`update_timestamp` TIMESTAMP NULL,
PRIMARY KEY (`revision_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_559402_schema') AS relationships;
