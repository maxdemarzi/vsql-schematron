INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 503623_DDL_Pedido
#
CREATE DATABASE `db_503623_DDL_Pedido`;
USE `db_503623_DDL_Pedido`;
CREATE TABLE `ITEM` (
`IDITEM` INT NOT NULL,
`DESCITEM` VARCHAR(50),
PRIMARY KEY (`IDITEM`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOCAB` (
`IDPEDIDOCAB` INT NOT NULL,
`DTEMISSAO` DATE,
`NUMERO` INT,
`CLIENTE` VARCHAR(50),
PRIMARY KEY (`IDPEDIDOCAB`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOITEM` (
`IDPEDIDOITEM` INT NOT NULL,
`IDPEDIDOCAB` INT,
`IDITEM` INT,
`QUANTIDADE` DOUBLE,
`VALORUNIT` DOUBLE,
`VALORTOTAL` DOUBLE,
PRIMARY KEY (`IDPEDIDOITEM`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_503623_DDL_Pedido') AS relationships;
relationships
Database: db_503623_DDL_Pedido

