[Implied]  PEDIDOITEM.IDITEM -> ITEM.IDITEM
[Implied]  PEDIDOITEM.IDPEDIDOCAB -> PEDIDOCAB.IDPEDIDOCAB

DROP DATABASE `db_503623_DDL_Pedido`;
