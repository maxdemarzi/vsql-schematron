INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 087459_V1_0_0__baseline
#
CREATE DATABASE `db_087459_V1_0_0__baseline`;
USE `db_087459_V1_0_0__baseline`;
CREATE TABLE `realm` (
`realm_id` VARCHAR(50) NOT NULL,
`realm_name` CHAR(50),
`enabled` BOOLEAN,
`sync_at` TIMESTAMP NULL,
PRIMARY KEY (`realm_id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
`account_id` VARCHAR(50) NOT NULL,
`account_name` CHAR(50),
`password` CHAR(50),
`user_name` CHAR(50),
`email` CHAR(50),
`locale` CHAR(50),
`realm_id` CHAR(50),
`enabled` BOOLEAN,
PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `notice` (
`notice_id` VARCHAR(50) NOT NULL,
`message` TEXT,
`start_at` DATE,
`end_at` DATE,
`update_at` TIMESTAMP NULL,
PRIMARY KEY (`notice_id`)
) CHARACTER SET latin1;
CREATE TABLE `group_generation` (
`group_generation_id` INT NOT NULL,
`is_current` BOOLEAN,
PRIMARY KEY (`group_generation_id`)
) CHARACTER SET latin1;
CREATE TABLE `lesson` (
`lesson_id` VARCHAR(50) NOT NULL,
`group_transition_id` VARCHAR(50),
`slide_id` CHAR(50),
PRIMARY KEY (`lesson_id`)
) CHARACTER SET latin1;
CREATE TABLE `study` (
`study_id` VARCHAR(50) NOT NULL,
`account_id` VARCHAR(50),
`slide_id` CHAR(50),
`status` CHAR(50),
`progress` VARCHAR(50),
`progress_rate` INT,
`answer` VARCHAR(50),
`score` VARCHAR(50),
`shuffled_question` VARCHAR(50),
`start_at` TIMESTAMP NULL,
`end_at` TIMESTAMP NULL,
PRIMARY KEY (`study_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_087459_V1_0_0__baseline') AS relationships;
