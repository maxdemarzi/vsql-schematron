INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 248647_schema
#
CREATE DATABASE `db_248647_schema`;
USE `db_248647_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emp_role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_248647_schema') AS relationships;
relationships
Database: db_248647_schema

Table Connections:
------------------
[Implied]  emp_role.department_id -> department.id
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> emp_role.id

DROP DATABASE `db_248647_schema`;
UNINSTALL EXTENSION vsql_schematron;
