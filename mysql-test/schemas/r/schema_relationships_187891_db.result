) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
