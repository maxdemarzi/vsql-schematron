INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 038210_lookups
#
CREATE DATABASE `db_038210_lookups`;
USE `db_038210_lookups`;
CREATE TABLE `departments` (
`dept_id` VARCHAR(50) NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `complex` (
`bldg_id` INT NOT NULL,
`bldg_name` VARCHAR(50),
PRIMARY KEY (`bldg_id`)
) CHARACTER SET latin1;
CREATE TABLE `suite` (
`bldg_id` INT NOT NULL,
`room_id` VARCHAR(50) NOT NULL,
`room_name` VARCHAR(50),
`room_level` VARCHAR(50),
`seating_capacity` INT,
PRIMARY KEY (`bldg_id`, `room_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_038210_lookups') AS relationships;
