INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 147836_contact_form
#
CREATE DATABASE `db_147836_contact_form`;
USE `db_147836_contact_form`;
CREATE TABLE `categories` (
`category_id` INT NOT NULL,
`category_name` VARCHAR(50),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`message_id` INT,
`name` VARCHAR(50),
`email` VARCHAR(50),
`phone` VARCHAR(50),
`message` VARCHAR(50),
`created_at` DATETIME,
`deleted_at` DATETIME,
`product_id` INT
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`product_name` TEXT,
`product_description` VARCHAR(50),
`product_price` DECIMAL(10,2),
`date_created` DATE,
`date_deleted` DATE,
`product_category_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_147836_contact_form') AS relationships;
relationships
Database: db_147836_contact_form

Table Connections:
------------------
[Implied]  messages.product_id -> products.id
[Implied]  products.product_category_id -> categories.category_id

DROP DATABASE `db_147836_contact_form`;
UNINSTALL EXTENSION vsql_schematron;
