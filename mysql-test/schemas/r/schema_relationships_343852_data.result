INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 343852_data
#
CREATE DATABASE `db_343852_data`;
USE `db_343852_data`;
CREATE TABLE `roles` (
`role_name` VARCHAR(50) NOT NULL,
PRIMARY KEY (`role_name`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`activated` BOOLEAN,
`non_locked` BOOLEAN,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`user_id` INT,
`role_name` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_343852_data') AS relationships;
relationships
