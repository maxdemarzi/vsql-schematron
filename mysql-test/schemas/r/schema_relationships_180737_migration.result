CREATE DATABASE `db_180737_migration`;
USE `db_180737_migration`;
CREATE TABLE `Product` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`name` TEXT,
`sku` TEXT,
`description` TEXT,
`quantity` INT,
`cartId` TEXT,
`categoryId` INT,
`orderId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cart` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` INT NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`email` TEXT,
`firstName` TEXT,
`lastName` TEXT,
`address` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_180737_migration') AS relationships;
