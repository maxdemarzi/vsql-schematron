CREATE DATABASE `db_178618_schema`;
USE `db_178618_schema`;
CREATE TABLE `parts` (
`id` INT NOT NULL,
`isTempPart` BOOLEAN,
`manufacturerOneId` VARCHAR(50),
`manufactureContractOneId` VARCHAR(50),
`uniqueId` VARCHAR(50),
`manufacturerUniqueId` VARCHAR(50),
`customerUniqueId` VARCHAR(50),
`qualityAlert` BOOLEAN,
`qualityType` VARCHAR(50),
`importTimestampUtc` TIMESTAMP NULL,
`validUntilUtc` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `partRelations` (
`parentPartId` INT,
`childPartId` INT
) CHARACTER SET latin1;
