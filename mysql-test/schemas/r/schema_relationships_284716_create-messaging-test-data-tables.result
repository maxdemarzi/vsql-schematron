CREATE DATABASE `db_284716_create_messaging_test_data_tables`;
USE `db_284716_create_messaging_test_data_tables`;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`message_id` INT NOT NULL,
`user_id` INT,
`room_id` INT,
`message` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_rooms` (
`room_id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`room_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_284716_create_messaging_test_data_tables') AS relationships;
