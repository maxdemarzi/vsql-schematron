CREATE DATABASE `db_595238_V5__bracket_remodel`;
USE `db_595238_V5__bracket_remodel`;
CREATE TABLE `games` (
`game_id` VARCHAR(50) NOT NULL,
`team_a` VARCHAR(50),
`team_b` VARCHAR(50),
`score_a` INT,
`score_b` INT,
`round_id` VARCHAR(50),
`game_index` VARCHAR(50),
`bracket_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `brackets` (
`bracket_id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`name` VARCHAR(50),
`master` TINYINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`bracket_id`)
) CHARACTER SET latin1;
