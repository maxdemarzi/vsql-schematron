CREATE TABLE `qr_report_v1.Users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`passwordHash` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `qr_report_v1.Assets` (
`id` INT NOT NULL,
`uniqueIdentifier` VARCHAR(50),
`building` VARCHAR(50),
`roomNumber` VARCHAR(50),
`appliance` VARCHAR(50),
`serviceRequired` BOOLEAN,
`userID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
