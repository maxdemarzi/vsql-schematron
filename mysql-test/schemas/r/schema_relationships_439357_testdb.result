INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 439357_testdb
#
CREATE DATABASE `db_439357_testdb`;
USE `db_439357_testdb`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`creation_timestamp` DATETIME,
`update_timestamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`creation_timestamp` DATETIME,
`update_timestamp` DATETIME,
`complete` TINYINT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_439357_testdb') AS relationships;
