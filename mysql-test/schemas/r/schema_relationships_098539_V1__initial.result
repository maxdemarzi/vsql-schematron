INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 098539_V1__initial
#
CREATE DATABASE `db_098539_V1__initial`;
USE `db_098539_V1__initial`;
CREATE TABLE `recipes` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`servings` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`quantity` INT,
`unit` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`recipe_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
`id` VARCHAR(50) NOT NULL,
`description` TEXT,
`duration` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`recipe_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_098539_V1__initial') AS relationships;
