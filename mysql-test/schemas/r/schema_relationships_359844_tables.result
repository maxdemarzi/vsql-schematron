CREATE DATABASE `db_359844_tables`;
USE `db_359844_tables`;
CREATE TABLE `GRANT_STATUSES` (
`ID` BIGINT NOT NULL,
`STATUS` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GRANT_TYPES` (
`ID` BIGINT NOT NULL,
`GRANT_TYPE` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORGANIZATIONS` (
`ID` BIGINT NOT NULL,
`ORGANIZATION` TEXT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOCATIONS` (
`ID` BIGINT NOT NULL,
`LOCATION` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `STRATEGIC_PRIORITIES` (
`ID` BIGINT NOT NULL,
`STRATEGIC_PRIORITY` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `STRATEGIC_RESULTS` (
`ID` BIGINT NOT NULL,
`STRATEGIC_RESULT` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GRANTS` (
`ID` BIGINT NOT NULL,
`GRANT_STATUS_ID` BIGINT,
`FISCAL_YEAR` INT,
`GRANT_TYPE_ID` BIGINT,
`ORGANIZATION_ID` BIGINT,
`PROJECT` VARCHAR(50),
`AMOUNT` BIGINT,
`LOCATION_ID` BIGINT,
`STRATEGIC_PRIORITY_ID` BIGINT,
`STRATEGIC_RESULT_ID` BIGINT,
`TOTAL_NUMBER_SERVED` INT,
`NUMBER_NATIVE_HAWAIIANS_SERVED` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
