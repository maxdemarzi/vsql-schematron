INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 385657_company_starter
#
CREATE DATABASE `db_385657_company_starter`;
USE `db_385657_company_starter`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_385657_company_starter') AS relationships;
relationships
Database: db_385657_company_starter

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> role.id
[Implied]  role.dept_id -> department.id

DROP DATABASE `db_385657_company_starter`;
UNINSTALL EXTENSION vsql_schematron;
