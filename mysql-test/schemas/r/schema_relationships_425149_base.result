CREATE DATABASE `db_425149_base`;
USE `db_425149_base`;
CREATE TABLE `my_models` (
`id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `my_model_properties` (
`my_model_id` VARCHAR(50) NOT NULL,
`property_id` VARCHAR(50) NOT NULL,
`seq_no` VARCHAR(50) NOT NULL,
`property_value` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`my_model_id`, `property_id`, `seq_no`)
) CHARACTER SET latin1;
