CREATE DATABASE `db_237007_bibliotheque`;
USE `db_237007_bibliotheque`;
CREATE TABLE `Lecteur` (
`id` VARCHAR(50) NOT NULL,
`nom` VARCHAR(50),
`prenom` VARCHAR(50),
`carte_numero` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Livre` (
`id` VARCHAR(50) NOT NULL,
`nom` VARCHAR(50),
`auteur` VARCHAR(50),
`categorie` VARCHAR(50),
`synopsis` TEXT,
`statut` BOOLEAN,
`lecteur_id` VARCHAR(50),
`date_pret` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
