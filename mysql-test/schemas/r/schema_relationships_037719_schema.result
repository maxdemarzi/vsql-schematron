INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 037719_schema
#
CREATE DATABASE `db_037719_schema`;
USE `db_037719_schema`;
CREATE TABLE `tenants` (
`id` INT NOT NULL,
`handle` VARCHAR(50),
`name` VARCHAR(50),
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`login` VARCHAR(50),
`active` BOOLEAN,
`phone` VARCHAR(50),
`password` VARCHAR(50),
`tenant_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
`id` INT NOT NULL,
`msg` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`published` BOOLEAN,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hash` (
`id` INT NOT NULL,
`k` VARCHAR(50),
`value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_037719_schema') AS relationships;
relationships
