INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 636948_schema
#
CREATE DATABASE `db_636948_schema`;
USE `db_636948_schema`;
CREATE TABLE `Units` (
`uid` INT,
`Name` TEXT,
`Position` INT
) CHARACTER SET latin1;
CREATE TABLE `Aisles` (
`uid` INT,
`Name` TEXT,
`Color` TEXT,
`Icon` TEXT,
`Position` INT
) CHARACTER SET latin1;
CREATE TABLE `Products` (
`uid` INT,
`Name` TEXT,
`Note` TEXT,
`LastUsed` TIMESTAMP NULL,
`AisleID` INT,
`UnitID` INT
) CHARACTER SET latin1;
CREATE TABLE `Lists` (
`uid` INT,
`Name` TEXT,
`Position` INT
) CHARACTER SET latin1;
CREATE TABLE `ProductsLists` (
`Position` INT,
`ListID` INT,
`ProductID` INT,
`Purchased` INT
) CHARACTER SET latin1;
CREATE TABLE `InternalInformation` (
`Version` TIMESTAMP NULL,
`CreatedDate` TIMESTAMP NULL
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_636948_schema') AS relationships;
relationships
