CREATE DATABASE `db_216213_C14337041LabTest`;
USE `db_216213_C14337041LabTest`;
CREATE TABLE `competition` (
`cID` DECIMAL(10,2) NOT NULL,
`cName` VARCHAR(50),
`cFee` DECIMAL(10,2),
`cPrize` DECIMAL(10,2),
`cDate` DATE,
PRIMARY KEY (`cID`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
`tID` DECIMAL(10,2) NOT NULL,
`tName` VARCHAR(50),
`tAgeGroup` DECIMAL(10,2),
`tManager` VARCHAR(50),
`tEmail` VARCHAR(50),
PRIMARY KEY (`tID`)
) CHARACTER SET latin1;
CREATE TABLE `competitionEnrollment` (
`compenrolID` DECIMAL(10,2) NOT NULL,
`competitionID` DECIMAL(10,2),
`teamID` DECIMAL(10,2),
`finalPlacing` DECIMAL(10,2),
PRIMARY KEY (`compenrolID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_216213_C14337041LabTest') AS relationships;
