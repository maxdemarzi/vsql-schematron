INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 368171_computer_store_db
#
CREATE DATABASE `db_368171_computer_store_db`;
USE `db_368171_computer_store_db`;
CREATE TABLE `country` (
`id` VARCHAR(50) NOT NULL,
`version` INT,
`name` VARCHAR(50),
`longitude` DOUBLE,
`country_code` VARCHAR(50),
`latitude` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`id` VARCHAR(50) NOT NULL,
`version` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`favorite_color` VARCHAR(50),
`birth_date` DATETIME,
`email_address` VARCHAR(50),
`male` VARCHAR(50),
`phone_number` VARCHAR(50),
`country_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` VARCHAR(50) NOT NULL,
`version` INT,
`name` VARCHAR(50),
`price` DOUBLE,
`quantity_in_stock` INT,
`product_category_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_category` (
`id` VARCHAR(50) NOT NULL,
`version` INT,
`name` VARCHAR(50),
`parent_category_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_368171_computer_store_db') AS relationships;
relationships
Database: db_368171_computer_store_db

Table Connections:
------------------
[Implied]  customer.country_id -> country.id
[Implied]  product.product_category_id -> product_category.id
[Implied]  product_category.parent_category_id -> product_category.id

DROP DATABASE `db_368171_computer_store_db`;
UNINSTALL EXTENSION vsql_schematron;
