CREATE DATABASE `db_001331_schema`;
USE `db_001331_schema`;
CREATE TABLE `sys_client_details` (
`id` BIGINT NOT NULL,
`access_token_validity_seconds` INT,
`authorizations` VARCHAR(50),
`auto_approve_scopes` VARCHAR(50),
`client_id` VARCHAR(50),
`client_secret` VARCHAR(50),
`grant_types` VARCHAR(50),
`redirect_url` VARCHAR(50),
`refresh_token_validity_seconds` INT,
`resource_ids` VARCHAR(50),
`scopes` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_role` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user_role` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`role_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_001331_schema') AS relationships;
