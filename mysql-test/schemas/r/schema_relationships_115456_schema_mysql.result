) CHARACTER SET latin1;
CREATE TABLE `BATCH_JOB_CONFIGURATION_PARAMETERS` (
`id` BIGINT NOT NULL,
`job_configuration_id` BIGINT,
`parameter_name` VARCHAR(50),
`parameter_value` VARCHAR(50),
`parameter_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
