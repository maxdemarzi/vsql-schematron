INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 386104_stdcust.ddl
#
CREATE DATABASE `db_386104_stdcust_ddl`;
USE `db_386104_stdcust_ddl`;
CREATE TABLE `customer` (
`CustomerId` VARCHAR(50) NOT NULL,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`MiddleName` VARCHAR(50),
`StreetAddress` VARCHAR(50),
`StreetAddress2` VARCHAR(50),
`City` VARCHAR(50),
`StateProvince` VARCHAR(50),
`PostalCode` VARCHAR(50),
`Country` VARCHAR(50),
`PhoneNumber` VARCHAR(50),
PRIMARY KEY (`CustomerId`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
`AccountID` DECIMAL(10,2) NOT NULL,
`CustomerId` VARCHAR(50),
`AccountType` VARCHAR(50),
`AccountStatus` VARCHAR(50),
`DateOpened` TIMESTAMP NULL,
`DateClosed` TIMESTAMP NULL,
PRIMARY KEY (`AccountID`)
) CHARACTER SET latin1;
CREATE TABLE `accountholdings` (
`TransactionID` VARCHAR(50) NOT NULL,
`AccountID` DECIMAL(10,2),
`ProductID` VARCHAR(50),
`PurchaseDate` TIMESTAMP NULL,
`ProductShares` DECIMAL(10,2),
PRIMARY KEY (`TransactionID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_386104_stdcust_ddl') AS relationships;
relationships
Database: db_386104_stdcust_ddl

Table Connections:
------------------
[Implied]  account.CustomerId -> customer.CustomerId
[Implied]  accountholdings.AccountID -> account.AccountID

DROP DATABASE `db_386104_stdcust_ddl`;
UNINSTALL EXTENSION vsql_schematron;
