INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 204625_database_pgsql
#
CREATE DATABASE `db_204625_database_pgsql`;
USE `db_204625_database_pgsql`;
CREATE TABLE `habitacion` (
`id_habitacion` INT NOT NULL,
`id_tipo` INT,
`nombre` VARCHAR(50),
`precio` DOUBLE,
`disponibilidad` BOOLEAN,
PRIMARY KEY (`id_habitacion`)
) CHARACTER SET latin1;
CREATE TABLE `persona` (
`id_persona` INT NOT NULL,
`cedula` VARCHAR(50),
`nombres` VARCHAR(50),
`apellidos` VARCHAR(50),
`correo` VARCHAR(50),
`telefono` VARCHAR(50),
PRIMARY KEY (`id_persona`)
) CHARACTER SET latin1;
CREATE TABLE `reservacion` (
`id_reservacion` INT NOT NULL,
`id_habitacion` INT,
`id_persona` INT,
`fecha_inicio` DATE,
`fecha_final` DATE,
`precio_total` DOUBLE,
`estado` BOOLEAN,
PRIMARY KEY (`id_reservacion`)
) CHARACTER SET latin1;
CREATE TABLE `rol` (
`id_rol` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_habitacion` (
`id_tipo` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`id_rol` INT,
`id_persona` INT,
`nombre_usuario` VARCHAR(50),
`clave` VARCHAR(50),
`imagen` VARCHAR(50),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_204625_database_pgsql') AS relationships;
relationships
Database: db_204625_database_pgsql

Table Connections:
------------------
[Implied]  habitacion.id_tipo -> tipo_habitacion.id_tipo
[Implied]  reservacion.id_habitacion -> habitacion.id_habitacion
[Implied]  reservacion.id_persona -> persona.id_persona
[Implied]  usuario.id_persona -> persona.id_persona
[Implied]  usuario.id_rol -> rol.id_rol

DROP DATABASE `db_204625_database_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
