[Implied]  SURVEY_RESPONSE.choice_id -> SURVEY_QUESTION_CHOICE.choice_id
[Implied]  SURVEY_RESPONSE.question_id -> SURVEY_QUESTION.question_id
[Implied]  SURVEY_RESPONSE.respondent_user_id -> APP_USER.user_id
[Implied]  SURVEY_RESPONSE.survey_id -> SURVEY.survey_id

DROP DATABASE `db_365519_data_model`;
UNINSTALL EXTENSION vsql_schematron;
