INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 258269_Team1SQLPresentationData_WebsiteStatistics
#
CREATE DATABASE `db_258269_Team1SQLPresentationData_WebsiteStatistics`;
USE `db_258269_Team1SQLPresentationData_WebsiteStatistics`;
CREATE TABLE `website` (
`website_id` VARCHAR(50) NOT NULL,
`website_name` VARCHAR(50),
`website_type` VARCHAR(50),
`region` VARCHAR(50),
PRIMARY KEY (`website_id`)
) CHARACTER SET latin1;
CREATE TABLE `ad_source` (
`ad_source_id` VARCHAR(50) NOT NULL,
`ad_source_name` VARCHAR(50),
`payment_partner` VARCHAR(50),
`pay_per_click` DOUBLE,
PRIMARY KEY (`ad_source_id`)
) CHARACTER SET latin1;
CREATE TABLE `pages` (
`page_id` VARCHAR(50) NOT NULL,
`category` VARCHAR(50),
`target_gender` VARCHAR(50),
`target_age` VARCHAR(50),
PRIMARY KEY (`page_id`)
) CHARACTER SET latin1;
CREATE TABLE `webstats` (
`day_date` DATE,
`website_id` VARCHAR(50),
`page_id` VARCHAR(50),
`no_users` BIGINT,
`ad_source_id` VARCHAR(50),
`ad_impressions` BIGINT,
`ad_click` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_258269_Team1SQLPresentationData_WebsiteStatistics') AS relationships;
relationships
Database: db_258269_Team1SQLPresentationData_WebsiteStatistics

Table Connections:
------------------
[Implied]  webstats.ad_source_id -> ad_source.ad_source_id
[Implied]  webstats.page_id -> pages.page_id
[Implied]  webstats.website_id -> website.website_id

DROP DATABASE `db_258269_Team1SQLPresentationData_WebsiteStatistics`;
UNINSTALL EXTENSION vsql_schematron;
