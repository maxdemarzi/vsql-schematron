INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 295111_schema
#
CREATE DATABASE `db_295111_schema`;
USE `db_295111_schema`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password_hash` VARCHAR(50),
`password_salt` VARCHAR(50),
`cookie_token` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pub` (
`id` INT,
`name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `status_update` (
`user_id` INT,
`pub_id` INT,
`timestamp` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_295111_schema') AS relationships;
