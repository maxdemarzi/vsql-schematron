CREATE DATABASE `db_563164_employee2_db`;
USE `db_563164_employee2_db`;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`id` INT NOT NULL,
`department` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`roles_id` INT,
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_563164_employee2_db') AS relationships;
