INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 592352_musique
#
CREATE DATABASE `db_592352_musique`;
USE `db_592352_musique`;
CREATE TABLE `artiste` (
`id` INT NOT NULL,
`nom` VARCHAR(50),
`est_solo` BOOLEAN,
`nombre_individus` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `maison_disque` (
`id` INT NOT NULL,
`nom` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
`id` INT NOT NULL,
`titre` VARCHAR(50),
`annee` INT,
`artiste_id` INT,
`maison_disque_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_592352_musique') AS relationships;
