INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 003050_DDL_DML_Productos
#
CREATE DATABASE `db_003050_DDL_DML_Productos`;
USE `db_003050_DDL_DML_Productos`;
CREATE TABLE `Empresa` (
`ID_Empresa` INT NOT NULL,
`Nombre` VARCHAR(50),
`NIT` VARCHAR(50),
`Fecha_Inicio` DATETIME,
`Antiguedad` INT,
PRIMARY KEY (`ID_Empresa`)
) CHARACTER SET latin1;
CREATE TABLE `Proveedor` (
`ID_Proveedor` INT NOT NULL,
`Nombre` VARCHAR(50),
`Direccion` VARCHAR(50),
`NIT` VARCHAR(50),
PRIMARY KEY (`ID_Proveedor`)
) CHARACTER SET latin1;
CREATE TABLE `Producto` (
`ID_Producto` INT NOT NULL,
`Nombre` TEXT,
`Precio_Unitario` DOUBLE,
`ID_Empresa` INT,
PRIMARY KEY (`ID_Producto`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_003050_DDL_DML_Productos') AS relationships;
