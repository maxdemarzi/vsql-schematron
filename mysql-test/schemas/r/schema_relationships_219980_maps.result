INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 219980_maps
#
CREATE DATABASE `db_219980_maps`;
USE `db_219980_maps`;
CREATE TABLE `application` (
`id` INT,
`user_id` INT,
`message` VARCHAR(50),
`city` VARCHAR(50),
`address` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(50) NOT NULL,
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`full_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_219980_maps') AS relationships;
