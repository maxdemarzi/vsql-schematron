CREATE DATABASE `db_588627_DummyQA`;
USE `db_588627_DummyQA`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`pass` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`context` VARCHAR(50),
`question_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`question_id` INT,
`comment` VARCHAR(50),
`comment_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588627_DummyQA') AS relationships;
