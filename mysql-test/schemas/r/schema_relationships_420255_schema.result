INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 420255_schema
#
CREATE DATABASE `db_420255_schema`;
USE `db_420255_schema`;
CREATE TABLE `user_t` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`key` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`session_id` VARCHAR(50) NOT NULL,
`jwt_token` VARCHAR(50),
`user_id` INT,
`created_at` TIMESTAMP NULL,
`revoked` BOOLEAN,
PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `passwords` (
`id` INT NOT NULL,
`user_id` INT,
`password` VARCHAR(50),
`category` TEXT,
`site` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `server_encryption_key` (
`server_key` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `server_auth_key` (
`auth_server_key` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_420255_schema') AS relationships;
relationships
Database: db_420255_schema

Table Connections:
------------------
[Implied]  passwords.user_id -> user_t.id
[Implied]  sessions.user_id -> user_t.id

DROP DATABASE `db_420255_schema`;
UNINSTALL EXTENSION vsql_schematron;
