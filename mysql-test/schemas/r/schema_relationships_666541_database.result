CREATE DATABASE `db_666541_database`;
USE `db_666541_database`;
CREATE TABLE `authors` (
`aut_id` INT NOT NULL,
`aut_date` TIMESTAMP NULL,
`aut_name` VARCHAR(50),
`aut_image` VARCHAR(50),
`aut_link` VARCHAR(50),
`aut_email` VARCHAR(50),
`aut_status` VARCHAR(50),
PRIMARY KEY (`aut_id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`art_id` INT NOT NULL,
`art_date` TIMESTAMP NULL,
`art_image` VARCHAR(50),
`art_title` VARCHAR(50),
`art_intro` VARCHAR(50),
`art_text` VARCHAR(50),
`art_author` INT,
`art_status` VARCHAR(50),
PRIMARY KEY (`art_id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
`id` INT NOT NULL,
`date` TIMESTAMP NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`subject` VARCHAR(50),
`message` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `config` (
`id` INT NOT NULL,
`var` VARCHAR(50),
`val` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `about` (
`abt_id` INT NOT NULL,
`abt_order` INT,
`abt_image` VARCHAR(50),
`abt_title` VARCHAR(50),
`abt_intro` VARCHAR(50),
`abt_text` VARCHAR(50),
`abt_status` VARCHAR(50),
PRIMARY KEY (`abt_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_666541_database') AS relationships;
