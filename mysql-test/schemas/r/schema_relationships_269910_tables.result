CREATE DATABASE `db_269910_tables`;
USE `db_269910_tables`;
CREATE TABLE `Destination` (
`dID` INT NOT NULL,
`Country` VARCHAR(50),
PRIMARY KEY (`dID`)
) CHARACTER SET latin1;
CREATE TABLE `Passport` (
`pID` INT NOT NULL,
`Country` VARCHAR(50),
PRIMARY KEY (`pID`)
) CHARACTER SET latin1;
CREATE TABLE `RequireDocs` (
`ID` INT NOT NULL,
`DestId` INT,
`PassId` INT,
`Cost` INT,
`Requred_Doc` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_269910_tables') AS relationships;
