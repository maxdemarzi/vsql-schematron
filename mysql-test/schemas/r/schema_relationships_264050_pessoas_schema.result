INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 264050_pessoas_schema
#
CREATE DATABASE `db_264050_pessoas_schema`;
USE `db_264050_pessoas_schema`;
CREATE TABLE `cidades` (
`id` INT NOT NULL,
`cidade` TEXT,
`uf` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pessoas` (
`id` INT NOT NULL,
`nome` TEXT,
`sobrenome` TEXT,
`email` TEXT,
`cidade_id` INT,
`criado_em` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_264050_pessoas_schema') AS relationships;
