CREATE DATABASE `db_383350_tables`;
USE `db_383350_tables`;
CREATE TABLE `Rooms` (
`id` INT NOT NULL,
`idHotel` INT,
`roomNumber` VARCHAR(50),
`maxCapacity` INT,
`rate` DOUBLE,
`phoneExtension` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Bookings` (
`id` INT NOT NULL,
`idRoom` INT,
`startDate` DATETIME,
`endDate` DATETIME,
`created` DATETIME,
`lastmodified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
