INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005528_estoque_pg
#
CREATE DATABASE `db_005528_estoque_pg`;
USE `db_005528_estoque_pg`;
CREATE TABLE `categorias` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`id` INT NOT NULL,
`nome` CHAR(50),
`cpf` CHAR(50),
`credito_liberado` CHAR(50),
`nascimento` DATE,
`email` VARCHAR(50),
`categoria_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
`unidade` CHAR(50),
`data_cadastro` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
`id` INT NOT NULL,
`cliente` INT,
`funcionario` INT,
`data_pedido` DATE,
`data_confirmacao` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedido_itens` (
`id` INT NOT NULL,
`quantidade` INT,
`preco_venda` DECIMAL(10,2),
`pedido` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005528_estoque_pg') AS relationships;
relationships
Database: db_005528_estoque_pg

Table Connections:
------------------
[Implied]  clientes.categoria_id -> categorias.id
[Implied]  pedido_itens.pedido -> pedidos.id
[Implied]  pedidos.cliente -> clientes.id

DROP DATABASE `db_005528_estoque_pg`;
UNINSTALL EXTENSION vsql_schematron;
