INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 644015_schema
#
CREATE DATABASE `db_644015_schema`;
USE `db_644015_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`department_id` INT,
`salary` DECIMAL(10,2),
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_644015_schema') AS relationships;
