CREATE DATABASE `db_209383_banque_php`;
USE `db_209383_banque_php`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`lastname` VARCHAR(50),
`firstname` VARCHAR(50),
`email` VARCHAR(50),
`city` VARCHAR(50),
`city_code` CHAR(50),
`adress` VARCHAR(50),
`sex` CHAR(50),
`password` VARCHAR(50),
`birth_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`id` VARCHAR(50) NOT NULL,
`amount` DECIMAL(10,2),
`opening_date` TIMESTAMP NULL,
`account_type` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Operation` (
`id` VARCHAR(50) NOT NULL,
`operation_type` VARCHAR(50),
`amount` DECIMAL(10,2),
`registered` TIMESTAMP NULL,
`label` VARCHAR(50),
`account_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_209383_banque_php') AS relationships;
