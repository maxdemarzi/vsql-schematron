CREATE TABLE `system_event_subscription` (
`id` INT NOT NULL,
`system_event_id` INT,
`remote_url` VARCHAR(50),
`enabled` TINYINT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `system_event_instance` (
`id` INT NOT NULL,
`system_event_id` INT,
`message` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `system_event_instance_message` (
`id` INT NOT NULL,
`system_event_instance_id` INT,
`system_event_subscription_id` INT,
`received` TINYINT,
`received_at` DATETIME,
`status_message` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
