CREATE DATABASE `db_004178_1_init`;
USE `db_004178_1_init`;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`is_parent` BOOLEAN,
`parent_id` INT,
`is_deleted` BOOLEAN,
`title` VARCHAR(50),
`text` TEXT,
`is_sage` BOOLEAN,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT NOT NULL,
`post_id` INT,
`name` VARCHAR(50),
`ext` VARCHAR(50),
`size` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_004178_1_init') AS relationships;
