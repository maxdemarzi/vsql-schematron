CREATE DATABASE `db_392793_entries_db_example`;
USE `db_392793_entries_db_example`;
CREATE TABLE `categories` (
`id` VARCHAR(50),
`name` VARCHAR(50),
`description` VARCHAR(50),
`type_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
`id` VARCHAR(50),
`title` VARCHAR(50),
`qty` DOUBLE,
`description` TEXT,
`date` DATETIME,
`receipt` VARCHAR(50),
`category_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `types` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_392793_entries_db_example') AS relationships;
