INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 471797_schema
#
CREATE DATABASE `db_471797_schema`;
USE `db_471797_schema`;
CREATE TABLE `ticket` (
`id` INT NOT NULL,
`department` TEXT,
`author_name` TEXT,
`author_email` TEXT,
`author_group` TEXT,
`claim_number` TEXT,
`created` TIMESTAMP NULL,
`resolved` TIMESTAMP NULL,
`title` TEXT,
`body` TEXT,
`response` TEXT,
`responder` TEXT,
`responder_email` TEXT,
`response_time` TIMESTAMP NULL,
`response_meeting` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`ticket_id` INT,
`author_name` TEXT,
`author_email` TEXT,
`comment` TEXT,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conversation` (
`id` INT NOT NULL,
`student_name` TEXT,
`student_email` TEXT,
`staff_name` TEXT,
`staff_email` TEXT,
`seen_by_staff` INT,
`seen_by_student` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT NOT NULL,
`conversation_id` INT,
`message` TEXT,
`created` TIMESTAMP NULL,
`author` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_471797_schema') AS relationships;
relationships
Database: db_471797_schema

