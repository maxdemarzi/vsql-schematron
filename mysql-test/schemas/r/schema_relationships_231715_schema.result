INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 231715_schema
#
CREATE DATABASE `db_231715_schema`;
USE `db_231715_schema`;
CREATE TABLE `users` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`enabled` BOOLEAN,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
`username` VARCHAR(50),
`authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `temperature_humidity` (
`id` BIGINT NOT NULL,
`humidity` VARCHAR(50),
`temp` VARCHAR(50),
`read_time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_231715_schema') AS relationships;
