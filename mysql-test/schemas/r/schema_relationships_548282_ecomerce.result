INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 548282_ecomerce
#
CREATE DATABASE `db_548282_ecomerce`;
USE `db_548282_ecomerce`;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellido` VARCHAR(50),
`email` VARCHAR(50),
`pass` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellido` VARCHAR(50),
`edad` VARCHAR(50),
`genero` VARCHAR(50),
`email` VARCHAR(50),
`pass` VARCHAR(50),
`telefono` INT,
`ciudad` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ventas` (
`id` INT NOT NULL,
`idCl` INT,
`fecha` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `productos` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`descripcion` TEXT,
`precio` DOUBLE,
`cantidad` INT,
`foto1` TEXT,
`foto2` TEXT,
`foto3` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `detalleventas` (
`id` INT NOT NULL,
`idProd` INT,
`idVenta` INT,
`cantidad` INT,
`precio` DOUBLE,
`subTotal` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_548282_ecomerce') AS relationships;
relationships
Database: db_548282_ecomerce

Table Connections:
------------------
[Implied]  detalleventas.idProd -> productos.id
[Implied]  detalleventas.idVenta -> ventas.id
[Implied]  ventas.idCl -> clientes.id

DROP DATABASE `db_548282_ecomerce`;
