CREATE DATABASE `db_023098_dbPhysic`;
USE `db_023098_dbPhysic`;
CREATE TABLE `player` (
`name` VARCHAR(50),
`email` VARCHAR(50),
`pic` VARCHAR(50),
`password` VARCHAR(50),
`nick` VARCHAR(50),
`id` INT NOT NULL,
`wins` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match` (
`date` DATE,
`status` CHAR(50),
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
`score` INT,
`id` INT NOT NULL,
`win` INT,
`fk_match_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plays` (
`fk_player_Id` INT,
`fk_team_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_023098_dbPhysic') AS relationships;
