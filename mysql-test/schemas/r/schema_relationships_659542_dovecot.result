CREATE DATABASE `db_659542_dovecot`;
USE `db_659542_dovecot`;
CREATE TABLE `alias` (
`id` INT NOT NULL,
`domain_id` INT,
`alias` VARCHAR(50),
`target` VARCHAR(50),
`enabled` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `domain` (
`id` INT NOT NULL,
`domain` VARCHAR(50),
`enabled` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`domain_id` INT,
`password` VARCHAR(50),
`user` VARCHAR(50),
`enabled` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
