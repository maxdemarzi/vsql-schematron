`user_agent` VARCHAR(50),
`url` VARCHAR(50),
`data` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_indenizacao` (
`id` INT NOT NULL,
`id_locatario` INT,
`id_mes` INT,
`descricao` VARCHAR(50),
`data` DATE,
`ano` INT,
`valor` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_perfil` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_renovacao_contrato` (
`id` INT NOT NULL,
`id_contrato` INT,
`id_status` INT,
`id_imovel` INT,
`data_inicio` DATE,
`data_fim` DATE,
`prazo` INT,
`primeiro_vencimento` DATE,
`valor` DECIMAL(10,2),
`chave` VARCHAR(50),
`numero` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_usuario` (
`id` INT NOT NULL,
`id_perfil` INT,
`nome` VARCHAR(50),
`login` VARCHAR(50),
`senha` VARCHAR(50),
`email` VARCHAR(50),
`ativo` INT,
`chave` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
