CREATE DATABASE `db_292507_create_tables`;
USE `db_292507_create_tables`;
CREATE TABLE `app.users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`email` TEXT,
`password_hash` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app.tasks` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`created_at` TIMESTAMP NULL,
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app.todos` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`is_done` BOOLEAN,
`created_at` TIMESTAMP NULL,
`task_id` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
