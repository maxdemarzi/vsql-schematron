INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 182423_000-initial
#
CREATE DATABASE `db_182423_000_initial`;
USE `db_182423_000_initial`;
CREATE TABLE `player` (
`playerid` INT NOT NULL,
`emailaddress` VARCHAR(50),
`player_name` VARCHAR(50),
`losses` INT,
`wins` INT,
PRIMARY KEY (`playerid`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
`gameid` INT NOT NULL,
`playera_id` INT,
`playerb_id` INT,
`playerc_id` INT,
`playerd_id` INT,
`gamedate` TIMESTAMP NULL,
`postedby` VARCHAR(50),
`teamabscore` INT,
`teamcdscore` INT,
PRIMARY KEY (`gameid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_182423_000_initial') AS relationships;
