CREATE DATABASE `db_672320_populator`;
USE `db_672320_populator`;
CREATE TABLE `db.roles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.moderators` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`role_id` INT,
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.subjects` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_by` VARCHAR(50),
`updated_by` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.tags` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_by` VARCHAR(50),
`updated_by` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.comments` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`content` VARCHAR(50),
`post_id` INT,
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
