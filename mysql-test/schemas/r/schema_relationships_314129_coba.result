CREATE DATABASE `db_314129_coba`;
USE `db_314129_coba`;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`deskripsi` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `urls` (
`hash` VARCHAR(50),
`title` VARCHAR(50),
`original_link` VARCHAR(50),
`total_clicked` VARCHAR(50),
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `urls_guest` (
`hash` VARCHAR(50),
`title` VARCHAR(50),
`original_link` VARCHAR(50),
`total_clicked` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`role_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_314129_coba') AS relationships;
