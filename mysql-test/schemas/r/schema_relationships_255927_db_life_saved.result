CREATE DATABASE `db_255927_db_life_saved`;
USE `db_255927_db_life_saved`;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`nome` VARCHAR(50),
`senha` CHAR(50),
`email` VARCHAR(50),
`cpf` CHAR(50),
`telefone` VARCHAR(50),
`sexo` CHAR(50),
`foto` VARCHAR(50),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `clinica` (
`id_clinica` INT NOT NULL,
`id_usuario` INT,
`nome` VARCHAR(50),
`senha` CHAR(50),
`email` VARCHAR(50),
`cnpj` CHAR(50),
`estado` CHAR(50),
`telefone` VARCHAR(50),
`descricao` TEXT,
PRIMARY KEY (`id_clinica`)
) CHARACTER SET latin1;
CREATE TABLE `contato` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`mensagem` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estados` (
`id_estado` INT,
`nome` VARCHAR(50),
`sigla` CHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_255927_db_life_saved') AS relationships;
