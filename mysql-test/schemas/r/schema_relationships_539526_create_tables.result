CREATE DATABASE `db_539526_create_tables`;
USE `db_539526_create_tables`;
CREATE TABLE `Login` (
`username` VARCHAR(50),
`password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Runway` (
`run_no` INT NOT NULL,
`status` VARCHAR(50),
`Time` TIME,
PRIMARY KEY (`run_no`)
) CHARACTER SET latin1;
CREATE TABLE `Route` (
`r_no` INT NOT NULL,
`status` VARCHAR(50),
PRIMARY KEY (`r_no`)
) CHARACTER SET latin1;
CREATE TABLE `Hangar` (
`p_no` INT NOT NULL,
`status` VARCHAR(50),
`Time` TIME,
PRIMARY KEY (`p_no`)
) CHARACTER SET latin1;
CREATE TABLE `FlightAir` (
`f_no` VARCHAR(50) NOT NULL,
`p_no` INT,
`r_no` INT,
`run_no` INT,
`landing` TIME,
`leaving` TIME,
`arrival` TIME,
`duration` TIME,
`departure` TIME,
PRIMARY KEY (`f_no`)
) CHARACTER SET latin1;
CREATE TABLE `Schedule` (
`Time` TIME NOT NULL,
`f_no` VARCHAR(50) NOT NULL,
`task` VARCHAR(50),
PRIMARY KEY (`Time`, `f_no`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_539526_create_tables') AS relationships;
