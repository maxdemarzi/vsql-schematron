[Implied]  libros.idCategoria -> categorias.idCategoria
[Implied]  libros.idEditorial -> editoriales.idEditorial
[Implied]  prestamos.idAlumno -> alumnos.idAlumno
[Implied]  prestamos.idLibro -> libros.idLibro
[Implied]  prestamos.idUsuario -> usuarios.idUsuario
[Implied]  relacion_autoria.idAutor -> autores.idAutor
[Implied]  relacion_autoria.idLibro -> libros.idLibro

DROP DATABASE `db_634785_bd_biblioteca`;
UNINSTALL EXTENSION vsql_schematron;
