INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 558251_demo
#
CREATE DATABASE `db_558251_demo`;
USE `db_558251_demo`;
CREATE TABLE `sys_user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_role` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user_role` (
`user_id` INT NOT NULL,
`role_id` INT NOT NULL,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `persistent_logins` (
`username` VARCHAR(50),
`series` VARCHAR(50) NOT NULL,
`token` VARCHAR(50),
`last_used` TIMESTAMP NULL,
PRIMARY KEY (`series`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_558251_demo') AS relationships;
relationships
