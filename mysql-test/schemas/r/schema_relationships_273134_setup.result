INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 273134_setup
#
CREATE DATABASE `db_273134_setup`;
USE `db_273134_setup`;
CREATE TABLE `image` (
`id` VARCHAR(50) NOT NULL,
`file_ext` VARCHAR(50),
`title` VARCHAR(50),
`source` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`edited_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag_category` (
`slug` VARCHAR(50) NOT NULL,
`color` CHAR(50),
PRIMARY KEY (`slug`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`slug` VARCHAR(50) NOT NULL,
`category` VARCHAR(50),
PRIMARY KEY (`slug`)
) CHARACTER SET latin1;
CREATE TABLE `image_tag` (
`image_id` VARCHAR(50) NOT NULL,
`tag` VARCHAR(50) NOT NULL,
PRIMARY KEY (`image_id`, `tag`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_273134_setup') AS relationships;
