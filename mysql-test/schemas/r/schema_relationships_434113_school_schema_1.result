INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 434113_school_schema_1
#
CREATE DATABASE `db_434113_school_schema_1`;
USE `db_434113_school_schema_1`;
CREATE TABLE `seminar` (
`id` INT NOT NULL,
`location` TEXT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`id` INT NOT NULL,
`location` TEXT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `seminar_2_student` (
`id` INT NOT NULL,
`seminar_id` INT,
`student_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `professor` (
`id` INT NOT NULL,
`birth_date` TEXT,
`name` TEXT,
`surname` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_434113_school_schema_1') AS relationships;
relationships
