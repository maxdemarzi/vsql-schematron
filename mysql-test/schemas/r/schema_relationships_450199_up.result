INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 450199_up
#
CREATE DATABASE `db_450199_up`;
USE `db_450199_up`;
CREATE TABLE `author` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `author_book` (
`id` INT NOT NULL,
`author_id` INT,
`book_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_450199_up') AS relationships;
relationships
