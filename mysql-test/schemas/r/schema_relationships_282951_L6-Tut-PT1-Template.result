INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 282951_L6-Tut-PT1-Template
#
CREATE DATABASE `db_282951_L6_Tut_PT1_Template`;
USE `db_282951_L6_Tut_PT1_Template`;
CREATE TABLE `product` (
`product_id` DECIMAL(10,2) NOT NULL,
`product_name` VARCHAR(50),
`supplier_name` VARCHAR(50),
`unit_price` DECIMAL(10,2),
`units` DECIMAL(10,2),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`customer_id` DECIMAL(10,2) NOT NULL,
`customer_name` VARCHAR(50),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
`order_id` DECIMAL(10,2) NOT NULL,
`product_id` DECIMAL(10,2),
`units` DECIMAL(10,2),
`customer` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_282951_L6_Tut_PT1_Template') AS relationships;
relationships
Database: db_282951_L6_Tut_PT1_Template

Table Connections:
------------------
[Implied]  order_item.customer -> customer.customer_id
[Implied]  order_item.product_id -> product.product_id

DROP DATABASE `db_282951_L6_Tut_PT1_Template`;
