INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 529661_schema
#
CREATE DATABASE `db_529661_schema`;
USE `db_529661_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`pass` VARCHAR(50),
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `userProfile` (
`user_id` INT,
`userResult` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `quiz` (
`id` INT NOT NULL,
`user_id` INT,
`question` TEXT,
`optionA` TEXT,
`optionB` TEXT,
`optionC` TEXT,
`optionD` TEXT,
`correctAnswer` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_529661_schema') AS relationships;
relationships
Database: db_529661_schema

Table Connections:
------------------
[Implied]  quiz.user_id -> users.id
[Implied]  userProfile.user_id -> users.id

DROP DATABASE `db_529661_schema`;
UNINSTALL EXTENSION vsql_schematron;
