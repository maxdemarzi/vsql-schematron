INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 609411_schema-mysql
#
CREATE DATABASE `db_609411_schema_mysql`;
USE `db_609411_schema_mysql`;
CREATE TABLE `author` (
`id` BIGINT NOT NULL,
`age` INT,
`genre` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` BIGINT NOT NULL,
`isbn` VARCHAR(50),
`title` VARCHAR(50),
`author_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_609411_schema_mysql') AS relationships;
