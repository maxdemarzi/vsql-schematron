CREATE TABLE `course` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
`teacher` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course_date` (
`id` INT NOT NULL,
`course_id` INT,
`begin` DATETIME,
`end` DATETIME,
`amount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
