INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 485205_db.Schema
#
CREATE DATABASE `db_485205_db_Schema`;
USE `db_485205_db_Schema`;
CREATE TABLE `barber` (
`id` INT NOT NULL,
`user_name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`city` VARCHAR(50),
`address` VARCHAR(50),
`gender` VARCHAR(50),
`age` INT,
`shop_gender` VARCHAR(50),
`shop_name` VARCHAR(50),
`phone_num` VARCHAR(50),
`profile_pic` VARCHAR(50),
`working_hours` VARCHAR(50),
`holidays` VARCHAR(50),
`state` VARCHAR(50),
`verification_token` VARCHAR(50),
`verified` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT NOT NULL,
`user_name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`city` VARCHAR(50),
`gender` VARCHAR(50),
`age` INT,
`phone_num` VARCHAR(50),
`profile_pic` VARCHAR(50),
`verification_token` VARCHAR(50),
`verified` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `services` (
`id` INT NOT NULL,
`barber_id` INT,
`service_name` VARCHAR(50),
`description` VARCHAR(50),
`price` INT,
`discount` INT,
`end_date` DATE,
`estimated_time` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`barber_id` INT,
`product_name` VARCHAR(50),
`description` VARCHAR(50),
`price` INT,
`discount` INT,
`end_date` DATE,
`product_image` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media` (
`id` INT NOT NULL,
`barber_id` INT,
`media_type` VARCHAR(50),
`media_path` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subscriptions` (
`id` INT NOT NULL,
`barber_id` INT,
`client_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
`id` INT NOT NULL,
`barber_id` INT,
`client_id` INT,
`service_id` INT,
`time` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queue` (
`id` INT NOT NULL,
`barber_id` INT,
`client_id` INT,
`service_id` INT,
`time` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT NOT NULL,
`barber_id` INT,
`client_id` INT,
`description` VARCHAR(50),
`date` TIMESTAMP NULL,
`rate` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_485205_db_Schema') AS relationships;
relationships
