CREATE DATABASE `db_013830_create`;
USE `db_013830_create`;
CREATE TABLE `position` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
`id` INT NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`position_id` INT,
`start_date` DATE,
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skill` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_skill` (
`profile_id` INT,
`skill_id` INT,
`score` INT
) CHARACTER SET latin1;
CREATE TABLE `characteristic` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_characteristic` (
`profile_id` INT,
`characteristic_id` INT
) CHARACTER SET latin1;
CREATE TABLE `meeting` (
`id` INT NOT NULL,
`profile_id` INT,
`meeting_date` DATETIME,
`content` TEXT,
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_013830_create') AS relationships;
