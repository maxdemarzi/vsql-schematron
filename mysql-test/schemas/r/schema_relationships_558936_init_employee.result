) CHARACTER SET latin1;
CREATE TABLE `address` (
`address_id` INT NOT NULL,
`city` VARCHAR(50),
`state` VARCHAR(50),
`country` VARCHAR(50),
`employee_id` INT,
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
