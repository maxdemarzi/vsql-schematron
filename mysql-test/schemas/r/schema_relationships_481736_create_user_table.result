`last_name` VARCHAR(50),
`birth_date` DATE,
`address` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`zip_code` VARCHAR(50),
`phone_number` VARCHAR(50),
`biography` TEXT,
`url` VARCHAR(50),
`profession` VARCHAR(50)
) CHARACTER SET latin1;
