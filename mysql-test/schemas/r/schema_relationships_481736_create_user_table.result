CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`created_on` TIMESTAMP NULL,
`last_modified` TIMESTAMP NULL,
`last_login` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_profiles` (
`user_id` VARCHAR(50),
