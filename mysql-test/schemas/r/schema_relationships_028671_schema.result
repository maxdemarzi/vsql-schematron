INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 028671_schema
#
CREATE DATABASE `db_028671_schema`;
USE `db_028671_schema`;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categorias` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
`cor` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tarefas` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
`data` DATETIME,
`realizado` BOOLEAN,
`categoria_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_028671_schema') AS relationships;
