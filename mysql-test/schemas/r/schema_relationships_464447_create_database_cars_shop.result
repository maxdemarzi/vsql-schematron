INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 464447_create_database_cars_shop
#
CREATE DATABASE `db_464447_create_database_cars_shop`;
USE `db_464447_create_database_cars_shop`;
CREATE TABLE `marks` (
`id` INT NOT NULL,
`mark` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT NOT NULL,
`mark_id` INT,
`model` VARCHAR(50),
`price` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`age` INT,
`phone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`car_id` INT,
`client_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_464447_create_database_cars_shop') AS relationships;
