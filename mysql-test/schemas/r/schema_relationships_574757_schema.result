CREATE TABLE `awsfederation.account` (
`id` VARCHAR(50) NOT NULL,
`email` VARCHAR(50),
`name` VARCHAR(50),
`accountType_id` INT,
`accountStatus_id` INT,
`federationUser_arn` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
