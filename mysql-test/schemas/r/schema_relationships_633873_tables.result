INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 633873_tables
#
CREATE DATABASE `db_633873_tables`;
USE `db_633873_tables`;
CREATE TABLE `repositories` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `repositories_contributors` (
`repository_id` INT,
`contributor_id` INT
) CHARACTER SET latin1;
CREATE TABLE `issues` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`issue_status` VARCHAR(50),
`repository_id` INT,
`assignee_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `commits` (
`id` INT NOT NULL,
`message` VARCHAR(50),
`issue_id` INT,
`repository_id` INT,
`contributor_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`size` DECIMAL(10,2),
`parent_id` INT,
`commit_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_633873_tables') AS relationships;
relationships
Database: db_633873_tables

Table Connections:
