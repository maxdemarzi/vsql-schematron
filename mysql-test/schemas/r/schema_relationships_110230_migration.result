CREATE DATABASE `db_110230_migration`;
USE `db_110230_migration`;
CREATE TABLE `Menu` (
`id` VARCHAR(50) NOT NULL,
`restaurantId` TEXT,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`price` DOUBLE,
`description` TEXT,
`menuId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_110230_migration') AS relationships;
