INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 157748_digitalstore
#
CREATE DATABASE `db_157748_digitalstore`;
USE `db_157748_digitalstore`;
CREATE TABLE `detail_transaksi` (
`kode_detail_transaksi` INT,
`kode_transaksi` INT,
`kode_kamera` INT,
`jumlah` INT
) CHARACTER SET latin1;
CREATE TABLE `kamera` (
`kode_kamera` INT,
`nama_kamera` VARCHAR(50),
`deskripsi` VARCHAR(50),
`kode_kategori` INT,
`harga` INT,
`foto` VARCHAR(50),
`stok` INT
) CHARACTER SET latin1;
CREATE TABLE `kategori` (
`kode_kategori` INT NOT NULL,
`nama_kategori` VARCHAR(50),
PRIMARY KEY (`kode_kategori`)
) CHARACTER SET latin1;
CREATE TABLE `transaksi` (
`kode_transaksi` INT,
`kode_user` INT,
`nama_pembeli` VARCHAR(50),
`total` INT,
`tanggal_beli` DATE
) CHARACTER SET latin1;
CREATE TABLE `user` (
`kode_user` INT NOT NULL,
`nama_user` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`level` VARCHAR(50),
PRIMARY KEY (`kode_user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_157748_digitalstore') AS relationships;
relationships
Database: db_157748_digitalstore

Table Connections:
------------------
[Implied]  kamera.kode_kategori -> kategori.kode_kategori
[Implied]  transaksi.kode_user -> user.kode_user

DROP DATABASE `db_157748_digitalstore`;
UNINSTALL EXTENSION vsql_schematron;
