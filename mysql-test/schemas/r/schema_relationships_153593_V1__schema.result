[Implied]  WATCH_LIST_ITEMS.ITEMS_ID -> ITEM.ID
[Implied]  WATCH_LIST_ITEMS.WATCH_LISTS_ID -> WATCH_LIST.ID

DROP DATABASE `db_153593_V1__schema`;
UNINSTALL EXTENSION vsql_schematron;
