INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 588323_provinces.cities.areas
#
CREATE DATABASE `db_588323_provinces_cities_areas`;
USE `db_588323_provinces_cities_areas`;
CREATE TABLE `provinces` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
`id` VARCHAR(50) NOT NULL,
`province_id` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `areas` (
`id` VARCHAR(50) NOT NULL,
`city_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`, `city_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588323_provinces_cities_areas') AS relationships;
relationships
Database: db_588323_provinces_cities_areas

Table Connections:
