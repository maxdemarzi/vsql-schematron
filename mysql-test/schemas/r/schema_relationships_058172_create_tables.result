CREATE DATABASE `db_058172_create_tables`;
USE `db_058172_create_tables`;
CREATE TABLE `Student` (
`snum` INT NOT NULL,
`sname` VARCHAR(50),
`major` VARCHAR(50),
`slevel` VARCHAR(50),
`age` INT,
PRIMARY KEY (`snum`)
) CHARACTER SET latin1;
CREATE TABLE `Faculty` (
`fid` INT NOT NULL,
`fname` VARCHAR(50),
`deptid` INT,
PRIMARY KEY (`fid`)
) CHARACTER SET latin1;
CREATE TABLE `Class` (
`cname` VARCHAR(50) NOT NULL,
`meets_at` VARCHAR(50),
`room` VARCHAR(50),
`fid` INT,
PRIMARY KEY (`cname`)
) CHARACTER SET latin1;
CREATE TABLE `Enrolled` (
`snum` INT,
`cname` VARCHAR(50)
) CHARACTER SET latin1;
