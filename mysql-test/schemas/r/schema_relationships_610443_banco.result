INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 610443_banco
#
CREATE DATABASE `db_610443_banco`;
USE `db_610443_banco`;
CREATE TABLE `aluno` (
`idaluno` INT NOT NULL,
`matricula` VARCHAR(50),
`nome` VARCHAR(50),
`telefone` VARCHAR(50),
`sexo` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`idaluno`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
`idendereco` INT NOT NULL,
`endereco` VARCHAR(50),
`bairro` VARCHAR(50),
`cep` VARCHAR(50),
`cidade` VARCHAR(50),
`estado` VARCHAR(50),
`idaluno` INT,
PRIMARY KEY (`idendereco`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_610443_banco') AS relationships;
relationships
