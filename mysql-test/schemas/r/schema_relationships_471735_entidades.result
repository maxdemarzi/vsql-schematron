`ds_uf` VARCHAR(50),
`ds_cidade` VARCHAR(50),
PRIMARY KEY (`cd_endereco`)
) CHARACTER SET latin1;
CREATE TABLE `t_funcionario` (
`cd_funcionario` INT NOT NULL,
`nm_funcionario` VARCHAR(50),
`nr_cargo` INT,
`ds_senha` VARCHAR(50),
PRIMARY KEY (`cd_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `t_pedido` (
`cd_pedido` INT NOT NULL,
`t_produto_cd_produto` INT,
`t_cliente_cd_cliente` INT,
`dt_pedido` DATE,
PRIMARY KEY (`cd_pedido`)
) CHARACTER SET latin1;
CREATE TABLE `t_produto` (
`cd_produto` INT NOT NULL,
`nm_produto` VARCHAR(50),
`vl_unitario` DECIMAL(10,2),
`ds_tipo` VARCHAR(50),
`qt_produto` INT,
`dt_insercao` DATE,
PRIMARY KEY (`cd_produto`)
) CHARACTER SET latin1;
CREATE TABLE `t_telefone` (
`cd_telefone` INT NOT NULL,
`nr_ddd` VARCHAR(50),
`nr_telefone` VARCHAR(50),
`t_cliente_cd_cliente` INT,
PRIMARY KEY (`cd_telefone`)
) CHARACTER SET latin1;
