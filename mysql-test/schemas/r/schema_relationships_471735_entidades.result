CREATE DATABASE `db_471735_entidades`;
USE `db_471735_entidades`;
CREATE TABLE `t_endereco` (
`cd_endereco` INT NOT NULL,
`ds_endereco` VARCHAR(50),
`nr_cep` INT,
`nr_endereco` INT,
`ds_complemento` VARCHAR(50),
