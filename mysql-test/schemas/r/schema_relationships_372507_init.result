INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 372507_init
#
CREATE DATABASE `db_372507_init`;
USE `db_372507_init`;
CREATE TABLE `Restos` (
`id` INT NOT NULL,
`rname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tables` (
`id` INT NOT NULL,
`resto_id` INT,
`max_people` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Bookings` (
`id` INT NOT NULL,
`resto_id` INT,
`table_id` INT,
`client_name` VARCHAR(50),
`client_id` VARCHAR(50),
`bdate` VARCHAR(50),
`btime` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_372507_init') AS relationships;
