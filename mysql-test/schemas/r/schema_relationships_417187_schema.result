CREATE DATABASE `db_417187_schema`;
USE `db_417187_schema`;
CREATE TABLE `author` (
`id` INT NOT NULL,
`fullname` VARCHAR(50),
`photo` VARCHAR(50),
`description` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
`content` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`author_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
