CREATE DATABASE `db_080308_lib_model_schema`;
USE `db_080308_lib_model_schema`;
CREATE TABLE `author` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`is_alive` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`author_id` INT,
`title` VARCHAR(50),
`year` INT,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
