CREATE DATABASE `db_173474_create_database`;
USE `db_173474_create_database`;
CREATE TABLE `locations` (
`location_id` VARCHAR(50) NOT NULL,
`city` VARCHAR(50),
`state` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_data` (
`location_id` VARCHAR(50) NOT NULL,
`day` INT NOT NULL,
`description` VARCHAR(50),
`high_temp` DOUBLE,
`low_temp` DOUBLE,
`humidity` INT,
PRIMARY KEY (`day`, `location_id`)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
`log_id` INT NOT NULL,
`ip` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
PRIMARY KEY (`log_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_173474_create_database') AS relationships;
