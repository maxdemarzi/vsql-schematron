INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 334322_schema
#
CREATE DATABASE `db_334322_schema`;
USE `db_334322_schema`;
CREATE TABLE `posts` (
`post_id` INT NOT NULL,
`title` VARCHAR(50),
`username` VARCHAR(50),
`membership` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`message` TEXT,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `attachments` (
`attachment_id` INT NOT NULL,
`post_id` INT,
`file` VARCHAR(50),
`name` VARCHAR(50),
`size` INT,
`type` VARCHAR(50),
PRIMARY KEY (`attachment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_334322_schema') AS relationships;
