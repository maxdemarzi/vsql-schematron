INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 506576_001-initial
#
CREATE DATABASE `db_506576_001_initial`;
USE `db_506576_001_initial`;
CREATE TABLE `Setting` (
`id` INT NOT NULL,
`name` TEXT,
`value` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
`id` INT NOT NULL,
`seriesName` TEXT,
`seriesId` INT,
`created` INT,
`price` INT,
`buyer` TEXT,
`seller` TEXT,
`issuer` TEXT,
`extra` TEXT,
`flags` INT,
`pdfname` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LineItem` (
`id` INT NOT NULL,
`name` TEXT,
`unit` TEXT,
`amount` INT,
`price` INT,
`invoiceId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_506576_001_initial') AS relationships;
