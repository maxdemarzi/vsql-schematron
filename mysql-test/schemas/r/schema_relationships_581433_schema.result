INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 581433_schema
#
CREATE DATABASE `db_581433_schema`;
USE `db_581433_schema`;
CREATE TABLE `chat_log` (
`id` INT NOT NULL,
`timestamp` INT,
`user` TEXT,
`message` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tracks` (
`id` INT NOT NULL,
`title` TEXT,
`path` TEXT,
`artist` TEXT,
`album` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vetoes` (
`id` INT NOT NULL,
`timestamp` INT,
`user` TEXT,
`track_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `requests` (
`id` INT NOT NULL,
`timestamp` INT,
`user` TEXT,
`track_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_581433_schema') AS relationships;
