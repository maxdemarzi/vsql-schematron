INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606812_petclinic_db
--echo #
CREATE DATABASE `db_606812_petclinic_db`;
USE `db_606812_petclinic_db`;
CREATE TABLE `owners` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `telephone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `birth_date` DATE,
  `type_id` VARCHAR(50),
  `owner_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialties` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `types` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `vets` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
  `id` VARCHAR(50) NOT NULL,
  `pet_id` VARCHAR(50),
  `visit_date` DATE,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606812_petclinic_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606812_petclinic_db') AS relationships;
DROP DATABASE `db_606812_petclinic_db`;
UNINSTALL EXTENSION vsql_schematron;
