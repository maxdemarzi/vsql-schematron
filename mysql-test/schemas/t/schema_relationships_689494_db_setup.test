INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 689494_db_setup
--echo #
CREATE DATABASE `db_689494_db_setup`;
USE `db_689494_db_setup`;
CREATE TABLE `Countries` (
  `country_id` INT NOT NULL,
  `country_code` INT,
  `country_name` VARCHAR(50),
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `Contacts` (
  `contact_id` INT NOT NULL,
  `contact_firstname` VARCHAR(50),
  `contact_lastname` VARCHAR(50),
  `contact_birthdate` DATE,
  `contact_register_date` TIMESTAMP NULL,
  `contact_last_modified` TIMESTAMP NULL,
  PRIMARY KEY (`contact_id`)
) CHARACTER SET latin1;
CREATE TABLE `Phones` (
  `phone_id` INT NOT NULL,
  `phone_label` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `phone_country` INT,
  `phone_contact` INT,
  PRIMARY KEY (`phone_id`)
) CHARACTER SET latin1;
CREATE TABLE `Emails` (
  `email_id` INT NOT NULL,
  `email_label` VARCHAR(50),
  `email_address` VARCHAR(50),
  `email_contact` INT,
  PRIMARY KEY (`email_id`)
) CHARACTER SET latin1;
CREATE TABLE `URLs` (
  `url_id` INT NOT NULL,
  `url_label` VARCHAR(50),
  `url_address` VARCHAR(50),
  `url_contact` INT,
  PRIMARY KEY (`url_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_689494_db_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_689494_db_setup') AS relationships;
DROP DATABASE `db_689494_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
