INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220995_create_db
--echo #
CREATE DATABASE `db_220995_create_db`;
USE `db_220995_create_db`;
CREATE TABLE `employee` (
  `employee_id` INT NOT NULL,
  `employee_name` VARCHAR(50),
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
  `company_id` INT NOT NULL,
  `company_name` VARCHAR(50),
  PRIMARY KEY (`company_id`)
) CHARACTER SET latin1;
CREATE TABLE `company_employee` (
  `employee_id` INT NOT NULL,
  `company_id` INT NOT NULL,
  PRIMARY KEY (`employee_id`, `company_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220995_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220995_create_db') AS relationships;
DROP DATABASE `db_220995_create_db`;
UNINSTALL EXTENSION vsql_schematron;
