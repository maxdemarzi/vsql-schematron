INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 468436_migration
--echo #
CREATE DATABASE `db_468436_migration`;
USE `db_468436_migration`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` TEXT,
  `first_name` TEXT,
  `last_name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `text` TEXT,
  `time` TIMESTAMP NULL,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_468436_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_468436_migration') AS relationships;
DROP DATABASE `db_468436_migration`;
UNINSTALL EXTENSION vsql_schematron;
