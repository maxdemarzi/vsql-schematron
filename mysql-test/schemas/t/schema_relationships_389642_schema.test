INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 389642_schema
--echo #
CREATE DATABASE `db_389642_schema`;
USE `db_389642_schema`;
CREATE TABLE `SENSORS` (
  `Id` INT NOT NULL,
  `Unit` TEXT,
  `Description` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `DATA` (
  `Id` INT NOT NULL,
  `Epoch` INT,
  `Value` DOUBLE,
  `Sensor` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_389642_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_389642_schema') AS relationships;
DROP DATABASE `db_389642_schema`;
UNINSTALL EXTENSION vsql_schematron;
