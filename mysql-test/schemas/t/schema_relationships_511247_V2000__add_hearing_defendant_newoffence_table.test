CREATE DATABASE `db_511247_V2000__add_hearing_defendant_newoffence_table`;
USE `db_511247_V2000__add_hearing_defendant_newoffence_table`;
CREATE TABLE `HEARING` (
  `ID` INT NOT NULL,
  `COURT_CASE_ID` INT,
  `HEARING_DAY` DATE,
  `HEARING_TIME` TIME,
  `COURT_CODE` TEXT,
  `COURT_ROOM` TEXT,
  `LIST_NO` TEXT,
  `CREATED` TIMESTAMP NULL,
  `CREATED_BY` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEFENDANT` (
  `ID` INT NOT NULL,
  `COURT_CASE_ID` INT,
  `DEFENDANT_NAME` TEXT,
  `TYPE` TEXT,
  `NAME` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  `CRN` TEXT,
  `PNC` TEXT,
  `CRO` TEXT,
  `DATE_OF_BIRTH` DATE,
  `SEX` TEXT,
  `NATIONALITY_1` TEXT,
  `NATIONALITY_2` TEXT,
  `CREATED` TIMESTAMP NULL,
  `CREATED_BY` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEFENDANT_OFFENCE` (
  `ID` INT NOT NULL,
  `DEFENDANT_ID` INT,
  `SUMMARY` TEXT,
  `TITLE` TEXT,
  `SEQUENCE` INT,
  `ACT` TEXT,
  `CREATED` TIMESTAMP NULL,
  `CREATED_BY` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
