INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204940_01-setup-tables
--echo #
CREATE DATABASE `db_204940_01_setup_tables`;
USE `db_204940_01_setup_tables`;
CREATE TABLE `regions` (
  `region_id` INT NOT NULL,
  `region_name` CHAR(50),
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `country_id` VARCHAR(50) NOT NULL,
  `country_name` CHAR(50),
  `region_id` INT,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `location_id` INT NOT NULL,
  `street_address` CHAR(50),
  `postal_code` CHAR(50),
  `city` CHAR(50),
  `state_province` CHAR(50),
  `country_id` CHAR(50),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `ctl.esquemas_tablas_databricks` (
  `nombre_tabla` CHAR(50),
  `ddl` CHAR(50),
  `columnas_particion` CHAR(50),
  `columnas_zorder` CHAR(50),
  `ruta_wasb_destino` CHAR(50),
  `separador_columna` CHAR(50),
  `archivo_contiene_header` BOOLEAN,
  `codificacion_archivo` CHAR(50),
  `formato_destino` CHAR(50),
  `modo_escritura` CHAR(50),
  `idsubsistemaorigen` INT,
  `columnas_particion_calculadas` CHAR(50),
  `nombre_bd_parquet` CHAR(50),
  `aplicar_optimizer` BOOLEAN
) CHARACTER SET latin1;
CREATE TABLE `ctl.log_csvparquet` (
  `id` INT,
  `aplicativo` CHAR(50),
  `insercion` TEXT,
  `nivel` CHAR(50),
  `mensaje` TEXT,
  `origen` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204940_01_setup_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204940_01_setup_tables') AS relationships;
DROP DATABASE `db_204940_01_setup_tables`;
UNINSTALL EXTENSION vsql_schematron;
