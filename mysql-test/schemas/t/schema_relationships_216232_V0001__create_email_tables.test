INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 216232_V0001__create_email_tables
--echo #
CREATE DATABASE `db_216232_V0001__create_email_tables`;
USE `db_216232_V0001__create_email_tables`;
CREATE TABLE `email` (
  `id` VARCHAR(50) NOT NULL,
  `message` VARCHAR(50),
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `email_recipients` (
  `email_id` VARCHAR(50),
  `recipients` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `attachment` (
  `filename` VARCHAR(50),
  `data` VARCHAR(50),
  `email_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_216232_V0001__create_email_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_216232_V0001__create_email_tables') AS relationships;
DROP DATABASE `db_216232_V0001__create_email_tables`;
UNINSTALL EXTENSION vsql_schematron;
