INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 489862_schema
--echo #
CREATE DATABASE `db_489862_schema`;
USE `db_489862_schema`;
CREATE TABLE `runs` (
  `id` INT NOT NULL,
  `createdAt` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `violations` (
  `id` INT NOT NULL,
  `resource_id` TEXT,
  `resource_type` TEXT,
  `run_id` INT,
  `rule_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_489862_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489862_schema') AS relationships;
DROP DATABASE `db_489862_schema`;
UNINSTALL EXTENSION vsql_schematron;
