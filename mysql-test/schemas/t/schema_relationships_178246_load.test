INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178246_load
--echo #
CREATE DATABASE `db_178246_load`;
USE `db_178246_load`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `email_address` TEXT,
  `first_name` TEXT,
  `last_name` TEXT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178246_load') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178246_load') AS relationships;
DROP DATABASE `db_178246_load`;
UNINSTALL EXTENSION vsql_schematron;
