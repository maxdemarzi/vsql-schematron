INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 639541_mysql_schema
--echo #
CREATE DATABASE `db_639541_mysql_schema`;
USE `db_639541_mysql_schema`;
CREATE TABLE `authors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `name_hash` CHAR(50),
  `image_path` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `name_hash` CHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
  `id` INT NOT NULL,
  `text` TEXT,
  `text_hash` CHAR(50),
  `author_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quote_tag_assoc` (
  `id` INT NOT NULL,
  `quote_id` INT,
  `tag_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_639541_mysql_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_639541_mysql_schema') AS relationships;
DROP DATABASE `db_639541_mysql_schema`;
UNINSTALL EXTENSION vsql_schematron;
