INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 109372_Queries
--echo #
CREATE DATABASE `db_109372_Queries`;
USE `db_109372_Queries`;
CREATE TABLE `testTbl` (
  `id` INT,
  `name` VARCHAR(50),
  `dob` DATE
) CHARACTER SET latin1;
CREATE TABLE `notnulltest` (
  `id` INT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `uniquetest` (
  `id` INT,
  `name` VARCHAR(50),
  `email` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `pktest` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `OrderId` INT NOT NULL,
  `OrderNumber` INT,
  `CustomerId` INT,
  PRIMARY KEY (`OrderId`)
) CHARACTER SET latin1;
CREATE TABLE `checktable` (
  `id` INT,
  `name` VARCHAR(50),
  `age` INT
) CHARACTER SET latin1;
CREATE TABLE `usertbl` (
  `userid` INT NOT NULL,
  `username` VARCHAR(50),
  `useremail` VARCHAR(50),
  `usercity` VARCHAR(50),
  `createdate` DATETIME,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `autotbltest` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Salaries` (
  `employeeNumber` INT NOT NULL,
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`employeeNumber`)
) CHARACTER SET latin1;
CREATE TABLE `SalaryBudgets` (
  `total` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_109372_Queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_109372_Queries') AS relationships;
DROP DATABASE `db_109372_Queries`;
UNINSTALL EXTENSION vsql_schematron;
