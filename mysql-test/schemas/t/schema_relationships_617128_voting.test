INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617128_voting
--echo #
CREATE DATABASE `db_617128_voting`;
USE `db_617128_voting`;
CREATE TABLE `surveys` (
  `survey_id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  `start_time` DATETIME,
  `end_time` DATETIME,
  `access_key` CHAR(50),
  `group_id` INT,
  `public` BOOLEAN,
  `results_shown` BOOLEAN,
  `creator` INT,
  PRIMARY KEY (`survey_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_question_types` (
  `type_id` INT NOT NULL,
  `type_name` VARCHAR(50),
  `choices` BOOLEAN,
  PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_questions` (
  `question_id` INT NOT NULL,
  `survey_id` INT,
  `title` VARCHAR(50),
  `description` TEXT,
  `list_order` INT,
  `type_id` INT,
  PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_question_choices` (
  `choice_id` INT NOT NULL,
  `question_id` INT,
  `choice` VARCHAR(50),
  PRIMARY KEY (`choice_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_responses` (
  `response_id` INT NOT NULL,
  `question_id` INT,
  `user_id` INT,
  `response` TEXT,
  PRIMARY KEY (`response_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617128_voting') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617128_voting') AS relationships;
DROP DATABASE `db_617128_voting`;
UNINSTALL EXTENSION vsql_schematron;
