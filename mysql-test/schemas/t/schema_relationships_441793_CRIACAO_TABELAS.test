INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 441793_CRIACAO_TABELAS
--echo #
CREATE DATABASE `db_441793_CRIACAO_TABELAS`;
USE `db_441793_CRIACAO_TABELAS`;
CREATE TABLE `ALUNO` (
  `RA_ALUNO` INT NOT NULL,
  `NOME_ALUNO` VARCHAR(50),
  `SEXO` CHAR(50),
  PRIMARY KEY (`RA_ALUNO`)
) CHARACTER SET latin1;
CREATE TABLE `DISCIPLINA` (
  `COD_DISCIPLINA` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`COD_DISCIPLINA`)
) CHARACTER SET latin1;
CREATE TABLE `PROFESSOR` (
  `MATRICULA_PROF` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`MATRICULA_PROF`)
) CHARACTER SET latin1;
CREATE TABLE `TURMA` (
  `NUM_TURMA` INT NOT NULL,
  `DATA_INICIO` DATE,
  `DATA_TERMINO` DATE,
  PRIMARY KEY (`NUM_TURMA`)
) CHARACTER SET latin1;
CREATE TABLE `OFERECIDA` (
  `NUM_OFERECIDA` INT NOT NULL,
  `SALA` VARCHAR(50),
  `BLOCO` VARCHAR(50),
  `NUM_TURMA` INT,
  `MATRICULA_PROF` INT,
  `COD_DISCIPLINA` INT,
  PRIMARY KEY (`NUM_OFERECIDA`)
) CHARACTER SET latin1;
CREATE TABLE `E_AVALIADO` (
  `RA_ALUNO` INT NOT NULL,
  `NUM_OFERECIDA` INT NOT NULL,
  `A1` DOUBLE,
  `A2` DOUBLE,
  `AF` DOUBLE,
  PRIMARY KEY (`RA_ALUNO`, `NUM_OFERECIDA`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_441793_CRIACAO_TABELAS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_441793_CRIACAO_TABELAS') AS relationships;
DROP DATABASE `db_441793_CRIACAO_TABELAS`;
UNINSTALL EXTENSION vsql_schematron;
