INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163979_psql_test
--echo #
CREATE DATABASE `db_163979_psql_test`;
USE `db_163979_psql_test`;
CREATE TABLE `customers` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` VARCHAR(50) NOT NULL,
  `customer_id` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163979_psql_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163979_psql_test') AS relationships;
DROP DATABASE `db_163979_psql_test`;
UNINSTALL EXTENSION vsql_schematron;
