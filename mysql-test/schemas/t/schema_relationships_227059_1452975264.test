INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 227059_1452975264
--echo #
CREATE DATABASE `db_227059_1452975264`;
USE `db_227059_1452975264`;
CREATE TABLE `bulletins` (
  `txid` VARCHAR(50) NOT NULL,
  `block` TEXT,
  `author` TEXT,
  `message` TEXT,
  `timestamp` INT,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  `height` DOUBLE,
  PRIMARY KEY (`txid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `txid` TEXT,
  `value` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_227059_1452975264') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_227059_1452975264') AS relationships;
DROP DATABASE `db_227059_1452975264`;
UNINSTALL EXTENSION vsql_schematron;
