INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 506769_script
--echo #
CREATE DATABASE `db_506769_script`;
USE `db_506769_script`;
CREATE TABLE `links` (
  `id` INT NOT NULL,
  `base_url` VARCHAR(50),
  `shortened_url` VARCHAR(50),
  `is_anonymous` INT,
  `user_id` INT,
  `short_description` VARCHAR(50),
  `expired_at` DATE,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_506769_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_506769_script') AS relationships;
DROP DATABASE `db_506769_script`;
UNINSTALL EXTENSION vsql_schematron;
