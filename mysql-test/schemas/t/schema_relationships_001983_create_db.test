INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 001983_create_db
--echo #
CREATE DATABASE `db_001983_create_db`;
USE `db_001983_create_db`;
CREATE TABLE `users` (
  `id` INT,
  `firstname` TEXT,
  `lastname` TEXT,
  `email` TEXT,
  `share_email` BOOLEAN,
  `password` TEXT,
  `password_lost` TEXT,
  `phone` TEXT,
  `share_phone` BOOLEAN,
  `has_whatsapp` BOOLEAN,
  `theme` TEXT,
  `role` TEXT,
  `notif_new_event` BOOLEAN,
  `notif_event_change` BOOLEAN,
  `notif_tomorrow_events` BOOLEAN,
  `wing` TEXT,
  `presentation` TEXT,
  `creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events` (
  `id` INT,
  `title` TEXT,
  `start_date` TEXT,
  `end_date` TEXT,
  `time` TEXT,
  `description` TEXT,
  `location` TEXT,
  `gps` TEXT,
  `gps_location` TEXT,
  `category` TEXT,
  `color` TEXT,
  `whatsapp_link` TEXT,
  `creator_id` INT,
  `creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events_registrations` (
  `id` INT,
  `event_id` INT,
  `user_id` INT,
  `interest` INT,
  `lastupdate_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT,
  `comment` TEXT,
  `author_id` INT,
  `event_id` INT,
  `creation_datetime` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `events_notifications_blocklist` (
  `event_id` INT,
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_001983_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_001983_create_db') AS relationships;
DROP DATABASE `db_001983_create_db`;
UNINSTALL EXTENSION vsql_schematron;
