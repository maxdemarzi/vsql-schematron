INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064907_CREATE_PG_TABLES
--echo #
CREATE DATABASE `db_064907_CREATE_PG_TABLES`;
USE `db_064907_CREATE_PG_TABLES`;
CREATE TABLE `questions` (
  `id` INT NOT NULL,
  `title` TEXT,
  `answer` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `title` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question_tags` (
  `id` INT NOT NULL,
  `question_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064907_CREATE_PG_TABLES') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064907_CREATE_PG_TABLES') AS relationships;
DROP DATABASE `db_064907_CREATE_PG_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
