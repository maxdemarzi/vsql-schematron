INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 166808_ecom
--echo #
CREATE DATABASE `db_166808_ecom`;
USE `db_166808_ecom`;
CREATE TABLE `cart` (
  `Email` VARCHAR(50),
  `Prod_id` INT,
  `UUID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `Categories_name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Categories_name`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `Prod_id` INT NOT NULL,
  `Categories_name` VARCHAR(50),
  `Prod_name` VARCHAR(50),
  `Prod_price` INT,
  `Prod_rating` INT,
  `Prod_specs` VARCHAR(50),
  `Prod_img_url` VARCHAR(50),
  PRIMARY KEY (`Prod_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `Name` VARCHAR(50),
  `DOB` DATE,
  `Phone` DECIMAL(10,2),
  `Email` VARCHAR(50) NOT NULL,
  `Password` VARCHAR(50),
  PRIMARY KEY (`Email`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_166808_ecom') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_166808_ecom') AS relationships;
DROP DATABASE `db_166808_ecom`;
UNINSTALL EXTENSION vsql_schematron;
