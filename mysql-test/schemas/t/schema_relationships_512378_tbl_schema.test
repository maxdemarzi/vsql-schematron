INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512378_tbl_schema
--echo #
CREATE DATABASE `db_512378_tbl_schema`;
USE `db_512378_tbl_schema`;
CREATE TABLE `tbl_info` (
  `id` INT NOT NULL,
  `title` TEXT,
  `info` TEXT,
  `user` TEXT,
  `time_added` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_tag` (
  `id` INT NOT NULL,
  `tag` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_info_tag_ref` (
  `id` INT NOT NULL,
  `info_id` INT,
  `tag_id` INT,
  `time_added` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512378_tbl_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512378_tbl_schema') AS relationships;
DROP DATABASE `db_512378_tbl_schema`;
UNINSTALL EXTENSION vsql_schematron;
