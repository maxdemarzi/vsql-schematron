INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510623_database
--echo #
CREATE DATABASE `db_510623_database`;
USE `db_510623_database`;
CREATE TABLE `author` (
  `author_id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `book_id` INT NOT NULL,
  `title` VARCHAR(50),
  `filename` VARCHAR(50),
  `author_id` INT,
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_rates` (
  `rate_id` INT NOT NULL,
  `book_id` INT,
  `rate` INT,
  PRIMARY KEY (`rate_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  `display_name` VARCHAR(50),
  `points` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510623_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510623_database') AS relationships;
DROP DATABASE `db_510623_database`;
UNINSTALL EXTENSION vsql_schematron;
