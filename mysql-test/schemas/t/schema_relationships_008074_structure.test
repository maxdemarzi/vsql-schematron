INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008074_structure
--echo #
CREATE DATABASE `db_008074_structure`;
USE `db_008074_structure`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `email` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `description` CHAR(50),
  `completed_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `description` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `taggings` (
  `id` BIGINT NOT NULL,
  `todo_id` BIGINT,
  `tag_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recommended_todos` (
  `id` BIGINT NOT NULL,
  `todo_id` BIGINT,
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008074_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008074_structure') AS relationships;
DROP DATABASE `db_008074_structure`;
UNINSTALL EXTENSION vsql_schematron;
