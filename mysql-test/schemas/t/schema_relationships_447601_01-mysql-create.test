INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447601_01-mysql-create
--echo #
CREATE DATABASE `db_447601_01_mysql_create`;
USE `db_447601_01_mysql_create`;
CREATE TABLE `ROLE` (
  `id` INT NOT NULL,
  `role_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLE` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `author_id` INT,
  `open_source` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447601_01_mysql_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447601_01_mysql_create') AS relationships;
DROP DATABASE `db_447601_01_mysql_create`;
UNINSTALL EXTENSION vsql_schematron;
