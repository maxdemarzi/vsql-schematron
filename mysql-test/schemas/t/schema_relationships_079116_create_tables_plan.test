INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079116_create_tables_plan
--echo #
CREATE DATABASE `db_079116_create_tables_plan`;
USE `db_079116_create_tables_plan`;
CREATE TABLE `plan` (
  `ID` INT NOT NULL,
  `ID_user` INT,
  `plan_days` INT,
  `description` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `menu` (
  `ID` INT NOT NULL,
  `ID_plan` INT,
  `day` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `meal` (
  `ID` INT NOT NULL,
  `ID_menu` INT,
  `time_of_day` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `meal_recipe` (
  `ID_meal` INT,
  `ID_recipe` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079116_create_tables_plan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079116_create_tables_plan') AS relationships;
DROP DATABASE `db_079116_create_tables_plan`;
UNINSTALL EXTENSION vsql_schematron;
