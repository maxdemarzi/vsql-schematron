INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 242041_202001281220
--echo #
CREATE DATABASE `db_242041_202001281220`;
USE `db_242041_202001281220`;
CREATE TABLE `job` (
  `id` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  `payload` VARCHAR(50),
  `parameter` VARCHAR(50),
  `status` VARCHAR(50),
  `attempt` VARCHAR(50),
  `activeState` VARCHAR(50),
  `updated` DATETIME,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jobHistory` (
  `id` VARCHAR(50) NOT NULL,
  `jobId` VARCHAR(50),
  `message` VARCHAR(50),
  `additionalData` VARCHAR(50),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_242041_202001281220') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_242041_202001281220') AS relationships;
DROP DATABASE `db_242041_202001281220`;
UNINSTALL EXTENSION vsql_schematron;
