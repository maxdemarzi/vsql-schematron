INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 503378_mutualismo_operario
--echo #
CREATE DATABASE `db_503378_mutualismo_operario`;
USE `db_503378_mutualismo_operario`;
CREATE TABLE `socios` (
  `id_socio` INT NOT NULL,
  `nome_socio` VARCHAR(50),
  `sexo_socio` VARCHAR(50),
  `profissao_socio` VARCHAR(50),
  `tipo_profissao_socio` VARCHAR(50),
  `imigrante_socio` VARCHAR(50),
  `elite_socio` VARCHAR(50),
  `data_entrada` DATE,
  `data_saida` DATE,
  `observacao` VARCHAR(50),
  PRIMARY KEY (`id_socio`)
) CHARACTER SET latin1;
CREATE TABLE `conta_corrente` (
  `id_conta` INT NOT NULL,
  `deve` INT,
  `haver` INT,
  `data_pagamento` DATE,
  `total_servicos` INT,
  `todos_servicos` VARCHAR(50),
  `complemento` VARCHAR(50),
  `id_socio` INT,
  PRIMARY KEY (`id_conta`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_503378_mutualismo_operario') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_503378_mutualismo_operario') AS relationships;
DROP DATABASE `db_503378_mutualismo_operario`;
UNINSTALL EXTENSION vsql_schematron;
