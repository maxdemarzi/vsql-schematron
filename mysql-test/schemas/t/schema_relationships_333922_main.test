INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333922_main
--echo #
CREATE DATABASE `db_333922_main`;
USE `db_333922_main`;
CREATE TABLE `menu_sections` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `type` VARCHAR(50),
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_items` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `sectionID` INT,
  `price` VARCHAR(50),
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `announcements` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact_us` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `subject` VARCHAR(50),
  `message` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cms_data` (
  `id` INT NOT NULL,
  `sectionName` VARCHAR(50),
  `sectionText` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333922_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333922_main') AS relationships;
DROP DATABASE `db_333922_main`;
UNINSTALL EXTENSION vsql_schematron;
