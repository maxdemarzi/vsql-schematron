INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 361596_join
--echo #
CREATE DATABASE `db_361596_join`;
USE `db_361596_join`;
CREATE TABLE `engine` (
  `id_e` INT NOT NULL,
  `name_e` VARCHAR(50),
  PRIMARY KEY (`id_e`)
) CHARACTER SET latin1;
CREATE TABLE `frame` (
  `id_f` INT NOT NULL,
  `name_f` VARCHAR(50),
  PRIMARY KEY (`id_f`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
  `id_t` INT NOT NULL,
  `name_t` VARCHAR(50),
  PRIMARY KEY (`id_t`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
  `id_c` INT NOT NULL,
  `name_c` VARCHAR(50),
  `id_f` INT,
  `id_e` INT,
  `id_t` INT,
  PRIMARY KEY (`id_c`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_361596_join') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_361596_join') AS relationships;
DROP DATABASE `db_361596_join`;
UNINSTALL EXTENSION vsql_schematron;
