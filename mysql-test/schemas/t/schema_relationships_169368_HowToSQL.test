INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 169368_HowToSQL
--echo #
CREATE DATABASE `db_169368_HowToSQL`;
USE `db_169368_HowToSQL`;
CREATE TABLE `Games` (
  `GameID` INT NOT NULL,
  `Name` TEXT,
  `Ratings` INT,
  `Price` DOUBLE,
  PRIMARY KEY (`GameID`)
) CHARACTER SET latin1;
CREATE TABLE `Reviews` (
  `ReviewID` INT NOT NULL,
  `GameID` INT,
  `Day` DATE,
  `Title` TEXT,
  `Stars` INT,
  `Review` TEXT,
  PRIMARY KEY (`ReviewID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_169368_HowToSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169368_HowToSQL') AS relationships;
DROP DATABASE `db_169368_HowToSQL`;
UNINSTALL EXTENSION vsql_schematron;
