INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 169919_schema
--echo #
CREATE DATABASE `db_169919_schema`;
USE `db_169919_schema`;
CREATE TABLE `emails` (
  `id` INT NOT NULL,
  `view_uuid` TEXT,
  `admin_uuid` TEXT,
  `sentfrom` TEXT,
  `subject` TEXT,
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `views` (
  `email` INT,
  `viewed` INT,
  `ip` TEXT,
  `user_agent` TEXT,
  `cookie_uuid` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_169919_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169919_schema') AS relationships;
DROP DATABASE `db_169919_schema`;
UNINSTALL EXTENSION vsql_schematron;
