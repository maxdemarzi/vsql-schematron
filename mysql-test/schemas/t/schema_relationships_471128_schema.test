INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 471128_schema
--echo #
CREATE DATABASE `db_471128_schema`;
USE `db_471128_schema`;
CREATE TABLE `addresses` (
  `id` INT NOT NULL,
  `country` VARCHAR(50),
  `city` VARCHAR(50),
  `postcode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `description` VARCHAR(50),
  `address_id` INT,
  `organization_id` INT,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_471128_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_471128_schema') AS relationships;
DROP DATABASE `db_471128_schema`;
UNINSTALL EXTENSION vsql_schematron;
