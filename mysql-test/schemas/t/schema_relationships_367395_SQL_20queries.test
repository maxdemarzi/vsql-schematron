INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 367395_SQL%20queries
--echo #
CREATE DATABASE `db_367395_SQL_20queries`;
USE `db_367395_SQL_20queries`;
CREATE TABLE `titles` (
  `emp_no` INT,
  `title` VARCHAR(50),
  `from_date` DATE,
  `to_date` DATE
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `emp_no` INT NOT NULL,
  `birth_date` DATE,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `hire_date` DATE,
  PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_367395_SQL_20queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_367395_SQL_20queries') AS relationships;
DROP DATABASE `db_367395_SQL_20queries`;
UNINSTALL EXTENSION vsql_schematron;
