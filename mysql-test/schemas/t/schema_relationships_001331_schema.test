INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 001331_schema
--echo #
CREATE DATABASE `db_001331_schema`;
USE `db_001331_schema`;
CREATE TABLE `sys_client_details` (
  `id` BIGINT NOT NULL,
  `access_token_validity_seconds` INT,
  `authorizations` VARCHAR(50),
  `auto_approve_scopes` VARCHAR(50),
  `client_id` VARCHAR(50),
  `client_secret` VARCHAR(50),
  `grant_types` VARCHAR(50),
  `redirect_url` VARCHAR(50),
  `refresh_token_validity_seconds` INT,
  `resource_ids` VARCHAR(50),
  `scopes` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_role` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user_role` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `role_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_001331_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_001331_schema') AS relationships;
DROP DATABASE `db_001331_schema`;
UNINSTALL EXTENSION vsql_schematron;
