INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060996_ddl
--echo #
CREATE DATABASE `db_060996_ddl`;
USE `db_060996_ddl`;
CREATE TABLE `account` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `display_name` VARCHAR(50),
  `avatar` TEXT,
  `header` TEXT,
  `note` TEXT,
  `create_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
  `id` BIGINT NOT NULL,
  `account_id` BIGINT,
  `content` TEXT,
  `create_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060996_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060996_ddl') AS relationships;
DROP DATABASE `db_060996_ddl`;
UNINSTALL EXTENSION vsql_schematron;
