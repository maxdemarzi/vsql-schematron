CREATE DATABASE `db_641237_20191111184655_create_users`;
USE `db_641237_20191111184655_create_users`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `admin_users` (
  `id` BIGINT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641237_20191111184655_create_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641237_20191111184655_create_users') AS relationships;
DROP DATABASE `db_641237_20191111184655_create_users`;
UNINSTALL EXTENSION vsql_schematron;
