INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068843_schema
--echo #
CREATE DATABASE `db_068843_schema`;
USE `db_068843_schema`;
CREATE TABLE `routes` (
  `id` INT NOT NULL,
  `path` TEXT,
  `model` TEXT,
  `view` TEXT,
  `templateFile` TEXT,
  `controller` TEXT,
  `action` TEXT,
  `requiresAuth` INT,
  `requiredRole` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `actionArgs` (
  `id` INT NOT NULL,
  `argument` TEXT,
  `type` TEXT,
  `routeID` INT,
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068843_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068843_schema') AS relationships;
DROP DATABASE `db_068843_schema`;
UNINSTALL EXTENSION vsql_schematron;
