INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015655_V1__INITIALIZE_SCHEMA
--echo #
CREATE DATABASE `db_015655_V1__INITIALIZE_SCHEMA`;
USE `db_015655_V1__INITIALIZE_SCHEMA`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `nickname` TEXT,
  `email_address` TEXT,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chores` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `description` TEXT,
  `due_date` DATE,
  `completed` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015655_V1__INITIALIZE_SCHEMA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015655_V1__INITIALIZE_SCHEMA') AS relationships;
DROP DATABASE `db_015655_V1__INITIALIZE_SCHEMA`;
UNINSTALL EXTENSION vsql_schematron;
