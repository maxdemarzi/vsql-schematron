INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279950_pocket
--echo #
CREATE DATABASE `db_279950_pocket`;
USE `db_279950_pocket`;
CREATE TABLE `tasks` (
  `Id_tasks` INT NOT NULL,
  `tas_name` VARCHAR(50),
  `tas_description` VARCHAR(50),
  `tas_points` INT,
  PRIMARY KEY (`Id_tasks`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
  `Id_person` INT NOT NULL,
  `per_name` VARCHAR(50),
  `per_age` INT,
  PRIMARY KEY (`Id_person`)
) CHARACTER SET latin1;
CREATE TABLE `ligne_task` (
  `Id_tasks` INT NOT NULL,
  `Id_person` INT NOT NULL,
  `pai_scale` INT,
  `date_done` DATE,
  `voluntary` BOOLEAN,
  PRIMARY KEY (`Id_tasks`, `Id_person`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279950_pocket') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279950_pocket') AS relationships;
DROP DATABASE `db_279950_pocket`;
UNINSTALL EXTENSION vsql_schematron;
