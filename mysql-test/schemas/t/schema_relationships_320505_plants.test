INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 320505_plants
--echo #
CREATE DATABASE `db_320505_plants`;
USE `db_320505_plants`;
CREATE TABLE `alias` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plant` (
  `id` INT NOT NULL,
  `rawname` TEXT,
  `symbol` TEXT,
  `symbolsynonym` TEXT,
  `family` TEXT,
  `genus` TEXT,
  `specific` TEXT,
  `type` TEXT,
  `sspvar` TEXT,
  `hybridpair` TEXT,
  `author` TEXT,
  `secondauthor` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plantalias` (
  `plant_id` INT,
  `alias_id` INT,
  `type` TEXT
) CHARACTER SET latin1;
CREATE TABLE `plantregion` (
  `plant_id` INT,
  `region_id` INT
) CHARACTER SET latin1;
CREATE TABLE `region` (
  `id` INT NOT NULL,
  `name` TEXT,
  `code` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_320505_plants') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_320505_plants') AS relationships;
DROP DATABASE `db_320505_plants`;
UNINSTALL EXTENSION vsql_schematron;
