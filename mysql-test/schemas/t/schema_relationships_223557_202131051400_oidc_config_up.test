CREATE TABLE `oidc_config` (
  `id` VARCHAR(50) NOT NULL,
  `gardener_config_id` VARCHAR(50),
  `client_id` TEXT,
  `groups_claim` TEXT,
  `issuer_url` TEXT,
  `username_claim` TEXT,
  `username_prefix` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signing_algorithms` (
  `id` VARCHAR(50) NOT NULL,
  `oidc_config_id` VARCHAR(50),
  `algorithm` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
