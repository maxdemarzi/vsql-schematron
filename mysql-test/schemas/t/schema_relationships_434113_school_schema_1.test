INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434113_school_schema_1
--echo #
CREATE DATABASE `db_434113_school_schema_1`;
USE `db_434113_school_schema_1`;
CREATE TABLE `seminar` (
  `id` INT NOT NULL,
  `location` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `id` INT NOT NULL,
  `location` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `seminar_2_student` (
  `id` INT NOT NULL,
  `seminar_id` INT,
  `student_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `professor` (
  `id` INT NOT NULL,
  `birth_date` TEXT,
  `name` TEXT,
  `surname` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434113_school_schema_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434113_school_schema_1') AS relationships;
DROP DATABASE `db_434113_school_schema_1`;
UNINSTALL EXTENSION vsql_schematron;
