INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152562_V0.1__create_symbols_quotes_tables
--echo #
CREATE DATABASE `db_152562_V0_1__create_symbols_quotes_tables`;
USE `db_152562_V0_1__create_symbols_quotes_tables`;
CREATE TABLE `symbols` (
  `VALUE` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`VALUE`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
  `id` VARCHAR(50) NOT NULL,
  `bid` DECIMAL(10,2),
  `ask` DECIMAL(10,2),
  `last_price` DECIMAL(10,2),
  `volume` DECIMAL(10,2),
  `symbol` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152562_V0_1__create_symbols_quotes_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152562_V0_1__create_symbols_quotes_tables') AS relationships;
DROP DATABASE `db_152562_V0_1__create_symbols_quotes_tables`;
UNINSTALL EXTENSION vsql_schematron;
