USE `db_045911_V1_8_1_2__plm_requirement`;
CREATE TABLE `PLM_REQUIREMENT` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `PRIORITY` INT,
  `TAG` VARCHAR(50),
  `STATUS` VARCHAR(50),
  `CREATE_TIME` DATETIME,
  `USER_ID` VARCHAR(50),
  `PARENT_ID` BIGINT,
  `ISSUE_ID` BIGINT,
  `VERSION_ID` BIGINT,
  `PROJECT_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045911_V1_8_1_2__plm_requirement') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045911_V1_8_1_2__plm_requirement') AS relationships;
DROP DATABASE `db_045911_V1_8_1_2__plm_requirement`;
UNINSTALL EXTENSION vsql_schematron;
