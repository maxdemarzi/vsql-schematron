INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 291868_schema
--echo #
CREATE DATABASE `db_291868_schema`;
USE `db_291868_schema`;
CREATE TABLE `boards` (
  `id` INT NOT NULL,
  `key` VARCHAR(50),
  `create_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` INT NOT NULL,
  `board_id` INT,
  `title` VARCHAR(50),
  `description` TEXT,
  `status` INT,
  `create_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `statuses` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_291868_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_291868_schema') AS relationships;
DROP DATABASE `db_291868_schema`;
UNINSTALL EXTENSION vsql_schematron;
