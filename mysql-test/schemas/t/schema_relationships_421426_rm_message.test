INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421426_rm_message
--echo #
CREATE DATABASE `db_421426_rm_message`;
USE `db_421426_rm_message`;
CREATE TABLE `RM_MESSAGE` (
  `ID` INT NOT NULL,
  `BIZ_KEYWORD` VARCHAR(50),
  `SENDER_ID` INT,
  `PARENT_MESSAGE_ID` INT,
  `OWNER_ORG_ID` VARCHAR(50),
  `TEMPLATE_ID` INT,
  `IS_AFFIX` CHAR(50),
  `RECORD_ID` VARCHAR(50),
  `MESSAGE_XML_CONTEXT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RM_MESSAGE_RECEIVER` (
  `ID` INT NOT NULL,
  `MESSAGE_ID` INT,
  `RECEIVER_ID` INT,
  `IS_HANDLE` CHAR(50),
  `HANDLE_DATE` DATE,
  `HANDLE_RESULT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421426_rm_message') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421426_rm_message') AS relationships;
DROP DATABASE `db_421426_rm_message`;
UNINSTALL EXTENSION vsql_schematron;
