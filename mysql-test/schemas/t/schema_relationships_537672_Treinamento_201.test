INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 537672_Treinamento%201
--echo #
CREATE DATABASE `db_537672_Treinamento_201`;
USE `db_537672_Treinamento_201`;
CREATE TABLE `FORNECEDOR` (
  `CodFornec` INT NOT NULL,
  `NomeFornec` CHAR(50),
  `Cidade` CHAR(50),
  PRIMARY KEY (`CodFornec`)
) CHARACTER SET latin1;
CREATE TABLE `PECA` (
  `CodPeca` INT NOT NULL,
  `NomePeca` CHAR(50),
  `Peso` DECIMAL(10,2),
  `Cor` CHAR(50),
  PRIMARY KEY (`CodPeca`)
) CHARACTER SET latin1;
CREATE TABLE `FORNECE` (
  `CodPeca` INT NOT NULL,
  `CodFornec` INT NOT NULL,
  `Qtde` INT,
  PRIMARY KEY (`CodPeca`, `CodFornec`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `num_pedido` INT NOT NULL,
  `prazo_entrega` INT,
  `codigo_cliente` INT,
  `codigo_vendedor` INT,
  PRIMARY KEY (`num_pedido`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_537672_Treinamento_201') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_537672_Treinamento_201') AS relationships;
DROP DATABASE `db_537672_Treinamento_201`;
UNINSTALL EXTENSION vsql_schematron;
