INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586289_create_db
--echo #
CREATE DATABASE `db_586289_create_db`;
USE `db_586289_create_db`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` CHAR(50),
  `registration_date` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `ideas` (
  `idea_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `image_path` VARCHAR(50),
  `date_entered` DATETIME,
  `likes` INT,
  `pursuer` VARCHAR(50),
  PRIMARY KEY (`idea_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `comment_id` VARCHAR(50) NOT NULL,
  `message` VARCHAR(50),
  `date_entered` DATETIME,
  `user_id` VARCHAR(50),
  `idea_id` VARCHAR(50),
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586289_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586289_create_db') AS relationships;
DROP DATABASE `db_586289_create_db`;
UNINSTALL EXTENSION vsql_schematron;
