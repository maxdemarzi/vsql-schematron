INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 594091_schema
--echo #
CREATE DATABASE `db_594091_schema`;
USE `db_594091_schema`;
CREATE TABLE `experiment` (
  `id` INT NOT NULL,
  `project_id` INT,
  `engine` VARCHAR(50),
  `hyperparams` VARCHAR(50),
  `metrics` VARCHAR(50),
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `serving` (
  `id` INT NOT NULL,
  `project_id` INT,
  `experiment_id` INT,
  `payload` VARCHAR(50),
  `api_key` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_594091_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_594091_schema') AS relationships;
DROP DATABASE `db_594091_schema`;
UNINSTALL EXTENSION vsql_schematron;
