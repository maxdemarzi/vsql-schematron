INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 647533_schema
--echo #
CREATE DATABASE `db_647533_schema`;
USE `db_647533_schema`;
CREATE TABLE `language` (
  `idlang` INT NOT NULL,
  `descriptor` CHAR(50),
  PRIMARY KEY (`idlang`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `idproject` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`idproject`)
) CHARACTER SET latin1;
CREATE TABLE `text_translation` (
  `idtext` INT NOT NULL,
  `paragraph` TEXT,
  `status` TINYINT,
  `lang` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`idtext`, `lang`)
) CHARACTER SET latin1;
CREATE TABLE `text` (
  `idtext` INT NOT NULL,
  `app` TINYINT,
  `web` TINYINT,
  `destinationfile` VARCHAR(50),
  `idproject` INT,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`idtext`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_647533_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_647533_schema') AS relationships;
DROP DATABASE `db_647533_schema`;
UNINSTALL EXTENSION vsql_schematron;
