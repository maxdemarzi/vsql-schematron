INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395016_CreateTables
--echo #
CREATE DATABASE `db_395016_CreateTables`;
USE `db_395016_CreateTables`;
CREATE TABLE `activity` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `timeslot` (
  `id` INT NOT NULL,
  `activityid` INT,
  `start` DATETIME,
  `end` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395016_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395016_CreateTables') AS relationships;
DROP DATABASE `db_395016_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
