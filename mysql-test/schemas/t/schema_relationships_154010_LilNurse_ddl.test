INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 154010_LilNurse.ddl
--echo #
CREATE DATABASE `db_154010_LilNurse_ddl`;
USE `db_154010_LilNurse_ddl`;
CREATE TABLE `Patient` (
  `pno` INT NOT NULL,
  `pname` VARCHAR(50),
  `hospital` VARCHAR(50),
  `docName` VARCHAR(50),
  PRIMARY KEY (`pno`)
) CHARACTER SET latin1;
CREATE TABLE `Medication` (
  `medName` VARCHAR(50) NOT NULL,
  `dosage` VARCHAR(50),
  `reason` VARCHAR(50),
  `refillNum` INT,
  `refillDate` DATE,
  `quantity` VARCHAR(50),
  `specialInstructions` VARCHAR(50),
  `pno` INT,
  PRIMARY KEY (`medName`)
) CHARACTER SET latin1;
CREATE TABLE `Prescription` (
  `dateIssued` DATE,
  `medName` VARCHAR(50),
  `pName` VARCHAR(50),
  `prescNo` INT NOT NULL,
  PRIMARY KEY (`prescNo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_154010_LilNurse_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_154010_LilNurse_ddl') AS relationships;
DROP DATABASE `db_154010_LilNurse_ddl`;
UNINSTALL EXTENSION vsql_schematron;
