INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221523_setup
--echo #
CREATE DATABASE `db_221523_setup`;
USE `db_221523_setup`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogs` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `image_url` TEXT,
  `body` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `comment_text` VARCHAR(50),
  `blog_id` INT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221523_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221523_setup') AS relationships;
DROP DATABASE `db_221523_setup`;
UNINSTALL EXTENSION vsql_schematron;
