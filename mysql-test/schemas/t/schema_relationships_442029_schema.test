INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 442029_schema
--echo #
CREATE DATABASE `db_442029_schema`;
USE `db_442029_schema`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `token` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `last_login` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` VARCHAR(50) NOT NULL,
  `category` VARCHAR(50),
  `labels` VARCHAR(50),
  `name` VARCHAR(50),
  `brand` VARCHAR(50),
  `color` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `price` (
  `id` VARCHAR(50) NOT NULL,
  `of_product` VARCHAR(50),
  `price` DOUBLE,
  `unit` VARCHAR(50),
  `currency` VARCHAR(50),
  `_created` DATE,
  `_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_442029_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_442029_schema') AS relationships;
DROP DATABASE `db_442029_schema`;
UNINSTALL EXTENSION vsql_schematron;
