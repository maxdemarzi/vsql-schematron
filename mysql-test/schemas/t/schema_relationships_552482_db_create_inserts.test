INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552482_db_create_inserts
--echo #
CREATE DATABASE `db_552482_db_create_inserts`;
USE `db_552482_db_create_inserts`;
CREATE TABLE `tb_usuario` (
  `cd_usuario` INT NOT NULL,
  `nm_usuario` VARCHAR(50),
  `senha_usuario` VARCHAR(50),
  PRIMARY KEY (`cd_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `tb_postagem` (
  `cd_postagem` INT NOT NULL,
  `nm_conteudo` TEXT,
  `tot_like` INT,
  `fk_cd_usuario` INT,
  PRIMARY KEY (`cd_postagem`)
) CHARACTER SET latin1;
CREATE TABLE `interacao_post` (
  `fk_cd_usuario` INT,
  `fk_cd_postagem` INT,
  `nr_like` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `comentarios` (
  `cd_comentario` INT NOT NULL,
  `nm_comentario` TEXT,
  `fk_cd_usuario` INT,
  `fk_cd_postagem` INT,
  PRIMARY KEY (`cd_comentario`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552482_db_create_inserts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552482_db_create_inserts') AS relationships;
DROP DATABASE `db_552482_db_create_inserts`;
UNINSTALL EXTENSION vsql_schematron;
