INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532419_ddl
--echo #
CREATE DATABASE `db_532419_ddl`;
USE `db_532419_ddl`;
CREATE TABLE `Apps` (
  `application_id` INT NOT NULL,
  `package` TEXT,
  `restriction_method` TEXT,
  `hashed_password` TEXT,
  PRIMARY KEY (`application_id`)
) CHARACTER SET latin1;
CREATE TABLE `Attempt` (
  `attempt_id` INT NOT NULL,
  `application_id` INT,
  `time_stamp` INT,
  `success` INT,
  PRIMARY KEY (`attempt_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532419_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532419_ddl') AS relationships;
DROP DATABASE `db_532419_ddl`;
UNINSTALL EXTENSION vsql_schematron;
