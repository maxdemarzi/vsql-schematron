INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 653848_gestion1
--echo #
CREATE DATABASE `db_653848_gestion1`;
USE `db_653848_gestion1`;
CREATE TABLE `classes` (
  `id` INT,
  `nom` VARCHAR(50),
  `filiere` INT
) CHARACTER SET latin1;
CREATE TABLE `employe` (
  `cin` VARCHAR(50) NOT NULL,
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `email` VARCHAR(50),
  `telephone` VARCHAR(50),
  `adresse` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  `photo` VARCHAR(50),
  PRIMARY KEY (`cin`)
) CHARACTER SET latin1;
CREATE TABLE `filiere` (
  `id` INT NOT NULL,
  `code` VARCHAR(50),
  `libelle` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_653848_gestion1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_653848_gestion1') AS relationships;
DROP DATABASE `db_653848_gestion1`;
UNINSTALL EXTENSION vsql_schematron;
