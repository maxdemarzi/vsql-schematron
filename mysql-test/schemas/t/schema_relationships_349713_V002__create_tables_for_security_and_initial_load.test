INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 349713_V002__create_tables_for_security_and_initial_load
--echo #
CREATE DATABASE `db_349713_V002__create_tables_for_security_and_initial_load`;
USE `db_349713_V002__create_tables_for_security_and_initial_load`;
CREATE TABLE `access_profile` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `fullname` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `status` INT,
  `province_id` BIGINT,
  `access_profile_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_349713_V002__create_tables_for_security_and_initial_load') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_349713_V002__create_tables_for_security_and_initial_load') AS relationships;
DROP DATABASE `db_349713_V002__create_tables_for_security_and_initial_load`;
