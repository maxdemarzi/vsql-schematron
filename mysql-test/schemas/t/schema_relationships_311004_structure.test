INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 311004_structure
--echo #
CREATE DATABASE `db_311004_structure`;
USE `db_311004_structure`;
CREATE TABLE `machine` (
  `machine` VARCHAR(50) NOT NULL,
  `key` TEXT,
  PRIMARY KEY (`machine`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `pid` INT NOT NULL,
  `product` TEXT,
  `price` INT,
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `slot_product` (
  `spid` INT NOT NULL,
  `slot` INT,
  `machine` TEXT,
  `product` INT,
  PRIMARY KEY (`spid`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `tid` INT NOT NULL,
  `uid` INT,
  `value` INT,
  `descr` TEXT,
  `timestamp` TIMESTAMP NULL,
  `machine` TEXT,
  `product` INT,
  `user` TEXT,
  `username` TEXT,
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `uid` INT NOT NULL,
  `username` TEXT,
  `card_data` TEXT,
  `enabled` INT,
  `admin` INT,
  `access_areas` TEXT,
  `phone` TEXT,
  `email` TEXT,
  `address` TEXT,
  `realname` TEXT,
  `password` TEXT,
  `sshkey` TEXT,
  `stripe_id` TEXT,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_311004_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_311004_structure') AS relationships;
DROP DATABASE `db_311004_structure`;
UNINSTALL EXTENSION vsql_schematron;
