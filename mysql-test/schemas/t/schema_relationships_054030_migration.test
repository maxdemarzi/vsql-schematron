INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054030_migration
--echo #
CREATE DATABASE `db_054030_migration`;
USE `db_054030_migration`;
CREATE TABLE `Domains` (
  `id` VARCHAR(50) NOT NULL,
  `domain` TEXT,
  `hits` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GuildConfigs` (
  `id` TEXT,
  `delete` BOOLEAN,
  `action` VARCHAR(50),
  `log_channel` TEXT,
  `mute_role` TEXT
) CHARACTER SET latin1;
CREATE TABLE `Exemptions` (
  `id` TEXT,
  `kind` VARCHAR(50),
  `guild_id` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054030_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054030_migration') AS relationships;
DROP DATABASE `db_054030_migration`;
UNINSTALL EXTENSION vsql_schematron;
