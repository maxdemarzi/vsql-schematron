INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547686_database
--echo #
CREATE DATABASE `db_547686_database`;
USE `db_547686_database`;
CREATE TABLE `AuthTokens` (
  `AuthID` INT,
  `Selector` CHAR(50),
  `Token` CHAR(50),
  `UserID` TINYINT,
  `Expires` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Temps` (
  `Time` TIMESTAMP NULL,
  `Temp1` DOUBLE,
  `Temp2` DOUBLE,
  `Average` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `TempSettings` (
  `TempSettingsID` TINYINT NOT NULL,
  `Low` TINYINT,
  `High` TINYINT,
  PRIMARY KEY (`TempSettingsID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `UserID` TINYINT NOT NULL,
  `Username` VARCHAR(50),
  `Password` BLOB,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547686_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547686_database') AS relationships;
DROP DATABASE `db_547686_database`;
UNINSTALL EXTENSION vsql_schematron;
