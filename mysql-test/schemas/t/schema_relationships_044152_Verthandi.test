INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 044152_Verthandi
--echo #
CREATE DATABASE `db_044152_Verthandi`;
USE `db_044152_Verthandi`;
CREATE TABLE `midia` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `tipo` INT,
  `autor` INT,
  `status` VARCHAR(50),
  `datatermino` DATE,
  `avaliacao` VARCHAR(50),
  `nota` INT,
  `usuario` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipo` (
  `idTipo` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `usuario` INT,
  PRIMARY KEY (`idTipo`)
) CHARACTER SET latin1;
CREATE TABLE `autor` (
  `idAutor` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `tipo` VARCHAR(50),
  `usuario` INT,
  PRIMARY KEY (`idAutor`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_044152_Verthandi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_044152_Verthandi') AS relationships;
DROP DATABASE `db_044152_Verthandi`;
UNINSTALL EXTENSION vsql_schematron;
