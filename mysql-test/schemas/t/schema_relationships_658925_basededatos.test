INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 658925_basededatos
--echo #
CREATE DATABASE `db_658925_basededatos`;
USE `db_658925_basededatos`;
CREATE TABLE `cargos` (
  `ID` INT,
  `NOMBRE` VARCHAR(50),
  `SUELDO` DOUBLE,
  `DEPARTAMENTO` INT
) CHARACTER SET latin1;
CREATE TABLE `departamentos` (
  `ID` INT NOT NULL,
  `NOMBRE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `empleados` (
  `ID` INT,
  `NOMBRE` VARCHAR(50),
  `APELLIDO` VARCHAR(50),
  `CEDULA` TEXT,
  `TELEFONO` VARCHAR(50),
  `CELULAR` VARCHAR(50),
  `EMAIL` TEXT,
  `SEXO` VARCHAR(50),
  `CARGO` INT,
  `SEGURO_MEDICO` INT
) CHARACTER SET latin1;
CREATE TABLE `nomina` (
  `ID` INT,
  `EMPLEADO` INT,
  `SALARIO_HR` INT,
  `HORAS_POR_QUINCENA` INT
) CHARACTER SET latin1;
CREATE TABLE `view_nomina_general` (
  `ID` INT,
  `NOMBRE` VARCHAR(50),
  `APELLIDO` VARCHAR(50),
  `CEDULA` TEXT,
  `TELEFONO` VARCHAR(50),
  `CELULAR` VARCHAR(50),
  `EMAIL` TEXT,
  `SEXO` VARCHAR(50),
  `CARGO` VARCHAR(50),
  `SEGURO_MEDICO` VARCHAR(50),
  `SALARIO_HR` INT,
  `HORAS_POR_QUINCENA` INT,
  `SALARIO_M` DECIMAL(10,2),
  `DEDUCCION_DE_SEGURO` BLOB,
  `ISR` BLOB,
  `SALARIO_NETO` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_658925_basededatos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_658925_basededatos') AS relationships;
DROP DATABASE `db_658925_basededatos`;
UNINSTALL EXTENSION vsql_schematron;
