USE `db_288533_HeadFirstSQL_20__20boys_20toys`;
CREATE TABLE `boys` (
  `boy_id` INT NOT NULL,
  `boy` VARCHAR(50),
  `toy_id` INT,
  PRIMARY KEY (`boy_id`)
) CHARACTER SET latin1;
CREATE TABLE `toys` (
  `toy_id` INT NOT NULL,
  `toy` VARCHAR(50),
  PRIMARY KEY (`toy_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
