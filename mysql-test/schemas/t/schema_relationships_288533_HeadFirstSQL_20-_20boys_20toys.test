while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_288533_HeadFirstSQL_20__20boys_20toys') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_288533_HeadFirstSQL_20__20boys_20toys') AS relationships;
