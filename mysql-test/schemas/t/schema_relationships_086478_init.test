INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086478_init
--echo #
CREATE DATABASE `db_086478_init`;
USE `db_086478_init`;
CREATE TABLE `product` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `description` TEXT,
  `price` INT,
  `img` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stocks` (
  `id` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  `count` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086478_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086478_init') AS relationships;
DROP DATABASE `db_086478_init`;
UNINSTALL EXTENSION vsql_schematron;
