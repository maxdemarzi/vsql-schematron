INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 327638_schema
--echo #
CREATE DATABASE `db_327638_schema`;
USE `db_327638_schema`;
CREATE TABLE `ATTR` (
  `ATTRID` INT NOT NULL,
  `IDENTIFIER` VARCHAR(50),
  `ATTRTYPEID` INT,
  `FIELD1` VARCHAR(50),
  `FIELD2` VARCHAR(50),
  `CREATED_DATE` DATE,
  `UPDATED_DATE` DATE,
  PRIMARY KEY (`ATTRID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
  `ITEMID` INT NOT NULL,
  `IDENTIFIER` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `ITEMTYPE` INT,
  `FIELD1` VARCHAR(50),
  `FIELD2` VARCHAR(50),
  `CREATED_DATE` DATE,
  `UPDATED_DATE` DATE,
  PRIMARY KEY (`ITEMID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEMATTRMAPPING` (
  `ITEMATTRMAPPINGID` INT NOT NULL,
  `ITEMID` INT,
  `ATTRID` INT,
  `ATTRVALUE` VARCHAR(50),
  `FIELD1` VARCHAR(50),
  `FIELD2` VARCHAR(50),
  `CREATED_DATE` DATE,
  `UPDATED_DATE` DATE,
  PRIMARY KEY (`ITEMATTRMAPPINGID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEMREL` (
  `ITEMRELID` INT NOT NULL,
  `ITEMID_PARENT` INT,
  `ITEMID_CHILD` INT,
  `FIELD1` VARCHAR(50),
  `FIELD2` VARCHAR(50),
  PRIMARY KEY (`ITEMRELID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_327638_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_327638_schema') AS relationships;
DROP DATABASE `db_327638_schema`;
UNINSTALL EXTENSION vsql_schematron;
