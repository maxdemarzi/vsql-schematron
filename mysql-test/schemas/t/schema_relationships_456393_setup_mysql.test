INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456393_setup_mysql
--echo #
CREATE DATABASE `db_456393_setup_mysql`;
USE `db_456393_setup_mysql`;
CREATE TABLE `protocols` (
  `protocolID` INT NOT NULL,
  `protocolName` VARCHAR(50),
  PRIMARY KEY (`protocolID`)
) CHARACTER SET latin1;
CREATE TABLE `hosts` (
  `hostID` INT NOT NULL,
  `hostName` VARCHAR(50),
  PRIMARY KEY (`hostID`)
) CHARACTER SET latin1;
CREATE TABLE `uris` (
  `uriID` INT NOT NULL,
  `uriName` VARCHAR(50),
  PRIMARY KEY (`uriID`)
) CHARACTER SET latin1;
CREATE TABLE `methods` (
  `methodID` INT NOT NULL,
  `methodName` VARCHAR(50),
  PRIMARY KEY (`methodID`)
) CHARACTER SET latin1;
CREATE TABLE `headers` (
  `headerID` INT NOT NULL,
  `headerName` TEXT,
  `headerValue` TEXT,
  PRIMARY KEY (`headerID`)
) CHARACTER SET latin1;
CREATE TABLE `sourceips` (
  `sourceipID` INT NOT NULL,
  `sourceip` VARCHAR(50),
  PRIMARY KEY (`sourceipID`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
  `jobID` INT NOT NULL,
  `jobName` VARCHAR(50),
  `active` TINYINT,
  `jobStart` DOUBLE,
  `jobStop` DOUBLE,
  `secure` VARCHAR(50),
  `protocol` VARCHAR(50),
  `host` VARCHAR(50),
  `uri` VARCHAR(50),
  `method` VARCHAR(50),
  `sourceip` VARCHAR(50),
  PRIMARY KEY (`jobID`)
) CHARACTER SET latin1;
CREATE TABLE `records` (
  `recordID` INT NOT NULL,
  `utime` DOUBLE,
  `secure` TINYINT,
  `protocol` INT,
  `host` INT,
  `uri` INT,
  `method` INT,
  `sourceip` INT,
  `body` VARCHAR(50),
  PRIMARY KEY (`recordID`)
) CHARACTER SET latin1;
CREATE TABLE `jobrel` (
  `jobID` INT,
  `recordID` INT
) CHARACTER SET latin1;
CREATE TABLE `headerrel` (
  `recordID` INT,
  `headerID` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456393_setup_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456393_setup_mysql') AS relationships;
DROP DATABASE `db_456393_setup_mysql`;
UNINSTALL EXTENSION vsql_schematron;
