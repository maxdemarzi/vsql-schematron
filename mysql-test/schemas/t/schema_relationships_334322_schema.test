INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334322_schema
--echo #
CREATE DATABASE `db_334322_schema`;
USE `db_334322_schema`;
CREATE TABLE `posts` (
  `post_id` INT NOT NULL,
  `title` VARCHAR(50),
  `username` VARCHAR(50),
  `membership` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `message` TEXT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `attachments` (
  `attachment_id` INT NOT NULL,
  `post_id` INT,
  `file` VARCHAR(50),
  `name` VARCHAR(50),
  `size` INT,
  `type` VARCHAR(50),
  PRIMARY KEY (`attachment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334322_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334322_schema') AS relationships;
DROP DATABASE `db_334322_schema`;
UNINSTALL EXTENSION vsql_schematron;
