INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 338315_banco
--echo #
CREATE DATABASE `db_338315_banco`;
USE `db_338315_banco`;
CREATE TABLE `mestre` (
  `id_mestre` INT NOT NULL,
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id_mestre`)
) CHARACTER SET latin1;
CREATE TABLE `detalhe` (
  `id_mestre` INT NOT NULL,
  `id_item` INT NOT NULL,
  `descricao` VARCHAR(50),
  `valor` DECIMAL(10,2),
  PRIMARY KEY (`id_mestre`, `id_item`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_338315_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_338315_banco') AS relationships;
DROP DATABASE `db_338315_banco`;
UNINSTALL EXTENSION vsql_schematron;
