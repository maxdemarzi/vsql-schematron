INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145723_foro
--echo #
CREATE DATABASE `db_145723_foro`;
USE `db_145723_foro`;
CREATE TABLE `users` (
  `name_user` VARCHAR(50) NOT NULL,
  `pass` VARCHAR(50),
  `email` VARCHAR(50),
  `nombre` VARCHAR(50),
  `puntos` INT,
  `estado` BOOLEAN,
  `rango` VARCHAR(50),
  `apellido` VARCHAR(50),
  `fecha` DATETIME,
  `img_perfil` VARCHAR(50),
  `img_portada` VARCHAR(50),
  PRIMARY KEY (`name_user`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `url` VARCHAR(50) NOT NULL,
  `titulo` VARCHAR(50),
  `cuerpo` VARCHAR(50),
  `fecha` DATETIME,
  `user` VARCHAR(50),
  PRIMARY KEY (`url`)
) CHARACTER SET latin1;
CREATE TABLE `comentario` (
  `id_comet` INT NOT NULL,
  `url` VARCHAR(50),
  `fecha` DATETIME,
  `user` VARCHAR(50),
  `contenido` VARCHAR(50),
  PRIMARY KEY (`id_comet`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145723_foro') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145723_foro') AS relationships;
DROP DATABASE `db_145723_foro`;
UNINSTALL EXTENSION vsql_schematron;
