INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319945_migration
--echo #
CREATE DATABASE `db_319945_migration`;
USE `db_319945_migration`;
CREATE TABLE `USERS` (
  `ID` INT NOT NULL,
  `LOGIN` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TOKENS` (
  `ID` INT NOT NULL,
  `USER_ID` INT,
  `TOKEN` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319945_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319945_migration') AS relationships;
DROP DATABASE `db_319945_migration`;
UNINSTALL EXTENSION vsql_schematron;
