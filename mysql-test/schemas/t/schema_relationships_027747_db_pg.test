INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 027747_db_pg
--echo #
CREATE DATABASE `db_027747_db_pg`;
USE `db_027747_db_pg`;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `id` INT NOT NULL,
  `data` DATE,
  `quantidade` INT,
  `cliente_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_027747_db_pg') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_027747_db_pg') AS relationships;
DROP DATABASE `db_027747_db_pg`;
UNINSTALL EXTENSION vsql_schematron;
