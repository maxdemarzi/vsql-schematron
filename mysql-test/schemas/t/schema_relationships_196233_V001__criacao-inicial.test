INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 196233_V001__criacao-inicial
--echo #
CREATE DATABASE `db_196233_V001__criacao_inicial`;
USE `db_196233_V001__criacao_inicial`;
CREATE TABLE `sprint` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `link` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estoria` (
  `id` INT NOT NULL,
  `id_sprint` BIGINT,
  `nome` VARCHAR(50),
  `link` VARCHAR(50),
  `pontuacao` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `desenvolvedor` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voto` (
  `id_estoria` BIGINT NOT NULL,
  `id_desenvolvedor` BIGINT NOT NULL,
  `pontos` INT,
  `data_hora` TIMESTAMP NULL,
  PRIMARY KEY (`id_estoria`, `id_desenvolvedor`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_196233_V001__criacao_inicial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_196233_V001__criacao_inicial') AS relationships;
DROP DATABASE `db_196233_V001__criacao_inicial`;
UNINSTALL EXTENSION vsql_schematron;
