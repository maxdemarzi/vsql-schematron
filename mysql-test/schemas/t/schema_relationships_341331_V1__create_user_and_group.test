INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341331_V1__create_user_and_group
--echo #
CREATE DATABASE `db_341331_V1__create_user_and_group`;
USE `db_341331_V1__create_user_and_group`;
CREATE TABLE `user_entity` (
  `user_id` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `gender` CHAR(50),
  `deleted_flg` CHAR(50),
  `created` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `group_entity` (
  `group_code` VARCHAR(50) NOT NULL,
  `group_name` VARCHAR(50),
  `deleted_flg` CHAR(50),
  `created` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  PRIMARY KEY (`group_code`)
) CHARACTER SET latin1;
CREATE TABLE `user_group_relation` (
  `user_id` VARCHAR(50) NOT NULL,
  `group_code` VARCHAR(50) NOT NULL,
  `deleted_flg` CHAR(50),
  `created` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  PRIMARY KEY (`user_id`, `group_code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341331_V1__create_user_and_group') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341331_V1__create_user_and_group') AS relationships;
DROP DATABASE `db_341331_V1__create_user_and_group`;
UNINSTALL EXTENSION vsql_schematron;
