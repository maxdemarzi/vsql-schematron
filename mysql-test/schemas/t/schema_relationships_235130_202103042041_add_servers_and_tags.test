INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235130_202103042041_add_servers_and_tags
--echo #
CREATE DATABASE `db_235130_202103042041_add_servers_and_tags`;
USE `db_235130_202103042041_add_servers_and_tags`;
CREATE TABLE `servers` (
  `sid` INT NOT NULL,
  `discord_id` BLOB,
  `create_time` TIMESTAMP NULL,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `key` VARCHAR(50) NOT NULL,
  `sid` INT NOT NULL,
  `uid` INT,
  `transfer_uid` INT,
  `value` TEXT,
  `create_time` TIMESTAMP NULL,
  `edit_time` TIMESTAMP NULL,
  PRIMARY KEY (`key`, `sid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_235130_202103042041_add_servers_and_tags') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235130_202103042041_add_servers_and_tags') AS relationships;
DROP DATABASE `db_235130_202103042041_add_servers_and_tags`;
UNINSTALL EXTENSION vsql_schematron;
