INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 477059_3
--echo #
CREATE DATABASE `db_477059_3`;
USE `db_477059_3`;
CREATE TABLE `wiki` (
  `id` INT NOT NULL,
  `title` CHAR(50),
  `language` CHAR(50),
  `canonical` CHAR(50),
  `editable` BOOLEAN,
  `visible` BOOLEAN,
  `group_id` INT,
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wikiversion` (
  `id` INT NOT NULL,
  `date` DATE,
  `content` TEXT,
  `active` BOOLEAN,
  `wiki_id` INT,
  `user_id` INT,
  `image` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wikicomment` (
  `id` INT NOT NULL,
  `title` CHAR(50),
  `content` TEXT,
  `date` DATE,
  `wiki_id` INT,
  `parent_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_477059_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_477059_3') AS relationships;
DROP DATABASE `db_477059_3`;
UNINSTALL EXTENSION vsql_schematron;
