INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543939_db-script
--echo #
CREATE DATABASE `db_543939_db_script`;
USE `db_543939_db_script`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todo` (
  `id` INT NOT NULL,
  `content` TEXT,
  `date` DATETIME,
  `status` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543939_db_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543939_db_script') AS relationships;
DROP DATABASE `db_543939_db_script`;
UNINSTALL EXTENSION vsql_schematron;
