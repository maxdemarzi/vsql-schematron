INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652547_machine_storage
--echo #
CREATE DATABASE `db_652547_machine_storage`;
USE `db_652547_machine_storage`;
CREATE TABLE `engine` (
  `id` INT NOT NULL,
  `engine_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
  `id` INT NOT NULL,
  `trans_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
  `id` INT NOT NULL,
  `model` VARCHAR(50),
  `car_body_id` INT,
  `engine_id` INT,
  `transmission_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652547_machine_storage') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652547_machine_storage') AS relationships;
DROP DATABASE `db_652547_machine_storage`;
UNINSTALL EXTENSION vsql_schematron;
