INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 452453_One-To-One-15-11-2020
--echo #
CREATE DATABASE `db_452453_One_To_One_15_11_2020`;
USE `db_452453_One_To_One_15_11_2020`;
CREATE TABLE `Passports` (
  `id` INT NOT NULL,
  `passport_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Persons` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `passport_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_452453_One_To_One_15_11_2020') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_452453_One_To_One_15_11_2020') AS relationships;
DROP DATABASE `db_452453_One_To_One_15_11_2020`;
UNINSTALL EXTENSION vsql_schematron;
