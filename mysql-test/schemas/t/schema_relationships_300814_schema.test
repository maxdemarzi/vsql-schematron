INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 300814_schema
--echo #
CREATE DATABASE `db_300814_schema`;
USE `db_300814_schema`;
CREATE TABLE `cat` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `content` VARCHAR(50),
  `who` VARCHAR(50),
  `cat_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_300814_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_300814_schema') AS relationships;
DROP DATABASE `db_300814_schema`;
UNINSTALL EXTENSION vsql_schematron;
