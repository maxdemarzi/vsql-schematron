INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 527735_database
--echo #
CREATE DATABASE `db_527735_database`;
USE `db_527735_database`;
CREATE TABLE `users` (
  `userId` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `transactionId` INT NOT NULL,
  `fromUserId` INT,
  `toUserId` INT,
  `amount` INT,
  `account` VARCHAR(50),
  `note` VARCHAR(50),
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`transactionId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_527735_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_527735_database') AS relationships;
DROP DATABASE `db_527735_database`;
UNINSTALL EXTENSION vsql_schematron;
