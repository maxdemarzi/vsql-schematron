INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093152_warship_dump
--echo #
CREATE DATABASE `db_093152_warship_dump`;
USE `db_093152_warship_dump`;
CREATE TABLE `BATTLE` (
  `ID` INT NOT NULL,
  `ACCOUNT_ID` INT,
  `SHIP_ID` INT,
  `EXP` INT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BATTLEHISTORY` (
  `ID` INT NOT NULL,
  `ACCOUNT_ID` INT,
  `BATTLE_ID` INT,
  `LOG` TEXT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RESEARCH` (
  `ID` INT NOT NULL,
  `ACCOUNT_ID` INT,
  `SHIP_ID` INT,
  `EXP` INT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SHIP` (
  `ID` INT NOT NULL,
  `SHIP_ID` INT,
  `NAME` VARCHAR(50),
  `NEXT_SHIP` TEXT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093152_warship_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093152_warship_dump') AS relationships;
DROP DATABASE `db_093152_warship_dump`;
UNINSTALL EXTENSION vsql_schematron;
