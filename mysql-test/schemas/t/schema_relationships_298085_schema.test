INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 298085_schema
--echo #
CREATE DATABASE `db_298085_schema`;
USE `db_298085_schema`;
CREATE TABLE `device` (
  `ip` CHAR(50),
  `mac` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `status` TEXT,
  `quota` DECIMAL(10,2),
  `bandwidth` DECIMAL(10,2),
  `period` DECIMAL(10,2),
  `quota_unit` CHAR(50),
  `bandwidth_unit` CHAR(50),
  `period_unit` CHAR(50),
  PRIMARY KEY (`mac`)
) CHARACTER SET latin1;
CREATE TABLE `period` (
  `start_time` TIMESTAMP NULL,
  `end_time` TIMESTAMP NULL,
  `mac` CHAR(50),
  `passed_bytes` DECIMAL(10,2),
  `dropped_bytes` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_298085_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_298085_schema') AS relationships;
DROP DATABASE `db_298085_schema`;
UNINSTALL EXTENSION vsql_schematron;
