INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646065_MagnetPole
--echo #
CREATE DATABASE `db_646065_MagnetPole`;
USE `db_646065_MagnetPole`;
CREATE TABLE `Magnet` (
  `MagnetAutoCounter` BIGINT NOT NULL,
  PRIMARY KEY (`MagnetAutoCounter`)
) CHARACTER SET latin1;
CREATE TABLE `MagnetPole` (
  `MagnetAutoCounter` BIGINT NOT NULL,
  `IsNorth` BOOLEAN NOT NULL,
  PRIMARY KEY (`MagnetAutoCounter`, `IsNorth`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646065_MagnetPole') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646065_MagnetPole') AS relationships;
DROP DATABASE `db_646065_MagnetPole`;
UNINSTALL EXTENSION vsql_schematron;
