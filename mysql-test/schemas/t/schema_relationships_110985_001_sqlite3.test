INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110985_001.sqlite3
--echo #
CREATE DATABASE `db_110985_001_sqlite3`;
USE `db_110985_001_sqlite3`;
CREATE TABLE `config_buckets` (
  `id` VARCHAR(50) NOT NULL,
  `version` CHAR(50),
  `slug` CHAR(50),
  `title` CHAR(50),
  `description` TEXT,
  `host_id` CHAR(50),
  `access` CHAR(50),
  `schema` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_published` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `config_variables` (
  `id` VARCHAR(50) NOT NULL,
  `version` CHAR(50),
  `bucket_id` CHAR(50),
  `name` CHAR(50),
  `description` TEXT,
  `value` VARCHAR(50),
  `is_locked` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110985_001_sqlite3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110985_001_sqlite3') AS relationships;
DROP DATABASE `db_110985_001_sqlite3`;
UNINSTALL EXTENSION vsql_schematron;
