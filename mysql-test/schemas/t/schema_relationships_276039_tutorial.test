INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276039_tutorial
--echo #
CREATE DATABASE `db_276039_tutorial`;
USE `db_276039_tutorial`;
CREATE TABLE `cities` (
  `abbr` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `LOCATION` VARCHAR(50),
  `create_dt` TIMESTAMP NULL,
  `update_dt` TIMESTAMP NULL,
  PRIMARY KEY (`abbr`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
  `id` INT NOT NULL,
  `city` CHAR(50),
  `date` DATE,
  `temp_lo` INT,
  `temp_hi` INT,
  `prcp` DOUBLE,
  `create_dt` TIMESTAMP NULL,
  `update_dt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276039_tutorial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276039_tutorial') AS relationships;
DROP DATABASE `db_276039_tutorial`;
UNINSTALL EXTENSION vsql_schematron;
