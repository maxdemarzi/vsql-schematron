INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 444110_script
--echo #
CREATE DATABASE `db_444110_script`;
USE `db_444110_script`;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `nickname` VARCHAR(50),
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `idiom` VARCHAR(50),
  `theme_is_night` BOOLEAN,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `makeup` (
  `id_makeup` INT NOT NULL,
  `name` VARCHAR(50),
  `id_brand` INT,
  `id_type` INT,
  PRIMARY KEY (`id_makeup`)
) CHARACTER SET latin1;
CREATE TABLE `brand` (
  `id_brand` INT NOT NULL,
  `name_brand` VARCHAR(50),
  PRIMARY KEY (`id_brand`)
) CHARACTER SET latin1;
CREATE TABLE `type` (
  `id_type` INT NOT NULL,
  `name_type` VARCHAR(50),
  PRIMARY KEY (`id_type`)
) CHARACTER SET latin1;
CREATE TABLE `favorites` (
  `id_favorite` INT NOT NULL,
  `id_user` INT,
  `id_makeup` INT,
  PRIMARY KEY (`id_favorite`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
  `id_location` INT NOT NULL,
  `id_user` INT,
  `id_country` INT,
  `location_city_state` INT,
  `address` VARCHAR(50),
  `district` VARCHAR(50),
  `number` INT,
  `postal_code` VARCHAR(50),
  `correct_position` BOOLEAN,
  PRIMARY KEY (`id_location`)
) CHARACTER SET latin1;
CREATE TABLE `state_city` (
  `id_state_city` INT NOT NULL,
  `name_state` VARCHAR(50),
  `name_city` VARCHAR(50),
  PRIMARY KEY (`id_state_city`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id_country` INT NOT NULL,
  `country` VARCHAR(50),
  PRIMARY KEY (`id_country`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_444110_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_444110_script') AS relationships;
DROP DATABASE `db_444110_script`;
UNINSTALL EXTENSION vsql_schematron;
