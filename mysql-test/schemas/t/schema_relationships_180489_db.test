INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180489_db
--echo #
CREATE DATABASE `db_180489_db`;
USE `db_180489_db`;
CREATE TABLE `commands` (
  `id` INT NOT NULL,
  `device_id` INT,
  `target_name` VARCHAR(50),
  `function_name` VARCHAR(50),
  `ir_command` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `devices` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `devtype` INT,
  `host` VARCHAR(50),
  `mac_address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180489_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180489_db') AS relationships;
DROP DATABASE `db_180489_db`;
UNINSTALL EXTENSION vsql_schematron;
