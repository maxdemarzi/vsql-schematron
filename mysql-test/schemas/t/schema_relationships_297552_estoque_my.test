INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297552_estoque_my
--echo #
CREATE DATABASE `db_297552_estoque_my`;
USE `db_297552_estoque_my`;
CREATE TABLE `categorias` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `nome` CHAR(50),
  `email` VARCHAR(50),
  `cpf` CHAR(50),
  `credito_liberado` CHAR(50),
  `nascimento` DATE,
  `categoria_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `id` INT NOT NULL,
  `cliente_id` INT,
  `data_pedido` DATE,
  `data_confirmacao` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedido_itens` (
  `id` INT NOT NULL,
  `quantidade` INT,
  `preco_venda` DECIMAL(10,2),
  `pedido_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  `unidade` CHAR(50),
  `cadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297552_estoque_my') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297552_estoque_my') AS relationships;
DROP DATABASE `db_297552_estoque_my`;
UNINSTALL EXTENSION vsql_schematron;
