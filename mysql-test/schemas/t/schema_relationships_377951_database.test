INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377951_database
--echo #
CREATE DATABASE `db_377951_database`;
USE `db_377951_database`;
CREATE TABLE `stations` (
  `intIdStation` INT NOT NULL,
  `strName` VARCHAR(50),
  `boolDelete` TINYINT,
  PRIMARY KEY (`intIdStation`)
) CHARACTER SET latin1;
CREATE TABLE `channels` (
  `strIdChannel` VARCHAR(50) NOT NULL,
  `intIdStation` INT,
  `strIdChannelStation` VARCHAR(50),
  `strName` VARCHAR(50),
  `intChannelNumber` INT,
  `boolDelete` TINYINT,
  PRIMARY KEY (`strIdChannel`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `intIdUser` INT NOT NULL,
  `strName` VARCHAR(50),
  `strEmail` VARCHAR(50),
  `strProjectName` VARCHAR(50),
  `strProjectDescription` TEXT,
  `strApiKey` VARCHAR(50),
  `dtaLastUsage` DATETIME,
  `dtaData` DATETIME,
  `boolDelete` TINYINT,
  PRIMARY KEY (`intIdUser`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377951_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377951_database') AS relationships;
DROP DATABASE `db_377951_database`;
UNINSTALL EXTENSION vsql_schematron;
