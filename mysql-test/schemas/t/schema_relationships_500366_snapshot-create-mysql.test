INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 500366_snapshot-create-mysql
--echo #
CREATE DATABASE `db_500366_snapshot_create_mysql`;
USE `db_500366_snapshot_create_mysql`;
CREATE TABLE `snapshot` (
  `id` BIGINT NOT NULL,
  `modified` DATETIME,
  `description` VARCHAR(50),
  `end_date` DATETIME,
  `name` VARCHAR(50),
  `snapshot_date` DATETIME,
  `host` VARCHAR(50),
  `port` INT,
  `space_id` VARCHAR(50),
  `store_id` VARCHAR(50),
  `start_date` DATETIME,
  `status` VARCHAR(50),
  `status_text` VARCHAR(50),
  `user_email` VARCHAR(50),
  `member_id` VARCHAR(50),
  `total_size_in_bytes` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `snapshot_alternate_ids` (
  `snapshot_id` BIGINT,
  `snapshot_alternate_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `snapshot_history` (
  `id` BIGINT NOT NULL,
  `modified` DATETIME,
  `history` VARCHAR(50),
  `history_date` DATETIME,
  `snapshot_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_500366_snapshot_create_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_500366_snapshot_create_mysql') AS relationships;
DROP DATABASE `db_500366_snapshot_create_mysql`;
UNINSTALL EXTENSION vsql_schematron;
