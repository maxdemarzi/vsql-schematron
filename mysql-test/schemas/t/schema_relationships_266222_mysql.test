INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266222_mysql
--echo #
CREATE DATABASE `db_266222_mysql`;
USE `db_266222_mysql`;
CREATE TABLE `USERS` (
  `USERNAME` VARCHAR(50) NOT NULL,
  `PASSWORD` VARCHAR(50),
  `ENABLED` SMALLINT,
  PRIMARY KEY (`USERNAME`)
) CHARACTER SET latin1;
CREATE TABLE `acl_sid` (
  `ID` BIGINT NOT NULL,
  `SID` VARCHAR(50),
  `PRINCIPAL` SMALLINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `acl_class` (
  `ID` BIGINT NOT NULL,
  `CLASS` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `acl_object_identity` (
  `ID` BIGINT NOT NULL,
  `OBJECT_ID_CLASS` BIGINT,
  `OBJECT_ID_IDENTITY` BIGINT,
  `PARENT_OBJECT` BIGINT,
  `OWNER_SID` BIGINT,
  `ENTRIES_INHERITING` SMALLINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `acl_entry` (
  `ID` BIGINT NOT NULL,
  `ACL_OBJECT_IDENTITY` BIGINT,
  `ACE_ORDER` INT,
  `SID` BIGINT,
  `MASK` INT,
  `GRANTING` SMALLINT,
  `AUDIT_SUCCESS` SMALLINT,
  `AUDIT_FAILURE` SMALLINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266222_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266222_mysql') AS relationships;
DROP DATABASE `db_266222_mysql`;
UNINSTALL EXTENSION vsql_schematron;
