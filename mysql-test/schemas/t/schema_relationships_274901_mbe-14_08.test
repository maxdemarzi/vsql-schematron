INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 274901_mbe-14.08
--echo #
CREATE DATABASE `db_274901_mbe_14_08`;
USE `db_274901_mbe_14_08`;
CREATE TABLE `tech_service_request` (
  `tech_service_request_id` INT NOT NULL,
  `type` INT,
  `brand` VARCHAR(50),
  `equipment` VARCHAR(50),
  `model` VARCHAR(50),
  `serial_number` VARCHAR(50),
  `date` DATETIME,
  `end_date` DATETIME,
  `customer` INT,
  `responsible` VARCHAR(50),
  `location` VARCHAR(50),
  `payment_status` VARCHAR(50),
  `shipping_method` VARCHAR(50),
  `contact_name` VARCHAR(50),
  `contact_phone_number` VARCHAR(50),
  `address` VARCHAR(50),
  `remarks` VARCHAR(50),
  `comment` VARCHAR(50),
  PRIMARY KEY (`tech_service_request_id`)
) CHARACTER SET latin1;
CREATE TABLE `tech_service_request_component` (
  `tech_service_request_component_id` INT NOT NULL,
  `request` INT,
  `name` VARCHAR(50),
  `quantity` INT,
  `serial_number` VARCHAR(50),
  `comment` VARCHAR(50),
  PRIMARY KEY (`tech_service_request_component_id`)
) CHARACTER SET latin1;
CREATE TABLE `tech_service_receipt` (
  `tech_service_receipt_id` INT NOT NULL,
  `brand` VARCHAR(50),
  `equipment` VARCHAR(50),
  `model` VARCHAR(50),
  `serial_number` VARCHAR(50),
  `date` DATETIME,
  `status` VARCHAR(50),
  `location` VARCHAR(50),
  `checker` VARCHAR(50),
  `comment` VARCHAR(50),
  PRIMARY KEY (`tech_service_receipt_id`)
) CHARACTER SET latin1;
CREATE TABLE `tech_service_receipt_component` (
  `tech_service_receipt_component_id` INT NOT NULL,
  `receipt` INT,
  `name` VARCHAR(50),
  `quantity` INT,
  `serial_number` VARCHAR(50),
  `comment` VARCHAR(50),
  PRIMARY KEY (`tech_service_receipt_component_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_274901_mbe_14_08') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_274901_mbe_14_08') AS relationships;
DROP DATABASE `db_274901_mbe_14_08`;
UNINSTALL EXTENSION vsql_schematron;
