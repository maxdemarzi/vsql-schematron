INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 662852_demo
--echo #
CREATE DATABASE `db_662852_demo`;
USE `db_662852_demo`;
CREATE TABLE `Countries` (
  `country_ID` INT NOT NULL,
  `name` VARCHAR(50),
  `population` INT,
  PRIMARY KEY (`country_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Persons` (
  `person_ID` INT NOT NULL,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `address` VARCHAR(50),
  `city_ID` INT,
  `country_ID` INT,
  PRIMARY KEY (`person_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Cities` (
  `city_ID` INT NOT NULL,
  `city_name` VARCHAR(50),
  `country_ID` INT,
  `population` INT,
  PRIMARY KEY (`city_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_662852_demo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_662852_demo') AS relationships;
DROP DATABASE `db_662852_demo`;
UNINSTALL EXTENSION vsql_schematron;
