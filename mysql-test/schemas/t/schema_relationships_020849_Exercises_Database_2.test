INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020849_Exercises_Database_2
--echo #
CREATE DATABASE `db_020849_Exercises_Database_2`;
USE `db_020849_Exercises_Database_2`;
CREATE TABLE `Students` (
  `StudentID` INT NOT NULL,
  `StudentName` VARCHAR(50),
  `Address` VARCHAR(50),
  PRIMARY KEY (`StudentID`)
) CHARACTER SET latin1;
CREATE TABLE `Courses` (
  `CourseID` INT NOT NULL,
  `CourseName` VARCHAR(50),
  PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;
CREATE TABLE `CourseEnrollment` (
  `CourseID` INT NOT NULL,
  `StudentID` INT NOT NULL,
  `Grade` DECIMAL(10,2),
  `Term` INT,
  PRIMARY KEY (`CourseID`, `StudentID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020849_Exercises_Database_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020849_Exercises_Database_2') AS relationships;
DROP DATABASE `db_020849_Exercises_Database_2`;
UNINSTALL EXTENSION vsql_schematron;
