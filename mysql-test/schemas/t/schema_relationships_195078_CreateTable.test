INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195078_CreateTable
--echo #
CREATE DATABASE `db_195078_CreateTable`;
USE `db_195078_CreateTable`;
CREATE TABLE `Employees` (
  `user_id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `dept` VARCHAR(50),
  `is_admin` TINYINT,
  `is_system_admin` TINYINT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Reservations` (
  `user_id` VARCHAR(50) NOT NULL,
  `desk_id` INT NOT NULL,
  `from_date` TIMESTAMP NOT NULL,
  `to_date` TIMESTAMP NOT NULL,
  PRIMARY KEY (`user_id`, `desk_id`, `from_date`, `to_date`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195078_CreateTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195078_CreateTable') AS relationships;
DROP DATABASE `db_195078_CreateTable`;
UNINSTALL EXTENSION vsql_schematron;
