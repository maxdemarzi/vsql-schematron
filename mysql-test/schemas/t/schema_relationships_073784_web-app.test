INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 073784_web-app
--echo #
CREATE DATABASE `db_073784_web_app`;
USE `db_073784_web_app`;
CREATE TABLE `scores` (
  `student-id` VARCHAR(50),
  `points` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `section` VARCHAR(50),
  `student-id` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`student-id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_073784_web_app') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_073784_web_app') AS relationships;
DROP DATABASE `db_073784_web_app`;
UNINSTALL EXTENSION vsql_schematron;
