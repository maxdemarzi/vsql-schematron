INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464523_auth
--echo #
CREATE DATABASE `db_464523_auth`;
USE `db_464523_auth`;
CREATE TABLE `user` (
  `created_at` TIMESTAMP NULL,
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `privilege` (
  `created_at` TIMESTAMP NULL,
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_privelege` (
  `user` INT,
  `created_at` TIMESTAMP NULL,
  `id` INT NOT NULL,
  `privilege` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_companies` (
  `user` INT,
  `created_at` TIMESTAMP NULL,
  `id` INT NOT NULL,
  `company` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464523_auth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464523_auth') AS relationships;
DROP DATABASE `db_464523_auth`;
UNINSTALL EXTENSION vsql_schematron;
