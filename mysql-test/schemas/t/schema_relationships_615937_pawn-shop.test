INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 615937_pawn-shop
--echo #
CREATE DATABASE `db_615937_pawn_shop`;
USE `db_615937_pawn_shop`;
CREATE TABLE `client` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `identity_number` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `country` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contract_item_type` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contract` (
  `id` INT NOT NULL,
  `client_id` INT,
  `amount` DECIMAL(10,2),
  `release_date` DATE,
  `released` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contract_item` (
  `id` INT NOT NULL,
  `contract_id` INT,
  `type` INT,
  `value` DECIMAL(10,2),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_615937_pawn_shop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_615937_pawn_shop') AS relationships;
DROP DATABASE `db_615937_pawn_shop`;
UNINSTALL EXTENSION vsql_schematron;
