INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 391290_db
--echo #
CREATE DATABASE `db_391290_db`;
USE `db_391290_db`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `nombrecompleto` VARCHAR(50),
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
  `id` INT NOT NULL,
  `titulo` VARCHAR(50),
  `url` VARCHAR(50),
  `descripcion` TEXT,
  `usuario_id` INT,
  `creado` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_391290_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_391290_db') AS relationships;
DROP DATABASE `db_391290_db`;
UNINSTALL EXTENSION vsql_schematron;
