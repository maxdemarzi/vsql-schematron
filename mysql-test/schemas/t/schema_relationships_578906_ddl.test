INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 578906_ddl
--echo #
CREATE DATABASE `db_578906_ddl`;
USE `db_578906_ddl`;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` VARCHAR(50),
  `phone_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `credit_cards` (
  `id` INT NOT NULL,
  `provider` VARCHAR(50),
  `number` VARCHAR(50),
  `security_code` VARCHAR(50),
  `expiry_date` VARCHAR(50),
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_578906_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_578906_ddl') AS relationships;
DROP DATABASE `db_578906_ddl`;
UNINSTALL EXTENSION vsql_schematron;
