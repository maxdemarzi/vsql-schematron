INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 346537_SqlCreate
--echo #
CREATE DATABASE `db_346537_SqlCreate`;
USE `db_346537_SqlCreate`;
CREATE TABLE `word_type` (
  `ID` INT NOT NULL,
  `word_type` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRAVA` (
  `ID` INT NOT NULL,
  `NAZEV` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRAVAXSKUPINAPRAV` (
  `ID` INT NOT NULL,
  `fk_prava` INT,
  `fk_skupinaprav` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UZIVATEL` (
  `ID` INT NOT NULL,
  `JMENO` VARCHAR(50),
  `PRIJMENI` VARCHAR(50),
  `fk_skupinaprav` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SKUPINAPRAV` (
  `ID` INT NOT NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_346537_SqlCreate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_346537_SqlCreate') AS relationships;
DROP DATABASE `db_346537_SqlCreate`;
UNINSTALL EXTENSION vsql_schematron;
