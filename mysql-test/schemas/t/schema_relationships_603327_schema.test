INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 603327_schema
--echo #
CREATE DATABASE `db_603327_schema`;
USE `db_603327_schema`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `slogan` VARCHAR(50),
  `description` TEXT,
  `category` VARCHAR(50),
  `default_price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `features` (
  `id` INT NOT NULL,
  `productId` INT,
  `feature` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
  `id` INT NOT NULL,
  `productId` INT,
  `name` VARCHAR(50),
  `sale_price` INT,
  `original_price` INT,
  `default_style` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
  `id` INT NOT NULL,
  `styleId` INT,
  `url` TEXT,
  `thumbnail_url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skus` (
  `id` INT NOT NULL,
  `styleId` INT,
  `size` VARCHAR(50),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `related` (
  `id` INT NOT NULL,
  `current_product_id` INT,
  `related_product_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_603327_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_603327_schema') AS relationships;
DROP DATABASE `db_603327_schema`;
UNINSTALL EXTENSION vsql_schematron;
