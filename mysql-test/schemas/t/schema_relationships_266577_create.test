INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266577_create
--echo #
CREATE DATABASE `db_266577_create`;
USE `db_266577_create`;
CREATE TABLE `languages` (
  `language` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`language`)
) CHARACTER SET latin1;
CREATE TABLE `pastes` (
  `id` BIGINT,
  `title` VARCHAR(50),
  `text` TEXT,
  `created_at` TIMESTAMP NULL,
  `expires_at` TIMESTAMP NULL,
  `language` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266577_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266577_create') AS relationships;
DROP DATABASE `db_266577_create`;
UNINSTALL EXTENSION vsql_schematron;
