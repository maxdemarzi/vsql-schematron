INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 185947_database
--echo #
CREATE DATABASE `db_185947_database`;
USE `db_185947_database`;
CREATE TABLE `rol` (
  `id_rol` INT NOT NULL,
  `nombre` VARCHAR(50),
  `estado` INT,
  PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `salt` VARCHAR(50),
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `direccion` VARCHAR(50),
  `email` VARCHAR(50),
  `estado` INT,
  `rol_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185947_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185947_database') AS relationships;
DROP DATABASE `db_185947_database`;
UNINSTALL EXTENSION vsql_schematron;
