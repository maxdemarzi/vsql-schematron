INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505939_dbSchema
--echo #
CREATE DATABASE `db_505939_dbSchema`;
USE `db_505939_dbSchema`;
CREATE TABLE `applications` (
  `id` INT NOT NULL,
  `job_seeker_id` INT,
  `company` VARCHAR(50),
  `job_title` VARCHAR(50),
  `how_applied` VARCHAR(50),
  `date_applied` DATE,
  `location` VARCHAR(50),
  `found_by` VARCHAR(50),
  `notes` VARCHAR(50),
  `app_status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job_seekers` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `cur_salary` INT,
  `dob` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_statuses` (
  `id` INT NOT NULL,
  `app_status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `id` INT NOT NULL,
  `app_id` INT,
  `date` DATE,
  `step_type` VARCHAR(50),
  `contact_name` VARCHAR(50),
  `contact_role` VARCHAR(50),
  `contact` VARCHAR(50),
  `notes` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505939_dbSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505939_dbSchema') AS relationships;
DROP DATABASE `db_505939_dbSchema`;
UNINSTALL EXTENSION vsql_schematron;
