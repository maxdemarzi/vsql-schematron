INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518524_init_db
--echo #
CREATE DATABASE `db_518524_init_db`;
USE `db_518524_init_db`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `nickname` VARCHAR(50),
  `reg_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `decks` (
  `id` SMALLINT NOT NULL,
  `alias` VARCHAR(50),
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
  `id` BIGINT NOT NULL,
  `description` VARCHAR(50),
  `deck_id` SMALLINT,
  `owner_id` INT,
  `started_at` TIMESTAMP NULL,
  `revealed_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
  `id` BIGINT NOT NULL,
  `game_id` BIGINT,
  `user_id` INT,
  `choice` SMALLINT,
  `voted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518524_init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518524_init_db') AS relationships;
DROP DATABASE `db_518524_init_db`;
UNINSTALL EXTENSION vsql_schematron;
