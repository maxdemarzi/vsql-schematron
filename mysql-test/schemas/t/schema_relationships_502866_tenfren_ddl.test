INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 502866_tenfren.ddl
--echo #
CREATE DATABASE `db_502866_tenfren_ddl`;
USE `db_502866_tenfren_ddl`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `screen_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `token_key` VARCHAR(50),
  `last_login_timestamp` TIMESTAMP NULL,
  `failed_login_attempts` INT,
  `lockout_time` TIMESTAMP NULL,
  `active` BOOLEAN,
  `created_timestamp` TIMESTAMP NULL,
  `created_user` VARCHAR(50),
  `modified_timestamp` TIMESTAMP NULL,
  `modified_user` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `account_id` INT,
  `name` VARCHAR(50),
  `active` BOOLEAN,
  `created_timestamp` TIMESTAMP NULL,
  `created_user` VARCHAR(50),
  `modified_timestamp` TIMESTAMP NULL,
  `modified_user` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_502866_tenfren_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_502866_tenfren_ddl') AS relationships;
DROP DATABASE `db_502866_tenfren_ddl`;
UNINSTALL EXTENSION vsql_schematron;
