INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 622831_V1__intialisation
--echo #
CREATE DATABASE `db_622831_V1__intialisation`;
USE `db_622831_V1__intialisation`;
CREATE TABLE `tokens` (
  `id` VARCHAR(50) NOT NULL,
  `hash` VARCHAR(50),
  `creation_date` TIMESTAMP NULL,
  `expiration_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `refresh_token_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_622831_V1__intialisation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_622831_V1__intialisation') AS relationships;
DROP DATABASE `db_622831_V1__intialisation`;
UNINSTALL EXTENSION vsql_schematron;
