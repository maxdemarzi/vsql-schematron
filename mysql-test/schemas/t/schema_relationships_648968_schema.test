INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648968_schema
--echo #
CREATE DATABASE `db_648968_schema`;
USE `db_648968_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` CHAR(50),
  `score` DECIMAL(10,2),
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_profile` (
  `user_id` INT,
  `firstname` CHAR(50),
  `lastname` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `actions` (
  `id` INT NOT NULL,
  `description` TEXT,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648968_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648968_schema') AS relationships;
DROP DATABASE `db_648968_schema`;
UNINSTALL EXTENSION vsql_schematron;
