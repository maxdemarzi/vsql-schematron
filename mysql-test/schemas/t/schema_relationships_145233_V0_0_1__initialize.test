INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145233_V0_0_1__initialize
--echo #
CREATE DATABASE `db_145233_V0_0_1__initialize`;
USE `db_145233_V0_0_1__initialize`;
CREATE TABLE `Role` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `label` VARCHAR(50),
  `ordinal` INT,
  `effectiveAt` DATETIME,
  `expiresAt` DATETIME,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AccountRole` (
  `accountId` BIGINT NOT NULL,
  `roleId` BIGINT NOT NULL,
  PRIMARY KEY (`accountId`, `roleId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145233_V0_0_1__initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145233_V0_0_1__initialize') AS relationships;
DROP DATABASE `db_145233_V0_0_1__initialize`;
UNINSTALL EXTENSION vsql_schematron;
