INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 208376_migration
--echo #
CREATE DATABASE `db_208376_migration`;
USE `db_208376_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `accessToken` TEXT,
  `weatherUsed` BOOLEAN,
  `githubUsed` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WeatherWidget` (
  `id` VARCHAR(50) NOT NULL,
  `param` TEXT,
  `timer` INT,
  `weather` VARCHAR(50),
  `userId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GithubWidget` (
  `id` VARCHAR(50) NOT NULL,
  `repo` TEXT,
  `timer` INT,
  `userId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_208376_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_208376_migration') AS relationships;
DROP DATABASE `db_208376_migration`;
UNINSTALL EXTENSION vsql_schematron;
