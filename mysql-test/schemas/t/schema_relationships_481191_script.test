INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 481191_script
--echo #
CREATE DATABASE `db_481191_script`;
USE `db_481191_script`;
CREATE TABLE `titulos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `tema` VARCHAR(50),
  `texto` VARCHAR(50),
  `id_titulos` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_481191_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_481191_script') AS relationships;
DROP DATABASE `db_481191_script`;
UNINSTALL EXTENSION vsql_schematron;
