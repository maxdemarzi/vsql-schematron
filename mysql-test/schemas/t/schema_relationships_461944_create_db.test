INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 461944_create_db
--echo #
CREATE DATABASE `db_461944_create_db`;
USE `db_461944_create_db`;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `id` INT NOT NULL,
  `make` VARCHAR(50),
  `model` VARCHAR(50),
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `customer_id` INT,
  `car_id` INT,
  `order_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_461944_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_461944_create_db') AS relationships;
DROP DATABASE `db_461944_create_db`;
UNINSTALL EXTENSION vsql_schematron;
