INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455908_initializeTables
--echo #
CREATE DATABASE `db_455908_initializeTables`;
USE `db_455908_initializeTables`;
CREATE TABLE `mydata1.Vanzator` (
  `ID` VARCHAR(50) NOT NULL,
  `Nume` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `mydata1.Cumparator` (
  `ID_vanz` CHAR(50),
  `ID` INT NOT NULL,
  `Nume` CHAR(50),
  `Ramura` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455908_initializeTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455908_initializeTables') AS relationships;
DROP DATABASE `db_455908_initializeTables`;
UNINSTALL EXTENSION vsql_schematron;
