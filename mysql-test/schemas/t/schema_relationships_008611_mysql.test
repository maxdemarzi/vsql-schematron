INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008611_mysql
--echo #
CREATE DATABASE `db_008611_mysql`;
USE `db_008611_mysql`;
CREATE TABLE `project` (
  `project_id` VARCHAR(50) NOT NULL,
  `project_code` VARCHAR(50),
  `project_name` VARCHAR(50),
  `pi` VARCHAR(50),
  `institution` VARCHAR(50),
  `project_type` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `sample` (
  `sample_id` VARCHAR(50) NOT NULL,
  `project_id` VARCHAR(50),
  `sample_acc` VARCHAR(50),
  `sample_type` VARCHAR(50),
  `sample_volume` VARCHAR(50),
  `volume_unit` VARCHAR(50),
  `filter_min` VARCHAR(50),
  `filter_max` VARCHAR(50),
  `sample_description` VARCHAR(50),
  `sample_name` VARCHAR(50),
  `comments` VARCHAR(50),
  `taxon_id` VARCHAR(50),
  `collection_start_time` VARCHAR(50),
  `collection_stop_time` VARCHAR(50),
  `biomaterial_name` VARCHAR(50),
  `description` VARCHAR(50),
  `material_acc` VARCHAR(50),
  `site_name` VARCHAR(50),
  `latitude` VARCHAR(50),
  `longitude` VARCHAR(50),
  `altitude` VARCHAR(50),
  `site_depth` VARCHAR(50),
  `site_description` VARCHAR(50),
  `country_name` VARCHAR(50),
  `region` VARCHAR(50),
  `habitat_name` VARCHAR(50),
  `host_taxon_id` VARCHAR(50),
  `host_description` VARCHAR(50),
  `host_organism` VARCHAR(50),
  `library_acc` VARCHAR(50),
  `sequencing_method` VARCHAR(50),
  `dna_type` VARCHAR(50),
  `num_of_reads` VARCHAR(50),
  `material_id` VARCHAR(50),
  `other` VARCHAR(50),
  PRIMARY KEY (`sample_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008611_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008611_mysql') AS relationships;
DROP DATABASE `db_008611_mysql`;
UNINSTALL EXTENSION vsql_schematron;
