INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 478053_schema
--echo #
CREATE DATABASE `db_478053_schema`;
USE `db_478053_schema`;
CREATE TABLE `author` (
  `author_name` VARCHAR(50) NOT NULL,
  `icon_url` VARCHAR(50),
  PRIMARY KEY (`author_name`)
) CHARACTER SET latin1;
CREATE TABLE `submission` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `author_name` VARCHAR(50),
  `rating` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_478053_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_478053_schema') AS relationships;
DROP DATABASE `db_478053_schema`;
UNINSTALL EXTENSION vsql_schematron;
