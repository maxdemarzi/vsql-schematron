INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376623_migration
--echo #
CREATE DATABASE `db_376623_migration`;
USE `db_376623_migration`;
CREATE TABLE `Coach` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `handle` TEXT,
  `name` TEXT,
  `type` TEXT,
  `isAssistant` TEXT,
  `teamId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ColorScheme` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `primary` TEXT,
  `secondary` TEXT,
  `teamId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Player` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `handle` TEXT,
  `name` TEXT,
  `slug` TEXT,
  `height` TEXT,
  `weight` TEXT,
  `number` TEXT,
  `position` TEXT,
  `teamId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Team` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `handle` TEXT,
  `name` TEXT,
  `slug` TEXT,
  `city` TEXT,
  `abbreviation` TEXT,
  `logo` TEXT,
  `logoSlug` TEXT,
  `wins` INT,
  `losses` INT,
  `winPercentage` DOUBLE,
  `conference` TEXT,
  `division` TEXT,
  `established` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376623_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376623_migration') AS relationships;
DROP DATABASE `db_376623_migration`;
UNINSTALL EXTENSION vsql_schematron;
