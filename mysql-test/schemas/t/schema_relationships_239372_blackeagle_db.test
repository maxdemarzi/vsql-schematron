INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239372_blackeagle_db
--echo #
CREATE DATABASE `db_239372_blackeagle_db`;
USE `db_239372_blackeagle_db`;
CREATE TABLE `admins` (
  `admin_id` INT NOT NULL,
  `admin_name` VARCHAR(50),
  `admin_surname` VARCHAR(50),
  `admin_username` VARCHAR(50),
  `admin_email` VARCHAR(50),
  `admin_password` VARCHAR(50),
  `admin_mobile_number` VARCHAR(50),
  PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;
CREATE TABLE `pins` (
  `pin_id` INT,
  `user_id` INT,
  `latitude` VARCHAR(50),
  `longitude` VARCHAR(50),
  `role` TINYINT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `randsalt` (
  `randSalt` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
  `report_id` INT,
  `user_id` INT,
  `report_name` VARCHAR(50),
  `report_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `user_surname` VARCHAR(50),
  `user_password` VARCHAR(50),
  `user_role` TINYINT,
  `user_email` VARCHAR(50),
  `user_mobile_number` VARCHAR(50),
  `user_organization_name` VARCHAR(50),
  `user_organization_number` VARCHAR(50),
  `verified` TINYINT,
  `approved` TINYINT,
  `removed` TINYINT,
  `token` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239372_blackeagle_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239372_blackeagle_db') AS relationships;
DROP DATABASE `db_239372_blackeagle_db`;
UNINSTALL EXTENSION vsql_schematron;
