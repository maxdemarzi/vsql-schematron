INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524036_Refget-Schema-1.0.0-SQLite
--echo #
CREATE DATABASE `db_524036_Refget_Schema_1_0_0_SQLite`;
USE `db_524036_Refget_Schema_1_0_0_SQLite`;
CREATE TABLE `division` (
  `division_id` INT NOT NULL,
  `division` VARCHAR(50),
  PRIMARY KEY (`division_id`)
) CHARACTER SET latin1;
CREATE TABLE `mol_type` (
  `mol_type_id` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`mol_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_seq` (
  `checksum` VARCHAR(50) NOT NULL,
  `seq` TEXT,
  PRIMARY KEY (`checksum`)
) CHARACTER SET latin1;
CREATE TABLE `seq` (
  `seq_id` INT NOT NULL,
  `md5` CHAR(50),
  `trunc512` CHAR(50),
  `size` INT,
  `circular` INT,
  PRIMARY KEY (`seq_id`)
) CHARACTER SET latin1;
CREATE TABLE `source` (
  `source_id` INT NOT NULL,
  `source` VARCHAR(50),
  PRIMARY KEY (`source_id`)
) CHARACTER SET latin1;
CREATE TABLE `species` (
  `species_id` INT NOT NULL,
  `species` VARCHAR(50),
  `assembly` VARCHAR(50),
  PRIMARY KEY (`species_id`)
) CHARACTER SET latin1;
CREATE TABLE `release` (
  `release_id` INT NOT NULL,
  `release` INT,
  `division_id` INT,
  `species_id` INT,
  PRIMARY KEY (`release_id`)
) CHARACTER SET latin1;
CREATE TABLE `molecule` (
  `molecule_id` INT NOT NULL,
  `seq_id` INT,
  `release_id` INT,
  `id` VARCHAR(50),
  `first_seen` INT,
  `mol_type_id` INT,
  `version` INT,
  `source_id` INT,
  PRIMARY KEY (`molecule_id`)
) CHARACTER SET latin1;
CREATE TABLE `synonym` (
  `synonym_id` INT NOT NULL,
  `molecule_id` INT,
  `source_id` INT,
  `synonym` VARCHAR(50),
  PRIMARY KEY (`synonym_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524036_Refget_Schema_1_0_0_SQLite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524036_Refget_Schema_1_0_0_SQLite') AS relationships;
DROP DATABASE `db_524036_Refget_Schema_1_0_0_SQLite`;
UNINSTALL EXTENSION vsql_schematron;
