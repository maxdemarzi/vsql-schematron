CREATE DATABASE `db_436407_V1_016__create_credit_cards`;
USE `db_436407_V1_016__create_credit_cards`;
CREATE TABLE `credit_cards` (
  `id` INT NOT NULL,
  `parent_id` INT,
  `customer_id` INT,
  `gateway_customer_id` VARCHAR(50),
  `gateway_card_id` VARCHAR(50),
  `holder_name` VARCHAR(50),
  `last_four` CHAR(50),
  `exp_month` INT,
  `exp_year` INT,
  `brand` VARCHAR(50),
  `is_default` BOOLEAN,
  `address1_check` VARCHAR(50),
  `zip_check` VARCHAR(50),
  `in_wallet` BOOLEAN,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  `region_id` INT,
  `address_name` VARCHAR(50),
  `address1` VARCHAR(50),
  `address2` VARCHAR(50),
  `city` VARCHAR(50),
  `zip` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_436407_V1_016__create_credit_cards') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_436407_V1_016__create_credit_cards') AS relationships;
DROP DATABASE `db_436407_V1_016__create_credit_cards`;
