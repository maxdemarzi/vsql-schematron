INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499217_reviewersMovie
--echo #
CREATE DATABASE `db_499217_reviewersMovie`;
USE `db_499217_reviewersMovie`;
CREATE TABLE `reviewer` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `release_year` INT,
  `genre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
  `id` INT NOT NULL,
  `rating` DECIMAL(10,2),
  `series_id` INT,
  `reviewer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499217_reviewersMovie') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499217_reviewersMovie') AS relationships;
DROP DATABASE `db_499217_reviewersMovie`;
UNINSTALL EXTENSION vsql_schematron;
