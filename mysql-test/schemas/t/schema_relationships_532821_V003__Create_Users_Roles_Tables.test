INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532821_V003__Create_Users_Roles_Tables
--echo #
CREATE DATABASE `db_532821_V003__Create_Users_Roles_Tables`;
USE `db_532821_V003__Create_Users_Roles_Tables`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `enabled` INT,
  `password` VARCHAR(50),
  `created` DATETIME,
  `last_login` DATETIME,
  `last_modified` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `role_id` INT NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532821_V003__Create_Users_Roles_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532821_V003__Create_Users_Roles_Tables') AS relationships;
DROP DATABASE `db_532821_V003__Create_Users_Roles_Tables`;
UNINSTALL EXTENSION vsql_schematron;
