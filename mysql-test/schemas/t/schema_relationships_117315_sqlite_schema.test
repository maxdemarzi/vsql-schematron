INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 117315_sqlite_schema
--echo #
CREATE DATABASE `db_117315_sqlite_schema`;
USE `db_117315_sqlite_schema`;
CREATE TABLE `notebooks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `parent_id` INT,
  `description` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `note_tags` (
  `id` INT NOT NULL,
  `tag_id` INT,
  `note_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `note_tag_id` INT,
  `notebook_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_markdown` INT,
  `local_uuid` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `remark` VARCHAR(50),
  `finished_at` DATETIME,
  `is_finished` INT,
  `note_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `group` VARCHAR(50),
  `priority` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_117315_sqlite_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_117315_sqlite_schema') AS relationships;
DROP DATABASE `db_117315_sqlite_schema`;
UNINSTALL EXTENSION vsql_schematron;
