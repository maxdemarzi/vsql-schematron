INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358637_LabExam
--echo #
CREATE DATABASE `db_358637_LabExam`;
USE `db_358637_LabExam`;
CREATE TABLE `Customer` (
  `custID` INT NOT NULL,
  `custName` VARCHAR(50),
  `custPhone` INT,
  `custEmail` VARCHAR(50),
  PRIMARY KEY (`custID`)
) CHARACTER SET latin1;
CREATE TABLE `Species` (
  `SpeciesCode` VARCHAR(50) NOT NULL,
  `speciesName` VARCHAR(50),
  `speciesPrice` DECIMAL(10,2),
  PRIMARY KEY (`SpeciesCode`)
) CHARACTER SET latin1;
CREATE TABLE `Animal` (
  `animalID` VARCHAR(50) NOT NULL,
  `SpeciesCode` VARCHAR(50),
  `dateShopPurchased` CHAR(50),
  `animalName` VARCHAR(50),
  PRIMARY KEY (`animalID`)
) CHARACTER SET latin1;
CREATE TABLE `AnimalSale` (
  `custID` INT NOT NULL,
  `animalID` VARCHAR(50) NOT NULL,
  `saleDate` DATE,
  PRIMARY KEY (`custID`, `animalID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358637_LabExam') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358637_LabExam') AS relationships;
DROP DATABASE `db_358637_LabExam`;
UNINSTALL EXTENSION vsql_schematron;
