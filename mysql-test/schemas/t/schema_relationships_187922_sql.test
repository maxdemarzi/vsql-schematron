INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187922_sql
--echo #
CREATE DATABASE `db_187922_sql`;
USE `db_187922_sql`;
CREATE TABLE `accounts` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `name` TEXT,
  `age` VARCHAR(50),
  `gender` VARCHAR(50),
  `account_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operators` (
  `account_id` VARCHAR(50),
  `case_number` VARCHAR(50),
  `business_permit` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `driver` (
  `account_id` VARCHAR(50),
  `prof_driver_license` VARCHAR(50),
  `vehicle_or` VARCHAR(50),
  `taxi_plate_num` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187922_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187922_sql') AS relationships;
DROP DATABASE `db_187922_sql`;
UNINSTALL EXTENSION vsql_schematron;
