INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 074632_seedWegotSidebar
--echo #
CREATE DATABASE `db_074632_seedWegotSidebar`;
USE `db_074632_seedWegotSidebar`;
CREATE TABLE `places` (
  `place_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `formatted_address` VARCHAR(50),
  `international_phone_number` VARCHAR(50),
  `website` TEXT,
  `url` TEXT,
  `open_now` BOOLEAN,
  `lat` DOUBLE,
  `lon` DOUBLE,
  PRIMARY KEY (`place_id`)
) CHARACTER SET latin1;
CREATE TABLE `openhours` (
  `place_id` VARCHAR(50),
  `openday` INT,
  `opentime` INT,
  `closeday` INT,
  `closetime` INT,
  `weekday_text` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_074632_seedWegotSidebar') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_074632_seedWegotSidebar') AS relationships;
DROP DATABASE `db_074632_seedWegotSidebar`;
UNINSTALL EXTENSION vsql_schematron;
