INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364131_01_init
--echo #
CREATE DATABASE `db_364131_01_init`;
USE `db_364131_01_init`;
CREATE TABLE `stations` (
  `no` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `area` TEXT,
  `address` TEXT,
  `total` INT,
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  PRIMARY KEY (`no`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
  `no` VARCHAR(50) NOT NULL,
  `time` INT NOT NULL,
  `number_of_available_vehicles` INT,
  `number_of_available_parking_space` INT,
  `is_servicing` INT,
  PRIMARY KEY (`no`, `time`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364131_01_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364131_01_init') AS relationships;
DROP DATABASE `db_364131_01_init`;
UNINSTALL EXTENSION vsql_schematron;
