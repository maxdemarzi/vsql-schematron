INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160660_4
--echo #
CREATE DATABASE `db_160660_4`;
USE `db_160660_4`;
CREATE TABLE `PARTT` (
  `PNO` VARCHAR(50) NOT NULL,
  `PNAME` VARCHAR(50),
  `COLOUR` VARCHAR(50),
  PRIMARY KEY (`PNO`)
) CHARACTER SET latin1;
CREATE TABLE `WAREHOUSE` (
  `WNO` VARCHAR(50) NOT NULL,
  `WNAME` VARCHAR(50),
  `CITY` VARCHAR(50),
  PRIMARY KEY (`WNO`)
) CHARACTER SET latin1;
CREATE TABLE `SHIPMENT` (
  `PNO` VARCHAR(50),
  `WNO` VARCHAR(50),
  `QUANTITY` DECIMAL(10,2),
  `DATEE` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160660_4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160660_4') AS relationships;
DROP DATABASE `db_160660_4`;
UNINSTALL EXTENSION vsql_schematron;
