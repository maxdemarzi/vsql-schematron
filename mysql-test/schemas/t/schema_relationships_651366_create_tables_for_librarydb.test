INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 651366_create_tables_for_librarydb
--echo #
CREATE DATABASE `db_651366_create_tables_for_librarydb`;
USE `db_651366_create_tables_for_librarydb`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `book_id` INT NOT NULL,
  `name` VARCHAR(50),
  `isbn` VARCHAR(50),
  `author` VARCHAR(50),
  `date_released` DATE,
  `published_by` VARCHAR(50),
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `books_lent` (
  `lent_id` INT NOT NULL,
  `user_id` INT,
  `book_id` INT,
  `lent_from` DATE,
  `lent_until` DATE,
  PRIMARY KEY (`lent_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_651366_create_tables_for_librarydb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_651366_create_tables_for_librarydb') AS relationships;
DROP DATABASE `db_651366_create_tables_for_librarydb`;
UNINSTALL EXTENSION vsql_schematron;
