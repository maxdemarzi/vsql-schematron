INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 309770_roles-and-permissions
--echo #
CREATE DATABASE `db_309770_roles_and_permissions`;
USE `db_309770_roles_and_permissions`;
CREATE TABLE `Permissions` (
  `id` VARCHAR(50) NOT NULL,
  `label` TEXT,
  `permission` TEXT,
  `type` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Role_permissions` (
  `role_id` BIGINT,
  `permission_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_309770_roles_and_permissions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_309770_roles_and_permissions') AS relationships;
DROP DATABASE `db_309770_roles_and_permissions`;
UNINSTALL EXTENSION vsql_schematron;
