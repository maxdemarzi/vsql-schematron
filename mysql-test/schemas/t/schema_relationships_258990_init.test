INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258990_init
--echo #
CREATE DATABASE `db_258990_init`;
USE `db_258990_init`;
CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(50) NOT NULL,
  `ProductVersion` CHAR(50),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
  `Id` INT NOT NULL,
  `Name` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `Id` VARCHAR(50) NOT NULL,
  `Username` TEXT,
  `PasswordHash` VARCHAR(50),
  `PasswordHashingKey` VARCHAR(50),
  `RoleId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258990_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258990_init') AS relationships;
DROP DATABASE `db_258990_init`;
UNINSTALL EXTENSION vsql_schematron;
