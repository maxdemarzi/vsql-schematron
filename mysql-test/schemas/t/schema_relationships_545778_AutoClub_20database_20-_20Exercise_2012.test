INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 545778_AutoClub%20database%20-%20Exercise%2012
--echo #
CREATE DATABASE `db_545778_AutoClub_20database_20__20Exercise_2012`;
USE `db_545778_AutoClub_20database_20__20Exercise_2012`;
CREATE TABLE `clubevents` (
  `ID` INT NOT NULL,
  `EventType` INT,
  `EventDate` DATE,
  `EventStartTime` TIME,
  `EventEndTime` TIME,
  `RegistrationTime` TIME,
  `VenueStart` INT,
  `VenuEnd` INT,
  `EntriesClose` DATETIME,
  `EntryFee` DOUBLE,
  `EventTitle` VARCHAR(50),
  `EventBlurb` VARCHAR(50),
  `clubeventscol` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `eventtype` (
  `ID` INT NOT NULL,
  `EventType` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `lookups` (
  `Key` VARCHAR(50) NOT NULL,
  `Value` VARCHAR(50),
  `Descriptions` VARCHAR(50),
  PRIMARY KEY (`Key`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_545778_AutoClub_20database_20__20Exercise_2012') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_545778_AutoClub_20database_20__20Exercise_2012') AS relationships;
DROP DATABASE `db_545778_AutoClub_20database_20__20Exercise_2012`;
UNINSTALL EXTENSION vsql_schematron;
