INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115425_criabanco
--echo #
CREATE DATABASE `db_115425_criabanco`;
USE `db_115425_criabanco`;
CREATE TABLE `progweb.professional` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progweb.professional_has_service_category` (
  `professional_id` VARCHAR(50) NOT NULL,
  `service_category_id` VARCHAR(50) NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`professional_id`, `service_category_id`)
) CHARACTER SET latin1;
CREATE TABLE `progweb.client` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progweb.city` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `state_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115425_criabanco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115425_criabanco') AS relationships;
DROP DATABASE `db_115425_criabanco`;
UNINSTALL EXTENSION vsql_schematron;
