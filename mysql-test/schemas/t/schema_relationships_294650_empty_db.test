INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294650_empty_db
--echo #
CREATE DATABASE `db_294650_empty_db`;
USE `db_294650_empty_db`;
CREATE TABLE `customers` (
  `internalId` INT NOT NULL,
  `externalId` VARCHAR(50),
  `masterExternalId` VARCHAR(50),
  `name` VARCHAR(50),
  `customerType` INT,
  `companyNumber` VARCHAR(50),
  `addressId` INT,
  PRIMARY KEY (`internalId`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `addressId` INT NOT NULL,
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  `postalCode` VARCHAR(50),
  PRIMARY KEY (`addressId`)
) CHARACTER SET latin1;
CREATE TABLE `shoppinglists` (
  `shoppinglistId` INT NOT NULL,
  `products` VARCHAR(50),
  PRIMARY KEY (`shoppinglistId`)
) CHARACTER SET latin1;
CREATE TABLE `customer_shoppinglists` (
  `customerId` INT,
  `shoppinglistId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294650_empty_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294650_empty_db') AS relationships;
DROP DATABASE `db_294650_empty_db`;
UNINSTALL EXTENSION vsql_schematron;
