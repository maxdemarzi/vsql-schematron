INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 482520_create_tables
--echo #
CREATE DATABASE `db_482520_create_tables`;
USE `db_482520_create_tables`;
CREATE TABLE `mail_log` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `to_mail` VARCHAR(50),
  `to_name` VARCHAR(50),
  `subject` VARCHAR(50),
  `error` VARCHAR(50),
  `inserted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plane` (
  `id` VARCHAR(50) NOT NULL,
  `model` VARCHAR(50),
  `lfz` CHAR(50),
  `wkz` VARCHAR(50),
  `alias` VARCHAR(50),
  `available` TINYINT,
  `updated_at` TIMESTAMP NULL,
  `inserted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plane_selection` (
  `attendance_id` VARCHAR(50) NOT NULL,
  `plane_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`attendance_id`, `plane_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_482520_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_482520_create_tables') AS relationships;
DROP DATABASE `db_482520_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
