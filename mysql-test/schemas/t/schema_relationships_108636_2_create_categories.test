INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108636_2.create.categories
--echo #
CREATE DATABASE `db_108636_2_create_categories`;
USE `db_108636_2_create_categories`;
CREATE TABLE `categories` (
  `category_id` INT NOT NULL,
  `parent_id` INT,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `image` VARCHAR(50),
  `show` BOOLEAN,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108636_2_create_categories') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108636_2_create_categories') AS relationships;
DROP DATABASE `db_108636_2_create_categories`;
UNINSTALL EXTENSION vsql_schematron;
