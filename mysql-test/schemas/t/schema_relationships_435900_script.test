INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435900_script
--echo #
CREATE DATABASE `db_435900_script`;
USE `db_435900_script`;
CREATE TABLE `tipo_user` (
  `id_tipo` INT NOT NULL,
  `tipo_user` VARCHAR(50),
  PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id_user` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone` VARCHAR(50),
  `cpf` VARCHAR(50),
  `senha` TEXT,
  `ativo` INT,
  `id_tipo` INT,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `fornecedor` (
  `id_forn` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `cnpj` VARCHAR(50),
  `telefone` VARCHAR(50),
  `ativo` INT,
  PRIMARY KEY (`id_forn`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `id_end` INT NOT NULL,
  `estado` VARCHAR(50),
  `cidade` VARCHAR(50),
  `rua` VARCHAR(50),
  `numero` INT,
  `cep` VARCHAR(50),
  `id_forn` INT,
  PRIMARY KEY (`id_end`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435900_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435900_script') AS relationships;
DROP DATABASE `db_435900_script`;
UNINSTALL EXTENSION vsql_schematron;
