INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000533_userAuth
--echo #
CREATE DATABASE `db_000533_userAuth`;
USE `db_000533_userAuth`;
CREATE TABLE `compositions` (
  `id` CHAR(50),
  `iduser` CHAR(50),
  `public` TINYINT,
  `name` VARCHAR(50),
  `duration` SMALLINT,
  `bpm` SMALLINT,
  `beatsPerMeasure` TINYINT,
  `stepsPerBeat` TINYINT,
  `data` VARCHAR(50),
  `created` DATETIME,
  `updated` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `passwordForgotten` (
  `id` INT,
  `email` VARCHAR(50),
  `code` CHAR(50),
  `expire` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `thingsNotVerified` (
  `id` INT,
  `iduser` CHAR(50),
  `data` VARCHAR(50),
  `code` VARCHAR(50),
  `expire` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` CHAR(50),
  `email` VARCHAR(50),
  `emailchecked` TINYINT,
  `emailpublic` TINYINT,
  `pass` CHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `username` VARCHAR(50),
  `avatar` VARCHAR(50),
  `created` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000533_userAuth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000533_userAuth') AS relationships;
DROP DATABASE `db_000533_userAuth`;
UNINSTALL EXTENSION vsql_schematron;
