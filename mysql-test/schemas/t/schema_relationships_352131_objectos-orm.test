INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352131_objectos-orm
--echo #
CREATE DATABASE `db_352131_objectos_orm`;
USE `db_352131_objectos_orm`;
CREATE TABLE `PAIR` (
  `ID` INT,
  `NAME` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `REVISION` (
  `SEQ` INT NOT NULL,
  `DATE` DATE,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`SEQ`)
) CHARACTER SET latin1;
CREATE TABLE `APP` (
  `ID` INT NOT NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
  `EMP_NO` INT NOT NULL,
  `BIRTH_DATE` DATE,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `HIRE_DATE` DATE,
  PRIMARY KEY (`EMP_NO`)
) CHARACTER SET latin1;
CREATE TABLE `SALARY` (
  `EMP_NO` INT NOT NULL,
  `SALARY` INT,
  `FROM_DATE` DATE NOT NULL,
  `TO_DATE` DATE,
  PRIMARY KEY (`EMP_NO`, `FROM_DATE`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352131_objectos_orm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352131_objectos_orm') AS relationships;
DROP DATABASE `db_352131_objectos_orm`;
UNINSTALL EXTENSION vsql_schematron;
