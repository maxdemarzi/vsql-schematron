USE `db_243381_V2020_08_04_10_14__entity_location_and_section`;
CREATE TABLE `location` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `date_from` TIMESTAMP NULL,
  `date_to` TIMESTAMP NULL,
  `project_id` BIGINT,
  `responsibility_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `section` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `location_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
