INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 516365_V0_18_0__gtnetwork
--echo #
CREATE DATABASE `db_516365_V0_18_0__gtnetwork`;
USE `db_516365_V0_18_0__gtnetwork`;
CREATE TABLE `gt_network` (
  `id_gt_network` INT NOT NULL,
  `domain_remote_name` VARCHAR(50),
  `allow_give_away` TINYINT,
  `accept_request` TINYINT,
  `daily_req_limit` INT,
  `daily_req_limit_count` INT,
  `daily_req_limit_remote` INT,
  `daily_req_limit_remote_count` INT,
  PRIMARY KEY (`id_gt_network`)
) CHARACTER SET latin1;
CREATE TABLE `gt_network_exchange` (
  `id_gt_network_exchange` INT NOT NULL,
  `id_gt_network` INT,
  `in_out` TINYINT,
  `entity` VARCHAR(50),
  `id_entity` INT,
  `id_entity_remote` INT,
  `send_msg_code` TINYINT,
  `send_msg_timestamp` TIMESTAMP NULL,
  `recv_msg_code` TINYINT,
  `recv_msg_timestamp` TIMESTAMP NULL,
  `request_entity_timestamp` TIMESTAMP NULL,
  `give_entity_timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`id_gt_network_exchange`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_516365_V0_18_0__gtnetwork') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_516365_V0_18_0__gtnetwork') AS relationships;
DROP DATABASE `db_516365_V0_18_0__gtnetwork`;
UNINSTALL EXTENSION vsql_schematron;
