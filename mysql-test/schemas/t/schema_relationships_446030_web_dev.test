INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 446030_web_dev
--echo #
CREATE DATABASE `db_446030_web_dev`;
USE `db_446030_web_dev`;
CREATE TABLE `images` (
  `image_id` INT,
  `user_id` INT,
  `title` VARCHAR(50),
  `image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_446030_web_dev') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_446030_web_dev') AS relationships;
DROP DATABASE `db_446030_web_dev`;
UNINSTALL EXTENSION vsql_schematron;
