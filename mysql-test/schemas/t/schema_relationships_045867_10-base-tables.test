INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045867_10-base-tables
--echo #
CREATE DATABASE `db_045867_10_base_tables`;
USE `db_045867_10_base_tables`;
CREATE TABLE `permissions` (
  `id` INT NOT NULL,
  `permission` VARCHAR(50),
  `restricted` BOOLEAN,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `grouptypes` (
  `id` INT NOT NULL,
  `grouptype` VARCHAR(50),
  `description` VARCHAR(50),
  `who_may_join` VARCHAR(50),
  `private_list` BOOLEAN,
  `public_list` BOOLEAN,
  `folder_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission_to_grouptype` (
  `permission_id` INT NOT NULL,
  `grouptype_id` INT NOT NULL,
  PRIMARY KEY (`permission_id`, `grouptype_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045867_10_base_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045867_10_base_tables') AS relationships;
DROP DATABASE `db_045867_10_base_tables`;
UNINSTALL EXTENSION vsql_schematron;
