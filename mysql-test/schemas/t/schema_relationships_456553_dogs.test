INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456553_dogs
--echo #
CREATE DATABASE `db_456553_dogs`;
USE `db_456553_dogs`;
CREATE TABLE `dog` (
  `Id` INT,
  `Name` VARCHAR(50),
  `Type` INT
) CHARACTER SET latin1;
CREATE TABLE `type` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456553_dogs') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456553_dogs') AS relationships;
DROP DATABASE `db_456553_dogs`;
UNINSTALL EXTENSION vsql_schematron;
