INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 214767_EntireDatabase
--echo #
CREATE DATABASE `db_214767_EntireDatabase`;
USE `db_214767_EntireDatabase`;
CREATE TABLE `Categories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
  `id` INT NOT NULL,
  `orderId` INT NOT NULL,
  `quantity` INT,
  `price` DECIMAL(10,2),
  `productId` INT,
  PRIMARY KEY (`id`, `orderId`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `id` INT NOT NULL,
  `clientId` INT,
  `totalPrice` DECIMAL(10,2),
  `createdAt` DATETIME,
  `delivered` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `quantity` INT,
  `price` DECIMAL(10,2),
  `categoryId` INT,
  `imageFileName` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProductsXSpecifications` (
  `id` INT NOT NULL,
  `value` VARCHAR(50),
  `productId` INT,
  `specificationId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Specifications` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `isNumeric` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_214767_EntireDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_214767_EntireDatabase') AS relationships;
DROP DATABASE `db_214767_EntireDatabase`;
UNINSTALL EXTENSION vsql_schematron;
