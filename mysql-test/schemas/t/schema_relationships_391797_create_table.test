INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 391797_create_table
--echo #
CREATE DATABASE `db_391797_create_table`;
USE `db_391797_create_table`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mv_ratings` (
  `id` INT NOT NULL,
  `movie_id` INT,
  `user_id` INT,
  `rating` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_391797_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_391797_create_table') AS relationships;
DROP DATABASE `db_391797_create_table`;
UNINSTALL EXTENSION vsql_schematron;
