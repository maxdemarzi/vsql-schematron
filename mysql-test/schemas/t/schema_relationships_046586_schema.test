INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046586_schema
--echo #
CREATE DATABASE `db_046586_schema`;
USE `db_046586_schema`;
CREATE TABLE `customers` (
  `customer_Id` INT NOT NULL,
  `customer_name` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `address1` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zipCode` VARCHAR(50),
  PRIMARY KEY (`customer_Id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `order_Id` INT NOT NULL,
  `customer_Id` INT,
  `order_date` DATE,
  `order_status` VARCHAR(50),
  `delivery_date` DATE,
  PRIMARY KEY (`order_Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046586_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046586_schema') AS relationships;
DROP DATABASE `db_046586_schema`;
UNINSTALL EXTENSION vsql_schematron;
