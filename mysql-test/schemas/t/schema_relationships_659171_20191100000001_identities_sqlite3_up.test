INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659171_20191100000001_identities.sqlite3.up
--echo #
CREATE DATABASE `db_659171_20191100000001_identities_sqlite3_up`;
USE `db_659171_20191100000001_identities_sqlite3_up`;
CREATE TABLE `identities` (
  `id` VARCHAR(50) NOT NULL,
  `traits_schema_id` TEXT,
  `traits` TEXT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `identity_credential_types` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `identity_credentials` (
  `id` VARCHAR(50) NOT NULL,
  `config` TEXT,
  `identity_credential_type_id` CHAR(50),
  `identity_id` CHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `identity_credential_identifiers` (
  `id` VARCHAR(50) NOT NULL,
  `identifier` TEXT,
  `identity_credential_id` CHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659171_20191100000001_identities_sqlite3_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659171_20191100000001_identities_sqlite3_up') AS relationships;
DROP DATABASE `db_659171_20191100000001_identities_sqlite3_up`;
UNINSTALL EXTENSION vsql_schematron;
