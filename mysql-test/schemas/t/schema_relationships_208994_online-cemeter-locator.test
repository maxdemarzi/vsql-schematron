INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 208994_online-cemeter-locator
--echo #
CREATE DATABASE `db_208994_online_cemeter_locator`;
USE `db_208994_online_cemeter_locator`;
CREATE TABLE `cemetery` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(50),
  `street` VARCHAR(50),
  `zip` VARCHAR(50),
  `longitude` VARCHAR(50),
  `latitude` VARCHAR(50),
  `phone` VARCHAR(50),
  `image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `obituary` (
  `id` INT,
  `user_id` INT,
  `person_name` VARCHAR(50),
  `dates` TEXT,
  `prayers` TEXT,
  `image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `pwd_reset_token` VARCHAR(50),
  `user_status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_208994_online_cemeter_locator') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_208994_online_cemeter_locator') AS relationships;
DROP DATABASE `db_208994_online_cemeter_locator`;
UNINSTALL EXTENSION vsql_schematron;
