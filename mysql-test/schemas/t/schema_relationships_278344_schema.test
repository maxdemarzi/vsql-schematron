INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278344_schema
--echo #
CREATE DATABASE `db_278344_schema`;
USE `db_278344_schema`;
CREATE TABLE `Departments` (
  `DepartmentID` INT NOT NULL,
  `DeptName` VARCHAR(50),
  PRIMARY KEY (`DepartmentID`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
  `RoleID` INT NOT NULL,
  `Title` VARCHAR(50),
  `Salary` DECIMAL(10,2),
  `DepartmentID` INT,
  PRIMARY KEY (`RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
  `EmployeeID` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `RoleID` INT,
  `ManagerID` INT,
  PRIMARY KEY (`EmployeeID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278344_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278344_schema') AS relationships;
DROP DATABASE `db_278344_schema`;
UNINSTALL EXTENSION vsql_schematron;
