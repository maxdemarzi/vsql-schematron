INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038500_prova1b
--echo #
CREATE DATABASE `db_038500_prova1b`;
USE `db_038500_prova1b`;
CREATE TABLE `GENERO` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSICA` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  `ANO` INT,
  `ID_GENERO` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038500_prova1b') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038500_prova1b') AS relationships;
DROP DATABASE `db_038500_prova1b`;
UNINSTALL EXTENSION vsql_schematron;
