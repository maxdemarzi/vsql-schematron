INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152792_init
--echo #
CREATE DATABASE `db_152792_init`;
USE `db_152792_init`;
CREATE TABLE `club` (
  `id` INT NOT NULL,
  `club` VARCHAR(50),
  `club_country` VARCHAR(50),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match` (
  `id` INT NOT NULL,
  `comment` VARCHAR(50),
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `club_match` (
  `idclub_match` INT NOT NULL,
  `idclub` INT,
  `idmatch` INT,
  `points` INT,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`idclub_match`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152792_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152792_init') AS relationships;
DROP DATABASE `db_152792_init`;
UNINSTALL EXTENSION vsql_schematron;
