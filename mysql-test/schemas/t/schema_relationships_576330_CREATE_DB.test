INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576330_CREATE_DB
--echo #
CREATE DATABASE `db_576330_CREATE_DB`;
USE `db_576330_CREATE_DB`;
CREATE TABLE `Certification` (
  `certificationID` INT NOT NULL,
  `certifyingAgency` VARCHAR(50),
  `certificationName` VARCHAR(50),
  `standardExpiry` CHAR(50),
  PRIMARY KEY (`certificationID`)
) CHARACTER SET latin1;
CREATE TABLE `MemberCertification` (
  `mcID` INT NOT NULL,
  `memberID` INT,
  `certificationID` INT,
  `renewedDate` DATE,
  `expirationDate` DATE,
  PRIMARY KEY (`mcID`)
) CHARACTER SET latin1;
CREATE TABLE `UserTable` (
  `email` VARCHAR(50) NOT NULL,
  `user_Password` VARCHAR(50),
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576330_CREATE_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576330_CREATE_DB') AS relationships;
DROP DATABASE `db_576330_CREATE_DB`;
UNINSTALL EXTENSION vsql_schematron;
