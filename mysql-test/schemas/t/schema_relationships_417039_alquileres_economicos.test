INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417039_alquileres_economicos
--echo #
CREATE DATABASE `db_417039_alquileres_economicos`;
USE `db_417039_alquileres_economicos`;
CREATE TABLE `alquileres` (
  `alquileres_id` INT,
  `cliente_id` INT,
  `productos` TEXT,
  `direccion` VARCHAR(50),
  `total` DECIMAL(10,2),
  `fecha_alquiler` TIMESTAMP NULL,
  `fecha_entrega` DATETIME,
  `estado` VARCHAR(50),
  `abono` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `cliente_id` INT NOT NULL,
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `dui` VARCHAR(50),
  `telefono` INT,
  `fecha_registro` TIMESTAMP NULL,
  PRIMARY KEY (`cliente_id`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `usuario_id` INT NOT NULL,
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `usuario` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `fecha_registro` TIMESTAMP NULL,
  `estado` TINYINT,
  PRIMARY KEY (`usuario_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417039_alquileres_economicos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417039_alquileres_economicos') AS relationships;
DROP DATABASE `db_417039_alquileres_economicos`;
UNINSTALL EXTENSION vsql_schematron;
