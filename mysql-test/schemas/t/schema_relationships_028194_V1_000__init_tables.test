INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028194_V1.000__init_tables
--echo #
CREATE DATABASE `db_028194_V1_000__init_tables`;
USE `db_028194_V1_000__init_tables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `is_admin` BOOLEAN,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feedbacks` (
  `id` VARCHAR(50) NOT NULL,
  `text` VARCHAR(50),
  `satisfaction_level` INT,
  `user_id` INT,
  `event_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028194_V1_000__init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028194_V1_000__init_tables') AS relationships;
DROP DATABASE `db_028194_V1_000__init_tables`;
UNINSTALL EXTENSION vsql_schematron;
