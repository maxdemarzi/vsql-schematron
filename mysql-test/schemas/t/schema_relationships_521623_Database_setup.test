INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521623_Database_setup
--echo #
CREATE DATABASE `db_521623_Database_setup`;
USE `db_521623_Database_setup`;
CREATE TABLE `Animes` (
  `anime_id` INT NOT NULL,
  `anime_title` VARCHAR(50),
  `main_url` VARCHAR(50),
  PRIMARY KEY (`anime_id`)
) CHARACTER SET latin1;
CREATE TABLE `Downloads` (
  `anime_id` INT,
  `episode_number` SMALLINT,
  `file_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Favorites` (
  `anime_id` INT,
  `cover_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Watching` (
  `anime_id` INT
) CHARACTER SET latin1;
CREATE TABLE `Covers` (
  `anime_id` INT,
  `cover_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Animes_Download_List` (
  `anime_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521623_Database_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521623_Database_setup') AS relationships;
DROP DATABASE `db_521623_Database_setup`;
UNINSTALL EXTENSION vsql_schematron;
