INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335520_V1.2__Create_table_message
--echo #
CREATE DATABASE `db_335520_V1_2__Create_table_message`;
USE `db_335520_V1_2__Create_table_message`;
CREATE TABLE `Message` (
  `id` BIGINT NOT NULL,
  `iv` BLOB,
  `type` VARCHAR(50),
  `sender` VARCHAR(50),
  `recipient` VARCHAR(50),
  `data` BLOB,
  `sent` BIGINT,
  `received` BIGINT,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Label` (
  `id` BIGINT NOT NULL,
  `label` VARCHAR(50),
  `type` VARCHAR(50),
  `color` INT,
  `ord` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Message_Label` (
  `message_id` BIGINT NOT NULL,
  `label_id` BIGINT NOT NULL,
  PRIMARY KEY (`message_id`, `label_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335520_V1_2__Create_table_message') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335520_V1_2__Create_table_message') AS relationships;
DROP DATABASE `db_335520_V1_2__Create_table_message`;
UNINSTALL EXTENSION vsql_schematron;
