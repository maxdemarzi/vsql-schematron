INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626596_demo1
--echo #
CREATE DATABASE `db_626596_demo1`;
USE `db_626596_demo1`;
CREATE TABLE `course` (
  `cid` INT NOT NULL,
  `cname` VARCHAR(50),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `uid` INT,
  `name` VARCHAR(50),
  `cid` INT,
  `address` VARCHAR(50),
  `email` VARCHAR(50),
  `p_image` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626596_demo1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626596_demo1') AS relationships;
DROP DATABASE `db_626596_demo1`;
UNINSTALL EXTENSION vsql_schematron;
