INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 299958_createdb
--echo #
CREATE DATABASE `db_299958_createdb`;
USE `db_299958_createdb`;
CREATE TABLE `Post` (
  `postID` INT NOT NULL,
  `published` DATE,
  `title` TEXT,
  `content` TEXT,
  PRIMARY KEY (`postID`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `commentID` INT NOT NULL,
  `postID` INT,
  `author` TEXT,
  `published` DATE,
  `content` TEXT,
  PRIMARY KEY (`commentID`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
  `tagID` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`tagID`)
) CHARACTER SET latin1;
CREATE TABLE `PostTag` (
  `postID` INT,
  `tagID` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_299958_createdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_299958_createdb') AS relationships;
DROP DATABASE `db_299958_createdb`;
UNINSTALL EXTENSION vsql_schematron;
