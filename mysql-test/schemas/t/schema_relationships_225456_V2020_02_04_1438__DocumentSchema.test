CREATE TABLE `orderlyweb_document` (
  `path` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `show` INT,
  `display_name` TEXT,
  `description` TEXT,
  `parent` TEXT,
  `is_file` INT,
  PRIMARY KEY (`path`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_225456_V2020_02_04_1438__DocumentSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_225456_V2020_02_04_1438__DocumentSchema') AS relationships;
