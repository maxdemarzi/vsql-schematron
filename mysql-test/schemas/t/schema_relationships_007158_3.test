INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 007158_3
--echo #
CREATE DATABASE `db_007158_3`;
USE `db_007158_3`;
CREATE TABLE `BOAT` (
  `BID` VARCHAR(50) NOT NULL,
  `BNAME` VARCHAR(50),
  `COLOUR` VARCHAR(50),
  PRIMARY KEY (`BID`)
) CHARACTER SET latin1;
CREATE TABLE `SAILOR` (
  `SID` VARCHAR(50) NOT NULL,
  `SNAME` VARCHAR(50),
  `AGE` VARCHAR(50),
  `RATING` VARCHAR(50),
  PRIMARY KEY (`SID`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVES` (
  `BID` VARCHAR(50) NOT NULL,
  `SID` VARCHAR(50) NOT NULL,
  `DAY` VARCHAR(50),
  PRIMARY KEY (`BID`, `SID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_007158_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_007158_3') AS relationships;
DROP DATABASE `db_007158_3`;
UNINSTALL EXTENSION vsql_schematron;
