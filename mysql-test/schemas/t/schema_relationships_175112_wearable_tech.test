INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175112_wearable_tech
--echo #
CREATE DATABASE `db_175112_wearable_tech`;
USE `db_175112_wearable_tech`;
CREATE TABLE `researcher` (
  `researcher_id` INT NOT NULL,
  `email` VARCHAR(50),
  `passwrd` VARCHAR(50),
  `f_name` VARCHAR(50),
  `m_initial` CHAR(50),
  `l_name` VARCHAR(50),
  `institution` VARCHAR(50),
  PRIMARY KEY (`researcher_id`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
  `subject_id` INT NOT NULL,
  `researcher_id` INT,
  `age` INT,
  `weight` INT,
  `height` DECIMAL(10,2),
  `bmi` DECIMAL(10,2),
  `ethnicity` VARCHAR(50),
  `fitzpatrick` VARCHAR(50),
  `gender` VARCHAR(50),
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `processed_data` (
  `body_location` VARCHAR(50) NOT NULL,
  `subject_id` INT NOT NULL,
  `wave_length` DECIMAL(10,2),
  `absorbance` DECIMAL(10,2),
  `time_date` TIMESTAMP NULL,
  PRIMARY KEY (`body_location`, `subject_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175112_wearable_tech') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175112_wearable_tech') AS relationships;
DROP DATABASE `db_175112_wearable_tech`;
UNINSTALL EXTENSION vsql_schematron;
