INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148727_schema
--echo #
CREATE DATABASE `db_148727_schema`;
USE `db_148727_schema`;
CREATE TABLE `foods` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `category` VARCHAR(50),
  `price` DOUBLE,
  `restaurant_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `rating` DOUBLE,
  `cnpj` VARCHAR(50),
  `phone` VARCHAR(50),
  `location` VARCHAR(50),
  `user_id` INT,
  `category` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `phone` VARCHAR(50),
  `role` INT,
  `location` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `id` INT NOT NULL,
  `number` INT,
  `street` VARCHAR(50),
  `neighborhood` VARCHAR(50),
  `complement` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `rating` DOUBLE,
  `user_id` INT,
  `restaurant_id` INT,
  `location` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `quantity` INT,
  `food_id` INT NOT NULL,
  `order_id` INT NOT NULL,
  PRIMARY KEY (`food_id`, `order_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_tokens` (
  `token` VARCHAR(50) NOT NULL,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148727_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148727_schema') AS relationships;
DROP DATABASE `db_148727_schema`;
UNINSTALL EXTENSION vsql_schematron;
