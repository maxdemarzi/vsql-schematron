INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583173_V85_13_0__public_content_domain_model
--echo #
CREATE DATABASE `db_583173_V85_13_0__public_content_domain_model`;
USE `db_583173_V85_13_0__public_content_domain_model`;
CREATE TABLE `public_content` (
  `id` BIGINT NOT NULL,
  `competition_id` BIGINT,
  `publish_date` DATETIME,
  `short_description` VARCHAR(50),
  `project_funding_range` VARCHAR(50),
  `eligibility_summary` VARCHAR(50),
  `summary` VARCHAR(50),
  `funding_type` VARCHAR(50),
  `project_size` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `keyword` (
  `id` BIGINT NOT NULL,
  `public_content_id` BIGINT,
  `keyword` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `content_event` (
  `id` BIGINT NOT NULL,
  `public_content_id` BIGINT,
  `date` DATETIME,
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `content_section` (
  `id` BIGINT NOT NULL,
  `public_content_id` BIGINT,
  `status` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `content_group` (
  `id` BIGINT NOT NULL,
  `content_section_id` BIGINT,
  `heading` VARCHAR(50),
  `content` VARCHAR(50),
  `file_entry_id` BIGINT,
  `priority` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583173_V85_13_0__public_content_domain_model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583173_V85_13_0__public_content_domain_model') AS relationships;
DROP DATABASE `db_583173_V85_13_0__public_content_domain_model`;
UNINSTALL EXTENSION vsql_schematron;
