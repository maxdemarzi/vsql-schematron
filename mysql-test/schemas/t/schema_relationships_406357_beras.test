INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 406357_beras
--echo #
CREATE DATABASE `db_406357_beras`;
USE `db_406357_beras`;
CREATE TABLE `barang` (
  `id_barang` VARCHAR(50) NOT NULL,
  `nama_barang` VARCHAR(50),
  `stok` INT,
  `harga_beli` INT,
  `harga_jual` INT,
  PRIMARY KEY (`id_barang`)
) CHARACTER SET latin1;
CREATE TABLE `transaksi` (
  `id_transaksi` INT,
  `id_barang` VARCHAR(50),
  `tipe` VARCHAR(50),
  `tanggal` DATE,
  `jumlah` INT,
  `total` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `nama` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_406357_beras') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_406357_beras') AS relationships;
DROP DATABASE `db_406357_beras`;
UNINSTALL EXTENSION vsql_schematron;
