INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077976_schema
--echo #
CREATE DATABASE `db_077976_schema`;
USE `db_077976_schema`;
CREATE TABLE `semesters` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `credit` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `group_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `semester_courses` (
  `semester_id` VARCHAR(50),
  `course_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `semester_students` (
  `semester_id` VARCHAR(50),
  `student_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `course_students` (
  `id` VARCHAR(50) NOT NULL,
  `course_id` VARCHAR(50),
  `student_id` VARCHAR(50),
  `grade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077976_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077976_schema') AS relationships;
DROP DATABASE `db_077976_schema`;
UNINSTALL EXTENSION vsql_schematron;
