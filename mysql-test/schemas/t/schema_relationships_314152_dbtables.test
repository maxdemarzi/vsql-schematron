INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 314152_dbtables
--echo #
CREATE DATABASE `db_314152_dbtables`;
USE `db_314152_dbtables`;
CREATE TABLE `collectors_collectors` (
  `collector_id` BIGINT NOT NULL,
  `mode` VARCHAR(50),
  `location` VARCHAR(50),
  PRIMARY KEY (`collector_id`)
) CHARACTER SET latin1;
CREATE TABLE `collectors_contents` (
  `collector_id` BIGINT NOT NULL,
  `material` VARCHAR(50) NOT NULL,
  `amount` INT,
  PRIMARY KEY (`collector_id`, `material`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_314152_dbtables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_314152_dbtables') AS relationships;
DROP DATABASE `db_314152_dbtables`;
UNINSTALL EXTENSION vsql_schematron;
