INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062022_186%20Event%20Service%20Providers
--echo #
CREATE DATABASE `db_062022_186_20Event_20Service_20Providers`;
USE `db_062022_186_20Event_20Service_20Providers`;
CREATE TABLE `service_provider` (
  `uniqueid` DECIMAL(10,2) NOT NULL,
  `reference` VARCHAR(50),
  `label` VARCHAR(50),
  `note` VARCHAR(50),
  `email` VARCHAR(50),
  `options` DECIMAL(10,2),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;
CREATE TABLE `event_service_provider` (
  `event_id` DECIMAL(10,2) NOT NULL,
  `provider_id` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`event_id`, `provider_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062022_186_20Event_20Service_20Providers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062022_186_20Event_20Service_20Providers') AS relationships;
DROP DATABASE `db_062022_186_20Event_20Service_20Providers`;
UNINSTALL EXTENSION vsql_schematron;
