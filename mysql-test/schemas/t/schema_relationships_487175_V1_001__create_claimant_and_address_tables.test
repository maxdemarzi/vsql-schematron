INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 487175_V1_001__create_claimant_and_address_tables
--echo #
CREATE DATABASE `db_487175_V1_001__create_claimant_and_address_tables`;
USE `db_487175_V1_001__create_claimant_and_address_tables`;
CREATE TABLE `claimant` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `nino` VARCHAR(50),
  `date_of_birth` DATE,
  `expected_delivery_date` DATE,
  `card_delivery_address_id` VARCHAR(50),
  `created_timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` VARCHAR(50) NOT NULL,
  `address_line_1` VARCHAR(50),
  `address_line_2` VARCHAR(50),
  `town_or_city` VARCHAR(50),
  `postcode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_487175_V1_001__create_claimant_and_address_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_487175_V1_001__create_claimant_and_address_tables') AS relationships;
DROP DATABASE `db_487175_V1_001__create_claimant_and_address_tables`;
UNINSTALL EXTENSION vsql_schematron;
