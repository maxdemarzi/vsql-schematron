INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531071_table_with_nullable_reference_to_another_table
--echo #
CREATE DATABASE `db_531071_table_with_nullable_reference_to_another_table`;
USE `db_531071_table_with_nullable_reference_to_another_table`;
CREATE TABLE `test_table_1` (
  `id` INT NOT NULL,
  `table_2_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_table_2` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531071_table_with_nullable_reference_to_another_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531071_table_with_nullable_reference_to_another_table') AS relationships;
DROP DATABASE `db_531071_table_with_nullable_reference_to_another_table`;
UNINSTALL EXTENSION vsql_schematron;
