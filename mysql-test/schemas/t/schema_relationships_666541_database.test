INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 666541_database
--echo #
CREATE DATABASE `db_666541_database`;
USE `db_666541_database`;
CREATE TABLE `authors` (
  `aut_id` INT NOT NULL,
  `aut_date` TIMESTAMP NULL,
  `aut_name` VARCHAR(50),
  `aut_image` VARCHAR(50),
  `aut_link` VARCHAR(50),
  `aut_email` VARCHAR(50),
  `aut_status` VARCHAR(50),
  PRIMARY KEY (`aut_id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `art_id` INT NOT NULL,
  `art_date` TIMESTAMP NULL,
  `art_image` VARCHAR(50),
  `art_title` VARCHAR(50),
  `art_intro` VARCHAR(50),
  `art_text` VARCHAR(50),
  `art_author` INT,
  `art_status` VARCHAR(50),
  PRIMARY KEY (`art_id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
  `id` INT NOT NULL,
  `date` TIMESTAMP NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `subject` VARCHAR(50),
  `message` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `config` (
  `id` INT NOT NULL,
  `var` VARCHAR(50),
  `val` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `about` (
  `abt_id` INT NOT NULL,
  `abt_order` INT,
  `abt_image` VARCHAR(50),
  `abt_title` VARCHAR(50),
  `abt_intro` VARCHAR(50),
  `abt_text` VARCHAR(50),
  `abt_status` VARCHAR(50),
  PRIMARY KEY (`abt_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_666541_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_666541_database') AS relationships;
DROP DATABASE `db_666541_database`;
UNINSTALL EXTENSION vsql_schematron;
