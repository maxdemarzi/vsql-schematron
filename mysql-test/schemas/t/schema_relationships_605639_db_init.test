INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605639_db_init
--echo #
CREATE DATABASE `db_605639_db_init`;
USE `db_605639_db_init`;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlist` (
  `wishlist_id` INT NOT NULL,
  `user_id` INT,
  `book_id` INT,
  PRIMARY KEY (`wishlist_id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `book_id` INT NOT NULL,
  `book_name` VARCHAR(50),
  `details` VARCHAR(50),
  `author` VARCHAR(50),
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `store` (
  `store_id` INT NOT NULL,
  `locale` VARCHAR(50),
  `hours` VARCHAR(50),
  PRIMARY KEY (`store_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605639_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605639_db_init') AS relationships;
DROP DATABASE `db_605639_db_init`;
UNINSTALL EXTENSION vsql_schematron;
