INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151761_orders
--echo #
CREATE DATABASE `db_151761_orders`;
USE `db_151761_orders`;
CREATE TABLE `salesmen` (
  `salesman_id` INT NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `commission` DECIMAL(10,2),
  PRIMARY KEY (`salesman_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `customer_id` INT NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `grade` VARCHAR(50),
  `salesman_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `order_id` INT NOT NULL,
  `purchase_amount` DECIMAL(10,2),
  `order_date` DATE,
  `customer_id` INT,
  `salesman_id` INT,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151761_orders') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151761_orders') AS relationships;
DROP DATABASE `db_151761_orders`;
UNINSTALL EXTENSION vsql_schematron;
