INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035662_01_create_new_database_schema-3.0.0
--echo #
CREATE DATABASE `db_035662_01_create_new_database_schema_3_0_0`;
USE `db_035662_01_create_new_database_schema_3_0_0`;
CREATE TABLE `job_entry` (
  `job_entry_id` INT NOT NULL,
  `job_type_cd` INT,
  `job_status_cd` INT,
  `job_description` VARCHAR(50),
  `job_parameters` VARCHAR(50),
  `entity_version_id` INT,
  `date_created` TIMESTAMP NULL,
  `date_started` TIMESTAMP NULL,
  `date_completed` TIMESTAMP NULL,
  `items_processed` INT,
  `items_successful` INT,
  `items_errored` INT,
  PRIMARY KEY (`job_entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `job_entry_event_log` (
  `job_entry_event_log_id` INT NOT NULL,
  `job_entry_id` INT,
  `log_message` VARCHAR(50),
  `date_created` TIMESTAMP NULL,
  PRIMARY KEY (`job_entry_event_log_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035662_01_create_new_database_schema_3_0_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035662_01_create_new_database_schema_3_0_0') AS relationships;
DROP DATABASE `db_035662_01_create_new_database_schema_3_0_0`;
UNINSTALL EXTENSION vsql_schematron;
