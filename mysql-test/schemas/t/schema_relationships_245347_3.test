INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 245347_3
--echo #
CREATE DATABASE `db_245347_3`;
USE `db_245347_3`;
CREATE TABLE `teams` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `tournament` BIGINT,
  `captain` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team_users` (
  `team` BIGINT NOT NULL,
  `attributes` TINYINT,
  `user` INT NOT NULL,
  PRIMARY KEY (`team`, `user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_245347_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_245347_3') AS relationships;
DROP DATABASE `db_245347_3`;
UNINSTALL EXTENSION vsql_schematron;
