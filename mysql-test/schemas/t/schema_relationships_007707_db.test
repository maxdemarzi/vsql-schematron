INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 007707_db
--echo #
CREATE DATABASE `db_007707_db`;
USE `db_007707_db`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `image_path` VARCHAR(50),
  `password` VARCHAR(50),
  `birth_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `post_title` VARCHAR(50),
  `post_text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `comment_id` INT NOT NULL,
  `user_id` INT,
  `post_id` INT,
  `comment_text` VARCHAR(50),
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_007707_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_007707_db') AS relationships;
DROP DATABASE `db_007707_db`;
UNINSTALL EXTENSION vsql_schematron;
