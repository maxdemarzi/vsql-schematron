INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 055803_schema
--echo #
CREATE DATABASE `db_055803_schema`;
USE `db_055803_schema`;
CREATE TABLE `dept_table` (
  `dept_id` INT NOT NULL,
  `dept_name` VARCHAR(50),
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `role_table` (
  `role_id` INT NOT NULL,
  `title` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `dept_id` INT,
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_table` (
  `employee_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `role_id` INT,
  `manager_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_055803_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_055803_schema') AS relationships;
DROP DATABASE `db_055803_schema`;
UNINSTALL EXTENSION vsql_schematron;
