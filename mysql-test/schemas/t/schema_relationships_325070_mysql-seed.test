INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325070_mysql-seed
--echo #
CREATE DATABASE `db_325070_mysql_seed`;
USE `db_325070_mysql_seed`;
CREATE TABLE `person` (
  `id` VARCHAR(50) NOT NULL,
  `tripId` VARCHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `phone` VARCHAR(50),
  `IDNumber` INT,
  `email` VARCHAR(50),
  `willTravel` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trip` (
  `id` VARCHAR(50) NOT NULL,
  `departureDate` DATETIME,
  `estimatedArrivalDate` DATETIME,
  `agencyId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325070_mysql_seed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325070_mysql_seed') AS relationships;
DROP DATABASE `db_325070_mysql_seed`;
UNINSTALL EXTENSION vsql_schematron;
