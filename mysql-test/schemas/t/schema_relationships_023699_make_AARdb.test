INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 023699_make_AARdb
--echo #
CREATE DATABASE `db_023699_make_AARdb`;
USE `db_023699_make_AARdb`;
CREATE TABLE `customer` (
  `cid` MEDIUMINT NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `state` CHAR(50),
  `zip` MEDIUMINT,
  `phone` CHAR(50),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `uname` VARCHAR(50) NOT NULL,
  `cid` MEDIUMINT,
  `role` VARCHAR(50),
  `pw` VARCHAR(50),
  PRIMARY KEY (`uname`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
  `j_ip` VARCHAR(50),
  `j_id` MEDIUMINT NOT NULL,
  `cid` MEDIUMINT,
  `make` VARCHAR(50),
  `appliance` CHAR(50),
  `appointment` DATE,
  `job_status` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`j_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_023699_make_AARdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_023699_make_AARdb') AS relationships;
DROP DATABASE `db_023699_make_AARdb`;
UNINSTALL EXTENSION vsql_schematron;
