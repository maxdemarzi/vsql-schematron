INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498059_V1_0_0_3__assessment_feedback_tables
--echo #
CREATE DATABASE `db_498059_V1_0_0_3__assessment_feedback_tables`;
USE `db_498059_V1_0_0_3__assessment_feedback_tables`;
CREATE TABLE `assessment` (
  `id` INT NOT NULL,
  `target_user_id` INT,
  `assesment_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feedback` (
  `id` INT NOT NULL,
  `user_id` INT,
  `assessment_id` INT,
  `feedback_date` DATETIME,
  `score` DECIMAL(10,2),
  `comment` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498059_V1_0_0_3__assessment_feedback_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498059_V1_0_0_3__assessment_feedback_tables') AS relationships;
DROP DATABASE `db_498059_V1_0_0_3__assessment_feedback_tables`;
UNINSTALL EXTENSION vsql_schematron;
