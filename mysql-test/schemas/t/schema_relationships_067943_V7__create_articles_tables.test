INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067943_V7__create_articles_tables
--echo #
CREATE DATABASE `db_067943_V7__create_articles_tables`;
USE `db_067943_V7__create_articles_tables`;
CREATE TABLE `articles` (
  `id` BIGINT NOT NULL,
  `original_lang_id` BIGINT,
  `author_id` BIGINT,
  `approved` BOOLEAN,
  `approver_id` BIGINT,
  `approved_date` TIMESTAMP NULL,
  `published` BOOLEAN,
  `publisher_id` BIGINT,
  `published_date` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  `source_title` TEXT,
  `source_url` TEXT,
  `source_author_name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_translations` (
  `id` BIGINT NOT NULL,
  `title` TEXT,
  `short_description` TEXT,
  `image_url` TEXT,
  `article_id` BIGINT,
  `lang_id` BIGINT,
  `author_id` BIGINT,
  `approved` BOOLEAN,
  `approver_id` BIGINT,
  `approved_date` TIMESTAMP NULL,
  `published` BOOLEAN,
  `publisher_id` BIGINT,
  `published_date` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_translation_versions` (
  `id` BIGINT NOT NULL,
  `article_translation_id` BIGINT,
  `text` TEXT,
  `author_id` BIGINT,
  `approved` BOOLEAN,
  `approver_id` BIGINT,
  `approved_date` TIMESTAMP NULL,
  `published` BOOLEAN,
  `publisher_id` BIGINT,
  `published_date` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067943_V7__create_articles_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067943_V7__create_articles_tables') AS relationships;
DROP DATABASE `db_067943_V7__create_articles_tables`;
UNINSTALL EXTENSION vsql_schematron;
