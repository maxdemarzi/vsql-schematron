INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425149_base
--echo #
CREATE DATABASE `db_425149_base`;
USE `db_425149_base`;
CREATE TABLE `my_models` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `my_model_properties` (
  `my_model_id` VARCHAR(50) NOT NULL,
  `property_id` VARCHAR(50) NOT NULL,
  `seq_no` VARCHAR(50) NOT NULL,
  `property_value` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`my_model_id`, `property_id`, `seq_no`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425149_base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425149_base') AS relationships;
DROP DATABASE `db_425149_base`;
UNINSTALL EXTENSION vsql_schematron;
