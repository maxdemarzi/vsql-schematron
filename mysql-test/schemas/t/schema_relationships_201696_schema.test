INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 201696_schema
--echo #
CREATE DATABASE `db_201696_schema`;
USE `db_201696_schema`;
CREATE TABLE `USRROLE` (
  `id` BIGINT NOT NULL,
  `description` VARCHAR(50),
  `role_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `last_login` TIMESTAMP NULL,
  `token` VARCHAR(50),
  `is_active` BOOLEAN,
  `created` TIMESTAMP NULL,
  `modified` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PHONE` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `number` VARCHAR(50),
  `city_code` VARCHAR(50),
  `country_code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLE` (
  `id` BIGINT NOT NULL,
  `user_id` VARCHAR(50),
  `usrrole_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_201696_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_201696_schema') AS relationships;
DROP DATABASE `db_201696_schema`;
UNINSTALL EXTENSION vsql_schematron;
