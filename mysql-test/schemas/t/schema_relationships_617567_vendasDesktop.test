INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617567_vendasDesktop
--echo #
CREATE DATABASE `db_617567_vendasDesktop`;
USE `db_617567_vendasDesktop`;
CREATE TABLE `vendedor` (
  `idVendedor` INT NOT NULL,
  `nomeUsuario` VARCHAR(50),
  `codVendedor` VARCHAR(50),
  `biVendedor` VARCHAR(50),
  `nomeVendedor` VARCHAR(50),
  `telefoneVendedor` VARCHAR(50),
  `estado` VARCHAR(50),
  PRIMARY KEY (`idVendedor`)
) CHARACTER SET latin1;
CREATE TABLE `cliente` (
  `idCliente` INT NOT NULL,
  `codCliente` VARCHAR(50),
  `biCliente` VARCHAR(50),
  `nomeCliente` VARCHAR(50),
  `enderecoCliente` VARCHAR(50),
  `estadoCliente` VARCHAR(50),
  PRIMARY KEY (`idCliente`)
) CHARACTER SET latin1;
CREATE TABLE `vendas` (
  `idVenda` INT NOT NULL,
  `vendedor_idVendedor` INT,
  `cliente_idCliente` INT,
  `numeroVendas` VARCHAR(50),
  `dataVenda` DATE,
  `valorVenda` DOUBLE,
  `estadoVenda` VARCHAR(50),
  PRIMARY KEY (`idVenda`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `idProduto` INT NOT NULL,
  `nomeProduto` VARCHAR(50),
  `precoProduto` DOUBLE,
  `stockProduto` INT,
  `estadoProduto` VARCHAR(50),
  PRIMARY KEY (`idProduto`)
) CHARACTER SET latin1;
CREATE TABLE `detalhesVenda` (
  `idDetalhe` INT NOT NULL,
  `venda_idVenda` INT,
  `produto_idProduto` INT,
  `quantidade` INT,
  `valorTotal` DOUBLE,
  PRIMARY KEY (`idDetalhe`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617567_vendasDesktop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617567_vendasDesktop') AS relationships;
DROP DATABASE `db_617567_vendasDesktop`;
UNINSTALL EXTENSION vsql_schematron;
