INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 003219_load
--echo #
CREATE DATABASE `db_003219_load`;
USE `db_003219_load`;
CREATE TABLE `wishlist_types` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mtu_list` (
  `id` VARCHAR(50) NOT NULL,
  `city` VARCHAR(50),
  `mtu_name` VARCHAR(50),
  `mtu_code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mtu_analysis` (
  `id` VARCHAR(50) NOT NULL,
  `analysis_option` VARCHAR(50),
  `mtu` VARCHAR(50),
  `result` DECIMAL(10,2),
  `year` INT,
  `notes` TEXT,
  `url` TEXT,
  `source_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `data` (
  `id` VARCHAR(50) NOT NULL,
  `case_study` VARCHAR(50),
  `result` DECIMAL(10,2),
  `year` INT,
  `notes` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_003219_load') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_003219_load') AS relationships;
DROP DATABASE `db_003219_load`;
UNINSTALL EXTENSION vsql_schematron;
