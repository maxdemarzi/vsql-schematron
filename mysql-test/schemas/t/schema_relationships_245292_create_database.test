INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 245292_create_database
--echo #
CREATE DATABASE `db_245292_create_database`;
USE `db_245292_create_database`;
CREATE TABLE `user` (
  `user_id` BIGINT NOT NULL,
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `employee_type_id` INT,
  `email` VARCHAR(50),
  `state` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `time_sheet` (
  `time_id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `employee_type_id` INT,
  `time` DATETIME,
  `state` VARCHAR(50),
  PRIMARY KEY (`time_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_log` (
  `session_id` VARCHAR(50),
  `user_id` BIGINT,
  `login_time` DATETIME,
  `url` TEXT
) CHARACTER SET latin1;
CREATE TABLE `occupation` (
  `employee_type_id` INT NOT NULL,
  `occupation_type` VARCHAR(50),
  `issue_time` DATETIME,
  `wage` INT,
  PRIMARY KEY (`employee_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_secret` (
  `password_id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `salt` VARCHAR(50),
  `email_verification_token` VARCHAR(50),
  `verified` BOOLEAN,
  `password` VARCHAR(50),
  PRIMARY KEY (`password_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_245292_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_245292_create_database') AS relationships;
DROP DATABASE `db_245292_create_database`;
UNINSTALL EXTENSION vsql_schematron;
