INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 203586_table_categories
--echo #
CREATE DATABASE `db_203586_table_categories`;
USE `db_203586_table_categories`;
CREATE TABLE `dbo.Categories` (
  `CategoryID` VARCHAR(50) NOT NULL,
  `ParentCategoryID` VARCHAR(50),
  `Title` VARCHAR(50),
  `Description` VARCHAR(50),
  `SEOUrl` VARCHAR(50),
  PRIMARY KEY (`CategoryID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_203586_table_categories') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_203586_table_categories') AS relationships;
DROP DATABASE `db_203586_table_categories`;
UNINSTALL EXTENSION vsql_schematron;
