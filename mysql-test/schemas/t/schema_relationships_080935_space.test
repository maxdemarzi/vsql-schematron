INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 080935_space
--echo #
CREATE DATABASE `db_080935_space`;
USE `db_080935_space`;
CREATE TABLE `uadmin` (
  `u_id` INT NOT NULL,
  `dob` DATE,
  PRIMARY KEY (`u_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `u_id` INT,
  `u_name` VARCHAR(50),
  `u_add` VARCHAR(50),
  `dob` DATE,
  `u_age` INT,
  `u_gender` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_080935_space') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_080935_space') AS relationships;
DROP DATABASE `db_080935_space`;
UNINSTALL EXTENSION vsql_schematron;
