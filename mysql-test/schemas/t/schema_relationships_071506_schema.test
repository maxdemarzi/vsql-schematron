INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 071506_schema
--echo #
CREATE DATABASE `db_071506_schema`;
USE `db_071506_schema`;
CREATE TABLE `events` (
  `id` INT NOT NULL,
  `title` TEXT,
  `description` TEXT,
  `geom` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  `publisher_id` INT,
  `feature_id` TEXT,
  `properties` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `http_requests` (
  `id` VARCHAR(50) NOT NULL,
  `scheme` CHAR(50),
  `userinfo` TEXT,
  `host` TEXT,
  `port` INT,
  `path` TEXT,
  `query` TEXT,
  `fragment` TEXT,
  `method` CHAR(50),
  `response_status` INT,
  `duration` INT,
  `started_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publishers` (
  `id` INT NOT NULL,
  `title` TEXT,
  `endpoint` TEXT,
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  `active` BOOLEAN,
  `city` TEXT,
  `icon` TEXT,
  `visible` BOOLEAN,
  `state` TEXT,
  `description` TEXT,
  `tags` VARCHAR(50),
  `event_display_endpoint` TEXT,
  `events_are_polygons` BOOLEAN,
  `sms_credentials_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schema_info` (
  `version` INT
) CHARACTER SET latin1;
CREATE TABLE `sms_credentials` (
  `id` INT NOT NULL,
  `credential_name` TEXT,
  `from_number` TEXT,
  `account_sid` TEXT,
  `auth_token` TEXT,
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subscriptions` (
  `geom` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  `publisher_id` INT,
  `channel` TEXT,
  `phone_number` TEXT,
  `email_address` TEXT,
  `webhook_url` TEXT,
  `unsubscribed_at` TIMESTAMP NULL,
  `id` VARCHAR(50) NOT NULL,
  `last_notified` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_071506_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_071506_schema') AS relationships;
DROP DATABASE `db_071506_schema`;
UNINSTALL EXTENSION vsql_schematron;
