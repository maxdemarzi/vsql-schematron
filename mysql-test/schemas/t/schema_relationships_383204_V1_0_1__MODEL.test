INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383204_V1.0.1__MODEL
--echo #
CREATE DATABASE `db_383204_V1_0_1__MODEL`;
USE `db_383204_V1_0_1__MODEL`;
CREATE TABLE `FOO` (
  `ID` INT NOT NULL,
  `DATA` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BAR` (
  `ID` INT NOT NULL,
  `FOO_ID` INT,
  `DATA` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383204_V1_0_1__MODEL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383204_V1_0_1__MODEL') AS relationships;
DROP DATABASE `db_383204_V1_0_1__MODEL`;
UNINSTALL EXTENSION vsql_schematron;
