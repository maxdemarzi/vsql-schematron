INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335642_Ex05
--echo #
CREATE DATABASE `db_335642_Ex05`;
USE `db_335642_Ex05`;
CREATE TABLE `client` (
  `cliNo` VARCHAR(50) NOT NULL,
  `cliName` VARCHAR(50),
  `cliPhone` VARCHAR(50),
  PRIMARY KEY (`cliNo`)
) CHARACTER SET latin1;
CREATE TABLE `orderProduct` (
  `ordNo` VARCHAR(50) NOT NULL,
  `ordCount` DECIMAL(10,2),
  `ordDay` DATE,
  `prdNo` VARCHAR(50),
  `cliNo` VARCHAR(50),
  PRIMARY KEY (`ordNo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335642_Ex05') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335642_Ex05') AS relationships;
DROP DATABASE `db_335642_Ex05`;
UNINSTALL EXTENSION vsql_schematron;
