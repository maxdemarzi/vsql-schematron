INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220768_20170119045003-initial-schema-up
--echo #
CREATE DATABASE `db_220768_20170119045003_initial_schema_up`;
USE `db_220768_20170119045003_initial_schema_up`;
CREATE TABLE `courtCases` (
  `id` BIGINT NOT NULL,
  `caseNumber` TEXT,
  `defendant` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `courtCaseEvents` (
  `id` BIGINT NOT NULL,
  `date` TIMESTAMP NULL,
  `courtCaseId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220768_20170119045003_initial_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220768_20170119045003_initial_schema_up') AS relationships;
DROP DATABASE `db_220768_20170119045003_initial_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
