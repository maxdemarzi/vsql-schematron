INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172537_3
--echo #
CREATE DATABASE `db_172537_3`;
USE `db_172537_3`;
CREATE TABLE `boat` (
  `bid` INT NOT NULL,
  `bname` VARCHAR(50),
  `colour` VARCHAR(50),
  PRIMARY KEY (`bid`)
) CHARACTER SET latin1;
CREATE TABLE `sailor` (
  `sid` INT NOT NULL,
  `sname` VARCHAR(50),
  `age` INT,
  `rating` INT,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `reserves` (
  `bid` INT NOT NULL,
  `sid` INT NOT NULL,
  `day` INT,
  PRIMARY KEY (`sid`, `bid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172537_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172537_3') AS relationships;
DROP DATABASE `db_172537_3`;
UNINSTALL EXTENSION vsql_schematron;
