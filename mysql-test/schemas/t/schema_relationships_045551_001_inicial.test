INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045551_001_inicial
--echo #
CREATE DATABASE `db_045551_001_inicial`;
USE `db_045551_001_inicial`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `senha` CHAR(50),
  `admin` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reclamacoes` (
  `id` INT NOT NULL,
  `data_incidente` TIMESTAMP NULL,
  `local` VARCHAR(50),
  `descricao` TEXT,
  `data_atendimento` TIMESTAMP NULL,
  `usuario_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045551_001_inicial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045551_001_inicial') AS relationships;
DROP DATABASE `db_045551_001_inicial`;
UNINSTALL EXTENSION vsql_schematron;
