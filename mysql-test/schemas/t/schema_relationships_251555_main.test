INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 251555_main
--echo #
CREATE DATABASE `db_251555_main`;
USE `db_251555_main`;
CREATE TABLE `student_info` (
  `std_id` INT NOT NULL,
  `f_name` VARCHAR(50),
  `l_name` VARCHAR(50),
  `birth_date` DATE,
  `sex` VARCHAR(50),
  `majorCode` INT,
  PRIMARY KEY (`std_id`)
) CHARACTER SET latin1;
CREATE TABLE `majorList` (
  `majorCode` INT NOT NULL,
  `majorName` VARCHAR(50),
  PRIMARY KEY (`majorCode`)
) CHARACTER SET latin1;
CREATE TABLE `instructor_info` (
  `ins_id` INT NOT NULL,
  `f_name` VARCHAR(50),
  `l_name` VARCHAR(50),
  PRIMARY KEY (`ins_id`)
) CHARACTER SET latin1;
CREATE TABLE `calc2` (
  `std_id` INT,
  `ins_id` INT,
  `yearTaken` INT,
  `term` VARCHAR(50),
  `mark` INT
) CHARACTER SET latin1;
CREATE TABLE `calc3` (
  `std_id` INT,
  `ins_id` INT,
  `yearTaken` INT,
  `term` VARCHAR(50),
  `mark` INT
) CHARACTER SET latin1;
CREATE TABLE `esp2` (
  `std_id` INT,
  `ins_id` INT,
  `yearTaken` INT,
  `term` VARCHAR(50),
  `mark` INT
) CHARACTER SET latin1;
CREATE TABLE `elecFundamentals` (
  `std_id` INT,
  `ins_id` INT,
  `yearTaken` INT,
  `term` VARCHAR(50),
  `mark` INT
) CHARACTER SET latin1;
CREATE TABLE `digitalSystems` (
  `std_id` INT,
  `ins_id` INT,
  `yearTaken` INT,
  `term` VARCHAR(50),
  `mark` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_251555_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_251555_main') AS relationships;
DROP DATABASE `db_251555_main`;
UNINSTALL EXTENSION vsql_schematron;
