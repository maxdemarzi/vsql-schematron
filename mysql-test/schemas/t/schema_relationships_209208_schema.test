INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 209208_schema
--echo #
CREATE DATABASE `db_209208_schema`;
USE `db_209208_schema`;
CREATE TABLE `student` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `enrolment` (
  `id` INT NOT NULL,
  `student_id` INT,
  `course_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_209208_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_209208_schema') AS relationships;
DROP DATABASE `db_209208_schema`;
UNINSTALL EXTENSION vsql_schematron;
