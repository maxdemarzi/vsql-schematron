INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 391008_setup-oracle
--echo #
CREATE DATABASE `db_391008_setup_oracle`;
USE `db_391008_setup_oracle`;
CREATE TABLE `plm_log_api` (
  `id` DECIMAL(10,2) NOT NULL,
  `date` TIMESTAMP NULL,
  `method` VARCHAR(50),
  `status_code` DECIMAL(10,2),
  `body_request` VARCHAR(50),
  `body_response` VARCHAR(50),
  `apiName` VARCHAR(50),
  `url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plm_log_header` (
  `id` DECIMAL(10,2) NOT NULL,
  `id_log_api` DECIMAL(10,2),
  `type` VARCHAR(50),
  `name` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_391008_setup_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_391008_setup_oracle') AS relationships;
DROP DATABASE `db_391008_setup_oracle`;
UNINSTALL EXTENSION vsql_schematron;
