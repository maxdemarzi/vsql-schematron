INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 304372_create
--echo #
CREATE DATABASE `db_304372_create`;
USE `db_304372_create`;
CREATE TABLE `libraries` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `buildings` (
  `id` INT NOT NULL,
  `library_id` INT,
  `kod` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` INT NOT NULL,
  `buildings_id` INT,
  `booknumber` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `catalogs` (
  `id` INT NOT NULL,
  `books_id` INT,
  `catalognumber` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `file_name` VARCHAR(50),
  `created` DATETIME,
  `modified` DATETIME,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_304372_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_304372_create') AS relationships;
DROP DATABASE `db_304372_create`;
UNINSTALL EXTENSION vsql_schematron;
