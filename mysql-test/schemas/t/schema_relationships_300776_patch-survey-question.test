INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 300776_patch-survey-question
--echo #
CREATE DATABASE `db_300776_patch_survey_question`;
USE `db_300776_patch_survey_question`;
CREATE TABLE `question` (
  `id` INT NOT NULL,
  `project_id` INT,
  `test_name` VARCHAR(50),
  `question_no` INT,
  `question` TEXT,
  `answer` CHAR(50),
  `response1` TEXT,
  `response2` TEXT,
  `response3` TEXT,
  `response4` TEXT,
  `response5` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
  `question_id` INT NOT NULL,
  `student_id` INT NOT NULL,
  `answer` CHAR(50),
  PRIMARY KEY (`question_id`, `student_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_300776_patch_survey_question') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_300776_patch_survey_question') AS relationships;
DROP DATABASE `db_300776_patch_survey_question`;
UNINSTALL EXTENSION vsql_schematron;
