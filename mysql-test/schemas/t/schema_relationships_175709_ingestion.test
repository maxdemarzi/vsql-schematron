INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175709_ingestion
--echo #
CREATE DATABASE `db_175709_ingestion`;
USE `db_175709_ingestion`;
CREATE TABLE `subreddits` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `post_id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `date` DATE,
  `subreddit` CHAR(50),
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175709_ingestion') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175709_ingestion') AS relationships;
DROP DATABASE `db_175709_ingestion`;
UNINSTALL EXTENSION vsql_schematron;
