INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 021982_bd_dapps_lista_deseos
--echo #
CREATE DATABASE `db_021982_bd_dapps_lista_deseos`;
USE `db_021982_bd_dapps_lista_deseos`;
CREATE TABLE `lista_deseos` (
  `usuario_id` VARCHAR(50) NOT NULL,
  `producto_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`usuario_id`, `producto_id`)
) CHARACTER SET latin1;
CREATE TABLE `producto` (
  `producto_id` VARCHAR(50) NOT NULL,
  `foto` VARCHAR(50),
  `modelo` VARCHAR(50),
  `categoria` VARCHAR(50),
  `calificacion` TINYINT,
  `precio` DOUBLE,
  `descripcion` TEXT,
  PRIMARY KEY (`producto_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_021982_bd_dapps_lista_deseos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_021982_bd_dapps_lista_deseos') AS relationships;
DROP DATABASE `db_021982_bd_dapps_lista_deseos`;
UNINSTALL EXTENSION vsql_schematron;
