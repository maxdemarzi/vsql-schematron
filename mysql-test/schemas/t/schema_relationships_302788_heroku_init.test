INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302788_heroku_init
--echo #
CREATE DATABASE `db_302788_heroku_init`;
USE `db_302788_heroku_init`;
CREATE TABLE `spring_session` (
  `PRIMARY_ID` VARCHAR(50) NOT NULL,
  `SESSION_ID` CHAR(50),
  `CREATION_TIME` BIGINT,
  `LAST_ACCESS_TIME` BIGINT,
  `MAX_INACTIVE_INTERVAL` INT,
  `EXPIRY_TIME` BIGINT,
  `PRINCIPAL_NAME` VARCHAR(50),
  PRIMARY KEY (`PRIMARY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `spring_session_attributes` (
  `session_primary_id` VARCHAR(50) NOT NULL,
  `attribute_name` VARCHAR(50) NOT NULL,
  `attribute_bytes` VARCHAR(50),
  PRIMARY KEY (`session_primary_id`, `attribute_name`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302788_heroku_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302788_heroku_init') AS relationships;
DROP DATABASE `db_302788_heroku_init`;
UNINSTALL EXTENSION vsql_schematron;
