INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606280_schema
--echo #
CREATE DATABASE `db_606280_schema`;
USE `db_606280_schema`;
CREATE TABLE `location` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `checkin` (
  `id` VARCHAR(50) NOT NULL,
  `location_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606280_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606280_schema') AS relationships;
DROP DATABASE `db_606280_schema`;
UNINSTALL EXTENSION vsql_schematron;
