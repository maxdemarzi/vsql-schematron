INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014691_schema
--echo #
CREATE DATABASE `db_014691_schema`;
USE `db_014691_schema`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` INT NOT NULL,
  `product_name` VARCHAR(50),
  `price` DECIMAL(10,2),
  `stock` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `id` INT NOT NULL,
  `tag_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `producttag` (
  `id` INT NOT NULL,
  `product_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014691_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014691_schema') AS relationships;
DROP DATABASE `db_014691_schema`;
UNINSTALL EXTENSION vsql_schematron;
