INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 306271_schema
--echo #
CREATE DATABASE `db_306271_schema`;
USE `db_306271_schema`;
CREATE TABLE `shopping_cart` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart_item` (
  `id` INT NOT NULL,
  `offer_id` INT,
  `tier_id` INT,
  `description` TEXT,
  `cart_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_306271_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_306271_schema') AS relationships;
DROP DATABASE `db_306271_schema`;
UNINSTALL EXTENSION vsql_schematron;
