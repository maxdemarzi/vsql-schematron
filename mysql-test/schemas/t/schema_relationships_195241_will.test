INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195241_will
--echo #
CREATE DATABASE `db_195241_will`;
USE `db_195241_will`;
CREATE TABLE `Species` (
  `speciesId` VARCHAR(50) NOT NULL,
  `species_name` VARCHAR(50),
  `species_price` DECIMAL(10,2),
  PRIMARY KEY (`speciesId`)
) CHARACTER SET latin1;
CREATE TABLE `Animal` (
  `animalId` VARCHAR(50) NOT NULL,
  `animal_name` VARCHAR(50),
  `species_Id` VARCHAR(50),
  PRIMARY KEY (`animalId`)
) CHARACTER SET latin1;
CREATE TABLE `Customer` (
  `custId` VARCHAR(50) NOT NULL,
  `cust_name` VARCHAR(50),
  `cust_email` VARCHAR(50),
  PRIMARY KEY (`custId`)
) CHARACTER SET latin1;
CREATE TABLE `Animal_Sale` (
  `sale_date` DATE,
  `animal_Id` VARCHAR(50),
  `cust_Id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195241_will') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195241_will') AS relationships;
DROP DATABASE `db_195241_will`;
UNINSTALL EXTENSION vsql_schematron;
