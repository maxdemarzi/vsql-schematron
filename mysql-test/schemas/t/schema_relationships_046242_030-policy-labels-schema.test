INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046242_030-policy-labels-schema
--echo #
CREATE DATABASE `db_046242_030_policy_labels_schema`;
USE `db_046242_030_policy_labels_schema`;
CREATE TABLE `x_policy_label` (
  `id` BIGINT NOT NULL,
  `guid` VARCHAR(50),
  `create_time` TIMESTAMP NULL,
  `update_time` TIMESTAMP NULL,
  `added_by_id` BIGINT,
  `upd_by_id` BIGINT,
  `label_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `x_policy_label_map` (
  `id` BIGINT NOT NULL,
  `guid` VARCHAR(50),
  `create_time` TIMESTAMP NULL,
  `update_time` TIMESTAMP NULL,
  `added_by_id` BIGINT,
  `upd_by_id` BIGINT,
  `policy_id` BIGINT,
  `policy_label_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046242_030_policy_labels_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046242_030_policy_labels_schema') AS relationships;
DROP DATABASE `db_046242_030_policy_labels_schema`;
UNINSTALL EXTENSION vsql_schematron;
