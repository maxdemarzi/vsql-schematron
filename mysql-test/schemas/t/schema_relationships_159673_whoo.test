INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159673_whoo
--echo #
CREATE DATABASE `db_159673_whoo`;
USE `db_159673_whoo`;
CREATE TABLE `whoo_user` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `email_verified` TINYINT,
  `sign_up_date_time` TIMESTAMP NULL,
  `sign_out_count` INT,
  `provider` VARCHAR(50),
  `provider_id` VARCHAR(50),
  `two_factor_authentication` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `whoo_authentication_code` (
  `id` INT NOT NULL,
  `type` INT,
  `code` VARCHAR(50),
  `trial_count` INT,
  `date_time` TIMESTAMP NULL,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159673_whoo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159673_whoo') AS relationships;
DROP DATABASE `db_159673_whoo`;
UNINSTALL EXTENSION vsql_schematron;
