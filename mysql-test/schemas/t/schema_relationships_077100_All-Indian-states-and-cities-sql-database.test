INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077100_All-Indian-states-and-cities-sql-database
--echo #
CREATE DATABASE `db_077100_All_Indian_states_and_cities_sql_database`;
USE `db_077100_All_Indian_states_and_cities_sql_database`;
CREATE TABLE `city` (
  `city_id` INT,
  `city_name` VARCHAR(50),
  `city_state_id` INT
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `country_id` INT,
  `country_code` VARCHAR(50),
  `country_name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `state` (
  `state_id` INT,
  `state_name` VARCHAR(50),
  `state_country_id` INT,
  `state_type` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077100_All_Indian_states_and_cities_sql_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077100_All_Indian_states_and_cities_sql_database') AS relationships;
DROP DATABASE `db_077100_All_Indian_states_and_cities_sql_database`;
UNINSTALL EXTENSION vsql_schematron;
