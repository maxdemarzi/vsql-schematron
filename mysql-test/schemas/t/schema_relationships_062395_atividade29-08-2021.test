INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062395_atividade29-08-2021
--echo #
CREATE DATABASE `db_062395_atividade29_08_2021`;
USE `db_062395_atividade29_08_2021`;
CREATE TABLE `cliente` (
  `nome` VARCHAR(50),
  `codigo` INT NOT NULL,
  `STATUS` CHAR(50),
  `limite_credito` VARCHAR(50),
  `cpf` CHAR(50),
  `rua` VARCHAR(50),
  `numero` CHAR(50),
  `cep` INT,
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `UF` CHAR(50),
  `complemento` VARCHAR(50),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
CREATE TABLE `telefone` (
  `numero` INT,
  `codigo` INT NOT NULL,
  `tipo` VARCHAR(50),
  `DDD` CHAR(50),
  `codCliente` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `codigo` INT NOT NULL,
  `DATA` DATE,
  `numero` INT,
  `codCliente` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `nome` VARCHAR(50),
  `codigo` INT NOT NULL,
  `categoria` VARCHAR(50),
  `preco` VARCHAR(50),
  `quantidade` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
CREATE TABLE `pedidoProduto` (
  `codigo` INT NOT NULL,
  `codPedido` INT,
  `codProduto` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062395_atividade29_08_2021') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062395_atividade29_08_2021') AS relationships;
DROP DATABASE `db_062395_atividade29_08_2021`;
UNINSTALL EXTENSION vsql_schematron;
