INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347641_Activity.CREATE
--echo #
CREATE DATABASE `db_347641_Activity_CREATE`;
USE `db_347641_Activity_CREATE`;
CREATE TABLE `Activity` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ActivityRole` (
  `ActivityId` VARCHAR(50) NOT NULL,
  `RoleName` VARCHAR(50) NOT NULL,
  `Operations` VARCHAR(50),
  PRIMARY KEY (`ActivityId`, `RoleName`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347641_Activity_CREATE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347641_Activity_CREATE') AS relationships;
DROP DATABASE `db_347641_Activity_CREATE`;
UNINSTALL EXTENSION vsql_schematron;
