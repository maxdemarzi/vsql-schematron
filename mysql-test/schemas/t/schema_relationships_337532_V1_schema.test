INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 337532_V1_schema
--echo #
CREATE DATABASE `db_337532_V1_schema`;
USE `db_337532_V1_schema`;
CREATE TABLE `BRANCH` (
  `BRANCH_ID` INT NOT NULL,
  `BRANCH_SHORT_NAME` VARCHAR(50),
  `BRANCH_NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`BRANCH_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SUBJECT` (
  `SUBJECT_ID` INT NOT NULL,
  `SUBJECT_NAME` VARCHAR(50),
  `SUBJECT_DESC` VARCHAR(50),
  PRIMARY KEY (`SUBJECT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BRANCH_SUBJECT` (
  `BRANCH_ID` INT NOT NULL,
  `SUBJECT_ID` INT NOT NULL,
  PRIMARY KEY (`BRANCH_ID`, `SUBJECT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK_AUTHOR` (
  `AUTHOR` INT NOT NULL,
  `BOOK` INT NOT NULL,
  PRIMARY KEY (`AUTHOR`, `BOOK`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_337532_V1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_337532_V1_schema') AS relationships;
DROP DATABASE `db_337532_V1_schema`;
UNINSTALL EXTENSION vsql_schematron;
