INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 155155_V1_4__oppdaterer_modell
--echo #
CREATE DATABASE `db_155155_V1_4__oppdaterer_modell`;
USE `db_155155_V1_4__oppdaterer_modell`;
CREATE TABLE `KARTLEGGING` (
  `kartlegging_id` DECIMAL(10,2) NOT NULL,
  `aktor_id` VARCHAR(50),
  `under_oppfolging` DECIMAL(10,2),
  `kartlegging_dato` TIMESTAMP NULL,
  PRIMARY KEY (`kartlegging_id`)
) CHARACTER SET latin1;
CREATE TABLE `BESVARELSE` (
  `besvarelse_id` DECIMAL(10,2) NOT NULL,
  `kartlegging_id` DECIMAL(10,2),
  `sporsmal_key` VARCHAR(50),
  `sporsmal` VARCHAR(50),
  `tips_key` VARCHAR(50),
  `tips` VARCHAR(50),
  PRIMARY KEY (`besvarelse_id`)
) CHARACTER SET latin1;
CREATE TABLE `SVARALTERNATIV` (
  `svaralternativ_id` DECIMAL(10,2) NOT NULL,
  `besvarelse_id` DECIMAL(10,2),
  `svaralternativ_key` VARCHAR(50),
  `svaralternativ` VARCHAR(50),
  PRIMARY KEY (`svaralternativ_id`)
) CHARACTER SET latin1;
CREATE TABLE `RAAD` (
  `raad_id` DECIMAL(10,2) NOT NULL,
  `kartlegging_id` DECIMAL(10,2),
  `raad_key` VARCHAR(50),
  `raad_tittel` VARCHAR(50),
  `raad_ingress` VARCHAR(50),
  PRIMARY KEY (`raad_id`)
) CHARACTER SET latin1;
CREATE TABLE `AKTIVITET` (
  `aktivitet_id` DECIMAL(10,2) NOT NULL,
  `raad_id` DECIMAL(10,2),
  `tittel` VARCHAR(50),
  `innhold` VARCHAR(50),
  PRIMARY KEY (`aktivitet_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_155155_V1_4__oppdaterer_modell') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_155155_V1_4__oppdaterer_modell') AS relationships;
DROP DATABASE `db_155155_V1_4__oppdaterer_modell`;
UNINSTALL EXTENSION vsql_schematron;
