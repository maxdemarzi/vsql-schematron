INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 567551_practice
--echo #
CREATE DATABASE `db_567551_practice`;
USE `db_567551_practice`;
CREATE TABLE `customer` (
  `customerid` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `location` VARCHAR(50),
  PRIMARY KEY (`customerid`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `productid` VARCHAR(50) NOT NULL,
  `productname` VARCHAR(50),
  `unitprice` DECIMAL(10,2),
  `category` VARCHAR(50),
  `provider` VARCHAR(50),
  PRIMARY KEY (`productid`)
) CHARACTER SET latin1;
CREATE TABLE `purcase` (
  `customerid` VARCHAR(50),
  `productid` VARCHAR(50),
  `quantity` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_567551_practice') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_567551_practice') AS relationships;
DROP DATABASE `db_567551_practice`;
UNINSTALL EXTENSION vsql_schematron;
