INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 569025_migration
--echo #
CREATE DATABASE `db_569025_migration`;
USE `db_569025_migration`;
CREATE TABLE `TeamMember` (
  `uuid` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `teamId` VARCHAR(50) NOT NULL,
  `memberId` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`teamId`, `memberId`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
  `uuid` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `displayName` TEXT,
  `description` TEXT,
  `ownerId` TEXT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_569025_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_569025_migration') AS relationships;
DROP DATABASE `db_569025_migration`;
UNINSTALL EXTENSION vsql_schematron;
