INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217959_01_ddl
--echo #
CREATE DATABASE `db_217959_01_ddl`;
USE `db_217959_01_ddl`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `post_id` INT NOT NULL,
  `title` VARCHAR(50),
  `body` TEXT,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217959_01_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217959_01_ddl') AS relationships;
DROP DATABASE `db_217959_01_ddl`;
UNINSTALL EXTENSION vsql_schematron;
