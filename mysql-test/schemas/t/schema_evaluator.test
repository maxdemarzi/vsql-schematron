INSTALL EXTENSION vsql_schematron;
--disable_warnings
DROP DATABASE IF EXISTS `db_033891_Week4_Class`;
--enable_warnings
CREATE DATABASE `db_033891_Week4_Class`;
USE `db_033891_Week4_Class`;
CREATE TABLE `dept` (
  `deptid` DECIMAL(10,2) NOT NULL,
  `dname` VARCHAR(50),
  `fax` VARCHAR(50),
  PRIMARY KEY (`deptid`)
) CHARACTER SET latin1;
CREATE TABLE `etypes` (
  `etypeid` DECIMAL(10,2) NOT NULL,
  `etypename` VARCHAR(50),
  PRIMARY KEY (`etypeid`)
) CHARACTER SET latin1;
CREATE TABLE `equip` (
  `equipid` DECIMAL(10,2) NOT NULL,
  `edesc` VARCHAR(50),
  `purchdate` DATE,
  `rating` CHAR(50),
  `deptid` DECIMAL(10,2),
  `etypeid` DECIMAL(10,2),
  PRIMARY KEY (`equipid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033891_Week4_Class') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
--echo SCHEMA_START: 033891_Week4_Class
SELECT vsql_schema_relationships('db_033891_Week4_Class') AS relationships;
--echo SCHEMA_END
DROP DATABASE `db_033891_Week4_Class`;
UNINSTALL EXTENSION vsql_schematron;
