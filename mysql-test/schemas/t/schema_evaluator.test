INSTALL EXTENSION vsql_schematron;
--disable_warnings
DROP DATABASE IF EXISTS `db_287324_database`;
--enable_warnings
CREATE DATABASE `db_287324_database`;
USE `db_287324_database`;
CREATE TABLE `person` (
  `idperson` INT NOT NULL,
  `fullName` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `status` CHAR(50),
  PRIMARY KEY (`idperson`)
) CHARACTER SET latin1;
CREATE TABLE `Transaction` (
  `idperson` INT,
  `idtransaction` INT NOT NULL,
  `description` VARCHAR(50),
  `value` VARCHAR(50),
  `date` DATE,
  PRIMARY KEY (`idtransaction`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_287324_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
--echo SCHEMA_START: 287324_database
SELECT vsql_schema_relationships('db_287324_database') AS relationships;
--echo SCHEMA_END
DROP DATABASE `db_287324_database`;
UNINSTALL EXTENSION vsql_schematron;
