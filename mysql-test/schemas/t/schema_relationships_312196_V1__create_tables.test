INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312196_V1__create_tables
--echo #
CREATE DATABASE `db_312196_V1__create_tables`;
USE `db_312196_V1__create_tables`;
CREATE TABLE `auction` (
  `id` BIGINT NOT NULL,
  `item_code` VARCHAR(50),
  `status` VARCHAR(50),
  `min_base_price` DOUBLE,
  `step_price` DOUBLE,
  `max_bid_amount` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bid` (
  `id` BIGINT NOT NULL,
  `auction_id` BIGINT,
  `user_id` BIGINT,
  `bid_amount` DOUBLE,
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312196_V1__create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312196_V1__create_tables') AS relationships;
DROP DATABASE `db_312196_V1__create_tables`;
UNINSTALL EXTENSION vsql_schematron;
