INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 628877_printer
--echo #
CREATE DATABASE `db_628877_printer`;
USE `db_628877_printer`;
CREATE TABLE `manufacturer` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `model` (
  `id` VARCHAR(50) NOT NULL,
  `manufacturer_id` VARCHAR(50),
  `name` VARCHAR(50),
  `driver` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `printer` (
  `id` VARCHAR(50) NOT NULL,
  `model_id` VARCHAR(50),
  `location_id` VARCHAR(50),
  `hostname` VARCHAR(50),
  `driver_extra` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_628877_printer') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_628877_printer') AS relationships;
DROP DATABASE `db_628877_printer`;
UNINSTALL EXTENSION vsql_schematron;
