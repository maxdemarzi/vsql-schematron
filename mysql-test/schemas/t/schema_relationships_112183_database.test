INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 112183_database
--echo #
CREATE DATABASE `db_112183_database`;
USE `db_112183_database`;
CREATE TABLE `patient` (
  `id` INT NOT NULL,
  `имя` VARCHAR(50),
  `фамилия` VARCHAR(50),
  `отчество` VARCHAR(50),
  `телефон` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `doctor` (
  `id` INT NOT NULL,
  `имя` VARCHAR(50),
  `фамилия` VARCHAR(50),
  `отчество` VARCHAR(50),
  `специализация` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
  `id` INT NOT NULL,
  `описание` VARCHAR(50),
  `дата_создания` INT,
  `срок_действия` INT,
  `приоритет` VARCHAR(50),
  `doctorid` INT,
  `patientid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_112183_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_112183_database') AS relationships;
DROP DATABASE `db_112183_database`;
UNINSTALL EXTENSION vsql_schematron;
