INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 401515_help
--echo #
CREATE DATABASE `db_401515_help`;
USE `db_401515_help`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `registration_time` TIMESTAMP NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `is_moderator` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `date` TIMESTAMP NULL,
  `header` VARCHAR(50),
  `description` BLOB,
  `comments_count` INT,
  `tags` BLOB,
  `user_id` INT,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_401515_help') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_401515_help') AS relationships;
DROP DATABASE `db_401515_help`;
UNINSTALL EXTENSION vsql_schematron;
