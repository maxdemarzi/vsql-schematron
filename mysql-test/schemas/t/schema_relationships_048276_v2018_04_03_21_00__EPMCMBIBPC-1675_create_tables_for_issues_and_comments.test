INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048276_v2018.04.03_21.00__EPMCMBIBPC-1675_create_tables_for_issues_and_comments
--echo #
CREATE DATABASE `db_048276_v2018_04_03_21_00__EPMCMBIBPC_1675_create_tables_for_i`;
USE `db_048276_v2018_04_03_21_00__EPMCMBIBPC_1675_create_tables_for_i`;
CREATE TABLE `pipeline.issue` (
  `issue_id` BIGINT NOT NULL,
  `issue_name` TEXT,
  `issue_text` TEXT,
  `issue_author` TEXT,
  `entity_id` BIGINT,
  `entity_class` TEXT,
  `created_date` TIMESTAMP NULL,
  `updated_date` TIMESTAMP NULL,
  `issue_status` BIGINT,
  `labels` VARCHAR(50),
  PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
CREATE TABLE `pipeline.issue_comment` (
  `comment_id` BIGINT NOT NULL,
  `issue_id` BIGINT,
  `comment_text` TEXT,
  `comment_author` TEXT,
  `created_date` TIMESTAMP NULL,
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048276_v2018_04_03_21_00__EPMCMBIBPC_1675_create_tables_for_i') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048276_v2018_04_03_21_00__EPMCMBIBPC_1675_create_tables_for_i') AS relationships;
DROP DATABASE `db_048276_v2018_04_03_21_00__EPMCMBIBPC_1675_create_tables_for_i`;
UNINSTALL EXTENSION vsql_schematron;
