INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351693_order
--echo #
CREATE DATABASE `db_351693_order`;
USE `db_351693_order`;
CREATE TABLE `orders` (
  `order_id` INT NOT NULL,
  `order_no` VARCHAR(50),
  `order_name` VARCHAR(50),
  `customer_name` VARCHAR(50),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `item_id` INT NOT NULL,
  `order_id` INT,
  `items_name` VARCHAR(50),
  `quantity` INT,
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351693_order') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351693_order') AS relationships;
DROP DATABASE `db_351693_order`;
UNINSTALL EXTENSION vsql_schematron;
