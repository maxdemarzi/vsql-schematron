INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 162281_h2-schema
--echo #
CREATE DATABASE `db_162281_h2_schema`;
USE `db_162281_h2_schema`;
CREATE TABLE `trainingtool.user` (
  `id` INT NOT NULL,
  `version` INT,
  `created_on` TIMESTAMP NULL,
  `modified_on` TIMESTAMP NULL,
  `pnr` VARCHAR(50),
  `username` VARCHAR(50),
  `role` VARCHAR(50),
  `lastname` VARCHAR(50),
  `firstname` VARCHAR(50),
  `email` VARCHAR(50),
  `sector` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `function` VARCHAR(50),
  `managername` VARCHAR(50),
  `subco` BOOLEAN,
  `ssin` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trainingtool.registration` (
  `id` INT NOT NULL,
  `version` INT,
  `created_on` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `modified_on` TIMESTAMP NULL,
  `modified_by` VARCHAR(50),
  `status` VARCHAR(50),
  `user_id` INT,
  `training_id` INT,
  `provider` VARCHAR(50),
  `provider_other` VARCHAR(50),
  `ssin` VARCHAR(50),
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `url` VARCHAR(50),
  `price` VARCHAR(50),
  `start_date` TIMESTAMP NULL,
  `end_date` TIMESTAMP NULL,
  `period` VARCHAR(50),
  `total_hour` VARCHAR(50),
  `location` VARCHAR(50),
  `self_study` VARCHAR(50),
  `mandatory` VARCHAR(50),
  `billable` VARCHAR(50),
  `cba_compliant` VARCHAR(50),
  `comment` VARCHAR(50),
  `motivation` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_162281_h2_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_162281_h2_schema') AS relationships;
DROP DATABASE `db_162281_h2_schema`;
UNINSTALL EXTENSION vsql_schematron;
