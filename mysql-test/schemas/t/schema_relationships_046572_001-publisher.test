INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046572_001-publisher
--echo #
CREATE DATABASE `db_046572_001_publisher`;
USE `db_046572_001_publisher`;
CREATE TABLE `publisher` (
  `id` INT NOT NULL,
  `name` TEXT,
  `url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publisher_feed` (
  `id` INT NOT NULL,
  `publisher_id` INT,
  `name` TEXT,
  `url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046572_001_publisher') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046572_001_publisher') AS relationships;
DROP DATABASE `db_046572_001_publisher`;
UNINSTALL EXTENSION vsql_schematron;
