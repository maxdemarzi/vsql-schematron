INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 078467_dbpoli
--echo #
CREATE DATABASE `db_078467_dbpoli`;
USE `db_078467_dbpoli`;
CREATE TABLE `bmi_pasien` (
  `id` INT,
  `tanggal` DATE,
  `berat` DOUBLE,
  `tinggi` DOUBLE,
  `bmi` DOUBLE,
  `status_bmi` VARCHAR(50),
  `catatan` VARCHAR(50),
  `pasien_id` INT
) CHARACTER SET latin1;
CREATE TABLE `pasien` (
  `id` INT,
  `kode` VARCHAR(50),
  `nama` VARCHAR(50),
  `gender` CHAR(50),
  `tmpt_lahir` VARCHAR(50),
  `tgl_lahir` DATE,
  `email` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_078467_dbpoli') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_078467_dbpoli') AS relationships;
DROP DATABASE `db_078467_dbpoli`;
UNINSTALL EXTENSION vsql_schematron;
