INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 104465_create_tables
--echo #
CREATE DATABASE `db_104465_create_tables`;
USE `db_104465_create_tables`;
CREATE TABLE `addresses` (
  `address_id` INT NOT NULL,
  `street` VARCHAR(50),
  `number` INT,
  `city` VARCHAR(50),
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `persons` (
  `person_id` INT NOT NULL,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `address_id` INT,
  PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_104465_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_104465_create_tables') AS relationships;
DROP DATABASE `db_104465_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
