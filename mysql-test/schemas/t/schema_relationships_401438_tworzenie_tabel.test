INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 401438_tworzenie_tabel
--echo #
CREATE DATABASE `db_401438_tworzenie_tabel`;
USE `db_401438_tworzenie_tabel`;
CREATE TABLE `Autor` (
  `id_autora` INT NOT NULL,
  `imie` VARCHAR(50),
  `nazwisko` VARCHAR(50),
  PRIMARY KEY (`id_autora`)
) CHARACTER SET latin1;
CREATE TABLE `Gatunek` (
  `id_gatunku` INT NOT NULL,
  `nazwa_gatunku` VARCHAR(50),
  PRIMARY KEY (`id_gatunku`)
) CHARACTER SET latin1;
CREATE TABLE `Wydawnictwo` (
  `id_wydawnictwa` INT NOT NULL,
  `nazwa` VARCHAR(50),
  PRIMARY KEY (`id_wydawnictwa`)
) CHARACTER SET latin1;
CREATE TABLE `uczen` (
  `id_ucznia` INT NOT NULL,
  `imie` VARCHAR(50),
  `nazwisko` VARCHAR(50),
  `rok_ur` INT,
  `klasa` VARCHAR(50),
  PRIMARY KEY (`id_ucznia`)
) CHARACTER SET latin1;
CREATE TABLE `Ksiazka` (
  `id_ksiazki` INT NOT NULL,
  `tytul` VARCHAR(50),
  `id_autora` INT,
  `id_gatunku` INT,
  `id_wydawnictwa` INT,
  `rok_wydania` INT,
  PRIMARY KEY (`id_ksiazki`)
) CHARACTER SET latin1;
CREATE TABLE `Wypozyczenie` (
  `id_wypozyczenia` INT NOT NULL,
  `id_ksiazki` INT,
  `id_autora` INT,
  `id_gatunku` INT,
  `id_wydawnictwa` INT,
  `id_ucznia` INT,
  `data_wypozyczenia` DATE,
  `data_zwrotu` DATE,
  PRIMARY KEY (`id_wypozyczenia`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_401438_tworzenie_tabel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_401438_tworzenie_tabel') AS relationships;
DROP DATABASE `db_401438_tworzenie_tabel`;
UNINSTALL EXTENSION vsql_schematron;
