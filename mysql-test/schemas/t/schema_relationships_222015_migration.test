INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 222015_migration
--echo #
CREATE DATABASE `db_222015_migration`;
USE `db_222015_migration`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `uuid` TEXT,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `role` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updater_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `uuid` TEXT,
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updater_at` TIMESTAMP NULL,
  `body` TEXT,
  `UserId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_222015_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_222015_migration') AS relationships;
DROP DATABASE `db_222015_migration`;
UNINSTALL EXTENSION vsql_schematron;
