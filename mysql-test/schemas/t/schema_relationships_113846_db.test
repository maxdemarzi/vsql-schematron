INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113846_db
--echo #
CREATE DATABASE `db_113846_db`;
USE `db_113846_db`;
CREATE TABLE `config` (
  `key` VARCHAR(50) NOT NULL,
  `value` TEXT,
  `datatype` VARCHAR(50),
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `passwordSalt` VARCHAR(50),
  `languageCode` VARCHAR(50),
  `verifyEmailCode` VARCHAR(50),
  `verifyEmailCodeExpires` DATETIME,
  `isAdmin` BOOLEAN,
  `lastUpdated` DATETIME,
  `badLoginAttempts` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reset_password` (
  `userId` INT,
  `token` VARCHAR(50),
  `expires` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
  `id` INT NOT NULL,
  `userId` INT,
  `public` BOOLEAN,
  `languageCode` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `category` VARCHAR(50),
  `portions` INT,
  `difficulty` INT,
  `preparation` TEXT,
  `preparationTime` INT,
  `restTime` INT,
  `cookTime` INT,
  `publishDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `id` INT NOT NULL,
  `recipeId` INT,
  `amount` DOUBLE,
  `unit` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_images` (
  `id` INT NOT NULL,
  `recipeId` INT,
  `path` TEXT,
  `mimeType` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113846_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113846_db') AS relationships;
DROP DATABASE `db_113846_db`;
UNINSTALL EXTENSION vsql_schematron;
