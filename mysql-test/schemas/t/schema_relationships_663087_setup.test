INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663087_setup
--echo #
CREATE DATABASE `db_663087_setup`;
USE `db_663087_setup`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `nickId` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `created_at` DATE,
  `updated_at` DATE,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `File` (
  `id` VARCHAR(50) NOT NULL,
  `filename` VARCHAR(50),
  `mimetype` VARCHAR(50),
  `url` VARCHAR(50),
  `owner_id` VARCHAR(50),
  `post_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id` VARCHAR(50) NOT NULL,
  `content` TEXT,
  `created_at` DATE,
  `user_id` VARCHAR(50),
  `post_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663087_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663087_setup') AS relationships;
DROP DATABASE `db_663087_setup`;
UNINSTALL EXTENSION vsql_schematron;
