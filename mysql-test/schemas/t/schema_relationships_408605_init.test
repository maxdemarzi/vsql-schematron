INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 408605_init
--echo #
CREATE DATABASE `db_408605_init`;
USE `db_408605_init`;
CREATE TABLE `hotels` (
  `id` INT NOT NULL,
  `description` TEXT,
  `cost` INT,
  `creation_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
  `booking_id` INT NOT NULL,
  `hotel_id` INT,
  `begin_data` DATE,
  `end_date` DATE,
  PRIMARY KEY (`booking_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_408605_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_408605_init') AS relationships;
DROP DATABASE `db_408605_init`;
UNINSTALL EXTENSION vsql_schematron;
