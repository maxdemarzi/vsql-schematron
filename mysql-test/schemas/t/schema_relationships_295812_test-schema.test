INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295812_test-schema
--echo #
CREATE DATABASE `db_295812_test_schema`;
USE `db_295812_test_schema`;
CREATE TABLE `TABLE1` (
  `NAME` VARCHAR(50) NOT NULL,
  `FIRST_NAME` VARCHAR(50) NOT NULL,
  `PROFESSION` VARCHAR(50),
  PRIMARY KEY (`NAME`, `FIRST_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `TABLE2` (
  `PROFESSION` VARCHAR(50) NOT NULL,
  `RECOGNITION` VARCHAR(50),
  `COMMENTS` TEXT,
  PRIMARY KEY (`PROFESSION`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295812_test_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295812_test_schema') AS relationships;
DROP DATABASE `db_295812_test_schema`;
UNINSTALL EXTENSION vsql_schematron;
