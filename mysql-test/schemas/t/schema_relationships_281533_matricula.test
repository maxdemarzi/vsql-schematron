INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281533_matricula
--echo #
CREATE DATABASE `db_281533_matricula`;
USE `db_281533_matricula`;
CREATE TABLE `rol` (
  `id` INT NOT NULL,
  `desc` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `creado` TIMESTAMP NULL,
  `modificado` TIMESTAMP NULL,
  `rol` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comentario` (
  `id` INT NOT NULL,
  `creado` TIMESTAMP NULL,
  `usuario` INT,
  `texto` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281533_matricula') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281533_matricula') AS relationships;
DROP DATABASE `db_281533_matricula`;
UNINSTALL EXTENSION vsql_schematron;
