INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086877_quickstack
--echo #
CREATE DATABASE `db_086877_quickstack`;
USE `db_086877_quickstack`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `uuid` CHAR(50),
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` TINYINT,
  `visible` TINYINT,
  `status` TINYINT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
  `id` INT NOT NULL,
  `uuid` CHAR(50),
  `user_id` INT,
  `dealer_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` TINYINT,
  `date_of_birth` DATE,
  `phone_number` VARCHAR(50),
  `mobile_number` VARCHAR(50),
  `image` TEXT,
  `company_name` VARCHAR(50),
  `primary_address_street` VARCHAR(50),
  `primary_address_street_2` VARCHAR(50),
  `primary_address_city` VARCHAR(50),
  `primary_address_state` VARCHAR(50),
  `primary_address_post_code` VARCHAR(50),
  `primary_address_country` VARCHAR(50),
  `billing_address_street` VARCHAR(50),
  `billing_address_city` VARCHAR(50),
  `billing_address_state` VARCHAR(50),
  `billing_address_post_code` VARCHAR(50),
  `billing_address_country` VARCHAR(50),
  `security_question_1` VARCHAR(50),
  `security_answer_1` VARCHAR(50),
  `security_question_2` VARCHAR(50),
  `security_answer_2` VARCHAR(50),
  `security_question_custom` VARCHAR(50),
  `security_answer_custom` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086877_quickstack') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086877_quickstack') AS relationships;
DROP DATABASE `db_086877_quickstack`;
UNINSTALL EXTENSION vsql_schematron;
