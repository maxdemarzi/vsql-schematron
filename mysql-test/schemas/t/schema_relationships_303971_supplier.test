INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303971_supplier
--echo #
CREATE DATABASE `db_303971_supplier`;
USE `db_303971_supplier`;
CREATE TABLE `suppliers` (
  `sno` INT NOT NULL,
  `sname` VARCHAR(50),
  `city` VARCHAR(50),
  PRIMARY KEY (`sno`)
) CHARACTER SET latin1;
CREATE TABLE `parts` (
  `pno` INT NOT NULL,
  `pname` VARCHAR(50),
  `price` DOUBLE,
  PRIMARY KEY (`pno`)
) CHARACTER SET latin1;
CREATE TABLE `supplies` (
  `sno` INT,
  `pno` INT,
  `quantity` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303971_supplier') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303971_supplier') AS relationships;
DROP DATABASE `db_303971_supplier`;
UNINSTALL EXTENSION vsql_schematron;
