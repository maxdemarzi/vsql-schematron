INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 309491_crawler
--echo #
CREATE DATABASE `db_309491_crawler`;
USE `db_309491_crawler`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `email` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `filtro` (
  `id` INT NOT NULL,
  `idUsuario` INT,
  `regional` TEXT,
  `municipio` TEXT,
  `cargo` TEXT,
  `categoria` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `envio` (
  `idUsuario` INT,
  `idDesignacao` TEXT,
  `enviado` INT
) CHARACTER SET latin1;
CREATE TABLE `designacao` (
  `id` VARCHAR(50) NOT NULL,
  `url` TEXT,
  `conteudo` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `configEmail` (
  `nome` TEXT,
  `tipoServico` TEXT,
  `email` TEXT,
  `login` TEXT,
  `senha` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_309491_crawler') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_309491_crawler') AS relationships;
DROP DATABASE `db_309491_crawler`;
UNINSTALL EXTENSION vsql_schematron;
