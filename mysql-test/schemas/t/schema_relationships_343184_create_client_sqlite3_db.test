INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343184_create_client_sqlite3_db
--echo #
CREATE DATABASE `db_343184_create_client_sqlite3_db`;
USE `db_343184_create_client_sqlite3_db`;
CREATE TABLE `sensor` (
  `sensor_id` INT NOT NULL,
  `type` TEXT,
  `name` TEXT,
  PRIMARY KEY (`sensor_id`)
) CHARACTER SET latin1;
CREATE TABLE `data` (
  `data_id` INT NOT NULL,
  `sensor_id` INT,
  `data` INT,
  `raw_data` INT,
  `date` INT,
  PRIMARY KEY (`data_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343184_create_client_sqlite3_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343184_create_client_sqlite3_db') AS relationships;
DROP DATABASE `db_343184_create_client_sqlite3_db`;
UNINSTALL EXTENSION vsql_schematron;
