INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 173474_create_database
--echo #
CREATE DATABASE `db_173474_create_database`;
USE `db_173474_create_database`;
CREATE TABLE `locations` (
  `location_id` VARCHAR(50) NOT NULL,
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_data` (
  `location_id` VARCHAR(50) NOT NULL,
  `day` INT NOT NULL,
  `description` VARCHAR(50),
  `high_temp` DOUBLE,
  `low_temp` DOUBLE,
  `humidity` INT,
  PRIMARY KEY (`day`, `location_id`)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
  `log_id` INT NOT NULL,
  `ip` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`log_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_173474_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_173474_create_database') AS relationships;
DROP DATABASE `db_173474_create_database`;
UNINSTALL EXTENSION vsql_schematron;
