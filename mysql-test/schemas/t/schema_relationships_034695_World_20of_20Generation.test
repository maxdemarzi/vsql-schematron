INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 034695_World%20of%20Generation
--echo #
CREATE DATABASE `db_034695_World_20of_20Generation`;
USE `db_034695_World_20of_20Generation`;
CREATE TABLE `tb_class` (
  `id_cla` INT NOT NULL,
  `apelido` VARCHAR(50),
  `Tipo` VARCHAR(50),
  `magia` INT,
  `arma` VARCHAR(50),
  `sabedoria` INT,
  PRIMARY KEY (`id_cla`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pers` (
  `id_pers` INT NOT NULL,
  `nome` VARCHAR(50),
  `fraqueza` VARCHAR(50),
  `poder_ataque` INT,
  `id_cla` INT,
  PRIMARY KEY (`id_pers`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_034695_World_20of_20Generation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_034695_World_20of_20Generation') AS relationships;
DROP DATABASE `db_034695_World_20of_20Generation`;
UNINSTALL EXTENSION vsql_schematron;
