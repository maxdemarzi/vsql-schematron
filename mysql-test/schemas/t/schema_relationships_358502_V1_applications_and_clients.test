INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358502_V1_applications_and_clients
--echo #
CREATE DATABASE `db_358502_V1_applications_and_clients`;
USE `db_358502_V1_applications_and_clients`;
CREATE TABLE `sec.client` (
  `client_id` VARCHAR(50) NOT NULL,
  `client_secret` CHAR(50),
  `grant_types` CHAR(50),
  `redirect_uris` CHAR(50),
  `access_token_lifetime` INT,
  `refresh_token_lifetime` INT,
  `logout_url` CHAR(50),
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `sec.client_role` (
  `client_id` VARCHAR(50) NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`client_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `sec.application` (
  `code` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  `system_code` CHAR(50),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358502_V1_applications_and_clients') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358502_V1_applications_and_clients') AS relationships;
DROP DATABASE `db_358502_V1_applications_and_clients`;
UNINSTALL EXTENSION vsql_schematron;
