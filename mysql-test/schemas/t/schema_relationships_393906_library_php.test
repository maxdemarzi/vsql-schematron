INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 393906_library_php
--echo #
CREATE DATABASE `db_393906_library_php`;
USE `db_393906_library_php`;
CREATE TABLE `People` (
  `id` VARCHAR(50) NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `card_number` INT,
  `adress` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
  `id` VARCHAR(50) NOT NULL,
  `book_name` VARCHAR(50),
  `writer` VARCHAR(50),
  `resume` TEXT,
  `created_date` VARCHAR(50),
  `category` VARCHAR(50),
  `borrowed` VARCHAR(50),
  `people_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_393906_library_php') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_393906_library_php') AS relationships;
DROP DATABASE `db_393906_library_php`;
UNINSTALL EXTENSION vsql_schematron;
