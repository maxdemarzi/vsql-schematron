INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 382718_text
--echo #
CREATE DATABASE `db_382718_text`;
USE `db_382718_text`;
CREATE TABLE `Files` (
  `id` INT NOT NULL,
  `full_name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `FilesText` (
  `id` INT NOT NULL,
  `fileId` INT,
  `rawText` VARCHAR(50),
  `cleanText` VARCHAR(50),
  `sentence` VARCHAR(50),
  `words` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_382718_text') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_382718_text') AS relationships;
DROP DATABASE `db_382718_text`;
UNINSTALL EXTENSION vsql_schematron;
