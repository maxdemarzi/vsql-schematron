  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_235777_000004_create_orders_and_order_items_table_up') AS relationships;
DROP DATABASE `db_235777_000004_create_orders_and_order_items_table_up`;
