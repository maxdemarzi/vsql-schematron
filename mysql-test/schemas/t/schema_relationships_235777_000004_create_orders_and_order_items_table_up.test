INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 235777_000004_create_orders_and_order_items_table.up
--echo #
CREATE DATABASE `db_235777_000004_create_orders_and_order_items_table_up`;
USE `db_235777_000004_create_orders_and_order_items_table_up`;
CREATE TABLE `public.orders` (
  `id` VARCHAR(50) NOT NULL,
  `customer_name` VARCHAR(50),
  `customer_email` VARCHAR(50),
  `customer_address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.order_items` (
  `id` BIGINT NOT NULL,
  `order_id` VARCHAR(50),
  `product_id` BIGINT,
  `name` VARCHAR(50),
  `description` TEXT,
  `photo` VARCHAR(50),
  `price` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
