INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 279378_script
--echo #
CREATE DATABASE `db_279378_script`;
USE `db_279378_script`;
CREATE TABLE `Customer` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `code` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `unitPrice` DECIMAL(10,2),
  `qtyOnHand` INT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` VARCHAR(50) NOT NULL,
  `date` DATE,
  `customerId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetail` (
  `orderId` VARCHAR(50) NOT NULL,
  `itemCode` VARCHAR(50) NOT NULL,
  `qty` INT,
  `unitPrice` DECIMAL(10,2),
  PRIMARY KEY (`orderId`, `itemCode`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_279378_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_279378_script') AS relationships;
DROP DATABASE `db_279378_script`;
UNINSTALL EXTENSION vsql_schematron;
