INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 489175_harissertif
--echo #
CREATE DATABASE `db_489175_harissertif`;
USE `db_489175_harissertif`;
CREATE TABLE `kategori` (
  `id_kategori` INT NOT NULL,
  `nama_kategori` VARCHAR(50),
  PRIMARY KEY (`id_kategori`)
) CHARACTER SET latin1;
CREATE TABLE `surat` (
  `id_surat` INT,
  `id_kategori` INT,
  `nomor_surat` VARCHAR(50),
  `judul` VARCHAR(50),
  `waktu_pengarsipan` TIMESTAMP NULL,
  `file` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_489175_harissertif') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489175_harissertif') AS relationships;
DROP DATABASE `db_489175_harissertif`;
UNINSTALL EXTENSION vsql_schematron;
