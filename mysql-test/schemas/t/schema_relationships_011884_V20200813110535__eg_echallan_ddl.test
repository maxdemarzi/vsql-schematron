CREATE TABLE `eg_challan_address` (
  `id` VARCHAR(50) NOT NULL,
  `tenantId` CHAR(50),
  `doorNo` CHAR(50),
  `plotNo` CHAR(50),
  `latitude` DOUBLE,
  `longitude` DOUBLE,
