  `country` CHAR(50),
  `locality` CHAR(50),
  `pincode` CHAR(50),
  `detail` CHAR(50),
  `echallanId` CHAR(50),
  `createdBy` CHAR(50),
  `lastModifiedBy` CHAR(50),
  `createdTime` BIGINT,
  `lastModifiedTime` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
