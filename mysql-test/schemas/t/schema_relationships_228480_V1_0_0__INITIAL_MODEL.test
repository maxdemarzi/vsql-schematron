INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228480_V1.0.0__INITIAL_MODEL
--echo #
CREATE DATABASE `db_228480_V1_0_0__INITIAL_MODEL`;
USE `db_228480_V1_0_0__INITIAL_MODEL`;
CREATE TABLE `ROLES` (
  `ROLE` VARCHAR(50) NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`ROLE`)
) CHARACTER SET latin1;
CREATE TABLE `USERS` (
  `USERNAME` VARCHAR(50) NOT NULL,
  `PASSWORD` VARCHAR(50),
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  PRIMARY KEY (`USERNAME`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLES` (
  `USERNAME` VARCHAR(50),
  `ROLE` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228480_V1_0_0__INITIAL_MODEL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228480_V1_0_0__INITIAL_MODEL') AS relationships;
DROP DATABASE `db_228480_V1_0_0__INITIAL_MODEL`;
UNINSTALL EXTENSION vsql_schematron;
