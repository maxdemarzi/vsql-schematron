INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 231196_crud-ci4
--echo #
CREATE DATABASE `db_231196_crud_ci4`;
USE `db_231196_crud_ci4`;
CREATE TABLE `books` (
  `id` VARCHAR(50),
  `status_id` VARCHAR(50),
  `title` VARCHAR(50),
  `author` VARCHAR(50),
  `description` TEXT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `class` TEXT,
  `group` VARCHAR(50),
  `namespace` VARCHAR(50),
  `time` INT,
  `batch` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
  `id` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_231196_crud_ci4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_231196_crud_ci4') AS relationships;
DROP DATABASE `db_231196_crud_ci4`;
UNINSTALL EXTENSION vsql_schematron;
