INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 043634_main
--echo #
CREATE DATABASE `db_043634_main`;
USE `db_043634_main`;
CREATE TABLE `person` (
  `cpf` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `phone` TEXT,
  `birth` TEXT,
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `piece` (
  `id` VARCHAR(50) NOT NULL,
  `value` DOUBLE,
  `date` TEXT,
  `person_cpf` TEXT,
  `title` TEXT,
  `desc` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exposition` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `date` TEXT,
  `time` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `creates` (
  `person_cpf` TEXT,
  `piece_id` TEXT
) CHARACTER SET latin1;
CREATE TABLE `visits` (
  `person_cpf` TEXT,
  `exposition_id` TEXT,
  `enter` TEXT,
  `leave` TEXT
) CHARACTER SET latin1;
CREATE TABLE `displays` (
  `piece_id` TEXT,
  `exposition_id` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_043634_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_043634_main') AS relationships;
DROP DATABASE `db_043634_main`;
UNINSTALL EXTENSION vsql_schematron;
