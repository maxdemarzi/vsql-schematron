INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 398807_usda_eat_2016-02-27
--echo #
CREATE DATABASE `db_398807_usda_eat_2016_02_27`;
USE `db_398807_usda_eat_2016_02_27`;
CREATE TABLE `applications` (
  `id` VARCHAR(50) NOT NULL,
  `income_children_total` DOUBLE,
  `income_children_total_frequency` VARCHAR(50),
  `assistance_program` VARCHAR(50),
  `case_number` VARCHAR(50),
  `address` VARCHAR(50),
  `address2` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  `phone` VARCHAR(50),
  `contact_method` VARCHAR(50),
  `email_address` VARCHAR(50),
  `ssn` INT,
  `no_ssn` VARCHAR(50),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `household_members` (
  `id` VARCHAR(50) NOT NULL,
  `application_id` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `middle_initial` VARCHAR(50),
  `income_work` DOUBLE,
  `income_work_frequency` VARCHAR(50),
  `income_public_assistance` DOUBLE,
  `income_public_assistance_frequency` VARCHAR(50),
  `income_other` DOUBLE,
  `income_other_frequency` VARCHAR(50),
  `income_data` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `household_students` (
  `id` VARCHAR(50) NOT NULL,
  `application_id` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `middle_initial` VARCHAR(50),
  `is_student` VARCHAR(50),
  `is_foster` VARCHAR(50),
  `is_homeless_migrant_runaway` VARCHAR(50),
  `ethnicity` VARCHAR(50),
  `race` TEXT,
  `income_data` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `keys` (
  `id` INT NOT NULL,
  `key` VARCHAR(50),
  `level` INT,
  `ignore_limits` TINYINT,
  `date_created` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schools` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `address2` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `id` VARCHAR(50),
  `ip_address` VARCHAR(50),
  `timestamp` VARCHAR(50),
  `data` BLOB
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_398807_usda_eat_2016_02_27') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_398807_usda_eat_2016_02_27') AS relationships;
DROP DATABASE `db_398807_usda_eat_2016_02_27`;
UNINSTALL EXTENSION vsql_schematron;
