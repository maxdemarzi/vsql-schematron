INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638707_tp_bd
--echo #
CREATE DATABASE `db_638707_tp_bd`;
USE `db_638707_tp_bd`;
CREATE TABLE `tb_user` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `pass` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_post` (
  `id` INT NOT NULL,
  `id_user` INT,
  `date` DATETIME,
  `title` VARCHAR(50),
  `text` TEXT,
  `category` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_comment` (
  `id` INT NOT NULL,
  `id_user` INT,
  `id_post` INT,
  `date` DATETIME,
  `text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638707_tp_bd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638707_tp_bd') AS relationships;
DROP DATABASE `db_638707_tp_bd`;
UNINSTALL EXTENSION vsql_schematron;
