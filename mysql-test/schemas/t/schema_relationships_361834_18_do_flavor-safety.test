INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 361834_18.do.flavor-safety
--echo #
CREATE DATABASE `db_361834_18_do_flavor_safety`;
USE `db_361834_18_do_flavor_safety`;
CREATE TABLE `ingredient_category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `ordinal` INT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredient` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `cas_number` VARCHAR(50),
  `ingredient_category_id` INT,
  `notes` TEXT,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `flavors_ingredients` (
  `flavor_id` BIGINT NOT NULL,
  `ingredient_id` INT NOT NULL,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`flavor_id`, `ingredient_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_361834_18_do_flavor_safety') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_361834_18_do_flavor_safety') AS relationships;
DROP DATABASE `db_361834_18_do_flavor_safety`;
UNINSTALL EXTENSION vsql_schematron;
