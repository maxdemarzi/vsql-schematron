INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072441_geek-text-def
--echo #
CREATE DATABASE `db_072441_geek_text_def`;
USE `db_072441_geek_text_def`;
CREATE TABLE `Author` (
  `authorID` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `bio` VARCHAR(50),
  PRIMARY KEY (`authorID`)
) CHARACTER SET latin1;
CREATE TABLE `Book` (
  `bookID` INT NOT NULL,
  `title` VARCHAR(50),
  `genre` VARCHAR(50),
  `authorID` INT,
  PRIMARY KEY (`bookID`)
) CHARACTER SET latin1;
CREATE TABLE `BookInfo` (
  `bookID` INT,
  `totalSold` INT,
  `rating` INT,
  `price` DECIMAL(10,2),
  `releaseDate` DATE
) CHARACTER SET latin1;
CREATE TABLE `Feedback` (
  `userID` INT,
  `bookID` INT,
  `rating` INT,
  `comment` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Credentials` (
  `userID` INT,
  `pw` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `PaymentInfo` (
  `userID` INT,
  `ccNum` INT NOT NULL,
  `cvc` INT,
  `expDate` DATE,
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` INT,
  `street` VARCHAR(50),
  PRIMARY KEY (`ccNum`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072441_geek_text_def') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072441_geek_text_def') AS relationships;
DROP DATABASE `db_072441_geek_text_def`;
UNINSTALL EXTENSION vsql_schematron;
