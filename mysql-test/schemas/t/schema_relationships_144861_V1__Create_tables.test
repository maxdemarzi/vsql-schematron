INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 144861_V1__Create_tables
--echo #
CREATE DATABASE `db_144861_V1__Create_tables`;
USE `db_144861_V1__Create_tables`;
CREATE TABLE `programmer` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `favorite_number` BIGINT,
  `company_id` BIGINT,
  `birthday` DATE,
  `created_timestamp` TIMESTAMP NULL,
  `updated_timestamp` TIMESTAMP NULL,
  `deleted_timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skill` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `programmer_skill` (
  `programmer_id` BIGINT NOT NULL,
  `skill_id` BIGINT NOT NULL,
  PRIMARY KEY (`programmer_id`, `skill_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_144861_V1__Create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_144861_V1__Create_tables') AS relationships;
DROP DATABASE `db_144861_V1__Create_tables`;
UNINSTALL EXTENSION vsql_schematron;
