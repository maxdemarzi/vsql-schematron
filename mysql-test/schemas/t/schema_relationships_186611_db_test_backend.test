INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186611_db_test_backend
--echo #
CREATE DATABASE `db_186611_db_test_backend`;
USE `db_186611_db_test_backend`;
CREATE TABLE `barang` (
  `ID_BARANG` VARCHAR(50),
  `ID_USER` VARCHAR(50),
  `NAMA_BARANG` VARCHAR(50),
  `KATEGORI_BARANG` VARCHAR(50),
  `FOTO_BARANG` VARCHAR(50),
  `HARGA_BARANG` INT,
  `DISKON_BARANG` INT
) CHARACTER SET latin1;
CREATE TABLE `jabatan` (
  `ID_JABATAN` VARCHAR(50) NOT NULL,
  `NAMA_JABATAN` VARCHAR(50),
  PRIMARY KEY (`ID_JABATAN`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `ID_USER` VARCHAR(50),
  `ID_JABATAN` VARCHAR(50),
  `NAMA_USER` VARCHAR(50),
  `USERNAME` VARCHAR(50),
  `PASSWORD` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186611_db_test_backend') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186611_db_test_backend') AS relationships;
DROP DATABASE `db_186611_db_test_backend`;
UNINSTALL EXTENSION vsql_schematron;
