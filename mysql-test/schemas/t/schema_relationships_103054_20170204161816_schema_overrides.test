INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103054_20170204161816_schema_overrides
--echo #
CREATE DATABASE `db_103054_20170204161816_schema_overrides`;
USE `db_103054_20170204161816_schema_overrides`;
CREATE TABLE `overrides` (
  `override_id` INT NOT NULL,
  `target_date` DATE,
  `target_block` TEXT,
  `name` TEXT,
  `color` TEXT,
  `note` TEXT,
  PRIMARY KEY (`override_id`)
) CHARACTER SET latin1;
CREATE TABLE `override_services` (
  `override_service_id` INT NOT NULL,
  `override_id` INT,
  `name` TEXT,
  `start_time` TIME,
  PRIMARY KEY (`override_service_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103054_20170204161816_schema_overrides') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103054_20170204161816_schema_overrides') AS relationships;
DROP DATABASE `db_103054_20170204161816_schema_overrides`;
UNINSTALL EXTENSION vsql_schematron;
