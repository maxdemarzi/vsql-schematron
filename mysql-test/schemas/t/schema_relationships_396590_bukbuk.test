INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 396590_bukbuk
--echo #
CREATE DATABASE `db_396590_bukbuk`;
USE `db_396590_bukbuk`;
CREATE TABLE `tbl_booking` (
  `id_booking` INT,
  `id_restaurant` INT,
  `time` DATETIME,
  `amount` INT,
  `name` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `email` VARCHAR(50),
  `status` INT
) CHARACTER SET latin1;
CREATE TABLE `tbl_menu` (
  `id_menu` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id_menu`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_product` (
  `id_product` INT,
  `id_menu` INT,
  `name` VARCHAR(50),
  `image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tbl_restaurant` (
  `id_restaurant` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id_restaurant`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_user` (
  `id_user` INT NOT NULL,
  `user_name` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_396590_bukbuk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_396590_bukbuk') AS relationships;
DROP DATABASE `db_396590_bukbuk`;
UNINSTALL EXTENSION vsql_schematron;
