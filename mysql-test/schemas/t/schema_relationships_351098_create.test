INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351098_create
--echo #
CREATE DATABASE `db_351098_create`;
USE `db_351098_create`;
CREATE TABLE `USERS` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CAMPS` (
  `id` VARCHAR(50) NOT NULL,
  `federalState` VARCHAR(50),
  `city` VARCHAR(50),
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `date` DATE,
  `userId` VARCHAR(50),
  `cost` DOUBLE,
  `score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351098_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351098_create') AS relationships;
DROP DATABASE `db_351098_create`;
UNINSTALL EXTENSION vsql_schematron;
