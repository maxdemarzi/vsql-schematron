INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530244_dump
--echo #
CREATE DATABASE `db_530244_dump`;
USE `db_530244_dump`;
CREATE TABLE `Post` (
  `id` VARCHAR(50) NOT NULL,
  `user` CHAR(50),
  `meta` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530244_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530244_dump') AS relationships;
DROP DATABASE `db_530244_dump`;
UNINSTALL EXTENSION vsql_schematron;
