CREATE TABLE `poll_config` (
  `id` BIGINT NOT NULL,
  `poll` TEXT,
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `poll_config_time` (
  `cfg` BIGINT NOT NULL,
  `time` TIME NOT NULL,
  PRIMARY KEY (`cfg`, `time`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
