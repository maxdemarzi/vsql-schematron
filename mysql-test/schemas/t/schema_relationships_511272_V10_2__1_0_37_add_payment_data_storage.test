CREATE DATABASE `db_511272_V10_2__1_0_37_add_payment_data_storage`;
USE `db_511272_V10_2__1_0_37_add_payment_data_storage`;
CREATE TABLE `rpt.payment` (
  `id` BIGINT NOT NULL,
  `external_id` CHAR(50),
  `party_id` CHAR(50),
  `shop_id` CHAR(50),
  `invoice_id` CHAR(50),
  `payment_id` CHAR(50),
  `amount` BIGINT,
  `origin_amount` BIGINT,
  `currency_code` CHAR(50),
  `fee` BIGINT,
  `provider_fee` BIGINT,
  `external_fee` BIGINT,
  `created_at` TIMESTAMP NULL,
  `payer_type` VARCHAR(50),
  `tool` VARCHAR(50),
  `status` VARCHAR(50),
  `status_created_at` TIMESTAMP NULL,
  `phone_number` CHAR(50),
  `email` CHAR(50),
  `flow` VARCHAR(50),
  `context_type` CHAR(50),
  `context` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rpt.payment_additional_info` (
  `ext_payment_id` BIGINT NOT NULL,
  `domain_revision` BIGINT,
  `party_revision` BIGINT,
  `provider_id` INT,
  `terminal_id` INT,
  `bank_card_token` CHAR(50),
  `bank_card_system` CHAR(50),
  `bank_card_bin` CHAR(50),
  `bank_card_masked_pan` CHAR(50),
  `bank_card_token_provider` VARCHAR(50),
  `terminal_provider` CHAR(50),
  `digital_wallet_id` CHAR(50),
  `digital_wallet_provider` CHAR(50),
  `session_id` CHAR(50),
  `fingerprint` CHAR(50),
  `ip` CHAR(50),
  `customer_id` CHAR(50),
  `recurrent_payer_parent_invoice_id` CHAR(50),
  `recurrent_payer_parent_payment_id` CHAR(50),
  `hold_on_expiration` VARCHAR(50),
  `hold_until` TIMESTAMP NULL,
  `make_recurrent_flag` BOOLEAN,
  `operation_failure_class` VARCHAR(50),
  `external_failure` CHAR(50),
  `external_failure_reason` CHAR(50),
  `payment_short_id` CHAR(50),
  `payer_crypto_currency_type` CHAR(50),
  `rrn` CHAR(50),
  `approval_code` CHAR(50),
  `acs_url` CHAR(50),
  `pareq` CHAR(50),
  `md` CHAR(50),
  `term_url` CHAR(50),
  `pares` CHAR(50),
  `eci` CHAR(50),
  `cavv` CHAR(50),
  `xid` CHAR(50),
  `cavv_algorithm` CHAR(50),
  `three_ds_verification` CHAR(50),
  PRIMARY KEY (`ext_payment_id`)
) CHARACTER SET latin1;
