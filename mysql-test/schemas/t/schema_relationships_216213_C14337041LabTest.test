INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 216213_C14337041LabTest
--echo #
CREATE DATABASE `db_216213_C14337041LabTest`;
USE `db_216213_C14337041LabTest`;
CREATE TABLE `competition` (
  `cID` DECIMAL(10,2) NOT NULL,
  `cName` VARCHAR(50),
  `cFee` DECIMAL(10,2),
  `cPrize` DECIMAL(10,2),
  `cDate` DATE,
  PRIMARY KEY (`cID`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
  `tID` DECIMAL(10,2) NOT NULL,
  `tName` VARCHAR(50),
  `tAgeGroup` DECIMAL(10,2),
  `tManager` VARCHAR(50),
  `tEmail` VARCHAR(50),
  PRIMARY KEY (`tID`)
) CHARACTER SET latin1;
CREATE TABLE `competitionEnrollment` (
  `compenrolID` DECIMAL(10,2) NOT NULL,
  `competitionID` DECIMAL(10,2),
  `teamID` DECIMAL(10,2),
  `finalPlacing` DECIMAL(10,2),
  PRIMARY KEY (`compenrolID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_216213_C14337041LabTest') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_216213_C14337041LabTest') AS relationships;
DROP DATABASE `db_216213_C14337041LabTest`;
UNINSTALL EXTENSION vsql_schematron;
