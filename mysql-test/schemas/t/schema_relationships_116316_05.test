INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116316_05
--echo #
CREATE DATABASE `db_116316_05`;
USE `db_116316_05`;
CREATE TABLE `youtube_users` (
  `youtube_user_id` INT NOT NULL,
  `youtube_id` CHAR(50),
  `etag` CHAR(50),
  `title` CHAR(50),
  `description` TEXT,
  `default_thumbnail` TEXT,
  `medium_thumbnail` TEXT,
  `high_thumbnail` TEXT,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`youtube_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `youtube_user_tokens` (
  `youtube_user_token_id` INT NOT NULL,
  `youtube_user_id` INT,
  `token` TEXT,
  `refresh_token` TEXT,
  `expires` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  `expired` TIMESTAMP NULL,
  PRIMARY KEY (`youtube_user_token_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116316_05') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116316_05') AS relationships;
DROP DATABASE `db_116316_05`;
UNINSTALL EXTENSION vsql_schematron;
