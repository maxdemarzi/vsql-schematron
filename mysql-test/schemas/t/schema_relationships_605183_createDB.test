INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605183_createDB
--echo #
CREATE DATABASE `db_605183_createDB`;
USE `db_605183_createDB`;
CREATE TABLE `profile` (
  `id` INT NOT NULL,
  `user_id` VARCHAR(50),
  `abn` VARCHAR(50),
  `name` VARCHAR(50),
  `phone` VARCHAR(50),
  `fax` VARCHAR(50),
  `address` VARCHAR(50),
  `suburb` VARCHAR(50),
  `state` VARCHAR(50),
  `postcode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `category_id` BIGINT,
  `name` VARCHAR(50),
  `price` DECIMAL(10,2),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_options` (
  `id` INT NOT NULL,
  `product_id` BIGINT,
  `name` VARCHAR(50),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `user_id` VARCHAR(50),
  `status` VARCHAR(50),
  `type` VARCHAR(50),
  `notes` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `id` INT NOT NULL,
  `order_id` BIGINT,
  `product_id` BIGINT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605183_createDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605183_createDB') AS relationships;
DROP DATABASE `db_605183_createDB`;
UNINSTALL EXTENSION vsql_schematron;
