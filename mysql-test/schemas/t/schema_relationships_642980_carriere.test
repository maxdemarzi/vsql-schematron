INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 642980_carriere
--echo #
CREATE DATABASE `db_642980_carriere`;
USE `db_642980_carriere`;
CREATE TABLE `carriere` (
  `id_carriere` INT NOT NULL,
  `nom` TEXT,
  `description` TEXT,
  `image` TEXT,
  `basique` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_dotation` (
  `id_carriere_dotation` INT NOT NULL,
  `id_carriere` INT,
  `id_objet` INT,
  `id_qualite` INT,
  `quantite` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_dotation`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_plan` (
  `id_carriere_plan` INT NOT NULL,
  `id_carriere` INT,
  `capacite_combat` INT,
  `capacite_tir` INT,
  `force` INT,
  `endurance` INT,
  `agilite` INT,
  `intelligence` INT,
  `force_mentale` INT,
  `sociabilite` INT,
  `attaque` INT,
  `blessure` INT,
  `mouvement` INT,
  `magie` INT,
  `fortune` INT,
  `destin` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_plan`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_competence` (
  `id_carriere_competence` INT NOT NULL,
  `id_carriere` INT,
  `id_competence` INT,
  `id_competence_specialisation` INT,
  `id_competence_exclue` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_competence`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_talent` (
  `id_carriere_talent` INT NOT NULL,
  `id_carriere` INT,
  `id_talent` INT,
  `id_talent_specialisation` INT,
  `id_talent_exclu` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_talent`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_sortie` (
  `id_carriere_sortie` INT NOT NULL,
  `id_carriere` INT,
  `id_carriere_de_sortie` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_sortie`)
) CHARACTER SET latin1;
CREATE TABLE `carriere_acces` (
  `id_carriere_acces` INT NOT NULL,
  `id_carriere` INT,
  `id_carriere_pour_acces` INT,
  `deleted` INT,
  PRIMARY KEY (`id_carriere_acces`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_642980_carriere') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_642980_carriere') AS relationships;
DROP DATABASE `db_642980_carriere`;
UNINSTALL EXTENSION vsql_schematron;
