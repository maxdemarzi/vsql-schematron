INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 043786_schema_10
--echo #
CREATE DATABASE `db_043786_schema_10`;
USE `db_043786_schema_10`;
CREATE TABLE `acl_role` (
  `id` BIGINT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT,
  `email` CHAR(50),
  `name` CHAR(50),
  `password` CHAR(50),
  `is_active` BOOLEAN,
  `updated` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  `role_id` BIGINT,
  `last_visit` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_043786_schema_10') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_043786_schema_10') AS relationships;
DROP DATABASE `db_043786_schema_10`;
UNINSTALL EXTENSION vsql_schematron;
