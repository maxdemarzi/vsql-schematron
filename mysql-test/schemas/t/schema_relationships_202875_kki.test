INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 202875_kki
--echo #
CREATE DATABASE `db_202875_kki`;
USE `db_202875_kki`;
CREATE TABLE `dosen` (
  `id_dosen` INT,
  `nidn` BIGINT,
  `nama` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `telp` VARCHAR(50),
  `level` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `kelas` (
  `id_kelas` INT,
  `nama` VARCHAR(50),
  `id_prodi` INT,
  `angkatan` INT
) CHARACTER SET latin1;
CREATE TABLE `mahasiswa` (
  `id_mhs` INT,
  `nim` BIGINT,
  `nama` VARCHAR(50),
  `password` VARCHAR(50),
  `id_kelas` INT,
  `email` VARCHAR(50),
  `telp` VARCHAR(50),
  `jenis_kelamin` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `prodi` (
  `id_prodi` INT NOT NULL,
  `nama` VARCHAR(50),
  PRIMARY KEY (`id_prodi`)
) CHARACTER SET latin1;
CREATE TABLE `soal` (
  `id_soal` INT,
  `id_prodi` INT,
  `judul` VARCHAR(50),
  `pg` INT,
  `isian` INT,
  `esai` INT,
  `matkul` VARCHAR(50),
  `ket` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_202875_kki') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_202875_kki') AS relationships;
DROP DATABASE `db_202875_kki`;
UNINSTALL EXTENSION vsql_schematron;
