INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 288332_20210511011428_init
--echo #
CREATE DATABASE `db_288332_20210511011428_init`;
USE `db_288332_20210511011428_init`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `is_admin` BOOLEAN,
  `hashed_password` TEXT,
  `joined` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apis` (
  `id` INT NOT NULL,
  `title` TEXT,
  `endpoints` TEXT,
  `user_id` INT,
  `created` TEXT,
  `updated` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_288332_20210511011428_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_288332_20210511011428_init') AS relationships;
DROP DATABASE `db_288332_20210511011428_init`;
UNINSTALL EXTENSION vsql_schematron;
