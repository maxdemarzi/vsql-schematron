INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 266785_schema
--echo #
CREATE DATABASE `db_266785_schema`;
USE `db_266785_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `admin` VARCHAR(50),
  `uri` TEXT,
  `deleted` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subgraph` (
  `id` INT NOT NULL,
  `name` TEXT,
  `finished` VARCHAR(50),
  `deleted` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `access` (
  `user_id` INT,
  `subgraph_id` INT
) CHARACTER SET latin1;
CREATE TABLE `knowledge` (
  `subgraph_id` INT,
  `subject` TEXT,
  `predicate` TEXT,
  `object` TEXT,
  `property_index` INT,
  `deleted` TEXT
) CHARACTER SET latin1;
CREATE TABLE `ontology` (
  `subject` TEXT,
  `predicate` TEXT,
  `object` TEXT
) CHARACTER SET latin1;
CREATE TABLE `namespace` (
  `prefix` TEXT,
  `uri` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_266785_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_266785_schema') AS relationships;
DROP DATABASE `db_266785_schema`;
UNINSTALL EXTENSION vsql_schematron;
