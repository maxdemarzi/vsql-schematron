INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395062_litostsc_otp_website
--echo #
CREATE DATABASE `db_395062_litostsc_otp_website`;
USE `db_395062_litostsc_otp_website`;
CREATE TABLE `medication` (
  `Id` INT,
  `medication_name` VARCHAR(50),
  `dosage` VARCHAR(50),
  `user_id` INT,
  `once_day` VARCHAR(50),
  `once_month` VARCHAR(50),
  `meal` TINYINT,
  `once_date` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `times` (
  `Id` INT,
  `medication_id` INT,
  `time` TIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `Id` INT NOT NULL,
  `phone_number` VARCHAR(50),
  `password` VARCHAR(50),
  `UTC_val` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `week` (
  `Id` INT,
  `medication_id` INT,
  `week` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395062_litostsc_otp_website') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395062_litostsc_otp_website') AS relationships;
DROP DATABASE `db_395062_litostsc_otp_website`;
UNINSTALL EXTENSION vsql_schematron;
