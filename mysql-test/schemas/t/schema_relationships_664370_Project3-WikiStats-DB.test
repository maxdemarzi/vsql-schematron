INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 664370_Project3-WikiStats-DB
--echo #
CREATE DATABASE `db_664370_Project3_WikiStats_DB`;
USE `db_664370_Project3_WikiStats_DB`;
CREATE TABLE `language` (
  `id` INT NOT NULL,
  `languagecode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `page` (
  `id` INT NOT NULL,
  `page` TEXT,
  `languageid` INT,
  `pagemd5` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pageviews` (
  `id` INT NOT NULL,
  `hourstamp` TIMESTAMP NULL,
  `pageid` INT,
  `pageviews` INT,
  `contentsize` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_664370_Project3_WikiStats_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_664370_Project3_WikiStats_DB') AS relationships;
DROP DATABASE `db_664370_Project3_WikiStats_DB`;
UNINSTALL EXTENSION vsql_schematron;
