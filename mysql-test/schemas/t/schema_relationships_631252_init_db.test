INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 631252_init_db
--echo #
CREATE DATABASE `db_631252_init_db`;
USE `db_631252_init_db`;
CREATE TABLE `Schedules` (
  `scheduleID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `minute_offset` INT,
  `s_day` INT,
  `s_hour` INT,
  `s_minute` INT,
  `state` VARCHAR(50),
  PRIMARY KEY (`scheduleID`)
) CHARACTER SET latin1;
CREATE TABLE `Sensors` (
  `sensorID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `value` INT,
  `readtime` TIMESTAMP NULL,
  PRIMARY KEY (`sensorID`)
) CHARACTER SET latin1;
CREATE TABLE `Channels` (
  `channelID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `scheduleID` MEDIUMINT,
  `sensorID` MEDIUMINT,
  `enabled` VARCHAR(50),
  `state` VARCHAR(50),
  PRIMARY KEY (`channelID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_631252_init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_631252_init_db') AS relationships;
DROP DATABASE `db_631252_init_db`;
UNINSTALL EXTENSION vsql_schematron;
