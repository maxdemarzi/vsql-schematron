INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303592__openPDC
--echo #
CREATE DATABASE `db_303592__openPDC`;
USE `db_303592__openPDC`;
CREATE TABLE `DataAvailability` (
  `ID` INT NOT NULL,
  `GoodAvailableData` DOUBLE,
  `BadAvailableData` DOUBLE,
  `TotalAvailableData` DOUBLE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AlarmState` (
  `ID` INT NOT NULL,
  `State` VARCHAR(50),
  `Color` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AlarmDevice` (
  `ID` INT NOT NULL,
  `DeviceID` INT,
  `StateID` INT,
  `TimeStamp` DATETIME,
  `DisplayData` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303592__openPDC') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303592__openPDC') AS relationships;
DROP DATABASE `db_303592__openPDC`;
UNINSTALL EXTENSION vsql_schematron;
