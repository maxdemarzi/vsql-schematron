INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016383_adshow-sql-structure
--echo #
CREATE DATABASE `db_016383_adshow_sql_structure`;
USE `db_016383_adshow_sql_structure`;
CREATE TABLE `department` (
  `ID` VARCHAR(50) NOT NULL,
  `department` VARCHAR(50),
  `title` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `playlist` (
  `ID` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `active` VARCHAR(50),
  `departmentIDfk` VARCHAR(50),
  `global` VARCHAR(50),
  `screenOrientation` TINYINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `screen` (
  `ID` VARCHAR(50) NOT NULL,
  `location` VARCHAR(50),
  `orientation` TINYINT,
  `departmentIDfk` VARCHAR(50),
  `pcName` VARCHAR(50),
  `playlistIDfk` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `slide` (
  `ID` VARCHAR(50) NOT NULL,
  `active` VARCHAR(50),
  `title` VARCHAR(50),
  `text` TEXT,
  `playtime` VARCHAR(50),
  `templateName` VARCHAR(50),
  `playlistID` VARCHAR(50),
  `imageURL` VARCHAR(50),
  `timestamp` TIMESTAMP NULL,
  `markdownEnabled` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `ID` VARCHAR(50) NOT NULL,
  `sNumber` VARCHAR(50),
  `departmentIDfk` VARCHAR(50),
  `permission` VARCHAR(50),
  `firstname` TEXT,
  `lastname` TEXT,
  `owner` VARCHAR(50),
  `global` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016383_adshow_sql_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016383_adshow_sql_structure') AS relationships;
DROP DATABASE `db_016383_adshow_sql_structure`;
UNINSTALL EXTENSION vsql_schematron;
