INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139868_up
--echo #
CREATE DATABASE `db_139868_up`;
USE `db_139868_up`;
CREATE TABLE `orangeconnex_packages` (
  `tracking_number` VARCHAR(50) NOT NULL,
  `recieved` BOOLEAN,
  PRIMARY KEY (`tracking_number`)
) CHARACTER SET latin1;
CREATE TABLE `orangeconnex_traces` (
  `id` VARCHAR(50) NOT NULL,
  `tracking_number` TEXT,
  `description` TEXT,
  `city` TEXT,
  `country` TEXT,
  `time_recorded` TEXT,
  `time_zone` TEXT,
  `ts` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139868_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139868_up') AS relationships;
DROP DATABASE `db_139868_up`;
UNINSTALL EXTENSION vsql_schematron;
