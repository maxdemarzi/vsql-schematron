INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 619044_V1__Init_db
--echo #
CREATE DATABASE `db_619044_V1__Init_db`;
USE `db_619044_V1__Init_db`;
CREATE TABLE `article` (
  `id` INT NOT NULL,
  `filename` VARCHAR(50),
  `name` VARCHAR(50),
  `text` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hibernate_sequence` (
  `next_val` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` BIGINT,
  `roles` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `usr` (
  `id` BIGINT NOT NULL,
  `activation_code` VARCHAR(50),
  `active` VARCHAR(50),
  `avatar_link` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `telephone` VARCHAR(50),
  `tg_link` VARCHAR(50),
  `username` VARCHAR(50),
  `vk_link` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_619044_V1__Init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_619044_V1__Init_db') AS relationships;
DROP DATABASE `db_619044_V1__Init_db`;
UNINSTALL EXTENSION vsql_schematron;
