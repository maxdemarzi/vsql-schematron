INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586033_setup
--echo #
CREATE DATABASE `db_586033_setup`;
USE `db_586033_setup`;
CREATE TABLE `games` (
  `id` INT NOT NULL,
  `startTime` TIMESTAMP NULL,
  `duration` INT,
  `mode` INT,
  `map` INT,
  `winner` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `results` (
  `id` INT NOT NULL,
  `userid` INT,
  `gameid` INT,
  `kills` INT,
  `assists` INT,
  `deaths` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playerBadges` (
  `id` INT NOT NULL,
  `userid` INT,
  `badgeid` INT,
  `badgeAchieved` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
  `id` INT NOT NULL,
  `userid` INT,
  `friendid` INT,
  `sentTime` TIMESTAMP NULL,
  `accepted` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586033_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586033_setup') AS relationships;
DROP DATABASE `db_586033_setup`;
UNINSTALL EXTENSION vsql_schematron;
