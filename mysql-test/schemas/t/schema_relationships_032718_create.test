INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 032718_create
--echo #
CREATE DATABASE `db_032718_create`;
USE `db_032718_create`;
CREATE TABLE `payload` (
  `id` INT NOT NULL,
  `event` VARCHAR(50),
  `payload_item_name` TEXT,
  `payload_item_url` TEXT,
  `payload_created_at` VARCHAR(50),
  `created_at` DATETIME,
  `downloaded` INT,
  `downloaded_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `downloads` (
  `id` INT NOT NULL,
  `payload_id` INT,
  `file_size` VARCHAR(50),
  `status_code` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `uploads` (
  `id` INT NOT NULL,
  `download_id` INT,
  `drive_id` TEXT,
  `drive_name` TEXT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_032718_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_032718_create') AS relationships;
DROP DATABASE `db_032718_create`;
UNINSTALL EXTENSION vsql_schematron;
