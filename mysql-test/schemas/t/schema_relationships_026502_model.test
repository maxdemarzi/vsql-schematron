INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 026502_model
--echo #
CREATE DATABASE `db_026502_model`;
USE `db_026502_model`;
CREATE TABLE `recetas` (
  `id` INT NOT NULL,
  `descripcion` VARCHAR(50),
  `foto` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pasos_recetas` (
  `id` INT NOT NULL,
  `descripcion` VARCHAR(50),
  `receta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipos` (
  `id` INT NOT NULL,
  `descripcion` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipos_recetas` (
  `id` INT NOT NULL,
  `receta` INT,
  `tipo` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredientes` (
  `id` INT NOT NULL,
  `descripcion` VARCHAR(50),
  `foto` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredientes_recetas` (
  `id` INT NOT NULL,
  `receta` INT,
  `cantidad` VARCHAR(50),
  `ingrediente` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_026502_model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_026502_model') AS relationships;
DROP DATABASE `db_026502_model`;
UNINSTALL EXTENSION vsql_schematron;
