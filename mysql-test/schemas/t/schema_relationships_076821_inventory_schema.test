INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076821_inventory_schema
--echo #
CREATE DATABASE `db_076821_inventory_schema`;
USE `db_076821_inventory_schema`;
CREATE TABLE `inventory.device` (
  `SerialNumber` VARCHAR(50) NOT NULL,
  `SerialDevice` VARCHAR(50),
  `Type` VARCHAR(50),
  `Description` TEXT,
  `Issues` TEXT,
  `PhotoName` VARCHAR(50),
  `Quality` VARCHAR(50),
  PRIMARY KEY (`SerialNumber`)
) CHARACTER SET latin1;
CREATE TABLE `inventory.log` (
  `Identifier` INT NOT NULL,
  `SerialNumber` VARCHAR(50),
  `Purpose` TEXT,
  `UserOut` VARCHAR(50),
  `DateOut` DATE,
  `AuthorizerOut` VARCHAR(50),
  `UserIn` VARCHAR(50),
  `DateIn` DATE,
  `AuthorizerIn` VARCHAR(50),
  PRIMARY KEY (`Identifier`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076821_inventory_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076821_inventory_schema') AS relationships;
DROP DATABASE `db_076821_inventory_schema`;
UNINSTALL EXTENSION vsql_schematron;
