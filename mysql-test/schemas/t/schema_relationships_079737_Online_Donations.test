INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079737_Online_Donations
--echo #
CREATE DATABASE `db_079737_Online_Donations`;
USE `db_079737_Online_Donations`;
CREATE TABLE `online_donations.country` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `online_donations.institution` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `id_country` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `online_donations.user` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `id_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079737_Online_Donations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079737_Online_Donations') AS relationships;
DROP DATABASE `db_079737_Online_Donations`;
UNINSTALL EXTENSION vsql_schematron;
