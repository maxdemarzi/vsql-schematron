INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325806_db
--echo #
CREATE DATABASE `db_325806_db`;
USE `db_325806_db`;
CREATE TABLE `user` (
  `ID` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `ID` INT NOT NULL,
  `parentID` INT,
  `ownerID` INT,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325806_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325806_db') AS relationships;
DROP DATABASE `db_325806_db`;
UNINSTALL EXTENSION vsql_schematron;
