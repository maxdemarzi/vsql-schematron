INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269058_create_tables
--echo #
CREATE DATABASE `db_269058_create_tables`;
USE `db_269058_create_tables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` CHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedules` (
  `id` INT NOT NULL,
  `user_id` INT,
  `day` VARCHAR(50),
  `start_at` TIME,
  `end_at` TIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269058_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269058_create_tables') AS relationships;
DROP DATABASE `db_269058_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
