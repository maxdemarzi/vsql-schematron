INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 394425_0tablas
--echo #
CREATE DATABASE `db_394425_0tablas`;
USE `db_394425_0tablas`;
CREATE TABLE `estado` (
  `idedo` INT NOT NULL,
  `edo` VARCHAR(50),
  PRIMARY KEY (`idedo`)
) CHARACTER SET latin1;
CREATE TABLE `semana` (
  `idia` INT NOT NULL,
  `dia` VARCHAR(50),
  PRIMARY KEY (`idia`)
) CHARACTER SET latin1;
CREATE TABLE `imparte` (
  `idh` INT NOT NULL,
  `idia` INT NOT NULL,
  `idr` INT NOT NULL,
  `ida` INT NOT NULL,
  PRIMARY KEY (`idh`, `idia`, `idr`, `ida`)
) CHARACTER SET latin1;
CREATE TABLE `certificado` (
  `matricula` VARCHAR(50) NOT NULL,
  `numero` VARCHAR(50),
  `libro` VARCHAR(50),
  `foja` VARCHAR(50),
  `fecha` VARCHAR(50),
  `periodo` VARCHAR(50),
  `fechaexp` VARCHAR(50),
  PRIMARY KEY (`matricula`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_394425_0tablas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_394425_0tablas') AS relationships;
DROP DATABASE `db_394425_0tablas`;
UNINSTALL EXTENSION vsql_schematron;
