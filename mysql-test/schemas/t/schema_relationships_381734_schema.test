INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381734_schema
--echo #
CREATE DATABASE `db_381734_schema`;
USE `db_381734_schema`;
CREATE TABLE `character` (
  `id` BIGINT NOT NULL,
  `idDiscord` BIGINT,
  `name` VARCHAR(50),
  `background` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `equipment` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `attack` INT,
  `defense` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `equipmentCharacter` (
  `characterId` BIGINT,
  `equipmentId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381734_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381734_schema') AS relationships;
DROP DATABASE `db_381734_schema`;
UNINSTALL EXTENSION vsql_schematron;
