INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605399_jogo-online
--echo #
CREATE DATABASE `db_605399_jogo_online`;
USE `db_605399_jogo_online`;
CREATE TABLE `tb_classe` (
  `id` INT NOT NULL,
  `nomeclass` VARCHAR(50),
  `armaInicial` VARCHAR(50),
  `armaduraInicial` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_personagem` (
  `id` INT NOT NULL,
  `nomechar` VARCHAR(50),
  `nivel` INT,
  `arma` VARCHAR(50),
  `armadura` VARCHAR(50),
  `forca` INT,
  `agilidade` INT,
  `energia` INT,
  `vida` INT,
  `mana` INT,
  `danoAtaque` INT,
  `danoHabilidade` INT,
  `guild` VARCHAR(50),
  `world` VARCHAR(50),
  `ranking` VARCHAR(50),
  `classeId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605399_jogo_online') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605399_jogo_online') AS relationships;
DROP DATABASE `db_605399_jogo_online`;
UNINSTALL EXTENSION vsql_schematron;
