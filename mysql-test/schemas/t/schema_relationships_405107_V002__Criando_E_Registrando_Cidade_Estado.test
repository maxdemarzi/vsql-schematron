INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405107_V002__Criando_E_Registrando_Cidade_Estado
--echo #
CREATE DATABASE `db_405107_V002__Criando_E_Registrando_Cidade_Estado`;
USE `db_405107_V002__Criando_E_Registrando_Cidade_Estado`;
CREATE TABLE `estado` (
  `codigo` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
CREATE TABLE `cidade` (
  `codigo` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  `codigo_estado` BIGINT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405107_V002__Criando_E_Registrando_Cidade_Estado') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405107_V002__Criando_E_Registrando_Cidade_Estado') AS relationships;
DROP DATABASE `db_405107_V002__Criando_E_Registrando_Cidade_Estado`;
UNINSTALL EXTENSION vsql_schematron;
