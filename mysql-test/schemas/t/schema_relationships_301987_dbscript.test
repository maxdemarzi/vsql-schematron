INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 301987_dbscript
--echo #
CREATE DATABASE `db_301987_dbscript`;
USE `db_301987_dbscript`;
CREATE TABLE `DEPT` (
  `DEPTNO` INT NOT NULL,
  `DNAME` VARCHAR(50),
  `LOCATION` VARCHAR(50),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
  `EMPNO` INT NOT NULL,
  `ENAME` VARCHAR(50),
  `JOB` VARCHAR(50),
  `HIREDATE` DATE,
  `SALARY` DECIMAL(10,2),
  `COMMISSION` DECIMAL(10,2),
  `DEPTNO` INT,
  `Version` INT,
  PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
  `accountName` VARCHAR(50),
  `balance` INT,
  `version` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_301987_dbscript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_301987_dbscript') AS relationships;
DROP DATABASE `db_301987_dbscript`;
UNINSTALL EXTENSION vsql_schematron;
