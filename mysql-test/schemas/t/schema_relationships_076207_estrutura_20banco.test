INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076207_estrutura%20banco
--echo #
CREATE DATABASE `db_076207_estrutura_20banco`;
USE `db_076207_estrutura_20banco`;
CREATE TABLE `TB_UF` (
  `UF` VARCHAR(50) NOT NULL,
  `DESCRICAO` VARCHAR(50),
  PRIMARY KEY (`UF`)
) CHARACTER SET latin1;
CREATE TABLE `TB_PESSOA` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  `ENDERECO` VARCHAR(50),
  `NUMERO` VARCHAR(50),
  `BAIRRO` VARCHAR(50),
  `CIDADE` VARCHAR(50),
  `UF` CHAR(50),
  `CEP` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TB_PESSOA_TELEFONE` (
  `ID_PESSOA` INT NOT NULL,
  `ID_TELEFONE` INT NOT NULL,
  `TELEFONE` VARCHAR(50),
  `CONTATO` VARCHAR(50),
  PRIMARY KEY (`ID_PESSOA`, `ID_TELEFONE`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076207_estrutura_20banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076207_estrutura_20banco') AS relationships;
DROP DATABASE `db_076207_estrutura_20banco`;
UNINSTALL EXTENSION vsql_schematron;
