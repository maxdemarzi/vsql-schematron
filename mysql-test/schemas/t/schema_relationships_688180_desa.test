INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 688180_desa
--echo #
CREATE DATABASE `db_688180_desa`;
USE `db_688180_desa`;
CREATE TABLE `berita` (
  `id_berita` INT NOT NULL,
  `judul` VARCHAR(50),
  `keterangan` TEXT,
  `tanggal` DATE,
  `foto_berita` VARCHAR(50),
  PRIMARY KEY (`id_berita`)
) CHARACTER SET latin1;
CREATE TABLE `galeri` (
  `id_galeri` INT NOT NULL,
  `keterangan` VARCHAR(50),
  `tanggal` DATE,
  `foto` VARCHAR(50),
  PRIMARY KEY (`id_galeri`)
) CHARACTER SET latin1;
CREATE TABLE `pegawai` (
  `id_pegawai` INT,
  `id_penduduk` INT,
  `jabatan` VARCHAR(50),
  `no_hp` VARCHAR(50),
  `foto` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `penduduk` (
  `id_penduduk` INT NOT NULL,
  `NIK` VARCHAR(50),
  `no_KK` VARCHAR(50),
  `nama` VARCHAR(50),
  `tempat_lahir` VARCHAR(50),
  `tanggal_lahir` DATE,
  `agama` VARCHAR(50),
  `status_perkawinan` VARCHAR(50),
  `pekerjaan` VARCHAR(50),
  `gol_darah` VARCHAR(50),
  `jenis_kelamin` VARCHAR(50),
  `alamat` VARCHAR(50),
  `RT` VARCHAR(50),
  `RW` VARCHAR(50),
  `desa` VARCHAR(50),
  `Kecamatan` VARCHAR(50),
  `foto` VARCHAR(50),
  `password` VARCHAR(50),
  `hak_akses` VARCHAR(50),
  PRIMARY KEY (`id_penduduk`)
) CHARACTER SET latin1;
CREATE TABLE `pengaduan` (
  `id_pengaduan` INT,
  `id_penduduk` INT,
  `jenis_pengaduan` VARCHAR(50),
  `tanggal` DATE,
  `alasan` TEXT,
  `keterangan` TEXT,
  `bukti` VARCHAR(50),
  `status` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_688180_desa') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_688180_desa') AS relationships;
DROP DATABASE `db_688180_desa`;
UNINSTALL EXTENSION vsql_schematron;
