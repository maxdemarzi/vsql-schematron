INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395657_eventor
--echo #
CREATE DATABASE `db_395657_eventor`;
USE `db_395657_eventor`;
CREATE TABLE `account` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `dob` VARCHAR(50),
  `phoneNumber` VARCHAR(50),
  `org_name` VARCHAR(50),
  `org_address` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `twitter` VARCHAR(50),
  `facebook` VARCHAR(50),
  `instagram` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `dob` VARCHAR(50),
  `phoneNumber` VARCHAR(50),
  `org_name` VARCHAR(50),
  `org_address` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `id` VARCHAR(50),
  `creator_id` VARCHAR(50),
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `sponsor_name` VARCHAR(50),
  `sponsor_logo` VARCHAR(50),
  `sponsor_url` VARCHAR(50),
  `event_flyer` VARCHAR(50),
  `org_name` VARCHAR(50),
  `org_logo` VARCHAR(50),
  `Address` VARCHAR(50),
  `state` VARCHAR(50),
  `city` VARCHAR(50),
  `status` VARCHAR(50),
  `event_starts` DATE,
  `event_ends` DATE,
  `ticket_price` VARCHAR(50),
  `ticket_qty` VARCHAR(50),
  `sales_start` VARCHAR(50),
  `sales_end` VARCHAR(50),
  `twitter` VARCHAR(50),
  `facebook` VARCHAR(50),
  `instagram` VARCHAR(50),
  `created_at` DATE,
  `updated_at` DATE
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `migration` VARCHAR(50),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `registration` (
  `regId` INT NOT NULL,
  `firstName` VARCHAR(50),
  `middleName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `phone` VARCHAR(50),
  `imageName` VARCHAR(50),
  PRIMARY KEY (`regId`)
) CHARACTER SET latin1;
CREATE TABLE `sandbox` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `dob` VARCHAR(50),
  `phoneNumber` VARCHAR(50),
  `twitter` VARCHAR(50),
  `facebook` VARCHAR(50),
  `instagram` VARCHAR(50),
  `org_name` VARCHAR(50),
  `Address` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395657_eventor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395657_eventor') AS relationships;
DROP DATABASE `db_395657_eventor`;
UNINSTALL EXTENSION vsql_schematron;
