INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147911_create_attendance
--echo #
CREATE DATABASE `db_147911_create_attendance`;
USE `db_147911_create_attendance`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `student_number` VARCHAR(50),
  `admin` BOOLEAN,
  `mentor` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `meetings` (
  `id` INT NOT NULL,
  `user_id` INT,
  `at` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147911_create_attendance') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147911_create_attendance') AS relationships;
DROP DATABASE `db_147911_create_attendance`;
UNINSTALL EXTENSION vsql_schematron;
