INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319129_up
--echo #
CREATE DATABASE `db_319129_up`;
USE `db_319129_up`;
CREATE TABLE `labels` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `color_hex` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `label_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319129_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319129_up') AS relationships;
DROP DATABASE `db_319129_up`;
UNINSTALL EXTENSION vsql_schematron;
