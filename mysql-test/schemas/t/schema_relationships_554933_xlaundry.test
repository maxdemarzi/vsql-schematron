INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 554933_xlaundry
--echo #
CREATE DATABASE `db_554933_xlaundry`;
USE `db_554933_xlaundry`;
CREATE TABLE `pengguna` (
  `id_pengguna` VARCHAR(50) NOT NULL,
  `kata_sandi` VARCHAR(50),
  `tipe_pengguna` INT,
  `status_pengguna` INT,
  `waktu_pembuatan` DATETIME,
  PRIMARY KEY (`id_pengguna`)
) CHARACTER SET latin1;
CREATE TABLE `pesanan` (
  `id_pesanan` VARCHAR(50) NOT NULL,
  `nama_pemesan` VARCHAR(50),
  `alamat_pemesan` TEXT,
  `telepon_pemesan` VARCHAR(50),
  `email_pemesan` VARCHAR(50),
  `estimasi_pesanan` INT,
  `total_harga` DECIMAL(10,2),
  `status_pesanan` INT,
  `tipe_pesanan` INT,
  `id_mesin_cuci` INT,
  `id_paketan` INT,
  `id_pengiriman` INT,
  `id_pengguna` VARCHAR(50),
  `id_promo` INT,
  `waktu_pesanan` DATETIME,
  `waktu_perubahan_terakhir` TIMESTAMP NULL,
  PRIMARY KEY (`id_pesanan`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_554933_xlaundry') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_554933_xlaundry') AS relationships;
DROP DATABASE `db_554933_xlaundry`;
UNINSTALL EXTENSION vsql_schematron;
