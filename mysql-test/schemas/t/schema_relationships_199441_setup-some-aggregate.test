INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 199441_setup-some-aggregate
--echo #
CREATE DATABASE `db_199441_setup_some_aggregate`;
USE `db_199441_setup_some_aggregate`;
CREATE TABLE `someaggregate` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `someclass` (
  `id` INT NOT NULL,
  `someAggregateId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_199441_setup_some_aggregate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_199441_setup_some_aggregate') AS relationships;
DROP DATABASE `db_199441_setup_some_aggregate`;
UNINSTALL EXTENSION vsql_schematron;
