INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 211945_create_spotify_schema
--echo #
CREATE DATABASE `db_211945_create_spotify_schema`;
USE `db_211945_create_spotify_schema`;
CREATE TABLE `track` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `audio_analysis` (
  `track_id` TEXT,
  `analysis` BLOB
) CHARACTER SET latin1;
CREATE TABLE `track_album_join` (
  `track_id` TEXT,
  `album_id` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_211945_create_spotify_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_211945_create_spotify_schema') AS relationships;
DROP DATABASE `db_211945_create_spotify_schema`;
UNINSTALL EXTENSION vsql_schematron;
