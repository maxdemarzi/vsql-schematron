INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278218_4_3_0
--echo #
CREATE DATABASE `db_278218_4_3_0`;
USE `db_278218_4_3_0`;
CREATE TABLE `co_asset` (
  `id` VARCHAR(50) NOT NULL,
  `color_others` VARCHAR(50),
  `color_primary` VARCHAR(50),
  `context` VARCHAR(50),
  `created` DATETIME,
  `eol` DATETIME,
  `file_size` BIGINT,
  `lqip` VARCHAR(50),
  `original_filename` VARCHAR(50),
  `reference_hash` VARCHAR(50),
  `reference_url` VARCHAR(50),
  `resolution_height` INT,
  `resolution_width` INT,
  `system_ref_id` VARCHAR(50),
  `type` VARCHAR(50),
  `url_path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `co_asset_keyvalue` (
  `asset_id` VARCHAR(50) NOT NULL,
  `field_value` VARCHAR(50),
  `field_key` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`asset_id`, `field_key`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278218_4_3_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278218_4_3_0') AS relationships;
DROP DATABASE `db_278218_4_3_0`;
UNINSTALL EXTENSION vsql_schematron;
