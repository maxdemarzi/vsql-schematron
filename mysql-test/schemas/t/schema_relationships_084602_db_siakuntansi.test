INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084602_db_siakuntansi
--echo #
CREATE DATABASE `db_084602_db_siakuntansi`;
USE `db_084602_db_siakuntansi`;
CREATE TABLE `jenisakun` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jurnal` (
  `id_jurnal` VARCHAR(50),
  `id_namaAkun` INT,
  `tanggal` DATE,
  `keterangan` VARCHAR(50),
  `nominal` INT,
  `jenisTransaksi` TINYINT,
  `saldo` INT
) CHARACTER SET latin1;
CREATE TABLE `namaakun` (
  `id` INT,
  `id_jenisAkun` INT,
  `nama` VARCHAR(50),
  `tambahDengan` TINYINT,
  `status` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084602_db_siakuntansi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084602_db_siakuntansi') AS relationships;
DROP DATABASE `db_084602_db_siakuntansi`;
UNINSTALL EXTENSION vsql_schematron;
