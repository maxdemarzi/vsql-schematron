INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160522_db
--echo #
CREATE DATABASE `db_160522_db`;
USE `db_160522_db`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `creationDate` DATETIME,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `creationDate` DATETIME,
  `postId` INT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160522_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160522_db') AS relationships;
DROP DATABASE `db_160522_db`;
UNINSTALL EXTENSION vsql_schematron;
