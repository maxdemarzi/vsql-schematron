INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 214440_tables
--echo #
CREATE DATABASE `db_214440_tables`;
USE `db_214440_tables`;
CREATE TABLE `game_sessions` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `owner_id` INT,
  `selected_time_offset` DOUBLE,
  `selected_time_duration` DOUBLE,
  `selected_time_timezone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `icon` VARCHAR(50),
  `session_id` INT,
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_rules` (
  `id` INT NOT NULL,
  `rule_operator` VARCHAR(50),
  `rule_value` INT,
  `session_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signups` (
  `id` INT NOT NULL,
  `anonymous_name` VARCHAR(50),
  `session_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signup_times` (
  `id` INT NOT NULL,
  `timezone` VARCHAR(50),
  `offset` DOUBLE,
  `duration` DOUBLE,
  `signup_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_signup_roles` (
  `id` INT NOT NULL,
  `weight` INT,
  `signup_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_invites` (
  `id` INT NOT NULL,
  `key` VARCHAR(50),
  `session_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_214440_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_214440_tables') AS relationships;
DROP DATABASE `db_214440_tables`;
UNINSTALL EXTENSION vsql_schematron;
