INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 217018_up
--echo #
CREATE DATABASE `db_217018_up`;
USE `db_217018_up`;
CREATE TABLE `rbac_resources` (
  `id` VARCHAR(50) NOT NULL,
  `realm_id` VARCHAR(50),
  `resource_name` VARCHAR(50),
  `description` TEXT,
  `allowable_actions` TEXT,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_resource_instances` (
  `id` VARCHAR(50) NOT NULL,
  `resource_id` VARCHAR(50),
  `license_policy_id` VARCHAR(50),
  `scope` VARCHAR(50),
  `ref_id` VARCHAR(50),
  `status` VARCHAR(50),
  `description` TEXT,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_resource_quotas` (
  `id` VARCHAR(50) NOT NULL,
  `resource_id` VARCHAR(50),
  `license_policy_id` VARCHAR(50),
  `scope` VARCHAR(50),
  `max_value` INT,
  `effective_at` TIMESTAMP NULL,
  `expired_at` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_217018_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_217018_up') AS relationships;
DROP DATABASE `db_217018_up`;
UNINSTALL EXTENSION vsql_schematron;
