INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 590155_0002_permissions.up
--echo #
CREATE DATABASE `db_590155_0002_permissions_up`;
USE `db_590155_0002_permissions_up`;
CREATE TABLE `permission_kinds` (
  `permission` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`permission`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `id` INT NOT NULL,
  `user_id` VARCHAR(50),
  `permission` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_590155_0002_permissions_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_590155_0002_permissions_up') AS relationships;
DROP DATABASE `db_590155_0002_permissions_up`;
UNINSTALL EXTENSION vsql_schematron;
