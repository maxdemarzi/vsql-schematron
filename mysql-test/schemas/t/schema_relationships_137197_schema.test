INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 137197_schema
--echo #
CREATE DATABASE `db_137197_schema`;
USE `db_137197_schema`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `category` VARCHAR(50),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `given_name` VARCHAR(50),
  `family_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  `register_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `customer_id` INT,
  `payment_date` DATETIME,
  `ship_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `order_id` INT NOT NULL,
  `product_id` INT NOT NULL,
  `quantity` SMALLINT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`order_id`, `product_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_137197_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_137197_schema') AS relationships;
DROP DATABASE `db_137197_schema`;
UNINSTALL EXTENSION vsql_schematron;
