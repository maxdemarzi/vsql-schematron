INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187424_V01__ADRESS
--echo #
CREATE DATABASE `db_187424_V01__ADRESS`;
USE `db_187424_V01__ADRESS`;
CREATE TABLE `country` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `state` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `shortname` VARCHAR(50),
  `id_country` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `idibge` VARCHAR(50),
  `id_state` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `neighborhood` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `id_city` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `street` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `cep` VARCHAR(50),
  `complement` VARCHAR(50),
  `type_adress` VARCHAR(50),
  `id_neighborhood` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187424_V01__ADRESS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187424_V01__ADRESS') AS relationships;
DROP DATABASE `db_187424_V01__ADRESS`;
UNINSTALL EXTENSION vsql_schematron;
