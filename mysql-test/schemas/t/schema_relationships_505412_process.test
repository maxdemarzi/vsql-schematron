INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505412_process
--echo #
CREATE DATABASE `db_505412_process`;
USE `db_505412_process`;
CREATE TABLE `active_task` (
  `id` INT,
  `bpmn_id` VARCHAR(50),
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `status` VARCHAR(50),
  `instance_id` INT
) CHARACTER SET latin1;
CREATE TABLE `process` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `recipe` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `process_instance` (
  `id` INT,
  `satus` VARCHAR(50),
  `process_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505412_process') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505412_process') AS relationships;
DROP DATABASE `db_505412_process`;
UNINSTALL EXTENSION vsql_schematron;
