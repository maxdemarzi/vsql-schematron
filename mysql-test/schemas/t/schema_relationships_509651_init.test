INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 509651_init
--echo #
CREATE DATABASE `db_509651_init`;
USE `db_509651_init`;
CREATE TABLE `guild` (
  `id` VARCHAR(50) NOT NULL,
  `command_prefix` VARCHAR(50),
  `volume` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `slot` (
  `id` VARCHAR(50) NOT NULL,
  `guild_id` VARCHAR(50),
  `slot_number` SMALLINT,
  `value` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_509651_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_509651_init') AS relationships;
DROP DATABASE `db_509651_init`;
UNINSTALL EXTENSION vsql_schematron;
