INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 284716_create-messaging-test-data-tables
--echo #
CREATE DATABASE `db_284716_create_messaging_test_data_tables`;
USE `db_284716_create_messaging_test_data_tables`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `message_id` INT NOT NULL,
  `user_id` INT,
  `room_id` INT,
  `message` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_rooms` (
  `room_id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`room_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_284716_create_messaging_test_data_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_284716_create_messaging_test_data_tables') AS relationships;
DROP DATABASE `db_284716_create_messaging_test_data_tables`;
UNINSTALL EXTENSION vsql_schematron;
