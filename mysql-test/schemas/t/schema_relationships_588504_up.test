INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588504_up
--echo #
CREATE DATABASE `db_588504_up`;
USE `db_588504_up`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `api_keys` (
  `key` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `pastes` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `visibility` SMALLINT,
  `author_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `deletion_keys` (
  `key` VARCHAR(50) NOT NULL,
  `paste_id` VARCHAR(50),
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` VARCHAR(50) NOT NULL,
  `paste_id` VARCHAR(50),
  `name` TEXT,
  `is_binary` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588504_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588504_up') AS relationships;
DROP DATABASE `db_588504_up`;
UNINSTALL EXTENSION vsql_schematron;
