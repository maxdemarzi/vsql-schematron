INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318081_initSchema
--echo #
CREATE DATABASE `db_318081_initSchema`;
USE `db_318081_initSchema`;
CREATE TABLE `product_info` (
  `product_id` INT NOT NULL,
  `name` VARCHAR(50),
  `slogan` VARCHAR(50),
  `description` TEXT,
  `category` VARCHAR(50),
  `default_price` INT,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
  `style_id` INT NOT NULL,
  `product_id` BIGINT,
  `name` VARCHAR(50),
  `sale_price` INT,
  `original_price` INT,
  `if_default` INT,
  PRIMARY KEY (`style_id`)
) CHARACTER SET latin1;
CREATE TABLE `features` (
  `feature_id` INT NOT NULL,
  `product_id` BIGINT,
  `feature` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`feature_id`)
) CHARACTER SET latin1;
CREATE TABLE `skus` (
  `sku_id` INT NOT NULL,
  `style_id` BIGINT,
  `size` VARCHAR(50),
  `quantity` INT,
  PRIMARY KEY (`sku_id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
  `photo_id` INT NOT NULL,
  `style_id` BIGINT,
  `url` TEXT,
  `thumbnail_url` TEXT,
  PRIMARY KEY (`photo_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318081_initSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318081_initSchema') AS relationships;
DROP DATABASE `db_318081_initSchema`;
UNINSTALL EXTENSION vsql_schematron;
