INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 422570_clinica
--echo #
CREATE DATABASE `db_422570_clinica`;
USE `db_422570_clinica`;
CREATE TABLE `consultas` (
  `id` INT NOT NULL,
  `idCita` INT,
  `idConsultorio` INT,
  `idPaciente` INT,
  `folio` VARCHAR(50),
  `fechaRegistro` TIMESTAMP NULL,
  `padeciActual` VARCHAR(50),
  `anteceOculares` VARCHAR(50),
  `antecePatologi` VARCHAR(50),
  `medicamenAlergi` VARCHAR(50),
  `tratamiento` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `expecidionoftalmologica` (
  `id` INT NOT NULL,
  `idConsulta` INT,
  `tipoOjo` TINYINT,
  `agudezaVisual` VARCHAR(50),
  `capacidadVisual` VARCHAR(50),
  `presionIntraocular` VARCHAR(50),
  `humorVitreo` VARCHAR(50),
  `parpadosCejas` VARCHAR(50),
  `conjuntiva` VARCHAR(50),
  `cornea` VARCHAR(50),
  `camaraAnterior` VARCHAR(50),
  `iris` VARCHAR(50),
  `cristalino` VARCHAR(50),
  `esquiascopia` VARCHAR(50),
  `queratometria` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exploracionfondo` (
  `id` INT NOT NULL,
  `idConsulta` INT,
  `reflejoFondo` VARCHAR(50),
  `excavacion` VARCHAR(50),
  `reflejoFondoRojo` VARCHAR(50),
  `papila` VARCHAR(50),
  `retina` VARCHAR(50),
  `areaMecular` VARCHAR(50),
  `exploestuadiciona` VARCHAR(50),
  `impreDiagno` VARCHAR(50),
  `planSegui` VARCHAR(50),
  `tipoOjo` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `graduaciones` (
  `id` INT NOT NULL,
  `idConsulta` INT,
  `esfera` VARCHAR(50),
  `cilindro` VARCHAR(50),
  `eje` VARCHAR(50),
  `adicion` VARCHAR(50),
  `tipoOjo` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notas` (
  `id` INT NOT NULL,
  `idConsulta` INT,
  `tipoOjo` TINYINT,
  `tipoImg` TINYINT,
  `positionTop` INT,
  `positionLeft` INT,
  `nota` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `refraccion` (
  `id` INT NOT NULL,
  `esfera` VARCHAR(50),
  `cilindro` VARCHAR(50),
  `eje` VARCHAR(50),
  `adicion` VARCHAR(50),
  `tipoOjo` TINYINT,
  `idConsulta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `retinoscopia` (
  `id` INT NOT NULL,
  `esfera` VARCHAR(50),
  `cilindro` VARCHAR(50),
  `eje` VARCHAR(50),
  `adicion` VARCHAR(50),
  `tipoOjo` TINYINT,
  `idConsulta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sesiones` (
  `id` INT NOT NULL,
  `jr_recno` CHAR(50),
  `ip` VARCHAR(50),
  `fechaRegistro` TIMESTAMP NULL,
  `idUsuario` INT,
  `userAgent` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_422570_clinica') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_422570_clinica') AS relationships;
DROP DATABASE `db_422570_clinica`;
UNINSTALL EXTENSION vsql_schematron;
