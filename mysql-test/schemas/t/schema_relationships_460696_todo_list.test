INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 460696_todo_list
--echo #
CREATE DATABASE `db_460696_todo_list`;
USE `db_460696_todo_list`;
CREATE TABLE `priorities` (
  `id` INT NOT NULL,
  `priority` VARCHAR(50),
  `color` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `priority_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_460696_todo_list') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_460696_todo_list') AS relationships;
DROP DATABASE `db_460696_todo_list`;
UNINSTALL EXTENSION vsql_schematron;
