INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409149_V1_2__situasjon
--echo #
CREATE DATABASE `db_409149_V1_2__situasjon`;
USE `db_409149_V1_2__situasjon`;
CREATE TABLE `SITUASJON` (
  `AKTORID` VARCHAR(50) NOT NULL,
  `OPPFOLGING` DECIMAL(10,2),
  `MANUELL` DECIMAL(10,2),
  PRIMARY KEY (`AKTORID`)
) CHARACTER SET latin1;
CREATE TABLE `BRUKERVILKAR` (
  `AKTORID` VARCHAR(50),
  `DATO` TIMESTAMP NULL,
  `VILKARSTATUS` VARCHAR(50),
  `TEKST` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409149_V1_2__situasjon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409149_V1_2__situasjon') AS relationships;
DROP DATABASE `db_409149_V1_2__situasjon`;
UNINSTALL EXTENSION vsql_schematron;
