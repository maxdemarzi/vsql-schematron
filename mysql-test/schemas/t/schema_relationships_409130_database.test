INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409130_database
--echo #
CREATE DATABASE `db_409130_database`;
USE `db_409130_database`;
CREATE TABLE `dbfastparking.tblcliente` (
  `idcliente` INT NOT NULL,
  `placacarro` VARCHAR(50),
  `data` DATE,
  `nomecliente` VARCHAR(50),
  `horaentrada` TIME,
  `horasaida` TIME,
  `comprovante` TEXT,
  `tblclientecol` VARCHAR(50),
  `statuscliente` TINYINT,
  `idpreco` INT,
  PRIMARY KEY (`idcliente`)
) CHARACTER SET latin1;
CREATE TABLE `dbfastparking.tblpreco` (
  `idpreco` INT NOT NULL,
  `valor` VARCHAR(50),
  `hora` VARCHAR(50),
  PRIMARY KEY (`idpreco`)
) CHARACTER SET latin1;
CREATE TABLE `dbfastparking.tblvaga` (
  `idvaga` INT NOT NULL,
  `numerovagas` INT,
  `blocos` VARCHAR(50),
  PRIMARY KEY (`idvaga`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409130_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409130_database') AS relationships;
DROP DATABASE `db_409130_database`;
UNINSTALL EXTENSION vsql_schematron;
