INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 405266_pisado
--echo #
CREATE DATABASE `db_405266_pisado`;
USE `db_405266_pisado`;
CREATE TABLE `comentario_group` (
  `id` INT NOT NULL,
  `id_group` BIGINT,
  `nia` BIGINT,
  `nombre` VARCHAR(50),
  `date` TIMESTAMP NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comentario_pisado` (
  `id` INT NOT NULL,
  `id_pisado` BIGINT,
  `nia` BIGINT,
  `nombre` VARCHAR(50),
  `date` TIMESTAMP NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group` (
  `id` INT NOT NULL,
  `subject` VARCHAR(50),
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `archive` (
  `id` INT NOT NULL,
  `id_pisado` BIGINT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pisado` (
  `id` INT NOT NULL,
  `nia` BIGINT,
  `email` VARCHAR(50),
  `autor` VARCHAR(50),
  `date` TIMESTAMP NULL,
  `id_titulacion` BIGINT,
  `asignatura` VARCHAR(50),
  `curso` SMALLINT,
  `grupo` BIGINT,
  `profesor` VARCHAR(50),
  `texto` TEXT,
  `id_group` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_405266_pisado') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_405266_pisado') AS relationships;
DROP DATABASE `db_405266_pisado`;
UNINSTALL EXTENSION vsql_schematron;
