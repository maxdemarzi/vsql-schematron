INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 495327_migration
--echo #
CREATE DATABASE `db_495327_migration`;
USE `db_495327_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Prompt` (
  `id` INT NOT NULL,
  `roundId` INT,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `new_Post` (
  `id` INT NOT NULL,
  `authorId` INT,
  `roundId` INT,
  `promptId` INT,
  `title` TEXT,
  `body` TEXT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_495327_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_495327_migration') AS relationships;
DROP DATABASE `db_495327_migration`;
UNINSTALL EXTENSION vsql_schematron;
