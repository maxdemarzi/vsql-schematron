INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110230_migration
--echo #
CREATE DATABASE `db_110230_migration`;
USE `db_110230_migration`;
CREATE TABLE `Menu` (
  `id` VARCHAR(50) NOT NULL,
  `restaurantId` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `price` DOUBLE,
  `description` TEXT,
  `menuId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110230_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110230_migration') AS relationships;
DROP DATABASE `db_110230_migration`;
UNINSTALL EXTENSION vsql_schematron;
