INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636158_migration
--echo #
CREATE DATABASE `db_636158_migration`;
USE `db_636158_migration`;
CREATE TABLE `BloodPressure` (
  `id` INT NOT NULL,
  `diastolic` INT,
  `systolic` INT,
  `vitalID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WaterIntake` (
  `id` INT NOT NULL,
  `measurement` VARCHAR(50),
  `intake` INT,
  `vitalID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `password` TEXT,
  `email` TEXT,
  `firstName` TEXT,
  `lastName` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Vital` (
  `id` INT NOT NULL,
  `notes` TEXT,
  `pulse` INT,
  `bodyTemperature` TEXT,
  `userId` INT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636158_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636158_migration') AS relationships;
DROP DATABASE `db_636158_migration`;
UNINSTALL EXTENSION vsql_schematron;
