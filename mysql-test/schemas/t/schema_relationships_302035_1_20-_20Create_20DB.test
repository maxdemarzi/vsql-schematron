INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302035_1%20-%20Create%20DB
--echo #
CREATE DATABASE `db_302035_1_20__20Create_20DB`;
USE `db_302035_1_20__20Create_20DB`;
CREATE TABLE `tbl_users` (
  `id_login` INT NOT NULL,
  `user_email` VARCHAR(50),
  `user_pass` VARCHAR(50),
  `user_name` VARCHAR(50),
  `userIsDeleted` BOOLEAN,
  PRIMARY KEY (`id_login`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_professions` (
  `id_profession` INT NOT NULL,
  `profession_name` VARCHAR(50),
  `professionIsDeleted` BOOLEAN,
  PRIMARY KEY (`id_profession`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_specialists` (
  `id_specialist` INT NOT NULL,
  `register` VARCHAR(50),
  `specialist_name` VARCHAR(50),
  `phone` VARCHAR(50),
  `cellphone` VARCHAR(50),
  `email` VARCHAR(50),
  `FK_id_address` INT,
  `FK_id_profession` INT,
  `specialistIsDeleted` BOOLEAN,
  PRIMARY KEY (`id_specialist`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_med_regs` (
  `id_med_reg` INT NOT NULL,
  `med_reg_date` DATE,
  `FK_id_client` INT,
  PRIMARY KEY (`id_med_reg`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_historic_med_regs` (
  `id_historic` INT NOT NULL,
  `date_med_reg` DATE,
  `time_med_reg` TIME,
  `description` TEXT,
  `FK_id_attendances` INT,
  PRIMARY KEY (`id_historic`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302035_1_20__20Create_20DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302035_1_20__20Create_20DB') AS relationships;
DROP DATABASE `db_302035_1_20__20Create_20DB`;
UNINSTALL EXTENSION vsql_schematron;
