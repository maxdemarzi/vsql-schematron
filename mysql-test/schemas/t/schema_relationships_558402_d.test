INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558402_d
--echo #
CREATE DATABASE `db_558402_d`;
USE `db_558402_d`;
CREATE TABLE `word` (
  `id` INT NOT NULL,
  `word` VARCHAR(50),
  `mean` VARCHAR(50),
  `pronounce` VARCHAR(50),
  `regDt` TIMESTAMP NULL,
  `wrong` BOOLEAN,
  `userId` INT,
  `category` VARCHAR(50),
  `testNum` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `userId` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `nickname` VARCHAR(50),
  `regDt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `testResults` (
  `testNum` INT NOT NULL,
  `tetName` VARCHAR(50),
  `collect` INT,
  `wrong` INT,
  `userId` INT,
  PRIMARY KEY (`testNum`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558402_d') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558402_d') AS relationships;
DROP DATABASE `db_558402_d`;
UNINSTALL EXTENSION vsql_schematron;
