INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 240723_migration
--echo #
CREATE DATABASE `db_240723_migration`;
USE `db_240723_migration`;
CREATE TABLE `Novels` (
  `id` INT NOT NULL,
  `slug` TEXT,
  `name` TEXT,
  `lastUpdated` TIMESTAMP NULL,
  `thumbnailUrl` TEXT,
  `defaultSource` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sources` (
  `id` INT NOT NULL,
  `source` TEXT,
  `novelId` INT,
  `chapter` TEXT,
  `chapterUrl` TEXT,
  `chapterNumber` INT,
  `lastUpdated` TIMESTAMP NULL,
  `linkSelector` TEXT,
  `titleSelector` TEXT,
  `numberSelector` TEXT,
  `chapterTitle` TEXT,
  `sourceUrl` TEXT,
  `relative` BOOLEAN,
  `parentUrl` TEXT,
  `roleId` TEXT,
  `channelId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_240723_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_240723_migration') AS relationships;
DROP DATABASE `db_240723_migration`;
UNINSTALL EXTENSION vsql_schematron;
