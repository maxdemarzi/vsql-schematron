INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558936_init_employee
--echo #
CREATE DATABASE `db_558936_init_employee`;
USE `db_558936_init_employee`;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `address_id` INT NOT NULL,
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50),
  `employee_id` INT,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558936_init_employee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558936_init_employee') AS relationships;
DROP DATABASE `db_558936_init_employee`;
UNINSTALL EXTENSION vsql_schematron;
