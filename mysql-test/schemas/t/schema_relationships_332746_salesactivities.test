INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 332746_salesactivities
--echo #
CREATE DATABASE `db_332746_salesactivities`;
USE `db_332746_salesactivities`;
CREATE TABLE `bastphoto` (
  `id` VARCHAR(50) NOT NULL,
  `officialreportdata_id` VARCHAR(50),
  `file` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ci_sessions` (
  `id` VARCHAR(50) NOT NULL,
  `ip_address` VARCHAR(50),
  `timestamp` VARCHAR(50),
  `data` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `negotiationdata` (
  `id` VARCHAR(50) NOT NULL,
  `customer_id` VARCHAR(50),
  `bid_price` DECIMAL(10,2),
  `product_offered` TEXT,
  `asking_price` DECIMAL(10,2),
  `agreed_price` DECIMAL(10,2),
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `note` (
  `id` VARCHAR(50) NOT NULL,
  `user_sales` VARCHAR(50),
  `user_supervisor` VARCHAR(50),
  `message` TEXT,
  `created_by` INT,
  `created_date` TIMESTAMP NULL,
  `read` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `officialreportdata` (
  `id` VARCHAR(50) NOT NULL,
  `customer_id` VARCHAR(50),
  `date` DATE,
  `pks` VARCHAR(50),
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `registrationdata` (
  `id` VARCHAR(50) NOT NULL,
  `customer_id` VARCHAR(50),
  `company_name` VARCHAR(50),
  `address` TEXT,
  `latitude` VARCHAR(50),
  `longitude` VARCHAR(50),
  `npwp` VARCHAR(50),
  `pic_signing` VARCHAR(50),
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `replyactivity` (
  `id` VARCHAR(50) NOT NULL,
  `activity_id` VARCHAR(50),
  `message` TEXT,
  `created_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_332746_salesactivities') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_332746_salesactivities') AS relationships;
DROP DATABASE `db_332746_salesactivities`;
UNINSTALL EXTENSION vsql_schematron;
