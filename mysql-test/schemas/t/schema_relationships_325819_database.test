INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325819_database
--echo #
CREATE DATABASE `db_325819_database`;
USE `db_325819_database`;
CREATE TABLE `contracts` (
  `id` INT NOT NULL,
  `description` TEXT,
  `amount` DOUBLE,
  `start_date` DATE,
  `end_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cashflows` (
  `id` INT NOT NULL,
  `reference_date` DATE,
  `amount` DOUBLE,
  `contract_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
  `id` INT NOT NULL,
  `contract_id` INT,
  `reference_date` DATE,
  `state` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325819_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325819_database') AS relationships;
DROP DATABASE `db_325819_database`;
UNINSTALL EXTENSION vsql_schematron;
