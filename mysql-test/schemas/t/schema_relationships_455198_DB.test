INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455198_DB
--echo #
CREATE DATABASE `db_455198_DB`;
USE `db_455198_DB`;
CREATE TABLE `Shops` (
  `shop_id` INT NOT NULL,
  `adress` VARCHAR(50),
  `shop_name` VARCHAR(50),
  PRIMARY KEY (`shop_id`)
) CHARACTER SET latin1;
CREATE TABLE `Med_groups` (
  `group_id` INT NOT NULL,
  `group_name` VARCHAR(50),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `Medicine` (
  `med_id` INT NOT NULL,
  `group_id` INT,
  `med_name` VARCHAR(50),
  PRIMARY KEY (`med_id`)
) CHARACTER SET latin1;
CREATE TABLE `Availability` (
  `id` INT NOT NULL,
  `shop_id` INT,
  `med_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
  `emp_id` INT NOT NULL,
  `shop_id` INT,
  `emp_name` VARCHAR(50),
  `position` VARCHAR(50),
  PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
CREATE TABLE `Sales` (
  `sale_id` INT NOT NULL,
  `shop_id` INT,
  `med_id` INT,
  `price` DOUBLE,
  `sale_date` VARCHAR(50),
  PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455198_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455198_DB') AS relationships;
DROP DATABASE `db_455198_DB`;
UNINSTALL EXTENSION vsql_schematron;
