INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161660_projectoclinica
--echo #
CREATE DATABASE `db_161660_projectoclinica`;
USE `db_161660_projectoclinica`;
CREATE TABLE `medicos` (
  `idmedico` VARCHAR(50) NOT NULL,
  `nome_medico` VARCHAR(50),
  `espec_medico` VARCHAR(50),
  `crm_medico` INT,
  `bi_medico` VARCHAR(50),
  PRIMARY KEY (`idmedico`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `nome_usuario` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `perfil` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `bairro` (
  `cod_bairro` INT NOT NULL,
  `nome_bairro` VARCHAR(50),
  PRIMARY KEY (`cod_bairro`)
) CHARACTER SET latin1;
CREATE TABLE `paciente` (
  `id_paciente` INT NOT NULL,
  `nome_paciente` VARCHAR(50),
  `nasc_paciente` VARCHAR(50),
  `bi_paciente` VARCHAR(50),
  `cell_paciente` VARCHAR(50),
  `rua_paciente` VARCHAR(50),
  `quar_paciente` VARCHAR(50),
  `casa_paciente` VARCHAR(50),
  `pac_bairro` INT,
  PRIMARY KEY (`id_paciente`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161660_projectoclinica') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161660_projectoclinica') AS relationships;
DROP DATABASE `db_161660_projectoclinica`;
UNINSTALL EXTENSION vsql_schematron;
