INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 292836_migration
--echo #
CREATE DATABASE `db_292836_migration`;
USE `db_292836_migration`;
CREATE TABLE `Budget` (
  `id` VARCHAR(50) NOT NULL,
  `month` TEXT,
  `year` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BudgetItem` (
  `id` VARCHAR(50) NOT NULL,
  `amount` INT,
  `budget` INT,
  `isExpense` BOOLEAN,
  `isIncome` BOOLEAN,
  `isTransfer` BOOLEAN,
  `categoryId` TEXT,
  `budgetId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_292836_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_292836_migration') AS relationships;
DROP DATABASE `db_292836_migration`;
UNINSTALL EXTENSION vsql_schematron;
