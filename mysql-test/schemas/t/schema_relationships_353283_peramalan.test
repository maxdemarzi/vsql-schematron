INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 353283_peramalan
--echo #
CREATE DATABASE `db_353283_peramalan`;
USE `db_353283_peramalan`;
CREATE TABLE `alpha` (
  `id_alpha` INT NOT NULL,
  `alpha` TEXT,
  PRIMARY KEY (`id_alpha`)
) CHARACTER SET latin1;
CREATE TABLE `barang_masuk` (
  `id_masuk` INT,
  `tanggal` DATE,
  `id_produk` INT,
  `jumlah` INT
) CHARACTER SET latin1;
CREATE TABLE `jenis_produk` (
  `id_jenis` INT NOT NULL,
  `nama_jenis` TEXT,
  PRIMARY KEY (`id_jenis`)
) CHARACTER SET latin1;
CREATE TABLE `produk` (
  `id_produk` INT,
  `nama_produk` VARCHAR(50),
  `jenis_produk` INT,
  `harga` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `email` TEXT,
  `nohp` TEXT,
  `nama` TEXT,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_353283_peramalan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_353283_peramalan') AS relationships;
DROP DATABASE `db_353283_peramalan`;
UNINSTALL EXTENSION vsql_schematron;
