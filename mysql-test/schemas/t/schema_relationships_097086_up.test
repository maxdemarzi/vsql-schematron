INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097086_up
--echo #
CREATE DATABASE `db_097086_up`;
USE `db_097086_up`;
CREATE TABLE `public.ref_situation` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `theme` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.ref_target` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `situation_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.ref_action` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `target_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097086_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097086_up') AS relationships;
DROP DATABASE `db_097086_up`;
UNINSTALL EXTENSION vsql_schematron;
