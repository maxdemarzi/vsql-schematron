INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434797_create
--echo #
CREATE DATABASE `db_434797_create`;
USE `db_434797_create`;
CREATE TABLE `products` (
  `productId` INT NOT NULL,
  `name` VARCHAR(50),
  `price` DOUBLE,
  `productImage` VARCHAR(50),
  PRIMARY KEY (`productId`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `orderId` INT NOT NULL,
  `productId` INT,
  `quantity` INT,
  PRIMARY KEY (`orderId`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `userId` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `productImages` (
  `imageId` INT NOT NULL,
  `productId` INT,
  `path` VARCHAR(50),
  PRIMARY KEY (`imageId`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `categoryId` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`categoryId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434797_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434797_create') AS relationships;
DROP DATABASE `db_434797_create`;
UNINSTALL EXTENSION vsql_schematron;
