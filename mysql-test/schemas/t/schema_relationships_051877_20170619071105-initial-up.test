INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051877_20170619071105-initial-up
--echo #
CREATE DATABASE `db_051877_20170619071105_initial_up`;
USE `db_051877_20170619071105_initial_up`;
CREATE TABLE `Item` (
  `id` INT NOT NULL,
  `title` TEXT,
  `quantity` DOUBLE,
  `unit` TEXT,
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Transaction` (
  `id` INT NOT NULL,
  `itemId` INT,
  `orderId` INT,
  `price` INT,
  `quantity` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051877_20170619071105_initial_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051877_20170619071105_initial_up') AS relationships;
DROP DATABASE `db_051877_20170619071105_initial_up`;
UNINSTALL EXTENSION vsql_schematron;
