INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 504715_V1__initial
--echo #
CREATE DATABASE `db_504715_V1__initial`;
USE `db_504715_V1__initial`;
CREATE TABLE `validators` (
  `id` INT NOT NULL,
  `public_key` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signed_blocks` (
  `validator_id` INT,
  `slot` DECIMAL(10,2),
  `signing_root` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `signed_attestations` (
  `validator_id` INT,
  `source_epoch` DECIMAL(10,2),
  `target_epoch` DECIMAL(10,2),
  `signing_root` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_504715_V1__initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_504715_V1__initial') AS relationships;
DROP DATABASE `db_504715_V1__initial`;
UNINSTALL EXTENSION vsql_schematron;
