INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048950_1
--echo #
CREATE DATABASE `db_048950_1`;
USE `db_048950_1`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `discord_user_id` VARCHAR(50),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallet_addresses` (
  `id` VARCHAR(50) NOT NULL,
  `current_user_id` VARCHAR(50),
  `address` VARCHAR(50),
  `locked_until` DATETIME,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `id` VARCHAR(50) NOT NULL,
  `from_user_id` VARCHAR(50),
  `to_user_id` VARCHAR(50),
  `status` VARCHAR(50),
  `transaction_type` VARCHAR(50),
  `amount` BIGINT,
  `transaction_id` VARCHAR(50),
  `vout` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048950_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048950_1') AS relationships;
DROP DATABASE `db_048950_1`;
UNINSTALL EXTENSION vsql_schematron;
