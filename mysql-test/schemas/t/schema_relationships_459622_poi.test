INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 459622_poi
--echo #
CREATE DATABASE `db_459622_poi`;
USE `db_459622_poi`;
CREATE TABLE `collections` (
  `id` INT NOT NULL,
  `collection` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `poi` (
  `id` INT NOT NULL,
  `id_collection` INT,
  `province` VARCHAR(50),
  `council` VARCHAR(50),
  `name` VARCHAR(50),
  `web` VARCHAR(50),
  `coordenadas` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `data` (
  `id` INT NOT NULL,
  `id_poi` INT,
  `key` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_459622_poi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_459622_poi') AS relationships;
DROP DATABASE `db_459622_poi`;
UNINSTALL EXTENSION vsql_schematron;
