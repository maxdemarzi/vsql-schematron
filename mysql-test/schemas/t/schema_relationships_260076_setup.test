INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 260076_setup
--echo #
CREATE DATABASE `db_260076_setup`;
USE `db_260076_setup`;
CREATE TABLE `Cryptocurrency` (
  `cryptocurrencyID` INT NOT NULL,
  `base` TEXT,
  `target` TEXT,
  `price` DOUBLE,
  `volume` DOUBLE,
  `change` DOUBLE,
  `time_stamp` BIGINT,
  `success` BOOLEAN,
  `error` TEXT,
  PRIMARY KEY (`cryptocurrencyID`)
) CHARACTER SET latin1;
CREATE TABLE `Market` (
  `marketID` INT NOT NULL,
  `cryptocurrencyID` INT,
  `indx` INT,
  `market` TEXT,
  `marketPrice` DOUBLE,
  `marketVolume` DOUBLE,
  PRIMARY KEY (`marketID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_260076_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_260076_setup') AS relationships;
DROP DATABASE `db_260076_setup`;
UNINSTALL EXTENSION vsql_schematron;
