INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 218244_db_pdv
--echo #
CREATE DATABASE `db_218244_db_pdv`;
USE `db_218244_db_pdv`;
CREATE TABLE `modules` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movements` (
  `id` INT NOT NULL,
  `id_product` INT,
  `id_user` INT,
  `type` VARCHAR(50),
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission` (
  `id` INT NOT NULL,
  `id_modules` INT,
  `id_user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_218244_db_pdv') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_218244_db_pdv') AS relationships;
DROP DATABASE `db_218244_db_pdv`;
UNINSTALL EXTENSION vsql_schematron;
