INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258385_create-db-invoicing
--echo #
CREATE DATABASE `db_258385_create_db_invoicing`;
USE `db_258385_create_db_invoicing`;
CREATE TABLE `payment_methods` (
  `payment_method_id` TINYINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`payment_method_id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
  `client_id` INT NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `state` CHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `invoices` (
  `invoice_id` INT NOT NULL,
  `number` VARCHAR(50),
  `client_id` INT,
  `invoice_total` DECIMAL(10,2),
  `payment_total` DECIMAL(10,2),
  `invoice_date` DATE,
  `due_date` DATE,
  `payment_date` DATE,
  PRIMARY KEY (`invoice_id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
  `payment_id` INT NOT NULL,
  `client_id` INT,
  `invoice_id` INT,
  `date` DATE,
  `amount` DECIMAL(10,2),
  `payment_method` TINYINT,
  PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258385_create_db_invoicing') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258385_create_db_invoicing') AS relationships;
DROP DATABASE `db_258385_create_db_invoicing`;
UNINSTALL EXTENSION vsql_schematron;
