INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347551_APAGA
--echo #
CREATE DATABASE `db_347551_APAGA`;
USE `db_347551_APAGA`;
CREATE TABLE `dim_produto` (
  `sk_produto` DECIMAL(10,2) NOT NULL,
  `cd_produto` DECIMAL(10,2),
  `nm_produto` VARCHAR(50),
  `nm_embalagem` VARCHAR(50),
  PRIMARY KEY (`sk_produto`)
) CHARACTER SET latin1;
CREATE TABLE `dim_promocao` (
  `sk_promocao` DECIMAL(10,2) NOT NULL,
  `cd_promocao` DECIMAL(10,2),
  `nm_promocao` VARCHAR(50),
  `dt_inicio` DATE,
  `dt_fim` DATE,
  PRIMARY KEY (`sk_promocao`)
) CHARACTER SET latin1;
CREATE TABLE `dim_promocaov1` (
  `sk_loja` DECIMAL(10,2) NOT NULL,
  `cd_loja` DECIMAL(10,2),
  `nm_loja` VARCHAR(50),
  `nm_estado` VARCHAR(50),
  `nm_cidade` VARCHAR(50),
  `nm_bairro` VARCHAR(50),
  PRIMARY KEY (`sk_loja`)
) CHARACTER SET latin1;
CREATE TABLE `dim_tempo` (
  `sk_tempo` DECIMAL(10,2) NOT NULL,
  `dt_evento` DATE,
  `nr_dia` DECIMAL(10,2),
  `nm_dia_semana` VARCHAR(50),
  `nr_mes` DECIMAL(10,2),
  `nr_ano` DECIMAL(10,2),
  PRIMARY KEY (`sk_tempo`)
) CHARACTER SET latin1;
CREATE TABLE `dim_vendedor` (
  `sk_vendedor` DECIMAL(10,2) NOT NULL,
  `cd_vendor` DECIMAL(10,2),
  `nr_cpf` DECIMAL(10,2),
  PRIMARY KEY (`sk_vendedor`)
) CHARACTER SET latin1;
CREATE TABLE `venda` (
  `sk_venda` DECIMAL(10,2) NOT NULL,
  `sk_produto` DECIMAL(10,2),
  `sk_tempo` DECIMAL(10,2),
  `sk_vendedor` DECIMAL(10,2),
  `qt_venda` DECIMAL(10,2),
  `vl_total_vendas` DECIMAL(10,2),
  `vl_unitario_venda` DECIMAL(10,2),
  `sk_promocao` DECIMAL(10,2),
  `qt_devolucao` DECIMAL(10,2),
  `vl_lucro_liquido` DECIMAL(10,2),
  PRIMARY KEY (`sk_venda`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347551_APAGA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347551_APAGA') AS relationships;
DROP DATABASE `db_347551_APAGA`;
UNINSTALL EXTENSION vsql_schematron;
