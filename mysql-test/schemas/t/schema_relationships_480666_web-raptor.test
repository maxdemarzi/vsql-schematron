INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480666_web-raptor
--echo #
CREATE DATABASE `db_480666_web_raptor`;
USE `db_480666_web_raptor`;
CREATE TABLE `function` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `instructions` VARCHAR(50),
  `variables` TEXT,
  `created` TIMESTAMP NULL,
  `modified` TIMESTAMP NULL,
  `active` TINYINT,
  `project_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `accessed` TIMESTAMP NULL,
  `active` TINYINT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480666_web_raptor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480666_web_raptor') AS relationships;
DROP DATABASE `db_480666_web_raptor`;
UNINSTALL EXTENSION vsql_schematron;
