INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 099757_up
--echo #
CREATE DATABASE `db_099757_up`;
USE `db_099757_up`;
CREATE TABLE `email` (
  `id` INT NOT NULL,
  `mailbox_id` INT,
  `fromaddr` VARCHAR(50),
  `message` TEXT,
  `timestamp` TIMESTAMP NULL,
  `sent_via_ssl` BOOLEAN,
  `read` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mailbox` (
  `id` INT NOT NULL,
  `address` VARCHAR(50),
  `last_activity` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_099757_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_099757_up') AS relationships;
DROP DATABASE `db_099757_up`;
UNINSTALL EXTENSION vsql_schematron;
