INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048326_bank_accenture
--echo #
CREATE DATABASE `db_048326_bank_accenture`;
USE `db_048326_bank_accenture`;
CREATE TABLE `agency` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `current_account` (
  `id` INT NOT NULL,
  `number` VARCHAR(50),
  `balance` DECIMAL(10,2),
  `fk_idAgency` INT,
  `fk_idClient` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `extract` (
  `idExtract` INT NOT NULL,
  `moveDate` DATETIME,
  `operation` VARCHAR(50),
  `value` DECIMAL(10,2),
  `fk_idCurrentAccount` INT,
  PRIMARY KEY (`idExtract`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048326_bank_accenture') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048326_bank_accenture') AS relationships;
DROP DATABASE `db_048326_bank_accenture`;
UNINSTALL EXTENSION vsql_schematron;
