INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 375111_data
--echo #
CREATE DATABASE `db_375111_data`;
USE `db_375111_data`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `user_id` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `career` VARCHAR(50),
  `manager` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
  `id` INT NOT NULL,
  `project_id` VARCHAR(50),
  `project_name` VARCHAR(50),
  `project_description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `timesheets` (
  `id` INT NOT NULL,
  `project_id` INT,
  `user_id` INT,
  `date_from` DATE,
  `date_to` DATE,
  `duration_min` INT,
  `comments` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_375111_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_375111_data') AS relationships;
DROP DATABASE `db_375111_data`;
UNINSTALL EXTENSION vsql_schematron;
