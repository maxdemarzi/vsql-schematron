INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535398_gregory_schema
--echo #
CREATE DATABASE `db_535398_gregory_schema`;
USE `db_535398_gregory_schema`;
CREATE TABLE `categories` (
  `category_id` INT NOT NULL,
  `category_name` TEXT,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `rel_articles_categories` (
  `article_id` INT,
  `category_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535398_gregory_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535398_gregory_schema') AS relationships;
DROP DATABASE `db_535398_gregory_schema`;
UNINSTALL EXTENSION vsql_schematron;
