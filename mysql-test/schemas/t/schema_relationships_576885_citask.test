INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576885_citask
--echo #
CREATE DATABASE `db_576885_citask`;
USE `db_576885_citask`;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `dept` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sub_department` (
  `id` INT,
  `id_dept` INT,
  `sub_dept` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `email` VARCHAR(50),
  `pwd` VARCHAR(50),
  `profile` TEXT,
  `dept` VARCHAR(50),
  `subdept` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576885_citask') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576885_citask') AS relationships;
DROP DATABASE `db_576885_citask`;
UNINSTALL EXTENSION vsql_schematron;
