INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 361250_db_jrentregas
--echo #
CREATE DATABASE `db_361250_db_jrentregas`;
USE `db_361250_db_jrentregas`;
CREATE TABLE `Products` (
  `id` INT,
  `name` VARCHAR(50),
  `trackingId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `SequelizeMeta` (
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Trackings` (
  `id` INT,
  `code` VARCHAR(50),
  `local` VARCHAR(50),
  `userId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_361250_db_jrentregas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_361250_db_jrentregas') AS relationships;
DROP DATABASE `db_361250_db_jrentregas`;
UNINSTALL EXTENSION vsql_schematron;
