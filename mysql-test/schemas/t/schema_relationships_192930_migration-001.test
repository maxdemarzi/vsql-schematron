INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 192930_migration-001
--echo #
CREATE DATABASE `db_192930_migration_001`;
USE `db_192930_migration_001`;
CREATE TABLE `auth_tokens` (
  `id` INT NOT NULL,
  `hash` CHAR(50),
  `email` CHAR(50),
  `date_created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` CHAR(50),
  `date_created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `id` CHAR(50),
  `user_id` INT,
  `date_created` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_192930_migration_001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_192930_migration_001') AS relationships;
DROP DATABASE `db_192930_migration_001`;
UNINSTALL EXTENSION vsql_schematron;
