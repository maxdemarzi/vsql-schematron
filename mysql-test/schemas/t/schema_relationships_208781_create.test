INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 208781_create
--echo #
CREATE DATABASE `db_208781_create`;
USE `db_208781_create`;
CREATE TABLE `directors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `birthyear` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genres` (
  `id` INT NOT NULL,
  `director_id` INT,
  `name` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ratings` (
  `id` INT NOT NULL,
  `movie_id` INT,
  `number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publishyear` (
  `id` INT NOT NULL,
  `movie_id` INT,
  `releasedate` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_208781_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_208781_create') AS relationships;
DROP DATABASE `db_208781_create`;
UNINSTALL EXTENSION vsql_schematron;
