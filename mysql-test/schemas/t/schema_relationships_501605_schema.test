INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501605_schema
--echo #
CREATE DATABASE `db_501605_schema`;
USE `db_501605_schema`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_to_groups` (
  `user_id` VARCHAR(50),
  `group_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501605_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501605_schema') AS relationships;
DROP DATABASE `db_501605_schema`;
UNINSTALL EXTENSION vsql_schematron;
