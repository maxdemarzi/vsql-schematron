INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 111413_0_ordersdb-schema
--echo #
CREATE DATABASE `db_111413_0_ordersdb_schema`;
USE `db_111413_0_ordersdb_schema`;
CREATE TABLE `booking` (
  `id` BIGINT NOT NULL,
  `cancellation_code` VARCHAR(50),
  `contact_email` VARCHAR(50),
  `created_on` DATETIME,
  `performance_id` BIGINT,
  `performance_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ticket` (
  `id` BIGINT NOT NULL,
  `price` DOUBLE,
  `number` INT,
  `row_number` INT,
  `section_id` BIGINT,
  `ticket_category_id` BIGINT,
  `booking_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `id_generator` (
  `IDKEY` CHAR(50),
  `IDVALUE` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_111413_0_ordersdb_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_111413_0_ordersdb_schema') AS relationships;
DROP DATABASE `db_111413_0_ordersdb_schema`;
UNINSTALL EXTENSION vsql_schematron;
