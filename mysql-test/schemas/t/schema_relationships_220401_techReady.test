INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220401_techReady
--echo #
CREATE DATABASE `db_220401_techReady`;
USE `db_220401_techReady`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` CHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `is_tutor` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` VARCHAR(50) NOT NULL,
  `question_title` VARCHAR(50),
  `question_text` TEXT,
  `user_id` VARCHAR(50),
  `question_tag` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` VARCHAR(50) NOT NULL,
  `comment_text` TEXT,
  `question_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quiz_results` (
  `id` VARCHAR(50) NOT NULL,
  `times_taken` VARCHAR(50),
  `last_score` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reputations` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `html_reputation` BOOLEAN,
  `css_reputation` BOOLEAN,
  `js_reputation` BOOLEAN,
  `sql_reputation` BOOLEAN,
  `node_reputation` BOOLEAN,
  `react_reputation` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tutors` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `is_frontend` BOOLEAN,
  `is_backend` BOOLEAN,
  `css` BOOLEAN,
  `html` BOOLEAN,
  `js` BOOLEAN,
  `sql_` BOOLEAN,
  `node` BOOLEAN,
  `react` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220401_techReady') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220401_techReady') AS relationships;
DROP DATABASE `db_220401_techReady`;
UNINSTALL EXTENSION vsql_schematron;
