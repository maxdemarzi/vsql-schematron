INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105083_estrangeira
--echo #
CREATE DATABASE `db_105083_estrangeira`;
USE `db_105083_estrangeira`;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `id` INT NOT NULL,
  `fkcliente` INT,
  `produto` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105083_estrangeira') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105083_estrangeira') AS relationships;
DROP DATABASE `db_105083_estrangeira`;
UNINSTALL EXTENSION vsql_schematron;
