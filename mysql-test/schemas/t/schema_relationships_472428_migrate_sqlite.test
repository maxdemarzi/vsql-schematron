INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472428_migrate.sqlite
--echo #
CREATE DATABASE `db_472428_migrate_sqlite`;
USE `db_472428_migrate_sqlite`;
CREATE TABLE `language` (
  `iso_code` VARCHAR(50),
  `name` VARCHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lexeme` (
  `lemma` VARCHAR(50),
  `gloss` VARCHAR(50),
  `subscript` INT,
  `language_id` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `word` (
  `form` VARCHAR(50),
  `parsing` VARCHAR(50),
  `gloss` VARCHAR(50),
  `lexeme_id` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `document` (
  `title` VARCHAR(50),
  `author` VARCHAR(50),
  `language_id` INT,
  `file_url` VARCHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `token` (
  `identifier` VARCHAR(50),
  `gloss` VARCHAR(50),
  `document_id` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `token_words` (
  `token_id` INT,
  `word_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472428_migrate_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472428_migrate_sqlite') AS relationships;
DROP DATABASE `db_472428_migrate_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
