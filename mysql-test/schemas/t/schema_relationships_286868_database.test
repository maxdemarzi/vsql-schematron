INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 286868_database
--echo #
CREATE DATABASE `db_286868_database`;
USE `db_286868_database`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password_hash` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_sessions` (
  `id` INT NOT NULL,
  `user_id` INT,
  `device_uuid` INT,
  `is_logged_in` INT,
  `last_updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genre` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_286868_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_286868_database') AS relationships;
DROP DATABASE `db_286868_database`;
UNINSTALL EXTENSION vsql_schematron;
