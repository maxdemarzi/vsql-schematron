INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512830_Organizando%20Chaves%20e%20Bases%20de%20Dicionario
--echo #
CREATE DATABASE `db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario`;
USE `db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario`;
CREATE TABLE `JOGADOR` (
  `IDJOGADOR` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`IDJOGADOR`)
) CHARACTER SET latin1;
CREATE TABLE `TIMES` (
  `IDTIME` INT NOT NULL,
  `NOME` VARCHAR(50),
  `ID_JOGADOR` INT,
  PRIMARY KEY (`IDTIME`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
  `IDCLIENTE` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`IDCLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `TELEFONE` (
  `IDTELEFONE` INT,
  `TIPO` CHAR(50),
  `NUMERO` VARCHAR(50),
  `ID_CLIENTE` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario') AS relationships;
DROP DATABASE `db_512830_Organizando_20Chaves_20e_20Bases_20de_20Dicionario`;
UNINSTALL EXTENSION vsql_schematron;
