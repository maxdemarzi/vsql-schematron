INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 357176_01-10-20
--echo #
CREATE DATABASE `db_357176_01_10_20`;
USE `db_357176_01_10_20`;
CREATE TABLE `pais` (
  `paisid` INT NOT NULL,
  `paisnome` VARCHAR(50),
  PRIMARY KEY (`paisid`)
) CHARACTER SET latin1;
CREATE TABLE `cidade` (
  `cidadeid` INT NOT NULL,
  `cidadenome` VARCHAR(50),
  `paisid` INT,
  PRIMARY KEY (`cidadeid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_357176_01_10_20') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_357176_01_10_20') AS relationships;
DROP DATABASE `db_357176_01_10_20`;
UNINSTALL EXTENSION vsql_schematron;
