INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 471325_V1.6-schema
--echo #
CREATE DATABASE `db_471325_V1_6_schema`;
USE `db_471325_V1_6_schema`;
CREATE TABLE `configuration.instance` (
  `instance_name` VARCHAR(50) NOT NULL,
  `hostname` VARCHAR(50),
  `last_config_get_date` TIMESTAMP NULL,
  PRIMARY KEY (`instance_name`)
) CHARACTER SET latin1;
CREATE TABLE `configuration.instance_configuration` (
  `instance_name` VARCHAR(50) NOT NULL,
  `configuration_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`instance_name`, `configuration_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_471325_V1_6_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_471325_V1_6_schema') AS relationships;
DROP DATABASE `db_471325_V1_6_schema`;
UNINSTALL EXTENSION vsql_schematron;
