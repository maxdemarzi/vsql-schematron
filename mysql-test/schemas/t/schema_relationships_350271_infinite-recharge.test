INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 350271_infinite-recharge
--echo #
CREATE DATABASE `db_350271_infinite_recharge`;
USE `db_350271_infinite_recharge`;
CREATE TABLE `teams` (
  `id` INT NOT NULL,
  `number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `matches` (
  `team_number` INT,
  `type` TEXT,
  `match_number` INT,
  `alliance` TINYINT,
  `power_cell_tracker_id` INT,
  `color_wheel_id` INT,
  `shield_generator_id` INT,
  `associated_team` INT,
  `tech_fouls` INT,
  `fouls` INT,
  `yellow_card` TINYINT,
  `red_card` TINYINT,
  `estopped` TINYINT,
  `borked` TINYINT,
  `ranking_points` INT,
  `foul_points` INT,
  `bonus_points` INT
) CHARACTER SET latin1;
CREATE TABLE `power_cell_trackers` (
  `id` INT NOT NULL,
  `color_wheel_spun` TINYINT,
  `low_auto` INT,
  `low_teleop` INT,
  `outer_auto` INT,
  `outer_teleop` INT,
  `inner_auto` INT,
  `inner_teleop` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `color_wheels` (
  `id` INT NOT NULL,
  `state` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shield_generators` (
  `id` INT NOT NULL,
  `hanging_bots` TINYINT,
  `floor_bots` TINYINT,
  `is_level` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_350271_infinite_recharge') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_350271_infinite_recharge') AS relationships;
DROP DATABASE `db_350271_infinite_recharge`;
UNINSTALL EXTENSION vsql_schematron;
