INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 078881_migration
--echo #
CREATE DATABASE `db_078881_migration`;
USE `db_078881_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `discriminator` TEXT,
  `hasSeenTLauncherMessage` BOOLEAN,
  `hasBeenSentJoinMessage` BOOLEAN,
  `warnings` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `jailedUntil` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Channel` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Message` (
  `id` VARCHAR(50) NOT NULL,
  `isSystemMessage` BOOLEAN,
  `isBotMessage` BOOLEAN,
  `content` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `deletedAt` TIMESTAMP NULL,
  `channelId` TEXT,
  `userId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Setting` (
  `name` TEXT,
  `value` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `Log` (
  `url` TEXT,
  `createdAt` TIMESTAMP NULL,
  `channelId` TEXT,
  `userId` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_078881_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_078881_migration') AS relationships;
DROP DATABASE `db_078881_migration`;
UNINSTALL EXTENSION vsql_schematron;
