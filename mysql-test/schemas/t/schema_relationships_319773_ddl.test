INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319773_ddl
--echo #
CREATE DATABASE `db_319773_ddl`;
USE `db_319773_ddl`;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `moderators` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `role_id` INT,
  `created_at` BIGINT,
  `updated_at` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` BIGINT,
  `updated_at` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `subject_id` INT,
  `activated` BOOLEAN,
  `endpoint` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` BIGINT,
  `updated_at` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `extension` VARCHAR(50),
  `width` INT,
  `height` INT,
  `size` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` BIGINT,
  `updated_at` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `email` VARCHAR(50),
  `content` VARCHAR(50),
  `post_id` INT,
  `created_at` BIGINT,
  `updated_at` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319773_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319773_ddl') AS relationships;
DROP DATABASE `db_319773_ddl`;
UNINSTALL EXTENSION vsql_schematron;
