INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068601_sqlite_db_setup_lcpserver
--echo #
CREATE DATABASE `db_068601_sqlite_db_setup_lcpserver`;
USE `db_068601_sqlite_db_setup_lcpserver`;
CREATE TABLE `content` (
  `id` VARCHAR(50) NOT NULL,
  `encryption_key` VARCHAR(50),
  `location` TEXT,
  `length` BIGINT,
  `sha256` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `license` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `provider` VARCHAR(50),
  `issued` DATETIME,
  `updated` DATETIME,
  `rights_print` INT,
  `rights_copy` INT,
  `rights_start` DATETIME,
  `rights_end` DATETIME,
  `content_fk` VARCHAR(50),
  `lsd_status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068601_sqlite_db_setup_lcpserver') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068601_sqlite_db_setup_lcpserver') AS relationships;
DROP DATABASE `db_068601_sqlite_db_setup_lcpserver`;
UNINSTALL EXTENSION vsql_schematron;
