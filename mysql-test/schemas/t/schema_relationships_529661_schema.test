INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 529661_schema
--echo #
CREATE DATABASE `db_529661_schema`;
USE `db_529661_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `userProfile` (
  `user_id` INT,
  `userResult` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `quiz` (
  `id` INT NOT NULL,
  `user_id` INT,
  `question` TEXT,
  `optionA` TEXT,
  `optionB` TEXT,
  `optionC` TEXT,
  `optionD` TEXT,
  `correctAnswer` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_529661_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_529661_schema') AS relationships;
DROP DATABASE `db_529661_schema`;
UNINSTALL EXTENSION vsql_schematron;
