INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098378_schema.docker.example2
--echo #
CREATE DATABASE `db_098378_schema_docker_example2`;
USE `db_098378_schema_docker_example2`;
CREATE TABLE `sess` (
  `session_id` INT NOT NULL,
  `session_name` VARCHAR(50),
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
  `id` INT NOT NULL,
  `session_id` INT,
  `product_id` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098378_schema_docker_example2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098378_schema_docker_example2') AS relationships;
DROP DATABASE `db_098378_schema_docker_example2`;
UNINSTALL EXTENSION vsql_schematron;
