INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494752_up
--echo #
CREATE DATABASE `db_494752_up`;
USE `db_494752_up`;
CREATE TABLE `site_user_status` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `site_user` (
  `id` INT NOT NULL,
  `site_user_status_id` INT,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_group` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `label` TEXT,
  `post_group_id` INT,
  `post_category_id` INT,
  `content` TEXT,
  `published` BOOLEAN,
  `embedded` BOOLEAN,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `content` VARCHAR(50),
  `post_id` INT,
  `site_user_id` INT,
  `parent_comment_id` INT,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494752_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494752_up') AS relationships;
DROP DATABASE `db_494752_up`;
UNINSTALL EXTENSION vsql_schematron;
