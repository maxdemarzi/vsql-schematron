INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033941_estructura
--echo #
CREATE DATABASE `db_033941_estructura`;
USE `db_033941_estructura`;
CREATE TABLE `departamentos` (
  `id_depa` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_depa`)
) CHARACTER SET latin1;
CREATE TABLE `point_acum` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `puntos_sum` INT,
  `puntos_rest` INT,
  `id_nivel` INT,
  `fecha_insert` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `punto_nivel` (
  `id` INT NOT NULL,
  `Nivel` VARCHAR(50),
  `puntos` INT,
  `valor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033941_estructura') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033941_estructura') AS relationships;
DROP DATABASE `db_033941_estructura`;
UNINSTALL EXTENSION vsql_schematron;
