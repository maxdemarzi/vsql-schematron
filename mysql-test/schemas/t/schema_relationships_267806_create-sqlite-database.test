INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 267806_create-sqlite-database
--echo #
CREATE DATABASE `db_267806_create_sqlite_database`;
USE `db_267806_create_sqlite_database`;
CREATE TABLE `PhysicalDimension` (
  `Id` INT NOT NULL,
  `Name` TEXT,
  `Scale` TEXT,
  `Created` DATETIME,
  `CreatedBy` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Sensor` (
  `Id` INT NOT NULL,
  `Name` TEXT,
  `Make` TEXT,
  `Model` TEXT,
  `SerialNumber` TEXT,
  `PhysicalDimensionId` INT,
  `Created` DATETIME,
  `CreatedBy` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Measure` (
  `Id` INT NOT NULL,
  `SensorId` INT,
  `Value` DOUBLE,
  `Created` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_267806_create_sqlite_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_267806_create_sqlite_database') AS relationships;
DROP DATABASE `db_267806_create_sqlite_database`;
UNINSTALL EXTENSION vsql_schematron;
