INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508873_V0_1_3__people
--echo #
CREATE DATABASE `db_508873_V0_1_3__people`;
USE `db_508873_V0_1_3__people`;
CREATE TABLE `cities` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `id` VARCHAR(50) NOT NULL,
  `street` VARCHAR(50),
  `city_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `people` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses_people` (
  `id` VARCHAR(50) NOT NULL,
  `person_id` VARCHAR(50),
  `address_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508873_V0_1_3__people') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508873_V0_1_3__people') AS relationships;
DROP DATABASE `db_508873_V0_1_3__people`;
UNINSTALL EXTENSION vsql_schematron;
