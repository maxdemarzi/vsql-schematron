INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 260275_code_calc
--echo #
CREATE DATABASE `db_260275_code_calc`;
USE `db_260275_code_calc`;
CREATE TABLE `code_calc_subject` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_calc_model` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_calc_progs` (
  `id` VARCHAR(50) NOT NULL,
  `url` VARCHAR(50),
  `name` VARCHAR(50),
  `released` INT,
  `subject` VARCHAR(50),
  `model` VARCHAR(50),
  `ticalc` VARCHAR(50),
  `descmd` TEXT,
  `deschtml` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_260275_code_calc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_260275_code_calc') AS relationships;
DROP DATABASE `db_260275_code_calc`;
UNINSTALL EXTENSION vsql_schematron;
