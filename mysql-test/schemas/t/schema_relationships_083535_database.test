INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 083535_database
--echo #
CREATE DATABASE `db_083535_database`;
USE `db_083535_database`;
CREATE TABLE `admin` (
  `idamin` INT NOT NULL,
  `nom` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`idamin`)
) CHARACTER SET latin1;
CREATE TABLE `caisse` (
  `idcaisse` INT NOT NULL,
  `nom` VARCHAR(50),
  PRIMARY KEY (`idcaisse`)
) CHARACTER SET latin1;
CREATE TABLE `categorie` (
  `idcategorie` INT NOT NULL,
  `nom` VARCHAR(50),
  PRIMARY KEY (`idcategorie`)
) CHARACTER SET latin1;
CREATE TABLE `produit` (
  `idproduit` INT NOT NULL,
  `nom` VARCHAR(50),
  `image` VARCHAR(50),
  `idcategorie` INT,
  `prix` DECIMAL(10,2),
  `stock` INT,
  `ispromotion` BOOLEAN,
  PRIMARY KEY (`idproduit`)
) CHARACTER SET latin1;
CREATE TABLE `promotion` (
  `idpromotion` INT NOT NULL,
  `idproduit` INT,
  `datedajout` TIMESTAMP NULL,
  `prixpromotion` DOUBLE,
  PRIMARY KEY (`idpromotion`)
) CHARACTER SET latin1;
CREATE TABLE `achat` (
  `idachat` INT NOT NULL,
  `idcaisse` INT,
  `datedachat` TIMESTAMP NULL,
  `quantite` INT,
  `prixTotal` DOUBLE,
  PRIMARY KEY (`idachat`)
) CHARACTER SET latin1;
CREATE TABLE `detailsachat` (
  `idachat` INT,
  `idproduit` INT,
  `prixUnitaire` DOUBLE,
  `quantite` INT,
  `total` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_083535_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_083535_database') AS relationships;
DROP DATABASE `db_083535_database`;
UNINSTALL EXTENSION vsql_schematron;
