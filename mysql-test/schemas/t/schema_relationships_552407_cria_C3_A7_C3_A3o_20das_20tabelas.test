INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552407_cria%C3%A7%C3%A3o%20das%20tabelas
--echo #
CREATE DATABASE `db_552407_cria_C3_A7_C3_A3o_20das_20tabelas`;
USE `db_552407_cria_C3_A7_C3_A3o_20das_20tabelas`;
CREATE TABLE `Produtos` (
  `idProdutos` INT NOT NULL,
  `nome_produto` VARCHAR(50),
  `descricao` TEXT,
  `preco` DECIMAL(10,2),
  `img_url` VARCHAR(50),
  PRIMARY KEY (`idProdutos`)
) CHARACTER SET latin1;
CREATE TABLE `Clientes` (
  `idClientes` INT NOT NULL,
  `primeiro_nome` VARCHAR(50),
  `ultimo_nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `endereco` VARCHAR(50),
  `bairro` VARCHAR(50),
  `num_casa` VARCHAR(50),
  `cep` VARCHAR(50),
  `cidade` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`idClientes`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `idsession` INT NOT NULL,
  `Clientes_idClientes` INT,
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `chave` VARCHAR(50),
  PRIMARY KEY (`idsession`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `idpedidos` INT NOT NULL,
  `Clientes_idClientes` INT,
  `num_pedido` INT,
  PRIMARY KEY (`idpedidos`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos_has_Produtos` (
  `pedidos_idpedidos` INT NOT NULL,
  `Produtos_idProdutos` INT NOT NULL,
  PRIMARY KEY (`pedidos_idpedidos`, `Produtos_idProdutos`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552407_cria_C3_A7_C3_A3o_20das_20tabelas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552407_cria_C3_A7_C3_A3o_20das_20tabelas') AS relationships;
DROP DATABASE `db_552407_cria_C3_A7_C3_A3o_20das_20tabelas`;
UNINSTALL EXTENSION vsql_schematron;
