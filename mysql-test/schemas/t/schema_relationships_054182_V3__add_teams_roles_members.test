CREATE DATABASE `db_054182_V3__add_teams_roles_members`;
USE `db_054182_V3__add_teams_roles_members`;
CREATE TABLE `teams` (
  `id` MEDIUMINT NOT NULL,
  `urn` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `viewable` BOOLEAN,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `persons` (
  `id` MEDIUMINT NOT NULL,
  `urn` VARCHAR(50),
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `guest` BOOLEAN,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `memberships` (
  `id` MEDIUMINT NOT NULL,
  `role` VARCHAR(50),
  `team_id` MEDIUMINT,
  `person_id` MEDIUMINT,
  `urn_person` VARCHAR(50),
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
