INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 203045_creatiing_a_database
--echo #
CREATE DATABASE `db_203045_creatiing_a_database`;
USE `db_203045_creatiing_a_database`;
CREATE TABLE `Manager` (
  `Mg_Name` VARCHAR(50),
  `Mg_Number` VARCHAR(50) NOT NULL,
  `Mg_Department` VARCHAR(50),
  PRIMARY KEY (`Mg_Number`)
) CHARACTER SET latin1;
CREATE TABLE `product_cost` (
  `pc_desc` VARCHAR(50),
  `pc_code` VARCHAR(50) NOT NULL,
  `pc_type` VARCHAR(50),
  `pc_amount` INT,
  PRIMARY KEY (`pc_code`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
  `P_Name` VARCHAR(50),
  `P_Number` VARCHAR(50) NOT NULL,
  `P_Manager` VARCHAR(50),
  `P_Act_Cost` INT,
  `P_Exp_Cost` INT,
  PRIMARY KEY (`P_Number`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_203045_creatiing_a_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_203045_creatiing_a_database') AS relationships;
DROP DATABASE `db_203045_creatiing_a_database`;
UNINSTALL EXTENSION vsql_schematron;
