INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 601132_createBioSchema
--echo #
CREATE DATABASE `db_601132_createBioSchema`;
USE `db_601132_createBioSchema`;
CREATE TABLE `Contributor` (
  `LabName` VARCHAR(50) NOT NULL,
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `Country` VARCHAR(50),
  `Contact` VARCHAR(50),
  PRIMARY KEY (`LabName`)
) CHARACTER SET latin1;
CREATE TABLE `Gene` (
  `GeneName` VARCHAR(50) NOT NULL,
  `GFunction` VARCHAR(50),
  `GOrganism` VARCHAR(50),
  `GSequence` VARCHAR(50),
  `GContributor` VARCHAR(50),
  PRIMARY KEY (`GeneName`)
) CHARACTER SET latin1;
CREATE TABLE `Protein` (
  `ProteinName` VARCHAR(50) NOT NULL,
  `Gene` VARCHAR(50),
  `PFunction` VARCHAR(50),
  `POrganism` VARCHAR(50),
  `PSequence` VARCHAR(50),
  `PContributor` VARCHAR(50),
  PRIMARY KEY (`ProteinName`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_601132_createBioSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_601132_createBioSchema') AS relationships;
DROP DATABASE `db_601132_createBioSchema`;
UNINSTALL EXTENSION vsql_schematron;
