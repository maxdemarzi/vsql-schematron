INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 533248_siskitnet20171130
--echo #
CREATE DATABASE `db_533248_siskitnet20171130`;
USE `db_533248_siskitnet20171130`;
CREATE TABLE `tb_acesso` (
  `id` INT NOT NULL,
  `id_usuario` INT,
  `ip` VARCHAR(50),
  `user_agent` VARCHAR(50),
  `url` VARCHAR(50),
  `data` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_indenizacao` (
  `id` INT NOT NULL,
  `id_locatario` INT,
  `id_mes` INT,
  `descricao` VARCHAR(50),
  `data` DATE,
  `ano` INT,
  `valor` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_perfil` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_renovacao_contrato` (
  `id` INT NOT NULL,
  `id_contrato` INT,
  `id_status` INT,
  `id_imovel` INT,
  `data_inicio` DATE,
  `data_fim` DATE,
  `prazo` INT,
  `primeiro_vencimento` DATE,
  `valor` DECIMAL(10,2),
  `chave` VARCHAR(50),
  `numero` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_usuario` (
  `id` INT NOT NULL,
  `id_perfil` INT,
  `nome` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `email` VARCHAR(50),
  `ativo` INT,
  `chave` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_533248_siskitnet20171130') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_533248_siskitnet20171130') AS relationships;
DROP DATABASE `db_533248_siskitnet20171130`;
UNINSTALL EXTENSION vsql_schematron;
