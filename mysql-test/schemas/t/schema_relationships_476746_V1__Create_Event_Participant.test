CREATE DATABASE `db_476746_V1__Create_Event_Participant`;
USE `db_476746_V1__Create_Event_Participant`;
CREATE TABLE `event` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `currency` VARCHAR(50),
  `number` DECIMAL(10,2),
  `title` VARCHAR(50),
  `local_date_time` TIMESTAMP NULL,
  `zone_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `participant` (
  `id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `event_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_476746_V1__Create_Event_Participant') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_476746_V1__Create_Event_Participant') AS relationships;
DROP DATABASE `db_476746_V1__Create_Event_Participant`;
UNINSTALL EXTENSION vsql_schematron;
