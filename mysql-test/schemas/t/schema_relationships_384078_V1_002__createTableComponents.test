CREATE DATABASE `db_384078_V1_002__createTableComponents`;
USE `db_384078_V1_002__createTableComponents`;
CREATE TABLE `T_COMPONENTS` (
  `ID` VARCHAR(50) NOT NULL,
  `PARENT_ID` VARCHAR(50),
  `CONTRACT_ID` VARCHAR(50),
  `COMPONENTDEFINITION_ID` VARCHAR(50),
  `PRODUCT_ID` VARCHAR(50),
  `CONFIGURATION` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_384078_V1_002__createTableComponents') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_384078_V1_002__createTableComponents') AS relationships;
DROP DATABASE `db_384078_V1_002__createTableComponents`;
