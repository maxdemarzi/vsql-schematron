INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 615072_hw02q02
--echo #
CREATE DATABASE `db_615072_hw02q02`;
USE `db_615072_hw02q02`;
CREATE TABLE `ACTORS` (
  `actor_id` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `nationality` VARCHAR(50),
  PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIES` (
  `movie_id` DECIMAL(10,2) NOT NULL,
  `title` VARCHAR(50),
  `year` DECIMAL(10,2),
  `studio` VARCHAR(50),
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;
CREATE TABLE `STARSIN` (
  `actor_id` DECIMAL(10,2) NOT NULL,
  `movie_id` DECIMAL(10,2) NOT NULL,
  `character` VARCHAR(50),
  PRIMARY KEY (`actor_id`, `movie_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_615072_hw02q02') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_615072_hw02q02') AS relationships;
DROP DATABASE `db_615072_hw02q02`;
UNINSTALL EXTENSION vsql_schematron;
