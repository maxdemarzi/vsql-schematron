INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 622081_bancodedados
--echo #
CREATE DATABASE `db_622081_bancodedados`;
USE `db_622081_bancodedados`;
CREATE TABLE `tipocampanha` (
  `idtipocampanha` INT NOT NULL,
  `nometipocampanha` VARCHAR(50),
  `descricaotipocampanha` VARCHAR(50),
  PRIMARY KEY (`idtipocampanha`)
) CHARACTER SET latin1;
CREATE TABLE `campanha` (
  `idcampanha` INT NOT NULL,
  `dataentrega` VARCHAR(50),
  `horaentrega` VARCHAR(50),
  `detalhes` VARCHAR(50),
  `enderecoentrega` VARCHAR(50),
  `encerrado` VARCHAR(50),
  `idtipocampanha` INT,
  PRIMARY KEY (`idcampanha`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_622081_bancodedados') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_622081_bancodedados') AS relationships;
DROP DATABASE `db_622081_bancodedados`;
UNINSTALL EXTENSION vsql_schematron;
