INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 185277_V1__Data_Setup
--echo #
CREATE DATABASE `db_185277_V1__Data_Setup`;
USE `db_185277_V1__Data_Setup`;
CREATE TABLE `AUTHOR` (
  `ID` INT NOT NULL,
  `AUTHOR` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `QUOTE` (
  `ID` INT NOT NULL,
  `AUTHOR_ID` INT,
  `QUOTE` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185277_V1__Data_Setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185277_V1__Data_Setup') AS relationships;
DROP DATABASE `db_185277_V1__Data_Setup`;
UNINSTALL EXTENSION vsql_schematron;
