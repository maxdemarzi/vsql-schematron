INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 683252_create
--echo #
CREATE DATABASE `db_683252_create`;
USE `db_683252_create`;
CREATE TABLE `tb_sales` (
  `id` BIGINT NOT NULL,
  `amount` DOUBLE,
  `date` DATE,
  `deals` INT,
  `visited` INT,
  `seller_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_sellers` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_683252_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_683252_create') AS relationships;
DROP DATABASE `db_683252_create`;
UNINSTALL EXTENSION vsql_schematron;
