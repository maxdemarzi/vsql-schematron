INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 298462_table
--echo #
CREATE DATABASE `db_298462_table`;
USE `db_298462_table`;
CREATE TABLE `member` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member_supplement` (
  `member_id` VARCHAR(50) NOT NULL,
  `kana` VARCHAR(50),
  `class` VARCHAR(50),
  `birthday` DATE,
  `bloodtype` VARCHAR(50),
  PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `discography` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `song` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_298462_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_298462_table') AS relationships;
DROP DATABASE `db_298462_table`;
UNINSTALL EXTENSION vsql_schematron;
