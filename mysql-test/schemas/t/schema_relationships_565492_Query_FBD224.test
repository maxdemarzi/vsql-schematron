INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565492_Query_FBD224
--echo #
CREATE DATABASE `db_565492_Query_FBD224`;
USE `db_565492_Query_FBD224`;
CREATE TABLE `empregados` (
  `id_empregados` INT NOT NULL,
  `nome` VARCHAR(50),
  `sobrenome` VARCHAR(50),
  `salario` DECIMAL(10,2),
  `email` VARCHAR(50),
  `data_admissao` DATE,
  `cargo_id` INT,
  `id_departamento` INT,
  PRIMARY KEY (`id_empregados`)
) CHARACTER SET latin1;
CREATE TABLE `departamentos` (
  `id_departamento` INT NOT NULL,
  `departamento_nome` VARCHAR(50),
  `id_localidade` INT,
  PRIMARY KEY (`id_departamento`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565492_Query_FBD224') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565492_Query_FBD224') AS relationships;
DROP DATABASE `db_565492_Query_FBD224`;
UNINSTALL EXTENSION vsql_schematron;
