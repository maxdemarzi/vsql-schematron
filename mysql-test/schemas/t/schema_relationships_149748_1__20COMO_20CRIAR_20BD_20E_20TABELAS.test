INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 149748_1.%20COMO%20CRIAR%20BD%20E%20TABELAS
--echo #
CREATE DATABASE `db_149748_1__20COMO_20CRIAR_20BD_20E_20TABELAS`;
USE `db_149748_1__20COMO_20CRIAR_20BD_20E_20TABELAS`;
CREATE TABLE `PRODUTOS` (
  `CODIGO` VARCHAR(50) NOT NULL,
  `DESCRITOR` VARCHAR(50),
  `SABOR` VARCHAR(50),
  `TAMANHO` VARCHAR(50),
  `EMBALAGEM` VARCHAR(50),
  `PRECO_LISTA` DOUBLE,
  PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `VENDEDORES` (
  `MATRICULA` VARCHAR(50) NOT NULL,
  `NOME` VARCHAR(50),
  `BAIRRO` VARCHAR(50),
  `COMISSAO` DOUBLE,
  `DATA_ADIMISSAO` DATE,
  `FERIAS` VARCHAR(50),
  PRIMARY KEY (`MATRICULA`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTES` (
  `CPF` VARCHAR(50) NOT NULL,
  `NOME` VARCHAR(50),
  `ENDERECO1` VARCHAR(50),
  `ENDERECO2` VARCHAR(50),
  `BAIRRO` VARCHAR(50),
  `CIDADE` VARCHAR(50),
  `ESTADO` VARCHAR(50),
  `CEP` VARCHAR(50),
  `IDADE` SMALLINT,
  `SEXO` VARCHAR(50),
  `LIMITE_CREDITO` DOUBLE,
  `VOLUME_COMPRA` DOUBLE,
  `PRIMEIRA_COMPRA` VARCHAR(50),
  PRIMARY KEY (`CPF`)
) CHARACTER SET latin1;
CREATE TABLE `TABELA_DE_VENDAS` (
  `NUMERO` VARCHAR(50) NOT NULL,
  `DATA_VENDA` DATE,
  `CPF` VARCHAR(50),
  `MATRICULA` VARCHAR(50),
  `IMPOSTO` DOUBLE,
  PRIMARY KEY (`NUMERO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_149748_1__20COMO_20CRIAR_20BD_20E_20TABELAS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_149748_1__20COMO_20CRIAR_20BD_20E_20TABELAS') AS relationships;
DROP DATABASE `db_149748_1__20COMO_20CRIAR_20BD_20E_20TABELAS`;
UNINSTALL EXTENSION vsql_schematron;
