INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 370615_3
--echo #
CREATE DATABASE `db_370615_3`;
USE `db_370615_3`;
CREATE TABLE `Employee` (
  `Emp_no` INT NOT NULL,
  `Emp_name` VARCHAR(50),
  `Address` VARCHAR(50),
  `DOB` DATE,
  `Date_of_Join` DATE,
  `Mobile_no` DECIMAL(10,2),
  `Dept_no` INT,
  `Salary` INT,
  PRIMARY KEY (`Emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `Department` (
  `Dept_no` INT NOT NULL,
  `Dept_name` VARCHAR(50),
  `Location` VARCHAR(50),
  PRIMARY KEY (`Dept_no`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_370615_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_370615_3') AS relationships;
DROP DATABASE `db_370615_3`;
UNINSTALL EXTENSION vsql_schematron;
