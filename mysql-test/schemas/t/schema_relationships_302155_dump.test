INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302155_dump
--echo #
CREATE DATABASE `db_302155_dump`;
USE `db_302155_dump`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `password` CHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302155_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302155_dump') AS relationships;
DROP DATABASE `db_302155_dump`;
UNINSTALL EXTENSION vsql_schematron;
