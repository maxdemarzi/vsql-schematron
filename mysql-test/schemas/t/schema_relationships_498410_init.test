INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 498410_init
--echo #
CREATE DATABASE `db_498410_init`;
USE `db_498410_init`;
CREATE TABLE `members` (
  `id` INT NOT NULL,
  `email` TEXT,
  `fullname` VARCHAR(50),
  `active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `attendances` (
  `day` DATE NOT NULL,
  `id` INT NOT NULL,
  PRIMARY KEY (`day`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `bringer` (
  `day` DATE NOT NULL,
  `id` INT NOT NULL,
  PRIMARY KEY (`day`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `app_state` (
  `dummy` INT NOT NULL,
  `attendance_primed_until` DATE,
  PRIMARY KEY (`dummy`)
) CHARACTER SET latin1;
CREATE TABLE `migratus` (
  `id` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_498410_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_498410_init') AS relationships;
DROP DATABASE `db_498410_init`;
UNINSTALL EXTENSION vsql_schematron;
