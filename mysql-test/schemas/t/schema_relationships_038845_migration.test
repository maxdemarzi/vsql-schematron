INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038845_migration
--echo #
CREATE DATABASE `db_038845_migration`;
USE `db_038845_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `address` TEXT,
  `authDetailId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AuthDetail` (
  `id` VARCHAR(50) NOT NULL,
  `nonce` TEXT,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038845_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038845_migration') AS relationships;
DROP DATABASE `db_038845_migration`;
UNINSTALL EXTENSION vsql_schematron;
