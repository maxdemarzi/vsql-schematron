INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 371285_init
--echo #
CREATE DATABASE `db_371285_init`;
USE `db_371285_init`;
CREATE TABLE `User` (
  `idx` VARCHAR(50),
  `id` VARCHAR(50),
  `password` VARCHAR(50),
  `level` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `Container` (
  `container_id` CHAR(50),
  `owner_id` VARCHAR(50),
  `container_describe` VARCHAR(50),
  `last_use_timestamp` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_371285_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_371285_init') AS relationships;
DROP DATABASE `db_371285_init`;
UNINSTALL EXTENSION vsql_schematron;
