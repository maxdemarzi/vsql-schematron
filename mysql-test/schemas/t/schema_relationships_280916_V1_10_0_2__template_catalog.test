INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 280916_V1_10_0_2__template_catalog
--echo #
CREATE DATABASE `db_280916_V1_10_0_2__template_catalog`;
USE `db_280916_V1_10_0_2__template_catalog`;
CREATE TABLE `CMS_TEMPLATE_CATALOG` (
  `ID` BIGINT NOT NULL,
  `TYPE` VARCHAR(50),
  `NAME` VARCHAR(50),
  `PRIORITY` INT,
  `PATH` VARCHAR(50),
  `PARENT_ID` BIGINT,
  `TENANT_ID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_280916_V1_10_0_2__template_catalog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_280916_V1_10_0_2__template_catalog') AS relationships;
DROP DATABASE `db_280916_V1_10_0_2__template_catalog`;
UNINSTALL EXTENSION vsql_schematron;
