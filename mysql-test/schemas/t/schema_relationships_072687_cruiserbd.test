INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072687_cruiserbd
--echo #
CREATE DATABASE `db_072687_cruiserbd`;
USE `db_072687_cruiserbd`;
CREATE TABLE `LOJA` (
  `loja_id` INT NOT NULL,
  `loja_cidade` VARCHAR(50),
  `loja_telefone` VARCHAR(50),
  `loja_tipo` VARCHAR(50),
  PRIMARY KEY (`loja_id`)
) CHARACTER SET latin1;
CREATE TABLE `FUNCIONARIO` (
  `func_id` INT NOT NULL,
  `func_nome` VARCHAR(50),
  `func_email` VARCHAR(50),
  `func_senha` VARCHAR(50),
  `func_cidade` VARCHAR(50),
  `func_departamento` VARCHAR(50),
  `func_status` BOOLEAN,
  `func_loja_id` INT,
  PRIMARY KEY (`func_id`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
  `cli_id` INT NOT NULL,
  `cli_nome` VARCHAR(50),
  `cli_cpf` VARCHAR(50),
  `cli_email` VARCHAR(50),
  PRIMARY KEY (`cli_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072687_cruiserbd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072687_cruiserbd') AS relationships;
DROP DATABASE `db_072687_cruiserbd`;
UNINSTALL EXTENSION vsql_schematron;
