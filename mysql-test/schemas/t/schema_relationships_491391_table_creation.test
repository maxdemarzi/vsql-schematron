INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 491391_table_creation
--echo #
CREATE DATABASE `db_491391_table_creation`;
USE `db_491391_table_creation`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_491391_table_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_491391_table_creation') AS relationships;
DROP DATABASE `db_491391_table_creation`;
UNINSTALL EXTENSION vsql_schematron;
