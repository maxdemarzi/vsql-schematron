INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524406_db_schema
--echo #
CREATE DATABASE `db_524406_db_schema`;
USE `db_524406_db_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `data_files` (
  `id` INT NOT NULL,
  `owner_id` INT,
  `filename` TEXT,
  `longitude` TEXT,
  `latitude` TEXT,
  `info` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `revisions` (
  `id` INT NOT NULL,
  `data_file_id` INT,
  `created` TIMESTAMP NULL,
  `filepath` TEXT,
  `revision` INT,
  `file_type` TEXT,
  `info` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `id` INT NOT NULL,
  `data_file_id` INT,
  `step` TEXT,
  `parameters` TEXT,
  `up_to_date` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524406_db_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524406_db_schema') AS relationships;
DROP DATABASE `db_524406_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
