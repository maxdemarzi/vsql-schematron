INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 243877_create_tables_xhv
--echo #
CREATE DATABASE `db_243877_create_tables_xhv`;
USE `db_243877_create_tables_xhv`;
CREATE TABLE `blocks` (
  `height` VARCHAR(50) NOT NULL,
  `block_size` VARCHAR(50),
  `weight` VARCHAR(50),
  `difficulty` BIGINT,
  `cumulative_difficulty` BIGINT,
  `hash` VARCHAR(50),
  `long_term_weight` VARCHAR(50),
  `major_version` VARCHAR(50),
  `minor_version` VARCHAR(50),
  `nonce` VARCHAR(50),
  `reward` VARCHAR(50),
  `block_time` VARCHAR(50),
  `wide_cumulative_difficulty` VARCHAR(50),
  `wide_difficulty` VARCHAR(50),
  PRIMARY KEY (`height`)
) CHARACTER SET latin1;
CREATE TABLE `txins` (
  `txin_id` VARCHAR(50) NOT NULL,
  `tx_id` VARCHAR(50),
  `amount` VARCHAR(50),
  `keyimage` VARCHAR(50),
  `coinbase` BOOLEAN,
  PRIMARY KEY (`txin_id`)
) CHARACTER SET latin1;
CREATE TABLE `txouts` (
  `tx_id` VARCHAR(50),
  `amount` VARCHAR(50),
  `target_key` VARCHAR(50),
  `tx_type` VARCHAR(50),
  `asset_type` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `key_offsets` (
  `txin_id` VARCHAR(50),
  `offset` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `output_details` (
  `tx_id` VARCHAR(50),
  `txin_id` VARCHAR(50),
  `height` VARCHAR(50),
  `key_hex` VARCHAR(50),
  `mask_hex` VARCHAR(50),
  `unlocked` BOOLEAN
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_243877_create_tables_xhv') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_243877_create_tables_xhv') AS relationships;
DROP DATABASE `db_243877_create_tables_xhv`;
UNINSTALL EXTENSION vsql_schematron;
