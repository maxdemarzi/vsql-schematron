INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 416633_assignment5
--echo #
CREATE DATABASE `db_416633_assignment5`;
USE `db_416633_assignment5`;
CREATE TABLE `employee` (
  `emp_name` VARCHAR(50) NOT NULL,
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  PRIMARY KEY (`emp_name`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
  `co_name` VARCHAR(50) NOT NULL,
  `city` VARCHAR(50),
  PRIMARY KEY (`co_name`)
) CHARACTER SET latin1;
CREATE TABLE `works` (
  `emp_name` VARCHAR(50),
  `co_name` VARCHAR(50),
  `salary` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_416633_assignment5') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_416633_assignment5') AS relationships;
DROP DATABASE `db_416633_assignment5`;
UNINSTALL EXTENSION vsql_schematron;
