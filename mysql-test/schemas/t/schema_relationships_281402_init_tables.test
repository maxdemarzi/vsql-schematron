INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281402_init_tables
--echo #
CREATE DATABASE `db_281402_init_tables`;
USE `db_281402_init_tables`;
CREATE TABLE `transmissions` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `engines` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bodies` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `id` INT NOT NULL,
  `transmission_id` INT,
  `engine_id` INT,
  `body_id` INT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281402_init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281402_init_tables') AS relationships;
DROP DATABASE `db_281402_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
