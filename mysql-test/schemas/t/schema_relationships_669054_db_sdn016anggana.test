    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_669054_db_sdn016anggana') AS relationships;
DROP DATABASE `db_669054_db_sdn016anggana`;
