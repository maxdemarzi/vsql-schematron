INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 618669_create_cadg_db
--echo #
CREATE DATABASE `db_618669_create_cadg_db`;
USE `db_618669_create_cadg_db`;
CREATE TABLE `cadg.disseminator` (
  `disseminator_id` INT NOT NULL,
  `disseminator_name` VARCHAR(50),
  `disseminator_type` VARCHAR(50),
  `message_format` VARCHAR(50),
  `ip` VARCHAR(50),
  `port` INT,
  `backup_port` INT,
  `status` VARCHAR(50),
  PRIMARY KEY (`disseminator_id`)
) CHARACTER SET latin1;
CREATE TABLE `cadg.alert` (
  `alert_id` INT NOT NULL,
  `identifier` VARCHAR(50),
  `originator_id` INT,
  `message_type` VARCHAR(50),
  `scope` VARCHAR(50),
  `status` VARCHAR(50),
  `urgency` VARCHAR(50),
  `severity` VARCHAR(50),
  `sent_time` VARCHAR(50),
  `cap_xml` TEXT,
  PRIMARY KEY (`alert_id`)
) CHARACTER SET latin1;
CREATE TABLE `cadg.originator` (
  `originator_id` INT NOT NULL,
  `originator_name` VARCHAR(50),
  `status` VARCHAR(50),
  `agency` VARCHAR(50),
  PRIMARY KEY (`originator_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_618669_create_cadg_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_618669_create_cadg_db') AS relationships;
DROP DATABASE `db_618669_create_cadg_db`;
UNINSTALL EXTENSION vsql_schematron;
