INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 474266_up
--echo #
CREATE DATABASE `db_474266_up`;
USE `db_474266_up`;
CREATE TABLE `cache_roots` (
  `id` INT NOT NULL,
  `path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cuboids` (
  `id` INT NOT NULL,
  `cache_root` INT,
  `cube_key` VARCHAR(50),
  `requests` BIGINT,
  `created` DATETIME,
  `last_accessed` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_474266_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_474266_up') AS relationships;
DROP DATABASE `db_474266_up`;
UNINSTALL EXTENSION vsql_schematron;
