INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 078438_schema
--echo #
CREATE DATABASE `db_078438_schema`;
USE `db_078438_schema`;
CREATE TABLE `PERSON` (
  `PERSON_ID` BIGINT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `EMAIL_ADDRESS` VARCHAR(50),
  PRIMARY KEY (`PERSON_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
  `ITEM_ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `MANUFACTURER` VARCHAR(50),
  `MODEL` VARCHAR(50),
  `QUANTITY` INT,
  `PERSON_ID` BIGINT,
  PRIMARY KEY (`ITEM_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_078438_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_078438_schema') AS relationships;
DROP DATABASE `db_078438_schema`;
UNINSTALL EXTENSION vsql_schematron;
