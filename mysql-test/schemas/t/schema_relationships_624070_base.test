INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624070_base
--echo #
CREATE DATABASE `db_624070_base`;
USE `db_624070_base`;
CREATE TABLE `cursos` (
  `id` INT NOT NULL,
  `titulo` VARCHAR(50),
  `profesor` VARCHAR(50),
  `dia` VARCHAR(50),
  `turno` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alumnos` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `edad` INT,
  `idCurso` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624070_base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624070_base') AS relationships;
DROP DATABASE `db_624070_base`;
UNINSTALL EXTENSION vsql_schematron;
