INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 394865_init
--echo #
CREATE DATABASE `db_394865_init`;
USE `db_394865_init`;
CREATE TABLE `movies` (
  `mid` INT NOT NULL,
  `title` VARCHAR(50),
  `year` INT,
  `rating` DOUBLE,
  `num_ratings` INT,
  PRIMARY KEY (`mid`)
) CHARACTER SET latin1;
CREATE TABLE `actors` (
  `mid` INT,
  `name` VARCHAR(50),
  `cast_position` INT
) CHARACTER SET latin1;
CREATE TABLE `genres` (
  `mid` INT,
  `genre` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tag_names` (
  `tid` INT NOT NULL,
  `tag` VARCHAR(50),
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `mid` INT,
  `tid` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_394865_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_394865_init') AS relationships;
DROP DATABASE `db_394865_init`;
UNINSTALL EXTENSION vsql_schematron;
