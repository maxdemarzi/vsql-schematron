INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068893_mysql
--echo #
CREATE DATABASE `db_068893_mysql`;
USE `db_068893_mysql`;
CREATE TABLE `patents` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `divisions` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stormtroopers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `nickname` VARCHAR(50),
  `id_patent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stormtrooper_division` (
  `id_stormtrooper` INT,
  `id_division` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068893_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068893_mysql') AS relationships;
DROP DATABASE `db_068893_mysql`;
UNINSTALL EXTENSION vsql_schematron;
