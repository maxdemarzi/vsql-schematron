INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084524_20210228194538_blogpost
--echo #
CREATE DATABASE `db_084524_20210228194538_blogpost`;
USE `db_084524_20210228194538_blogpost`;
CREATE TABLE `authors` (
  `author_id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `blogposts` (
  `blogpost_id` VARCHAR(50) NOT NULL,
  `author_id` VARCHAR(50),
  `uuid_list` VARCHAR(50),
  `title` TEXT,
  `content` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`blogpost_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084524_20210228194538_blogpost') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084524_20210228194538_blogpost') AS relationships;
DROP DATABASE `db_084524_20210228194538_blogpost`;
UNINSTALL EXTENSION vsql_schematron;
