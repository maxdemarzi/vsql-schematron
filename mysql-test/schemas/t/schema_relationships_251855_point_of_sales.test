INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 251855_point_of_sales
--echo #
CREATE DATABASE `db_251855_point_of_sales`;
USE `db_251855_point_of_sales`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
  `id` INT NOT NULL,
  `invoice` VARCHAR(50),
  `username` VARCHAR(50),
  `date` DATETIME,
  `product_name` VARCHAR(50),
  `price` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` INT,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `image` TEXT,
  `id_category` INT,
  `price` INT,
  `stock` INT,
  `date_added` DATETIME,
  `date_updated` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_251855_point_of_sales') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_251855_point_of_sales') AS relationships;
DROP DATABASE `db_251855_point_of_sales`;
UNINSTALL EXTENSION vsql_schematron;
