INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054404_reset_table
--echo #
CREATE DATABASE `db_054404_reset_table`;
USE `db_054404_reset_table`;
CREATE TABLE `member` (
  `member_id` INT NOT NULL,
  `member_name` VARCHAR(50),
  PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `issue` (
  `issue_id` INT NOT NULL,
  `issue_name` VARCHAR(50),
  `issue_description` VARCHAR(50),
  `member_id` INT,
  PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054404_reset_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054404_reset_table') AS relationships;
DROP DATABASE `db_054404_reset_table`;
UNINSTALL EXTENSION vsql_schematron;
