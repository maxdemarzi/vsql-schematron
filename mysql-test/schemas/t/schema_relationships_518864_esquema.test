INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518864_esquema
--echo #
CREATE DATABASE `db_518864_esquema`;
USE `db_518864_esquema`;
CREATE TABLE `usuarios` (
  `id` VARCHAR(50) NOT NULL,
  `correo` VARCHAR(50),
  `pass` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `id` VARCHAR(50) NOT NULL,
  `idUsuario` VARCHAR(50),
  `razonSocial` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ajustes` (
  `idUsuario` VARCHAR(50),
  `remitente` VARCHAR(50),
  `mensajePresentacion` VARCHAR(50),
  `mensajeAgradecimiento` VARCHAR(50),
  `mensajePie` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `cotizaciones` (
  `id` VARCHAR(50) NOT NULL,
  `idUsuario` VARCHAR(50),
  `idCliente` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `fecha` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `servicios_cotizaciones` (
  `id` VARCHAR(50) NOT NULL,
  `idCotizacion` VARCHAR(50),
  `servicio` VARCHAR(50),
  `costo` DECIMAL(10,2),
  `tiempoEnMinutos` VARCHAR(50),
  `multiplicador` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `caracteristicas_cotizaciones` (
  `id` VARCHAR(50) NOT NULL,
  `idCotizacion` VARCHAR(50),
  `caracteristica` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sesiones` (
  `id` VARCHAR(50) NOT NULL,
  `datos` TEXT,
  `ultimo_acceso` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518864_esquema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518864_esquema') AS relationships;
DROP DATABASE `db_518864_esquema`;
UNINSTALL EXTENSION vsql_schematron;
