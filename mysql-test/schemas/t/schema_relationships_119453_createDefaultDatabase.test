INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 119453_createDefaultDatabase
--echo #
CREATE DATABASE `db_119453_createDefaultDatabase`;
USE `db_119453_createDefaultDatabase`;
CREATE TABLE `Language` (
  `ID` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `TS` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `String` (
  `ID` VARCHAR(50) NOT NULL,
  `Value` VARCHAR(50),
  `Description` VARCHAR(50),
  `MaxLenght` VARCHAR(50),
  `State` VARCHAR(50),
  `LanguageID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_119453_createDefaultDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_119453_createDefaultDatabase') AS relationships;
DROP DATABASE `db_119453_createDefaultDatabase`;
UNINSTALL EXTENSION vsql_schematron;
