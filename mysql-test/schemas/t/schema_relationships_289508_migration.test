INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289508_migration
--echo #
CREATE DATABASE `db_289508_migration`;
USE `db_289508_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `username` TEXT,
  `email` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Photo` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  `authorId` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289508_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289508_migration') AS relationships;
DROP DATABASE `db_289508_migration`;
UNINSTALL EXTENSION vsql_schematron;
