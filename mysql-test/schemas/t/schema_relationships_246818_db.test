INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246818_db
--echo #
CREATE DATABASE `db_246818_db`;
USE `db_246818_db`;
CREATE TABLE `tblUsers` (
  `userId` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `passwordHash` TEXT,
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `tblItems` (
  `itemId` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `costPrice` DECIMAL(10,2),
  `quantity` DECIMAL(10,2),
  `sellPrice` DECIMAL(10,2),
  PRIMARY KEY (`itemId`)
) CHARACTER SET latin1;
CREATE TABLE `tblCustomers` (
  `customerId` INT NOT NULL,
  `userId` INT,
  `billingAddress` TEXT,
  PRIMARY KEY (`customerId`)
) CHARACTER SET latin1;
CREATE TABLE `tblOrders` (
  `orderId` INT NOT NULL,
  `customerId` INT,
  `orderDate` DATETIME,
  `shippingAddress` TEXT,
  PRIMARY KEY (`orderId`)
) CHARACTER SET latin1;
CREATE TABLE `tblOrderItems` (
  `orderItemId` INT NOT NULL,
  `orderId` INT,
  `itemId` VARCHAR(50),
  `quantity` DECIMAL(10,2),
  PRIMARY KEY (`orderItemId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246818_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246818_db') AS relationships;
DROP DATABASE `db_246818_db`;
UNINSTALL EXTENSION vsql_schematron;
