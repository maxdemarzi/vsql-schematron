INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 397216_ddl
--echo #
CREATE DATABASE `db_397216_ddl`;
USE `db_397216_ddl`;
CREATE TABLE `seasons` (
  `SEASON_ID` INT NOT NULL,
  `year` INT,
  PRIMARY KEY (`SEASON_ID`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
  `TEAM_ID` INT NOT NULL,
  `team_name` VARCHAR(50),
  `team_city` VARCHAR(50),
  `home_stadium` VARCHAR(50),
  `team_nickname` VARCHAR(50),
  `team_owner` VARCHAR(50),
  PRIMARY KEY (`TEAM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
  `GAME_ID` INT NOT NULL,
  `season` INT,
  `pats` VARCHAR(50),
  `pat_score` INT,
  `against_team` INT,
  `against_score` INT,
  `game_date` VARCHAR(50),
  `game_stadium` VARCHAR(50),
  PRIMARY KEY (`GAME_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_397216_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_397216_ddl') AS relationships;
DROP DATABASE `db_397216_ddl`;
UNINSTALL EXTENSION vsql_schematron;
