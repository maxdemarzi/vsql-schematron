INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360152_jsp-template-sistema
--echo #
CREATE DATABASE `db_360152_jsp_template_sistema`;
USE `db_360152_jsp_template_sistema`;
CREATE TABLE `profiles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `telephone` CHAR(50),
  `email` VARCHAR(50),
  `login` CHAR(50),
  `password` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_profiles` (
  `id_user` INT NOT NULL,
  `id_profile` INT NOT NULL,
  PRIMARY KEY (`id_user`, `id_profile`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360152_jsp_template_sistema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360152_jsp_template_sistema') AS relationships;
DROP DATABASE `db_360152_jsp_template_sistema`;
UNINSTALL EXTENSION vsql_schematron;
