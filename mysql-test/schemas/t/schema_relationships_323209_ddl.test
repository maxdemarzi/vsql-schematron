INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 323209_ddl
--echo #
CREATE DATABASE `db_323209_ddl`;
USE `db_323209_ddl`;
CREATE TABLE `client` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email_address` VARCHAR(50),
  `account_type` VARCHAR(50),
  `extra` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stock` (
  `stock_id` INT NOT NULL,
  `client_id` INT,
  `ticker` CHAR(50),
  `shares` INT,
  `purchased_value` INT,
  `purchased_date` VARCHAR(50),
  PRIMARY KEY (`stock_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_323209_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_323209_ddl') AS relationships;
DROP DATABASE `db_323209_ddl`;
UNINSTALL EXTENSION vsql_schematron;
