INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 294026_00_clear_database
--echo #
CREATE DATABASE `db_294026_00_clear_database`;
USE `db_294026_00_clear_database`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `salt` VARCHAR(50),
  `reset_token` CHAR(50),
  `reset_token_expire` DATETIME,
  `created_date` DATETIME,
  `last_login_date` DATETIME,
  `is_active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `role_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles_users` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_294026_00_clear_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_294026_00_clear_database') AS relationships;
DROP DATABASE `db_294026_00_clear_database`;
UNINSTALL EXTENSION vsql_schematron;
