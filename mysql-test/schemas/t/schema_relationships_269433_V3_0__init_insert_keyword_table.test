INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 269433_V3_0__init_insert_keyword_table
--echo #
CREATE DATABASE `db_269433_V3_0__init_insert_keyword_table`;
USE `db_269433_V3_0__init_insert_keyword_table`;
CREATE TABLE `keyword_entity` (
  `keyword_uuid` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `alias` VARCHAR(50),
  `creation_user` VARCHAR(50),
  `creation_date` DATETIME,
  `version` INT,
  `active` BOOLEAN,
  PRIMARY KEY (`keyword_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `keyword_product` (
  `product_uuid` VARCHAR(50),
  `keyword_uuid` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_269433_V3_0__init_insert_keyword_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_269433_V3_0__init_insert_keyword_table') AS relationships;
DROP DATABASE `db_269433_V3_0__init_insert_keyword_table`;
UNINSTALL EXTENSION vsql_schematron;
