INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070832_create
--echo #
CREATE DATABASE `db_070832_create`;
USE `db_070832_create`;
CREATE TABLE `TOURNAMENT` (
  `ID` INT NOT NULL,
  `ID_ASSOCIATION` INT,
  `TYPE_ASSOCIATION` VARCHAR(50),
  `LOCATION` VARCHAR(50),
  `NAME` VARCHAR(50),
  `YEAR` INT,
  `COURT` VARCHAR(50),
  `SURFACE` VARCHAR(50),
  `BEST_OF_SET` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PLAYER` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `SEXE` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MATCHES` (
  `ID` INT NOT NULL,
  `P1_SETS` INT,
  `P1_SET1` INT,
  `P1_SET2` INT,
  `P1_SET3` INT,
  `P1_SET4` INT,
  `P1_SET5` INT,
  `P2_SETS` INT,
  `P2_SET1` INT,
  `P2_SET2` INT,
  `P2_SET3` INT,
  `P2_SET4` INT,
  `P2_SET5` INT,
  `ROUND` VARCHAR(50),
  `STATE` VARCHAR(50),
  `COMMENT` VARCHAR(50),
  `WINNER` INT,
  `LOSER` INT,
  `PLAYER1_ID` INT,
  `PLAYER2_ID` INT,
  `TOURNAMENT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070832_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070832_create') AS relationships;
DROP DATABASE `db_070832_create`;
UNINSTALL EXTENSION vsql_schematron;
