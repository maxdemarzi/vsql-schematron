INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383074_migration
--echo #
CREATE DATABASE `db_383074_migration`;
USE `db_383074_migration`;
CREATE TABLE `Deck` (
  `id` VARCHAR(50) NOT NULL,
  `authorId` VARCHAR(50),
  `title` TEXT,
  `description` TEXT,
  `visibility` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Card` (
  `id` VARCHAR(50) NOT NULL,
  `position` INT,
  `frontText` TEXT,
  `backText` TEXT,
  `deckId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `check` VARCHAR(50),
  `active` BOOLEAN,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `RevokedTokens` (
  `jti` VARCHAR(50) NOT NULL,
  `exp` INT,
  PRIMARY KEY (`jti`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383074_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383074_migration') AS relationships;
DROP DATABASE `db_383074_migration`;
UNINSTALL EXTENSION vsql_schematron;
