INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178019_38
--echo #
CREATE DATABASE `db_178019_38`;
USE `db_178019_38`;
CREATE TABLE `PUBLISHER` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER_PERMISSION` (
  `PUBLISHER_ID` VARCHAR(50),
  `USERCODE` VARCHAR(50),
  `ROLE` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178019_38') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178019_38') AS relationships;
DROP DATABASE `db_178019_38`;
UNINSTALL EXTENSION vsql_schematron;
