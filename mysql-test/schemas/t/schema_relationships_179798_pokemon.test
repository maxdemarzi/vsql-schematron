INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 179798_pokemon
--echo #
CREATE DATABASE `db_179798_pokemon`;
USE `db_179798_pokemon`;
CREATE TABLE `A_TRAINER` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `NUM_BADGES` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `A_POKEMON` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `TRAINER` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_179798_pokemon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_179798_pokemon') AS relationships;
DROP DATABASE `db_179798_pokemon`;
UNINSTALL EXTENSION vsql_schematron;
