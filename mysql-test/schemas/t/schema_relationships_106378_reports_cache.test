INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106378_reports_cache
--echo #
CREATE DATABASE `db_106378_reports_cache`;
USE `db_106378_reports_cache`;
CREATE TABLE `cache_state` (
  `param_string` VARCHAR(50) NOT NULL,
  `last_update` DATETIME,
  PRIMARY KEY (`param_string`)
) CHARACTER SET latin1;
CREATE TABLE `invalid_sublibraries` (
  `param_string` VARCHAR(50),
  `Z30_SUB_LIBRARY` VARCHAR(50),
  `C` INT
) CHARACTER SET latin1;
CREATE TABLE `items_per_collection` (
  `param_string` VARCHAR(50),
  `Z30_COLLECTION` VARCHAR(50),
  `C` INT
) CHARACTER SET latin1;
CREATE TABLE `registrars_list` (
  `param_string` VARCHAR(50),
  `Z303_HOME_LIBRARY` VARCHAR(50),
  `Z305_EXPIRY_DATE` VARCHAR(50),
  `Z303_NAME` VARCHAR(50),
  `AMOUNT` VARCHAR(50),
  `BARCODE` VARCHAR(50),
  `INST_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `small_old_fines` (
  `param_string` VARCHAR(50),
  `Z303_REC_KEY` VARCHAR(50),
  `Z303_NAME` VARCHAR(50),
  `Z303_HOME_LIBRARY` VARCHAR(50),
  `AMOUNT` VARCHAR(50),
  `BARCODE` VARCHAR(50),
  `INST_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `spent_ytd_list` (
  `param_string` VARCHAR(50),
  `BUDGET_NUMBER` VARCHAR(50),
  `Z76_NAME` VARCHAR(50),
  `LOCALSUM` VARCHAR(50),
  `ORDER_NUMBER` VARCHAR(50),
  `Z68_ORDERING_UNIT` VARCHAR(50),
  `VENDOR_CODE` VARCHAR(50),
  `Z68_ORDER_TYPE` CHAR(50),
  `Z68_MATERIAL_TYPE` VARCHAR(50),
  `UNITS_ORDERED` VARCHAR(50),
  `UNITS_INVOICED` VARCHAR(50),
  `UNITS_ARRIVED` VARCHAR(50),
  `OBJECT_CODE` VARCHAR(50),
  `Z77_P_DATE` CHAR(50),
  `ADM_NUMBER` CHAR(50),
  `BIB_NUMBER` CHAR(50),
  `Z13_AUTHOR` VARCHAR(50),
  `Z13_TITLE` VARCHAR(50),
  `Z13_IMPRINT` VARCHAR(50),
  `Z13_ISBN_ISSN` VARCHAR(50),
  `Z13_CALL_NO` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `spent_ytd_summary` (
  `param_string` VARCHAR(50),
  `BUDGET_NUMBER` VARCHAR(50),
  `BUDGET` VARCHAR(50),
  `ALLOCATED` VARCHAR(50),
  `MAX_OVER_SPEND` VARCHAR(50),
  `SPENT` VARCHAR(50),
  `PERCENT_SPENT` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106378_reports_cache') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106378_reports_cache') AS relationships;
DROP DATABASE `db_106378_reports_cache`;
UNINSTALL EXTENSION vsql_schematron;
