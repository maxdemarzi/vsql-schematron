INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411202_03persist_ui_auth
--echo #
CREATE DATABASE `db_411202_03persist_ui_auth`;
USE `db_411202_03persist_ui_auth`;
CREATE TABLE `ui_auth_sessions` (
  `session_id` TEXT,
  `creation_time` BIGINT,
  `serverdict` TEXT,
  `clientdict` TEXT,
  `uri` TEXT,
  `method` TEXT,
  `description` TEXT
) CHARACTER SET latin1;
CREATE TABLE `ui_auth_sessions_credentials` (
  `session_id` TEXT,
  `stage_type` TEXT,
  `result` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411202_03persist_ui_auth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411202_03persist_ui_auth') AS relationships;
DROP DATABASE `db_411202_03persist_ui_auth`;
UNINSTALL EXTENSION vsql_schematron;
