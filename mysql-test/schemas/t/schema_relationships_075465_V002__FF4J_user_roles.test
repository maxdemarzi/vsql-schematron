INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 075465_V002__FF4J_user_roles
--echo #
CREATE DATABASE `db_075465_V002__FF4J_user_roles`;
USE `db_075465_V002__FF4J_user_roles`;
CREATE TABLE `USERS` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `username` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_075465_V002__FF4J_user_roles') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_075465_V002__FF4J_user_roles') AS relationships;
DROP DATABASE `db_075465_V002__FF4J_user_roles`;
UNINSTALL EXTENSION vsql_schematron;
