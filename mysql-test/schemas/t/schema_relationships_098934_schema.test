INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098934_schema
--echo #
CREATE DATABASE `db_098934_schema`;
USE `db_098934_schema`;
CREATE TABLE `status` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task_type` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
  `id` INT NOT NULL,
  `profile_email` VARCHAR(50),
  `profile_name` VARCHAR(50),
  `profile_location` VARCHAR(50),
  `positive_points` INT,
  `negative_points` INT,
  `first_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
  `id` INT NOT NULL,
  `task_text` VARCHAR(50),
  `task_type_id` INT,
  `person_1_id` INT,
  `person_2_id` INT,
  `location_start` VARCHAR(50),
  `location_end` VARCHAR(50),
  `status_id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098934_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098934_schema') AS relationships;
DROP DATABASE `db_098934_schema`;
UNINSTALL EXTENSION vsql_schematron;
