INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 268124_up
--echo #
CREATE DATABASE `db_268124_up`;
USE `db_268124_up`;
CREATE TABLE `parts` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `pn` VARCHAR(50),
  `mpn` VARCHAR(50),
  `digikeypn` VARCHAR(50),
  `descr` VARCHAR(50),
  `ver` INT,
  `val` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inventories` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `quantity` INT,
  `consumed` INT,
  `unit_price` DOUBLE,
  `notes` TEXT,
  `part_ver` INT,
  `part_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `builds` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `estimated_completion` TIMESTAMP NULL,
  `quantity` INT,
  `cost` DOUBLE,
  `complete` INT,
  `notes` TEXT,
  `part_ver` INT,
  `part_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parts_parts` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `quantity` INT,
  `bom_ver` INT,
  `refdes` VARCHAR(50),
  `nostuff` INT,
  `bom_part_id` INT,
  `part_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_268124_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_268124_up') AS relationships;
DROP DATABASE `db_268124_up`;
UNINSTALL EXTENSION vsql_schematron;
