INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103102_0002_create_annotations_tables
--echo #
CREATE DATABASE `db_103102_0002_create_annotations_tables`;
USE `db_103102_0002_create_annotations_tables`;
CREATE TABLE `streams` (
  `id` VARCHAR(50) NOT NULL,
  `org_id` VARCHAR(50),
  `name` TEXT,
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `annotations` (
  `id` VARCHAR(50) NOT NULL,
  `org_id` VARCHAR(50),
  `stream_id` VARCHAR(50),
  `summary` TEXT,
  `message` TEXT,
  `stickers` TEXT,
  `duration` TEXT,
  `lower` TIMESTAMP NULL,
  `upper` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103102_0002_create_annotations_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103102_0002_create_annotations_tables') AS relationships;
DROP DATABASE `db_103102_0002_create_annotations_tables`;
UNINSTALL EXTENSION vsql_schematron;
