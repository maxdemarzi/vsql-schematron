INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 526306_20210419132738_initial
--echo #
CREATE DATABASE `db_526306_20210419132738_initial`;
USE `db_526306_20210419132738_initial`;
CREATE TABLE `banners` (
  `id` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `deleted` BOOLEAN,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `slots` (
  `id` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `deleted` BOOLEAN,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `deleted` BOOLEAN,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rotations` (
  `id` VARCHAR(50) NOT NULL,
  `banner_id` VARCHAR(50),
  `slot_id` VARCHAR(50),
  `group_id` VARCHAR(50),
  `shows` INT,
  `clicks` INT,
  `deleted` BOOLEAN,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
  `id` VARCHAR(50) NOT NULL,
  `rotation_id` VARCHAR(50),
  `stamp` TIMESTAMP NULL,
  `event_type` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_526306_20210419132738_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_526306_20210419132738_initial') AS relationships;
DROP DATABASE `db_526306_20210419132738_initial`;
UNINSTALL EXTENSION vsql_schematron;
