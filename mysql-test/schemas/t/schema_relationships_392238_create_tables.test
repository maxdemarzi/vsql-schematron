INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 392238_create_tables
--echo #
CREATE DATABASE `db_392238_create_tables`;
USE `db_392238_create_tables`;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `name` TEXT,
  `website` TEXT,
  `lat` DECIMAL(10,2),
  `long` DECIMAL(10,2),
  `primary_poc` TEXT,
  `sales_rep_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `account_id` INT,
  `occurred_at` TIMESTAMP NULL,
  `standard_qty` INT,
  `gloss_qty` INT,
  `poster_qty` INT,
  `total` INT,
  `standard_amt_usd` DECIMAL(10,2),
  `gloss_amt_usd` DECIMAL(10,2),
  `poster_amt_usd` DECIMAL(10,2),
  `total_amt_usd` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sales_reps` (
  `id` INT NOT NULL,
  `name` TEXT,
  `region_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `web_events` (
  `id` INT NOT NULL,
  `account_id` INT,
  `occurred_at` TIMESTAMP NULL,
  `channel` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_392238_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_392238_create_tables') AS relationships;
DROP DATABASE `db_392238_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
