INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 365806_create_tables
--echo #
CREATE DATABASE `db_365806_create_tables`;
USE `db_365806_create_tables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `nick` VARCHAR(50),
  `premmision` CHAR(50),
  `pas_hash` CHAR(50),
  `registration` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `info` (
  `user_id` INT,
  `data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(50),
  `text` TEXT,
  `image` VARCHAR(50),
  `time` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_365806_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_365806_create_tables') AS relationships;
DROP DATABASE `db_365806_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
