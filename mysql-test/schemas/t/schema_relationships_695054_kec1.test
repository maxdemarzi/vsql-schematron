INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 695054_kec1
--echo #
CREATE DATABASE `db_695054_kec1`;
USE `db_695054_kec1`;
CREATE TABLE `admin_security_details` (
  `Aemail` VARCHAR(50),
  `AOTP` INT,
  `Averification` INT,
  `AOTPdate` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `grievancesdetails` (
  `Uemail` VARCHAR(50),
  `s_id` INT,
  `type` VARCHAR(50),
  `Gid` VARCHAR(50),
  `comments` VARCHAR(50),
  `Category` VARCHAR(50),
  `Scategory` VARCHAR(50),
  `GpostDate` DATE,
  `Gsolution` VARCHAR(50),
  `GclosedDate` DATE,
  `Gstatus` INT
) CHARACTER SET latin1;
CREATE TABLE `headdetalis` (
  `Authorisedpt` VARCHAR(50),
  `Aid` VARCHAR(50),
  `Aname` VARCHAR(50),
  `Amobile` VARCHAR(50),
  `Aemail` VARCHAR(50) NOT NULL,
  `Apassword` VARCHAR(50),
  PRIMARY KEY (`Aemail`)
) CHARACTER SET latin1;
CREATE TABLE `userotp` (
  `Uemail` VARCHAR(50),
  `UOTP` VARCHAR(50),
  `Uverification` INT,
  `UOTPdate` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `userverification` (
  `Usid` VARCHAR(50),
  `U_name` VARCHAR(50),
  `User` VARCHAR(50),
  `Umobile` VARCHAR(50),
  `Uemail` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Uemail`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_695054_kec1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_695054_kec1') AS relationships;
DROP DATABASE `db_695054_kec1`;
UNINSTALL EXTENSION vsql_schematron;
