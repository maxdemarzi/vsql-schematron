INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186232_migration-036-037
--echo #
CREATE DATABASE `db_186232_migration_036_037`;
USE `db_186232_migration_036_037`;
CREATE TABLE `DATA_STORE_SERVICES` (
  `ID` VARCHAR(50) NOT NULL,
  `LABEL` VARCHAR(50),
  `KIND` VARCHAR(50),
  `DATA_STORE_ID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DATA_STORE_SERVICE_DATA_SET_TYPES` (
  `DATA_STORE_SERVICE_ID` VARCHAR(50),
  `DATA_SET_TYPE_ID` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186232_migration_036_037') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186232_migration_036_037') AS relationships;
DROP DATABASE `db_186232_migration_036_037`;
UNINSTALL EXTENSION vsql_schematron;
