INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 422130_accounts
--echo #
CREATE DATABASE `db_422130_accounts`;
USE `db_422130_accounts`;
CREATE TABLE `Users` (
  `userid` VARCHAR(50) NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `birthdate` DATE,
  `locationstreet` VARCHAR(50),
  `locationcity` VARCHAR(50),
  `locationstate` CHAR(50),
  `locationzip` INT,
  `tier` INT,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `Permissions` (
  `userid` CHAR(50),
  `permissions` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_422130_accounts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_422130_accounts') AS relationships;
DROP DATABASE `db_422130_accounts`;
UNINSTALL EXTENSION vsql_schematron;
