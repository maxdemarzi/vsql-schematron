INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165598_V1__Database_structure
--echo #
CREATE DATABASE `db_165598_V1__Database_structure`;
USE `db_165598_V1__Database_structure`;
CREATE TABLE `manufacturer` (
  `id` INT,
  `name` VARCHAR(50),
  `updated` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `car` (
  `id` INT NOT NULL,
  `model` VARCHAR(50),
  `manufacturer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165598_V1__Database_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165598_V1__Database_structure') AS relationships;
DROP DATABASE `db_165598_V1__Database_structure`;
UNINSTALL EXTENSION vsql_schematron;
