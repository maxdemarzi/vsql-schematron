INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004783_migration
--echo #
CREATE DATABASE `db_004783_migration`;
USE `db_004783_migration`;
CREATE TABLE `account` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `is_admin` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `event_id` INT NOT NULL,
  `website_id` INT,
  `session_id` INT,
  `created_at` TIMESTAMP NULL,
  `url` VARCHAR(50),
  `event_type` VARCHAR(50),
  `event_value` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `pageview` (
  `view_id` INT NOT NULL,
  `website_id` INT,
  `session_id` INT,
  `created_at` TIMESTAMP NULL,
  `url` VARCHAR(50),
  `referrer` VARCHAR(50),
  PRIMARY KEY (`view_id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `session_id` INT NOT NULL,
  `session_uuid` VARCHAR(50),
  `website_id` INT,
  `created_at` TIMESTAMP NULL,
  `hostname` VARCHAR(50),
  `browser` VARCHAR(50),
  `os` VARCHAR(50),
  `device` VARCHAR(50),
  `screen` VARCHAR(50),
  `language` VARCHAR(50),
  `country` CHAR(50),
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `website` (
  `website_id` INT NOT NULL,
  `website_uuid` VARCHAR(50),
  `user_id` INT,
  `name` VARCHAR(50),
  `domain` VARCHAR(50),
  `share_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`website_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004783_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004783_migration') AS relationships;
DROP DATABASE `db_004783_migration`;
UNINSTALL EXTENSION vsql_schematron;
