INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 628419_20210410.up
--echo #
CREATE DATABASE `db_628419_20210410_up`;
USE `db_628419_20210410_up`;
CREATE TABLE `projects` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `title` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `closed` TIMESTAMP NULL,
  `title` TEXT,
  `body` TEXT,
  `state` TEXT,
  `metadata` TEXT,
  `project_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `body` TEXT,
  `issue_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_628419_20210410_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_628419_20210410_up') AS relationships;
DROP DATABASE `db_628419_20210410_up`;
UNINSTALL EXTENSION vsql_schematron;
