INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363019_001-db
--echo #
CREATE DATABASE `db_363019_001_db`;
USE `db_363019_001_db`;
CREATE TABLE `Province` (
  `id` VARCHAR(50) NOT NULL,
  `nameEn` TEXT,
  `nameFr` TEXT,
  `sourceLink` TEXT,
  `sourceEn` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Holiday` (
  `id` INT NOT NULL,
  `date` TEXT,
  `nameEn` TEXT,
  `nameFr` TEXT,
  `federal` BOOLEAN,
  `firstOccurence` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProvinceHoliday` (
  `id` INT NOT NULL,
  `provinceId` CHAR(50),
  `holidayId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363019_001_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363019_001_db') AS relationships;
DROP DATABASE `db_363019_001_db`;
UNINSTALL EXTENSION vsql_schematron;
