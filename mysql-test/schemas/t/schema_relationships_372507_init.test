INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 372507_init
--echo #
CREATE DATABASE `db_372507_init`;
USE `db_372507_init`;
CREATE TABLE `Restos` (
  `id` INT NOT NULL,
  `rname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tables` (
  `id` INT NOT NULL,
  `resto_id` INT,
  `max_people` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Bookings` (
  `id` INT NOT NULL,
  `resto_id` INT,
  `table_id` INT,
  `client_name` VARCHAR(50),
  `client_id` VARCHAR(50),
  `bdate` VARCHAR(50),
  `btime` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_372507_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_372507_init') AS relationships;
DROP DATABASE `db_372507_init`;
UNINSTALL EXTENSION vsql_schematron;
