INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 237660_scripts
--echo #
CREATE DATABASE `db_237660_scripts`;
USE `db_237660_scripts`;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `date_of_joining` TIMESTAMP NULL,
  `designation` VARCHAR(50),
  `gender` VARCHAR(50),
  `email` VARCHAR(50),
  `bio` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_assignment` (
  `id` INT NOT NULL,
  `employee_id` INT,
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_237660_scripts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_237660_scripts') AS relationships;
DROP DATABASE `db_237660_scripts`;
UNINSTALL EXTENSION vsql_schematron;
