INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 422315_v.201511152254__schema
--echo #
CREATE DATABASE `db_422315_v_201511152254__schema`;
USE `db_422315_v_201511152254__schema`;
CREATE TABLE `comment` (
  `id` BIGINT NOT NULL,
  `content` VARCHAR(50),
  `at` DATETIME,
  `post_id` BIGINT,
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` BIGINT NOT NULL,
  `body` VARCHAR(50),
  `subject` VARCHAR(50),
  `at` DATETIME,
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tags` (
  `post_id` BIGINT,
  `tags` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_422315_v_201511152254__schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_422315_v_201511152254__schema') AS relationships;
DROP DATABASE `db_422315_v_201511152254__schema`;
UNINSTALL EXTENSION vsql_schematron;
