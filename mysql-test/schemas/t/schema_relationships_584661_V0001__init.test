INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 584661_V0001__init
--echo #
CREATE DATABASE `db_584661_V0001__init`;
USE `db_584661_V0001__init`;
CREATE TABLE `country` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `film` (
  `id` INT NOT NULL,
  `country_id` BIGINT,
  `title` VARCHAR(50),
  `genre` VARCHAR(50),
  `tags` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `actor` (
  `id` INT NOT NULL,
  `country_id` BIGINT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `birthday` DATE,
  `gender` VARCHAR(50),
  `tags` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `film_actor` (
  `film_id` BIGINT NOT NULL,
  `actor_id` BIGINT NOT NULL,
  PRIMARY KEY (`film_id`, `actor_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_584661_V0001__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_584661_V0001__init') AS relationships;
DROP DATABASE `db_584661_V0001__init`;
UNINSTALL EXTENSION vsql_schematron;
