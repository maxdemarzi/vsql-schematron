INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 255980_create-db
--echo #
CREATE DATABASE `db_255980_create_db`;
USE `db_255980_create_db`;
CREATE TABLE `Item` (
  `id` INT NOT NULL,
  `sku` TEXT,
  `name` VARCHAR(50),
  `price` DOUBLE,
  `category` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_255980_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_255980_create_db') AS relationships;
DROP DATABASE `db_255980_create_db`;
UNINSTALL EXTENSION vsql_schematron;
