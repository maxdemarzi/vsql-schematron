INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 229020_schema
--echo #
CREATE DATABASE `db_229020_schema`;
USE `db_229020_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kids` (
  `id` INT NOT NULL,
  `child_name` VARCHAR(50),
  `current_points` INT,
  `banked_points` INT,
  `users_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `task_name` VARCHAR(50),
  `task_points` INT,
  `kids_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_229020_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_229020_schema') AS relationships;
DROP DATABASE `db_229020_schema`;
UNINSTALL EXTENSION vsql_schematron;
