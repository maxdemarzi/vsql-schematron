INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 169415_create-test-db
--echo #
CREATE DATABASE `db_169415_create_test_db`;
USE `db_169415_create_test_db`;
CREATE TABLE `FOLDER` (
  `ID_FOLDER` INT NOT NULL,
  `NAME_FOLDER` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `CREATE_DATE` DATE,
  PRIMARY KEY (`ID_FOLDER`)
) CHARACTER SET latin1;
CREATE TABLE `TASK` (
  `ID_TASK` INT NOT NULL,
  `ID_FOLDER` INT,
  `NAME_TASK` VARCHAR(50),
  `PRIORITY` INT,
  `DESCRIPTION` VARCHAR(50),
  `START_DATE` DATE,
  `DUE_DATE` DATE,
  `CREATE_DATE` DATE,
  `DONE_MARK` BOOLEAN,
  `DONE_DATE` DATE,
  PRIMARY KEY (`ID_TASK`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_169415_create_test_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169415_create_test_db') AS relationships;
DROP DATABASE `db_169415_create_test_db`;
UNINSTALL EXTENSION vsql_schematron;
