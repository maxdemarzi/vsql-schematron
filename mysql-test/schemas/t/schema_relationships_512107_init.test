INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512107_init
--echo #
CREATE DATABASE `db_512107_init`;
USE `db_512107_init`;
CREATE TABLE `REQUEST` (
  `ID` INT NOT NULL,
  `TIMESTAMP` INT,
  `APP` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SCHEDULES` (
  `REQUEST_ID` INT,
  `TIMESTAMP` INT,
  `VOTES` INT,
  `PRIORITY` INT,
  `APP` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512107_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512107_init') AS relationships;
DROP DATABASE `db_512107_init`;
UNINSTALL EXTENSION vsql_schematron;
