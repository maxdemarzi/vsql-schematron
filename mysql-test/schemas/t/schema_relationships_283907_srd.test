INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 283907_srd
--echo #
CREATE DATABASE `db_283907_srd`;
USE `db_283907_srd`;
CREATE TABLE `languages` (
  `languages_id` INT NOT NULL,
  `name` VARCHAR(50),
  `number` DOUBLE,
  `repository_id` INT,
  PRIMARY KEY (`languages_id`)
) CHARACTER SET latin1;
CREATE TABLE `repository` (
  `repository_id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `description` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`repository_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `name` VARCHAR(50),
  `location` VARCHAR(50),
  `company` VARCHAR(50),
  `email` VARCHAR(50),
  `bio` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_283907_srd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_283907_srd') AS relationships;
DROP DATABASE `db_283907_srd`;
UNINSTALL EXTENSION vsql_schematron;
