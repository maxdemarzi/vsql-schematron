INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 431030_initdb
--echo #
CREATE DATABASE `db_431030_initdb`;
USE `db_431030_initdb`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_urls` (
  `id` VARCHAR(50),
  `url` TEXT,
  `code` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  `total_click` INT,
  `user_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_431030_initdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_431030_initdb') AS relationships;
DROP DATABASE `db_431030_initdb`;
UNINSTALL EXTENSION vsql_schematron;
