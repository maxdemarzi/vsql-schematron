INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 241961_G7
--echo #
CREATE DATABASE `db_241961_G7`;
USE `db_241961_G7`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `usuario` VARCHAR(50),
  `contrasenia` VARCHAR(50),
  `email` VARCHAR(50),
  `estado` BOOLEAN,
  `codigo` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rol` (
  `id` TINYINT NOT NULL,
  `rol` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `empleado` (
  `legajo` TINYINT NOT NULL,
  `dni` INT,
  `fecha_nacimiento` DATETIME,
  `usuario_id` INT,
  `id_rol` TINYINT,
  PRIMARY KEY (`legajo`)
) CHARACTER SET latin1;
CREATE TABLE `administrador` (
  `id` TINYINT NOT NULL,
  `legajo` TINYINT,
  `id_rol` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `supervisor` (
  `id` TINYINT NOT NULL,
  `legajo` TINYINT,
  `id_rol` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chofer` (
  `id` TINYINT NOT NULL,
  `tipo_licencia` VARCHAR(50),
  `legajo` TINYINT,
  `id_rol` TINYINT,
  `patente` VARCHAR(50),
  `estado` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mecanico` (
  `id` TINYINT NOT NULL,
  `legajo` TINYINT,
  `id_rol` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `camiones` (
  `id` TINYINT NOT NULL,
  `patente` VARCHAR(50),
  `marca` VARCHAR(50),
  `modelo` VARCHAR(50),
  `nro_motor` INT,
  `nro_chasis` VARCHAR(50),
  `kilometraje` INT,
  `ultimo_service` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `arrastrador` (
  `id` TINYINT NOT NULL,
  `nro_chasis` INT,
  `tipo` VARCHAR(50),
  `patente` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `viaje` (
  `id` TINYINT NOT NULL,
  `origen` VARCHAR(50),
  `destino` VARCHAR(50),
  `fecha_carga` DATETIME,
  `estado` VARCHAR(50),
  `id_supervisor` TINYINT,
  `fecha_llegada_previsto` DATETIME,
  `fecha_llegada_real` DATETIME,
  `fecha_salida_previsto` DATETIME,
  `fecha_salida_real` DATETIME,
  `combustible_previsto` INT,
  `combustible_real` INT,
  `kilometros_real` INT,
  `kilometros_previsto` INT,
  `importe_combustible_real` INT,
  `importe_combustible_previsto` INT,
  `peajes_previsto` INT,
  `peajes_real` INT,
  `pesajes_previsto` INT,
  `pesajes_real` INT,
  `viaticos_previsto` INT,
  `viaticos_real` INT,
  `extras_previsto` INT,
  `extras_real` INT,
  `fee_previsto` INT,
  `fee_real` INT,
  `hazard_precio` INT,
  `reefer_precio` INT,
  `gasto_total` INT,
  `id_chofer` TINYINT,
  `id_camion` TINYINT,
  `id_arrastrador` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `costeo` (
  `id` TINYINT NOT NULL,
  `id_viaje` TINYINT,
  `km` INT,
  `litros` INT,
  `importe` INT,
  `viatico` DOUBLE,
  `peaje` DOUBLE,
  `extras` DOUBLE,
  `latitud` DOUBLE,
  `longitud` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `carga` (
  `id` TINYINT NOT NULL,
  `tipo_carga` VARCHAR(50),
  `hazard` BOOLEAN,
  `imo_class` VARCHAR(50),
  `reefer` BOOLEAN,
  `temperatura` INT,
  `peso_neto` VARCHAR(50),
  `id_viaje` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cliente` (
  `id` TINYINT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `telefono` INT,
  `cuit` BIGINT,
  `direccion` VARCHAR(50),
  `email` VARCHAR(50),
  `id_viaje` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mantenimiento` (
  `id` TINYINT NOT NULL,
  `fecha` DATETIME,
  `costo` INT,
  `tipo` VARCHAR(50),
  `repuesto_cam` VARCHAR(50),
  `id_camion` TINYINT,
  `id_mecanico` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_241961_G7') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_241961_G7') AS relationships;
DROP DATABASE `db_241961_G7`;
UNINSTALL EXTENSION vsql_schematron;
