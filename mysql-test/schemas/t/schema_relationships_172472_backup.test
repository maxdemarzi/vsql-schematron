INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172472_backup
--echo #
CREATE DATABASE `db_172472_backup`;
USE `db_172472_backup`;
CREATE TABLE `Ban_Users` (
  `username` VARCHAR(50),
  `ban_times` INT,
  `started_at` DATETIME,
  `finished_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `salt` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172472_backup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172472_backup') AS relationships;
DROP DATABASE `db_172472_backup`;
UNINSTALL EXTENSION vsql_schematron;
