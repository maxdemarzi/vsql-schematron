INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 538904_database
--echo #
CREATE DATABASE `db_538904_database`;
USE `db_538904_database`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `category_id` INT,
  `user_id` INT,
  `name` TEXT,
  `description` TEXT,
  `old_price` INT,
  `price` INT,
  `quantity` INT,
  `status` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `name` TEXT,
  `path` TEXT,
  `product_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_538904_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_538904_database') AS relationships;
DROP DATABASE `db_538904_database`;
UNINSTALL EXTENSION vsql_schematron;
