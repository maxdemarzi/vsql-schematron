INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053574_005-SENTRY-398.derby
--echo #
CREATE DATABASE `db_053574_005_SENTRY_398_derby`;
USE `db_053574_005_SENTRY_398_derby`;
CREATE TABLE `SENTRY_GM_PRIVILEGE` (
  `GM_PRIVILEGE_ID` BIGINT NOT NULL,
  `ACTION` VARCHAR(50),
  `COMPONENT_NAME` VARCHAR(50),
  `CREATE_TIME` BIGINT,
  `WITH_GRANT_OPTION` CHAR(50),
  `RESOURCE_NAME_0` VARCHAR(50),
  `RESOURCE_NAME_1` VARCHAR(50),
  `RESOURCE_NAME_2` VARCHAR(50),
  `RESOURCE_NAME_3` VARCHAR(50),
  `RESOURCE_TYPE_0` VARCHAR(50),
  `RESOURCE_TYPE_1` VARCHAR(50),
  `RESOURCE_TYPE_2` VARCHAR(50),
  `RESOURCE_TYPE_3` VARCHAR(50),
  `SCOPE` VARCHAR(50),
  `SERVICE_NAME` VARCHAR(50),
  PRIMARY KEY (`GM_PRIVILEGE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SENTRY_ROLE_GM_PRIVILEGE_MAP` (
  `ROLE_ID` BIGINT NOT NULL,
  `GM_PRIVILEGE_ID` BIGINT NOT NULL,
  PRIMARY KEY (`ROLE_ID`, `GM_PRIVILEGE_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053574_005_SENTRY_398_derby') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053574_005_SENTRY_398_derby') AS relationships;
DROP DATABASE `db_053574_005_SENTRY_398_derby`;
UNINSTALL EXTENSION vsql_schematron;
