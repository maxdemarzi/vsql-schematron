INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 486410_DBI-Practical%20Class%20-Week10-Setup
--echo #
CREATE DATABASE `db_486410_DBI_Practical_20Class_20_Week10_Setup`;
USE `db_486410_DBI_Practical_20Class_20_Week10_Setup`;
CREATE TABLE `Sport` (
  `sportCode` DECIMAL(10,2) NOT NULL,
  `sportName` VARCHAR(50),
  PRIMARY KEY (`sportCode`)
) CHARACTER SET latin1;
CREATE TABLE `Competitor` (
  `compID` DECIMAL(10,2) NOT NULL,
  `compName` VARCHAR(50),
  `compDOB` DATE,
  PRIMARY KEY (`compID`)
) CHARACTER SET latin1;
CREATE TABLE `EventResult` (
  `eventID` DECIMAL(10,2) NOT NULL,
  `compID` DECIMAL(10,2) NOT NULL,
  `Position` DECIMAL(10,2),
  PRIMARY KEY (`eventID`, `compID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_486410_DBI_Practical_20Class_20_Week10_Setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_486410_DBI_Practical_20Class_20_Week10_Setup') AS relationships;
DROP DATABASE `db_486410_DBI_Practical_20Class_20_Week10_Setup`;
UNINSTALL EXTENSION vsql_schematron;
