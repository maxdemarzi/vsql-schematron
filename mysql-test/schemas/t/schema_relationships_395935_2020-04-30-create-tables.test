INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395935_2020-04-30-create-tables
--echo #
CREATE DATABASE `db_395935_2020_04_30_create_tables`;
USE `db_395935_2020_04_30_create_tables`;
CREATE TABLE `shows` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `start_year` INT,
  `rating` DECIMAL(10,2),
  `num_votes` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `episodes` (
  `id` VARCHAR(50) NOT NULL,
  `show_id` TEXT,
  `season_number` INT,
  `episode_number` INT,
  `rating` DECIMAL(10,2),
  `num_votes` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395935_2020_04_30_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395935_2020_04_30_create_tables') AS relationships;
DROP DATABASE `db_395935_2020_04_30_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
