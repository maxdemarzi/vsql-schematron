INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037198_tables
--echo #
CREATE DATABASE `db_037198_tables`;
USE `db_037198_tables`;
CREATE TABLE `node_tree` (
  `idNode` INT NOT NULL,
  `level` INT,
  `iLeft` INT,
  `iRight` INT,
  PRIMARY KEY (`idNode`)
) CHARACTER SET latin1;
CREATE TABLE `node_tree_names` (
  `idNode` INT,
  `language` TEXT,
  `nodeName` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037198_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037198_tables') AS relationships;
DROP DATABASE `db_037198_tables`;
UNINSTALL EXTENSION vsql_schematron;
