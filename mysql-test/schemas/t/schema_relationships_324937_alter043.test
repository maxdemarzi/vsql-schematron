INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 324937_alter043
--echo #
CREATE DATABASE `db_324937_alter043`;
USE `db_324937_alter043`;
CREATE TABLE `테이블1` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `테이블2` (
  `테이블1` CHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_324937_alter043') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_324937_alter043') AS relationships;
DROP DATABASE `db_324937_alter043`;
UNINSTALL EXTENSION vsql_schematron;
