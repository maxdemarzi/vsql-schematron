INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606284_schema
--echo #
CREATE DATABASE `db_606284_schema`;
USE `db_606284_schema`;
CREATE TABLE `chart` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `theme` VARCHAR(50),
  `created_at` DATETIME,
  `last_modified_at` DATETIME,
  `type` VARCHAR(50),
  `metadata` VARCHAR(50),
  `deleted` TINYINT,
  `deleted_at` DATETIME,
  `author_id` INT,
  `show_in_gallery` TINYINT,
  `language` VARCHAR(50),
  `guest_session` VARCHAR(50),
  `last_edit_step` INT,
  `published_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `pwd` VARCHAR(50),
  `activate_token` VARCHAR(50),
  `reset_password_token` VARCHAR(50),
  `role` TINYINT,
  `deleted` TINYINT,
  `language` VARCHAR(50),
  `created_at` DATETIME,
  `name` VARCHAR(50),
  `website` VARCHAR(50),
  `sm_profile` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
  `id` INT NOT NULL,
  `user_id` INT,
  `action_time` DATETIME,
  `key` VARCHAR(50),
  `details` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stats` (
  `id` INT NOT NULL,
  `time` DATETIME,
  `metric` VARCHAR(50),
  `value` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606284_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606284_schema') AS relationships;
DROP DATABASE `db_606284_schema`;
UNINSTALL EXTENSION vsql_schematron;
