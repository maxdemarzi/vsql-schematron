INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 349062_V1_permissions
--echo #
CREATE DATABASE `db_349062_V1_permissions`;
USE `db_349062_V1_permissions`;
CREATE TABLE `sec.permission` (
  `name` CHAR(50),
  `code` VARCHAR(50) NOT NULL,
  `parent_code` CHAR(50),
  `system_code` CHAR(50),
  `user_level` CHAR(50),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `sec.role_permission` (
  `role_id` INT NOT NULL,
  `permission_code` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`role_id`, `permission_code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_349062_V1_permissions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_349062_V1_permissions') AS relationships;
DROP DATABASE `db_349062_V1_permissions`;
UNINSTALL EXTENSION vsql_schematron;
