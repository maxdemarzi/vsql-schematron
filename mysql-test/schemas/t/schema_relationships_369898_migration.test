INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 369898_migration
--echo #
CREATE DATABASE `db_369898_migration`;
USE `db_369898_migration`;
CREATE TABLE `Hormones` (
  `id` VARCHAR(50) NOT NULL,
  `kind` VARCHAR(50),
  `pictureUrl` TEXT,
  `halfLife` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HormoneTrans` (
  `id` VARCHAR(50) NOT NULL,
  `locale` TEXT,
  `hormonesId` TEXT,
  `title` TEXT,
  `description` TEXT,
  `doses` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_369898_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_369898_migration') AS relationships;
DROP DATABASE `db_369898_migration`;
UNINSTALL EXTENSION vsql_schematron;
