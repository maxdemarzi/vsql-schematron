INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620142_entrega_sql_zona_azul
--echo #
CREATE DATABASE `db_620142_entrega_sql_zona_azul`;
USE `db_620142_entrega_sql_zona_azul`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `id_card` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone_number` VARCHAR(50),
  `account_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicles` (
  `id` VARCHAR(50) NOT NULL,
  `plate_number` VARCHAR(50),
  `model` VARCHAR(50),
  `mark` VARCHAR(50),
  `type` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parks` (
  `id` VARCHAR(50) NOT NULL,
  `initial_time` DATETIME,
  `finish_time` DATETIME,
  `vehicle_id` VARCHAR(50),
  `zone_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zones` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `initial_time` DATETIME,
  `finish_time` DATETIME,
  `limit_time` VARCHAR(50),
  `prize_minute` VARCHAR(50),
  `comments` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fines` (
  `id` VARCHAR(50) NOT NULL,
  `ammount` VARCHAR(50),
  `status` BOOLEAN,
  `park_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `claims` (
  `id` VARCHAR(50) NOT NULL,
  `date` DATE,
  `comments` VARCHAR(50),
  `reason` VARCHAR(50),
  `status` BOOLEAN,
  `fine_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620142_entrega_sql_zona_azul') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620142_entrega_sql_zona_azul') AS relationships;
DROP DATABASE `db_620142_entrega_sql_zona_azul`;
UNINSTALL EXTENSION vsql_schematron;
