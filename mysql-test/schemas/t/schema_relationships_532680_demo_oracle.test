INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532680_demo_oracle
--echo #
CREATE DATABASE `db_532680_demo_oracle`;
USE `db_532680_demo_oracle`;
CREATE TABLE `EXP_FRIEND` (
  `FRIENDID` DECIMAL(10,2) NOT NULL,
  `FRIENDNAME` VARCHAR(50),
  `PHONE` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  PRIMARY KEY (`FRIENDID`)
) CHARACTER SET latin1;
CREATE TABLE `EXP_UF_RELATION` (
  `USERID` DECIMAL(10,2) NOT NULL,
  `FRIENDID` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`USERID`, `FRIENDID`)
) CHARACTER SET latin1;
CREATE TABLE `EXP_USER` (
  `USERID` DECIMAL(10,2) NOT NULL,
  `PASSWD` VARCHAR(50),
  `USERNAME` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `SEX` DECIMAL(10,2),
  `BIRTHDAY` DATE,
  PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532680_demo_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532680_demo_oracle') AS relationships;
DROP DATABASE `db_532680_demo_oracle`;
UNINSTALL EXTENSION vsql_schematron;
