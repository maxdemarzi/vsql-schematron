INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 055539_dbrest
--echo #
CREATE DATABASE `db_055539_dbrest`;
USE `db_055539_dbrest`;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_055539_dbrest') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_055539_dbrest') AS relationships;
DROP DATABASE `db_055539_dbrest`;
UNINSTALL EXTENSION vsql_schematron;
