INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 550221_setup
--echo #
CREATE DATABASE `db_550221_setup`;
USE `db_550221_setup`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `foreignId` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `happyHours` (
  `id` INT NOT NULL,
  `venueId` TEXT,
  `date` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `confirmations` (
  `happyHourId` INT,
  `userId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_550221_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_550221_setup') AS relationships;
DROP DATABASE `db_550221_setup`;
UNINSTALL EXTENSION vsql_schematron;
