INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480693_up
--echo #
CREATE DATABASE `db_480693_up`;
USE `db_480693_up`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `name` TEXT,
  `screen_name` TEXT,
  `bcrypt_hash` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ssh_keys` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `key` TEXT,
  `user_id` INT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `user_id` INT,
  `name` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480693_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480693_up') AS relationships;
DROP DATABASE `db_480693_up`;
UNINSTALL EXTENSION vsql_schematron;
