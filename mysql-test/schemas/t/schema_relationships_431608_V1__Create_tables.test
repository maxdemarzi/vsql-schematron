INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 431608_V1__Create_tables
--echo #
CREATE DATABASE `db_431608_V1__Create_tables`;
USE `db_431608_V1__Create_tables`;
CREATE TABLE `USER` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `LOGIN` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `SALT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERMISSION` (
  `ID` DECIMAL(10,2) NOT NULL,
  `USER_ID` INT,
  `ROLE` VARCHAR(50),
  `RESOURCE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNTING` (
  `ID` DECIMAL(10,2) NOT NULL,
  `PERMISSION_ID` INT,
  `DATE_START` DATE,
  `DATE_END` DATE,
  `VOLUME` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_431608_V1__Create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_431608_V1__Create_tables') AS relationships;
DROP DATABASE `db_431608_V1__Create_tables`;
UNINSTALL EXTENSION vsql_schematron;
