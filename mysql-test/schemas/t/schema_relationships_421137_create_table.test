INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421137_create_table
--echo #
CREATE DATABASE `db_421137_create_table`;
USE `db_421137_create_table`;
CREATE TABLE `room` (
  `id` VARCHAR(50) NOT NULL,
  `max_player` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exp` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `exp` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room_player` (
  `user_id` VARCHAR(50),
  `room_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `game` (
  `id` VARCHAR(50) NOT NULL,
  `room_id` VARCHAR(50),
  `game_type` VARCHAR(50),
  `game_config` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_move` (
  `id` VARCHAR(50) NOT NULL,
  `game_id` VARCHAR(50),
  `move` VARCHAR(50),
  `state` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exp_snapshot` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `exp` INT,
  `last_exp_id` VARCHAR(50),
  `last_exp_created_at` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421137_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421137_create_table') AS relationships;
DROP DATABASE `db_421137_create_table`;
UNINSTALL EXTENSION vsql_schematron;
