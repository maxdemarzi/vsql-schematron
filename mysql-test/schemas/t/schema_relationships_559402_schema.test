INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 559402_schema
--echo #
CREATE DATABASE `db_559402_schema`;
USE `db_559402_schema`;
CREATE TABLE `policy` (
  `id` BIGINT NOT NULL,
  `kind` VARCHAR(50),
  `name` VARCHAR(50),
  `version` VARCHAR(50),
  `description` TEXT,
  `disabled` BOOLEAN,
  `definition` BLOB,
  `generated` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `policy_dependency` (
  `policy_id` BIGINT NOT NULL,
  `dependency_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`policy_id`, `dependency_id`)
) CHARACTER SET latin1;
CREATE TABLE `policy_revision` (
  `revision_id` INT NOT NULL,
  `action` VARCHAR(50),
  `id` BIGINT,
  `kind` VARCHAR(50),
  `name` VARCHAR(50),
  `version` VARCHAR(50),
  `description` TEXT,
  `disabled` BOOLEAN,
  `definition` BLOB,
  `update_timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`revision_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_559402_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_559402_schema') AS relationships;
DROP DATABASE `db_559402_schema`;
UNINSTALL EXTENSION vsql_schematron;
