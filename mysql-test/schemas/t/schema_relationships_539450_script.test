INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539450_script
--echo #
CREATE DATABASE `db_539450_script`;
USE `db_539450_script`;
CREATE TABLE `Categorias` (
  `CategoriaId` INT NOT NULL,
  `Nome` VARCHAR(50),
  PRIMARY KEY (`CategoriaId`)
) CHARACTER SET latin1;
CREATE TABLE `Produtos` (
  `ProdutoId` INT NOT NULL,
  `Nome` VARCHAR(50),
  `Quantidade` INT,
  `CategoriaId` INT,
  PRIMARY KEY (`ProdutoId`)
) CHARACTER SET latin1;
CREATE TABLE `Compras` (
  `CompraId` INT NOT NULL,
  `Mes` VARCHAR(50),
  `ProdutoId` INT,
  PRIMARY KEY (`CompraId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539450_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539450_script') AS relationships;
DROP DATABASE `db_539450_script`;
UNINSTALL EXTENSION vsql_schematron;
