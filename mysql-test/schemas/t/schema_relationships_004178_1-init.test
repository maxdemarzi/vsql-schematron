INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004178_1-init
--echo #
CREATE DATABASE `db_004178_1_init`;
USE `db_004178_1_init`;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `is_parent` BOOLEAN,
  `parent_id` INT,
  `is_deleted` BOOLEAN,
  `title` VARCHAR(50),
  `text` TEXT,
  `is_sage` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `post_id` INT,
  `name` VARCHAR(50),
  `ext` VARCHAR(50),
  `size` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004178_1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004178_1_init') AS relationships;
DROP DATABASE `db_004178_1_init`;
UNINSTALL EXTENSION vsql_schematron;
