INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659542_dovecot
--echo #
CREATE DATABASE `db_659542_dovecot`;
USE `db_659542_dovecot`;
CREATE TABLE `alias` (
  `id` INT NOT NULL,
  `domain_id` INT,
  `alias` VARCHAR(50),
  `target` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `domain` (
  `id` INT NOT NULL,
  `domain` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `domain_id` INT,
  `password` VARCHAR(50),
  `user` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659542_dovecot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659542_dovecot') AS relationships;
DROP DATABASE `db_659542_dovecot`;
UNINSTALL EXTENSION vsql_schematron;
