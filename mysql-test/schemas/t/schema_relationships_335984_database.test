INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335984_database
--echo #
CREATE DATABASE `db_335984_database`;
USE `db_335984_database`;
CREATE TABLE `seed` (
  `type` VARCHAR(50) NOT NULL,
  `value` BIGINT,
  PRIMARY KEY (`type`)
) CHARACTER SET latin1;
CREATE TABLE `minted` (
  `type` VARCHAR(50) NOT NULL,
  `value` VARCHAR(50) NOT NULL,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`type`, `value`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335984_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335984_database') AS relationships;
DROP DATABASE `db_335984_database`;
UNINSTALL EXTENSION vsql_schematron;
