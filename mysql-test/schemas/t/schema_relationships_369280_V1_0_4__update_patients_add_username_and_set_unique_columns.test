CREATE TABLE `credentials` (
  `ID` INT NOT NULL,
  `USERNAME` VARCHAR(50),
  `HASHED_PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `credential_roles` (
  `CREDENTIAL_ID` INT NOT NULL,
  `ROLE_ID` INT NOT NULL,
  PRIMARY KEY (`CREDENTIAL_ID`, `ROLE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `personnel` (
  `ID` INT NOT NULL,
  `PERSONAL_ID` VARCHAR(50),
  `NAME` VARCHAR(50),
  `PHONE` VARCHAR(50),
  `CREDENTIALS_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
