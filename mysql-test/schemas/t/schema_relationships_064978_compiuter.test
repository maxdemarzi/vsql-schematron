INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064978_compiuter
--echo #
CREATE DATABASE `db_064978_compiuter`;
USE `db_064978_compiuter`;
CREATE TABLE `empleados` (
  `cod_emp` INT NOT NULL,
  `nom_emp` VARCHAR(50),
  `ape_emp` VARCHAR(50),
  `ced_emp` VARCHAR(50),
  `cor_emp` VARCHAR(50),
  `dir_emp` VARCHAR(50),
  `tel_emp` VARCHAR(50),
  `car_emp` VARCHAR(50),
  PRIMARY KEY (`cod_emp`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `cod_cli` INT NOT NULL,
  `nom_cli` VARCHAR(50),
  `ape_cli` VARCHAR(50),
  `ced_cli` VARCHAR(50),
  `dir_cli` VARCHAR(50),
  `tel_cli` VARCHAR(50),
  PRIMARY KEY (`cod_cli`)
) CHARACTER SET latin1;
CREATE TABLE `categorias` (
  `cod_cat` INT NOT NULL,
  `nom_cat` VARCHAR(50),
  PRIMARY KEY (`cod_cat`)
) CHARACTER SET latin1;
CREATE TABLE `diagnosticos` (
  `cod_dia` INT NOT NULL,
  `fal_cli_dia` VARCHAR(50),
  `fal_ini_dia` VARCHAR(50),
  `sol_dia` VARCHAR(50),
  PRIMARY KEY (`cod_dia`)
) CHARACTER SET latin1;
CREATE TABLE `equipos` (
  `cod_equ` INT NOT NULL,
  `ser_equ` VARCHAR(50),
  `des_equ` VARCHAR(50),
  `mar_equ` VARCHAR(50),
  `fky_categorias` INT,
  `fky_diagnosticos` INT,
  PRIMARY KEY (`cod_equ`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `cod_ped` INT NOT NULL,
  `fec_ped` DATE,
  `fky_clientes` INT,
  `fky_equipos` INT,
  `fky_empleados` INT,
  PRIMARY KEY (`cod_ped`)
) CHARACTER SET latin1;
CREATE TABLE `facturas` (
  `cod_fac` INT NOT NULL,
  `fec_fac` DATE,
  `mon_fac` DOUBLE,
  `div_fac` VARCHAR(50),
  `des_fac` VARCHAR(50),
  `fky_pedidos` INT,
  PRIMARY KEY (`cod_fac`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064978_compiuter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064978_compiuter') AS relationships;
DROP DATABASE `db_064978_compiuter`;
UNINSTALL EXTENSION vsql_schematron;
