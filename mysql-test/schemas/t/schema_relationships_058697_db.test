INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058697_db
--echo #
CREATE DATABASE `db_058697_db`;
USE `db_058697_db`;
CREATE TABLE `groups` (
  `group_id` INT NOT NULL,
  `group_name` VARCHAR(50),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `email` TEXT,
  `password` TEXT,
  `group_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `category_id` INT NOT NULL,
  `category_name` TEXT,
  `group_id` INT,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `item_id` INT NOT NULL,
  `item_name` TEXT,
  `category_id` INT,
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058697_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058697_db') AS relationships;
DROP DATABASE `db_058697_db`;
UNINSTALL EXTENSION vsql_schematron;
