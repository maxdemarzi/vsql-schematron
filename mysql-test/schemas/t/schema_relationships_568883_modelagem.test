INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568883_modelagem
--echo #
CREATE DATABASE `db_568883_modelagem`;
USE `db_568883_modelagem`;
CREATE TABLE `pessoa` (
  `id` INT NOT NULL,
  `nome` TEXT,
  `cpf` CHAR(50),
  `email` VARCHAR(50),
  `telefone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `uf` (
  `id` INT NOT NULL,
  `uf` CHAR(50),
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `id` INT NOT NULL,
  `pessoa_id` INT,
  `uf_id` INT,
  `logradouro` TEXT,
  `complemento` TEXT,
  `bairro` TEXT,
  `cidade` TEXT,
  `cep` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568883_modelagem') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568883_modelagem') AS relationships;
DROP DATABASE `db_568883_modelagem`;
UNINSTALL EXTENSION vsql_schematron;
