INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 223645_schema
--echo #
CREATE DATABASE `db_223645_schema`;
USE `db_223645_schema`;
CREATE TABLE `system` (
  `id` INT NOT NULL,
  `name` TEXT,
  `code` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media` (
  `id` INT NOT NULL,
  `name` TEXT,
  `system_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file` (
  `id` INT NOT NULL,
  `name` TEXT,
  `data` BLOB,
  `size` INT,
  `compression` TEXT,
  `media_id` INT,
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `checksum` (
  `file_id` INT,
  `name` TEXT,
  `data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `id` INT NOT NULL,
  `name` TEXT,
  `value` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mediatag` (
  `tag_id` INT,
  `media_id` INT
) CHARACTER SET latin1;
CREATE TABLE `filetag` (
  `tag_id` INT,
  `file_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_223645_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_223645_schema') AS relationships;
DROP DATABASE `db_223645_schema`;
UNINSTALL EXTENSION vsql_schematron;
