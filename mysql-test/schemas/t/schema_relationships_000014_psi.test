INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000014_psi
--echo #
CREATE DATABASE `db_000014_psi`;
USE `db_000014_psi`;
CREATE TABLE `branch` (
  `branch_id` INT,
  `branch_address` VARCHAR(50),
  `branch_contact_number` VARCHAR(50),
  `number_of_employees` INT,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `employee_id` INT,
  `branch_id` INT,
  `employee_name` VARCHAR(50),
  `gender` VARCHAR(50),
  `employee_address` VARCHAR(50),
  `employee_contact_number` VARCHAR(50),
  `employee_email_address` VARCHAR(50),
  `status` VARCHAR(50),
  `position` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000014_psi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000014_psi') AS relationships;
DROP DATABASE `db_000014_psi`;
UNINSTALL EXTENSION vsql_schematron;
