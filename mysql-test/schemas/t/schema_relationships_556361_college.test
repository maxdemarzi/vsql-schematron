INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 556361_college
--echo #
CREATE DATABASE `db_556361_college`;
USE `db_556361_college`;
CREATE TABLE `professors` (
  `id` INT NOT NULL,
  `f_name` CHAR(50),
  `l_name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `id` BIGINT NOT NULL,
  `f_name` CHAR(50),
  `l_name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
  `id` BIGINT NOT NULL,
  `name` CHAR(50),
  `professor_id` INT,
  `start_date` TIMESTAMP NULL,
  `is_full` BOOLEAN,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `enrollment` (
  `id` BIGINT NOT NULL,
  `course_id` INT,
  `student_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_556361_college') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_556361_college') AS relationships;
DROP DATABASE `db_556361_college`;
UNINSTALL EXTENSION vsql_schematron;
