INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 401336_update_001
--echo #
CREATE DATABASE `db_401336_update_001`;
USE `db_401336_update_001`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
  `id` BIGINT NOT NULL,
  `description` VARCHAR(50),
  `user_id` BIGINT,
  `created` BIGINT,
  `done` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_401336_update_001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_401336_update_001') AS relationships;
DROP DATABASE `db_401336_update_001`;
UNINSTALL EXTENSION vsql_schematron;
