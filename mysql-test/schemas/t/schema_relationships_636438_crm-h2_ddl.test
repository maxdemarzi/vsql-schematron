INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636438_crm-h2.ddl
--echo #
CREATE DATABASE `db_636438_crm_h2_ddl`;
USE `db_636438_crm_h2_ddl`;
CREATE TABLE `Customer` (
  `id` VARCHAR(50) NOT NULL,
  `uuid` VARCHAR(50),
  `title` VARCHAR(50),
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `suffix` VARCHAR(50),
  `dateOfBirth` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Identifier` (
  `id` VARCHAR(50) NOT NULL,
  `customerId` VARCHAR(50),
  `providerCode` VARCHAR(50),
  `type` VARCHAR(50),
  `identifier` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Properties` (
  `id` VARCHAR(50) NOT NULL,
  `customerId` VARCHAR(50),
  `name` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636438_crm_h2_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636438_crm_h2_ddl') AS relationships;
DROP DATABASE `db_636438_crm_h2_ddl`;
UNINSTALL EXTENSION vsql_schematron;
