INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 295154_ConnectedAccount
--echo #
CREATE DATABASE `db_295154_ConnectedAccount`;
USE `db_295154_ConnectedAccount`;
CREATE TABLE `ServiceProvider` (
  `name` VARCHAR(50) NOT NULL,
  `displayName` VARCHAR(50),
  `implementation` VARCHAR(50),
  `apiKey` VARCHAR(50),
  `secret` VARCHAR(50),
  `appId` BIGINT,
  `requestTokenUrl` VARCHAR(50),
  `authorizeUrl` VARCHAR(50),
  `accessTokenUrl` VARCHAR(50),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `AccountConnection` (
  `member` BIGINT NOT NULL,
  `provider` VARCHAR(50) NOT NULL,
  `accessToken` VARCHAR(50) NOT NULL,
  `secret` VARCHAR(50),
  `accountId` VARCHAR(50),
  `profileUrl` VARCHAR(50),
  PRIMARY KEY (`member`, `provider`, `accessToken`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_295154_ConnectedAccount') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_295154_ConnectedAccount') AS relationships;
DROP DATABASE `db_295154_ConnectedAccount`;
UNINSTALL EXTENSION vsql_schematron;
