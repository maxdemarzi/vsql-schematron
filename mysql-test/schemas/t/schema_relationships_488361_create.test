INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488361_create
--echo #
CREATE DATABASE `db_488361_create`;
USE `db_488361_create`;
CREATE TABLE `thinks` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `listIndex` INT,
  `color` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `annotations` (
  `id` INT NOT NULL,
  `think_id` INT,
  `title` VARCHAR(50),
  `text` TEXT,
  `password` TEXT,
  `color` INT,
  `listIndex` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `annotation_files` (
  `id` INT NOT NULL,
  `annotation_id` INT,
  `title` VARCHAR(50),
  `description` TEXT,
  `type` VARCHAR(50),
  `path` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488361_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488361_create') AS relationships;
DROP DATABASE `db_488361_create`;
UNINSTALL EXTENSION vsql_schematron;
