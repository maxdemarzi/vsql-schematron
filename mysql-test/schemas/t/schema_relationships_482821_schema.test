INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 482821_schema
--echo #
CREATE DATABASE `db_482821_schema`;
USE `db_482821_schema`;
CREATE TABLE `libraries` (
  `id` INT NOT NULL,
  `name` TEXT,
  `path` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artists` (
  `id` INT NOT NULL,
  `name` TEXT,
  `dirname` TEXT,
  `library` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `albums` (
  `id` INT NOT NULL,
  `name` TEXT,
  `artist` INT,
  `dirname` TEXT,
  `library` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs` (
  `id` INT NOT NULL,
  `name` TEXT,
  `number` INT,
  `artist` INT,
  `album` INT,
  `path` TEXT,
  `library` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db_version` (
  `version` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_482821_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_482821_schema') AS relationships;
DROP DATABASE `db_482821_schema`;
UNINSTALL EXTENSION vsql_schematron;
