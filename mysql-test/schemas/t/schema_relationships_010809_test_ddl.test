INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010809_test_ddl
--echo #
CREATE DATABASE `db_010809_test_ddl`;
USE `db_010809_test_ddl`;
CREATE TABLE `address` (
  `id` VARCHAR(50) NOT NULL,
  `address` VARCHAR(50),
  `city_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `country_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `address_id` VARCHAR(50),
  `create_time` TIMESTAMP NULL,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010809_test_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010809_test_ddl') AS relationships;
DROP DATABASE `db_010809_test_ddl`;
UNINSTALL EXTENSION vsql_schematron;
