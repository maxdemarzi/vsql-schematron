INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 419059_V12__Add_Rss_tables
--echo #
CREATE DATABASE `db_419059_V12__Add_Rss_tables`;
USE `db_419059_V12__Add_Rss_tables`;
CREATE TABLE `rss_subscription` (
  `id` INT NOT NULL,
  `subject` VARCHAR(50),
  `provider` INT,
  `lastScanAttempt` BIGINT,
  `lastScanComplete` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `channel_rss_subscription` (
  `id` INT NOT NULL,
  `rss_subscription_id` INT,
  `text_channel_id` VARCHAR(50),
  `keyword` VARCHAR(50),
  `author` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_419059_V12__Add_Rss_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_419059_V12__Add_Rss_tables') AS relationships;
DROP DATABASE `db_419059_V12__Add_Rss_tables`;
UNINSTALL EXTENSION vsql_schematron;
