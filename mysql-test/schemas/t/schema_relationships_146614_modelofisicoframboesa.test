INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 146614_modelofisicoframboesa
--echo #
CREATE DATABASE `db_146614_modelofisicoframboesa`;
USE `db_146614_modelofisicoframboesa`;
CREATE TABLE `rua` (
  `id_rua` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id_rua`)
) CHARACTER SET latin1;
CREATE TABLE `cacho` (
  `id` INT NOT NULL,
  `tag_rfid` VARCHAR(50),
  `nome` VARCHAR(50),
  `data_inicio` VARCHAR(50),
  `data_fim` VARCHAR(50),
  `id_rua` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `umidade` (
  `id` INT NOT NULL,
  `estado` INT,
  `id_rua` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `temperatura` (
  `id` INT NOT NULL,
  `temperatura` DOUBLE,
  `id_rua` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_146614_modelofisicoframboesa') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_146614_modelofisicoframboesa') AS relationships;
DROP DATABASE `db_146614_modelofisicoframboesa`;
UNINSTALL EXTENSION vsql_schematron;
