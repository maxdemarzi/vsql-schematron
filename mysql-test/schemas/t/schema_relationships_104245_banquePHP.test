INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 104245_banquePHP
--echo #
CREATE DATABASE `db_104245_banquePHP`;
USE `db_104245_banquePHP`;
CREATE TABLE `alb_users` (
  `u_id` VARCHAR(50) NOT NULL,
  `u_civility` VARCHAR(50),
  `u_firstname` VARCHAR(50),
  `u_lastname` VARCHAR(50),
  `u_birthdate` DATE,
  `u_email` VARCHAR(50),
  `u_password` VARCHAR(50),
  `u_address_line1` VARCHAR(50),
  `u_address_line2` VARCHAR(50),
  `u_zipcode` VARCHAR(50),
  `u_city` VARCHAR(50),
  `u_country` VARCHAR(50),
  `u_creation_date` DATE,
  PRIMARY KEY (`u_id`)
) CHARACTER SET latin1;
CREATE TABLE `alb_accounts` (
  `a_id` VARCHAR(50) NOT NULL,
  `a_user_id` VARCHAR(50),
  `a_number` VARCHAR(50),
  `a_type` VARCHAR(50),
  `a_balance` DECIMAL(10,2),
  `a_creation_date` DATE,
  `a_close_date` DATE,
  PRIMARY KEY (`a_id`)
) CHARACTER SET latin1;
CREATE TABLE `alb_transactions` (
  `t_id` VARCHAR(50) NOT NULL,
  `t_account_id` VARCHAR(50),
  `t_description` VARCHAR(50),
  `t_type` VARCHAR(50),
  `t_amount` DECIMAL(10,2),
  `t_date` DATE,
  PRIMARY KEY (`t_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_104245_banquePHP') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_104245_banquePHP') AS relationships;
DROP DATABASE `db_104245_banquePHP`;
UNINSTALL EXTENSION vsql_schematron;
