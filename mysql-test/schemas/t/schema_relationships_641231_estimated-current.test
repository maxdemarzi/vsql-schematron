INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641231_estimated-current
--echo #
CREATE DATABASE `db_641231_estimated_current`;
USE `db_641231_estimated_current`;
CREATE TABLE `sessions` (
  `session_id` VARCHAR(50) NOT NULL,
  `user_id` INT,
  `max_age_secs` VARCHAR(50),
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `copy_paste_tokens` (
  `id` VARCHAR(50) NOT NULL,
  `session_id` VARCHAR(50),
  `max_age_secs` VARCHAR(50),
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641231_estimated_current') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641231_estimated_current') AS relationships;
DROP DATABASE `db_641231_estimated_current`;
UNINSTALL EXTENSION vsql_schematron;
