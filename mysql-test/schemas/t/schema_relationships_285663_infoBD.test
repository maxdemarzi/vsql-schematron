INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 285663_infoBD
--echo #
CREATE DATABASE `db_285663_infoBD`;
USE `db_285663_infoBD`;
CREATE TABLE `produto` (
  `id_produto` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao_p` VARCHAR(50),
  `valor` DOUBLE,
  PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
CREATE TABLE `servico` (
  `id_servico` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao_s` VARCHAR(50),
  `valor` DOUBLE,
  PRIMARY KEY (`id_servico`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `id_pedido` INT NOT NULL,
  `id_produto` INT,
  `id_servico` INT,
  `descricao_pedido` VARCHAR(50),
  `data` VARCHAR(50),
  `hora` VARCHAR(50),
  `status` VARCHAR(50),
  `valor` DOUBLE,
  PRIMARY KEY (`id_pedido`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_285663_infoBD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_285663_infoBD') AS relationships;
DROP DATABASE `db_285663_infoBD`;
UNINSTALL EXTENSION vsql_schematron;
