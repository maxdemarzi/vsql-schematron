INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352105_mall
--echo #
CREATE DATABASE `db_352105_mall`;
USE `db_352105_mall`;
CREATE TABLE `area` (
  `areaCode` VARCHAR(50) NOT NULL,
  `area` VARCHAR(50),
  `cityCode` VARCHAR(50),
  PRIMARY KEY (`areaCode`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `cityCode` VARCHAR(50) NOT NULL,
  `city` VARCHAR(50),
  `provinceCode` VARCHAR(50),
  PRIMARY KEY (`cityCode`)
) CHARACTER SET latin1;
CREATE TABLE `province` (
  `provinceCode` VARCHAR(50) NOT NULL,
  `province` VARCHAR(50),
  PRIMARY KEY (`provinceCode`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352105_mall') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352105_mall') AS relationships;
DROP DATABASE `db_352105_mall`;
UNINSTALL EXTENSION vsql_schematron;
