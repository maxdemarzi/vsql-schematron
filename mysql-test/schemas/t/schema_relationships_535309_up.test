INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535309_up
--echo #
CREATE DATABASE `db_535309_up`;
USE `db_535309_up`;
CREATE TABLE `entrepreneurs` (
  `id` INT NOT NULL,
  `account_id` INT,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `account_number_country_code` VARCHAR(50),
  `account_number_prefix` SMALLINT,
  `vat` VARCHAR(50),
  `account_number` BIGINT,
  `account_bank_code` SMALLINT,
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `currency_code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `settings` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
  `id` INT NOT NULL,
  `entrepreneur_id` INT,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `vat` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `invoices` (
  `id` INT NOT NULL,
  `entrepreneur_id` INT,
  `contact_id` INT,
  `code` VARCHAR(50),
  `created` DATE,
  `pay_until` DATE,
  `payed` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `login_sessions` (
  `id` VARCHAR(50) NOT NULL,
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535309_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535309_up') AS relationships;
DROP DATABASE `db_535309_up`;
UNINSTALL EXTENSION vsql_schematron;
