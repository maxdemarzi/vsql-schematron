INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153989_databaseschema
--echo #
CREATE DATABASE `db_153989_databaseschema`;
USE `db_153989_databaseschema`;
CREATE TABLE `PROBLEM` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `PROBLEMTYPE` BIGINT,
  `CREATEDBY` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FOLDER` (
  `ID` BIGINT NOT NULL,
  `LONGDESCRIPTION` VARCHAR(50),
  `COURSEID` BIGINT,
  `CREATEDBY` BIGINT,
  `ISVISIBLE` BOOLEAN,
  `ENDDATE` TIMESTAMP NULL,
  `STARTDATE` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EXERCISE` (
  `ID` BIGINT NOT NULL,
  `REFERENCEDPROBLEMID` BIGINT,
  `COURSEID` BIGINT,
  `FOLDERID` BIGINT,
  `ALLOWEDATTEMPTS` BIGINT,
  `MAXGRADE` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153989_databaseschema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153989_databaseschema') AS relationships;
DROP DATABASE `db_153989_databaseschema`;
UNINSTALL EXTENSION vsql_schematron;
