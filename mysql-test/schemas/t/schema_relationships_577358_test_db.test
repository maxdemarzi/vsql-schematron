INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577358_test_db
--echo #
CREATE DATABASE `db_577358_test_db`;
USE `db_577358_test_db`;
CREATE TABLE `trainings` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `user_guid` CHAR(50),
  `video_id` INT,
  `timestamp` DATETIME,
  `success` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `guid` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `completed_training` TINYINT,
  PRIMARY KEY (`guid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577358_test_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577358_test_db') AS relationships;
DROP DATABASE `db_577358_test_db`;
UNINSTALL EXTENSION vsql_schematron;
