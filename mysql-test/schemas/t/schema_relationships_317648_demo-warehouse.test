INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317648_demo-warehouse
--echo #
CREATE DATABASE `db_317648_demo_warehouse`;
USE `db_317648_demo_warehouse`;
CREATE TABLE `Article` (
  `id` INT NOT NULL,
  `identification` INT,
  `name` TEXT,
  `availableStock` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` INT NOT NULL,
  `name` TEXT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ArticlesOnProducts` (
  `productId` INT NOT NULL,
  `articleId` INT NOT NULL,
  `quantity` INT,
  PRIMARY KEY (`productId`, `articleId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317648_demo_warehouse') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317648_demo_warehouse') AS relationships;
DROP DATABASE `db_317648_demo_warehouse`;
UNINSTALL EXTENSION vsql_schematron;
