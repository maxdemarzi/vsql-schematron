INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515874_schema
--echo #
CREATE DATABASE `db_515874_schema`;
USE `db_515874_schema`;
CREATE TABLE `USERS` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHORITIES` (
  `authority` VARCHAR(50),
  `username` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515874_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515874_schema') AS relationships;
DROP DATABASE `db_515874_schema`;
UNINSTALL EXTENSION vsql_schematron;
