INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 443340_schema
--echo #
CREATE DATABASE `db_443340_schema`;
USE `db_443340_schema`;
CREATE TABLE `requestMethod` (
  `requestMethodID` VARCHAR(50) NOT NULL,
  `requestMethod` VARCHAR(50),
  PRIMARY KEY (`requestMethodID`)
) CHARACTER SET latin1;
CREATE TABLE `accessLog` (
  `accessLogID` VARCHAR(50) NOT NULL,
  `requestTime` DATETIME,
  `requestUri` VARCHAR(50),
  `requestMethod` VARCHAR(50),
  `requestParams` TEXT,
  `responseTime` DATETIME,
  `responseStatus` VARCHAR(50),
  `response` TEXT,
  PRIMARY KEY (`accessLogID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_443340_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_443340_schema') AS relationships;
DROP DATABASE `db_443340_schema`;
UNINSTALL EXTENSION vsql_schematron;
