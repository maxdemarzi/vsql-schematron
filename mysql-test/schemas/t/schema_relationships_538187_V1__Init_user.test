INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 538187_V1__Init_user
--echo #
CREATE DATABASE `db_538187_V1__Init_user`;
USE `db_538187_V1__Init_user`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_permission` (
  `id` BIGINT NOT NULL,
  `permission` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_detail` (
  `id` BIGINT NOT NULL,
  `key` VARCHAR(50),
  `value` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_538187_V1__Init_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_538187_V1__Init_user') AS relationships;
DROP DATABASE `db_538187_V1__Init_user`;
UNINSTALL EXTENSION vsql_schematron;
