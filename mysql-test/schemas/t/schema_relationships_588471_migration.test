INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588471_migration
--echo #
CREATE DATABASE `db_588471_migration`;
USE `db_588471_migration`;
CREATE TABLE `Poll` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Choice` (
  `id` INT NOT NULL,
  `name` TEXT,
  `pollId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Response` (
  `id` INT NOT NULL,
  `choiceId` INT,
  `ipAddress` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588471_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588471_migration') AS relationships;
DROP DATABASE `db_588471_migration`;
UNINSTALL EXTENSION vsql_schematron;
