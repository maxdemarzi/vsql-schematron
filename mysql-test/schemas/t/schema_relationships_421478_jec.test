INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 421478_jec
--echo #
CREATE DATABASE `db_421478_jec`;
USE `db_421478_jec`;
CREATE TABLE `teachers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `designation` VARCHAR(50),
  `phonenumber` VARCHAR(50),
  `email` VARCHAR(50),
  `departmentid` INT,
  `imagepath` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subject_teachers` (
  `id` BIGINT NOT NULL,
  `subjectid` BIGINT,
  `departmentid` BIGINT,
  `teacherid` BIGINT,
  `year` VARCHAR(50),
  `semester` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_421478_jec') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_421478_jec') AS relationships;
DROP DATABASE `db_421478_jec`;
UNINSTALL EXTENSION vsql_schematron;
