INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546550_V20210816132213__AddDashboardTables
--echo #
CREATE DATABASE `db_546550_V20210816132213__AddDashboardTables`;
USE `db_546550_V20210816132213__AddDashboardTables`;
CREATE TABLE `dashboard_definition` (
  `id` BIGINT NOT NULL,
  `creation_time` DATETIME,
  `last_update_time` DATETIME,
  `tag` VARCHAR(50),
  `title_key` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dashboard_widget` (
  `id` BIGINT NOT NULL,
  `creation_time` DATETIME,
  `last_update_time` DATETIME,
  `params` VARCHAR(50),
  `title_key` VARCHAR(50),
  `type` VARCHAR(50),
  `settings` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dashboard_widget_rel` (
  `id` BIGINT NOT NULL,
  `creation_time` DATETIME,
  `last_update_time` DATETIME,
  `sort` INT,
  `width_data` VARCHAR(50),
  `dashboard_definition_id` BIGINT,
  `dashboard_widget_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546550_V20210816132213__AddDashboardTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546550_V20210816132213__AddDashboardTables') AS relationships;
DROP DATABASE `db_546550_V20210816132213__AddDashboardTables`;
UNINSTALL EXTENSION vsql_schematron;
