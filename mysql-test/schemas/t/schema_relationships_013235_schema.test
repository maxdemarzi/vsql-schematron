INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013235_schema
--echo #
CREATE DATABASE `db_013235_schema`;
USE `db_013235_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stat` (
  `id` INT NOT NULL,
  `user_id` INT,
  `created` TEXT,
  `total` INT,
  `added` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013235_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013235_schema') AS relationships;
DROP DATABASE `db_013235_schema`;
UNINSTALL EXTENSION vsql_schematron;
