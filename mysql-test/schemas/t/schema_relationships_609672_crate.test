INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609672_crate
--echo #
CREATE DATABASE `db_609672_crate`;
USE `db_609672_crate`;
CREATE TABLE `companies` (
  `id` INT NOT NULL,
  `company` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `crates` (
  `id` INT,
  `id_company` INT,
  `content` VARCHAR(50),
  `active` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `id_company` INT,
  `auth_key` VARCHAR(50),
  `owner` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `values` (
  `id` INT,
  `id_crate` INT,
  `date` DATETIME,
  `temperature` DOUBLE,
  `humidity` INT,
  `hydrogen` INT,
  `oxigen` INT,
  `latitude` DOUBLE,
  `longitude` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609672_crate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609672_crate') AS relationships;
DROP DATABASE `db_609672_crate`;
UNINSTALL EXTENSION vsql_schematron;
