INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 206352_%E5%A4%96%E9%94%AE%E7%BA%A6%E6%9D%9F
--echo #
CREATE DATABASE `db_206352__E5_A4_96_E9_94_AE_E7_BA_A6_E6_9D_9F`;
USE `db_206352__E5_A4_96_E9_94_AE_E7_BA_A6_E6_9D_9F`;
CREATE TABLE `emp` (
  `id` INT NOT NULL,
  `NAME` VARCHAR(50),
  `age` INT,
  `dep_name` VARCHAR(50),
  `dep_location` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `dep_name` VARCHAR(50),
  `dep_location` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `NAME` VARCHAR(50),
  `age` INT,
  `dep_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_206352__E5_A4_96_E9_94_AE_E7_BA_A6_E6_9D_9F') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_206352__E5_A4_96_E9_94_AE_E7_BA_A6_E6_9D_9F') AS relationships;
DROP DATABASE `db_206352__E5_A4_96_E9_94_AE_E7_BA_A6_E6_9D_9F`;
UNINSTALL EXTENSION vsql_schematron;
