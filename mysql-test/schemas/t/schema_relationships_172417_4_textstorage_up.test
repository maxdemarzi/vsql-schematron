INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172417_4_textstorage.up
--echo #
CREATE DATABASE `db_172417_4_textstorage_up`;
USE `db_172417_4_textstorage_up`;
CREATE TABLE `textstorage_text` (
  `id` INT NOT NULL,
  `text` TEXT,
  `last_updated` TIMESTAMP NULL,
  `revision` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `textstorage_revision` (
  `text_id` INT NOT NULL,
  `revision` INT NOT NULL,
  `text` TEXT,
  `timestamp` TIMESTAMP NULL,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`text_id`, `revision`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172417_4_textstorage_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172417_4_textstorage_up') AS relationships;
DROP DATABASE `db_172417_4_textstorage_up`;
UNINSTALL EXTENSION vsql_schematron;
