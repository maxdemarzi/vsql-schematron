INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 453047_MiauCaoCeSePuder
--echo #
CREATE DATABASE `db_453047_MiauCaoCeSePuder`;
USE `db_453047_MiauCaoCeSePuder`;
CREATE TABLE `usuario` (
  `cod_usuario` INT NOT NULL,
  `usuario_nickname` VARCHAR(50),
  `usuario_senha` VARCHAR(50),
  `usuario_nome_completo` VARCHAR(50),
  `usuario_telefone` VARCHAR(50),
  `usuario_estado` VARCHAR(50),
  `usuario_cidade` VARCHAR(50),
  `usuario_email` VARCHAR(50),
  `usuario_tipo` INT,
  PRIMARY KEY (`cod_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `anuncio` (
  `cod_anuncio` INT NOT NULL,
  `anuncio_desc` VARCHAR(50),
  `anuncio_nome_completo` VARCHAR(50),
  `anuncio_numero_telefone` VARCHAR(50),
  `anuncio_email_contato` VARCHAR(50),
  `anuncio_estado_local_animal` VARCHAR(50),
  `anuncio_cidade_local_animal` VARCHAR(50),
  `anuncio_cod_usuario` INT,
  PRIMARY KEY (`cod_anuncio`)
) CHARACTER SET latin1;
CREATE TABLE `animal` (
  `cod_animal` INT NOT NULL,
  `animal_situacao` VARCHAR(50),
  `animal_nome` VARCHAR(50),
  `animal_tipo` VARCHAR(50),
  `animal_raca` VARCHAR(50),
  `animal_sexo` VARCHAR(50),
  `animal_porte` VARCHAR(50),
  `animal_idade` VARCHAR(50),
  `animal_pelagem` VARCHAR(50),
  `animal_foto_1` VARCHAR(50),
  `animal_foto_2` VARCHAR(50),
  `animal_desc` VARCHAR(50),
  `animal_cod_anuncio` INT,
  `animal_cod_usuario` INT,
  PRIMARY KEY (`cod_animal`)
) CHARACTER SET latin1;
CREATE TABLE `contato` (
  `cod_contato` INT NOT NULL,
  `contato_nome_completo` VARCHAR(50),
  `contato_telefone` VARCHAR(50),
  `contato_email` VARCHAR(50),
  `contato_estado` VARCHAR(50),
  `contato_cidade` VARCHAR(50),
  `contato_assunto` VARCHAR(50),
  `contato_texto_mensagem` VARCHAR(50),
  `contato_cod_usuario` INT,
  PRIMARY KEY (`cod_contato`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_453047_MiauCaoCeSePuder') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_453047_MiauCaoCeSePuder') AS relationships;
DROP DATABASE `db_453047_MiauCaoCeSePuder`;
UNINSTALL EXTENSION vsql_schematron;
