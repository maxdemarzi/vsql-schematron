INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 523851_V1.0.0__book
--echo #
CREATE DATABASE `db_523851_V1_0_0__book`;
USE `db_523851_V1_0_0__book`;
CREATE TABLE `author` (
  `id` INT NOT NULL,
  `last_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` INT NOT NULL,
  `author_id` INT,
  `title` VARCHAR(50),
  `number_pages` INT,
  `dms_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_523851_V1_0_0__book') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_523851_V1_0_0__book') AS relationships;
DROP DATABASE `db_523851_V1_0_0__book`;
UNINSTALL EXTENSION vsql_schematron;
