INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 666707_201604081443__create_search
--echo #
CREATE DATABASE `db_666707_201604081443__create_search`;
USE `db_666707_201604081443__create_search`;
CREATE TABLE `search_profile` (
  `id` VARCHAR(50) NOT NULL,
  `name_pt` VARCHAR(50),
  `name_en` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `search_question` (
  `id` VARCHAR(50) NOT NULL,
  `description_pt` VARCHAR(50),
  `description_en` VARCHAR(50),
  `answer` VARCHAR(50),
  `profile_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `search_selector` (
  `id` VARCHAR(50) NOT NULL,
  `name_pt` VARCHAR(50),
  `name_en` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `search_question_selector` (
  `question_id` VARCHAR(50) NOT NULL,
  `selector_id` VARCHAR(50) NOT NULL,
  `order` INT,
  PRIMARY KEY (`question_id`, `selector_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_666707_201604081443__create_search') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_666707_201604081443__create_search') AS relationships;
DROP DATABASE `db_666707_201604081443__create_search`;
UNINSTALL EXTENSION vsql_schematron;
