INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 472039_db-1
--echo #
CREATE DATABASE `db_472039_db_1`;
USE `db_472039_db_1`;
CREATE TABLE `livresauteurs` (
  `livre_id` INT NOT NULL,
  `auteur_id` INT NOT NULL,
  PRIMARY KEY (`livre_id`, `auteur_id`)
) CHARACTER SET latin1;
CREATE TABLE `auteurs` (
  `id` INT NOT NULL,
  `nom` TEXT,
  `prenom` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `livres` (
  `id` INT NOT NULL,
  `titre` TEXT,
  `gencod` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_472039_db_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_472039_db_1') AS relationships;
DROP DATABASE `db_472039_db_1`;
UNINSTALL EXTENSION vsql_schematron;
