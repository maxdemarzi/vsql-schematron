INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 526723_create_region_sql
--echo #
CREATE DATABASE `db_526723_create_region_sql`;
USE `db_526723_create_region_sql`;
CREATE TABLE `provinces` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `provinceID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `cityID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_526723_create_region_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_526723_create_region_sql') AS relationships;
DROP DATABASE `db_526723_create_region_sql`;
UNINSTALL EXTENSION vsql_schematron;
