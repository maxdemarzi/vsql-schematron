INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 633873_tables
--echo #
CREATE DATABASE `db_633873_tables`;
USE `db_633873_tables`;
CREATE TABLE `repositories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `repositories_contributors` (
  `repository_id` INT,
  `contributor_id` INT
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `issue_status` VARCHAR(50),
  `repository_id` INT,
  `assignee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `commits` (
  `id` INT NOT NULL,
  `message` VARCHAR(50),
  `issue_id` INT,
  `repository_id` INT,
  `contributor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `size` DECIMAL(10,2),
  `parent_id` INT,
  `commit_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_633873_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_633873_tables') AS relationships;
DROP DATABASE `db_633873_tables`;
UNINSTALL EXTENSION vsql_schematron;
