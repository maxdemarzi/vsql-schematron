INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555044_up
--echo #
CREATE DATABASE `db_555044_up`;
USE `db_555044_up`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `token` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `friendly_name` VARCHAR(50),
  `display_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `map` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  `name` VARCHAR(50),
  `segment_count` VARCHAR(50),
  `path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `replay` (
  `id` INT NOT NULL,
  `scoreid` INT,
  `path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `score` (
  `id` INT NOT NULL,
  `userid` INT,
  `mapid` INT,
  `segment_times` VARCHAR(50),
  `strafes` INT,
  `jumps` INT,
  `total_time` DOUBLE,
  `max_speed` DOUBLE,
  `average_speed` DOUBLE,
  `season` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_stat` (
  `id` INT NOT NULL,
  `userid` INT,
  `jumps` BIGINT,
  `strafes` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `badge` (
  `id` INT NOT NULL,
  `friendly_name` VARCHAR(50),
  `display_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_badge` (
  `id` INT NOT NULL,
  `userid` INT,
  `badgeid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_reset` (
  `id` INT NOT NULL,
  `userid` INT,
  `token` VARCHAR(50),
  `valid_until` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `id` INT NOT NULL,
  `userid` INT,
  `roleid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `season` (
  `id` INT NOT NULL,
  `display_name` VARCHAR(50),
  `friendly_name` VARCHAR(50),
  `ends_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555044_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555044_up') AS relationships;
DROP DATABASE `db_555044_up`;
UNINSTALL EXTENSION vsql_schematron;
