INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153283_schema
--echo #
CREATE DATABASE `db_153283_schema`;
USE `db_153283_schema`;
CREATE TABLE `card_holder` (
  `card_holder_id` INT NOT NULL,
  `card_holder_name` VARCHAR(50),
  PRIMARY KEY (`card_holder_id`)
) CHARACTER SET latin1;
CREATE TABLE `credit_card` (
  `credit_card_number` VARCHAR(50) NOT NULL,
  `card_holder_id` INT,
  PRIMARY KEY (`credit_card_number`)
) CHARACTER SET latin1;
CREATE TABLE `merchant_category` (
  `merchant_category_id` INT NOT NULL,
  `merchant_category_name` VARCHAR(50),
  PRIMARY KEY (`merchant_category_id`)
) CHARACTER SET latin1;
CREATE TABLE `merchant` (
  `merchant_id` INT NOT NULL,
  `merchant_name` VARCHAR(50),
  `merchant_category_id` INT,
  PRIMARY KEY (`merchant_id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
  `transaction_id` INT,
  `transaction_date` TIMESTAMP NULL,
  `transaction_amount` DOUBLE,
  `credit_card_number` VARCHAR(50),
  `merchant_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153283_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153283_schema') AS relationships;
DROP DATABASE `db_153283_schema`;
UNINSTALL EXTENSION vsql_schematron;
