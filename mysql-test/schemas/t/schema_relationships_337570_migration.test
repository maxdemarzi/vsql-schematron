INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 337570_migration
--echo #
CREATE DATABASE `db_337570_migration`;
USE `db_337570_migration`;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `title` TEXT,
  `body` TEXT,
  `authorId` TEXT,
  `editorId` TEXT,
  `publisherId` TEXT,
  `publishedAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Contact` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `name` TEXT,
  `email` TEXT,
  `message` TEXT,
  `userId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `UserProfile` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `uuid` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `UserRole` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` TEXT,
  `userProfileId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_337570_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_337570_migration') AS relationships;
DROP DATABASE `db_337570_migration`;
UNINSTALL EXTENSION vsql_schematron;
