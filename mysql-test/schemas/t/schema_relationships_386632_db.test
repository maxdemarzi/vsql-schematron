INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 386632_db
--echo #
CREATE DATABASE `db_386632_db`;
USE `db_386632_db`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `forget` VARCHAR(50),
  `image` VARCHAR(50),
  `user_type` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cpf` (
  `id` INT NOT NULL,
  `cpf` VARCHAR(50),
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cnpj` (
  `id` INT NOT NULL,
  `cnpj` VARCHAR(50),
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `category` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `price` VARCHAR(50),
  `image` VARCHAR(50),
  `category_id` INT,
  `brand_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_386632_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_386632_db') AS relationships;
DROP DATABASE `db_386632_db`;
UNINSTALL EXTENSION vsql_schematron;
