INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626659_13-Procedures
--echo #
CREATE DATABASE `db_626659_13_Procedures`;
USE `db_626659_13_Procedures`;
CREATE TABLE `employee` (
  `empl_id` INT NOT NULL,
  `empl_name` VARCHAR(50),
  `hourly_rate` DOUBLE,
  `email` VARCHAR(50),
  PRIMARY KEY (`empl_id`)
) CHARACTER SET latin1;
CREATE TABLE `animal` (
  `animal_id` INT NOT NULL,
  `animal_type` VARCHAR(50),
  PRIMARY KEY (`animal_id`)
) CHARACTER SET latin1;
CREATE TABLE `pet` (
  `pet_id` INT NOT NULL,
  `pet_name` VARCHAR(50),
  `animal_id` INT,
  PRIMARY KEY (`pet_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626659_13_Procedures') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626659_13_Procedures') AS relationships;
DROP DATABASE `db_626659_13_Procedures`;
UNINSTALL EXTENSION vsql_schematron;
