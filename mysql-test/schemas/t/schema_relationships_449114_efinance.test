INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449114_efinance
--echo #
CREATE DATABASE `db_449114_efinance`;
USE `db_449114_efinance`;
CREATE TABLE `laporan` (
  `id_laporan` INT NOT NULL,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `judul` VARCHAR(50),
  `isi` TEXT,
  PRIMARY KEY (`id_laporan`)
) CHARACTER SET latin1;
CREATE TABLE `pemasukan` (
  `id_pemasukan` INT,
  `tgl_pemasukan` DATE,
  `jumlah` INT,
  `keterangan` TEXT,
  `id_user` INT
) CHARACTER SET latin1;
CREATE TABLE `pengeluaran` (
  `id_pengeluaran` INT,
  `tgl_pengeluaran` DATE,
  `jumlah` INT,
  `keterangan` TEXT,
  `id_user` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT,
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  `noHP` VARCHAR(50),
  `username` VARCHAR(50),
  `pass` VARCHAR(50),
  `type` VARCHAR(50),
  `status` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449114_efinance') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449114_efinance') AS relationships;
DROP DATABASE `db_449114_efinance`;
UNINSTALL EXTENSION vsql_schematron;
