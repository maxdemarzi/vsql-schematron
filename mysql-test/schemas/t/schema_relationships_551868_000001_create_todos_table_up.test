CREATE DATABASE `db_551868_000001_create_todos_table_up`;
USE `db_551868_000001_create_todos_table_up`;
CREATE TABLE `todo_statuses` (
  `id` INT NOT NULL,
  `val` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
  `ulid` VARCHAR(50) NOT NULL,
  `contents` TEXT,
  `todo_status_id` INT,
  PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_551868_000001_create_todos_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_551868_000001_create_todos_table_up') AS relationships;
DROP DATABASE `db_551868_000001_create_todos_table_up`;
UNINSTALL EXTENSION vsql_schematron;
