INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 528805_mule7148_banksoal
--echo #
CREATE DATABASE `db_528805_mule7148_banksoal`;
USE `db_528805_mule7148_banksoal`;
CREATE TABLE `tbl_fakultas` (
  `id_fakultas` INT NOT NULL,
  `nama_fakultas` VARCHAR(50),
  `alamat_fakultas` TEXT,
  `notelp_fakultas` VARCHAR(50),
  `email_fakultas` VARCHAR(50),
  `created_fakultas` DATETIME,
  `updated_fakultas` DATETIME,
  PRIMARY KEY (`id_fakultas`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_kelasmahasiswa` (
  `id_kelasmahasiswa` INT NOT NULL,
  `id_prodi` INT,
  `periode_kelasmahasiswa` VARCHAR(50),
  `gg_kelasmahasiswa` VARCHAR(50),
  `semester_kelasmahasiswa` INT,
  `nomor_kelasmahasiswa` INT,
  `created_kelasmahasiswa` DATETIME,
  `updated_kelasmahasiswa` DATETIME,
  PRIMARY KEY (`id_kelasmahasiswa`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_soal` (
  `id_soal` INT NOT NULL,
  `id_matakuliah` INT,
  `id_formatsoal` INT,
  `id_kelasmahasiswa` INT,
  `id_user_dosen_soal` INT,
  `tanggal_soal` DATE,
  `totalwaktu_soal` INT,
  `sifatujian_soal` INT,
  `tipe_soal` VARCHAR(50),
  `isi_soal` TEXT,
  `created_soal` DATETIME,
  `updated_soal` DATETIME,
  PRIMARY KEY (`id_soal`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_528805_mule7148_banksoal') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_528805_mule7148_banksoal') AS relationships;
DROP DATABASE `db_528805_mule7148_banksoal`;
UNINSTALL EXTENSION vsql_schematron;
