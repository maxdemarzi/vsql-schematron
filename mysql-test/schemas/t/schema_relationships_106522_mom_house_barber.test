INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106522_mom_house_barber
--echo #
CREATE DATABASE `db_106522_mom_house_barber`;
USE `db_106522_mom_house_barber`;
CREATE TABLE `close_branch` (
  `OB_ID` VARCHAR(50),
  `OB_DATE` DATE,
  `SOB_ID` INT
) CHARACTER SET latin1;
CREATE TABLE `login` (
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  `S_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `offwork` (
  `OW_ID` VARCHAR(50),
  `B_ID` VARCHAR(50),
  `Date` DATE
) CHARACTER SET latin1;
CREATE TABLE `status` (
  `S_ID` VARCHAR(50) NOT NULL,
  `S_Name` VARCHAR(50),
  PRIMARY KEY (`S_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106522_mom_house_barber') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106522_mom_house_barber') AS relationships;
DROP DATABASE `db_106522_mom_house_barber`;
UNINSTALL EXTENSION vsql_schematron;
