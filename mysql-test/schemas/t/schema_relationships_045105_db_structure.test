INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045105_db_structure
--echo #
CREATE DATABASE `db_045105_db_structure`;
USE `db_045105_db_structure`;
CREATE TABLE `{PREFIX10}_role` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `{PREFIX13}_role_permission` (
  `id` INT NOT NULL,
  `role_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `{PREFIX17}_menu` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `type` TINYINT,
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045105_db_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045105_db_structure') AS relationships;
DROP DATABASE `db_045105_db_structure`;
UNINSTALL EXTENSION vsql_schematron;
