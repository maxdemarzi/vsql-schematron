INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178003_schema
--echo #
CREATE DATABASE `db_178003_schema`;
USE `db_178003_schema`;
CREATE TABLE `users_roles` (
  `user_id` BIGINT,
  `role_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `role_id` BIGINT NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `spring_users` (
  `user_id` BIGINT NOT NULL,
  `login` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `active` BOOLEAN,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178003_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178003_schema') AS relationships;
DROP DATABASE `db_178003_schema`;
UNINSTALL EXTENSION vsql_schematron;
