INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 690079_sql-tutorial
--echo #
CREATE DATABASE `db_690079_sql_tutorial`;
USE `db_690079_sql_tutorial`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `species` VARCHAR(50),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `message` VARCHAR(50),
  `posted` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_690079_sql_tutorial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_690079_sql_tutorial') AS relationships;
DROP DATABASE `db_690079_sql_tutorial`;
UNINSTALL EXTENSION vsql_schematron;
