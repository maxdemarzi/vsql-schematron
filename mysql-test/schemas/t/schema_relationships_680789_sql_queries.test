INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 680789_sql_queries
--echo #
CREATE DATABASE `db_680789_sql_queries`;
USE `db_680789_sql_queries`;
CREATE TABLE `city` (
  `city_id` INT NOT NULL,
  `city_name` VARCHAR(50),
  `population` INT,
  `mean_income` DOUBLE,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `customer_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `date_of_birth` DATE,
  `gender` VARCHAR(50),
  `city_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `plan` (
  `plan_id` INT NOT NULL,
  `plan_name` VARCHAR(50),
  `free_minutes` VARCHAR(50),
  `free_sms` VARCHAR(50),
  `free_mbs` VARCHAR(50),
  PRIMARY KEY (`plan_id`)
) CHARACTER SET latin1;
CREATE TABLE `contract` (
  `contract_id` INT NOT NULL,
  `phone_number` VARCHAR(50),
  `contract_desc` VARCHAR(50),
  `start_date` DATE,
  `end_date` DATE,
  `customer_id` INT,
  `plan_id` INT,
  PRIMARY KEY (`contract_id`)
) CHARACTER SET latin1;
CREATE TABLE `calls` (
  `call_id` INT NOT NULL,
  `date_time_of_call` DATETIME,
  `called_phone_number` VARCHAR(50),
  `duration` INT,
  `contract_id` INT,
  PRIMARY KEY (`call_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_680789_sql_queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_680789_sql_queries') AS relationships;
DROP DATABASE `db_680789_sql_queries`;
UNINSTALL EXTENSION vsql_schematron;
