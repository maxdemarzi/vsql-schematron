INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458056_mobilefirstTraining
--echo #
CREATE DATABASE `db_458056_mobilefirstTraining`;
USE `db_458056_mobilefirstTraining`;
CREATE TABLE `accounts` (
  `accountId` VARCHAR(50) NOT NULL,
  `userId` VARCHAR(50),
  `accountType` VARCHAR(50),
  PRIMARY KEY (`accountId`)
) CHARACTER SET latin1;
CREATE TABLE `accounttransactions` (
  `transactionId` VARCHAR(50) NOT NULL,
  `fromAccount` VARCHAR(50),
  `toAccount` VARCHAR(50),
  `transactionType` VARCHAR(50),
  `transactionDate` DATETIME,
  `transactionAmount` DECIMAL(10,2),
  PRIMARY KEY (`transactionId`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `userId` VARCHAR(50) NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `weather` (
  `city` TEXT,
  `identifier` TEXT,
  `summary` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458056_mobilefirstTraining') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458056_mobilefirstTraining') AS relationships;
DROP DATABASE `db_458056_mobilefirstTraining`;
UNINSTALL EXTENSION vsql_schematron;
