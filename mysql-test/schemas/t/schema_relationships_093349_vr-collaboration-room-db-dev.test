INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093349_vr-collaboration-room-db-dev
--echo #
CREATE DATABASE `db_093349_vr_collaboration_room_db_dev`;
USE `db_093349_vr_collaboration_room_db_dev`;
CREATE TABLE `User` (
  `userID` INT NOT NULL,
  `username` VARCHAR(50),
  `userEmail` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `Model` (
  `modelID` INT NOT NULL,
  `uploaded` BLOB,
  `dateUploaded` DATE,
  `name` VARCHAR(50),
  `userID` INT,
  PRIMARY KEY (`modelID`)
) CHARACTER SET latin1;
CREATE TABLE `Server` (
  `serverID` INT NOT NULL,
  `hostIP` VARCHAR(50),
  `hostPort` INT,
  `isAllocated` VARCHAR(50),
  PRIMARY KEY (`serverID`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
  `sessionID` INT NOT NULL,
  `sessionName` VARCHAR(50),
  `mapName` VARCHAR(50),
  `maxParticipants` INT,
  `serverID` INT,
  `hostUserID` INT,
  `participantCount` INT,
  PRIMARY KEY (`sessionID`)
) CHARACTER SET latin1;
CREATE TABLE `Invited_Participant` (
  `userID` INT,
  `sessionID` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093349_vr_collaboration_room_db_dev') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093349_vr_collaboration_room_db_dev') AS relationships;
DROP DATABASE `db_093349_vr_collaboration_room_db_dev`;
UNINSTALL EXTENSION vsql_schematron;
