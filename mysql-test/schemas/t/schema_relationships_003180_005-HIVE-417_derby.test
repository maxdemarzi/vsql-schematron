INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 003180_005-HIVE-417.derby
--echo #
CREATE DATABASE `db_003180_005_HIVE_417_derby`;
USE `db_003180_005_HIVE_417_derby`;
CREATE TABLE `IDXS` (
  `INDEX_ID` BIGINT NOT NULL,
  `CREATE_TIME` INT,
  `DEFERRED_REBUILD` CHAR(50),
  `INDEX_HANDLER_CLASS` VARCHAR(50),
  `INDEX_NAME` VARCHAR(50),
  `INDEX_TBL_ID` BIGINT,
  `LAST_ACCESS_TIME` INT,
  `ORIG_TBL_ID` BIGINT,
  `SD_ID` BIGINT,
  PRIMARY KEY (`INDEX_ID`)
) CHARACTER SET latin1;
CREATE TABLE `INDEX_PARAMS` (
  `INDEX_ID` BIGINT NOT NULL,
  `PARAM_KEY` VARCHAR(50) NOT NULL,
  `PARAM_VALUE` VARCHAR(50),
  PRIMARY KEY (`INDEX_ID`, `PARAM_KEY`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_003180_005_HIVE_417_derby') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_003180_005_HIVE_417_derby') AS relationships;
DROP DATABASE `db_003180_005_HIVE_417_derby`;
UNINSTALL EXTENSION vsql_schematron;
