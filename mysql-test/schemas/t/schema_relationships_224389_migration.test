INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 224389_migration
--echo #
CREATE DATABASE `db_224389_migration`;
USE `db_224389_migration`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `username` TEXT,
  `password` TEXT,
  `provider` VARCHAR(50),
  `providerId` TEXT,
  `bio` TEXT,
  `profilePhoto` TEXT,
  `coverPhoto` TEXT,
  `phone` TEXT,
  `birthday` TIMESTAMP NULL,
  `isActive` BOOLEAN,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `resetPasswordToken` TEXT,
  `resetPasswordExpiration` BIGINT,
  `confirmationToken` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets` (
  `id` INT NOT NULL,
  `content` TEXT,
  `imageUrl` TEXT,
  `isPublic` BOOLEAN,
  `createdAt` TIMESTAMP NULL,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_224389_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_224389_migration') AS relationships;
DROP DATABASE `db_224389_migration`;
UNINSTALL EXTENSION vsql_schematron;
