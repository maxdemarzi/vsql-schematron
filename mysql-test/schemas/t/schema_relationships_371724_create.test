INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 371724_create
--echo #
CREATE DATABASE `db_371724_create`;
USE `db_371724_create`;
CREATE TABLE `PLAYER` (
  `id` INT NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `POINTS` (
  `player_id` INT,
  `world_id` INT,
  `score` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_371724_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_371724_create') AS relationships;
DROP DATABASE `db_371724_create`;
UNINSTALL EXTENSION vsql_schematron;
