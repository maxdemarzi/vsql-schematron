INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058172_create_tables
--echo #
CREATE DATABASE `db_058172_create_tables`;
USE `db_058172_create_tables`;
CREATE TABLE `Student` (
  `snum` INT NOT NULL,
  `sname` VARCHAR(50),
  `major` VARCHAR(50),
  `slevel` VARCHAR(50),
  `age` INT,
  PRIMARY KEY (`snum`)
) CHARACTER SET latin1;
CREATE TABLE `Faculty` (
  `fid` INT NOT NULL,
  `fname` VARCHAR(50),
  `deptid` INT,
  PRIMARY KEY (`fid`)
) CHARACTER SET latin1;
CREATE TABLE `Class` (
  `cname` VARCHAR(50) NOT NULL,
  `meets_at` VARCHAR(50),
  `room` VARCHAR(50),
  `fid` INT,
  PRIMARY KEY (`cname`)
) CHARACTER SET latin1;
CREATE TABLE `Enrolled` (
  `snum` INT,
  `cname` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058172_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058172_create_tables') AS relationships;
DROP DATABASE `db_058172_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
