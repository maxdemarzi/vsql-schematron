INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381530_boiseRockForm
--echo #
CREATE DATABASE `db_381530_boiseRockForm`;
USE `db_381530_boiseRockForm`;
CREATE TABLE `employee` (
  `employeeID` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `emailAddress` VARCHAR(50),
  PRIMARY KEY (`employeeID`)
) CHARACTER SET latin1;
CREATE TABLE `contactMSG` (
  `contactMSGID` INT NOT NULL,
  `name` VARCHAR(50),
  `userEmail` VARCHAR(50),
  `userMSG` VARCHAR(50),
  `msgDate` DATETIME,
  `employeeID` INT,
  PRIMARY KEY (`contactMSGID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381530_boiseRockForm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381530_boiseRockForm') AS relationships;
DROP DATABASE `db_381530_boiseRockForm`;
UNINSTALL EXTENSION vsql_schematron;
