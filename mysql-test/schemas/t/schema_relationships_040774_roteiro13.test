INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040774_roteiro13
--echo #
CREATE DATABASE `db_040774_roteiro13`;
USE `db_040774_roteiro13`;
CREATE TABLE `tbTipo` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbMorador` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbRepublica` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbConta` (
  `id` INT NOT NULL,
  `mes` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `idTipo` INT,
  `idRepublica` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbRateio` (
  `id` INT NOT NULL,
  `valor` DECIMAL(10,2),
  `situacao` INT,
  `idMorador` INT,
  `idConta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbProduto` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `quantidade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040774_roteiro13') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040774_roteiro13') AS relationships;
DROP DATABASE `db_040774_roteiro13`;
UNINSTALL EXTENSION vsql_schematron;
