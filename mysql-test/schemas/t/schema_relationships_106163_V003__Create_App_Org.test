INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106163_V003__Create_App_Org
--echo #
CREATE DATABASE `db_106163_V003__Create_App_Org`;
USE `db_106163_V003__Create_App_Org`;
CREATE TABLE `productline` (
  `productline_id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`productline_id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `project_id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `owning_productline` BIGINT,
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `projectfilter` (
  `filter_id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`filter_id`)
) CHARACTER SET latin1;
CREATE TABLE `filter_projects` (
  `filter_id` BIGINT NOT NULL,
  `project_id` BIGINT NOT NULL,
  PRIMARY KEY (`filter_id`, `project_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106163_V003__Create_App_Org') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106163_V003__Create_App_Org') AS relationships;
DROP DATABASE `db_106163_V003__Create_App_Org`;
UNINSTALL EXTENSION vsql_schematron;
