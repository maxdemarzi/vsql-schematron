INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638909_up
--echo #
CREATE DATABASE `db_638909_up`;
USE `db_638909_up`;
CREATE TABLE `rbac_principals` (
  `id` VARCHAR(50) NOT NULL,
  `organization_id` VARCHAR(50),
  `username` VARCHAR(50),
  `description` TEXT,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_group_principals` (
  `group_id` VARCHAR(50) NOT NULL,
  `principal_id` VARCHAR(50) NOT NULL,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`group_id`, `principal_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638909_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638909_up') AS relationships;
DROP DATABASE `db_638909_up`;
UNINSTALL EXTENSION vsql_schematron;
