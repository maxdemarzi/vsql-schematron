  `event` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`event`)
) CHARACTER SET latin1;
CREATE TABLE `EVENT` (
  `event_id` DECIMAL(10,2) NOT NULL,
  `dialogid` DECIMAL(10,2),
  `event` VARCHAR(50),
  `tidspunkt` TIMESTAMP NULL,
  `aktor_id` VARCHAR(50),
  `aktivitet_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
