INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002270_schema
--echo #
CREATE DATABASE `db_002270_schema`;
USE `db_002270_schema`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `access_token` VARCHAR(50),
  `mastodon_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `snapshots` (
  `id` BIGINT NOT NULL,
  `owner` BIGINT,
  `snap_type` VARCHAR(50),
  `status` VARCHAR(50),
  `bucket` VARCHAR(50),
  `key` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002270_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002270_schema') AS relationships;
DROP DATABASE `db_002270_schema`;
UNINSTALL EXTENSION vsql_schematron;
