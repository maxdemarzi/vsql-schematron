INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 101086_db
--echo #
CREATE DATABASE `db_101086_db`;
USE `db_101086_db`;
CREATE TABLE `vendedores` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `idade` INT,
  `vendedor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `quantidade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
  `id` INT NOT NULL,
  `data` DATE,
  `quantidade` INT,
  `produto_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_101086_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_101086_db') AS relationships;
DROP DATABASE `db_101086_db`;
UNINSTALL EXTENSION vsql_schematron;
