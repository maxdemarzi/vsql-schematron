INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106051_migration
--echo #
CREATE DATABASE `db_106051_migration`;
USE `db_106051_migration`;
CREATE TABLE `Challenge` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `beginsAt` TIMESTAMP NULL,
  `endsAt` TIMESTAMP NULL,
  `name` TEXT,
  `description` TEXT,
  `slug` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Entry` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `challengeId` TEXT,
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Vote` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `entryId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106051_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106051_migration') AS relationships;
DROP DATABASE `db_106051_migration`;
UNINSTALL EXTENSION vsql_schematron;
