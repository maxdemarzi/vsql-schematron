INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 220234_seed
--echo #
CREATE DATABASE `db_220234_seed`;
USE `db_220234_seed`;
CREATE TABLE `tbl_channels` (
  `id` VARCHAR(50) NOT NULL,
  `guild` VARCHAR(50),
  `category` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_users` (
  `id` BIGINT NOT NULL,
  `user_id` VARCHAR(50),
  `channel_id` VARCHAR(50),
  `nick` VARCHAR(50),
  `valor_sujo` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_220234_seed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_220234_seed') AS relationships;
DROP DATABASE `db_220234_seed`;
UNINSTALL EXTENSION vsql_schematron;
