INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 119155_main
--echo #
CREATE DATABASE `db_119155_main`;
USE `db_119155_main`;
CREATE TABLE `CUSTOMER` (
  `CUSTOMER_ID` INT NOT NULL,
  `CUSTOMER_NAME` VARCHAR(50),
  `CUSTOMER_TEL` VARCHAR(50),
  `CUSTOMER_EMAIL` VARCHAR(50),
  `CUSTOMER_ADDRESS` VARCHAR(50),
  `CUSTOMER_CITY_CODE` VARCHAR(50),
  `CUSTOMER_USERNAME` VARCHAR(50),
  `CUSTOMER_PASSWORD` VARCHAR(50),
  `CUSTOMER_BALANCE` DOUBLE,
  `CUSTOMER_ADMIN` BOOLEAN,
  PRIMARY KEY (`CUSTOMER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CAR` (
  `CAR_ID` INT NOT NULL,
  `CAR_MODEL` VARCHAR(50),
  `CAR_CODE` VARCHAR(50),
  `AVAILABILITY_CODE` VARCHAR(50),
  PRIMARY KEY (`CAR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `FLOWER` (
  `FLOWER_ID` INT NOT NULL,
  `STORE_CODE` VARCHAR(50),
  `PRICE` DOUBLE,
  PRIMARY KEY (`FLOWER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TRIP` (
  `TRIP_ID` INT NOT NULL,
  `DESTINATION_CODE` VARCHAR(50),
  `SOURCE_CODE` VARCHAR(50),
  `DISTANCE` DOUBLE,
  `CAR_ID` INT,
  `PRICE` DOUBLE,
  PRIMARY KEY (`TRIP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER_ORDER` (
  `ORDER_ID` INT NOT NULL,
  `DATE_ISSUED` TIMESTAMP NULL,
  `DATE_DONE` DATE,
  `TOTAL_PRICE` DOUBLE,
  `PAYMENT_CODE` VARCHAR(50),
  `CUSTOMER_ID` INT,
  `TRIP_ID` INT,
  `FLOWER_ID` INT,
  PRIMARY KEY (`ORDER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT_REVIEW` (
  `REVIEW_ID` INT NOT NULL,
  `R_CONTEXT` VARCHAR(50),
  `R_SCORE` INT,
  `FLOWER_ID` INT,
  PRIMARY KEY (`REVIEW_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DRIVER_REVIEW` (
  `REVIEW_ID` INT NOT NULL,
  `R_CONTEXT` VARCHAR(50),
  `R_SCORE` INT,
  `CAR_ID` INT,
  PRIMARY KEY (`REVIEW_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_119155_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_119155_main') AS relationships;
DROP DATABASE `db_119155_main`;
UNINSTALL EXTENSION vsql_schematron;
