INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348435_criaBD
--echo #
CREATE DATABASE `db_348435_criaBD`;
USE `db_348435_criaBD`;
CREATE TABLE `Fornecedor` (
  `id_fornecedor` INT NOT NULL,
  `razao_social` VARCHAR(50),
  `nome_fantasia` VARCHAR(50),
  `rua` VARCHAR(50),
  `numero` INT,
  `cep` VARCHAR(50),
  `cnpj` VARCHAR(50),
  `telefone` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id_fornecedor`)
) CHARACTER SET latin1;
CREATE TABLE `Produto` (
  `id_produto` INT NOT NULL,
  `descricao` VARCHAR(50),
  `preco` DECIMAL(10,2),
  PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
CREATE TABLE `Funcionario` (
  `id_funcionario` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `email` VARCHAR(50),
  `data_nascimento` DATE,
  `data_admissao` DATE,
  `conta_salario` VARCHAR(50),
  `numero_carteira` VARCHAR(50),
  `rua` VARCHAR(50),
  `cep` VARCHAR(50),
  `numero` INT,
  `cargo` INT,
  PRIMARY KEY (`id_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `Pedido` (
  `id_pedido` INT NOT NULL,
  `valor_total` DOUBLE,
  `data` DATE,
  `status` INT,
  `id_funcionario` INT,
  PRIMARY KEY (`id_pedido`)
) CHARACTER SET latin1;
CREATE TABLE `Item_Pedido` (
  `id_produto` INT,
  `id_pedido` INT
) CHARACTER SET latin1;
CREATE TABLE `Ingrediente` (
  `id_ingrediente` INT NOT NULL,
  `descricao` VARCHAR(50),
  `perecibilidade` INT,
  PRIMARY KEY (`id_ingrediente`)
) CHARACTER SET latin1;
CREATE TABLE `Estoque` (
  `id_estoque` INT NOT NULL,
  `quantidade` DOUBLE,
  `data_validade` DATE,
  `id_ingrediente` INT,
  `id_produto` INT,
  PRIMARY KEY (`id_estoque`)
) CHARACTER SET latin1;
CREATE TABLE `Fornecedor_Estoque` (
  `id_fornecedor` INT NOT NULL,
  `id_estoque` INT NOT NULL,
  `data_entrega` DATE,
  `quantidade_entrega` DECIMAL(10,2),
  PRIMARY KEY (`id_fornecedor`, `id_estoque`)
) CHARACTER SET latin1;
CREATE TABLE `Produto_Ingrediente` (
  `id_produto` INT,
  `id_ingrediente` INT,
  `quantidade` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348435_criaBD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348435_criaBD') AS relationships;
DROP DATABASE `db_348435_criaBD`;
UNINSTALL EXTENSION vsql_schematron;
