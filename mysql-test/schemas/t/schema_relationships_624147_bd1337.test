INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624147_bd1337
--echo #
CREATE DATABASE `db_624147_bd1337`;
USE `db_624147_bd1337`;
CREATE TABLE `evaluation` (
  `DateEval` DATE,
  `IdHotel` INT,
  `NoteAccueil` INT,
  `NoteRest` INT,
  `NoteExtra` INT
) CHARACTER SET latin1;
CREATE TABLE `hotel` (
  `IdHotel` INT NOT NULL,
  `NomHotel` VARCHAR(50),
  `TelHotel` VARCHAR(50),
  `VilleHotel` VARCHAR(50),
  PRIMARY KEY (`IdHotel`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624147_bd1337') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624147_bd1337') AS relationships;
DROP DATABASE `db_624147_bd1337`;
UNINSTALL EXTENSION vsql_schematron;
