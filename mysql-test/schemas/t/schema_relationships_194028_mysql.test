INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 194028_mysql
--echo #
CREATE DATABASE `db_194028_mysql`;
USE `db_194028_mysql`;
CREATE TABLE `empresa` (
  `id` INT NOT NULL,
  `cnpj` VARCHAR(50),
  `razaoSocial` VARCHAR(50),
  `endereco` VARCHAR(50),
  `bairro` VARCHAR(50),
  `uf` VARCHAR(50),
  `cidade` VARCHAR(50),
  `cep` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vaga` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `especificacaoDoCargo` VARCHAR(50),
  `remuneracao` VARCHAR(50),
  `valeTransporte` BOOLEAN,
  `valeRefeicao` BOOLEAN,
  `uf` VARCHAR(50),
  `turno` VARCHAR(50),
  `formaDeContratacao` VARCHAR(50),
  `empresa_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candidato` (
  `id` INT NOT NULL,
  `dataNascimento` VARCHAR(50),
  `cpf` VARCHAR(50),
  `nome` VARCHAR(50),
  `estadoCivil` VARCHAR(50),
  `sexo` VARCHAR(50),
  `endereco` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `experiencia` (
  `id` INT NOT NULL,
  `cargo` VARCHAR(50),
  `funcao` VARCHAR(50),
  `candidato_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_194028_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_194028_mysql') AS relationships;
DROP DATABASE `db_194028_mysql`;
UNINSTALL EXTENSION vsql_schematron;
