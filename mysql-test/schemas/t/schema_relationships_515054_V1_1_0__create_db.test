INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515054_V1_1_0__create_db
--echo #
CREATE DATABASE `db_515054_V1_1_0__create_db`;
USE `db_515054_V1_1_0__create_db`;
CREATE TABLE `identity` (
  `id` VARCHAR(50) NOT NULL,
  `publickey` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endpoint` (
  `id` VARCHAR(50) NOT NULL,
  `lastSeen` TIMESTAMP NULL,
  `lastVerified` TIMESTAMP NULL,
  `host` TEXT,
  `port` INT,
  `identity` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nodeInfo` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `host` TEXT,
  `port` INT,
  `publickey` VARCHAR(50),
  `p2pversion` INT,
  `clientId` TEXT,
  `capabilities` TEXT,
  `genesisHash` TEXT,
  `bestHash` TEXT,
  `totalDifficulty` TEXT,
  `identity` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515054_V1_1_0__create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515054_V1_1_0__create_db') AS relationships;
DROP DATABASE `db_515054_V1_1_0__create_db`;
UNINSTALL EXTENSION vsql_schematron;
