INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246318_Canadiens
--echo #
CREATE DATABASE `db_246318_Canadiens`;
USE `db_246318_Canadiens`;
CREATE TABLE `adversaires` (
  `code` VARCHAR(50) NOT NULL,
  `nom` TEXT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `parties` (
  `id` INT NOT NULL,
  `date` DATE,
  `adversaire` CHAR(50),
  `pointage_canadiens` INT,
  `pointage_adversaire` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246318_Canadiens') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246318_Canadiens') AS relationships;
DROP DATABASE `db_246318_Canadiens`;
UNINSTALL EXTENSION vsql_schematron;
