INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060318_tables
--echo #
CREATE DATABASE `db_060318_tables`;
USE `db_060318_tables`;
CREATE TABLE `Cats` (
  `Id` INT NOT NULL,
  `WoolColor` DOUBLE,
  `EyeColor` DOUBLE,
  `Coloration` DOUBLE,
  `TailLength` DOUBLE,
  `WoolLength` DOUBLE,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `SystemUsers` (
  `Id` INT NOT NULL,
  `Login` VARCHAR(50),
  `Password` VARCHAR(50),
  `FullName` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `EvaluatedCats` (
  `Id` INT NOT NULL,
  `UserId` INT,
  `CatId` INT,
  `Grade` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
  `Id` INT NOT NULL,
  `UserId` INT,
  `Token` VARCHAR(50),
  `Data` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060318_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060318_tables') AS relationships;
DROP DATABASE `db_060318_tables`;
UNINSTALL EXTENSION vsql_schematron;
