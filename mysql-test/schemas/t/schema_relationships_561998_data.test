INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 561998_data
--echo #
CREATE DATABASE `db_561998_data`;
USE `db_561998_data`;
CREATE TABLE `STUDY_GROUP` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(50),
  `STUDY_GROUP_ID` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `GRADE` (
  `ID` DECIMAL(10,2),
  `COURSE` VARCHAR(50),
  `GRADE` VARCHAR(50),
  `STUDENT_ID` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_561998_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_561998_data') AS relationships;
DROP DATABASE `db_561998_data`;
UNINSTALL EXTENSION vsql_schematron;
