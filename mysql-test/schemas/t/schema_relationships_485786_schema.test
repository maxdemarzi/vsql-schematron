INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485786_schema
--echo #
CREATE DATABASE `db_485786_schema`;
USE `db_485786_schema`;
CREATE TABLE `role` (
  `role_id` BIGINT NOT NULL,
  `role_name` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_role_id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `role_id` BIGINT,
  PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485786_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485786_schema') AS relationships;
DROP DATABASE `db_485786_schema`;
UNINSTALL EXTENSION vsql_schematron;
