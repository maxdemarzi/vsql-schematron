INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659793_sql_init
--echo #
CREATE DATABASE `db_659793_sql_init`;
USE `db_659793_sql_init`;
CREATE TABLE `article_type` (
  `article_type_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`article_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `article_type_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659793_sql_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659793_sql_init') AS relationships;
DROP DATABASE `db_659793_sql_init`;
UNINSTALL EXTENSION vsql_schematron;
