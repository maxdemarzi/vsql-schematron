INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 316758_V1.4__Group_Tables
--echo #
CREATE DATABASE `db_316758_V1_4__Group_Tables`;
USE `db_316758_V1_4__Group_Tables`;
CREATE TABLE `student_group` (
  `id` INT NOT NULL,
  `number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_member` (
  `id` INT NOT NULL,
  `group_id` INT,
  `role` VARCHAR(50),
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_316758_V1_4__Group_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_316758_V1_4__Group_Tables') AS relationships;
DROP DATABASE `db_316758_V1_4__Group_Tables`;
UNINSTALL EXTENSION vsql_schematron;
