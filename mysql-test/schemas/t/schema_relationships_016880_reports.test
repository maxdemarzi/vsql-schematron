INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016880_reports
--echo #
CREATE DATABASE `db_016880_reports`;
USE `db_016880_reports`;
CREATE TABLE `reports` (
  `id` VARCHAR(50) NOT NULL,
  `startDate` DATE,
  `endDate` DATE,
  `performer` VARCHAR(50),
  `activity` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  `app_user` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `username` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `registers` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50) NOT NULL,
  `op_id` VARCHAR(50) NOT NULL,
  `record_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`, `user_id`, `op_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016880_reports') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016880_reports') AS relationships;
DROP DATABASE `db_016880_reports`;
UNINSTALL EXTENSION vsql_schematron;
