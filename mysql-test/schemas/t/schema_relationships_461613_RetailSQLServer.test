INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 461613_RetailSQLServer
--echo #
CREATE DATABASE `db_461613_RetailSQLServer`;
USE `db_461613_RetailSQLServer`;
CREATE TABLE `CUSTOMER` (
  `CUSTOMER_ID` INT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `SURNAME` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  `CONTACT_NUMBER` DECIMAL(10,2),
  `EMAIL` VARCHAR(50),
  PRIMARY KEY (`CUSTOMER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
  `EMPLOYEE_ID` VARCHAR(50) NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `SURNAME` VARCHAR(50),
  `CONTACT_NUMBER` DECIMAL(10,2),
  `POSITION` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  PRIMARY KEY (`EMPLOYEE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DELIVERY` (
  `DELIVERY_ID` INT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  `DISPATCH_DATE` DATE,
  `DELIVERY_DATE` DATE,
  PRIMARY KEY (`DELIVERY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RETURNS` (
  `RETURN_ID` VARCHAR(50) NOT NULL,
  `RETURN_DATE` DATE,
  `REASON` VARCHAR(50),
  PRIMARY KEY (`RETURN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT` (
  `PRODUCT_ID` INT NOT NULL,
  `PRODUCT` VARCHAR(50),
  `PRICE` DECIMAL(10,2),
  `QTY` INT,
  PRIMARY KEY (`PRODUCT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BILLING` (
  `BILL_ID` INT NOT NULL,
  `CUSTOMER_ID` INT,
  `BILL_DATE` DATE,
  `EMPLOYEE_ID` VARCHAR(50),
  PRIMARY KEY (`BILL_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT_BILLING` (
  `DELIVERY_ID` INT,
  `RETURN_ID` VARCHAR(50),
  `PRODUCT_ID` INT,
  `BILL_ID` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_461613_RetailSQLServer') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_461613_RetailSQLServer') AS relationships;
DROP DATABASE `db_461613_RetailSQLServer`;
UNINSTALL EXTENSION vsql_schematron;
