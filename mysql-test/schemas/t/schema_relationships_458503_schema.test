INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 458503_schema
--echo #
CREATE DATABASE `db_458503_schema`;
USE `db_458503_schema`;
CREATE TABLE `te_user` (
  `id` VARCHAR(50) NOT NULL,
  `display_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `te_currency` (
  `id` INT NOT NULL,
  `name_singular` VARCHAR(50),
  `name_plural` VARCHAR(50),
  `symbol` VARCHAR(50),
  `num_fraction_digits` INT,
  `is_default` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `te_balance` (
  `user_id` VARCHAR(50),
  `currency_id` INT,
  `balance` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_458503_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_458503_schema') AS relationships;
DROP DATABASE `db_458503_schema`;
UNINSTALL EXTENSION vsql_schematron;
