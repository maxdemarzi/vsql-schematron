INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041296_script
--echo #
CREATE DATABASE `db_041296_script`;
USE `db_041296_script`;
CREATE TABLE `hospital` (
  `hospital_id` VARCHAR(50) NOT NULL,
  `hospital_name` VARCHAR(50),
  `city` VARCHAR(50),
  `district` VARCHAR(50),
  `capacity` INT,
  `director_name` VARCHAR(50),
  `director_contact` VARCHAR(50),
  `hospital_contact_01` VARCHAR(50),
  `hospital_contact_02` VARCHAR(50),
  `hospital_fax_number` VARCHAR(50),
  `hospital_email` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`hospital_id`)
) CHARACTER SET latin1;
CREATE TABLE `quarantine_center` (
  `quarantine_id` VARCHAR(50) NOT NULL,
  `quarantine_name` VARCHAR(50),
  `quarantine_city` VARCHAR(50),
  `quarantine_district` VARCHAR(50),
  `quarantine_head_name` VARCHAR(50),
  `quarantine_head_contact` VARCHAR(50),
  `quarantine_contact_01` VARCHAR(50),
  `quarantine_contact_02` VARCHAR(50),
  `quarantine_capacity` INT,
  `status` VARCHAR(50),
  PRIMARY KEY (`quarantine_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `contact_number` VARCHAR(50),
  `email` VARCHAR(50),
  `role` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `location` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `global_update_detail` (
  `update_id` INT NOT NULL,
  `admin_id` VARCHAR(50),
  `updated_date` DATE,
  `confirmed_count` DECIMAL(10,2),
  `recovered_count` DECIMAL(10,2),
  `death_count` DECIMAL(10,2),
  PRIMARY KEY (`update_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041296_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041296_script') AS relationships;
DROP DATABASE `db_041296_script`;
UNINSTALL EXTENSION vsql_schematron;
