INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 548228_V2__Create_tables
--echo #
CREATE DATABASE `db_548228_V2__Create_tables`;
USE `db_548228_V2__Create_tables`;
CREATE TABLE `rule_set` (
  `id` BIGINT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `project_path` VARCHAR(50),
  `game` VARCHAR(50),
  `last_build_date` TIMESTAMP NULL,
  `last_build_size` BIGINT,
  `best_compression_rule_set_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rule_set_compression_rules_string` (
  `rule_set_id` BIGINT,
  `compression_rules_string` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_548228_V2__Create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_548228_V2__Create_tables') AS relationships;
DROP DATABASE `db_548228_V2__Create_tables`;
UNINSTALL EXTENSION vsql_schematron;
