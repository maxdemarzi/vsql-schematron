INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530482_write_c
--echo #
CREATE DATABASE `db_530482_write_c`;
USE `db_530482_write_c`;
CREATE TABLE `oath_details` (
  `id` INT NOT NULL,
  `oath_category_name` VARCHAR(50),
  `oath_title` VARCHAR(50),
  `oath_section` VARCHAR(50),
  `oath_code` VARCHAR(50),
  `min` INT,
  `max` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `summons_category` (
  `id` INT NOT NULL,
  `category_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `summons_details` (
  `id` INT,
  `summons_category_id` INT,
  `summons_title` VARCHAR(50),
  `summons_section` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530482_write_c') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530482_write_c') AS relationships;
DROP DATABASE `db_530482_write_c`;
UNINSTALL EXTENSION vsql_schematron;
