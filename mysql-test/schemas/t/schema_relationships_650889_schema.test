INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 650889_schema
--echo #
CREATE DATABASE `db_650889_schema`;
USE `db_650889_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `hidden` BOOLEAN,
  `created_at` DATETIME,
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `checklist` (
  `id` INT NOT NULL,
  `body` VARCHAR(50),
  `completed` BOOLEAN,
  `hidden` BOOLEAN,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `likes` (
  `id` INT NOT NULL,
  `quote_id` INT,
  `reflection` VARCHAR(50),
  `liked` BOOLEAN,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
  `id` INT NOT NULL,
  `quote_body` VARCHAR(50),
  `quote_author` VARCHAR(50),
  `image_url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_650889_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_650889_schema') AS relationships;
DROP DATABASE `db_650889_schema`;
UNINSTALL EXTENSION vsql_schematron;
