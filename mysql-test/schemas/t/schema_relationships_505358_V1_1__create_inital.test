INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505358_V1_1__create_inital
--echo #
CREATE DATABASE `db_505358_V1_1__create_inital`;
USE `db_505358_V1_1__create_inital`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  `authorities` VARCHAR(50),
  `register_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `login_token` (
  `id` INT NOT NULL,
  `token` VARCHAR(50),
  `user_id` INT,
  `description` VARCHAR(50),
  `last_used` TIMESTAMP NULL,
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505358_V1_1__create_inital') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505358_V1_1__create_inital') AS relationships;
DROP DATABASE `db_505358_V1_1__create_inital`;
UNINSTALL EXTENSION vsql_schematron;
