INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072085_database
--echo #
CREATE DATABASE `db_072085_database`;
USE `db_072085_database`;
CREATE TABLE `largeproject.loginFT` (
  `FTID` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`FTID`)
) CHARACTER SET latin1;
CREATE TABLE `largeproject.loginET` (
  `ETID` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`ETID`)
) CHARACTER SET latin1;
CREATE TABLE `largeproject.FTinfo` (
  `FTinfoID` INT NOT NULL,
  `TruckName` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `Zip` VARCHAR(50),
  `phonenumber` VARCHAR(50),
  `email` VARCHAR(50),
  `FTID` INT,
  PRIMARY KEY (`FTinfoID`)
) CHARACTER SET latin1;
CREATE TABLE `largeproject.ETinfo` (
  `ETinfoID` INT NOT NULL,
  `EntertainerName` VARCHAR(50),
  `address` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `Zip` VARCHAR(50),
  `phonenumber` VARCHAR(50),
  `email` VARCHAR(50),
  `ETID` INT,
  PRIMARY KEY (`ETinfoID`)
) CHARACTER SET latin1;
CREATE TABLE `largeproject.Menu` (
  `FoodID` INT NOT NULL,
  `DishName` VARCHAR(50),
  `Description` VARCHAR(50),
  `Price` VARCHAR(50),
  `FTID` INT,
  PRIMARY KEY (`FoodID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072085_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072085_database') AS relationships;
DROP DATABASE `db_072085_database`;
UNINSTALL EXTENSION vsql_schematron;
