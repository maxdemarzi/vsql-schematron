INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409643_V1.7.1__scirpt_1.0
--echo #
CREATE DATABASE `db_409643_V1_7_1__scirpt_1_0`;
USE `db_409643_V1_7_1__scirpt_1_0`;
CREATE TABLE `note_book` (
  `id` VARCHAR(50) NOT NULL,
  `crt_dttm` DATETIME,
  `crt_user` VARCHAR(50),
  `enable_flag` VARCHAR(50),
  `last_update_dttm` DATETIME,
  `last_update_user` VARCHAR(50),
  `version` BIGINT,
  `name` VARCHAR(50),
  `description` TEXT,
  `sessions_id` VARCHAR(50),
  `code_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `code_snippet` (
  `id` VARCHAR(50),
  `crt_dttm` DATETIME,
  `crt_user` VARCHAR(50),
  `enable_flag` VARCHAR(50),
  `last_update_dttm` DATETIME,
  `last_update_user` VARCHAR(50),
  `version` BIGINT,
  `fk_note_book_id` VARCHAR(50),
  `execute_id` VARCHAR(50),
  `code_content` TEXT,
  `code_snippet_sort` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `flow_global_params` (
  `id` VARCHAR(50) NOT NULL,
  `crt_dttm` DATETIME,
  `crt_user` VARCHAR(50),
  `enable_flag` VARCHAR(50),
  `last_update_dttm` DATETIME,
  `last_update_user` VARCHAR(50),
  `version` BIGINT,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `association_global_params_flow` (
  `global_params_id` VARCHAR(50),
  `flow_id` VARCHAR(50),
  `process_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409643_V1_7_1__scirpt_1_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409643_V1_7_1__scirpt_1_0') AS relationships;
DROP DATABASE `db_409643_V1_7_1__scirpt_1_0`;
UNINSTALL EXTENSION vsql_schematron;
