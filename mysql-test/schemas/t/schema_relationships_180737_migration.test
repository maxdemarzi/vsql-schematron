INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180737_migration
--echo #
CREATE DATABASE `db_180737_migration`;
USE `db_180737_migration`;
CREATE TABLE `Product` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `name` TEXT,
  `sku` TEXT,
  `description` TEXT,
  `quantity` INT,
  `cartId` TEXT,
  `categoryId` INT,
  `orderId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cart` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `email` TEXT,
  `firstName` TEXT,
  `lastName` TEXT,
  `address` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180737_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180737_migration') AS relationships;
DROP DATABASE `db_180737_migration`;
UNINSTALL EXTENSION vsql_schematron;
