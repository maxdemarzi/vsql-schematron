INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064529_make_db
--echo #
CREATE DATABASE `db_064529_make_db`;
USE `db_064529_make_db`;
CREATE TABLE `congreso_2011.post_codes` (
  `id` INT NOT NULL,
  `name` TEXT,
  `post_code` TEXT,
  `localidad` VARCHAR(50),
  `parent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064529_make_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064529_make_db') AS relationships;
DROP DATABASE `db_064529_make_db`;
UNINSTALL EXTENSION vsql_schematron;
