INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354546_V1.0__create_database
--echo #
CREATE DATABASE `db_354546_V1_0__create_database`;
USE `db_354546_V1_0__create_database`;
CREATE TABLE `commercial_policy` (
  `id` BIGINT NOT NULL,
  `active` BOOLEAN,
  `expire_date` DATETIME,
  `name` VARCHAR(50),
  `priority` INT,
  `start_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `commercial_policy_carrier` (
  `id` BIGINT NOT NULL,
  `carrier` VARCHAR(50),
  `percentage` DECIMAL(10,2),
  `commercial_policy_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354546_V1_0__create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354546_V1_0__create_database') AS relationships;
DROP DATABASE `db_354546_V1_0__create_database`;
UNINSTALL EXTENSION vsql_schematron;
