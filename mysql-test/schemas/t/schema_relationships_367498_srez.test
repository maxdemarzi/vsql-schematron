INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 367498_srez
--echo #
CREATE DATABASE `db_367498_srez`;
USE `db_367498_srez`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
  `version` VARCHAR(50) NOT NULL,
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `request` (
  `id` INT,
  `status` VARCHAR(50),
  `name` VARCHAR(50),
  `before_img` VARCHAR(50),
  `after_img` VARCHAR(50),
  `why_not` TEXT,
  `category_id` INT,
  `created_at` DATETIME,
  `created_by` INT,
  `updated_by` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_367498_srez') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_367498_srez') AS relationships;
DROP DATABASE `db_367498_srez`;
UNINSTALL EXTENSION vsql_schematron;
