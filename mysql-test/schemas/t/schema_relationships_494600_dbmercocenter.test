INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494600_dbmercocenter
--echo #
CREATE DATABASE `db_494600_dbmercocenter`;
USE `db_494600_dbmercocenter`;
CREATE TABLE `tbusuarios` (
  `coduser` INT NOT NULL,
  `nomeuser` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`coduser`)
) CHARACTER SET latin1;
CREATE TABLE `tbentradaprodutos` (
  `codproduto` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `marca` VARCHAR(50),
  `coduser` INT,
  `dataentrada` TIMESTAMP NULL,
  PRIMARY KEY (`codproduto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494600_dbmercocenter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494600_dbmercocenter') AS relationships;
DROP DATABASE `db_494600_dbmercocenter`;
UNINSTALL EXTENSION vsql_schematron;
