INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147476_schema
--echo #
CREATE DATABASE `db_147476_schema`;
USE `db_147476_schema`;
CREATE TABLE `bedrooms` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
  `id` VARCHAR(50) NOT NULL,
  `bedroom_id` VARCHAR(50),
  `customer_id` VARCHAR(50),
  `period_from` TIMESTAMP NULL,
  `period_to` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
  `id` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  `output_field` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147476_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147476_schema') AS relationships;
DROP DATABASE `db_147476_schema`;
UNINSTALL EXTENSION vsql_schematron;
