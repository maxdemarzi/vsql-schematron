INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531668_csmvc
--echo #
CREATE DATABASE `db_531668_csmvc`;
USE `db_531668_csmvc`;
CREATE TABLE `pemain` (
  `id` INT,
  `nama` VARCHAR(50),
  `posisi_id` INT,
  `negara` VARCHAR(50),
  `keterangan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `posisi` (
  `id` INT,
  `nama` VARCHAR(50),
  `keterangan` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531668_csmvc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531668_csmvc') AS relationships;
DROP DATABASE `db_531668_csmvc`;
UNINSTALL EXTENSION vsql_schematron;
