INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 200989_ZenQuery_postgres
--echo #
CREATE DATABASE `db_200989_ZenQuery_postgres`;
USE `db_200989_ZenQuery_postgres`;
CREATE TABLE `database_connections` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `url` CHAR(50),
  `username` CHAR(50),
  `password` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queries` (
  `id` INT NOT NULL,
  `key` CHAR(50),
  `database_connection_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `query_versions` (
  `id` INT NOT NULL,
  `content` CHAR(50),
  `version` INT,
  `is_current_version` BOOLEAN,
  `query_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_200989_ZenQuery_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_200989_ZenQuery_postgres') AS relationships;
DROP DATABASE `db_200989_ZenQuery_postgres`;
UNINSTALL EXTENSION vsql_schematron;
