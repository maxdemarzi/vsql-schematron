INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094197_1443044703
--echo #
CREATE DATABASE `db_094197_1443044703`;
USE `db_094197_1443044703`;
CREATE TABLE `language` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `label` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `collection` (
  `id` INT NOT NULL,
  `language_id` INT,
  `name` VARCHAR(50),
  `label` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `field` (
  `id` INT NOT NULL,
  `collection_id` INT,
  `language_id` INT,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `value` TEXT,
  `label` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
  `id` INT NOT NULL,
  `text` TEXT,
  `field_id` INT,
  `language_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094197_1443044703') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094197_1443044703') AS relationships;
DROP DATABASE `db_094197_1443044703`;
UNINSTALL EXTENSION vsql_schematron;
