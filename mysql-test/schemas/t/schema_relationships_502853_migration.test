INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 502853_migration
--echo #
CREATE DATABASE `db_502853_migration`;
USE `db_502853_migration`;
CREATE TABLE `Symbol` (
  `id` VARCHAR(50) NOT NULL,
  `symbol` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Price` (
  `id` VARCHAR(50) NOT NULL,
  `symbolId` TEXT,
  `date` TIMESTAMP NULL,
  `realDate` TIMESTAMP NULL,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Candle` (
  `id` VARCHAR(50) NOT NULL,
  `symbolId` TEXT,
  `interval` VARCHAR(50),
  `openTime` TIMESTAMP NULL,
  `open` DECIMAL(10,2),
  `high` DECIMAL(10,2),
  `low` DECIMAL(10,2),
  `close` DECIMAL(10,2),
  `volume` DECIMAL(10,2),
  `closeTime` TIMESTAMP NULL,
  `quoteVolume` DECIMAL(10,2),
  `trades` INT,
  `baseAssetVolume` DECIMAL(10,2),
  `quoteAssetVolume` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_502853_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_502853_migration') AS relationships;
DROP DATABASE `db_502853_migration`;
UNINSTALL EXTENSION vsql_schematron;
