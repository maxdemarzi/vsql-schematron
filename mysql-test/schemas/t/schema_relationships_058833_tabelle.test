INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058833_tabelle
--echo #
CREATE DATABASE `db_058833_tabelle`;
USE `db_058833_tabelle`;
CREATE TABLE `a.tab_a` (
  `tab_a_id` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`tab_a_id`)
) CHARACTER SET latin1;
CREATE TABLE `b.tab_b` (
  `ref_tab_a_id` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058833_tabelle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058833_tabelle') AS relationships;
DROP DATABASE `db_058833_tabelle`;
UNINSTALL EXTENSION vsql_schematron;
