INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 509272_actions.sqlite
--echo #
CREATE DATABASE `db_509272_actions_sqlite`;
USE `db_509272_actions_sqlite`;
CREATE TABLE `scopes` (
  `id` INT NOT NULL,
  `scope` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `illuminance` (
  `level` INT NOT NULL,
  `scopeid` INT NOT NULL,
  `delay` INT,
  `action` TEXT,
  PRIMARY KEY (`level`, `scopeid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_509272_actions_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_509272_actions_sqlite') AS relationships;
DROP DATABASE `db_509272_actions_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
