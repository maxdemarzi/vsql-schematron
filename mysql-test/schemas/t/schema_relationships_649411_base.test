INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 649411_base
--echo #
CREATE DATABASE `db_649411_base`;
USE `db_649411_base`;
CREATE TABLE `amb_sender` (
  `senderID` INT NOT NULL,
  `senderName` VARCHAR(50),
  `senderAddress` VARCHAR(50),
  `senderPassword` VARCHAR(50),
  `salt` VARCHAR(50),
  PRIMARY KEY (`senderID`)
) CHARACTER SET latin1;
CREATE TABLE `amb_outgoing` (
  `messageID` INT NOT NULL,
  `recipient` VARCHAR(50),
  `subject` VARCHAR(50),
  `body` TEXT,
  `sendDate` TIMESTAMP NULL,
  PRIMARY KEY (`messageID`)
) CHARACTER SET latin1;
CREATE TABLE `amb_attachment` (
  `attachmentID` INT NOT NULL,
  `messageID` INT,
  `fileURL` VARCHAR(50),
  PRIMARY KEY (`attachmentID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_649411_base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_649411_base') AS relationships;
DROP DATABASE `db_649411_base`;
UNINSTALL EXTENSION vsql_schematron;
