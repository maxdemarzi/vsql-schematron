INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352098_sqlscript
--echo #
CREATE DATABASE `db_352098_sqlscript`;
USE `db_352098_sqlscript`;
CREATE TABLE `town` (
  `town_id` INT NOT NULL,
  `silver` INT,
  `iron` INT,
  `wood` INT,
  `spearman` INT,
  `townhall` INT,
  `barrack` INT,
  `raidinghut` INT,
  `woodcutter` INT,
  `ironmine` INT,
  `farm` INT,
  `x` INT,
  `y` INT,
  `townname` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`town_id`)
) CHARACTER SET latin1;
CREATE TABLE `attack` (
  `attack_id` INT NOT NULL,
  `attackerTown` INT,
  `defenderTown` INT,
  `eta` INT,
  PRIMARY KEY (`attack_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352098_sqlscript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352098_sqlscript') AS relationships;
DROP DATABASE `db_352098_sqlscript`;
UNINSTALL EXTENSION vsql_schematron;
