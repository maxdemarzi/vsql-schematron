INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204955_%E5%A4%9A%E8%A1%A8%E6%9F%A5%E8%AF%A2
--echo #
CREATE DATABASE `db_204955__E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2`;
USE `db_204955__E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2`;
CREATE TABLE `dept` (
  `id` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emp` (
  `id` INT NOT NULL,
  `NAME` VARCHAR(50),
  `gender` CHAR(50),
  `salary` DOUBLE,
  `join_date` DATE,
  `dept_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204955__E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204955__E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2') AS relationships;
DROP DATABASE `db_204955__E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2`;
UNINSTALL EXTENSION vsql_schematron;
