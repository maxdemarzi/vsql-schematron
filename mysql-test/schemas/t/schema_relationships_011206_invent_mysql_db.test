INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011206_invent.mysql.db
--echo #
CREATE DATABASE `db_011206_invent_mysql_db`;
USE `db_011206_invent_mysql_db`;
CREATE TABLE `unidades` (
  `id` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categorias` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `productos` (
  `id` INT NOT NULL,
  `codigo` VARCHAR(50),
  `nombre` VARCHAR(50),
  `marca` VARCHAR(50),
  `unidad_id` VARCHAR(50),
  `categoria_id` INT,
  `precio` DECIMAL(10,2),
  `fecha_registro` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011206_invent_mysql_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011206_invent_mysql_db') AS relationships;
DROP DATABASE `db_011206_invent_mysql_db`;
UNINSTALL EXTENSION vsql_schematron;
