INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 399417_mysql_db_init
--echo #
CREATE DATABASE `db_399417_mysql_db_init`;
USE `db_399417_mysql_db_init`;
CREATE TABLE `languages` (
  `id` INT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `sort` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` INT NOT NULL,
  `file` VARCHAR(50),
  `crc32` BIGINT,
  `archive` VARCHAR(50),
  `size` BIGINT,
  `format` VARCHAR(50),
  `title` VARCHAR(50),
  `sort` VARCHAR(50),
  `year` VARCHAR(50),
  `language_id` INT,
  `plot` VARCHAR(50),
  `cover` VARCHAR(50),
  `updated` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_authors` (
  `id` INT NOT NULL,
  `book_id` INT,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_genres` (
  `id` INT NOT NULL,
  `book_id` INT,
  `genre_code` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_series` (
  `id` INT NOT NULL,
  `serie_num` INT,
  `book_id` INT,
  `serie_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_399417_mysql_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_399417_mysql_db_init') AS relationships;
DROP DATABASE `db_399417_mysql_db_init`;
UNINSTALL EXTENSION vsql_schematron;
