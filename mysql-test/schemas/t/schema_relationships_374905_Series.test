INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 374905_Series
--echo #
CREATE DATABASE `db_374905_Series`;
USE `db_374905_Series`;
CREATE TABLE `diffuseurs` (
  `code` VARCHAR(50) NOT NULL,
  `nom` TEXT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
  `id` INT NOT NULL,
  `titre` TEXT,
  `diffuseur` CHAR(50),
  `nbSaisons` INT,
  `nbEpisodes` INT,
  `nbEpisodesVus` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_374905_Series') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_374905_Series') AS relationships;
DROP DATABASE `db_374905_Series`;
UNINSTALL EXTENSION vsql_schematron;
