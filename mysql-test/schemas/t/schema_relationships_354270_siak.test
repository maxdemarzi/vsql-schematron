INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354270_siak
--echo #
CREATE DATABASE `db_354270_siak`;
USE `db_354270_siak`;
CREATE TABLE `akun` (
  `no_reff` INT,
  `id_user` INT,
  `nama_reff` VARCHAR(50),
  `keterangan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `transaksi` (
  `id_transaksi` INT,
  `id_user` INT,
  `no_reff` INT,
  `tgl_input` DATETIME,
  `tgl_transaksi` DATE,
  `jenis_saldo` VARCHAR(50),
  `saldo` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `nama` VARCHAR(50),
  `jk` VARCHAR(50),
  `alamat` VARCHAR(50),
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `last_login` DATETIME,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354270_siak') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354270_siak') AS relationships;
DROP DATABASE `db_354270_siak`;
UNINSTALL EXTENSION vsql_schematron;
