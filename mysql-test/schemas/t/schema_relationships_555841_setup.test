INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555841_setup
--echo #
CREATE DATABASE `db_555841_setup`;
USE `db_555841_setup`;
CREATE TABLE `quiz` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
  `id` VARCHAR(50) NOT NULL,
  `quizId` VARCHAR(50),
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
  `id` VARCHAR(50) NOT NULL,
  `questionId` VARCHAR(50),
  `text` TEXT,
  `correct` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555841_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555841_setup') AS relationships;
DROP DATABASE `db_555841_setup`;
UNINSTALL EXTENSION vsql_schematron;
