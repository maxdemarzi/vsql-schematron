INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 246103_database
--echo #
CREATE DATABASE `db_246103_database`;
USE `db_246103_database`;
CREATE TABLE `LOGIN` (
  `LOGIN_ID` INT NOT NULL,
  `LOGIN_EMAIL` TEXT,
  `LOGIN_PASSWORD` TEXT,
  PRIMARY KEY (`LOGIN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `USERS` (
  `USER_ID` INT NOT NULL,
  `USER_FNAME` VARCHAR(50),
  `USER_LNAME` VARCHAR(50),
  `USER_PROFESSION` TEXT,
  `USER_PHONE_NO` VARCHAR(50),
  `USER_LOCATION` TEXT,
  `USER_LOGIN_ID` INT,
  `USER_JOIN_DATE` DATE,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORIES` (
  `CATEGORY_ID` INT NOT NULL,
  `CATEGORY_ICON` VARCHAR(50),
  `CATEGORY_NAME` VARCHAR(50),
  `CATEGORY_DEFAULT_IMAGE` VARCHAR(50),
  `CATEGORY_NO_OF_POSTS` INT,
  PRIMARY KEY (`CATEGORY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BLOGS` (
  `BLOG_ID` INT NOT NULL,
  `BLOG_CATEGORY` TEXT,
  `BLOG_TITLE` TEXT,
  `BLOG_POST_DATE` DATE,
  `BLOG_AUTHOR` VARCHAR(50),
  `BLOG_IMAGE` VARCHAR(50),
  `BLOG_CONTENT` VARCHAR(50),
  `BLOG_USER_ID` INT,
  `BLOG_CATEGORY_ID` INT,
  PRIMARY KEY (`BLOG_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_246103_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_246103_database') AS relationships;
DROP DATABASE `db_246103_database`;
UNINSTALL EXTENSION vsql_schematron;
