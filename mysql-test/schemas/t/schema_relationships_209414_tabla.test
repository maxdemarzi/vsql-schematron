INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 209414_tabla
--echo #
CREATE DATABASE `db_209414_tabla`;
USE `db_209414_tabla`;
CREATE TABLE `clases` (
  `cod` DECIMAL(10,2) NOT NULL,
  `nombre` VARCHAR(50),
  `ingresos` DECIMAL(10,2),
  `num_pob` DECIMAL(10,2),
  PRIMARY KEY (`cod`)
) CHARACTER SET latin1;
CREATE TABLE `personajes` (
  `id` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `fechanac` DATE,
  `cp` VARCHAR(50),
  `sexo` VARCHAR(50),
  `patrimonio` DECIMAL(10,2),
  `clase` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_209414_tabla') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_209414_tabla') AS relationships;
DROP DATABASE `db_209414_tabla`;
UNINSTALL EXTENSION vsql_schematron;
