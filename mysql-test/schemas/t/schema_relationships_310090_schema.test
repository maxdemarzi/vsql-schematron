INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 310090_schema
--echo #
CREATE DATABASE `db_310090_schema`;
USE `db_310090_schema`;
CREATE TABLE `paper` (
  `id` INT NOT NULL,
  `title` TEXT,
  `authors` TEXT,
  `abstract` TEXT,
  `venue` TEXT,
  `year` INT,
  `doi` TEXT,
  `source` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `remark` (
  `id` INT NOT NULL,
  `paper_id` INT,
  `created` TIMESTAMP NULL,
  `author` TEXT,
  `acceptance` INT,
  `inclusion_note` TEXT,
  `exclusion_note` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_310090_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_310090_schema') AS relationships;
DROP DATABASE `db_310090_schema`;
UNINSTALL EXTENSION vsql_schematron;
