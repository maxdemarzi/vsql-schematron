INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045585_a
--echo #
CREATE DATABASE `db_045585_a`;
USE `db_045585_a`;
CREATE TABLE `person` (
  `id` INT NOT NULL,
  `name` TEXT,
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `detective` (
  `id` INT NOT NULL,
  `person_id` INT,
  `toys` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045585_a') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045585_a') AS relationships;
DROP DATABASE `db_045585_a`;
UNINSTALL EXTENSION vsql_schematron;
