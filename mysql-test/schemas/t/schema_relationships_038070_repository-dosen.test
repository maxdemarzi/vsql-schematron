INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038070_repository-dosen
--echo #
CREATE DATABASE `db_038070_repository_dosen`;
USE `db_038070_repository_dosen`;
CREATE TABLE `masterfaculty` (
  `idFaculty` VARCHAR(50) NOT NULL,
  `nameFaculty` VARCHAR(50),
  PRIMARY KEY (`idFaculty`)
) CHARACTER SET latin1;
CREATE TABLE `masterlecture` (
  `idLecture` VARCHAR(50) NOT NULL,
  `nameLecture` VARCHAR(50),
  PRIMARY KEY (`idLecture`)
) CHARACTER SET latin1;
CREATE TABLE `mastermajor` (
  `idMajor` VARCHAR(50) NOT NULL,
  `nameMajor` VARCHAR(50),
  `idFaculty` VARCHAR(50),
  PRIMARY KEY (`idMajor`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038070_repository_dosen') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038070_repository_dosen') AS relationships;
DROP DATABASE `db_038070_repository_dosen`;
UNINSTALL EXTENSION vsql_schematron;
