INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 595447_dbinfox
--echo #
CREATE DATABASE `db_595447_dbinfox`;
USE `db_595447_dbinfox`;
CREATE TABLE `tbclientes` (
  `idcli` INT NOT NULL,
  `nomecli` VARCHAR(50),
  `endcli` VARCHAR(50),
  `fonecli` VARCHAR(50),
  `emailcli` VARCHAR(50),
  PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
  `os` INT NOT NULL,
  `data_os` TIMESTAMP NULL,
  `equipamento` VARCHAR(50),
  `defeito` VARCHAR(50),
  `servico` VARCHAR(50),
  `tecnico` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `idcli` INT,
  PRIMARY KEY (`os`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_595447_dbinfox') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_595447_dbinfox') AS relationships;
DROP DATABASE `db_595447_dbinfox`;
UNINSTALL EXTENSION vsql_schematron;
