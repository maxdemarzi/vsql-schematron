INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 411984_projectsdb
--echo #
CREATE DATABASE `db_411984_projectsdb`;
USE `db_411984_projectsdb`;
CREATE TABLE `pf_usuarios` (
  `ID_USUARIO` VARCHAR(50) NOT NULL,
  `NOMBRE` VARCHAR(50),
  `APELLIDO` VARCHAR(50),
  `USUARIO` VARCHAR(50),
  `CLAVE` VARCHAR(50),
  PRIMARY KEY (`ID_USUARIO`)
) CHARACTER SET latin1;
CREATE TABLE `pf_usuarios_resultados` (
  `ID_USUARIO_RESULTADO` VARCHAR(50),
  `ID_USUARIO` VARCHAR(50),
  `TIEMPO` VARCHAR(50),
  `CANTIDAD_MOVIMIENTOS` INT,
  `PORCENTAJE_COMPLETADO` INT,
  `DIFICULTAD` VARCHAR(50),
  `FECHA` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_411984_projectsdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_411984_projectsdb') AS relationships;
DROP DATABASE `db_411984_projectsdb`;
UNINSTALL EXTENSION vsql_schematron;
