INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 222641_Pivot%20and%20other%20mysql%20fun
--echo #
CREATE DATABASE `db_222641_Pivot_20and_20other_20mysql_20fun`;
USE `db_222641_Pivot_20and_20other_20mysql_20fun`;
CREATE TABLE `products` (
  `prod_id` INT NOT NULL,
  `prod_name` VARCHAR(50),
  PRIMARY KEY (`prod_id`)
) CHARACTER SET latin1;
CREATE TABLE `reps` (
  `rep_id` INT NOT NULL,
  `rep_name` VARCHAR(50),
  PRIMARY KEY (`rep_id`)
) CHARACTER SET latin1;
CREATE TABLE `sales` (
  `prod_id` INT NOT NULL,
  `rep_id` INT NOT NULL,
  `sale_date` DATETIME NOT NULL,
  `quantity` INT,
  PRIMARY KEY (`prod_id`, `rep_id`, `sale_date`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_222641_Pivot_20and_20other_20mysql_20fun') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_222641_Pivot_20and_20other_20mysql_20fun') AS relationships;
DROP DATABASE `db_222641_Pivot_20and_20other_20mysql_20fun`;
UNINSTALL EXTENSION vsql_schematron;
