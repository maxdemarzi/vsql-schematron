INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302931_init
--echo #
CREATE DATABASE `db_302931_init`;
USE `db_302931_init`;
CREATE TABLE `USERS` (
  `USERNAME` VARCHAR(50) NOT NULL,
  `PASSWORD` VARCHAR(50),
  `ENABLED` TINYINT,
  PRIMARY KEY (`USERNAME`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHORITIES` (
  `USERNAME` VARCHAR(50),
  `AUTHORITY` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302931_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302931_init') AS relationships;
DROP DATABASE `db_302931_init`;
UNINSTALL EXTENSION vsql_schematron;
