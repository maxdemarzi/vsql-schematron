INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema
--echo #
CREATE DATABASE `db_076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema`;
USE `db_076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema`;
CREATE TABLE `ShowInfo` (
  `show_id` INT NOT NULL,
  `title` TEXT,
  `director` TEXT,
  `musical_director` TEXT,
  `show_info` TEXT,
  `page_live_date` DATETIME,
  `reserve_live_date` DATETIME,
  PRIMARY KEY (`show_id`)
) CHARACTER SET latin1;
CREATE TABLE `Performances` (
  `show_id` INT,
  `p_id` INT NOT NULL,
  `date_time` DATETIME,
  `tickets` INT,
  `reserves` INT,
  PRIMARY KEY (`p_id`)
) CHARACTER SET latin1;
CREATE TABLE `Attendees` (
  `p_id` INT,
  `name` TEXT,
  `email` TEXT
) CHARACTER SET latin1;
CREATE TABLE `Reserves` (
  `show_id` INT,
  `name` TEXT,
  `tickets_alloted` INT,
  `email` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema') AS relationships;
DROP DATABASE `db_076964_12f06ab11fd5723bb9f2e3cee2050bec7fe52b9eschema`;
UNINSTALL EXTENSION vsql_schematron;
