INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067414_chirp.ddl
--echo #
CREATE DATABASE `db_067414_chirp_ddl`;
USE `db_067414_chirp_ddl`;
CREATE TABLE `AUTHOR` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MICROBLOG` (
  `ID` INT NOT NULL,
  `AUTHOR_ID` INT,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHIRP` (
  `ID` INT NOT NULL,
  `MICROBLOG_ID` INT,
  `CONTENT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067414_chirp_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067414_chirp_ddl') AS relationships;
DROP DATABASE `db_067414_chirp_ddl`;
UNINSTALL EXTENSION vsql_schematron;
