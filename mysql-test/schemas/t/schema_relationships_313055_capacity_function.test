INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 313055_capacity_function
--echo #
CREATE DATABASE `db_313055_capacity_function`;
USE `db_313055_capacity_function`;
CREATE TABLE `personality_cluster_info` (
  `id` INT NOT NULL,
  `cluster_type` VARCHAR(50),
  `creation_date` DATE,
  `personality_stage_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `personality_esx_cluster_info` (
  `personality_cluster_info_id` INT NOT NULL,
  `vmhost_capacity_function` VARCHAR(50),
  PRIMARY KEY (`personality_cluster_info_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_313055_capacity_function') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_313055_capacity_function') AS relationships;
DROP DATABASE `db_313055_capacity_function`;
UNINSTALL EXTENSION vsql_schematron;
