INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 141724_data
--echo #
CREATE DATABASE `db_141724_data`;
USE `db_141724_data`;
CREATE TABLE `Customer` (
  `email` VARCHAR(50) NOT NULL,
  `firstName` CHAR(50),
  `lastName` CHAR(50),
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
  `eID` INT NOT NULL,
  `firstName` CHAR(50),
  `lastName` CHAR(50),
  PRIMARY KEY (`eID`)
) CHARACTER SET latin1;
CREATE TABLE `Process_Purchase_Membership` (
  `mID` INT NOT NULL,
  `cost` DOUBLE,
  `email` CHAR(50),
  `purchaseDate` DATE,
  `confirmationNum` INT,
  `eID` INT,
  PRIMARY KEY (`mID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_141724_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_141724_data') AS relationships;
DROP DATABASE `db_141724_data`;
UNINSTALL EXTENSION vsql_schematron;
