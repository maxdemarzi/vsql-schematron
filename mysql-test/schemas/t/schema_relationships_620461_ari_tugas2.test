INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620461_ari_tugas2
--echo #
CREATE DATABASE `db_620461_ari_tugas2`;
USE `db_620461_ari_tugas2`;
CREATE TABLE `role` (
  `id_role` INT NOT NULL,
  `nama_role` VARCHAR(50),
  PRIMARY KEY (`id_role`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT,
  `nama` VARCHAR(50),
  `alamat` VARCHAR(50),
  `email` VARCHAR(50),
  `telepon` VARCHAR(50),
  `id_role` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620461_ari_tugas2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620461_ari_tugas2') AS relationships;
DROP DATABASE `db_620461_ari_tugas2`;
UNINSTALL EXTENSION vsql_schematron;
