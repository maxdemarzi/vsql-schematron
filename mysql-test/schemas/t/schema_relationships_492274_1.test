INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492274_1
--echo #
CREATE DATABASE `db_492274_1`;
USE `db_492274_1`;
CREATE TABLE `POLLS` (
  `id` BIGINT NOT NULL,
  `owner_id` BIGINT,
  `description` VARCHAR(50),
  `hash_tag` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CHOICES` (
  `id` BIGINT NOT NULL,
  `poll_id` BIGINT,
  `description` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `RESPONSES` (
  `id` BIGINT NOT NULL,
  `twitter_user_id` BIGINT,
  `poll_id` BIGINT,
  `choice_id` BIGINT,
  `explanation` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TARGETS` (
  `id` BIGINT NOT NULL,
  `twitter_user_id` BIGINT,
  `poll_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492274_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492274_1') AS relationships;
DROP DATABASE `db_492274_1`;
UNINSTALL EXTENSION vsql_schematron;
