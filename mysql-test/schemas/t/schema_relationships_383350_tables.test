INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383350_tables
--echo #
CREATE DATABASE `db_383350_tables`;
USE `db_383350_tables`;
CREATE TABLE `Rooms` (
  `id` INT NOT NULL,
  `idHotel` INT,
  `roomNumber` VARCHAR(50),
  `maxCapacity` INT,
  `rate` DOUBLE,
  `phoneExtension` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Bookings` (
  `id` INT NOT NULL,
  `idRoom` INT,
  `startDate` DATETIME,
  `endDate` DATETIME,
  `created` DATETIME,
  `lastmodified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383350_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383350_tables') AS relationships;
DROP DATABASE `db_383350_tables`;
UNINSTALL EXTENSION vsql_schematron;
