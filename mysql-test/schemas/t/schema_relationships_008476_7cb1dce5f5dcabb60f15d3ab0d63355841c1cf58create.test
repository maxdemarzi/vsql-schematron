INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create
--echo #
CREATE DATABASE `db_008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create`;
USE `db_008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create`;
CREATE TABLE `versions` (
  `id` INT NOT NULL,
  `name` TEXT,
  `major` INT,
  `minor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apis` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `histories` (
  `api_id` INT NOT NULL,
  `version_id` INT NOT NULL,
  `status` INT NOT NULL,
  PRIMARY KEY (`api_id`, `version_id`, `status`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create') AS relationships;
DROP DATABASE `db_008476_7cb1dce5f5dcabb60f15d3ab0d63355841c1cf58create`;
UNINSTALL EXTENSION vsql_schematron;
