INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 424858_veicoli
--echo #
CREATE DATABASE `db_424858_veicoli`;
USE `db_424858_veicoli`;
CREATE TABLE `191125Veicolo` (
  `targa` VARCHAR(50) NOT NULL,
  `descrizione` VARCHAR(50),
  PRIMARY KEY (`targa`)
) CHARACTER SET latin1;
CREATE TABLE `191125Posizione` (
  `veicolo` VARCHAR(50) NOT NULL,
  `data_ora` TIMESTAMP NOT NULL,
  `latitudine` DOUBLE,
  `longitudine` DOUBLE,
  PRIMARY KEY (`veicolo`, `data_ora`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_424858_veicoli') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_424858_veicoli') AS relationships;
DROP DATABASE `db_424858_veicoli`;
UNINSTALL EXTENSION vsql_schematron;
