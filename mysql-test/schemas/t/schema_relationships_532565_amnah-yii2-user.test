INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532565_amnah-yii2-user
--echo #
CREATE DATABASE `db_532565_amnah_yii2_user`;
USE `db_532565_amnah_yii2_user`;
CREATE TABLE `migration` (
  `version` VARCHAR(50) NOT NULL,
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `can_admin` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `role_id` INT,
  `status` SMALLINT,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `auth_key` VARCHAR(50),
  `access_token` VARCHAR(50),
  `logged_in_ip` VARCHAR(50),
  `logged_in_at` TIMESTAMP NULL,
  `created_ip` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `banned_at` TIMESTAMP NULL,
  `banned_reason` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_token` (
  `id` INT NOT NULL,
  `user_id` INT,
  `type` SMALLINT,
  `token` VARCHAR(50),
  `data` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `expired_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
  `id` INT NOT NULL,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `full_name` VARCHAR(50),
  `timezone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_auth` (
  `id` INT NOT NULL,
  `user_id` INT,
  `provider` VARCHAR(50),
  `provider_id` VARCHAR(50),
  `provider_attributes` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532565_amnah_yii2_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532565_amnah_yii2_user') AS relationships;
DROP DATABASE `db_532565_amnah_yii2_user`;
UNINSTALL EXTENSION vsql_schematron;
