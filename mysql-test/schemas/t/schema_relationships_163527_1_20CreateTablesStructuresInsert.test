INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163527_1%20CreateTablesStructuresInsert
--echo #
CREATE DATABASE `db_163527_1_20CreateTablesStructuresInsert`;
USE `db_163527_1_20CreateTablesStructuresInsert`;
CREATE TABLE `bodyes` (
  `id_body` INT NOT NULL,
  `name_body` CHAR(50),
  `description` CHAR(50),
  PRIMARY KEY (`id_body`)
) CHARACTER SET latin1;
CREATE TABLE `engines` (
  `id_engine` INT NOT NULL,
  `name_engine` CHAR(50),
  `description` CHAR(50),
  PRIMARY KEY (`id_engine`)
) CHARACTER SET latin1;
CREATE TABLE `transmissions` (
  `id_transmission` INT NOT NULL,
  `name_transmission` CHAR(50),
  `description` CHAR(50),
  `automate` BOOLEAN,
  `number_gears` INT,
  PRIMARY KEY (`id_transmission`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `id_car` INT NOT NULL,
  `name_car` CHAR(50),
  `description` CHAR(50),
  `id_body` INT,
  `id_engine` INT,
  `id_transmission` INT,
  PRIMARY KEY (`id_car`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163527_1_20CreateTablesStructuresInsert') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163527_1_20CreateTablesStructuresInsert') AS relationships;
DROP DATABASE `db_163527_1_20CreateTablesStructuresInsert`;
UNINSTALL EXTENSION vsql_schematron;
