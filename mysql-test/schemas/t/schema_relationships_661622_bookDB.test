INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 661622_bookDB
--echo #
CREATE DATABASE `db_661622_bookDB`;
USE `db_661622_bookDB`;
CREATE TABLE `t_user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_order` (
  `order_id` VARCHAR(50) NOT NULL,
  `create_time` DATETIME,
  `price` DECIMAL(10,2),
  `status` INT,
  `user_id` INT,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_order_item` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `count` INT,
  `price` DECIMAL(10,2),
  `total_price` DECIMAL(10,2),
  `order_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_661622_bookDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_661622_bookDB') AS relationships;
DROP DATABASE `db_661622_bookDB`;
UNINSTALL EXTENSION vsql_schematron;
