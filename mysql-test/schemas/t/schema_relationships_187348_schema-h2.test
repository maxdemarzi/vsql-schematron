INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187348_schema-h2
--echo #
CREATE DATABASE `db_187348_schema_h2`;
USE `db_187348_schema_h2`;
CREATE TABLE `auditevent` (
  `id` BIGINT NOT NULL,
  `uuid` VARCHAR(50),
  `principal` VARCHAR(50),
  `eventName` VARCHAR(50),
  `eventType` VARCHAR(50),
  `eventTime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auditcontext` (
  `id` BIGINT NOT NULL,
  `contextName` VARCHAR(50),
  `contextValue` VARCHAR(50),
  `auditEventId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187348_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187348_schema_h2') AS relationships;
DROP DATABASE `db_187348_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
