INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 403098_migration
--echo #
CREATE DATABASE `db_403098_migration`;
USE `db_403098_migration`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `email` TEXT,
  `flags` TEXT,
  `registered_on` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
  `game_id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `short_name` TEXT,
  `link` TEXT,
  PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `areas` (
  `area_id` INT NOT NULL,
  `name` TEXT,
  `game_id` INT,
  PRIMARY KEY (`area_id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `room_id` INT NOT NULL,
  `name` TEXT,
  `link` TEXT,
  `area_id` INT,
  PRIMARY KEY (`room_id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `category_id` INT NOT NULL,
  `name` TEXT,
  `glitched` INT,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `strats` (
  `strat_id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `link` TEXT,
  `difficulty` INT,
  `created_on` TIMESTAMP NULL,
  `area_id` INT,
  `user_id` INT,
  `category_id` INT,
  `room_id` INT,
  `game_id` INT,
  PRIMARY KEY (`strat_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_403098_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_403098_migration') AS relationships;
DROP DATABASE `db_403098_migration`;
UNINSTALL EXTENSION vsql_schematron;
