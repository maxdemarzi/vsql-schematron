INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 396821_migration
--echo #
CREATE DATABASE `db_396821_migration`;
USE `db_396821_migration`;
CREATE TABLE `Admin` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `nome` TEXT,
  `email` TEXT,
  `senha` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessao` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `valido` BOOLEAN,
  `token` TEXT,
  `adminId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Obra` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `categoria` VARCHAR(50),
  `numeroLicitacao` TEXT,
  `descricao` TEXT,
  `convenioNumeroAno` TEXT,
  `convenioConcedente` TEXT,
  `convenioRepasse` DOUBLE,
  `convenioContrapartida` DOUBLE,
  `contratadoCpfCcnpj` TEXT,
  `contratadoRasaoSocial` TEXT,
  `contratoNumeroAno` TEXT,
  `contratoDataInicio` TEXT,
  `contratoPrazo` TEXT,
  `contratoValorContratado` DOUBLE,
  `contratoDataConclusao` TEXT,
  `aditivoPrazoAditado` TEXT,
  `aditivoValorAditadoAcumulado` TEXT,
  `execucaoReajuste` DOUBLE,
  `execucaoNaturezaDespesa` TEXT,
  `execucaoValorMedidoAcumulado` DOUBLE,
  `execucaoValorPagoAcumuladoPeriodo` DOUBLE,
  `execucaoValorPagoAcumuladoExercicio` DOUBLE,
  `valorPagoAcumulado` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comentario` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `token` TEXT,
  `titulo` TEXT,
  `mensagem` TEXT,
  `nomeUsuario` TEXT,
  `email` TEXT,
  `imagemUrl` TEXT,
  `obraId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Nota` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `token` TEXT,
  `nota` INT,
  `email` TEXT,
  `obraId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Noticia` (
  `id` INT NOT NULL,
  `dataCriacao` TIMESTAMP NULL,
  `dataAtualizacao` TIMESTAMP NULL,
  `token` TEXT,
  `titulo` TEXT,
  `mensagem` TEXT,
  `link` TEXT,
  `imagemUrl` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_396821_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_396821_migration') AS relationships;
DROP DATABASE `db_396821_migration`;
UNINSTALL EXTENSION vsql_schematron;
