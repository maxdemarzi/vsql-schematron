INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553243_orders
--echo #
CREATE DATABASE `db_553243_orders`;
USE `db_553243_orders`;
CREATE TABLE `SALESMAN` (
  `SALESMAN_ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `CITY` VARCHAR(50),
  `COMMISSION` INT,
  PRIMARY KEY (`SALESMAN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
  `CUSTOMER_ID` INT NOT NULL,
  `CUST_NAME` VARCHAR(50),
  `CITY` VARCHAR(50),
  `GRADE` INT,
  `SALESMAN_ID` INT,
  PRIMARY KEY (`CUSTOMER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
  `ORD_NO` INT NOT NULL,
  `PURCHASE_AMT` INT,
  `ORD_DATE` DATE,
  `CUSTOMER_ID` INT,
  `SALESMAN_ID` INT,
  PRIMARY KEY (`ORD_NO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553243_orders') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553243_orders') AS relationships;
DROP DATABASE `db_553243_orders`;
UNINSTALL EXTENSION vsql_schematron;
