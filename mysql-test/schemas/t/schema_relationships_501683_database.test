INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501683_database
--echo #
CREATE DATABASE `db_501683_database`;
USE `db_501683_database`;
CREATE TABLE `reservations` (
  `reservation_id` INT NOT NULL,
  `user_id` INT,
  `room_id` INT,
  `booking_date` DATE,
  `no_adults` INT,
  `no_children` INT,
  `reservation_created` TIMESTAMP NULL,
  PRIMARY KEY (`reservation_id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
  `payment_id` INT NOT NULL,
  `user_id` INT,
  `reservation_id` INT,
  `currency` VARCHAR(50),
  `method` VARCHAR(50),
  `amount` INT,
  PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501683_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501683_database') AS relationships;
DROP DATABASE `db_501683_database`;
UNINSTALL EXTENSION vsql_schematron;
