INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 491427_000003_blogs_and_posts.up
--echo #
CREATE DATABASE `db_491427_000003_blogs_and_posts_up`;
USE `db_491427_000003_blogs_and_posts_up`;
CREATE TABLE `blogs` (
  `id_blog` BIGINT NOT NULL,
  `id_user` BIGINT,
  `id_user_plant` BIGINT,
  `name_blog` VARCHAR(50),
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_blog`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id_post` BIGINT NOT NULL,
  `id_blog` BIGINT,
  `text_post` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_post`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_491427_000003_blogs_and_posts_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_491427_000003_blogs_and_posts_up') AS relationships;
DROP DATABASE `db_491427_000003_blogs_and_posts_up`;
UNINSTALL EXTENSION vsql_schematron;
