INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 593344_HeadFirstSQL%20-%20BankAccount
--echo #
CREATE DATABASE `db_593344_HeadFirstSQL_20__20BankAccount`;
USE `db_593344_HeadFirstSQL_20__20BankAccount`;
CREATE TABLE `users` (
  `account_id` INT NOT NULL,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `address` VARCHAR(50),
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `checking` (
  `account_id` INT,
  `balance` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `savings` (
  `account_id` INT,
  `balance` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_593344_HeadFirstSQL_20__20BankAccount') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_593344_HeadFirstSQL_20__20BankAccount') AS relationships;
DROP DATABASE `db_593344_HeadFirstSQL_20__20BankAccount`;
UNINSTALL EXTENSION vsql_schematron;
