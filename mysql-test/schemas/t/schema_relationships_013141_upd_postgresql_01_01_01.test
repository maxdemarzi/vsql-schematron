INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013141_upd_postgresql_01_01_01
--echo #
CREATE DATABASE `db_013141_upd_postgresql_01_01_01`;
USE `db_013141_upd_postgresql_01_01_01`;
CREATE TABLE `configurationsetting` (
  `settingkey` VARCHAR(50) NOT NULL,
  `settingvalue` TEXT,
  PRIMARY KEY (`settingkey`)
) CHARACTER SET latin1;
CREATE TABLE `instanceparameter` (
  `tkey` BIGINT NOT NULL,
  `serviceinstance_tkey` BIGINT,
  `parameterkey` VARCHAR(50),
  `parametervalue` TEXT,
  PRIMARY KEY (`tkey`)
) CHARACTER SET latin1;
CREATE TABLE `serviceinstance` (
  `tkey` BIGINT NOT NULL,
  `subscriptionid` VARCHAR(50),
  `organizationid` VARCHAR(50),
  `defaultlocale` VARCHAR(50),
  `besloginurl` VARCHAR(50),
  `baseurl` VARCHAR(50),
  `organizationname` VARCHAR(50),
  `requesttime` BIGINT,
  `provisioningstatus` VARCHAR(50),
  `iaasinstanceid` VARCHAR(50),
  `serviceaccessinfo` VARCHAR(50),
  `servicebaseurl` VARCHAR(50),
  `serviceloginpath` VARCHAR(50),
  `locked` BOOLEAN,
  `runwithtimer` BOOLEAN,
  PRIMARY KEY (`tkey`)
) CHARACTER SET latin1;
CREATE TABLE `version` (
  `productmajorversion` INT,
  `productminorversion` INT,
  `schemaversion` INT,
  `migrationdate` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `hibernate_sequences` (
  `sequence_name` VARCHAR(50),
  `sequence_next_hi_value` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013141_upd_postgresql_01_01_01') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013141_upd_postgresql_01_01_01') AS relationships;
DROP DATABASE `db_013141_upd_postgresql_01_01_01`;
UNINSTALL EXTENSION vsql_schematron;
