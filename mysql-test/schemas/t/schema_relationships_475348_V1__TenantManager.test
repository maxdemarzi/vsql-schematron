INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 475348_V1__TenantManager
--echo #
CREATE DATABASE `db_475348_V1__TenantManager`;
USE `db_475348_V1__TenantManager`;
CREATE TABLE `tenants` (
  `tenantId` VARCHAR(50) NOT NULL,
  `createdOn` TIMESTAMP NULL,
  `createdBy` VARCHAR(50),
  `organizationId` VARCHAR(50),
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`tenantId`)
) CHARACTER SET latin1;
CREATE TABLE `tenantlimits` (
  `id` BIGINT NOT NULL,
  `resourcetype` VARCHAR(50),
  `resourcelimit` BIGINT,
  `tenantId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_475348_V1__TenantManager') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_475348_V1__TenantManager') AS relationships;
DROP DATABASE `db_475348_V1__TenantManager`;
UNINSTALL EXTENSION vsql_schematron;
