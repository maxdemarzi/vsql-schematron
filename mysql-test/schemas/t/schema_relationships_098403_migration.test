INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098403_migration
--echo #
CREATE DATABASE `db_098403_migration`;
USE `db_098403_migration`;
CREATE TABLE `Student` (
  `id` INT NOT NULL,
  `email` TEXT,
  `firstName` TEXT,
  `lastName` TEXT,
  `role` TEXT,
  `courseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Grade` (
  `id` INT NOT NULL,
  `grade` TEXT,
  `studentId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098403_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098403_migration') AS relationships;
DROP DATABASE `db_098403_migration`;
UNINSTALL EXTENSION vsql_schematron;
