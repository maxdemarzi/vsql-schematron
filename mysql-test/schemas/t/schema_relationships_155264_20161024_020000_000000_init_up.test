INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 155264_20161024_020000.000000_init.up
--echo #
CREATE DATABASE `db_155264_20161024_020000_000000_init_up`;
USE `db_155264_20161024_020000_000000_init_up`;
CREATE TABLE `user_status` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` CHAR(50),
  `status_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `note` (
  `id` INT NOT NULL,
  `name` TEXT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_155264_20161024_020000_000000_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_155264_20161024_020000_000000_init_up') AS relationships;
DROP DATABASE `db_155264_20161024_020000_000000_init_up`;
UNINSTALL EXTENSION vsql_schematron;
