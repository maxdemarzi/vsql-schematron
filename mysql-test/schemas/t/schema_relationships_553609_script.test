INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553609_script
--echo #
CREATE DATABASE `db_553609_script`;
USE `db_553609_script`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `unitary_value` DECIMAL(10,2),
  `qtd_stock` INT,
  `creation_date` DATETIME,
  `update_date` DATETIME,
  `exclusion_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `id` INT NOT NULL,
  `product_id` INT,
  `sale_value` DECIMAL(10,2),
  `date_sale` DATETIME,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553609_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553609_script') AS relationships;
DROP DATABASE `db_553609_script`;
UNINSTALL EXTENSION vsql_schematron;
