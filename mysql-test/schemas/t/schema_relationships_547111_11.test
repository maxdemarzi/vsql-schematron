INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547111_11
--echo #
CREATE DATABASE `db_547111_11`;
USE `db_547111_11`;
CREATE TABLE `adhesion` (
  `id` VARCHAR(50) NOT NULL,
  `period` VARCHAR(50),
  `user_id` VARCHAR(50),
  `accepted` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `adhesion_member` (
  `id` VARCHAR(50) NOT NULL,
  `adhesion` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `birthday` TIMESTAMP NULL,
  `activity` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547111_11') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547111_11') AS relationships;
DROP DATABASE `db_547111_11`;
UNINSTALL EXTENSION vsql_schematron;
