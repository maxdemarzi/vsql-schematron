CREATE TABLE `bulkSms` (
  `id` INT NOT NULL,
  `twilioSid` VARCHAR(50),
  `clientsMatched` INT,
  `clientsWithPhone` INT,
  `leadsMatched` INT,
  `leadsWithPhone` INT,
  `uniquePhoneNumbers` INT,
  `smsBody` VARCHAR(50),
  `addedBy` INT,
  `dateAdded` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bulkSmsRecipients` (
  `id` INT NOT NULL,
  `phone` VARCHAR(50),
  `bulkSmsId` INT,
  `leadId` INT,
  `clientId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
