INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 241822_schema
--echo #
CREATE DATABASE `db_241822_schema`;
USE `db_241822_schema`;
CREATE TABLE `Stocks` (
  `id` VARCHAR(50) NOT NULL,
  `ticker_symbol` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Votes` (
  `stock_id` VARCHAR(50),
  `date` DATE,
  `voter` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
  `stock_id` VARCHAR(50),
  `date` DATE,
  `comment` VARCHAR(50),
  `commenter` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_241822_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_241822_schema') AS relationships;
DROP DATABASE `db_241822_schema`;
UNINSTALL EXTENSION vsql_schematron;
