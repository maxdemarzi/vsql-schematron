INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 182451_AngelCheck
--echo #
CREATE DATABASE `db_182451_AngelCheck`;
USE `db_182451_AngelCheck`;
CREATE TABLE `Address` (
  `Address_ID` INT NOT NULL,
  `Address_1` VARCHAR(50),
  `Address_2` VARCHAR(50),
  `City` VARCHAR(50),
  `St` CHAR(50),
  `Zip` INT,
  PRIMARY KEY (`Address_ID`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `Customer_ID` INT NOT NULL,
  `Email` VARCHAR(50),
  `Phone` INT,
  `First_Name` VARCHAR(50),
  `Last_Name` VARCHAR(50),
  `Address_ID` INT,
  PRIMARY KEY (`Customer_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Suppliers` (
  `Sup_ID` INT NOT NULL,
  `Sup_Name` VARCHAR(50),
  `Website` VARCHAR(50),
  `Email` VARCHAR(50),
  `Address_ID` INT,
  PRIMARY KEY (`Sup_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Guitar_Body` (
  `Body_ID` INT NOT NULL,
  `Body_Shape` VARCHAR(50),
  `Body_Wood` VARCHAR(50),
  `Sup_ID` INT,
  PRIMARY KEY (`Body_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Neck` (
  `Neck_ID` INT NOT NULL,
  `Neck_Wood` VARCHAR(50),
  `Headstock_Format` VARCHAR(50),
  `Sup_ID` INT,
  PRIMARY KEY (`Neck_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_182451_AngelCheck') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_182451_AngelCheck') AS relationships;
DROP DATABASE `db_182451_AngelCheck`;
UNINSTALL EXTENSION vsql_schematron;
