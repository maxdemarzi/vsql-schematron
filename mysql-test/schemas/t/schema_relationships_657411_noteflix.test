INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 657411_noteflix
--echo #
CREATE DATABASE `db_657411_noteflix`;
USE `db_657411_noteflix`;
CREATE TABLE `notes` (
  `id_note` INT NOT NULL,
  `movie_name` VARCHAR(50),
  `movie_note` INT,
  `movie_description` VARCHAR(50),
  `id_user` INT,
  PRIMARY KEY (`id_note`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id_user` INT NOT NULL,
  `email_user` VARCHAR(50),
  `name_user` VARCHAR(50),
  `password_user` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_657411_noteflix') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_657411_noteflix') AS relationships;
DROP DATABASE `db_657411_noteflix`;
UNINSTALL EXTENSION vsql_schematron;
