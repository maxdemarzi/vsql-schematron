INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 221974_populate
--echo #
CREATE DATABASE `db_221974_populate`;
USE `db_221974_populate`;
CREATE TABLE `PERSON` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `AGE` DECIMAL(10,2),
  `IQ` DECIMAL(10,2),
  `BIRTHDAY` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON_FIELDS` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `VALUE` VARCHAR(50),
  `PERSON_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPTY` (
  `NAME` VARCHAR(50),
  `VALUE` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `TYPES` (
  `ID` INT NOT NULL,
  `TIMESTAMP_TYPE` TIMESTAMP NULL,
  `DATETIME_TYPE` VARCHAR(50),
  `DATE_TYPE` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_221974_populate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_221974_populate') AS relationships;
DROP DATABASE `db_221974_populate`;
UNINSTALL EXTENSION vsql_schematron;
