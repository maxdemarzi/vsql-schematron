INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 662255_lab2
--echo #
CREATE DATABASE `db_662255_lab2`;
USE `db_662255_lab2`;
CREATE TABLE `actor` (
  `ACTID` INT NOT NULL,
  `ANAME` VARCHAR(50),
  `SEX` VARCHAR(50),
  `BYEAR` INT,
  PRIMARY KEY (`ACTID`)
) CHARACTER SET latin1;
CREATE TABLE `film` (
  `FID` INT NOT NULL,
  `FNAME` VARCHAR(50),
  `FTYPE` VARCHAR(50),
  `DNAME` VARCHAR(50),
  `FLENGTH` INT,
  `IS3D` VARCHAR(50),
  `GRADE` INT,
  PRIMARY KEY (`FID`)
) CHARACTER SET latin1;
CREATE TABLE `showt` (
  `FID` INT NOT NULL,
  `TID` INT NOT NULL,
  `PRICEC` INT,
  `SYEAR` INT,
  `SMONTH` INT,
  PRIMARY KEY (`FID`, `TID`)
) CHARACTER SET latin1;
CREATE TABLE `theater` (
  `TID` INT NOT NULL,
  `TNAME` VARCHAR(50),
  `TAREA` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  PRIMARY KEY (`TID`)
) CHARACTER SET latin1;
CREATE TABLE `test` (
  `a` INT,
  `b` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_662255_lab2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_662255_lab2') AS relationships;
DROP DATABASE `db_662255_lab2`;
UNINSTALL EXTENSION vsql_schematron;
