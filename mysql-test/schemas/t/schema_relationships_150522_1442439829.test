INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 150522_1442439829
--echo #
CREATE DATABASE `db_150522_1442439829`;
USE `db_150522_1442439829`;
CREATE TABLE `bootstraps` (
  `id` INT NOT NULL,
  `active` VARCHAR(50),
  `name` VARCHAR(50),
  `gray_base` VARCHAR(50),
  `brand_primary` VARCHAR(50),
  `brand_success` VARCHAR(50),
  `brand_info` VARCHAR(50),
  `brand_warning` VARCHAR(50),
  `brand_danger` VARCHAR(50),
  `body_bg` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
  `id` VARCHAR(50) NOT NULL,
  `users_id` VARCHAR(50),
  `title` VARCHAR(50),
  `origin` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `layouts` (
  `id` VARCHAR(50) NOT NULL,
  `slug` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `obligations` (
  `id` VARCHAR(50) NOT NULL,
  `title_cs` VARCHAR(50),
  `title_en` VARCHAR(50),
  `body_cs` TEXT,
  `body_en` TEXT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` VARCHAR(50) NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `settings` (
  `id` VARCHAR(50) NOT NULL,
  `layouts_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_150522_1442439829') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_150522_1442439829') AS relationships;
DROP DATABASE `db_150522_1442439829`;
UNINSTALL EXTENSION vsql_schematron;
