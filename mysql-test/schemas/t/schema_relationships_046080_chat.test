INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046080_chat
--echo #
CREATE DATABASE `db_046080_chat`;
USE `db_046080_chat`;
CREATE TABLE `chat` (
  `chat_id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`chat_id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_user` (
  `id` INT NOT NULL,
  `chat_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046080_chat') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046080_chat') AS relationships;
DROP DATABASE `db_046080_chat`;
UNINSTALL EXTENSION vsql_schematron;
