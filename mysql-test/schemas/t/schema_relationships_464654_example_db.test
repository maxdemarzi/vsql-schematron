INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464654_example_db
--echo #
CREATE DATABASE `db_464654_example_db`;
USE `db_464654_example_db`;
CREATE TABLE `person` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `status` TINYINT,
  `created_at` DATETIME,
  `created_by` INT,
  `updated_at` DATETIME,
  `updated_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `person_id` INT,
  `status` TINYINT,
  `created_at` DATETIME,
  `created_by` INT,
  `updated_at` DATETIME,
  `updated_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464654_example_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464654_example_db') AS relationships;
DROP DATABASE `db_464654_example_db`;
UNINSTALL EXTENSION vsql_schematron;
