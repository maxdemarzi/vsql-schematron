INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325705_db
--echo #
CREATE DATABASE `db_325705_db`;
USE `db_325705_db`;
CREATE TABLE `owner` (
  `photo` VARCHAR(50),
  `first` VARCHAR(50),
  `last` VARCHAR(50),
  `building` VARCHAR(50),
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  `phone` VARCHAR(50),
  `alive` VARCHAR(50),
  `notes` VARCHAR(50),
  `link_to_pet` VARCHAR(50),
  `hide` TINYINT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet` (
  `id` INT NOT NULL,
  `photo` VARCHAR(50),
  `name` VARCHAR(50),
  `breed` VARCHAR(50),
  `species` VARCHAR(50),
  `dob` DATE,
  `shots` DATE,
  `licensed` DATE,
  `sex` VARCHAR(50),
  `neutered` VARCHAR(50),
  `alive` VARCHAR(50),
  `notes` VARCHAR(50),
  `hide` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owner_pet` (
  `id` INT NOT NULL,
  `owner_id` INT,
  `pet_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325705_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325705_db') AS relationships;
DROP DATABASE `db_325705_db`;
UNINSTALL EXTENSION vsql_schematron;
