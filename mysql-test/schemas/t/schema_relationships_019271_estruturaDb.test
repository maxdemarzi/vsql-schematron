INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 019271_estruturaDb
--echo #
CREATE DATABASE `db_019271_estruturaDb`;
USE `db_019271_estruturaDb`;
CREATE TABLE `categoria` (
  `idCategoria` INT NOT NULL,
  `nomeCategoria` VARCHAR(50),
  PRIMARY KEY (`idCategoria`)
) CHARACTER SET latin1;
CREATE TABLE `projeto` (
  `idProjeto` INT NOT NULL,
  `nomeProjeto` VARCHAR(50),
  `idCategoria` INT,
  PRIMARY KEY (`idProjeto`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `idUsuario` INT NOT NULL,
  `nomeUsuario` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone` VARCHAR(50),
  `dataContrato` VARCHAR(50),
  `idProjeto` INT,
  PRIMARY KEY (`idUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `registro` (
  `idRegistro` INT NOT NULL,
  `descricao` VARCHAR(50),
  `timeStart` DATETIME,
  `timeEnd` DATETIME,
  PRIMARY KEY (`idRegistro`)
) CHARACTER SET latin1;
CREATE TABLE `projetoRegistros` (
  `idRegistro` INT,
  `idProjeto` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_019271_estruturaDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_019271_estruturaDb') AS relationships;
DROP DATABASE `db_019271_estruturaDb`;
UNINSTALL EXTENSION vsql_schematron;
