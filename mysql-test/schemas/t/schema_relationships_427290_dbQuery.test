INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 427290_dbQuery
--echo #
CREATE DATABASE `db_427290_dbQuery`;
USE `db_427290_dbQuery`;
CREATE TABLE `person` (
  `PersonId` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`PersonId`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
  `PhoneId` INT NOT NULL,
  `Phone` VARCHAR(50),
  `PersonId` INT,
  PRIMARY KEY (`PhoneId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_427290_dbQuery') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_427290_dbQuery') AS relationships;
DROP DATABASE `db_427290_dbQuery`;
UNINSTALL EXTENSION vsql_schematron;
