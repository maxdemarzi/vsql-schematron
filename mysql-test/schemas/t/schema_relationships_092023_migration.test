INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 092023_migration
--echo #
CREATE DATABASE `db_092023_migration`;
USE `db_092023_migration`;
CREATE TABLE `Country` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `iso2` CHAR(50),
  `iso3` CHAR(50),
  `numeric_code` CHAR(50),
  `phonecode` VARCHAR(50),
  `capital` VARCHAR(50),
  `currency` VARCHAR(50),
  `current_symbol` VARCHAR(50),
  `tld` CHAR(50),
  `native` VARCHAR(50),
  `region` VARCHAR(50),
  `subregion` VARCHAR(50),
  `translations` VARCHAR(50),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `emoji` VARCHAR(50),
  `emojiU` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Timezone` (
  `id` INT NOT NULL,
  `zoneName` VARCHAR(50),
  `gmtOffset` INT,
  `gmtOffSetName` VARCHAR(50),
  `abbreviation` VARCHAR(50),
  `tzName` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `countryId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_092023_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_092023_migration') AS relationships;
DROP DATABASE `db_092023_migration`;
UNINSTALL EXTENSION vsql_schematron;
