INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307979_Aula01
--echo #
CREATE DATABASE `db_307979_Aula01`;
USE `db_307979_Aula01`;
CREATE TABLE `cidade` (
  `nome` VARCHAR(50),
  `cep` VARCHAR(50) NOT NULL,
  `numero_habitantes` DOUBLE,
  `capital` BOOLEAN,
  `estado` VARCHAR(50),
  `renda_per_capta` DECIMAL(10,2),
  `data_fundacao` DATE,
  PRIMARY KEY (`cep`)
) CHARACTER SET latin1;
CREATE TABLE `estado` (
  `nome` VARCHAR(50),
  `sigla` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`sigla`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307979_Aula01') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307979_Aula01') AS relationships;
DROP DATABASE `db_307979_Aula01`;
UNINSTALL EXTENSION vsql_schematron;
