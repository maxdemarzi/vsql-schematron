INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652088_SQL
--echo #
CREATE DATABASE `db_652088_SQL`;
USE `db_652088_SQL`;
CREATE TABLE `podcasts` (
  `id` INT NOT NULL,
  `created` TIMESTAMP NULL,
  `number` VARCHAR(50),
  `title` VARCHAR(50),
  `description` TEXT,
  `cover` VARCHAR(50),
  `duration` VARCHAR(50),
  `duration_type` CHAR(50),
  `link` VARCHAR(50),
  `mp3` VARCHAR(50),
  `published` VARCHAR(50),
  `podcast` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `created` TIMESTAMP NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `podcast_categories` (
  `podcast_id` INT,
  `category_id` INT,
  `created` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652088_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652088_SQL') AS relationships;
DROP DATABASE `db_652088_SQL`;
UNINSTALL EXTENSION vsql_schematron;
