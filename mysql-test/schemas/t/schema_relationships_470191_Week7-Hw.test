INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470191_Week7-Hw
--echo #
CREATE DATABASE `db_470191_Week7_Hw`;
USE `db_470191_Week7_Hw`;
CREATE TABLE `vehicle` (
  `id` INT NOT NULL,
  `make` VARCHAR(50),
  `model` VARCHAR(50),
  `year` INT,
  `description` VARCHAR(50),
  `retailprice` DECIMAL(10,2),
  `availablestarting` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehiclepart` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `partnumber` VARCHAR(50),
  `vehicleid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470191_Week7_Hw') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470191_Week7_Hw') AS relationships;
DROP DATABASE `db_470191_Week7_Hw`;
UNINSTALL EXTENSION vsql_schematron;
