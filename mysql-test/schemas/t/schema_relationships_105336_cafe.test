INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105336_cafe
--echo #
CREATE DATABASE `db_105336_cafe`;
USE `db_105336_cafe`;
CREATE TABLE `compra` (
  `nrofactura` INT NOT NULL,
  `nrosacos` DECIMAL(10,2),
  `pesofinal` DECIMAL(10,2),
  `totalquintales` DECIMAL(10,2),
  `estado` INT,
  `finca` INT,
  `preciolibra` DECIMAL(10,2),
  `totalpagar` DECIMAL(10,2),
  `fecha` DATETIME,
  PRIMARY KEY (`nrofactura`)
) CHARACTER SET latin1;
CREATE TABLE `deposito` (
  `ndeposito` INT NOT NULL,
  `nrosacos` DECIMAL(10,2),
  `pesobruto` DECIMAL(10,2),
  `pesofinal` DECIMAL(10,2),
  `estado` INT,
  `finca` INT,
  PRIMARY KEY (`ndeposito`)
) CHARACTER SET latin1;
CREATE TABLE `fincas` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `propietario` VARCHAR(50),
  `direccion` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estado` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `porcentaje` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105336_cafe') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105336_cafe') AS relationships;
DROP DATABASE `db_105336_cafe`;
UNINSTALL EXTENSION vsql_schematron;
