INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 549726_updates
--echo #
CREATE DATABASE `db_549726_updates`;
USE `db_549726_updates`;
CREATE TABLE `update_messages` (
  `id` VARCHAR(50) NOT NULL,
  `posted` VARCHAR(50),
  `html` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `update_comments` (
  `id` VARCHAR(50) NOT NULL,
  `message` VARCHAR(50),
  `posted` INT,
  `user` VARCHAR(50),
  `name` VARCHAR(50),
  `contacturl` VARCHAR(50),
  `html` TEXT,
  `markdown` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_549726_updates') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_549726_updates') AS relationships;
DROP DATABASE `db_549726_updates`;
UNINSTALL EXTENSION vsql_schematron;
