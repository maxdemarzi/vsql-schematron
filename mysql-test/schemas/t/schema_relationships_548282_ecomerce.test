INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 548282_ecomerce
--echo #
CREATE DATABASE `db_548282_ecomerce`;
USE `db_548282_ecomerce`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `edad` VARCHAR(50),
  `genero` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  `telefono` INT,
  `ciudad` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ventas` (
  `id` INT NOT NULL,
  `idCl` INT,
  `fecha` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `productos` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `descripcion` TEXT,
  `precio` DOUBLE,
  `cantidad` INT,
  `foto1` TEXT,
  `foto2` TEXT,
  `foto3` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `detalleventas` (
  `id` INT NOT NULL,
  `idProd` INT,
  `idVenta` INT,
  `cantidad` INT,
  `precio` DOUBLE,
  `subTotal` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_548282_ecomerce') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_548282_ecomerce') AS relationships;
DROP DATABASE `db_548282_ecomerce`;
UNINSTALL EXTENSION vsql_schematron;
