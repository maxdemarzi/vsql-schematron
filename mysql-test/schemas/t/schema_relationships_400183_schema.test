INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400183_schema
--echo #
CREATE DATABASE `db_400183_schema`;
USE `db_400183_schema`;
CREATE TABLE `MY_SCHEMA.ACCOUNT_TYPE` (
  `ACCOUNT_TYPE_ID` BIGINT NOT NULL,
  `MNEMONIC` VARCHAR(50),
  `ACCOUNT_TYPE_NAME` VARCHAR(50),
  `CREATION_DATE` DATE,
  PRIMARY KEY (`ACCOUNT_TYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MY_SCHEMA.ACCOUNT_TX` (
  `TX_ID` BIGINT NOT NULL,
  `ACCOUNT_TYPE_ID` BIGINT,
  `MEMBER_ID` BIGINT,
  `AMOUNT` BIGINT,
  `TX_DATE` DATE,
  PRIMARY KEY (`TX_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MY_SCHEMA.ACCOUNT_TX_DETAILS` (
  `ACCOUNT_TX_DETAILS_ID` BIGINT NOT NULL,
  `TX_ID` BIGINT,
  `PARTNER_NAME` VARCHAR(50),
  `NUMBER_OF_ITEMS` BIGINT,
  `AMOUNT` BIGINT,
  `TX_DATE` DATE,
  PRIMARY KEY (`ACCOUNT_TX_DETAILS_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400183_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400183_schema') AS relationships;
DROP DATABASE `db_400183_schema`;
UNINSTALL EXTENSION vsql_schematron;
