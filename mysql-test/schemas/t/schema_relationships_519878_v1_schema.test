INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 519878_v1_schema
--echo #
CREATE DATABASE `db_519878_v1_schema`;
USE `db_519878_v1_schema`;
CREATE TABLE `tb_order` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `price` DOUBLE,
  `payment_method` SMALLINT,
  `status` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_order_item` (
  `order_id` BIGINT NOT NULL,
  `item_id` BIGINT NOT NULL,
  `item_count` INT,
  PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_519878_v1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_519878_v1_schema') AS relationships;
DROP DATABASE `db_519878_v1_schema`;
UNINSTALL EXTENSION vsql_schematron;
