INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379037_0-init
--echo #
CREATE DATABASE `db_379037_0_init`;
USE `db_379037_0_init`;
CREATE TABLE `entries` (
  `id` INT NOT NULL,
  `title` TEXT,
  `artist` TEXT,
  `url` TEXT,
  `created_at` INT,
  `genre` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` TEXT,
  `entry_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379037_0_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379037_0_init') AS relationships;
DROP DATABASE `db_379037_0_init`;
UNINSTALL EXTENSION vsql_schematron;
