INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552247_initialization
--echo #
CREATE DATABASE `db_552247_initialization`;
USE `db_552247_initialization`;
CREATE TABLE `classes` (
  `class_id` VARCHAR(50) NOT NULL,
  `grade` INT,
  `section` CHAR(50),
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `student_id` VARCHAR(50) NOT NULL,
  `full_name` VARCHAR(50),
  `class_id` CHAR(50),
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552247_initialization') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552247_initialization') AS relationships;
DROP DATABASE `db_552247_initialization`;
UNINSTALL EXTENSION vsql_schematron;
