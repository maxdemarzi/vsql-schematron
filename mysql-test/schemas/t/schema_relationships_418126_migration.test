INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 418126_migration
--echo #
CREATE DATABASE `db_418126_migration`;
USE `db_418126_migration`;
CREATE TABLE `Blog` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `name` TEXT,
  `viewCount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `name` TEXT,
  `blogId` INT,
  `rating` DOUBLE,
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `title` TEXT,
  `blogId` INT,
  `status` VARCHAR(50),
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
  `id` INT NOT NULL,
  `value` TEXT,
  `postId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_418126_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_418126_migration') AS relationships;
DROP DATABASE `db_418126_migration`;
UNINSTALL EXTENSION vsql_schematron;
