INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352108_curl_comm
--echo #
CREATE DATABASE `db_352108_curl_comm`;
USE `db_352108_curl_comm`;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `create_time` DATETIME,
  `last_update_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `note` (
  `id` VARCHAR(50) NOT NULL,
  `user` VARCHAR(50),
  `title` VARCHAR(50),
  `contents` TEXT,
  `create_time` DATETIME,
  `last_update_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352108_curl_comm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352108_curl_comm') AS relationships;
DROP DATABASE `db_352108_curl_comm`;
UNINSTALL EXTENSION vsql_schematron;
