INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425633_xpto
--echo #
CREATE DATABASE `db_425633_xpto`;
USE `db_425633_xpto`;
CREATE TABLE `accounts` (
  `id` VARCHAR(50) NOT NULL,
  `document_number` VARCHAR(50),
  `credit_limit` DECIMAL(10,2),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `id` VARCHAR(50) NOT NULL,
  `account_id` VARCHAR(50),
  `operation_type` VARCHAR(50),
  `amount` DECIMAL(10,2),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425633_xpto') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425633_xpto') AS relationships;
DROP DATABASE `db_425633_xpto`;
UNINSTALL EXTENSION vsql_schematron;
