INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095823_ddl-medellin
--echo #
CREATE DATABASE `db_095823_ddl_medellin`;
USE `db_095823_ddl_medellin`;
CREATE TABLE `banco_medellin.ciudad` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `banco_medellin.tipo_transaccion` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `banco_medellin.cuenta` (
  `num` INT NOT NULL,
  `cedula` VARCHAR(50),
  `nombre` VARCHAR(50),
  `telefono` VARCHAR(50),
  `saldo` DOUBLE,
  `ciudad` INT,
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095823_ddl_medellin') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095823_ddl_medellin') AS relationships;
DROP DATABASE `db_095823_ddl_medellin`;
UNINSTALL EXTENSION vsql_schematron;
