INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 329504_venta_helado_g1
--echo #
CREATE DATABASE `db_329504_venta_helado_g1`;
USE `db_329504_venta_helado_g1`;
CREATE TABLE `Rol_Usuario` (
  `id_rol` INT NOT NULL,
  `nombre_rol` VARCHAR(50),
  PRIMARY KEY (`id_rol`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario` (
  `id_usuario` INT NOT NULL,
  `id_rol` INT,
  `correo_usuario` VARCHAR(50),
  `password_usuario` VARCHAR(50),
  `nombre_usuario` VARCHAR(50),
  `apellido_usuario` VARCHAR(50),
  `direccion_usuario` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `Categoria` (
  `id_categoria` INT NOT NULL,
  `nombre_categoria` VARCHAR(50),
  `descripcion_categoria` VARCHAR(50),
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `Helado` (
  `id_helado` INT NOT NULL,
  `nombre_helado` VARCHAR(50),
  `precio_helado` DOUBLE,
  `stock_helado` INT,
  `imagen1_helado` VARCHAR(50),
  `imagen2_helado` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `id_categoria` INT,
  PRIMARY KEY (`id_helado`)
) CHARACTER SET latin1;
CREATE TABLE `Ventas` (
  `id_venta` INT NOT NULL,
  `id_usuario` INT,
  `id_helado` INT,
  `fecha` DATETIME,
  `cantidad` INT,
  `precio_total` DOUBLE,
  PRIMARY KEY (`id_venta`)
) CHARACTER SET latin1;
CREATE TABLE `Empresa` (
  `id_empresa` INT NOT NULL,
  `nombre_empresa` VARCHAR(50),
  `slogan_empresa` VARCHAR(50),
  `telefono1_empresa` VARCHAR(50),
  `telefono2_empresa` VARCHAR(50),
  `email1_empresa` VARCHAR(50),
  `email2_empresa` VARCHAR(50),
  `icono_empresa` VARCHAR(50),
  `logo_empresa` VARCHAR(50),
  `ubicacion_empresa` VARCHAR(50),
  `mapa_empresa` VARCHAR(50),
  PRIMARY KEY (`id_empresa`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_329504_venta_helado_g1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_329504_venta_helado_g1') AS relationships;
DROP DATABASE `db_329504_venta_helado_g1`;
UNINSTALL EXTENSION vsql_schematron;
