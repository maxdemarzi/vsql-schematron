INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 183351_createTables
--echo #
CREATE DATABASE `db_183351_createTables`;
USE `db_183351_createTables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `text` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_183351_createTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_183351_createTables') AS relationships;
DROP DATABASE `db_183351_createTables`;
UNINSTALL EXTENSION vsql_schematron;
