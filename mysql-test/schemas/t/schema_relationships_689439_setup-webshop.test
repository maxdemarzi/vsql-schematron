INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 689439_setup-webshop
--echo #
CREATE DATABASE `db_689439_setup_webshop`;
USE `db_689439_setup_webshop`;
CREATE TABLE `ProdCategory` (
  `id` INT NOT NULL,
  `category` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  `image` VARCHAR(50),
  `price` INT,
  `deleted` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Prod2Cat` (
  `id` INT NOT NULL,
  `product_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Inventory` (
  `id` INT NOT NULL,
  `product_id` INT,
  `amount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `InventoryLog` (
  `id` INT NOT NULL,
  `product_id` INT,
  `amount` INT,
  `when` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cart` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CartRow` (
  `id` INT NOT NULL,
  `cart_id` INT,
  `product_id` INT,
  `amount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` INT NOT NULL,
  `user_id` INT,
  `created` TIMESTAMP NULL,
  `updated` DATETIME,
  `deleted` DATETIME,
  `delivery` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderRow` (
  `id` INT NOT NULL,
  `order_id` INT,
  `product_id` INT,
  `amount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_689439_setup_webshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_689439_setup_webshop') AS relationships;
DROP DATABASE `db_689439_setup_webshop`;
UNINSTALL EXTENSION vsql_schematron;
