INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 293163_database
--echo #
CREATE DATABASE `db_293163_database`;
USE `db_293163_database`;
CREATE TABLE `cities` (
  `id` INT NOT NULL,
  `city` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `password` TEXT,
  `city_id` INT,
  `reset_token` TEXT,
  `reset_token_expires` TEXT,
  `is_admin` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `id` INT NOT NULL,
  `room` INT,
  `city_id` INT,
  `limit` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `desks` (
  `id` INT NOT NULL,
  `room_id` INT,
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedules` (
  `id` INT NOT NULL,
  `schedule` TIMESTAMP NULL,
  `user_id` INT,
  `desk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_293163_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_293163_database') AS relationships;
DROP DATABASE `db_293163_database`;
UNINSTALL EXTENSION vsql_schematron;
