INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 244541_esquema
--echo #
CREATE DATABASE `db_244541_esquema`;
USE `db_244541_esquema`;
CREATE TABLE `clientes` (
  `id` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `departamento` VARCHAR(50),
  `edad` INT,
  `fecha_registro` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ventas_clientes` (
  `id` VARCHAR(50) NOT NULL,
  `id_cliente` VARCHAR(50),
  `monto` DECIMAL(10,2),
  `fecha` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_244541_esquema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_244541_esquema') AS relationships;
DROP DATABASE `db_244541_esquema`;
UNINSTALL EXTENSION vsql_schematron;
