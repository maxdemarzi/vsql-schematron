INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 117441_01_create_tables
--echo #
CREATE DATABASE `db_117441_01_create_tables`;
USE `db_117441_01_create_tables`;
CREATE TABLE `BAR_USER_STATUS` (
  `ust_id` VARCHAR(50) NOT NULL,
  `ust_description` VARCHAR(50),
  `ust_label` VARCHAR(50),
  PRIMARY KEY (`ust_id`)
) CHARACTER SET latin1;
CREATE TABLE `BAR_USER` (
  `usr_id` VARCHAR(50) NOT NULL,
  `ust_id` VARCHAR(50),
  `usr_name` VARCHAR(50),
  `usr_password_hash` VARCHAR(50),
  `usr_email` VARCHAR(50),
  PRIMARY KEY (`usr_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_117441_01_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_117441_01_create_tables') AS relationships;
DROP DATABASE `db_117441_01_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
