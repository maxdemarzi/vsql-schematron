INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 455933_16
--echo #
CREATE DATABASE `db_455933_16`;
USE `db_455933_16`;
CREATE TABLE `mission_type` (
  `mission_type_id` INT NOT NULL,
  `mission_type` TEXT,
  PRIMARY KEY (`mission_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `mission` (
  `mission_id` INT NOT NULL,
  `region_id` INT,
  `label` TEXT,
  `level` INT,
  `deleted` BOOLEAN,
  `coverage` DOUBLE,
  `distance` DOUBLE,
  `distance_ft` DOUBLE,
  `distance_mi` DOUBLE,
  PRIMARY KEY (`mission_id`)
) CHARACTER SET latin1;
CREATE TABLE `mission_user` (
  `mission_user_id` INT NOT NULL,
  `mission_id` INT,
  `user_id` TEXT,
  `paid` BOOLEAN,
  `pay_per_mile` DOUBLE,
  PRIMARY KEY (`mission_user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_455933_16') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_455933_16') AS relationships;
DROP DATABASE `db_455933_16`;
UNINSTALL EXTENSION vsql_schematron;
