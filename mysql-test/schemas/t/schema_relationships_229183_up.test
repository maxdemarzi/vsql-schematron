INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 229183_up
--echo #
CREATE DATABASE `db_229183_up`;
USE `db_229183_up`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `password_hash` TEXT,
  `registration_date` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `capabilities` (
  `label` TEXT,
  `user_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `session_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `expiration_date` TIMESTAMP NULL,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_229183_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_229183_up') AS relationships;
DROP DATABASE `db_229183_up`;
UNINSTALL EXTENSION vsql_schematron;
