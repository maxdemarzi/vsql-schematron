INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553046_CreateSchema
--echo #
CREATE DATABASE `db_553046_CreateSchema`;
USE `db_553046_CreateSchema`;
CREATE TABLE `CONSUMER` (
  `ConsumerID` INT NOT NULL,
  `Name` VARCHAR(50),
  `DOB` DATE,
  `Pincode` INT,
  `Phone` BIGINT,
  `AccountNo` BIGINT,
  `PIN` INT,
  PRIMARY KEY (`ConsumerID`)
) CHARACTER SET latin1;
CREATE TABLE `BALANCE` (
  `BalanceID` INT NOT NULL,
  `ConsumerID` INT,
  `AccountNo` BIGINT,
  `Balance` INT,
  PRIMARY KEY (`BalanceID`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSACTION` (
  `TransactionID` INT NOT NULL,
  `SourceAccount` BIGINT,
  `TYPE` VARCHAR(50),
  `Date` DATE,
  `Amount` INT,
  `Destination` BIGINT,
  PRIMARY KEY (`TransactionID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553046_CreateSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553046_CreateSchema') AS relationships;
DROP DATABASE `db_553046_CreateSchema`;
UNINSTALL EXTENSION vsql_schematron;
