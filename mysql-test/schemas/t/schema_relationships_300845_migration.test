INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 300845_migration
--echo #
CREATE DATABASE `db_300845_migration`;
USE `db_300845_migration`;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `published` BOOLEAN,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
  `id` INT NOT NULL,
  `bio` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `email` TEXT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_300845_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_300845_migration') AS relationships;
DROP DATABASE `db_300845_migration`;
UNINSTALL EXTENSION vsql_schematron;
