INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038388_Script0003_sqlite
--echo #
CREATE DATABASE `db_038388_Script0003_sqlite`;
USE `db_038388_Script0003_sqlite`;
CREATE TABLE `User` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Role` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `UserRoles` (
  `UserId` INT NOT NULL,
  `RoleId` INT NOT NULL,
  PRIMARY KEY (`UserId`, `RoleId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038388_Script0003_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038388_Script0003_sqlite') AS relationships;
DROP DATABASE `db_038388_Script0003_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
