INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 380235_schema
--echo #
CREATE DATABASE `db_380235_schema`;
USE `db_380235_schema`;
CREATE TABLE `departments` (
  `id` INT NOT NULL,
  `department_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `role_title` VARCHAR(50),
  `role_salary` DECIMAL(10,2),
  `is_manager` BOOLEAN,
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `role_id` INT,
  `manager_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_380235_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_380235_schema') AS relationships;
DROP DATABASE `db_380235_schema`;
UNINSTALL EXTENSION vsql_schematron;
