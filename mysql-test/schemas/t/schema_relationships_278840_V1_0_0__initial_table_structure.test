INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278840_V1_0_0__initial_table_structure
--echo #
CREATE DATABASE `db_278840_V1_0_0__initial_table_structure`;
USE `db_278840_V1_0_0__initial_table_structure`;
CREATE TABLE `email` (
  `id` BIGINT,
  `from_address` VARCHAR(50),
  `to_address` VARCHAR(50),
  `subject` TEXT,
  `received_on` TIMESTAMP NULL,
  `raw_data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `email_content` (
  `id` BIGINT,
  `email` BIGINT,
  `content_type` VARCHAR(50),
  `data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `email_attachment` (
  `id` BIGINT,
  `email` BIGINT,
  `filename` VARCHAR(50),
  `data` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278840_V1_0_0__initial_table_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278840_V1_0_0__initial_table_structure') AS relationships;
DROP DATABASE `db_278840_V1_0_0__initial_table_structure`;
UNINSTALL EXTENSION vsql_schematron;
