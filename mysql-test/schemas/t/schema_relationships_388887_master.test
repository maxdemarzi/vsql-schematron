INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 388887_master
--echo #
CREATE DATABASE `db_388887_master`;
USE `db_388887_master`;
CREATE TABLE `authors` (
  `id_author` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `create_at` DATETIME,
  `update_at` DATETIME,
  PRIMARY KEY (`id_author`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id_book` VARCHAR(50),
  `title_book` VARCHAR(50),
  `description_book` TEXT,
  `author` VARCHAR(50),
  `create_at` DATETIME,
  `update_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `class` VARCHAR(50),
  `group` VARCHAR(50),
  `namespace` VARCHAR(50),
  `time` INT,
  `batch` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_388887_master') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_388887_master') AS relationships;
DROP DATABASE `db_388887_master`;
UNINSTALL EXTENSION vsql_schematron;
