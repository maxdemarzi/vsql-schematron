INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 226805_V12__add_batches
--echo #
CREATE DATABASE `db_226805_V12__add_batches`;
USE `db_226805_V12__add_batches`;
CREATE TABLE `achievements` (
  `id` BIGINT NOT NULL,
  `domain_id` BIGINT,
  `name` TEXT,
  `batch_name` TEXT,
  `title` TEXT,
  `start_time` DATETIME,
  `end_time` DATETIME,
  `points_lvl1` BIGINT,
  `points_lvl2` BIGINT,
  `points_lvl3` BIGINT,
  `points_lvl4` BIGINT,
  `description_lvl1` TEXT,
  `description_lvl2` TEXT,
  `description_lvl3` TEXT,
  `description_lvl4` TEXT,
  `depends_on` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_achievements` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `achievements_id` BIGINT,
  `points` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_226805_V12__add_batches') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_226805_V12__add_batches') AS relationships;
DROP DATABASE `db_226805_V12__add_batches`;
UNINSTALL EXTENSION vsql_schematron;
