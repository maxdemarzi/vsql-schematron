INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257979_V1__Create_user_table
--echo #
CREATE DATABASE `db_257979_V1__Create_user_table`;
USE `db_257979_V1__Create_user_table`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `code` VARCHAR(50),
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email1` VARCHAR(50),
  `email2` VARCHAR(50),
  `email3` VARCHAR(50),
  `phone1` VARCHAR(50),
  `phone2` VARCHAR(50),
  `phone3` VARCHAR(50),
  `pancard` VARCHAR(50),
  `passport_no` VARCHAR(50),
  `gender` VARCHAR(50),
  `house_no` VARCHAR(50),
  `street` VARCHAR(50),
  `pincode` VARCHAR(50),
  `landmark` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50),
  `full_address` VARCHAR(50),
  `date_of_birth` DATE,
  `place_of_birth` VARCHAR(50),
  `attributes` VARCHAR(50),
  `roles` VARCHAR(50),
  `scopes` VARCHAR(50),
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `house_no` VARCHAR(50),
  `street` VARCHAR(50),
  `pincode` VARCHAR(50),
  `landmark` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50),
  `full_address` VARCHAR(50),
  `attributes` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257979_V1__Create_user_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257979_V1__Create_user_table') AS relationships;
DROP DATABASE `db_257979_V1__Create_user_table`;
UNINSTALL EXTENSION vsql_schematron;
