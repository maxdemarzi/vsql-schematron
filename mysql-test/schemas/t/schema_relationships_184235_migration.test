INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184235_migration
--echo #
CREATE DATABASE `db_184235_migration`;
USE `db_184235_migration`;
CREATE TABLE `daily_exchange` (
  `id` INT NOT NULL,
  `currency_id` INT,
  `open` INT,
  `high` INT,
  `low` INT,
  `close` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weekly_exchange` (
  `id` INT NOT NULL,
  `currency_id` INT,
  `open` INT,
  `high` INT,
  `low` INT,
  `close` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `monthly_exchange` (
  `id` INT NOT NULL,
  `currency_id` INT,
  `open` INT,
  `high` INT,
  `low` INT,
  `close` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `house_number` INT,
  `user_id` TEXT,
  `person_id` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `provinces` (
  `id` INT NOT NULL,
  `name` TEXT,
  `address_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
  `id` INT NOT NULL,
  `name` TEXT,
  `Zip_code` INT,
  `province_id` INT,
  `address_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `neighborhoods` (
  `id` INT NOT NULL,
  `name` TEXT,
  `city_id` INT,
  `address_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blocks` (
  `id` INT NOT NULL,
  `block` INT,
  `neighborhood_id` INT,
  `address_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184235_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184235_migration') AS relationships;
DROP DATABASE `db_184235_migration`;
UNINSTALL EXTENSION vsql_schematron;
