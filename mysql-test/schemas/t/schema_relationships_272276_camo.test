INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 272276_camo
--echo #
CREATE DATABASE `db_272276_camo`;
USE `db_272276_camo`;
CREATE TABLE `machines` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `max_rpm` INT,
  `spot` VARCHAR(50),
  `drill` VARCHAR(50),
  `tap` VARCHAR(50),
  `peck` VARCHAR(50),
  `ream` VARCHAR(50),
  `drill_format` VARCHAR(50),
  `tap_format` VARCHAR(50),
  `program_start` VARCHAR(50),
  `program_end` VARCHAR(50),
  `tool_start` VARCHAR(50),
  `tool_end` VARCHAR(50),
  `op_start` VARCHAR(50),
  `countersink` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `camo_ops` (
  `id` INT NOT NULL,
  `op_type` VARCHAR(50),
  `function` VARCHAR(50),
  `priority` VARCHAR(50),
  `feature_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `features` (
  `name` VARCHAR(50),
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  `feature_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature_types` (
  `id` INT NOT NULL,
  `feature_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
  `id` INT NOT NULL,
  `feature_id` INT,
  `tool_id` INT,
  `camo_op_id` INT,
  `peck` DECIMAL(10,2),
  `feed` DECIMAL(10,2),
  `speed` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tools` (
  `id` INT NOT NULL,
  `qb_id` INT,
  `tool_type_id` INT,
  `tool_number` INT,
  `name` VARCHAR(50),
  `diameter` DECIMAL(10,2),
  `number_of_flutes` INT,
  `pitch` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tool_types` (
  `id` INT NOT NULL,
  `tool_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_272276_camo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_272276_camo') AS relationships;
DROP DATABASE `db_272276_camo`;
UNINSTALL EXTENSION vsql_schematron;
