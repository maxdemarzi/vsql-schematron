INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015018_ocorrencia
--echo #
CREATE DATABASE `db_015018_ocorrencia`;
USE `db_015018_ocorrencia`;
CREATE TABLE `ocorrencia.usuario` (
  `idusuario` INT NOT NULL,
  `nomeCompleto` VARCHAR(50),
  `raCpf` VARCHAR(50),
  PRIMARY KEY (`idusuario`)
) CHARACTER SET latin1;
CREATE TABLE `ocorrencia.patrimonio` (
  `idpatrimonio` INT NOT NULL,
  `numPatrimonio` INT,
  `descricao` VARCHAR(50),
  `modelo` VARCHAR(50),
  `marca` VARCHAR(50),
  PRIMARY KEY (`idpatrimonio`)
) CHARACTER SET latin1;
CREATE TABLE `ocorrencia.laboratorio` (
  `idlaboratorio` INT NOT NULL,
  `sala` VARCHAR(50),
  PRIMARY KEY (`idlaboratorio`)
) CHARACTER SET latin1;
CREATE TABLE `ocorrencia.dadosOcorrencia` (
  `idocorrencia` INT NOT NULL,
  `dataAbertura` DATE,
  `descricaoProblema` VARCHAR(50),
  `usuario_idusuario` INT,
  `patrimonio_idpatrimonio` INT,
  `laboratorio_idlaboratorio` INT,
  PRIMARY KEY (`idocorrencia`)
) CHARACTER SET latin1;
CREATE TABLE `ocorrencia.statusOcorrencia` (
  `idstatus` INT NOT NULL,
  `data` DATE,
  `status` VARCHAR(50),
  PRIMARY KEY (`idstatus`)
) CHARACTER SET latin1;
CREATE TABLE `ocorrencia.dadosStatus` (
  `dadosOcorrencia_idocorrencia` INT NOT NULL,
  `statusOcorrencia_idstatus` INT NOT NULL,
  PRIMARY KEY (`dadosOcorrencia_idocorrencia`, `statusOcorrencia_idstatus`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015018_ocorrencia') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015018_ocorrencia') AS relationships;
DROP DATABASE `db_015018_ocorrencia`;
UNINSTALL EXTENSION vsql_schematron;
