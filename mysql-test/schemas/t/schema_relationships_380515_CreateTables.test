INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 380515_CreateTables
--echo #
CREATE DATABASE `db_380515_CreateTables`;
USE `db_380515_CreateTables`;
CREATE TABLE `MicroSungero_Planning_TodoList` (
  `Id` INT NOT NULL,
  `TypeGuid` VARCHAR(50),
  `Title` VARCHAR(50),
  `Description` VARCHAR(50),
  `AuthorId` INT,
  `CreatedDate` TIMESTAMP NULL,
  `Deadline` TIMESTAMP NULL,
  `IsCompleted` BOOLEAN,
  `CompletedDate` TIMESTAMP NULL,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `MicroSungero_Planning_Todo` (
  `Id` INT NOT NULL,
  `TypeGuid` VARCHAR(50),
  `Title` VARCHAR(50),
  `Description` VARCHAR(50),
  `Note` VARCHAR(50),
  `PerformerId` INT,
  `Priority` VARCHAR(50),
  `CreatedDate` TIMESTAMP NULL,
  `Deadline` TIMESTAMP NULL,
  `IsCompleted` BOOLEAN,
  `CompletedDate` TIMESTAMP NULL,
  `TodoListId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `MicroSungero_Planning_TodoTag` (
  `Id` INT NOT NULL,
  `TypeGuid` VARCHAR(50),
  `Tag_Name` VARCHAR(50),
  `Tag_Color` VARCHAR(50),
  `TodoId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_380515_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_380515_CreateTables') AS relationships;
DROP DATABASE `db_380515_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
