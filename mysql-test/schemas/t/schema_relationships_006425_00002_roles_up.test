INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 006425_00002_roles.up
--echo #
CREATE DATABASE `db_006425_00002_roles_up`;
USE `db_006425_00002_roles_up`;
CREATE TABLE `roles` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_and_permissions` (
  `role_id` BIGINT,
  `permission_id` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_006425_00002_roles_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_006425_00002_roles_up') AS relationships;
DROP DATABASE `db_006425_00002_roles_up`;
UNINSTALL EXTENSION vsql_schematron;
