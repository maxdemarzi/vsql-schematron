INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588345_create_tables
--echo #
CREATE DATABASE `db_588345_create_tables`;
USE `db_588345_create_tables`;
CREATE TABLE `artikler` (
  `id_a` INT NOT NULL,
  `navnPost` VARCHAR(50),
  `postTid` TIMESTAMP NULL,
  `overskrift` VARCHAR(50),
  `brodtekst` VARCHAR(50),
  `bilde` VARCHAR(50),
  `alt` VARCHAR(50),
  `relevanse` VARCHAR(50),
  `forfatter` VARCHAR(50),
  `rate` INT,
  PRIMARY KEY (`id_a`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id_com` INT NOT NULL,
  `comment` VARCHAR(50),
  `nickname` VARCHAR(50),
  `id_a` INT,
  PRIMARY KEY (`id_com`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
  `id_c` INT NOT NULL,
  `navn` VARCHAR(50),
  PRIMARY KEY (`id_c`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588345_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588345_create_tables') AS relationships;
DROP DATABASE `db_588345_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
