INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 268399_EMPLOYEE_DEPART
--echo #
CREATE DATABASE `db_268399_EMPLOYEE_DEPART`;
USE `db_268399_EMPLOYEE_DEPART`;
CREATE TABLE `depart` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `sex` CHAR(50),
  `salary` DOUBLE,
  `birthday` DATE,
  `depart_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_268399_EMPLOYEE_DEPART') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_268399_EMPLOYEE_DEPART') AS relationships;
DROP DATABASE `db_268399_EMPLOYEE_DEPART`;
UNINSTALL EXTENSION vsql_schematron;
