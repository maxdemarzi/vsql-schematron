INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 400916_db_scheme
--echo #
CREATE DATABASE `db_400916_db_scheme`;
USE `db_400916_db_scheme`;
CREATE TABLE `hashtag` (
  `hashtag_id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`hashtag_id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tags` (
  `hashtag_id` INT,
  `post_id` INT,
  `created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `post_id` INT NOT NULL,
  `user_id` INT,
  `caption` TEXT,
  `created_at` DATETIME,
  `attachment` VARCHAR(50),
  `tag_id` INT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `bio` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_400916_db_scheme') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_400916_db_scheme') AS relationships;
DROP DATABASE `db_400916_db_scheme`;
UNINSTALL EXTENSION vsql_schematron;
