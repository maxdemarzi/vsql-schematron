INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 340093_Exercicio%2004
--echo #
CREATE DATABASE `db_340093_Exercicio_2004`;
USE `db_340093_Exercicio_2004`;
CREATE TABLE `tb_categoria` (
  `id_categoria` INT NOT NULL,
  `tipo_categoria` VARCHAR(50),
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `tb_produto` (
  `id_produto` INT NOT NULL,
  `nome` VARCHAR(50),
  `preco` DOUBLE,
  `quantidade` INT,
  `fk_categoria` INT,
  PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_340093_Exercicio_2004') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_340093_Exercicio_2004') AS relationships;
DROP DATABASE `db_340093_Exercicio_2004`;
UNINSTALL EXTENSION vsql_schematron;
