INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 561455_penjualan
--echo #
CREATE DATABASE `db_561455_penjualan`;
USE `db_561455_penjualan`;
CREATE TABLE `accesories` (
  `accesories_id` INT NOT NULL,
  `accesories_name` VARCHAR(50),
  `price` INT,
  `photo` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`accesories_id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `category_id` VARCHAR(50) NOT NULL,
  `category_name` VARCHAR(50),
  `category_status` VARCHAR(50),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `class` VARCHAR(50),
  `group` VARCHAR(50),
  `namespace` VARCHAR(50),
  `time` INT,
  `batch` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
  `id` INT NOT NULL,
  `id_transaksi` INT,
  `id_product` INT,
  `name_product` VARCHAR(50),
  `price_product` INT,
  `qty_product` INT,
  `subtotal` INT,
  `image_product` TEXT,
  `sku` TEXT,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `product_id` VARCHAR(50),
  `category_id` VARCHAR(50),
  `product_name` VARCHAR(50),
  `product_price` INT,
  `product_sku` VARCHAR(50),
  `product_status` VARCHAR(50),
  `product_image` VARCHAR(50),
  `product_description` TEXT
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
  `id` INT NOT NULL,
  `kode_unik` VARCHAR(50),
  `total` INT,
  `date_create` TIMESTAMP NULL,
  `barcode` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `status` VARCHAR(50),
  `level` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_561455_penjualan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_561455_penjualan') AS relationships;
DROP DATABASE `db_561455_penjualan`;
UNINSTALL EXTENSION vsql_schematron;
