INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084471_up
--echo #
CREATE DATABASE `db_084471_up`;
USE `db_084471_up`;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` TEXT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag_bindings` (
  `id` INT NOT NULL,
  `kind` INT,
  `item_id` INT,
  `tag` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084471_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084471_up') AS relationships;
DROP DATABASE `db_084471_up`;
UNINSTALL EXTENSION vsql_schematron;
