INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025429_manage_DB
--echo #
CREATE DATABASE `db_025429_manage_DB`;
USE `db_025429_manage_DB`;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `salary` INT,
  `deptID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `roleID` INT,
  `managerID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025429_manage_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025429_manage_DB') AS relationships;
DROP DATABASE `db_025429_manage_DB`;
UNINSTALL EXTENSION vsql_schematron;
