INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053673_resetDb
--echo #
CREATE DATABASE `db_053673_resetDb`;
USE `db_053673_resetDb`;
CREATE TABLE `gqscrape.user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gqscrape.question` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `thumbs` INT,
  `gold` VARCHAR(50),
  `user_id` INT,
  `date` VARCHAR(50),
  `scrape_time` VARCHAR(50),
  `num_answers` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gqscrape.answer` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `thumbs` INT,
  `gold` VARCHAR(50),
  `date` VARCHAR(50),
  `scrape_time` VARCHAR(50),
  `user_id` INT,
  `question_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053673_resetDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053673_resetDb') AS relationships;
DROP DATABASE `db_053673_resetDb`;
UNINSTALL EXTENSION vsql_schematron;
