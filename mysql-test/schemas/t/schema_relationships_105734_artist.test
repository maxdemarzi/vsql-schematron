INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105734_artist
--echo #
CREATE DATABASE `db_105734_artist`;
USE `db_105734_artist`;
CREATE TABLE `artist` (
  `ID` BIGINT NOT NULL,
  `available` DATE,
  `name` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `artist_dispatch_contract` (
  `ID` BIGINT NOT NULL,
  `customer_name` VARCHAR(50),
  `DATE` DATE,
  `ARTIST_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105734_artist') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105734_artist') AS relationships;
DROP DATABASE `db_105734_artist`;
UNINSTALL EXTENSION vsql_schematron;
