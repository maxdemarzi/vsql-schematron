INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172297_1
--echo #
CREATE DATABASE `db_172297_1`;
USE `db_172297_1`;
CREATE TABLE `member` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `content` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `member_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172297_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172297_1') AS relationships;
DROP DATABASE `db_172297_1`;
UNINSTALL EXTENSION vsql_schematron;
