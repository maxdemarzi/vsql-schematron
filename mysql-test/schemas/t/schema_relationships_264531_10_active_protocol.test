INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264531_10_active_protocol
--echo #
CREATE DATABASE `db_264531_10_active_protocol`;
USE `db_264531_10_active_protocol`;
CREATE TABLE `deathstar_protocols` (
  `id` INT NOT NULL,
  `label` VARCHAR(50),
  `alert_level` VARCHAR(50),
  `defense_mode` VARCHAR(50),
  `power_level` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `deathstar_protocol_active` (
  `id` INT NOT NULL,
  `only_one` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264531_10_active_protocol') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264531_10_active_protocol') AS relationships;
DROP DATABASE `db_264531_10_active_protocol`;
UNINSTALL EXTENSION vsql_schematron;
