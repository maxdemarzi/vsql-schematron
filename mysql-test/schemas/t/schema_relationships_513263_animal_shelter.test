INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 513263_animal_shelter
--echo #
CREATE DATABASE `db_513263_animal_shelter`;
USE `db_513263_animal_shelter`;
CREATE TABLE `animals` (
  `id` INT,
  `title` VARCHAR(50),
  `age` INT,
  `type` INT,
  `status` TINYINT,
  `created_dt` TIMESTAMP NULL,
  `updated_dt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `animals_types` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `created_dt` TIMESTAMP NULL,
  `updated_dt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
  `version` VARCHAR(50) NOT NULL,
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513263_animal_shelter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513263_animal_shelter') AS relationships;
DROP DATABASE `db_513263_animal_shelter`;
UNINSTALL EXTENSION vsql_schematron;
