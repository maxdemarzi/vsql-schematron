INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 610443_banco
--echo #
CREATE DATABASE `db_610443_banco`;
USE `db_610443_banco`;
CREATE TABLE `aluno` (
  `idaluno` INT NOT NULL,
  `matricula` VARCHAR(50),
  `nome` VARCHAR(50),
  `telefone` VARCHAR(50),
  `sexo` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`idaluno`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `idendereco` INT NOT NULL,
  `endereco` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cep` VARCHAR(50),
  `cidade` VARCHAR(50),
  `estado` VARCHAR(50),
  `idaluno` INT,
  PRIMARY KEY (`idendereco`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_610443_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_610443_banco') AS relationships;
DROP DATABASE `db_610443_banco`;
UNINSTALL EXTENSION vsql_schematron;
