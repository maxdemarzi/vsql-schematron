INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178618_schema
--echo #
CREATE DATABASE `db_178618_schema`;
USE `db_178618_schema`;
CREATE TABLE `parts` (
  `id` INT NOT NULL,
  `isTempPart` BOOLEAN,
  `manufacturerOneId` VARCHAR(50),
  `manufactureContractOneId` VARCHAR(50),
  `uniqueId` VARCHAR(50),
  `manufacturerUniqueId` VARCHAR(50),
  `customerUniqueId` VARCHAR(50),
  `qualityAlert` BOOLEAN,
  `qualityType` VARCHAR(50),
  `importTimestampUtc` TIMESTAMP NULL,
  `validUntilUtc` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `partRelations` (
  `parentPartId` INT,
  `childPartId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178618_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178618_schema') AS relationships;
DROP DATABASE `db_178618_schema`;
UNINSTALL EXTENSION vsql_schematron;
