INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515419_03_raceresults.up
--echo #
CREATE DATABASE `db_515419_03_raceresults_up`;
USE `db_515419_03_raceresults_up`;
CREATE TABLE `race_stats` (
  `fk_subsession_id` INT,
  `starttime` TIMESTAMP NULL,
  `simulated_starttime` TIMESTAMP NULL,
  `lead_changes` INT,
  `laps` INT,
  `cautions` INT,
  `caution_laps` INT,
  `corners_per_lap` INT,
  `avg_laptime` INT,
  `avg_quali_laps` INT,
  `weather_rh` INT,
  `weather_temp` INT
) CHARACTER SET latin1;
CREATE TABLE `clubs` (
  `pk_club_id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`pk_club_id`)
) CHARACTER SET latin1;
CREATE TABLE `drivers` (
  `pk_driver_id` INT NOT NULL,
  `name` TEXT,
  `fk_club_id` INT,
  PRIMARY KEY (`pk_driver_id`)
) CHARACTER SET latin1;
CREATE TABLE `race_results` (
  `fk_subsession_id` INT,
  `fk_driver_id` INT,
  `old_irating` INT,
  `new_irating` INT,
  `old_license_level` INT,
  `new_license_level` INT,
  `old_safety_rating` INT,
  `new_safety_rating` INT,
  `old_cpi` DECIMAL(10,2),
  `new_cpi` DECIMAL(10,2),
  `license_group` INT,
  `aggregate_champpoints` INT,
  `champpoints` INT,
  `clubpoints` INT,
  `car_number` INT,
  `fk_car_id` INT,
  `car_class_id` INT,
  `starting_position` INT,
  `position` INT,
  `finishing_position` INT,
  `finishing_position_in_class` INT,
  `division` INT,
  `interval` INT,
  `class_interval` INT,
  `avg_laptime` INT,
  `laps_completed` INT,
  `laps_lead` INT,
  `incidents` INT,
  `reason_out` TEXT,
  `session_starttime` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515419_03_raceresults_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515419_03_raceresults_up') AS relationships;
DROP DATABASE `db_515419_03_raceresults_up`;
UNINSTALL EXTENSION vsql_schematron;
