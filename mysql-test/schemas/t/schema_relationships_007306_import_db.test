INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 007306_import_db
--echo #
CREATE DATABASE `db_007306_import_db`;
USE `db_007306_import_db`;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `yr` INT,
  `director` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `actors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `castings` (
  `movie_id` INT,
  `actor_id` INT,
  `ord` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_007306_import_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_007306_import_db') AS relationships;
DROP DATABASE `db_007306_import_db`;
UNINSTALL EXTENSION vsql_schematron;
