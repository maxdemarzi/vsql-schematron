INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 102066_schema
--echo #
CREATE DATABASE `db_102066_schema`;
USE `db_102066_schema`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` INT,
  `description` TEXT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cartItem` (
  `id` INT NOT NULL,
  `quantity` INT,
  `productId` INT,
  `orderId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_102066_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_102066_schema') AS relationships;
DROP DATABASE `db_102066_schema`;
UNINSTALL EXTENSION vsql_schematron;
