INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 309140_mysql-initial
--echo #
CREATE DATABASE `db_309140_mysql_initial`;
USE `db_309140_mysql_initial`;
CREATE TABLE `mds-sm.StateMachineVersion` (
  `id` VARCHAR(50) NOT NULL,
  `definition` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.StateMachine` (
  `id` VARCHAR(50) NOT NULL,
  `account_id` VARCHAR(50),
  `name` VARCHAR(50),
  `active_version` CHAR(50),
  `is_deleted` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.Execution` (
  `id` VARCHAR(50) NOT NULL,
  `created` CHAR(50),
  `status` VARCHAR(50),
  `version` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.Operation` (
  `id` VARCHAR(50) NOT NULL,
  `execution` CHAR(50),
  `created` CHAR(50),
  `stateKey` VARCHAR(50),
  `status` VARCHAR(50),
  `input` TEXT,
  `inputType` VARCHAR(50),
  `output` TEXT,
  `outputType` VARCHAR(50),
  `waitUntilUtc` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_309140_mysql_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_309140_mysql_initial') AS relationships;
DROP DATABASE `db_309140_mysql_initial`;
UNINSTALL EXTENSION vsql_schematron;
