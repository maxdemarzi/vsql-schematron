INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480286_create_locations_db
--echo #
CREATE DATABASE `db_480286_create_locations_db`;
USE `db_480286_create_locations_db`;
CREATE TABLE `locations` (
  `locId` INT NOT NULL,
  `country` TEXT,
  `region` TEXT,
  `city` TEXT,
  `postalCode` TEXT,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  `metroCode` TEXT,
  `areaCode` TEXT,
  PRIMARY KEY (`locId`)
) CHARACTER SET latin1;
CREATE TABLE `blocks` (
  `startIpNum` INT,
  `endIpNum` INT,
  `locId` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480286_create_locations_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480286_create_locations_db') AS relationships;
DROP DATABASE `db_480286_create_locations_db`;
UNINSTALL EXTENSION vsql_schematron;
