INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 021582_InventoryDdl
--echo #
CREATE DATABASE `db_021582_InventoryDdl`;
USE `db_021582_InventoryDdl`;
CREATE TABLE `PRODUCT` (
  `SKU` INT NOT NULL,
  `INSTOCK` INT,
  `VERSION` INT,
  `SUPP_ID` INT,
  PRIMARY KEY (`SKU`)
) CHARACTER SET latin1;
CREATE TABLE `SUPPLIER` (
  `SUPP_ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`SUPP_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_021582_InventoryDdl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_021582_InventoryDdl') AS relationships;
DROP DATABASE `db_021582_InventoryDdl`;
UNINSTALL EXTENSION vsql_schematron;
