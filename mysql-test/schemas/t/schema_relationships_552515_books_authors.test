INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552515_books_authors
--echo #
CREATE DATABASE `db_552515_books_authors`;
USE `db_552515_books_authors`;
CREATE TABLE `Authors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `country` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BooksAuthors` (
  `author_id` INT,
  `book_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552515_books_authors') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552515_books_authors') AS relationships;
DROP DATABASE `db_552515_books_authors`;
UNINSTALL EXTENSION vsql_schematron;
