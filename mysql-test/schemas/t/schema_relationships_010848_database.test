INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010848_database
--echo #
CREATE DATABASE `db_010848_database`;
USE `db_010848_database`;
CREATE TABLE `repositories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `enabled` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dependencies` (
  `id` INT NOT NULL,
  `repository_id` INT,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010848_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010848_database') AS relationships;
DROP DATABASE `db_010848_database`;
UNINSTALL EXTENSION vsql_schematron;
