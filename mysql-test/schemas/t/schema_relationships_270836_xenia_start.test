INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 270836_xenia_start
--echo #
CREATE DATABASE `db_270836_xenia_start`;
USE `db_270836_xenia_start`;
CREATE TABLE `roles` (
  `name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `forbids` (
  `id` INT NOT NULL,
  `role` VARCHAR(50),
  `forbmethod` VARCHAR(50),
  `forbresource` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` BLOB,
  `role` VARCHAR(50),
  `first` VARCHAR(50),
  `last` VARCHAR(50),
  `gender` VARCHAR(50),
  `email` VARCHAR(50),
  `homepage` VARCHAR(50),
  `weblog` VARCHAR(50),
  `uri` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_270836_xenia_start') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_270836_xenia_start') AS relationships;
DROP DATABASE `db_270836_xenia_start`;
UNINSTALL EXTENSION vsql_schematron;
