INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331303_scheduler_schema_postgres
--echo #
CREATE DATABASE `db_331303_scheduler_schema_postgres`;
USE `db_331303_scheduler_schema_postgres`;
CREATE TABLE `SCHEDULER_CONFIGURATION` (
  `id` INT NOT NULL,
  `application_name` VARCHAR(50),
  `job_name` VARCHAR(50),
  `configuration_status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SCHEDULER_CONFIGURATION_VALUE` (
  `id` INT NOT NULL,
  `scheduler_configuration_id` BIGINT,
  `type` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SCHEDULER_EXECUTION` (
  `id` INT NOT NULL,
  `scheduler_configuration_id` BIGINT,
  `next_fire_time` TIMESTAMP NULL,
  `execution_count` INT,
  `state` INT,
  `last_update` TIMESTAMP NULL,
  `next_retry` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331303_scheduler_schema_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331303_scheduler_schema_postgres') AS relationships;
DROP DATABASE `db_331303_scheduler_schema_postgres`;
UNINSTALL EXTENSION vsql_schematron;
