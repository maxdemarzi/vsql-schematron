INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 645615_01_initial
--echo #
CREATE DATABASE `db_645615_01_initial`;
USE `db_645615_01_initial`;
CREATE TABLE `posts` (
  `post_id` INT NOT NULL,
  `post_created_at` TEXT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `media` (
  `post_id` INT NOT NULL,
  `media_index` INT NOT NULL,
  `file_name` TEXT,
  `caption` TEXT,
  `width` INT,
  `height` INT,
  PRIMARY KEY (`post_id`, `media_index`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_645615_01_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_645615_01_initial') AS relationships;
DROP DATABASE `db_645615_01_initial`;
UNINSTALL EXTENSION vsql_schematron;
