INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 182247_Query_3
--echo #
CREATE DATABASE `db_182247_Query_3`;
USE `db_182247_Query_3`;
CREATE TABLE `Skills` (
  `skill_id` DECIMAL(10,2) NOT NULL,
  `skill_name` VARCHAR(50),
  PRIMARY KEY (`skill_id`)
) CHARACTER SET latin1;
CREATE TABLE `Tasks` (
  `task` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Capabilities` (
  `employee_id` DECIMAL(10,2),
  `skill_id` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_182247_Query_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_182247_Query_3') AS relationships;
DROP DATABASE `db_182247_Query_3`;
UNINSTALL EXTENSION vsql_schematron;
