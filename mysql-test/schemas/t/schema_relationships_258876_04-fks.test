INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 258876_04-fks
--echo #
CREATE DATABASE `db_258876_04_fks`;
USE `db_258876_04_fks`;
CREATE TABLE `lusers` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `foo` (
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_258876_04_fks') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_258876_04_fks') AS relationships;
DROP DATABASE `db_258876_04_fks`;
UNINSTALL EXTENSION vsql_schematron;
