INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 143662_Dump-Msql3parte
--echo #
CREATE DATABASE `db_143662_Dump_Msql3parte`;
USE `db_143662_Dump_Msql3parte`;
CREATE TABLE `tb_ender` (
  `cep` VARCHAR(50) NOT NULL,
  `cidade` VARCHAR(50),
  `uf` CHAR(50),
  PRIMARY KEY (`cep`)
) CHARACTER SET latin1;
CREATE TABLE `tb_item_compra` (
  `qtd_item_compra` INT,
  `vl_item_compra` DECIMAL(10,2),
  `cod_compra` VARCHAR(50),
  `cod_prod` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_login` (
  `senha_login` VARCHAR(50),
  `cpf_func` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_prod` (
  `cod_prod` VARCHAR(50) NOT NULL,
  `nome_prod` VARCHAR(50),
  `tam_prod` VARCHAR(50),
  `vlun_prod` DECIMAL(10,2),
  `prcusto_prod` DECIMAL(10,2),
  `dtcad_prod` DATE,
  `est_prod` INT,
  `cod_fornec` VARCHAR(50),
  `cod_tipo_prod` VARCHAR(50),
  PRIMARY KEY (`cod_prod`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_143662_Dump_Msql3parte') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_143662_Dump_Msql3parte') AS relationships;
DROP DATABASE `db_143662_Dump_Msql3parte`;
UNINSTALL EXTENSION vsql_schematron;
