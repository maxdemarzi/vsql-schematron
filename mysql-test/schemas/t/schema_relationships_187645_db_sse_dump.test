INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187645_db_sse_dump
--echo #
CREATE DATABASE `db_187645_db_sse_dump`;
USE `db_187645_db_sse_dump`;
CREATE TABLE `tbl_notification` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `notification_data` TEXT,
  `icon` VARCHAR(50),
  `badge` VARCHAR(50),
  `tag` VARCHAR(50),
  `action_link` VARCHAR(50),
  `sound_link` VARCHAR(50),
  `created_datetime` TIMESTAMP NULL,
  `is_active` VARCHAR(50),
  `order_code` INT,
  `priority` INT,
  `ttl` VARCHAR(50),
  `rel_id` INT,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_notification_consumer` (
  `id` INT NOT NULL,
  `not_id` INT,
  `user_id` INT,
  `is_read_status` VARCHAR(50),
  `read_datetime` VARCHAR(50),
  `is_active` VARCHAR(50),
  `created_datetime` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187645_db_sse_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187645_db_sse_dump') AS relationships;
DROP DATABASE `db_187645_db_sse_dump`;
UNINSTALL EXTENSION vsql_schematron;
