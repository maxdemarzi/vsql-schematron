INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037089_create_bookdb_database
--echo #
CREATE DATABASE `db_037089_create_bookdb_database`;
USE `db_037089_create_bookdb_database`;
CREATE TABLE `books` (
  `book_id` INT NOT NULL,
  `book_name` VARCHAR(50),
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
  `author_id` INT NOT NULL,
  `author_name` VARCHAR(50),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_author` (
  `book_id` INT NOT NULL,
  `author_id` INT NOT NULL,
  PRIMARY KEY (`book_id`, `author_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037089_create_bookdb_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037089_create_bookdb_database') AS relationships;
DROP DATABASE `db_037089_create_bookdb_database`;
UNINSTALL EXTENSION vsql_schematron;
