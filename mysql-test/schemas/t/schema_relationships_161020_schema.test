INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161020_schema
--echo #
CREATE DATABASE `db_161020_schema`;
USE `db_161020_schema`;
CREATE TABLE `Users` (
  `uid` INT NOT NULL,
  `username` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `Blog` (
  `bid` INT NOT NULL,
  `author_id` INT,
  `title` VARCHAR(50),
  `visible` BOOLEAN,
  `created` TIMESTAMP NULL,
  `posted` TIMESTAMP NULL,
  PRIMARY KEY (`bid`)
) CHARACTER SET latin1;
CREATE TABLE `Content` (
  `tid` INT NOT NULL,
  `bid` INT,
  `author_id` INT,
  `content` VARCHAR(50),
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161020_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161020_schema') AS relationships;
DROP DATABASE `db_161020_schema`;
UNINSTALL EXTENSION vsql_schematron;
