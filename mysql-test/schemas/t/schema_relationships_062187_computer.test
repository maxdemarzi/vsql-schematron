INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062187_computer
--echo #
CREATE DATABASE `db_062187_computer`;
USE `db_062187_computer`;
CREATE TABLE `PC` (
  `code` INT NOT NULL,
  `model` VARCHAR(50),
  `speed` INT,
  `ram` INT,
  `hd` DOUBLE,
  `cd` VARCHAR(50),
  `price` DOUBLE,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `maker` VARCHAR(50),
  `model` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`model`)
) CHARACTER SET latin1;
CREATE TABLE `Printer` (
  `code` INT NOT NULL,
  `model` VARCHAR(50),
  `color` CHAR(50),
  `type` VARCHAR(50),
  `price` DOUBLE,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062187_computer') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062187_computer') AS relationships;
DROP DATABASE `db_062187_computer`;
UNINSTALL EXTENSION vsql_schematron;
