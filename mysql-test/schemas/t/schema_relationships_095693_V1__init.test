INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095693_V1__init
--echo #
CREATE DATABASE `db_095693_V1__init`;
USE `db_095693_V1__init`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `user_name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `billing_address` VARCHAR(50),
  `billing_province` VARCHAR(50),
  `billing_country` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `zip` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` BIGINT NOT NULL,
  `title` VARCHAR(50),
  `author` VARCHAR(50),
  `account_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chapter` (
  `id` BIGINT NOT NULL,
  `title` VARCHAR(50),
  `book_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercise` (
  `id` BIGINT NOT NULL,
  `chapter_id` BIGINT,
  `exercise` VARCHAR(50),
  `answer` INT,
  `question` VARCHAR(50),
  `one` VARCHAR(50),
  `two` VARCHAR(50),
  `three` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095693_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095693_V1__init') AS relationships;
DROP DATABASE `db_095693_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
