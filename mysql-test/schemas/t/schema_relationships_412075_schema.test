INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 412075_schema
--echo #
CREATE DATABASE `db_412075_schema`;
USE `db_412075_schema`;
CREATE TABLE `warehouse_products.users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `warehouse_products.user_authorities` (
  `user_role_id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `authority` VARCHAR(50),
  PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
CREATE TABLE `warehouse_products.details` (
  `product_id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `storage_temp` VARCHAR(50),
  `height` SMALLINT,
  `width` SMALLINT,
  `length` SMALLINT,
  `weight` DECIMAL(10,2),
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `warehouse_products.barcodes` (
  `barcode` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  PRIMARY KEY (`barcode`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_412075_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_412075_schema') AS relationships;
DROP DATABASE `db_412075_schema`;
UNINSTALL EXTENSION vsql_schematron;
