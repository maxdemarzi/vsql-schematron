INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 032237_schema.mysql
--echo #
CREATE DATABASE `db_032237_schema_mysql`;
USE `db_032237_schema_mysql`;
CREATE TABLE `gallery` (
  `id` INT NOT NULL,
  `versions_data` TEXT,
  `name` TINYINT,
  `description` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gallery_photo` (
  `id` INT NOT NULL,
  `gallery_id` INT,
  `rank` INT,
  `name` VARCHAR(50),
  `description` TEXT,
  `file_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_032237_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_032237_schema_mysql') AS relationships;
DROP DATABASE `db_032237_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
