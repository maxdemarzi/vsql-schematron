  `district_name` CHAR(50),
  `longitude` DOUBLE,
  `latitude` DOUBLE,
  `preferences` DECIMAL(10,2),
  `region_name` CHAR(50),
  `grade` CHAR(50),
  `tenantid` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
