INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142829_customer
--echo #
CREATE DATABASE `db_142829_customer`;
USE `db_142829_customer`;
CREATE TABLE `country` (
  `id` INT NOT NULL,
  `country` VARCHAR(50),
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` INT NOT NULL,
  `city` VARCHAR(50),
  `country_id` INT,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `address` VARCHAR(50),
  `address2` VARCHAR(50),
  `district` VARCHAR(50),
  `city_id` INT,
  `postal_code` VARCHAR(50),
  `phone` VARCHAR(50),
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `id` INT NOT NULL,
  `store_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `address_id` INT,
  `active` BOOLEAN,
  `create_Date` TIMESTAMP NULL,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142829_customer') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142829_customer') AS relationships;
DROP DATABASE `db_142829_customer`;
UNINSTALL EXTENSION vsql_schematron;
