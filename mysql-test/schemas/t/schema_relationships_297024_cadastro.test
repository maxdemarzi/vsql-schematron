INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297024_cadastro
--echo #
CREATE DATABASE `db_297024_cadastro`;
USE `db_297024_cadastro`;
CREATE TABLE `paciente` (
  `id` INT NOT NULL,
  `data` DATETIME,
  `email` VARCHAR(50),
  `nome` VARCHAR(50),
  `nome_mae` VARCHAR(50),
  `nome_pai` VARCHAR(50),
  `status` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `id` INT NOT NULL,
  `data` DATETIME,
  `nome_bairro` VARCHAR(50),
  `rua` VARCHAR(50),
  `status` BOOLEAN,
  `paciente_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297024_cadastro') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297024_cadastro') AS relationships;
DROP DATABASE `db_297024_cadastro`;
UNINSTALL EXTENSION vsql_schematron;
