INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152230_init
--echo #
CREATE DATABASE `db_152230_init`;
USE `db_152230_init`;
CREATE TABLE `data` (
  `id` INT NOT NULL,
  `mes` INT,
  `ano` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cidade` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `estado` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clima` (
  `id` INT NOT NULL,
  `temp_med_celsius` DOUBLE,
  `temp_min_celsius` DOUBLE,
  `temp_max_celsius` DOUBLE,
  `precipitacao_mensal_mm` DOUBLE,
  `data_id` INT,
  `cidade_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dengue` (
  `id` INT NOT NULL,
  `n_casos` INT,
  `data_id` INT,
  `cidade_id` INT,
  `clima_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152230_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152230_init') AS relationships;
DROP DATABASE `db_152230_init`;
UNINSTALL EXTENSION vsql_schematron;
