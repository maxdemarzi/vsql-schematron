INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535366_Script%20sql%20Exercice%201
--echo #
CREATE DATABASE `db_535366_Script_20sql_20Exercice_201`;
USE `db_535366_Script_20sql_20Exercice_201`;
CREATE TABLE `Personne` (
  `per_num` INT NOT NULL,
  `per_nom` VARCHAR(50),
  `per_prenom` VARCHAR(50),
  `per_adresse` VARCHAR(50),
  `per_ville` VARCHAR(50),
  PRIMARY KEY (`per_num`)
) CHARACTER SET latin1;
CREATE TABLE `Groupe` (
  `gro_num` INT NOT NULL,
  `gro_libelle` VARCHAR(50),
  PRIMARY KEY (`gro_num`)
) CHARACTER SET latin1;
CREATE TABLE `Appartient` (
  `per_num` INT,
  `gro_num` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535366_Script_20sql_20Exercice_201') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535366_Script_20sql_20Exercice_201') AS relationships;
DROP DATABASE `db_535366_Script_20sql_20Exercice_201`;
UNINSTALL EXTENSION vsql_schematron;
