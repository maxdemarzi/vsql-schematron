INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 111134_create
--echo #
CREATE DATABASE `db_111134_create`;
USE `db_111134_create`;
CREATE TABLE `cities` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
  `id` INT NOT NULL,
  `time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guesses` (
  `game` INT,
  `city` INT,
  `lat` DOUBLE,
  `lng` DOUBLE,
  `duration` DOUBLE,
  `points` INT,
  `distance` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_111134_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_111134_create') AS relationships;
DROP DATABASE `db_111134_create`;
UNINSTALL EXTENSION vsql_schematron;
