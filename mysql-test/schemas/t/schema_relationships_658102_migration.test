INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 658102_migration
--echo #
CREATE DATABASE `db_658102_migration`;
USE `db_658102_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `role` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Torrent` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `userId` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_658102_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_658102_migration') AS relationships;
DROP DATABASE `db_658102_migration`;
UNINSTALL EXTENSION vsql_schematron;
