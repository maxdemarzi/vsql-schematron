INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153205_schemacarmodels
--echo #
CREATE DATABASE `db_153205_schemacarmodels`;
USE `db_153205_schemacarmodels`;
CREATE TABLE `car_brands` (
  `car_brand_id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `car_brand_name` VARCHAR(50),
  `brand_photo` VARCHAR(50),
  PRIMARY KEY (`car_brand_id`)
) CHARACTER SET latin1;
CREATE TABLE `car_models` (
  `car_model_id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `car_model_name` VARCHAR(50),
  `car_brand` INT,
  PRIMARY KEY (`car_model_id`)
) CHARACTER SET latin1;
CREATE TABLE `body_types` (
  `body_type_id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `body_type` VARCHAR(50),
  PRIMARY KEY (`body_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `car_id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `car_name` VARCHAR(50),
  `car_model` INT,
  `body_type` INT,
  `modification` VARCHAR(50),
  `capacity` INT,
  `year_of_issue` INT,
  `year_end` INT,
  PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;
CREATE TABLE `car_photos` (
  `photo_id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `car_id` INT,
  `rand_photo` VARCHAR(50),
  PRIMARY KEY (`photo_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153205_schemacarmodels') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153205_schemacarmodels') AS relationships;
DROP DATABASE `db_153205_schemacarmodels`;
UNINSTALL EXTENSION vsql_schematron;
