INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641523_init_database
--echo #
CREATE DATABASE `db_641523_init_database`;
USE `db_641523_init_database`;
CREATE TABLE `propietario` (
  `id` INT NOT NULL,
  `nombre` TEXT,
  `telefono` TEXT,
  `correo` TEXT,
  `fecha_creacion` DATETIME,
  `fecha_modificacion` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ciudad` (
  `id` INT NOT NULL,
  `nombre` TEXT,
  `fecha_creacion` DATETIME,
  `fecha_modificacion` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `localidad` (
  `id` INT NOT NULL,
  `nombre` TEXT,
  `id_ciudad` INT,
  `fecha_creacion` DATETIME,
  `fecha_modificacion` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641523_init_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641523_init_database') AS relationships;
DROP DATABASE `db_641523_init_database`;
UNINSTALL EXTENSION vsql_schematron;
