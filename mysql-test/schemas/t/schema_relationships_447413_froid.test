INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 447413_froid
--echo #
CREATE DATABASE `db_447413_froid`;
USE `db_447413_froid`;
CREATE TABLE `sent` (
  `id` INT NOT NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `word` (
  `id` INT NOT NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sent_word` (
  `sent_id` INT,
  `word_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_447413_froid') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_447413_froid') AS relationships;
DROP DATABASE `db_447413_froid`;
UNINSTALL EXTENSION vsql_schematron;
