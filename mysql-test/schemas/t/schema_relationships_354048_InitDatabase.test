INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354048_InitDatabase
--echo #
CREATE DATABASE `db_354048_InitDatabase`;
USE `db_354048_InitDatabase`;
CREATE TABLE `testing.player` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `Age` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `testing.kingdom` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `testing.general` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `Attack` VARCHAR(50),
  `Defense` VARCHAR(50),
  `PlayerId` VARCHAR(50),
  `KingdomId` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354048_InitDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354048_InitDatabase') AS relationships;
DROP DATABASE `db_354048_InitDatabase`;
UNINSTALL EXTENSION vsql_schematron;
