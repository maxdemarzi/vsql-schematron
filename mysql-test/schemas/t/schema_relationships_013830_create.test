INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013830_create
--echo #
CREATE DATABASE `db_013830_create`;
USE `db_013830_create`;
CREATE TABLE `position` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
  `id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `position_id` INT,
  `start_date` DATE,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skill` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_skill` (
  `profile_id` INT,
  `skill_id` INT,
  `score` INT
) CHARACTER SET latin1;
CREATE TABLE `characteristic` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_characteristic` (
  `profile_id` INT,
  `characteristic_id` INT
) CHARACTER SET latin1;
CREATE TABLE `meeting` (
  `id` INT NOT NULL,
  `profile_id` INT,
  `meeting_date` DATETIME,
  `content` TEXT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013830_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013830_create') AS relationships;
DROP DATABASE `db_013830_create`;
UNINSTALL EXTENSION vsql_schematron;
