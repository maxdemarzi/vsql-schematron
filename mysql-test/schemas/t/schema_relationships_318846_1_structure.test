INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318846_1_structure
--echo #
CREATE DATABASE `db_318846_1_structure`;
USE `db_318846_1_structure`;
CREATE TABLE `USERS` (
  `ID` BIGINT NOT NULL,
  `USERNAME` VARCHAR(50),
  `PASSWORD` BLOB,
  `TYPE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USERS_DATA_APPROVAL` (
  `ID` BIGINT NOT NULL,
  `USER_ID` BIGINT,
  `APPROVAL_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHRASES` (
  `ID` BIGINT NOT NULL,
  `USER_ID` BIGINT,
  `LANGUAGE` VARCHAR(50),
  `PHRASE` TEXT,
  `STATE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318846_1_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318846_1_structure') AS relationships;
DROP DATABASE `db_318846_1_structure`;
UNINSTALL EXTENSION vsql_schematron;
