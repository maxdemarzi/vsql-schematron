INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 286037_common_crawl
--echo #
CREATE DATABASE `db_286037_common_crawl`;
USE `db_286037_common_crawl`;
CREATE TABLE `test` (
  `id` INT NOT NULL,
  `state` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `worker` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `process` (
  `id` INT NOT NULL,
  `id_data` INT,
  `size` INT,
  `processed_at` DATETIME,
  `id_worker` INT,
  `uri` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_286037_common_crawl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_286037_common_crawl') AS relationships;
DROP DATABASE `db_286037_common_crawl`;
UNINSTALL EXTENSION vsql_schematron;
