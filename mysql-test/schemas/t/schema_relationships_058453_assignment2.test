INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058453_assignment2
--echo #
CREATE DATABASE `db_058453_assignment2`;
USE `db_058453_assignment2`;
CREATE TABLE `hotel` (
  `hno` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  PRIMARY KEY (`hno`)
) CHARACTER SET latin1;
CREATE TABLE `room` (
  `rno` DECIMAL(10,2) NOT NULL,
  `rtype` VARCHAR(50),
  `hno` DECIMAL(10,2),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`rno`)
) CHARACTER SET latin1;
CREATE TABLE `guest` (
  `gno` DECIMAL(10,2) NOT NULL,
  `gname` VARCHAR(50),
  `gaddress` VARCHAR(50),
  PRIMARY KEY (`gno`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
  `hno` DECIMAL(10,2),
  `gno` DECIMAL(10,2),
  `rno` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058453_assignment2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058453_assignment2') AS relationships;
DROP DATABASE `db_058453_assignment2`;
UNINSTALL EXTENSION vsql_schematron;
