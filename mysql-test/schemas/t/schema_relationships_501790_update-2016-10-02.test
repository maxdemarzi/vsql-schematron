INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501790_update-2016-10-02
--echo #
CREATE DATABASE `db_501790_update_2016_10_02`;
USE `db_501790_update_2016_10_02`;
CREATE TABLE `packages` (
  `id` INT NOT NULL,
  `system` INT,
  `category` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `package_versions` (
  `id` INT NOT NULL,
  `package` INT,
  `version` VARCHAR(50),
  `released` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501790_update_2016_10_02') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501790_update_2016_10_02') AS relationships;
DROP DATABASE `db_501790_update_2016_10_02`;
UNINSTALL EXTENSION vsql_schematron;
