INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 239949_001
--echo #
CREATE DATABASE `db_239949_001`;
USE `db_239949_001`;
CREATE TABLE `Projects` (
  `id` INT NOT NULL,
  `slug` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Test_Cases` (
  `id` INT NOT NULL,
  `project_id` INT,
  `class` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Test_Runs` (
  `id` INT NOT NULL,
  `project_id` INT,
  `timestamp` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Test_Run_Results` (
  `run_id` INT NOT NULL,
  `case_id` INT NOT NULL,
  `flaky_status` TEXT,
  PRIMARY KEY (`run_id`, `case_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_239949_001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_239949_001') AS relationships;
DROP DATABASE `db_239949_001`;
UNINSTALL EXTENSION vsql_schematron;
