INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 314129_coba
--echo #
CREATE DATABASE `db_314129_coba`;
USE `db_314129_coba`;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `deskripsi` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `urls` (
  `hash` VARCHAR(50),
  `title` VARCHAR(50),
  `original_link` VARCHAR(50),
  `total_clicked` VARCHAR(50),
  `user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `urls_guest` (
  `hash` VARCHAR(50),
  `title` VARCHAR(50),
  `original_link` VARCHAR(50),
  `total_clicked` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `role_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_314129_coba') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_314129_coba') AS relationships;
DROP DATABASE `db_314129_coba`;
UNINSTALL EXTENSION vsql_schematron;
