INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 320113_blog_website
--echo #
CREATE DATABASE `db_320113_blog_website`;
USE `db_320113_blog_website`;
CREATE TABLE `blog` (
  `blog_id` INT,
  `user_id` INT,
  `blog_date` DATE,
  `blog_title` VARCHAR(50),
  `blog_content` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `users_email` VARCHAR(50),
  `users_username` VARCHAR(50),
  `users_password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_320113_blog_website') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_320113_blog_website') AS relationships;
DROP DATABASE `db_320113_blog_website`;
UNINSTALL EXTENSION vsql_schematron;
