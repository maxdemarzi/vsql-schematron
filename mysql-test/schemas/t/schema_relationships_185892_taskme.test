INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 185892_taskme
--echo #
CREATE DATABASE `db_185892_taskme`;
USE `db_185892_taskme`;
CREATE TABLE `tasks` (
  `idTask` INT,
  `user` INT,
  `what` VARCHAR(50),
  `status` VARCHAR(50),
  `time_creation` TIME,
  `time_start` TIME,
  `time_done` TIME,
  `repeating` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `idUser` INT NOT NULL,
  `fname` VARCHAR(50),
  `name` VARCHAR(50),
  `isAdmin` TINYINT,
  PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185892_taskme') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185892_taskme') AS relationships;
DROP DATABASE `db_185892_taskme`;
UNINSTALL EXTENSION vsql_schematron;
