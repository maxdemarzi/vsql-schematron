INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347863_04%20CREATE%20TABLE%20TERRITORIOS
--echo #
CREATE DATABASE `db_347863_04_20CREATE_20TABLE_20TERRITORIOS`;
USE `db_347863_04_20CREATE_20TABLE_20TERRITORIOS`;
CREATE TABLE `Pais` (
  `id` DECIMAL(10,2),
  `descripcion` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Provincia` (
  `id` DECIMAL(10,2),
  `idPais` DECIMAL(10,2),
  `descripcion` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Canton` (
  `id` DECIMAL(10,2),
  `idProvincia` DECIMAL(10,2),
  `descripcion` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Distrito` (
  `id` DECIMAL(10,2),
  `idCanton` DECIMAL(10,2),
  `descripcion` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347863_04_20CREATE_20TABLE_20TERRITORIOS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347863_04_20CREATE_20TABLE_20TERRITORIOS') AS relationships;
DROP DATABASE `db_347863_04_20CREATE_20TABLE_20TERRITORIOS`;
UNINSTALL EXTENSION vsql_schematron;
