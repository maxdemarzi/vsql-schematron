INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 442115_new%202
--echo #
CREATE DATABASE `db_442115_new_202`;
USE `db_442115_new_202`;
CREATE TABLE `TABELA` (
  `COLUNA1` VARCHAR(50) NOT NULL,
  `COLUNA2` VARCHAR(50),
  `COLUNA3` VARCHAR(50),
  PRIMARY KEY (`COLUNA1`)
) CHARACTER SET latin1;
CREATE TABLE `TIMES` (
  `IDTIME` INT NOT NULL,
  `NOMETIME` VARCHAR(50),
  `ID_JOGADOR` INT,
  PRIMARY KEY (`IDTIME`)
) CHARACTER SET latin1;
CREATE TABLE `JOGADOR` (
  `IDJOGADOR` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`IDJOGADOR`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
  `IDCLIENTE` INT NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`IDCLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `TELEFONE` (
  `IDTELEFONE` INT,
  `TIPO` CHAR(50),
  `NUMERO` VARCHAR(50),
  `IDCLIENTE` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_442115_new_202') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_442115_new_202') AS relationships;
DROP DATABASE `db_442115_new_202`;
UNINSTALL EXTENSION vsql_schematron;
