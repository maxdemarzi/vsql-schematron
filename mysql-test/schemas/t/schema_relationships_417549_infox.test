INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417549_infox
--echo #
CREATE DATABASE `db_417549_infox`;
USE `db_417549_infox`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `usuario` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `idcli` INT NOT NULL,
  `nome` VARCHAR(50),
  `fone` VARCHAR(50),
  PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
  `os` INT NOT NULL,
  `equipamento` VARCHAR(50),
  `defeito` VARCHAR(50),
  `dataos` TIMESTAMP NULL,
  `statusOs` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `idcli` INT,
  PRIMARY KEY (`os`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417549_infox') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417549_infox') AS relationships;
DROP DATABASE `db_417549_infox`;
UNINSTALL EXTENSION vsql_schematron;
