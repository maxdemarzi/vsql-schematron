INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 489980_banque_phpAlexis
--echo #
CREATE DATABASE `db_489980_banque_phpAlexis`;
USE `db_489980_banque_phpAlexis`;
CREATE TABLE `Users` (
  `id` VARCHAR(50) NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `adress` VARCHAR(50),
  `city` VARCHAR(50),
  `postal_code` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
  `id` VARCHAR(50) NOT NULL,
  `account_type` VARCHAR(50),
  `account_number` VARCHAR(50),
  `amount` INT,
  `opening_date` TIMESTAMP NULL,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Operation` (
  `id` VARCHAR(50) NOT NULL,
  `operation_type` VARCHAR(50),
  `amount` DECIMAL(10,2),
  `registered` TIMESTAMP NULL,
  `label` VARCHAR(50),
  `account_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_489980_banque_phpAlexis') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489980_banque_phpAlexis') AS relationships;
DROP DATABASE `db_489980_banque_phpAlexis`;
UNINSTALL EXTENSION vsql_schematron;
