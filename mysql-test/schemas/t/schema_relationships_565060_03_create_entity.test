INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565060_03_create_entity
--echo #
CREATE DATABASE `db_565060_03_create_entity`;
USE `db_565060_03_create_entity`;
CREATE TABLE `entity` (
  `uuid` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `description` TEXT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `account_entity` (
  `account_username` VARCHAR(50) NOT NULL,
  `entity_uuid` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`account_username`, `entity_uuid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565060_03_create_entity') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565060_03_create_entity') AS relationships;
DROP DATABASE `db_565060_03_create_entity`;
UNINSTALL EXTENSION vsql_schematron;
