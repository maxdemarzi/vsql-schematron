INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 427838_V1_users
--echo #
CREATE DATABASE `db_427838_V1_users`;
USE `db_427838_V1_users`;
CREATE TABLE `sec.user` (
  `id` INT NOT NULL,
  `username` CHAR(50),
  `email` CHAR(50),
  `surname` CHAR(50),
  `name` CHAR(50),
  `patronymic` CHAR(50),
  `password` CHAR(50),
  `is_active` BOOLEAN,
  `snils` CHAR(50),
  `region_id` INT,
  `organization_id` INT,
  `department_id` INT,
  `position` CHAR(50),
  `user_level` CHAR(50),
  `ext_sys` CHAR(50),
  `ext_uid` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sec.user_role` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_427838_V1_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_427838_V1_users') AS relationships;
DROP DATABASE `db_427838_V1_users`;
UNINSTALL EXTENSION vsql_schematron;
