INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638530_setup
--echo #
CREATE DATABASE `db_638530_setup`;
USE `db_638530_setup`;
CREATE TABLE `Descript` (
  `shortname` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `fileurl` VARCHAR(50),
  PRIMARY KEY (`shortname`)
) CHARACTER SET latin1;
CREATE TABLE `Adresses` (
  `shortname` VARCHAR(50) NOT NULL,
  `street` VARCHAR(50),
  `campus` VARCHAR(50),
  `nr` VARCHAR(50),
  PRIMARY KEY (`shortname`)
) CHARACTER SET latin1;
CREATE TABLE `meta` (
  `setting` VARCHAR(50) NOT NULL,
  `val` VARCHAR(50),
  PRIMARY KEY (`setting`)
) CHARACTER SET latin1;
CREATE TABLE `OSMBuildings` (
  `id` INT NOT NULL,
  `adress` VARCHAR(50),
  `descript` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638530_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638530_setup') AS relationships;
DROP DATABASE `db_638530_setup`;
UNINSTALL EXTENSION vsql_schematron;
