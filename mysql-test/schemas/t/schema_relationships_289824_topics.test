INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 289824_topics
--echo #
CREATE DATABASE `db_289824_topics`;
USE `db_289824_topics`;
CREATE TABLE `module` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `topics` (
  `id` VARCHAR(50) NOT NULL,
  `module_id` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_289824_topics') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_289824_topics') AS relationships;
DROP DATABASE `db_289824_topics`;
UNINSTALL EXTENSION vsql_schematron;
