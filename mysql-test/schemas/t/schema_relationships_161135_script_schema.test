INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161135_script_schema
--echo #
CREATE DATABASE `db_161135_script_schema`;
USE `db_161135_script_schema`;
CREATE TABLE `Workflows` (
  `Id` INT NOT NULL,
  `WorkflowName` VARCHAR(50),
  `LastRun` TIMESTAMP NULL,
  `NextRun` TIMESTAMP NULL,
  `TimesToRun` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ActivityTypes` (
  `Id` INT NOT NULL,
  `ActivityTypeName` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ParameterTypes` (
  `Id` INT NOT NULL,
  `ActivityType` INT,
  `ParameterName` VARCHAR(50),
  `LogicalType` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Activities` (
  `Id` INT NOT NULL,
  `WorkflowId` INT,
  `ActivityType` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Parameters` (
  `Id` INT NOT NULL,
  `ActivityId` INT,
  `ParameterValue` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161135_script_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161135_script_schema') AS relationships;
DROP DATABASE `db_161135_script_schema`;
UNINSTALL EXTENSION vsql_schematron;
