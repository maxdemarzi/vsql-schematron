INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 263605_simpleorder
--echo #
CREATE DATABASE `db_263605_simpleorder`;
USE `db_263605_simpleorder`;
CREATE TABLE `customer` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Status` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
  `ID` INT,
  `IDCust` INT,
  `Item` VARCHAR(50),
  `Status` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_263605_simpleorder') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_263605_simpleorder') AS relationships;
DROP DATABASE `db_263605_simpleorder`;
UNINSTALL EXTENSION vsql_schematron;
