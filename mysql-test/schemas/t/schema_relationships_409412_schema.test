INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 409412_schema
--echo #
CREATE DATABASE `db_409412_schema`;
USE `db_409412_schema`;
CREATE TABLE `experiment` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `protocol` VARCHAR(50),
  `lab` VARCHAR(50),
  `experimenter` VARCHAR(50),
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `experiment_property` (
  `id` VARCHAR(50) NOT NULL,
  `experiment_id` VARCHAR(50),
  `type` VARCHAR(50),
  `value` TEXT,
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sequence` (
  `id` VARCHAR(50) NOT NULL,
  `experiment_id` VARCHAR(50),
  `name` VARCHAR(50),
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sequence_property` (
  `id` VARCHAR(50) NOT NULL,
  `sequence_id` VARCHAR(50),
  `type` VARCHAR(50),
  `value` TEXT,
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region` (
  `id` VARCHAR(50) NOT NULL,
  `experiment_id` VARCHAR(50),
  `line` VARCHAR(50),
  `name` VARCHAR(50),
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region_property` (
  `id` VARCHAR(50) NOT NULL,
  `region_id` VARCHAR(50),
  `type` VARCHAR(50),
  `value` TEXT,
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_409412_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_409412_schema') AS relationships;
DROP DATABASE `db_409412_schema`;
UNINSTALL EXTENSION vsql_schematron;
