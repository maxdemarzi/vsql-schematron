INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 675127_up
--echo #
CREATE DATABASE `db_675127_up`;
USE `db_675127_up`;
CREATE TABLE `Label` (
  `id` INT NOT NULL,
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tiling` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TilingLabel` (
  `id` INT NOT NULL,
  `tiling_id` INT,
  `label_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Polygon` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PolygonLabel` (
  `id` INT NOT NULL,
  `polygon_id` INT,
  `label_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Point` (
  `id` INT NOT NULL,
  `x` DOUBLE,
  `y` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PolygonPoint` (
  `id` INT NOT NULL,
  `polygon_id` INT,
  `point_id` INT,
  `sequence` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_675127_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_675127_up') AS relationships;
DROP DATABASE `db_675127_up`;
UNINSTALL EXTENSION vsql_schematron;
