INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163505_schema
--echo #
CREATE DATABASE `db_163505_schema`;
USE `db_163505_schema`;
CREATE TABLE `countries` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `property_types` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guest_spaces` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `id` INT NOT NULL,
  `city` VARCHAR(50),
  `country_id` VARCHAR(50),
  `postcode` VARCHAR(50),
  `street_name` VARCHAR(50),
  `street_number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `properties` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `property_type_id` INT,
  `guest_space_id` INT,
  `max_guest_number` INT,
  `bedroom_number` INT,
  `bath_number` INT,
  `price_per_night` INT,
  `address_id` INT,
  `owner` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `property_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `amenities` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `property_amenities` (
  `property_id` INT,
  `amenity_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163505_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163505_schema') AS relationships;
DROP DATABASE `db_163505_schema`;
UNINSTALL EXTENSION vsql_schematron;
