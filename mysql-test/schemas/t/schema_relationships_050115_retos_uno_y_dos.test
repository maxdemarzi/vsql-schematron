INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 050115_retos_uno_y_dos
--echo #
CREATE DATABASE `db_050115_retos_uno_y_dos`;
USE `db_050115_retos_uno_y_dos`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `genero` VARCHAR(50),
  `edad` INT,
  `ocup` INT,
  `cp` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
  `id_movie` INT NOT NULL,
  `title` VARCHAR(50),
  `geners` VARCHAR(50),
  PRIMARY KEY (`id_movie`)
) CHARACTER SET latin1;
CREATE TABLE `rating` (
  `id_users` INT,
  `id_movie` INT,
  `ratings` INT,
  `time_stamp` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_050115_retos_uno_y_dos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_050115_retos_uno_y_dos') AS relationships;
DROP DATABASE `db_050115_retos_uno_y_dos`;
UNINSTALL EXTENSION vsql_schematron;
