INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 030888_structure
--echo #
CREATE DATABASE `db_030888_structure`;
USE `db_030888_structure`;
CREATE TABLE `answers` (
  `id` INT NOT NULL,
  `question_id` INT,
  `answer_text` TEXT,
  `is_correct` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` INT NOT NULL,
  `quiz_id` INT,
  `question_text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quizes` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_answer` (
  `user_id` INT NOT NULL,
  `answer_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `answer_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_030888_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_030888_structure') AS relationships;
DROP DATABASE `db_030888_structure`;
UNINSTALL EXTENSION vsql_schematron;
