INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064048_000004-create-volumes-table
--echo #
CREATE DATABASE `db_064048_000004_create_volumes_table`;
USE `db_064048_000004_create_volumes_table`;
CREATE TABLE `volumes` (
  `id` INT NOT NULL,
  `active` BOOLEAN,
  `copyright` SMALLINT,
  `isbn` TEXT,
  `library_id` INT,
  `location` TEXT,
  `media` TEXT,
  `name` TEXT,
  `notes` TEXT,
  `read` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authors_volumes` (
  `id` INT NOT NULL,
  `author_id` INT,
  `volume_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064048_000004_create_volumes_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064048_000004_create_volumes_table') AS relationships;
DROP DATABASE `db_064048_000004_create_volumes_table`;
UNINSTALL EXTENSION vsql_schematron;
