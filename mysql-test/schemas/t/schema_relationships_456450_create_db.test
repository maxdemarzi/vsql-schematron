INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 456450_create_db
--echo #
CREATE DATABASE `db_456450_create_db`;
USE `db_456450_create_db`;
CREATE TABLE `Autor` (
  `id_autor` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_autor`)
) CHARACTER SET latin1;
CREATE TABLE `Genero` (
  `id_genero` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_genero`)
) CHARACTER SET latin1;
CREATE TABLE `Editorial` (
  `id_editorial` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id_editorial`)
) CHARACTER SET latin1;
CREATE TABLE `Libro` (
  `isbn` VARCHAR(50) NOT NULL,
  `id_autor` INT,
  `id_editorial` INT,
  `titulo` VARCHAR(50),
  `img_referencia` VARCHAR(50),
  `year` INT,
  `descripcion` TEXT,
  `edicion` INT,
  `ubicacion_archivo` VARCHAR(50),
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `LibroHasGenero` (
  `id_lhg` INT NOT NULL,
  `id_libro` VARCHAR(50),
  `id_genero` INT,
  PRIMARY KEY (`id_lhg`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario` (
  `id_usuario` VARCHAR(50) NOT NULL,
  `tipo` VARCHAR(50),
  `nombre` VARCHAR(50),
  `nacimiento` DATE,
  `correo` VARCHAR(50),
  `psswd` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `Favorito` (
  `id_favorito` VARCHAR(50) NOT NULL,
  `id_usuario` VARCHAR(50),
  `id_libro` VARCHAR(50),
  PRIMARY KEY (`id_favorito`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_456450_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_456450_create_db') AS relationships;
DROP DATABASE `db_456450_create_db`;
UNINSTALL EXTENSION vsql_schematron;
