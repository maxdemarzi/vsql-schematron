INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047382_0072
--echo #
CREATE DATABASE `db_047382_0072`;
USE `db_047382_0072`;
CREATE TABLE `barcodes.daklapack_order` (
  `dak_order_id` VARCHAR(50) NOT NULL,
  `submitter_acct_id` VARCHAR(50),
  `description` VARCHAR(50),
  `fulfillment_hold_msg` VARCHAR(50),
  `order_json` VARCHAR(50),
  `creation_timestamp` TIMESTAMP NULL,
  `last_polling_timestamp` TIMESTAMP NULL,
  `last_polling_status` VARCHAR(50),
  PRIMARY KEY (`dak_order_id`)
) CHARACTER SET latin1;
CREATE TABLE `barcodes.daklapack_order_to_project` (
  `dak_order_id` VARCHAR(50) NOT NULL,
  `project_id` BIGINT NOT NULL,
  PRIMARY KEY (`dak_order_id`, `project_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047382_0072') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047382_0072') AS relationships;
DROP DATABASE `db_047382_0072`;
UNINSTALL EXTENSION vsql_schematron;
