INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470571_database
--echo #
CREATE DATABASE `db_470571_database`;
USE `db_470571_database`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `encrypted_password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `statistics` (
  `statistic_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `unit_of_measurement` VARCHAR(50),
  PRIMARY KEY (`statistic_id`)
) CHARACTER SET latin1;
CREATE TABLE `favourites` (
  `favourite_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `statistic_id` VARCHAR(50),
  `priority` VARCHAR(50),
  PRIMARY KEY (`favourite_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470571_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470571_database') AS relationships;
DROP DATABASE `db_470571_database`;
UNINSTALL EXTENSION vsql_schematron;
