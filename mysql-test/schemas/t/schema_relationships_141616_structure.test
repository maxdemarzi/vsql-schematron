INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 141616_structure
--echo #
CREATE DATABASE `db_141616_structure`;
USE `db_141616_structure`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `id` BIGINT NOT NULL,
  `user` INT,
  `token` VARCHAR(50),
  `ip` VARCHAR(50),
  `data` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `country` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_141616_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_141616_structure') AS relationships;
DROP DATABASE `db_141616_structure`;
UNINSTALL EXTENSION vsql_schematron;
