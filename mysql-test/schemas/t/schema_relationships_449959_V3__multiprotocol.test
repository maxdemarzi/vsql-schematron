INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 449959_V3__multiprotocol
--echo #
CREATE DATABASE `db_449959_V3__multiprotocol`;
USE `db_449959_V3__multiprotocol`;
CREATE TABLE `multiprotocol` (
  `id` VARCHAR(50) NOT NULL,
  `created` TIMESTAMP NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `multiprotocol2treatment` (
  `id_multiprotocol` VARCHAR(50) NOT NULL,
  `id_treatment` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id_multiprotocol`, `id_treatment`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_449959_V3__multiprotocol') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_449959_V3__multiprotocol') AS relationships;
DROP DATABASE `db_449959_V3__multiprotocol`;
UNINSTALL EXTENSION vsql_schematron;
