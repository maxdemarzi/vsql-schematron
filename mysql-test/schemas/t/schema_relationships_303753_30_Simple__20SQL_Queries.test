INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303753_30_Simple_%20SQL_Queries
--echo #
CREATE DATABASE `db_303753_30_Simple__20SQL_Queries`;
USE `db_303753_30_Simple__20SQL_Queries`;
CREATE TABLE `department` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `revenue` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `department_id` INT,
  `salary` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303753_30_Simple__20SQL_Queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303753_30_Simple__20SQL_Queries') AS relationships;
DROP DATABASE `db_303753_30_Simple__20SQL_Queries`;
UNINSTALL EXTENSION vsql_schematron;
