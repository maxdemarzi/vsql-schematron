INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115302_mooc
--echo #
CREATE DATABASE `db_115302_mooc`;
USE `db_115302_mooc`;
CREATE TABLE `videos` (
  `id` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `course_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `total_videos_created` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `id` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  `lesson_id` CHAR(50),
  `title` VARCHAR(50),
  `estimated_duration` INT,
  `step_order` INT,
  `creation_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_challenges` (
  `id` VARCHAR(50) NOT NULL,
  `statement` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_quiz` (
  `id` VARCHAR(50) NOT NULL,
  `questions` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_video` (
  `id` VARCHAR(50) NOT NULL,
  `url` VARCHAR(50),
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115302_mooc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115302_mooc') AS relationships;
DROP DATABASE `db_115302_mooc`;
UNINSTALL EXTENSION vsql_schematron;
