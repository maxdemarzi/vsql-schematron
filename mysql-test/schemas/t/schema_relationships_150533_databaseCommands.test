INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 150533_databaseCommands
--echo #
CREATE DATABASE `db_150533_databaseCommands`;
USE `db_150533_databaseCommands`;
CREATE TABLE `individuals` (
  `id` INT NOT NULL,
  `name` TEXT,
  `nickname` TEXT,
  `created_at` TIMESTAMP NULL,
  `species_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sightings` (
  `id` INT NOT NULL,
  `date_of_sighting` DATE,
  `location` VARCHAR(50),
  `healty` BOOLEAN,
  `email_of_sighter` TEXT,
  `individual_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_150533_databaseCommands') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_150533_databaseCommands') AS relationships;
DROP DATABASE `db_150533_databaseCommands`;
UNINSTALL EXTENSION vsql_schematron;
