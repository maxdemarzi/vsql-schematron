INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115441_menus
--echo #
CREATE DATABASE `db_115441_menus`;
USE `db_115441_menus`;
CREATE TABLE `configurations` (
  `id` VARCHAR(50) NOT NULL,
  `name_app` VARCHAR(50),
  `icon_app` VARCHAR(50),
  `email` VARCHAR(50),
  `intro` TEXT,
  `footer` TEXT,
  `meta_description` TEXT,
  `meta_keywords` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menus` (
  `id` VARCHAR(50) NOT NULL,
  `option` VARCHAR(50),
  `url` VARCHAR(50),
  `icon` VARCHAR(50),
  `position` INT,
  `type` VARCHAR(50),
  `references` INT,
  `status` VARCHAR(50),
  `component` VARCHAR(50),
  `title` VARCHAR(50),
  `description` TEXT,
  `table` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `id` VARCHAR(50),
  `typeUser` VARCHAR(50),
  `menu_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `notifications` (
  `id` VARCHAR(50),
  `title` VARCHAR(50),
  `body` TEXT,
  `icon` VARCHAR(50),
  `color` VARCHAR(50),
  `created_at` DATETIME,
  `user_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115441_menus') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115441_menus') AS relationships;
DROP DATABASE `db_115441_menus`;
UNINSTALL EXTENSION vsql_schematron;
