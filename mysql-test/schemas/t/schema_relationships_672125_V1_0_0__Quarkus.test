INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 672125_V1.0.0__Quarkus
--echo #
CREATE DATABASE `db_672125_V1_0_0__Quarkus`;
USE `db_672125_V1_0_0__Quarkus`;
CREATE TABLE `CUSTOMER` (
  `SSN` VARCHAR(50) NOT NULL,
  `FIRSTNAME` VARCHAR(50),
  `LASTNAME` VARCHAR(50),
  `PHONE` VARCHAR(50),
  PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `ADDRESS` (
  `SSN` CHAR(50),
  `ST_ADDRESS` VARCHAR(50),
  `APT_NUMBER` VARCHAR(50),
  `CITY` VARCHAR(50),
  `STATE` VARCHAR(50),
  `ZIPCODE` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNT` (
  `ACCOUNT_ID` INT NOT NULL,
  `SSN` CHAR(50),
  `STATUS` CHAR(50),
  `TYPE` CHAR(50),
  `DATEOPENED` TIMESTAMP NULL,
  `DATECLOSED` TIMESTAMP NULL,
  PRIMARY KEY (`ACCOUNT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCT` (
  `ID` INT NOT NULL,
  `SYMBOL` VARCHAR(50),
  `COMPANY_NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HOLDINGS` (
  `TRANSACTION_ID` INT NOT NULL,
  `ACCOUNT_ID` INT,
  `PRODUCT_ID` INT,
  `PURCHASE_DATE` TIMESTAMP NULL,
  `SHARES_COUNT` INT,
  PRIMARY KEY (`TRANSACTION_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_672125_V1_0_0__Quarkus') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_672125_V1_0_0__Quarkus') AS relationships;
DROP DATABASE `db_672125_V1_0_0__Quarkus`;
UNINSTALL EXTENSION vsql_schematron;
