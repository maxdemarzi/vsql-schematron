INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341213_create_database
--echo #
CREATE DATABASE `db_341213_create_database`;
USE `db_341213_create_database`;
CREATE TABLE `Movie` (
  `mID` INT NOT NULL,
  `title` TEXT,
  `year` INT,
  `director` TEXT,
  PRIMARY KEY (`mID`)
) CHARACTER SET latin1;
CREATE TABLE `Reviewer` (
  `rID` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`rID`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
  `rID` INT NOT NULL,
  `mID` INT NOT NULL,
  `start` INT,
  `ratingDate` TEXT,
  PRIMARY KEY (`rID`, `mID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341213_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341213_create_database') AS relationships;
DROP DATABASE `db_341213_create_database`;
UNINSTALL EXTENSION vsql_schematron;
