INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036850_up
--echo #
CREATE DATABASE `db_036850_up`;
USE `db_036850_up`;
CREATE TABLE `rbac_roles` (
  `id` VARCHAR(50) NOT NULL,
  `parent_id` VARCHAR(50),
  `realm_id` VARCHAR(50),
  `organization_id` VARCHAR(50),
  `name` VARCHAR(50),
  `description` TEXT,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rbac_role_roleables` (
  `role_id` VARCHAR(50) NOT NULL,
  `roleable_id` VARCHAR(50) NOT NULL,
  `roleable_type` VARCHAR(50) NOT NULL,
  `role_constraints` TEXT,
  `effective_at` TIMESTAMP NULL,
  `expired_at` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_by` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`role_id`, `roleable_id`, `roleable_type`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036850_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036850_up') AS relationships;
DROP DATABASE `db_036850_up`;
UNINSTALL EXTENSION vsql_schematron;
