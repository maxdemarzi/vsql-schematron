INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 252220_schema.example
--echo #
CREATE DATABASE `db_252220_schema_example`;
USE `db_252220_schema_example`;
CREATE TABLE `sess` (
  `session_id` INT NOT NULL,
  `session_name` VARCHAR(50),
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
  `id` INT NOT NULL,
  `session_id` INT,
  `product_id` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `styles` (
  `id` INT NOT NULL,
  `productId` INT,
  `name` VARCHAR(50),
  `photos` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
  `id` INT NOT NULL,
  `styleId` INT,
  `photoObj` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_252220_schema_example') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_252220_schema_example') AS relationships;
DROP DATABASE `db_252220_schema_example`;
UNINSTALL EXTENSION vsql_schematron;
