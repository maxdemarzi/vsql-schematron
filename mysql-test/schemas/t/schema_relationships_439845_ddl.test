INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439845_ddl
--echo #
CREATE DATABASE `db_439845_ddl`;
USE `db_439845_ddl`;
CREATE TABLE `Game` (
  `game_id` INT NOT NULL,
  `turn_number` INT,
  `grid_number` INT,
  `user_name` TEXT,
  `win` INT,
  PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `Fighter` (
  `fighter_id` INT NOT NULL,
  `name` TEXT,
  `strength` INT,
  `ship_id` INT,
  PRIMARY KEY (`fighter_id`)
) CHARACTER SET latin1;
CREATE TABLE `Ship` (
  `ship_id` INT NOT NULL,
  `strength` INT,
  `position` INT,
  `game_id` INT,
  `name` INT,
  `type` INT,
  PRIMARY KEY (`ship_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439845_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439845_ddl') AS relationships;
DROP DATABASE `db_439845_ddl`;
UNINSTALL EXTENSION vsql_schematron;
