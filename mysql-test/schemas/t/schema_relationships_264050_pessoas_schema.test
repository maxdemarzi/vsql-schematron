INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 264050_pessoas_schema
--echo #
CREATE DATABASE `db_264050_pessoas_schema`;
USE `db_264050_pessoas_schema`;
CREATE TABLE `cidades` (
  `id` INT NOT NULL,
  `cidade` TEXT,
  `uf` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pessoas` (
  `id` INT NOT NULL,
  `nome` TEXT,
  `sobrenome` TEXT,
  `email` TEXT,
  `cidade_id` INT,
  `criado_em` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_264050_pessoas_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_264050_pessoas_schema') AS relationships;
DROP DATABASE `db_264050_pessoas_schema`;
UNINSTALL EXTENSION vsql_schematron;
