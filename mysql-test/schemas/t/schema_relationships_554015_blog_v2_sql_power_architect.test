INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 554015_blog_v2_sql_power_architect
--echo #
CREATE DATABASE `db_554015_blog_v2_sql_power_architect`;
USE `db_554015_blog_v2_sql_power_architect`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `activated` TINYINT,
  `date_creation` DATE,
  `date_update` DATE,
  `user_role` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `chapo` VARCHAR(50),
  `content` VARCHAR(50),
  `date_creation` DATE,
  `date_update` DATE,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `valid` TINYINT,
  `date_creation` DATE,
  `date_update` DATE,
  `user_id` INT,
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_554015_blog_v2_sql_power_architect') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_554015_blog_v2_sql_power_architect') AS relationships;
DROP DATABASE `db_554015_blog_v2_sql_power_architect`;
UNINSTALL EXTENSION vsql_schematron;
