INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574056_query
--echo #
CREATE DATABASE `db_574056_query`;
USE `db_574056_query`;
CREATE TABLE `customers` (
  `customer_id` INT NOT NULL,
  `name` VARCHAR(50),
  `phone_number` VARCHAR(50),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `item_id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `order_id` INT NOT NULL,
  `customer_id` INT,
  `order_date` DATE,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `itemorders` (
  `order_id` INT,
  `item_id` INT,
  `quantity` INT,
  `price_each` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574056_query') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574056_query') AS relationships;
DROP DATABASE `db_574056_query`;
UNINSTALL EXTENSION vsql_schematron;
