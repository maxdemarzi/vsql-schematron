INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025092_task2
--echo #
CREATE DATABASE `db_025092_task2`;
USE `db_025092_task2`;
CREATE TABLE `HOBBIES` (
  `H#` INT NOT NULL,
  `HobbyName` VARCHAR(50),
  PRIMARY KEY (`H#`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEEHOBBIES` (
  `H#` INT NOT NULL,
  `E#` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`H#`, `E#`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025092_task2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025092_task2') AS relationships;
DROP DATABASE `db_025092_task2`;
UNINSTALL EXTENSION vsql_schematron;
