INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 645243_1.create_schema
--echo #
CREATE DATABASE `db_645243_1_create_schema`;
USE `db_645243_1_create_schema`;
CREATE TABLE `author` (
  `id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `body` TEXT,
  `creation_date` DATETIME,
  `publish_date` DATETIME,
  `author_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_645243_1_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_645243_1_create_schema') AS relationships;
DROP DATABASE `db_645243_1_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
