INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051923_sql
--echo #
CREATE DATABASE `db_051923_sql`;
USE `db_051923_sql`;
CREATE TABLE `companies` (
  `id` INT NOT NULL,
  `name_company` VARCHAR(50),
  `type_services` VARCHAR(50),
  `show_type_services` VARCHAR(50),
  `descriptionServices` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `longitude` VARCHAR(50),
  `latitude` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `zip_code` VARCHAR(50),
  `road` VARCHAR(50),
  `district` VARCHAR(50),
  `city` VARCHAR(50),
  `number_place` VARCHAR(50),
  `fk_id_companies` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051923_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051923_sql') AS relationships;
DROP DATABASE `db_051923_sql`;
UNINSTALL EXTENSION vsql_schematron;
