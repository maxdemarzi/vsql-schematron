INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473677_inventory
--echo #
CREATE DATABASE `db_473677_inventory`;
USE `db_473677_inventory`;
CREATE TABLE `routers` (
  `router_id` VARCHAR(50) NOT NULL,
  `router_type` VARCHAR(50),
  PRIMARY KEY (`router_id`)
) CHARACTER SET latin1;
CREATE TABLE `switches` (
  `switch_id` VARCHAR(50) NOT NULL,
  `router_id` VARCHAR(50),
  `switch_type` VARCHAR(50),
  `switch_ip_protocol` VARCHAR(50),
  `switch_ip_address` VARCHAR(50),
  PRIMARY KEY (`switch_id`)
) CHARACTER SET latin1;
CREATE TABLE `networks` (
  `network_id` INT NOT NULL,
  `switch_id` VARCHAR(50),
  `network_protocol` VARCHAR(50),
  `network_address` VARCHAR(50),
  `network_name` VARCHAR(50),
  `network_cidr` VARCHAR(50),
  PRIMARY KEY (`network_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473677_inventory') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473677_inventory') AS relationships;
DROP DATABASE `db_473677_inventory`;
UNINSTALL EXTENSION vsql_schematron;
