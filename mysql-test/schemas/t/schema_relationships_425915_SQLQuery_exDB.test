INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 425915_SQLQuery_exDB
--echo #
CREATE DATABASE `db_425915_SQLQuery_exDB`;
USE `db_425915_SQLQuery_exDB`;
CREATE TABLE `PDepartment` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Location` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PEmployee` (
  `ID` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LatName` VARCHAR(50),
  `SSN` VARCHAR(50),
  `DeptID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_425915_SQLQuery_exDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_425915_SQLQuery_exDB') AS relationships;
DROP DATABASE `db_425915_SQLQuery_exDB`;
UNINSTALL EXTENSION vsql_schematron;
