INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635967_V5__add_orders
--echo #
CREATE DATABASE `db_635967_V5__add_orders`;
USE `db_635967_V5__add_orders`;
CREATE TABLE `orders` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `user_api_key_id` VARCHAR(50),
  `exchange_name` TEXT,
  `exchange_order_id` TEXT,
  `exchange_market_name` TEXT,
  `market_name` TEXT,
  `side` TEXT,
  `type` TEXT,
  `price` DECIMAL(10,2),
  `quantity` DECIMAL(10,2),
  `quantity_remaining` DECIMAL(10,2),
  `status` TEXT,
  `conditions` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `updated_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_fills` (
  `id` VARCHAR(50) NOT NULL,
  `order_id` VARCHAR(50),
  `condition` VARCHAR(50),
  `price` DECIMAL(10,2),
  `quantity` DECIMAL(10,2),
  `created_on` TIMESTAMP NULL,
  `updated_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635967_V5__add_orders') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635967_V5__add_orders') AS relationships;
DROP DATABASE `db_635967_V5__add_orders`;
UNINSTALL EXTENSION vsql_schematron;
