INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 541211_script
--echo #
CREATE DATABASE `db_541211_script`;
USE `db_541211_script`;
CREATE TABLE `organizacao_causa` (
  `id` INT NOT NULL,
  `idorganizacao` INT,
  `idcausa` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consultoria` (
  `id` INT NOT NULL,
  `idorganizacao` INT,
  `idorientador` INT,
  `idgestor` INT,
  `idconsultor` INT,
  `idconsultor2` INT,
  `idconsultor3` INT,
  `idconsultor4` INT,
  `categoria` VARCHAR(50),
  `ano` INT,
  `semestre` INT,
  `criacao` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consultoria_causa` (
  `id` INT NOT NULL,
  `idconsultoria` INT,
  `idcausa` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_541211_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_541211_script') AS relationships;
DROP DATABASE `db_541211_script`;
UNINSTALL EXTENSION vsql_schematron;
