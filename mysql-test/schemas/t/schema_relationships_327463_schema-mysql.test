INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 327463_schema-mysql
--echo #
CREATE DATABASE `db_327463_schema_mysql`;
USE `db_327463_schema_mysql`;
CREATE TABLE `ACCOUNT_SUMMARY` (
  `id` INT NOT NULL,
  `account_number` VARCHAR(50),
  `current_balance` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSACTION` (
  `id` INT NOT NULL,
  `timestamp` TIMESTAMP NULL,
  `amount` DECIMAL(10,2),
  `account_summary_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_327463_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_327463_schema_mysql') AS relationships;
DROP DATABASE `db_327463_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
