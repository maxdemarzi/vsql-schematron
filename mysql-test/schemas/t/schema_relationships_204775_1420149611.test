INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 204775_1420149611
--echo #
CREATE DATABASE `db_204775_1420149611`;
USE `db_204775_1420149611`;
CREATE TABLE `job` (
  `id` INT NOT NULL,
  `created_on` TIMESTAMP NULL,
  `completed_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job_urls` (
  `id` INT NOT NULL,
  `job_id` INT,
  `url` TEXT,
  `completed_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `url` (
  `id` INT NOT NULL,
  `mime` TEXT,
  `url` TEXT,
  `referer` TEXT,
  `has_descendants` BOOLEAN,
  `created_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `url_pending` (
  `id` INT NOT NULL,
  `origin` TEXT,
  `descendant` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_204775_1420149611') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_204775_1420149611') AS relationships;
DROP DATABASE `db_204775_1420149611`;
UNINSTALL EXTENSION vsql_schematron;
