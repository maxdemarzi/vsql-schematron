INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 385745_M3E5
--echo #
CREATE DATABASE `db_385745_M3E5`;
USE `db_385745_M3E5`;
CREATE TABLE `guilds` (
  `guild_id` BIGINT NOT NULL,
  PRIMARY KEY (`guild_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `guild_id` BIGINT,
  `role_id` BIGINT,
  `role_name` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_385745_M3E5') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_385745_M3E5') AS relationships;
DROP DATABASE `db_385745_M3E5`;
UNINSTALL EXTENSION vsql_schematron;
