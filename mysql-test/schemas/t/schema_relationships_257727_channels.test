INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 257727_channels
--echo #
CREATE DATABASE `db_257727_channels`;
USE `db_257727_channels`;
CREATE TABLE `channel_groups` (
  `id` INT NOT NULL,
  `name` TEXT,
  `Reference` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `channels` (
  `channel_group_id` INT,
  `name` TEXT,
  `type` TEXT,
  `units` TEXT,
  `low_cutoff` DOUBLE,
  `high_cutoff` DOUBLE,
  `reference` TEXT,
  `groups` TEXT,
  `description` TEXT,
  `notch` DOUBLE,
  `status` TEXT,
  `status_description` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_257727_channels') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_257727_channels') AS relationships;
DROP DATABASE `db_257727_channels`;
UNINSTALL EXTENSION vsql_schematron;
