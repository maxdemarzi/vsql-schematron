INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 439357_testdb
--echo #
CREATE DATABASE `db_439357_testdb`;
USE `db_439357_testdb`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `creation_timestamp` DATETIME,
  `update_timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `creation_timestamp` DATETIME,
  `update_timestamp` DATETIME,
  `complete` TINYINT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_439357_testdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_439357_testdb') AS relationships;
DROP DATABASE `db_439357_testdb`;
UNINSTALL EXTENSION vsql_schematron;
