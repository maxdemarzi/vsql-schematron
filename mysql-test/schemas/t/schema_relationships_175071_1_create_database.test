INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175071_1_create_database
--echo #
CREATE DATABASE `db_175071_1_create_database`;
USE `db_175071_1_create_database`;
CREATE TABLE `public.users` (
  `id` INT NOT NULL,
  `username` TEXT,
  `email` TEXT,
  `first_name` TEXT,
  `last_name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.types_spending` (
  `id` INT NOT NULL,
  `type` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.categories_spending` (
  `id` INT NOT NULL,
  `type_id` INT,
  `category` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.budgets_spending` (
  `id` INT NOT NULL,
  `category_id` INT,
  `budget` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.expenses_spending` (
  `id` INT NOT NULL,
  `category_id` INT,
  `description` TEXT,
  `expense` INT,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175071_1_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175071_1_create_database') AS relationships;
DROP DATABASE `db_175071_1_create_database`;
UNINSTALL EXTENSION vsql_schematron;
