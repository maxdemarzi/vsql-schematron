INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574086_V14__Graphenee
--echo #
CREATE DATABASE `db_574086_V14__Graphenee`;
USE `db_574086_V14__Graphenee`;
CREATE TABLE `gx_mobile_application` (
  `oid` INT NOT NULL,
  `application_name` VARCHAR(50),
  `is_active` BOOLEAN,
  `oid_namespace` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_registered_device` (
  `oid` INT NOT NULL,
  `oid_mobile_application` INT,
  `system_name` VARCHAR(50),
  `unique_id` VARCHAR(50),
  `is_tablet` BOOLEAN,
  `brand` VARCHAR(50),
  `is_active` BOOLEAN,
  `owner_id` VARCHAR(50),
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574086_V14__Graphenee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574086_V14__Graphenee') AS relationships;
DROP DATABASE `db_574086_V14__Graphenee`;
UNINSTALL EXTENSION vsql_schematron;
