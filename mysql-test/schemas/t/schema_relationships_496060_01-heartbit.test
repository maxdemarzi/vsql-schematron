INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 496060_01-heartbit
--echo #
CREATE DATABASE `db_496060_01_heartbit`;
USE `db_496060_01_heartbit`;
CREATE TABLE `Users` (
  `ID` INT NOT NULL,
  `LastName` VARCHAR(50),
  `FirstName` VARCHAR(50),
  `Email` VARCHAR(50),
  `GenderCode` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UserData` (
  `DataID` INT NOT NULL,
  `Heartrate` INT,
  `GeoLocation` INT,
  `TimeStamp` TIMESTAMP NULL,
  `Pulse` INT,
  `UserID` INT,
  PRIMARY KEY (`DataID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_496060_01_heartbit') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_496060_01_heartbit') AS relationships;
DROP DATABASE `db_496060_01_heartbit`;
UNINSTALL EXTENSION vsql_schematron;
