INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 150341_DbSupportMySqlIT.create
--echo #
CREATE DATABASE `db_150341_DbSupportMySqlIT_create`;
USE `db_150341_DbSupportMySqlIT_create`;
CREATE TABLE `Customer` (
  `ID` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Street` VARCHAR(50),
  `City` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
  `ID` INT NOT NULL,
  `CustomerID` INT,
  `Total` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Price` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `ID` INT NOT NULL,
  `InvoiceID` INT,
  `Item` INT,
  `ProductID` INT,
  `Quantity` INT,
  `Cost` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_150341_DbSupportMySqlIT_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_150341_DbSupportMySqlIT_create') AS relationships;
DROP DATABASE `db_150341_DbSupportMySqlIT_create`;
UNINSTALL EXTENSION vsql_schematron;
