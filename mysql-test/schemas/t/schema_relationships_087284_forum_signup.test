INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087284_forum_signup
--echo #
CREATE DATABASE `db_087284_forum_signup`;
USE `db_087284_forum_signup`;
CREATE TABLE `characters` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `username` VARCHAR(50),
  `last_update` DATETIME,
  `corporation_name` VARCHAR(50),
  `alliance_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `character_groups` (
  `id` INT NOT NULL,
  `character_id` BIGINT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087284_forum_signup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087284_forum_signup') AS relationships;
DROP DATABASE `db_087284_forum_signup`;
UNINSTALL EXTENSION vsql_schematron;
