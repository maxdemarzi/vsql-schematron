INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033124_atividade%2010
--echo #
CREATE DATABASE `db_033124_atividade_2010`;
USE `db_033124_atividade_2010`;
CREATE TABLE `fornecedor` (
  `codigo_fornecedor` INT NOT NULL,
  `nome` CHAR(50),
  `uf` CHAR(50),
  PRIMARY KEY (`codigo_fornecedor`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `codigo` INT NOT NULL,
  `nome_produto` CHAR(50),
  `estoque` INT,
  `valor` INT,
  `codigo_fornecedor` INT,
  `desconto` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033124_atividade_2010') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033124_atividade_2010') AS relationships;
DROP DATABASE `db_033124_atividade_2010`;
UNINSTALL EXTENSION vsql_schematron;
