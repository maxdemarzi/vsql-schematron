INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373778_blog
--echo #
CREATE DATABASE `db_373778_blog`;
USE `db_373778_blog`;
CREATE TABLE `blog` (
  `blog_id` INT,
  `title` VARCHAR(50),
  `created` VARCHAR(50),
  `description` VARCHAR(50),
  `attachment` VARCHAR(50),
  `user_id` INT,
  `category` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `lastname` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373778_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373778_blog') AS relationships;
DROP DATABASE `db_373778_blog`;
UNINSTALL EXTENSION vsql_schematron;
