INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172077_dhcp_snooping_schema_ver2
--echo #
CREATE DATABASE `db_172077_dhcp_snooping_schema_ver2`;
USE `db_172077_dhcp_snooping_schema_ver2`;
CREATE TABLE `switches` (
  `hostname` VARCHAR(50) NOT NULL,
  `location` TEXT,
  PRIMARY KEY (`hostname`)
) CHARACTER SET latin1;
CREATE TABLE `dhcp` (
  `mac` VARCHAR(50) NOT NULL,
  `ip` TEXT,
  `vlan` TEXT,
  `interface` TEXT,
  `switch` TEXT,
  PRIMARY KEY (`mac`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172077_dhcp_snooping_schema_ver2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172077_dhcp_snooping_schema_ver2') AS relationships;
DROP DATABASE `db_172077_dhcp_snooping_schema_ver2`;
UNINSTALL EXTENSION vsql_schematron;
