INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 034207_migration
--echo #
CREATE DATABASE `db_034207_migration`;
USE `db_034207_migration`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` TEXT,
  `vote_id` TEXT,
  `voteDirection` INT,
  `hasLiked` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
  `id` TEXT,
  `namespace` TEXT,
  `total` INT,
  `type` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_034207_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_034207_migration') AS relationships;
DROP DATABASE `db_034207_migration`;
UNINSTALL EXTENSION vsql_schematron;
