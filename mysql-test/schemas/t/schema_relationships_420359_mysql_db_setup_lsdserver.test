INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 420359_mysql_db_setup_lsdserver
--echo #
CREATE DATABASE `db_420359_mysql_db_setup_lsdserver`;
USE `db_420359_mysql_db_setup_lsdserver`;
CREATE TABLE `license_status` (
  `id` INT NOT NULL,
  `status` INT,
  `license_updated` DATETIME,
  `status_updated` DATETIME,
  `device_count` INT,
  `potential_rights_end` DATETIME,
  `license_ref` VARCHAR(50),
  `rights_end` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `id` INT NOT NULL,
  `device_name` VARCHAR(50),
  `timestamp` DATETIME,
  `type` INT,
  `device_id` VARCHAR(50),
  `license_status_fk` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_420359_mysql_db_setup_lsdserver') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_420359_mysql_db_setup_lsdserver') AS relationships;
DROP DATABASE `db_420359_mysql_db_setup_lsdserver`;
UNINSTALL EXTENSION vsql_schematron;
