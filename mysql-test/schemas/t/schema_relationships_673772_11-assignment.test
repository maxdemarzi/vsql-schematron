INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 673772_11-assignment
--echo #
CREATE DATABASE `db_673772_11_assignment`;
USE `db_673772_11_assignment`;
CREATE TABLE `mediatype` (
  `mediatypeID` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`mediatypeID`)
) CHARACTER SET latin1;
CREATE TABLE `genre` (
  `genreID` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`genreID`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
  `artistID` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`artistID`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
  `albumID` DECIMAL(10,2) NOT NULL,
  `title` VARCHAR(50),
  `artistID` DECIMAL(10,2),
  PRIMARY KEY (`albumID`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
  `trackID` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `albumID` DECIMAL(10,2),
  `mediatypeID` DECIMAL(10,2),
  `genreID` DECIMAL(10,2),
  `composer` VARCHAR(50),
  `milliseconds` DECIMAL(10,2),
  `bytes` DECIMAL(10,2),
  `unitprice` DECIMAL(10,2),
  PRIMARY KEY (`trackID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_673772_11_assignment') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_673772_11_assignment') AS relationships;
DROP DATABASE `db_673772_11_assignment`;
UNINSTALL EXTENSION vsql_schematron;
