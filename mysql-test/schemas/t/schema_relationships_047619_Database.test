INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047619_Database
--echo #
CREATE DATABASE `db_047619_Database`;
USE `db_047619_Database`;
CREATE TABLE `harta` (
  `id_harta` VARCHAR(50),
  `id_profil` VARCHAR(50),
  `jenis` VARCHAR(50),
  `jumlah` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `profil` (
  `id_profil` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `nama` VARCHAR(50),
  `alamat` VARCHAR(50),
  `tempat_lahir` VARCHAR(50),
  `tanggal_lahir` VARCHAR(50),
  `gender` VARCHAR(50),
  `no_telp` VARCHAR(50),
  `foto_profil` VARCHAR(50),
  PRIMARY KEY (`id_profil`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047619_Database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047619_Database') AS relationships;
DROP DATABASE `db_047619_Database`;
UNINSTALL EXTENSION vsql_schematron;
