INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558772_init-schema
--echo #
CREATE DATABASE `db_558772_init_schema`;
USE `db_558772_init_schema`;
CREATE TABLE `tbl_task` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `done` BOOLEAN,
  `time_started` TIMESTAMP NULL,
  `date_created` TIMESTAMP NULL,
  `next_task` VARCHAR(50),
  `parent_task` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_player` (
  `id` VARCHAR(50) NOT NULL,
  `name_alias` VARCHAR(50),
  `date_joined` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_assignment` (
  `player_id` VARCHAR(50) NOT NULL,
  `task_id` VARCHAR(50) NOT NULL,
  `date_assigned` TIMESTAMP NULL,
  PRIMARY KEY (`player_id`, `task_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558772_init_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558772_init_schema') AS relationships;
DROP DATABASE `db_558772_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
