INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212996_tables
--echo #
CREATE DATABASE `db_212996_tables`;
USE `db_212996_tables`;
CREATE TABLE `User` (
  `user_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` CHAR(50),
  `join_date` DATETIME,
  `last_login_date` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `item_id` INT NOT NULL,
  `user_id` CHAR(50),
  `post_date` DATETIME,
  `body` VARCHAR(50),
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212996_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212996_tables') AS relationships;
DROP DATABASE `db_212996_tables`;
UNINSTALL EXTENSION vsql_schematron;
