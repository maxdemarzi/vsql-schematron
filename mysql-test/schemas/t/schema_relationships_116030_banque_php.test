INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116030_banque_php
--echo #
CREATE DATABASE `db_116030_banque_php`;
USE `db_116030_banque_php`;
CREATE TABLE `customer` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `user_password` VARCHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `street_number` VARCHAR(50),
  `street_address` VARCHAR(50),
  `area_code` VARCHAR(50),
  `city` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
  `id` VARCHAR(50) NOT NULL,
  `account_type` VARCHAR(50),
  `account_number` VARCHAR(50),
  `account_amount` DECIMAL(10,2),
  `account_fees` DECIMAL(10,2),
  `creation_date` DATE,
  `customer_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operation` (
  `id` VARCHAR(50) NOT NULL,
  `type_of_operation` VARCHAR(50),
  `label` VARCHAR(50),
  `operation_date` DATE,
  `amount` DECIMAL(10,2),
  `account_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116030_banque_php') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116030_banque_php') AS relationships;
DROP DATABASE `db_116030_banque_php`;
UNINSTALL EXTENSION vsql_schematron;
