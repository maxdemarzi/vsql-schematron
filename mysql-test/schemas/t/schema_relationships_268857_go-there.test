INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 268857_go-there
--echo #
CREATE DATABASE `db_268857_go_there`;
USE `db_268857_go_there`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `is_admin` TINYINT,
  `password_hash` VARCHAR(50),
  `api_key_hash` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `go` (
  `path` VARCHAR(50),
  `target` TEXT,
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_268857_go_there') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_268857_go_there') AS relationships;
DROP DATABASE `db_268857_go_there`;
UNINSTALL EXTENSION vsql_schematron;
