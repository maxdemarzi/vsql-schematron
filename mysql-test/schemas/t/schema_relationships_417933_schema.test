INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417933_schema
--echo #
CREATE DATABASE `db_417933_schema`;
USE `db_417933_schema`;
CREATE TABLE `course` (
  `courseid` INT NOT NULL,
  `coursecode` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`courseid`)
) CHARACTER SET latin1;
CREATE TABLE `studentcourse` (
  `studentid` INT,
  `courseid` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417933_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417933_schema') AS relationships;
DROP DATABASE `db_417933_schema`;
UNINSTALL EXTENSION vsql_schematron;
