INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 540672_demo
--echo #
CREATE DATABASE `db_540672_demo`;
USE `db_540672_demo`;
CREATE TABLE `languages` (
  `lang_id` BIGINT NOT NULL,
  `name` TEXT,
  `code` TEXT,
  PRIMARY KEY (`lang_id`)
) CHARACTER SET latin1;
CREATE TABLE `wordtypes` (
  `wordtype_id` BIGINT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`wordtype_id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `tag_id` BIGINT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
  `entry_id` BIGINT NOT NULL,
  `headword` TEXT,
  `wordtype` BIGINT,
  `definition` TEXT,
  `hw_lang` BIGINT,
  `def_lang` BIGINT,
  PRIMARY KEY (`entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `entry_tags` (
  `tag_id` BIGINT NOT NULL,
  `entry_id` BIGINT NOT NULL,
  PRIMARY KEY (`tag_id`, `entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `uid` BIGINT NOT NULL,
  `username` TEXT,
  `hash` TEXT,
  `email` TEXT,
  `dob` DATE,
  `gender` TEXT,
  `joindate` TIMESTAMP NULL,
  `language` BIGINT,
  `fluency` VARCHAR(50),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_540672_demo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_540672_demo') AS relationships;
DROP DATABASE `db_540672_demo`;
UNINSTALL EXTENSION vsql_schematron;
