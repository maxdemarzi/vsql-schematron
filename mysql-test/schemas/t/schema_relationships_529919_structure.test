INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 529919_structure
--echo #
CREATE DATABASE `db_529919_structure`;
USE `db_529919_structure`;
CREATE TABLE `Participant` (
  `id` VARCHAR(50) NOT NULL,
  `userId` VARCHAR(50),
  `eventId` VARCHAR(50),
  `requestTime` DATETIME,
  `approved` VARCHAR(50),
  `disqualified` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id` VARCHAR(50) NOT NULL,
  `eventId` VARCHAR(50),
  `userId` VARCHAR(50),
  `Comment` VARCHAR(50),
  `createTime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
  `id` VARCHAR(50) NOT NULL,
  `participantId` VARCHAR(50),
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `gitRepoUri` VARCHAR(50),
  `demoPageUri` VARCHAR(50),
  `createTime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProjectBlog` (
  `id` VARCHAR(50) NOT NULL,
  `projectId` VARCHAR(50),
  `title` VARCHAR(50),
  `blogText` VARCHAR(50),
  `createTime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
  `id` VARCHAR(50) NOT NULL,
  `userId` VARCHAR(50),
  `projectId` VARCHAR(50),
  `creativity` VARCHAR(50),
  `implementation` VARCHAR(50),
  `structure` VARCHAR(50),
  `technology` VARCHAR(50),
  `scope` VARCHAR(50),
  `submitTime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_529919_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_529919_structure') AS relationships;
DROP DATABASE `db_529919_structure`;
UNINSTALL EXTENSION vsql_schematron;
