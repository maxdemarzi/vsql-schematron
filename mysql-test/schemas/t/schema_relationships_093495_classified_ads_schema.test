INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093495_classified_ads_schema
--echo #
CREATE DATABASE `db_093495_classified_ads_schema`;
USE `db_093495_classified_ads_schema`;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
  `id` INT NOT NULL,
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
  `id` INT NOT NULL,
  `ad_id` INT,
  `image_url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ads_tags` (
  `id` INT NOT NULL,
  `ad_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093495_classified_ads_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093495_classified_ads_schema') AS relationships;
DROP DATABASE `db_093495_classified_ads_schema`;
UNINSTALL EXTENSION vsql_schematron;
