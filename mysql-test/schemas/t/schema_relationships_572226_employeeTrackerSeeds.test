INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 572226_employeeTrackerSeeds
--echo #
CREATE DATABASE `db_572226_employeeTrackerSeeds`;
USE `db_572226_employeeTrackerSeeds`;
CREATE TABLE `departments` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `salary` DECIMAL(10,2),
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_572226_employeeTrackerSeeds') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_572226_employeeTrackerSeeds') AS relationships;
DROP DATABASE `db_572226_employeeTrackerSeeds`;
UNINSTALL EXTENSION vsql_schematron;
