INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 029611_shopgiay
--echo #
CREATE DATABASE `db_029611_shopgiay`;
USE `db_029611_shopgiay`;
CREATE TABLE `ADMIN` (
  `AD_ID` INT NOT NULL,
  `AD_USERNAME` VARCHAR(50),
  `AD_PASSWORD` VARCHAR(50),
  `AD_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`AD_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATRUC` (
  `CA_ID` INT NOT NULL,
  `AD_ID` INT,
  `CA_TEN` VARCHAR(50),
  `CA_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`CA_ID`)
) CHARACTER SET latin1;
CREATE TABLE `HOADON` (
  `HD_ID` INT NOT NULL,
  `KH_ID` INT,
  `NV_ID` INT,
  `HD_NGAYLAP` VARCHAR(50),
  `HD_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`HD_ID`)
) CHARACTER SET latin1;
CREATE TABLE `KHACHHANG` (
  `KH_ID` INT NOT NULL,
  `KH_USERNAME` VARCHAR(50),
  `KH_PASSWORD` VARCHAR(50),
  `KH_HOTEN` VARCHAR(50),
  `KH_NGAYSINH` VARCHAR(50),
  `KH_GIOITINH` SMALLINT,
  `KH_DIACHI` VARCHAR(50),
  `KH_SDT` VARCHAR(50),
  `KH_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`KH_ID`)
) CHARACTER SET latin1;
CREATE TABLE `KHUYENMAI` (
  `KM_ID` INT NOT NULL,
  `KM_NGAYBD` VARCHAR(50),
  `KM_NGAYKT` VARCHAR(50),
  `KM_PHANTRAM` DOUBLE,
  `KM_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`KM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOAIGIAY` (
  `LOAI_ID` INT NOT NULL,
  `LOAI_TEN` VARCHAR(50),
  `LOAI_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`LOAI_ID`)
) CHARACTER SET latin1;
CREATE TABLE `NHACUNGCAP` (
  `NCC_ID` INT NOT NULL,
  `NCC_TEN` VARCHAR(50),
  `NCC_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`NCC_ID`)
) CHARACTER SET latin1;
CREATE TABLE `NHANVIEN` (
  `NV_ID` INT NOT NULL,
  `NV_USERNAME` VARCHAR(50),
  `NV_PASSWORD` VARCHAR(50),
  `NV_HOTEN` VARCHAR(50),
  `NV_GIOITINH` SMALLINT,
  `NV_NGAYSINH` VARCHAR(50),
  `NV_DIACHI` VARCHAR(50),
  `NV_SDT` VARCHAR(50),
  `NV_TRANGTHAI` SMALLINT,
  PRIMARY KEY (`NV_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_029611_shopgiay') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_029611_shopgiay') AS relationships;
DROP DATABASE `db_029611_shopgiay`;
UNINSTALL EXTENSION vsql_schematron;
