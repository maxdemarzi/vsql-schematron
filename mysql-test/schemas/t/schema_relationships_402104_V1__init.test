INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 402104_V1__init
--echo #
CREATE DATABASE `db_402104_V1__init`;
USE `db_402104_V1__init`;
CREATE TABLE `ponto_eletronico.empresa` (
  `id_empresa` INT NOT NULL,
  `num_cnpj` VARCHAR(50),
  `data_criacao` TIMESTAMP NULL,
  `data_atualizacao` TIMESTAMP NULL,
  `razao_social` VARCHAR(50),
  PRIMARY KEY (`id_empresa`)
) CHARACTER SET latin1;
CREATE TABLE `ponto_eletronico.funcionario` (
  `id_funcionario` INT NOT NULL,
  `num_cpf` VARCHAR(50),
  `email` VARCHAR(50),
  `nome` VARCHAR(50),
  `data_criacao` TIMESTAMP NULL,
  `data_atualizacao` TIMESTAMP NULL,
  `perfil` VARCHAR(50),
  `senha` VARCHAR(50),
  `qtd_horas_almoco` DECIMAL(10,2),
  `qtd_horas_trabalho_dia` DECIMAL(10,2),
  `valor_hora` DECIMAL(10,2),
  `id_empresa_fk` INT,
  PRIMARY KEY (`id_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `ponto_eletronico.lancamento` (
  `id_lancamento` INT NOT NULL,
  `data_lancamento` TIMESTAMP NULL,
  `data_criacao` TIMESTAMP NULL,
  `data_atualizacao` TIMESTAMP NULL,
  `descricao` VARCHAR(50),
  `localizacao` VARCHAR(50),
  `tipo_lancamento` VARCHAR(50),
  `id_funcionario_fk` INT,
  PRIMARY KEY (`id_lancamento`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_402104_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_402104_V1__init') AS relationships;
DROP DATABASE `db_402104_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
