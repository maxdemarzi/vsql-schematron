INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 485422_20210602063413_create_db
--echo #
CREATE DATABASE `db_485422_20210602063413_create_db`;
USE `db_485422_20210602063413_create_db`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `twitter_user_id` TEXT,
  `twitter_name` TEXT,
  `twitter_handle` TEXT,
  `profile_url` TEXT,
  `profile_image` TEXT,
  `followers_count` BIGINT,
  `following_count` BIGINT,
  `listed_count` BIGINT,
  `tweet_count` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `tweet_id` TEXT,
  `tweet_created_at` TIMESTAMP NULL,
  `tweet_text` TEXT,
  `tweet_url` TEXT,
  `replied_to_tweet_id` TEXT,
  `quoted_tweet_id` TEXT,
  `tweet_class` TEXT,
  `like_count` BIGINT,
  `quote_count` BIGINT,
  `reply_count` BIGINT,
  `retweet_count` BIGINT,
  `total_retweet_count` BIGINT,
  `popularity_count` BIGINT,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `media` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `media_key` TEXT,
  `media_type` TEXT,
  `display_url` TEXT,
  `tweet_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_485422_20210602063413_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_485422_20210602063413_create_db') AS relationships;
DROP DATABASE `db_485422_20210602063413_create_db`;
UNINSTALL EXTENSION vsql_schematron;
