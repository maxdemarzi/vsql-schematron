INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 661253_001_inicial
--echo #
CREATE DATABASE `db_661253_001_inicial`;
USE `db_661253_001_inicial`;
CREATE TABLE `usuarios` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `senha` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mensagens` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `texto` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_661253_001_inicial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_661253_001_inicial') AS relationships;
DROP DATABASE `db_661253_001_inicial`;
UNINSTALL EXTENSION vsql_schematron;
