  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `PARENT_ID` BIGINT,
  `SCOPE_ID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
