INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 513294_V001__Create_Veracode_SCA_Tables
--echo #
CREATE DATABASE `db_513294_V001__Create_Veracode_SCA_Tables`;
USE `db_513294_V001__Create_Veracode_SCA_Tables`;
CREATE TABLE `veracode_sca_clients` (
  `client_id` VARCHAR(50) NOT NULL,
  `api_id` VARCHAR(50),
  `api_secret_key` VARCHAR(50),
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `veracode_sca_thresholds` (
  `thresholds_id` VARCHAR(50) NOT NULL,
  `green_yellow` BIGINT,
  `yellow_red` BIGINT,
  PRIMARY KEY (`thresholds_id`)
) CHARACTER SET latin1;
CREATE TABLE `veracode_sca_workspaces` (
  `workspace_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `site_id` VARCHAR(50),
  `excluded` BOOLEAN,
  PRIMARY KEY (`workspace_id`)
) CHARACTER SET latin1;
CREATE TABLE `veracode_sca_projects` (
  `project_id` VARCHAR(50) NOT NULL,
  `branches` TEXT,
  `default_branch` VARCHAR(50),
  `last_scan_date` TIMESTAMP NULL,
  `name` VARCHAR(50),
  `site_id` VARCHAR(50),
  `workspace_id` VARCHAR(50),
  `synapse_project` BIGINT,
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `veracode_sca_issues` (
  `issue_id` VARCHAR(50) NOT NULL,
  `created_date` TIMESTAMP NULL,
  `ignored_date` TIMESTAMP NULL,
  `fixed_date` TIMESTAMP NULL,
  `last_updated_date` TIMESTAMP NULL,
  `ignored` BOOLEAN,
  `issue_status` VARCHAR(50),
  `issue_type` VARCHAR(50),
  `project_branch` VARCHAR(50),
  `project_id` VARCHAR(50),
  `severity` DOUBLE,
  `vulnerability` VARCHAR(50),
  `vulnerable_method` BOOLEAN,
  PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513294_V001__Create_Veracode_SCA_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513294_V001__Create_Veracode_SCA_Tables') AS relationships;
DROP DATABASE `db_513294_V001__Create_Veracode_SCA_Tables`;
UNINSTALL EXTENSION vsql_schematron;
