INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212178_GuorjAccount
--echo #
CREATE DATABASE `db_212178_GuorjAccount`;
USE `db_212178_GuorjAccount`;
CREATE TABLE `roles` (
  `RoleID` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `userroles` (
  `UserID` VARCHAR(50) NOT NULL,
  `RoleID` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`UserID`, `RoleID`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `ID` VARCHAR(50) NOT NULL,
  `NickName` VARCHAR(50),
  `Birthday` DATE,
  `Gender` TINYINT,
  `CreateAt` DATETIME,
  `UpdateAt` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212178_GuorjAccount') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212178_GuorjAccount') AS relationships;
DROP DATABASE `db_212178_GuorjAccount`;
UNINSTALL EXTENSION vsql_schematron;
