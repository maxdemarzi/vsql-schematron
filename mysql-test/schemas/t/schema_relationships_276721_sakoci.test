INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276721_sakoci
--echo #
CREATE DATABASE `db_276721_sakoci`;
USE `db_276721_sakoci`;
CREATE TABLE `admin` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `jadwal` (
  `ID` INT NOT NULL,
  `hari` VARCHAR(50),
  `jam` VARCHAR(50),
  `lokasi` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `kendaraan` (
  `id` VARCHAR(50),
  `no_kendaraan` VARCHAR(50) NOT NULL,
  `merk` VARCHAR(50),
  `tahun_pembuatan` VARCHAR(50),
  `tipe` VARCHAR(50),
  `jenis` VARCHAR(50),
  `no_rangka` VARCHAR(50),
  `no_mesin` VARCHAR(50),
  `warna` VARCHAR(50),
  `warna_tnkb` VARCHAR(50),
  `no_bpkb` VARCHAR(50),
  PRIMARY KEY (`no_kendaraan`)
) CHARACTER SET latin1;
CREATE TABLE `krisar` (
  `id` INT NOT NULL,
  `subjek` VARCHAR(50),
  `pesan` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pajak` (
  `id` VARCHAR(50),
  `no_kendaraan` VARCHAR(50),
  `nama_pemilik` VARCHAR(50),
  `biaya_pokok` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276721_sakoci') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276721_sakoci') AS relationships;
DROP DATABASE `db_276721_sakoci`;
UNINSTALL EXTENSION vsql_schematron;
