INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139120_bank
--echo #
CREATE DATABASE `db_139120_bank`;
USE `db_139120_bank`;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `category` INT,
  `tag` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139120_bank') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139120_bank') AS relationships;
DROP DATABASE `db_139120_bank`;
UNINSTALL EXTENSION vsql_schematron;
