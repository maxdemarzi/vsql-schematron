INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464641_V2017082701_Initial
--echo #
CREATE DATABASE `db_464641_V2017082701_Initial`;
USE `db_464641_V2017082701_Initial`;
CREATE TABLE `auth_password` (
  `id` BIGINT NOT NULL,
  `expire` DATETIME,
  `hashed_password` VARCHAR(50),
  `single_use` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `login_token` (
  `id` BIGINT NOT NULL,
  `expire` DATETIME,
  `login_token` VARCHAR(50),
  `redirect_url` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `address` VARCHAR(50),
  `email` VARCHAR(50),
  `first_name` VARCHAR(50),
  `is_admin` VARCHAR(50),
  `lang` VARCHAR(50),
  `last_name` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464641_V2017082701_Initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464641_V2017082701_Initial') AS relationships;
DROP DATABASE `db_464641_V2017082701_Initial`;
UNINSTALL EXTENSION vsql_schematron;
