INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636578_test-escaping
--echo #
CREATE DATABASE `db_636578_test_escaping`;
USE `db_636578_test_escaping`;
CREATE TABLE `TABLE` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GROUP` (
  `ID` DECIMAL(10,2) NOT NULL,
  `TABLE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636578_test_escaping') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636578_test_escaping') AS relationships;
DROP DATABASE `db_636578_test_escaping`;
UNINSTALL EXTENSION vsql_schematron;
