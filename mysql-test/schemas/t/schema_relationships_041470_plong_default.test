INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041470_plong_default
--echo #
CREATE DATABASE `db_041470_plong_default`;
USE `db_041470_plong_default`;
CREATE TABLE `migrations` (
  `migration` VARCHAR(50),
  `batch` INT
) CHARACTER SET latin1;
CREATE TABLE `real_answers` (
  `reply_id` VARCHAR(50),
  `answer_id` VARCHAR(50),
  `input` VARCHAR(50),
  `unknown` TINYINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `replies` (
  `id` VARCHAR(50) NOT NULL,
  `residence_id` VARCHAR(50),
  `question_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041470_plong_default') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041470_plong_default') AS relationships;
DROP DATABASE `db_041470_plong_default`;
UNINSTALL EXTENSION vsql_schematron;
