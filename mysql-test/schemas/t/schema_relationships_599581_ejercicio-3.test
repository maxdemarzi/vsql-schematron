INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 599581_ejercicio-3
--echo #
CREATE DATABASE `db_599581_ejercicio_3`;
USE `db_599581_ejercicio_3`;
CREATE TABLE `profesor` (
  `DNI` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `direccion` VARCHAR(50),
  `tlf` INT,
  PRIMARY KEY (`DNI`)
) CHARACTER SET latin1;
CREATE TABLE `modulo` (
  `ID` INT NOT NULL,
  `nombre` VARCHAR(50),
  `dni_profesor` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `alumno` (
  `num_expediente` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `fecha_nacimiento` DATE,
  PRIMARY KEY (`num_expediente`)
) CHARACTER SET latin1;
CREATE TABLE `matriculas_modulo` (
  `id_modulo` INT,
  `num_expediente_alumno` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_599581_ejercicio_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_599581_ejercicio_3') AS relationships;
DROP DATABASE `db_599581_ejercicio_3`;
UNINSTALL EXTENSION vsql_schematron;
