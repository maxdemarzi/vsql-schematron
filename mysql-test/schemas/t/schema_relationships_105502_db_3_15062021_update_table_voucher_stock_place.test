INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105502_db_3_15062021_update_table_voucher_stock_place
--echo #
CREATE DATABASE `db_105502_db_3_15062021_update_table_voucher_stock_place`;
USE `db_105502_db_3_15062021_update_table_voucher_stock_place`;
CREATE TABLE `Voucher` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `begin_date` TIMESTAMP NULL,
  `end_date` TIMESTAMP NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_deleted` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Place` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `short_name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_deleted` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Stock` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `place_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_deleted` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `StockInProduct` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `stock_id` INT,
  `product_id` INT,
  `quantity` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `is_deleted` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105502_db_3_15062021_update_table_voucher_stock_place') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105502_db_3_15062021_update_table_voucher_stock_place') AS relationships;
DROP DATABASE `db_105502_db_3_15062021_update_table_voucher_stock_place`;
UNINSTALL EXTENSION vsql_schematron;
