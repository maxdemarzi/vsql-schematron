INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098723_schema
--echo #
CREATE DATABASE `db_098723_schema`;
USE `db_098723_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activityType` (
  `id` INT NOT NULL,
  `activityType` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activity` (
  `id` INT NOT NULL,
  `inputUser` INT,
  `activityType` INT,
  `activityDescription` TEXT,
  `activityLengthSec` INT,
  `entryDatetime` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098723_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098723_schema') AS relationships;
DROP DATABASE `db_098723_schema`;
UNINSTALL EXTENSION vsql_schematron;
