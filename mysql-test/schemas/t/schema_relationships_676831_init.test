INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 676831_init
--echo #
CREATE DATABASE `db_676831_init`;
USE `db_676831_init`;
CREATE TABLE `demo_product` (
  `id` BIGINT NOT NULL,
  `create_by_id` BIGINT,
  `create_date` DATETIME,
  `status` INT,
  `update_by_id` BIGINT,
  `update_date` DATETIME,
  `code` VARCHAR(50),
  `description` VARCHAR(50),
  `display_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `demo_sales_item` (
  `id` BIGINT NOT NULL,
  `create_by_id` BIGINT,
  `create_date` DATETIME,
  `status` INT,
  `update_by_id` BIGINT,
  `update_date` DATETIME,
  `code` VARCHAR(50),
  `number` INT,
  `type` VARCHAR(50),
  `product_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `demo_json_template` (
  `id` BIGINT NOT NULL,
  `create_by_id` BIGINT,
  `create_date` DATETIME,
  `status` INT,
  `update_by_id` BIGINT,
  `update_date` DATETIME,
  `template_key` VARCHAR(50),
  `template_value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_676831_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_676831_init') AS relationships;
DROP DATABASE `db_676831_init`;
UNINSTALL EXTENSION vsql_schematron;
