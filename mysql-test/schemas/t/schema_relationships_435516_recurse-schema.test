INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 435516_recurse-schema
--echo #
CREATE DATABASE `db_435516_recurse_schema`;
USE `db_435516_recurse_schema`;
CREATE TABLE `TREE_ELEMENT` (
  `ID` DECIMAL(10,2) NOT NULL,
  `VALUE` VARCHAR(50),
  `PARENT_ID` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_435516_recurse_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_435516_recurse_schema') AS relationships;
DROP DATABASE `db_435516_recurse_schema`;
UNINSTALL EXTENSION vsql_schematron;
