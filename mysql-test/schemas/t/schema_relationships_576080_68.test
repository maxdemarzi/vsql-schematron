INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576080_68
--echo #
CREATE DATABASE `db_576080_68`;
USE `db_576080_68`;
CREATE TABLE `institution` (
  `id` INT NOT NULL,
  `organization_id` INT,
  `name` TEXT,
  `type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `organization_id` INT,
  `person_id` INT,
  `institution_id` INT,
  `type` INT,
  `initial_balance` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576080_68') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576080_68') AS relationships;
DROP DATABASE `db_576080_68`;
UNINSTALL EXTENSION vsql_schematron;
