INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 457901_migration
--echo #
CREATE DATABASE `db_457901_migration`;
USE `db_457901_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `token` TEXT,
  `administrator` BOOLEAN,
  `embedTitle` TEXT,
  `embedColor` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Image` (
  `id` INT NOT NULL,
  `file` TEXT,
  `mimetype` TEXT,
  `created_at` TIMESTAMP NULL,
  `views` INT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `InvisibleImage` (
  `id` INT,
  `invis` TEXT
) CHARACTER SET latin1;
CREATE TABLE `Url` (
  `id` INT NOT NULL,
  `to` TEXT,
  `created_at` TIMESTAMP NULL,
  `views` INT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `InvisibleUrl` (
  `id` INT,
  `invis` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_457901_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_457901_migration') AS relationships;
DROP DATABASE `db_457901_migration`;
UNINSTALL EXTENSION vsql_schematron;
