INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145645_eSocial_201807
--echo #
CREATE DATABASE `db_145645_eSocial_201807`;
USE `db_145645_eSocial_201807`;
CREATE TABLE `ESOCIAL_FATOR_RISCO` (
  `CODIGO` VARCHAR(50) NOT NULL,
  `DESCRICAO` VARCHAR(50),
  PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `DEPTO_FATOR_RISCO` (
  `ID_DEPTO` INT NOT NULL,
  `ID_FATOR_RISCO` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`ID_DEPTO`, `ID_FATOR_RISCO`)
) CHARACTER SET latin1;
CREATE TABLE `ESOCIAL_RETORNO_PROTOCOLO` (
  `NUMERO` VARCHAR(50) NOT NULL,
  `INSCRICAO` VARCHAR(50),
  `DATA_HORA` TIMESTAMP NULL,
  `VERSAO` VARCHAR(50),
  `ARQUIVO_ENVIADO` BLOB,
  `ARQUIVO_RETORNO` BLOB,
  PRIMARY KEY (`NUMERO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145645_eSocial_201807') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145645_eSocial_201807') AS relationships;
DROP DATABASE `db_145645_eSocial_201807`;
UNINSTALL EXTENSION vsql_schematron;
