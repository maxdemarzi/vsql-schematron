INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 022700_database
--echo #
CREATE DATABASE `db_022700_database`;
USE `db_022700_database`;
CREATE TABLE `Owner` (
  `OwnerId` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `DateOfBirth` DATE,
  `Address` VARCHAR(50),
  PRIMARY KEY (`OwnerId`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
  `AccountId` VARCHAR(50) NOT NULL,
  `DateCreated` DATE,
  `AccountType` VARCHAR(50),
  `OwnerId` CHAR(50),
  PRIMARY KEY (`AccountId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_022700_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_022700_database') AS relationships;
DROP DATABASE `db_022700_database`;
UNINSTALL EXTENSION vsql_schematron;
