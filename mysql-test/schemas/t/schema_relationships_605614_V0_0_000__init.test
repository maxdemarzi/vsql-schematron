INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605614_V0_0_000__init
--echo #
CREATE DATABASE `db_605614_V0_0_000__init`;
USE `db_605614_V0_0_000__init`;
CREATE TABLE `todo` (
  `id` INT NOT NULL,
  `title` CHAR(50),
  `content` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todo_comment` (
  `id` INT NOT NULL,
  `todo_id` INT,
  `content` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605614_V0_0_000__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605614_V0_0_000__init') AS relationships;
DROP DATABASE `db_605614_V0_0_000__init`;
UNINSTALL EXTENSION vsql_schematron;
