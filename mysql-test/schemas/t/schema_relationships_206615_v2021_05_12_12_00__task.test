INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 206615_v2021.05.12_12.00__task
--echo #
CREATE DATABASE `db_206615_v2021_05_12_12_00__task`;
USE `db_206615_v2021_05_12_12_00__task`;
CREATE TABLE `CATGENOME.TASK` (
  `TASK_ID` BIGINT NOT NULL,
  `TITLE` VARCHAR(50),
  `CREATED_DATE` TIMESTAMP NULL,
  `STATUS` INT,
  `END_DATE` TIMESTAMP NULL,
  `STATUS_REASON` VARCHAR(50),
  `QUERY` VARCHAR(50),
  `DATABASE` VARCHAR(50),
  `EXECUTABLE` VARCHAR(50),
  `ALGORITHM` VARCHAR(50),
  `OPTIONS` VARCHAR(50),
  `OWNER` VARCHAR(50),
  PRIMARY KEY (`TASK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_PARAMETER` (
  `PARAMETER_ID` BIGINT NOT NULL,
  `TASK_ID` BIGINT,
  `PARAMETER` VARCHAR(50),
  `VALUE` VARCHAR(50),
  PRIMARY KEY (`PARAMETER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_ORGANISM` (
  `ORGANISM_ID` BIGINT NOT NULL,
  `TASK_ID` BIGINT,
  `ORGANISM` VARCHAR(50),
  PRIMARY KEY (`ORGANISM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATGENOME.TASK_EXCL_ORGANISM` (
  `ORGANISM_ID` BIGINT NOT NULL,
  `TASK_ID` BIGINT,
  `ORGANISM` VARCHAR(50),
  PRIMARY KEY (`ORGANISM_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_206615_v2021_05_12_12_00__task') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_206615_v2021_05_12_12_00__task') AS relationships;
DROP DATABASE `db_206615_v2021_05_12_12_00__task`;
UNINSTALL EXTENSION vsql_schematron;
