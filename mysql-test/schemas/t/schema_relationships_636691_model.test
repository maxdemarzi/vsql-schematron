INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636691_model
--echo #
CREATE DATABASE `db_636691_model`;
USE `db_636691_model`;
CREATE TABLE `elector` (
  `elecId` INT NOT NULL,
  `elecIp` TEXT,
  PRIMARY KEY (`elecId`)
) CHARACTER SET latin1;
CREATE TABLE `alternative` (
  `altId` INT NOT NULL,
  `altName` TEXT,
  `altDescription` TEXT,
  `altIcon` TEXT,
  PRIMARY KEY (`altId`)
) CHARACTER SET latin1;
CREATE TABLE `ranking` (
  `elecId` INT NOT NULL,
  `altId` INT NOT NULL,
  `rankMin` INT,
  `rankMax` INT,
  PRIMARY KEY (`elecId`, `altId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636691_model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636691_model') AS relationships;
DROP DATABASE `db_636691_model`;
UNINSTALL EXTENSION vsql_schematron;
