INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317945_oficina
--echo #
CREATE DATABASE `db_317945_oficina`;
USE `db_317945_oficina`;
CREATE TABLE `clientes` (
  `cpf` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  `idade` INT,
  `rg` VARCHAR(50),
  `telefone` VARCHAR(50),
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `carros` (
  `placa` VARCHAR(50) NOT NULL,
  `anomodelo` INT,
  `marca` VARCHAR(50),
  `modelo` VARCHAR(50),
  `anofabricacao` INT,
  `cpf_cliente` VARCHAR(50),
  PRIMARY KEY (`placa`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317945_oficina') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317945_oficina') AS relationships;
DROP DATABASE `db_317945_oficina`;
UNINSTALL EXTENSION vsql_schematron;
