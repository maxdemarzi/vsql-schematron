INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 155673_schema
--echo #
CREATE DATABASE `db_155673_schema`;
USE `db_155673_schema`;
CREATE TABLE `account` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `secret` BLOB,
  `create_date` DATE,
  `change_date` DATE,
  `deleted` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chef` (
  `id` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  `rfc` VARCHAR(50),
  `curp` VARCHAR(50),
  `rating` DOUBLE,
  `create_date` DATE,
  `change_date` DATE,
  `deleted` VARCHAR(50),
  `fk_id_account` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `telephone` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `number` VARCHAR(50),
  `lada` VARCHAR(50),
  `type` VARCHAR(50),
  `fk_id_chef` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
  `id` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `rating` DOUBLE,
  `create_date` DATE,
  `change_date` DATE,
  `deleted` VARCHAR(50),
  `fk_id_telephone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_155673_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_155673_schema') AS relationships;
DROP DATABASE `db_155673_schema`;
UNINSTALL EXTENSION vsql_schematron;
