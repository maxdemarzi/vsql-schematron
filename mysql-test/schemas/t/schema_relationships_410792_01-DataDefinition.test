INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410792_01-DataDefinition
--echo #
CREATE DATABASE `db_410792_01_DataDefinition`;
USE `db_410792_01_DataDefinition`;
CREATE TABLE `Classes` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `subject` VARCHAR(50),
  `course_number` INT,
  `section` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Assignments` (
  `id` INT NOT NULL,
  `class_id` INT,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `pin` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Ratings` (
  `id` INT NOT NULL,
  `score` SMALLINT,
  `category` VARCHAR(50),
  `assignment_id` INT,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
  `id` INT NOT NULL,
  `body` TEXT,
  `created` DATETIME,
  `author_id` INT,
  `assignment_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Votes` (
  `student_id` INT,
  `comment_id` INT,
  `value` SMALLINT
) CHARACTER SET latin1;
CREATE TABLE `Students_Classes` (
  `student_id` INT,
  `class_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410792_01_DataDefinition') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410792_01_DataDefinition') AS relationships;
DROP DATABASE `db_410792_01_DataDefinition`;
UNINSTALL EXTENSION vsql_schematron;
