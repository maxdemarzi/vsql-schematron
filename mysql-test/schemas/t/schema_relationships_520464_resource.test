INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520464_resource
--echo #
CREATE DATABASE `db_520464_resource`;
USE `db_520464_resource`;
CREATE TABLE `IDN_UMA_RESOURCE` (
  `ID` INT NOT NULL,
  `RESOURCE_ID` VARCHAR(50),
  `RESOURCE_NAME` VARCHAR(50),
  `TIME_CREATED` TIMESTAMP NULL,
  `RESOURCE_OWNER_NAME` VARCHAR(50),
  `TENANT_ID` INT,
  `CLIENT_ID` VARCHAR(50),
  `USER_DOMAIN` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `IDN_UMA_RESOURCE_SCOPE` (
  `ID` INT NOT NULL,
  `RESOURCE_IDENTITY` INT,
  `SCOPE_NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `IDN_UMA_RESOURCE_META_DATA` (
  `ID` INT NOT NULL,
  `RESOURCE_IDENTITY` INT,
  `PROPERTY_KEY` VARCHAR(50),
  `PROPERTY_VALUE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520464_resource') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520464_resource') AS relationships;
DROP DATABASE `db_520464_resource`;
UNINSTALL EXTENSION vsql_schematron;
