INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 203694_postgresql
--echo #
CREATE DATABASE `db_203694_postgresql`;
USE `db_203694_postgresql`;
CREATE TABLE `Acct_perf` (
  `ACCT_NUM` INT NOT NULL,
  `PRD_CD` INT,
  `CREDIT_RISK_INDICATOR` VARCHAR(50),
  `TM_ON_BOOK` INT,
  `DAY_PST_DUE` INT,
  `RMNG_AMORT_PERIOD` INT,
  `DEFLT_INSUR_CD` VARCHAR(50),
  `CRNT_AUTH_LIMIT_AMT` DECIMAL(10,2),
  `OS_BAL_AMT` DECIMAL(10,2),
  `PRPTY_TYPE_CD` VARCHAR(50),
  `PRPTY_POSTAL_CD` CHAR(50),
  `CRNT_LTV_RATIO` DOUBLE,
  `MTH_END_DT` DATE,
  `INSURANCE_FEE_INDICATOR` VARCHAR(50),
  PRIMARY KEY (`ACCT_NUM`)
) CHARACTER SET latin1;
CREATE TABLE `DATA_PRODUCT_MAPPING_LKP` (
  `PRD_CD` INT NOT NULL,
  `IB_CB_INDICATOR` CHAR(50),
  `PRD_LVL1` VARCHAR(50),
  `PRD_LVL2` VARCHAR(50),
  `PRD_LVL3` VARCHAR(50),
  `PRD_LVL4` VARCHAR(50),
  `PRD_LVL5` VARCHAR(50),
  `EFF_FROM_DT` DATE,
  `EFF_TO_DT` DATE,
  `CRNT_F` CHAR(50),
  `INSRT_PROCESS_TMSTMP` DECIMAL(10,2),
  `UPDT_PROCESS_TMSTMP` DECIMAL(10,2),
  PRIMARY KEY (`PRD_CD`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_203694_postgresql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_203694_postgresql') AS relationships;
DROP DATABASE `db_203694_postgresql`;
UNINSTALL EXTENSION vsql_schematron;
