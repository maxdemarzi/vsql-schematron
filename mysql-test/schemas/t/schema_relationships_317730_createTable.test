INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317730_createTable
--echo #
CREATE DATABASE `db_317730_createTable`;
USE `db_317730_createTable`;
CREATE TABLE `folders_t` (
  `folder_id` INT NOT NULL,
  `folder_name` VARCHAR(50),
  `folder_path` VARCHAR(50),
  `rem` VARCHAR(50),
  PRIMARY KEY (`folder_id`)
) CHARACTER SET latin1;
CREATE TABLE `files_t` (
  `file_id` INT NOT NULL,
  `file_name` VARCHAR(50),
  `upload_datetime` DATETIME,
  `folder_id` INT,
  `rem` VARCHAR(50),
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317730_createTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317730_createTable') AS relationships;
DROP DATABASE `db_317730_createTable`;
UNINSTALL EXTENSION vsql_schematron;
