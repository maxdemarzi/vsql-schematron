INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547067_learing
--echo #
CREATE DATABASE `db_547067_learing`;
USE `db_547067_learing`;
CREATE TABLE `comments` (
  `ID` INT NOT NULL,
  `POST_ID` INT,
  `NAME` VARCHAR(50),
  `COMMENT` VARCHAR(50),
  `CREATE_DATE` DATETIME,
  `EDIT_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `ID` INT NOT NULL,
  `BLOG_ID` INT,
  `AUTHOR_ID` INT,
  `SECTION` VARCHAR(50),
  `SUBJECT` VARCHAR(50),
  `DRAFT` VARCHAR(50),
  `BODY` VARCHAR(50),
  `CREATED_ON` DATETIME,
  `EDIT_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
  `ID` INT NOT NULL,
  `POST_ID` INT,
  `TAG_ID` INT,
  `CREATE_DATE` DATETIME,
  `EDIT_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `ID` INT NOT NULL,
  `NAME` INT,
  `CREATE_DATE` DATETIME,
  `EDIT_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547067_learing') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547067_learing') AS relationships;
DROP DATABASE `db_547067_learing`;
UNINSTALL EXTENSION vsql_schematron;
