INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 550030_corephpblog
--echo #
CREATE DATABASE `db_550030_corephpblog`;
USE `db_550030_corephpblog`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `role` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `views` INT,
  `image` VARCHAR(50),
  `body` TEXT,
  `published` TINYINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `topics` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `slug` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_topic` (
  `id` INT NOT NULL,
  `post_id` INT,
  `topic_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_550030_corephpblog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_550030_corephpblog') AS relationships;
DROP DATABASE `db_550030_corephpblog`;
UNINSTALL EXTENSION vsql_schematron;
