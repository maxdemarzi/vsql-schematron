INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576470_Base
--echo #
CREATE DATABASE `db_576470_Base`;
USE `db_576470_Base`;
CREATE TABLE `admin` (
  `idadmin` INT NOT NULL,
  `nom` VARCHAR(50),
  `login` VARCHAR(50),
  `mdp` VARCHAR(50),
  PRIMARY KEY (`idadmin`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `iduser` INT NOT NULL,
  `login` VARCHAR(50),
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `mdp` VARCHAR(50),
  PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `categorie` (
  `idcategorie` INT NOT NULL,
  `nom` VARCHAR(50),
  `icone` VARCHAR(50),
  PRIMARY KEY (`idcategorie`)
) CHARACTER SET latin1;
CREATE TABLE `contenu` (
  `idcontenu` INT NOT NULL,
  `daty` DATE,
  `titre` VARCHAR(50),
  `categories` VARCHAR(50),
  `typee` VARCHAR(50),
  `texte` VARCHAR(50),
  `photo` VARCHAR(50),
  `video` VARCHAR(50),
  `audio` VARCHAR(50),
  `pdf` VARCHAR(50),
  `etat` VARCHAR(50),
  `visites` INT,
  `prix` DOUBLE,
  `iduser` INT,
  `idadmin` INT,
  `auteur` VARCHAR(50),
  PRIMARY KEY (`idcontenu`)
) CHARACTER SET latin1;
CREATE TABLE `geolocalisation` (
  `idcontenu` INT,
  `latitude` DOUBLE,
  `longitude` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576470_Base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576470_Base') AS relationships;
DROP DATABASE `db_576470_Base`;
UNINSTALL EXTENSION vsql_schematron;
