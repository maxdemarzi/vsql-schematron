INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 308395_students
--echo #
CREATE DATABASE `db_308395_students`;
USE `db_308395_students`;
CREATE TABLE `Modules` (
  `code` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Programmes` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Programme_Modules` (
  `programme` VARCHAR(50),
  `module` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Student_Programme` (
  `id` INT,
  `programme` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_308395_students') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_308395_students') AS relationships;
DROP DATABASE `db_308395_students`;
UNINSTALL EXTENSION vsql_schematron;
