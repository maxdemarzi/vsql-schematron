INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524558_booking_system
--echo #
CREATE DATABASE `db_524558_booking_system`;
USE `db_524558_booking_system`;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `slug` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(50),
  `slug` VARCHAR(50),
  `image` VARCHAR(50),
  `price` DOUBLE,
  `description` TEXT,
  `category_id` INT
) CHARACTER SET latin1;
CREATE TABLE `reservations` (
  `id` INT,
  `transaction_id` VARCHAR(50),
  `date_time` DATETIME,
  `no_of_people` INT,
  `contact_number` VARCHAR(50),
  `status` VARCHAR(50),
  `user_id` INT,
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `token` VARCHAR(50),
  `active` TINYINT,
  `is_admin` TINYINT,
  `is_product_manager` TINYINT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524558_booking_system') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524558_booking_system') AS relationships;
DROP DATABASE `db_524558_booking_system`;
UNINSTALL EXTENSION vsql_schematron;
