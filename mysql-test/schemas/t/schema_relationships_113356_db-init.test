INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113356_db-init
--echo #
CREATE DATABASE `db_113356_db_init`;
USE `db_113356_db_init`;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `email` VARCHAR(50),
  `access_granted` BOOLEAN,
  `role_id` INT,
  `last_seen` TIMESTAMP NULL,
  `creation_date` TIMESTAMP NULL,
  `failed_login_attempts` INT,
  `pass_change_req` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `details` VARCHAR(50),
  `time_creation` TIMESTAMP NULL,
  `all_day_event` BOOLEAN,
  `time_event_start` TIMESTAMP NULL,
  `time_event_stop` TIMESTAMP NULL,
  `to_notify` BOOLEAN,
  `time_notify` TIMESTAMP NULL,
  `author_uid` INT,
  `notification_sent` BOOLEAN,
  `is_active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `log` (
  `id` INT NOT NULL,
  `log_name` VARCHAR(50),
  `level` VARCHAR(50),
  `msg` VARCHAR(50),
  `time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notification` (
  `id` INT NOT NULL,
  `notify_unit` VARCHAR(50),
  `notify_interval` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_to_event` (
  `user_id` INT,
  `event_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113356_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113356_db_init') AS relationships;
DROP DATABASE `db_113356_db_init`;
UNINSTALL EXTENSION vsql_schematron;
