INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 682107_masakyuk
--echo #
CREATE DATABASE `db_682107_masakyuk`;
USE `db_682107_masakyuk`;
CREATE TABLE `kategori` (
  `id_kategori` INT NOT NULL,
  `nama_kategori` VARCHAR(50),
  PRIMARY KEY (`id_kategori`)
) CHARACTER SET latin1;
CREATE TABLE `resep` (
  `id_resep` INT,
  `nama_resep` VARCHAR(50),
  `deskripsi` TEXT,
  `deskripsi_singkat` TEXT,
  `ingridient` TEXT,
  `rating` INT,
  `gambar` VARCHAR(50),
  `petunjuk_pembuatan` TEXT,
  `kategori` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_682107_masakyuk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_682107_masakyuk') AS relationships;
DROP DATABASE `db_682107_masakyuk`;
UNINSTALL EXTENSION vsql_schematron;
