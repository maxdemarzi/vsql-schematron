INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 488385_schema_driver
--echo #
CREATE DATABASE `db_488385_schema_driver`;
USE `db_488385_schema_driver`;
CREATE TABLE `party_driver` (
  `party_id` VARCHAR(50) NOT NULL,
  `status_id` VARCHAR(50),
  `last_updated_stamp` TIMESTAMP NULL,
  `created_stamp` TIMESTAMP NULL,
  PRIMARY KEY (`party_id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicle_driver` (
  `vehicle_driver_id` VARCHAR(50) NOT NULL,
  `party_driver_id` VARCHAR(50),
  `vehicle_id` VARCHAR(50),
  `from_date` TIMESTAMP NULL,
  `thru_date` TIMESTAMP NULL,
  `last_updated_stamp` TIMESTAMP NULL,
  `created_stamp` TIMESTAMP NULL,
  PRIMARY KEY (`vehicle_driver_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_488385_schema_driver') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_488385_schema_driver') AS relationships;
DROP DATABASE `db_488385_schema_driver`;
UNINSTALL EXTENSION vsql_schematron;
