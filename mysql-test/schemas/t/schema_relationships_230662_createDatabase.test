INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 230662_createDatabase
--echo #
CREATE DATABASE `db_230662_createDatabase`;
USE `db_230662_createDatabase`;
CREATE TABLE `AUTHOR` (
  `ID` BIGINT NOT NULL,
  `FIRSTNAME` VARCHAR(50),
  `LASTNAME` VARCHAR(50),
  `VITA` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
  `ID` BIGINT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  `ISBN` VARCHAR(50),
  `TITLE` VARCHAR(50),
  `PUBLISHER_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR_BOOK` (
  `AUTHOR_ID` BIGINT NOT NULL,
  `BOOK_ID` BIGINT NOT NULL,
  PRIMARY KEY (`AUTHOR_ID`, `BOOK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SEQUENCE` (
  `SEQ_NAME` VARCHAR(50) NOT NULL,
  `SEQ_COUNT` DECIMAL(10,2),
  PRIMARY KEY (`SEQ_NAME`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_230662_createDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_230662_createDatabase') AS relationships;
DROP DATABASE `db_230662_createDatabase`;
UNINSTALL EXTENSION vsql_schematron;
