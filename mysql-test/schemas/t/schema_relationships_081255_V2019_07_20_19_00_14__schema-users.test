INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081255_V2019_07_20_19_00_14__schema-users
--echo #
CREATE DATABASE `db_081255_V2019_07_20_19_00_14__schema_users`;
USE `db_081255_V2019_07_20_19_00_14__schema_users`;
CREATE TABLE `AUTH_ROLES` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_PRIVILEGES` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` TIMESTAMP NULL,
  `last_update_by` VARCHAR(50),
  `last_update_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_AUTHORITIES` (
  `id` VARCHAR(50) NOT NULL,
  `privilege_id` VARCHAR(50),
  `role_id` INT,
  `created_by` VARCHAR(50),
  `created_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_USER_PRIVILEGES` (
  `id` VARCHAR(50) NOT NULL,
  `privilege_id` VARCHAR(50),
  `user_id` DECIMAL(10,2),
  `created_by` VARCHAR(50),
  `created_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081255_V2019_07_20_19_00_14__schema_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081255_V2019_07_20_19_00_14__schema_users') AS relationships;
DROP DATABASE `db_081255_V2019_07_20_19_00_14__schema_users`;
UNINSTALL EXTENSION vsql_schematron;
