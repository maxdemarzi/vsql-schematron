INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046821_schema
--echo #
CREATE DATABASE `db_046821_schema`;
USE `db_046821_schema`;
CREATE TABLE `Person` (
  `id` VARCHAR(50) NOT NULL,
  `lastName` VARCHAR(50),
  `firstName` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Contract` (
  `id` VARCHAR(50) NOT NULL,
  `number` VARCHAR(50),
  `premium` DECIMAL(10,2),
  `inceptionDate` DATE,
  `signingTime` TIMESTAMP NULL,
  `comments` VARCHAR(50),
  `insuredPerson` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046821_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046821_schema') AS relationships;
DROP DATABASE `db_046821_schema`;
UNINSTALL EXTENSION vsql_schematron;
