INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 080308_lib.model.schema
--echo #
CREATE DATABASE `db_080308_lib_model_schema`;
USE `db_080308_lib_model_schema`;
CREATE TABLE `author` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `is_alive` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` INT NOT NULL,
  `author_id` INT,
  `title` VARCHAR(50),
  `year` INT,
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_080308_lib_model_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_080308_lib_model_schema') AS relationships;
DROP DATABASE `db_080308_lib_model_schema`;
UNINSTALL EXTENSION vsql_schematron;
