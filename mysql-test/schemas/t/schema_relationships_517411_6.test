INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 517411_6
--echo #
CREATE DATABASE `db_517411_6`;
USE `db_517411_6`;
CREATE TABLE `prioritypointsconfiguration` (
  `id` BIGINT NOT NULL,
  `emailAddress` VARCHAR(50),
  `daytimeTelephoneNumber` VARCHAR(50),
  `mobilePhoneNumber` VARCHAR(50),
  `address` VARCHAR(50),
  `creditCardNumber` VARCHAR(50),
  `creditCardSecurityCode` INT,
  `creditCardExpiryMonth` INT,
  `creditCardExpiryYear` INT,
  `nameOnCreditCard` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `referenceNumber` INT,
  `priorityPointsConfigurationId` BIGINT,
  `clientType` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_517411_6') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_517411_6') AS relationships;
DROP DATABASE `db_517411_6`;
UNINSTALL EXTENSION vsql_schematron;
