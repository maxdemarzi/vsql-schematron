INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635799_001_migrations
--echo #
CREATE DATABASE `db_635799_001_migrations`;
USE `db_635799_001_migrations`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `username` TEXT,
  `email` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_messages` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `message` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635799_001_migrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635799_001_migrations') AS relationships;
DROP DATABASE `db_635799_001_migrations`;
UNINSTALL EXTENSION vsql_schematron;
