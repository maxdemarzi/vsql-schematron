INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 457344_000001_init_schema.up
--echo #
CREATE DATABASE `db_457344_000001_init_schema_up`;
USE `db_457344_000001_init_schema_up`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `languages` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `time_limit` INT,
  `memory` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_cases` (
  `id` INT NOT NULL,
  `task_id` INT,
  `test_data` TEXT,
  `answer` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history_user` (
  `uuid` VARCHAR(50) NOT NULL,
  `user_id` INT,
  `task_id` INT,
  `language_id` INT,
  `solution` TEXT,
  `result` VARCHAR(50),
  `timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_457344_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_457344_000001_init_schema_up') AS relationships;
DROP DATABASE `db_457344_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
