INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 092563_territorial_hierarchy
--echo #
CREATE DATABASE `db_092563_territorial_hierarchy`;
USE `db_092563_territorial_hierarchy`;
CREATE TABLE `District` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Municipality` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `district` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Town` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `municipality` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_092563_territorial_hierarchy') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_092563_territorial_hierarchy') AS relationships;
DROP DATABASE `db_092563_territorial_hierarchy`;
UNINSTALL EXTENSION vsql_schematron;
