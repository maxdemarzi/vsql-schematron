INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373495_init
--echo #
CREATE DATABASE `db_373495_init`;
USE `db_373495_init`;
CREATE TABLE `user_i` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `avatar` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `theme` VARCHAR(50),
  `last_login` TIMESTAMP NULL,
  `password_reset_token` TEXT,
  `currency_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currency` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `country` VARCHAR(50),
  `symbol` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373495_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373495_init') AS relationships;
DROP DATABASE `db_373495_init`;
UNINSTALL EXTENSION vsql_schematron;
