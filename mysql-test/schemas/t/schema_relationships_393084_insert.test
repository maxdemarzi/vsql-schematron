INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 393084_insert
--echo #
CREATE DATABASE `db_393084_insert`;
USE `db_393084_insert`;
CREATE TABLE `alumno` (
  `id_alumno` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id_alumno`)
) CHARACTER SET latin1;
CREATE TABLE `cuadernos` (
  `id_cuaderno` INT NOT NULL,
  `tamanio` VARCHAR(50),
  `alumno_id` INT,
  PRIMARY KEY (`id_cuaderno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_393084_insert') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_393084_insert') AS relationships;
DROP DATABASE `db_393084_insert`;
UNINSTALL EXTENSION vsql_schematron;
