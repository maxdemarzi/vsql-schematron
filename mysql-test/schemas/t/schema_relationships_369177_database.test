INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 369177_database
--echo #
CREATE DATABASE `db_369177_database`;
USE `db_369177_database`;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `senha` VARCHAR(50),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `bueiro` (
  `id_bueiro` INT NOT NULL,
  `id_usuario` INT,
  `nome` VARCHAR(50),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id_bueiro`)
) CHARACTER SET latin1;
CREATE TABLE `sinais` (
  `sin_id` INT NOT NULL,
  `id_bueiro` INT,
  `sin_dist` VARCHAR(50),
  `sin_data` DATETIME,
  PRIMARY KEY (`sin_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_369177_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_369177_database') AS relationships;
DROP DATABASE `db_369177_database`;
UNINSTALL EXTENSION vsql_schematron;
