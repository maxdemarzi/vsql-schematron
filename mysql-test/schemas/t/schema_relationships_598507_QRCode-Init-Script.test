INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 598507_QRCode-Init-Script
--echo #
CREATE DATABASE `db_598507_QRCode_Init_Script`;
USE `db_598507_QRCode_Init_Script`;
CREATE TABLE `qr_report_v1.Users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `passwordHash` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `qr_report_v1.Assets` (
  `id` INT NOT NULL,
  `uniqueIdentifier` VARCHAR(50),
  `building` VARCHAR(50),
  `roomNumber` VARCHAR(50),
  `appliance` VARCHAR(50),
  `serviceRequired` BOOLEAN,
  `userID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_598507_QRCode_Init_Script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_598507_QRCode_Init_Script') AS relationships;
DROP DATABASE `db_598507_QRCode_Init_Script`;
UNINSTALL EXTENSION vsql_schematron;
