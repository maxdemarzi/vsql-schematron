INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426486_personal_blog
--echo #
CREATE DATABASE `db_426486_personal_blog`;
USE `db_426486_personal_blog`;
CREATE TABLE `tbl_berita` (
  `id_berita` INT NOT NULL,
  `judul_berita` VARCHAR(50),
  `desk` TEXT,
  `berita` TEXT,
  `foto` TEXT,
  `tgl_input` TIMESTAMP NULL,
  `tgl_update` TIMESTAMP NULL,
  `url_slug` VARCHAR(50),
  `tags` TEXT,
  PRIMARY KEY (`id_berita`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_komentar` (
  `id_komen` INT,
  `id_parent_komen` INT,
  `id_berita` INT,
  `email` VARCHAR(50),
  `nama` VARCHAR(50),
  `komen` TEXT,
  `captcha` VARCHAR(50),
  `tgl_input` TIMESTAMP NULL,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tbl_kontak` (
  `id_kontak` INT NOT NULL,
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  `subjek` VARCHAR(50),
  `pesan` TEXT,
  `tgl_input` TIMESTAMP NULL,
  PRIMARY KEY (`id_kontak`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426486_personal_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426486_personal_blog') AS relationships;
DROP DATABASE `db_426486_personal_blog`;
UNINSTALL EXTENSION vsql_schematron;
