INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 278545_ex1_new_personnel
--echo #
CREATE DATABASE `db_278545_ex1_new_personnel`;
USE `db_278545_ex1_new_personnel`;
CREATE TABLE `DEPT` (
  `DEPTNO` INT NOT NULL,
  `DNAME` VARCHAR(50),
  `LOC` VARCHAR(50),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `PROJ` (
  `PROJ_CODE` INT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`PROJ_CODE`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGN` (
  `EMPNO` INT NOT NULL,
  `PROJ_CODE` INT NOT NULL,
  `A_TIME` INT,
  PRIMARY KEY (`EMPNO`, `PROJ_CODE`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_278545_ex1_new_personnel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_278545_ex1_new_personnel') AS relationships;
DROP DATABASE `db_278545_ex1_new_personnel`;
UNINSTALL EXTENSION vsql_schematron;
