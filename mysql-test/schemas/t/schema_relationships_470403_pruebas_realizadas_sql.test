INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 470403_pruebas_realizadas_sql
--echo #
CREATE DATABASE `db_470403_pruebas_realizadas_sql`;
USE `db_470403_pruebas_realizadas_sql`;
CREATE TABLE `Sujetos` (
  `SujetoID` INT NOT NULL,
  `Edad` INT,
  `Sexo` TEXT,
  PRIMARY KEY (`SujetoID`)
) CHARACTER SET latin1;
CREATE TABLE `PruebasRealizadas` (
  `PruebaRealizadaID` INT NOT NULL,
  `SujetoID` INT,
  `FechaHora` TEXT,
  `PathArchivoEDF` TEXT,
  PRIMARY KEY (`PruebaRealizadaID`)
) CHARACTER SET latin1;
CREATE TABLE `Tests` (
  `TestID` INT NOT NULL,
  `TestNombre` TEXT,
  `TestDescripcion` TEXT,
  PRIMARY KEY (`TestID`)
) CHARACTER SET latin1;
CREATE TABLE `PruebasDetalles` (
  `PruebaRealizadaID` INT NOT NULL,
  `TestRealizadoNumber` INT NOT NULL,
  `Puntuacion` INT,
  `TestID` INT,
  PRIMARY KEY (`PruebaRealizadaID`, `TestRealizadoNumber`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_470403_pruebas_realizadas_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_470403_pruebas_realizadas_sql') AS relationships;
DROP DATABASE `db_470403_pruebas_realizadas_sql`;
UNINSTALL EXTENSION vsql_schematron;
