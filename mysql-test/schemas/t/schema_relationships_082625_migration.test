INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 082625_migration
--echo #
CREATE DATABASE `db_082625_migration`;
USE `db_082625_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `createdAt` DATETIME,
  `email` TEXT,
  `name` TEXT,
  `password` TEXT,
  `groupId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `published` BOOLEAN,
  `title` TEXT,
  `authorId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id` INT NOT NULL,
  `contain` TEXT,
  `postId` INT,
  `authorId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Group` (
  `id` INT NOT NULL,
  `name` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_082625_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_082625_migration') AS relationships;
DROP DATABASE `db_082625_migration`;
UNINSTALL EXTENSION vsql_schematron;
