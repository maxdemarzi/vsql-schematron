INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303049_V0.0.1__user_mgmt_tables
--echo #
CREATE DATABASE `db_303049_V0_0_1__user_mgmt_tables`;
USE `db_303049_V0_0_1__user_mgmt_tables`;
CREATE TABLE `address_info` (
  `id` INT NOT NULL,
  `disabled` VARCHAR(50),
  `uuid` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` VARCHAR(50),
  `updated_date` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `preferred` VARCHAR(50),
  `address1` VARCHAR(50),
  `address2` VARCHAR(50),
  `address3` VARCHAR(50),
  `city` VARCHAR(50),
  `country` VARCHAR(50),
  `state` VARCHAR(50),
  `type` VARCHAR(50),
  `zip` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `email_info` (
  `id` INT NOT NULL,
  `disabled` VARCHAR(50),
  `uuid` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` VARCHAR(50),
  `updated_date` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `preferred` VARCHAR(50),
  `email` VARCHAR(50),
  `type` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `name_info` (
  `id` INT NOT NULL,
  `disabled` VARCHAR(50),
  `uuid` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` VARCHAR(50),
  `updated_date` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `preferred` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `title` VARCHAR(50),
  `user_id` INT,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone_info` (
  `id` INT NOT NULL,
  `disabled` VARCHAR(50),
  `uuid` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` VARCHAR(50),
  `updated_date` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `preferred` VARCHAR(50),
  `phone` VARCHAR(50),
  `type` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_info` (
  `id` INT NOT NULL,
  `disabled` VARCHAR(50),
  `uuid` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created_date` VARCHAR(50),
  `updated_date` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303049_V0_0_1__user_mgmt_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303049_V0_0_1__user_mgmt_tables') AS relationships;
DROP DATABASE `db_303049_V0_0_1__user_mgmt_tables`;
UNINSTALL EXTENSION vsql_schematron;
