INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 323696_tables
--echo #
CREATE DATABASE `db_323696_tables`;
USE `db_323696_tables`;
CREATE TABLE `users` (
  `id_users` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id_users`)
) CHARACTER SET latin1;
CREATE TABLE `players` (
  `Numero_de_licence` VARCHAR(50) NOT NULL,
  `Nom` VARCHAR(50),
  `Prenom` VARCHAR(50),
  `Photo` VARCHAR(50),
  `Date_de_naissance` DATE,
  `Taille` SMALLINT,
  `Poids` SMALLINT,
  `Poste_prefere` CHAR(50),
  `Statut` VARCHAR(50),
  PRIMARY KEY (`Numero_de_licence`)
) CHARACTER SET latin1;
CREATE TABLE `rencontre` (
  `Id_rencontre` INT NOT NULL,
  `Date_rencontre` DATE,
  `Heure_rencontre` TIME,
  `Nom_adversaire` VARCHAR(50),
  `Lieu_de_rencontre` VARCHAR(50),
  `Points_equipe` SMALLINT,
  `Points_adversaire` SMALLINT,
  PRIMARY KEY (`Id_rencontre`)
) CHARACTER SET latin1;
CREATE TABLE `jouer` (
  `Numero_de_licence` VARCHAR(50) NOT NULL,
  `Id_rencontre` INT NOT NULL,
  `Titulaire` BOOLEAN,
  `Note` BOOLEAN,
  `Commentaire` TEXT,
  PRIMARY KEY (`Id_rencontre`, `Numero_de_licence`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_323696_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_323696_tables') AS relationships;
DROP DATABASE `db_323696_tables`;
UNINSTALL EXTENSION vsql_schematron;
