INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543819_TableCreation
--echo #
CREATE DATABASE `db_543819_TableCreation`;
USE `db_543819_TableCreation`;
CREATE TABLE `Passwords` (
  `PasswordID` INT NOT NULL,
  `CurrentPassword` VARCHAR(50),
  `PreviousPassword` VARCHAR(50),
  `LastChangedDate` DATE,
  `ExpiryDate` DATE,
  `SecurityQuestion` VARCHAR(50),
  `SecurityAnswer` VARCHAR(50),
  `Strikes` INT,
  PRIMARY KEY (`PasswordID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `UserID` INT NOT NULL,
  `UserName` VARCHAR(50),
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `UserType` INT,
  `EmailAddress` VARCHAR(50),
  `EmailCode` VARCHAR(50),
  `BirthDate` DATE,
  `PasswordID` INT,
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543819_TableCreation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543819_TableCreation') AS relationships;
DROP DATABASE `db_543819_TableCreation`;
UNINSTALL EXTENSION vsql_schematron;
