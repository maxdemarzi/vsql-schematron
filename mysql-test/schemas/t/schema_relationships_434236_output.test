INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 434236_output
--echo #
CREATE DATABASE `db_434236_output`;
USE `db_434236_output`;
CREATE TABLE `message` (
  `id` INT NOT NULL,
  `body` TEXT,
  `status` TEXT,
  `contact_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact` (
  `id` INT NOT NULL,
  `name` TEXT,
  `phone` INT,
  `zip` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_434236_output') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_434236_output') AS relationships;
DROP DATABASE `db_434236_output`;
UNINSTALL EXTENSION vsql_schematron;
