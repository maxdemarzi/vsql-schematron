INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 192822_cykspace
--echo #
CREATE DATABASE `db_192822_cykspace`;
USE `db_192822_cykspace`;
CREATE TABLE `relations` (
  `id` VARCHAR(50) NOT NULL,
  `postId` VARCHAR(50),
  `tagId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` VARCHAR(50) NOT NULL,
  `tag` VARCHAR(50),
  `tagId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_192822_cykspace') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_192822_cykspace') AS relationships;
DROP DATABASE `db_192822_cykspace`;
UNINSTALL EXTENSION vsql_schematron;
