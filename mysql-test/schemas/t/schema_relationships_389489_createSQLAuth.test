INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 389489_createSQLAuth
--echo #
CREATE DATABASE `db_389489_createSQLAuth`;
USE `db_389489_createSQLAuth`;
CREATE TABLE `USERS` (
  `U_NAME` VARCHAR(50) NOT NULL,
  `U_PASSWORD` VARCHAR(50),
  `U_DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`U_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `GROUPS` (
  `G_NAME` VARCHAR(50) NOT NULL,
  `G_DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`G_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `GROUPMEMBERS` (
  `G_NAME` VARCHAR(50) NOT NULL,
  `G_MEMBER` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`G_NAME`, `G_MEMBER`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_389489_createSQLAuth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_389489_createSQLAuth') AS relationships;
DROP DATABASE `db_389489_createSQLAuth`;
UNINSTALL EXTENSION vsql_schematron;
