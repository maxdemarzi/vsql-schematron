INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 063992_schema
--echo #
CREATE DATABASE `db_063992_schema`;
USE `db_063992_schema`;
CREATE TABLE `jobs` (
  `id` INT NOT NULL,
  `job_title` VARCHAR(50),
  `min_salary` DOUBLE,
  `max_salary` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `regions` (
  `id` INT NOT NULL,
  `region_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `id` INT NOT NULL,
  `street_address` VARCHAR(50),
  `postal_code` VARCHAR(50),
  `city` VARCHAR(50),
  `state_province` VARCHAR(50),
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
  `id` INT NOT NULL,
  `department_name` VARCHAR(50),
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `hire_date` DATE,
  `job_id` INT,
  `salary` DOUBLE,
  `manager_id` INT,
  `department_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dependents` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `relationship` VARCHAR(50),
  `employee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_063992_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_063992_schema') AS relationships;
DROP DATABASE `db_063992_schema`;
UNINSTALL EXTENSION vsql_schematron;
