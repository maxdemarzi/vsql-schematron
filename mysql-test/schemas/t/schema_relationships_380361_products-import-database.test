INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 380361_products-import-database
--echo #
CREATE DATABASE `db_380361_products_import_database`;
USE `db_380361_products_import_database`;
CREATE TABLE `Imports` (
  `Id` VARCHAR(50) NOT NULL,
  `CreatedAt` TIMESTAMP NULL,
  `CompletedAt` TIMESTAMP NULL,
  `SpreadsheetFileUrl` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ImportProducts` (
  `ImportId` VARCHAR(50) NOT NULL,
  `ProductCode` VARCHAR(50) NOT NULL,
  `IsProcessed` BOOLEAN,
  `Observation` VARCHAR(50),
  `ProcessedAt` VARCHAR(50),
  `Line` DECIMAL(10,2),
  PRIMARY KEY (`ImportId`, `ProductCode`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_380361_products_import_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_380361_products_import_database') AS relationships;
DROP DATABASE `db_380361_products_import_database`;
UNINSTALL EXTENSION vsql_schematron;
