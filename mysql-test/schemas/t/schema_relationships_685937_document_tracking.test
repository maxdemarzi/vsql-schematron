INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 685937_document_tracking
--echo #
CREATE DATABASE `db_685937_document_tracking`;
USE `db_685937_document_tracking`;
CREATE TABLE `Inward` (
  `inward_id` INT NOT NULL,
  `place_of_receiving` VARCHAR(50),
  `doc_id` INT,
  PRIMARY KEY (`inward_id`)
) CHARACTER SET latin1;
CREATE TABLE `Name` (
  `First_name` VARCHAR(50),
  `Middle_name` VARCHAR(50),
  `Last_name` VARCHAR(50),
  `user_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Outward` (
  `outward_id` INT NOT NULL,
  `sending_place` VARCHAR(50),
  `to_whom_addressed` VARCHAR(50),
  `doc_id` INT,
  PRIMARY KEY (`outward_id`)
) CHARACTER SET latin1;
CREATE TABLE `Postal_charges` (
  `post_id` INT NOT NULL,
  `type_of_post` VARCHAR(50),
  `estimated_cost` INT,
  `outward_id` INT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `Process` (
  `movement_date` DATETIME,
  `comment` VARCHAR(50),
  `user_id` VARCHAR(50),
  `doc_id` INT,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_685937_document_tracking') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_685937_document_tracking') AS relationships;
DROP DATABASE `db_685937_document_tracking`;
UNINSTALL EXTENSION vsql_schematron;
