INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 218220_album
--echo #
CREATE DATABASE `db_218220_album`;
USE `db_218220_album`;
CREATE TABLE `album` (
  `id` INT NOT NULL,
  `parent_id` INT,
  `name` TEXT,
  `alias` TEXT,
  `path` TEXT,
  `base_path` TEXT,
  `tags` TEXT,
  `custom_sql` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photo` (
  `id` INT NOT NULL,
  `album_id` INT,
  `file` TEXT,
  `width` INT,
  `height` INT,
  `thumb_width` INT,
  `thumb_height` INT,
  `caption` TEXT,
  `tags` TEXT,
  `rating` INT,
  `favorite` INT,
  `date_time` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `tags` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_218220_album') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_218220_album') AS relationships;
DROP DATABASE `db_218220_album`;
UNINSTALL EXTENSION vsql_schematron;
