INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381559_moonverse
--echo #
CREATE DATABASE `db_381559_moonverse`;
USE `db_381559_moonverse`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `number_posts` INT,
  `birth_date` DATE,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `post_id` INT,
  `user_id` INT,
  `count_likes` INT,
  `post_text` VARCHAR(50),
  `post_date` DATE,
  `post_media_url` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
  `profile_id` INT,
  `user_id` INT,
  `about_me` VARCHAR(50),
  `age` INT,
  `city` VARCHAR(50),
  `profession` VARCHAR(50),
  `favorite_planet` VARCHAR(50),
  `profile_picture` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381559_moonverse') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381559_moonverse') AS relationships;
DROP DATABASE `db_381559_moonverse`;
UNINSTALL EXTENSION vsql_schematron;
