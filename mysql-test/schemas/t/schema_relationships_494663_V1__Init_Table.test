INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 494663_V1__Init_Table
--echo #
CREATE DATABASE `db_494663_V1__Init_Table`;
USE `db_494663_V1__Init_Table`;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `username` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` BIGINT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `added_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_494663_V1__Init_Table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_494663_V1__Init_Table') AS relationships;
DROP DATABASE `db_494663_V1__Init_Table`;
UNINSTALL EXTENSION vsql_schematron;
