INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510540_mydemo
--echo #
CREATE DATABASE `db_510540_mydemo`;
USE `db_510540_mydemo`;
CREATE TABLE `customer` (
  `customer_id` INT,
  `customer_first_name` VARCHAR(50),
  `customer_last_name` VARCHAR(50),
  `customer_email` VARCHAR(50),
  `customer_phone` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `maillist` (
  `maillist_id` INT,
  `maillist_email` VARCHAR(50),
  `customer_customer_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510540_mydemo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510540_mydemo') AS relationships;
DROP DATABASE `db_510540_mydemo`;
UNINSTALL EXTENSION vsql_schematron;
