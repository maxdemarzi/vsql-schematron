INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366582_cities-mysql-create
--echo #
CREATE DATABASE `db_366582_cities_mysql_create`;
USE `db_366582_cities_mysql_create`;
CREATE TABLE `states` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
  `id` INT NOT NULL,
  `idstate` CHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366582_cities_mysql_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366582_cities_mysql_create') AS relationships;
DROP DATABASE `db_366582_cities_mysql_create`;
UNINSTALL EXTENSION vsql_schematron;
