INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028432_1
--echo #
CREATE DATABASE `db_028432_1`;
USE `db_028432_1`;
CREATE TABLE `directory` (
  `id` BIGINT NOT NULL,
  `hash` VARCHAR(50),
  `path` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `mtime` DOUBLE,
  `hash_name` VARCHAR(50),
  `hash_mtime` VARCHAR(50),
  `hash_combined` VARCHAR(50),
  `md5` VARCHAR(50),
  `directory_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028432_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028432_1') AS relationships;
DROP DATABASE `db_028432_1`;
UNINSTALL EXTENSION vsql_schematron;
