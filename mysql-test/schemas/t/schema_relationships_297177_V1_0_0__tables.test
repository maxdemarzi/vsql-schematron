INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297177_V1.0.0__tables
--echo #
CREATE DATABASE `db_297177_V1_0_0__tables`;
USE `db_297177_V1_0_0__tables`;
CREATE TABLE `t_city` (
  `city_uuid` VARCHAR(50) NOT NULL,
  `label` VARCHAR(50),
  `meta` TEXT,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  PRIMARY KEY (`city_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `t_address` (
  `address_uuid` VARCHAR(50) NOT NULL,
  `label` VARCHAR(50),
  `line1` VARCHAR(50),
  `line2` VARCHAR(50),
  `meta` TEXT,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `city_uuid` VARCHAR(50),
  PRIMARY KEY (`address_uuid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297177_V1_0_0__tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297177_V1_0_0__tables') AS relationships;
DROP DATABASE `db_297177_V1_0_0__tables`;
UNINSTALL EXTENSION vsql_schematron;
