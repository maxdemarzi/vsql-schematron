INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 234183_1450376301
--echo #
CREATE DATABASE `db_234183_1450376301`;
USE `db_234183_1450376301`;
CREATE TABLE `bulletins` (
  `txid` VARCHAR(50) NOT NULL,
  `block` TEXT,
  `author` TEXT,
  `message` TEXT,
  `timestamp` INT,
  `latitude` INT,
  `longitude` INT,
  `height` INT,
  PRIMARY KEY (`txid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `txid` TEXT,
  `value` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_234183_1450376301') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_234183_1450376301') AS relationships;
DROP DATABASE `db_234183_1450376301`;
UNINSTALL EXTENSION vsql_schematron;
