INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 179510_3_0
--echo #
CREATE DATABASE `db_179510_3_0`;
USE `db_179510_3_0`;
CREATE TABLE `P` (
  `A` INT NOT NULL,
  PRIMARY KEY (`A`)
) CHARACTER SET latin1;
CREATE TABLE `C` (
  `A` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_179510_3_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_179510_3_0') AS relationships;
DROP DATABASE `db_179510_3_0`;
UNINSTALL EXTENSION vsql_schematron;
