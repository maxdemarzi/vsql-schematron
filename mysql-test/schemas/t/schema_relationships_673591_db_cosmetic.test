INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 673591_db_cosmetic
--echo #
CREATE DATABASE `db_673591_db_cosmetic`;
USE `db_673591_db_cosmetic`;
CREATE TABLE `b_admin` (
  `id` INT NOT NULL,
  `HoTen` VARCHAR(50),
  `Truong` VARCHAR(50),
  `Email` VARCHAR(50),
  `HoKhau` VARCHAR(50),
  `ThanhPho` VARCHAR(50),
  `QuocGia` VARCHAR(50),
  `SDT` VARCHAR(50),
  `GhiChu` TEXT,
  `Anh` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `b_cmt` (
  `id` INT,
  `NoiDung` VARCHAR(50),
  `KichHoat` INT
) CHARACTER SET latin1;
CREATE TABLE `b_cthdb` (
  `SoHDB` VARCHAR(50),
  `MaSP` VARCHAR(50),
  `SoLuong` INT,
  `DonGia` DOUBLE,
  `GiamGia` DOUBLE,
  `ThanhTien` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `b_cthdn` (
  `SoHDN` VARCHAR(50),
  `MaSP` VARCHAR(50),
  `SoLuong` INT,
  `DonGia` DOUBLE,
  `CKTT` DOUBLE,
  `CKTM` DOUBLE,
  `ThanhTien` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `b_dm` (
  `id_dm` INT,
  `ten_dm` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `b_dmsp` (
  `MaSP` VARCHAR(50),
  `TenSP` VARCHAR(50),
  `DonGia` DOUBLE,
  `MoTa` TEXT,
  `DVT` CHAR(50),
  `SL` INT,
  `Anh` TEXT,
  `Anh1` VARCHAR(50),
  `Anh2` VARCHAR(50),
  `Anh3` VARCHAR(50),
  `Anh4` VARCHAR(50),
  `id_dm` INT
) CHARACTER SET latin1;
CREATE TABLE `b_hdb` (
  `SoHDB` INT,
  `Ngay` DATE,
  `TongTien` DOUBLE,
  `MaNV` VARCHAR(50),
  `MaKH` VARCHAR(50),
  `ten` VARCHAR(50),
  `ho` VARCHAR(50),
  `email` VARCHAR(50),
  `sdt` VARCHAR(50),
  `dia_chi` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `b_hdn` (
  `SoHDN` VARCHAR(50),
  `Ngay` DATE,
  `TongTien` DOUBLE,
  `MaNCC` VARCHAR(50),
  `MaNV` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `b_kh` (
  `MaKH` VARCHAR(50),
  `TenKH` VARCHAR(50),
  `GioiTinh` CHAR(50),
  `SDT` VARCHAR(50),
  `Email` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `b_loaidm` (
  `id_loadm` INT NOT NULL,
  `ten_loaidm` VARCHAR(50),
  PRIMARY KEY (`id_loadm`)
) CHARACTER SET latin1;
CREATE TABLE `b_ncc` (
  `MaNCC` VARCHAR(50),
  `TenNCC` VARCHAR(50),
  `ChiNhanh` VARCHAR(50),
  `DiaChi` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `b_nv` (
  `MaNV` VARCHAR(50),
  `TenNV` VARCHAR(50),
  `Luong` DOUBLE,
  `GioiTinh` CHAR(50),
  `DiaChi` VARCHAR(50),
  `SDT` VARCHAR(50),
  `Anh` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_673591_db_cosmetic') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_673591_db_cosmetic') AS relationships;
DROP DATABASE `db_673591_db_cosmetic`;
UNINSTALL EXTENSION vsql_schematron;
