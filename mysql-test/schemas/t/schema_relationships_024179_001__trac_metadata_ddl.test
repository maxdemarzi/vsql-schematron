INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 024179_001__trac_metadata.ddl
--echo #
CREATE DATABASE `db_024179_001__trac_metadata_ddl`;
USE `db_024179_001__trac_metadata_ddl`;
CREATE TABLE `tenant` (
  `tenant_id` SMALLINT NOT NULL,
  `tenant_code` VARCHAR(50),
  PRIMARY KEY (`tenant_id`)
) CHARACTER SET latin1;
CREATE TABLE `tag_attr` (
  `tenant_id` SMALLINT,
  `tag_fk` BIGINT,
  `attr_name` VARCHAR(50),
  `attr_type` VARCHAR(50),
  `attr_index` INT,
  `attr_value_boolean` VARCHAR(50),
  `attr_value_integer` BIGINT,
  `attr_value_float` DOUBLE,
  `attr_value_string` VARCHAR(50),
  `attr_value_decimal` DECIMAL(10,2),
  `attr_value_date` DATE,
  `attr_value_datetime` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_024179_001__trac_metadata_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_024179_001__trac_metadata_ddl') AS relationships;
DROP DATABASE `db_024179_001__trac_metadata_ddl`;
UNINSTALL EXTENSION vsql_schematron;
