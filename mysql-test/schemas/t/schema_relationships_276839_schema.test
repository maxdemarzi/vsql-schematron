INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 276839_schema
--echo #
CREATE DATABASE `db_276839_schema`;
USE `db_276839_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` TEXT,
  `password` TEXT,
  `admin` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `borrower` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_276839_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_276839_schema') AS relationships;
DROP DATABASE `db_276839_schema`;
UNINSTALL EXTENSION vsql_schematron;
