INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086492_create_databse
--echo #
CREATE DATABASE `db_086492_create_databse`;
USE `db_086492_create_databse`;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `producttable` (
  `id` VARCHAR(50) NOT NULL,
  `productCode` VARCHAR(50),
  `productName` VARCHAR(50),
  `productSource` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shoprecords` (
  `id` VARCHAR(50) NOT NULL,
  `userId` VARCHAR(50),
  `productId` VARCHAR(50),
  `number` VARCHAR(50),
  `shopDate` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086492_create_databse') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086492_create_databse') AS relationships;
DROP DATABASE `db_086492_create_databse`;
UNINSTALL EXTENSION vsql_schematron;
