INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148092_quiz
--echo #
CREATE DATABASE `db_148092_quiz`;
USE `db_148092_quiz`;
CREATE TABLE `usuario` (
  `nome` VARCHAR(50),
  `email` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `pergunta` (
  `id` INT NOT NULL,
  `texto` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resposta` (
  `id` INT,
  `texto` TEXT,
  `status` TINYINT,
  `idpergunta` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148092_quiz') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148092_quiz') AS relationships;
DROP DATABASE `db_148092_quiz`;
UNINSTALL EXTENSION vsql_schematron;
