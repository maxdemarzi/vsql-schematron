INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 482583_V1__initial_structure
--echo #
CREATE DATABASE `db_482583_V1__initial_structure`;
USE `db_482583_V1__initial_structure`;
CREATE TABLE `public.role` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.permission` (
  `id` BIGINT NOT NULL,
  `description` CHAR(50),
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.role_permission` (
  `id_role` BIGINT NOT NULL,
  `id_permission` BIGINT NOT NULL,
  PRIMARY KEY (`id_role`, `id_permission`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_482583_V1__initial_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_482583_V1__initial_structure') AS relationships;
DROP DATABASE `db_482583_V1__initial_structure`;
UNINSTALL EXTENSION vsql_schematron;
