INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 632495_data
--echo #
CREATE DATABASE `db_632495_data`;
USE `db_632495_data`;
CREATE TABLE `comments` (
  `comment_id` INT,
  `user_uid` VARCHAR(50),
  `comment_content` VARCHAR(50),
  `comment_time` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_uid` VARCHAR(50) NOT NULL,
  `user_email` VARCHAR(50),
  `user_password` VARCHAR(50),
  PRIMARY KEY (`user_uid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_632495_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_632495_data') AS relationships;
DROP DATABASE `db_632495_data`;
UNINSTALL EXTENSION vsql_schematron;
