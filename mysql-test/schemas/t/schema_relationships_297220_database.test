INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 297220_database
--echo #
CREATE DATABASE `db_297220_database`;
USE `db_297220_database`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `user_name` VARCHAR(50),
  `user_email` VARCHAR(50),
  `user_password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `post_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_297220_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_297220_database') AS relationships;
DROP DATABASE `db_297220_database`;
UNINSTALL EXTENSION vsql_schematron;
