INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 182696_V2.10__meeting_agenda
--echo #
CREATE DATABASE `db_182696_V2_10__meeting_agenda`;
USE `db_182696_V2_10__meeting_agenda`;
CREATE TABLE `meeting_agenda` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `meeting_agenda_item` (
  `id` INT NOT NULL,
  `meeting_agenda_id` BIGINT,
  `item` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_182696_V2_10__meeting_agenda') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_182696_V2_10__meeting_agenda') AS relationships;
DROP DATABASE `db_182696_V2_10__meeting_agenda`;
UNINSTALL EXTENSION vsql_schematron;
