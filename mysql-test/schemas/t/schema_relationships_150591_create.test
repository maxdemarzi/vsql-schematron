INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 150591_create
--echo #
CREATE DATABASE `db_150591_create`;
USE `db_150591_create`;
CREATE TABLE `products` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `price` DOUBLE,
  `image` VARCHAR(50),
  `unit` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stocks` (
  `stock_id` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  `count` INT,
  PRIMARY KEY (`stock_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_150591_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_150591_create') AS relationships;
DROP DATABASE `db_150591_create`;
UNINSTALL EXTENSION vsql_schematron;
