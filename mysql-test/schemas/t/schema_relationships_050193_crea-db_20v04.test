INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 050193_crea-db%20v04
--echo #
CREATE DATABASE `db_050193_crea_db_20v04`;
USE `db_050193_crea_db_20v04`;
CREATE TABLE `parametro` (
  `ID_CONNESSIONE` INT NOT NULL,
  `SEZIONE` VARCHAR(50) NOT NULL,
  `NOME` VARCHAR(50) NOT NULL,
  `VALORE` VARCHAR(50),
  PRIMARY KEY (`ID_CONNESSIONE`, `SEZIONE`, `NOME`)
) CHARACTER SET latin1;
CREATE TABLE `sessione` (
  `ID` INT NOT NULL,
  `ID_CONNESSIONE_AGENT` INT,
  `ID_CONNESSIONE_MANAGER` INT,
  `STATO` VARCHAR(50),
  `DATA_INIZIO` DATETIME,
  `DATA_FINE` DATETIME,
  `ID_RICHIESTA` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `chat` (
  `ID_RICHIESTA` INT,
  `DATA_INVIO` DATETIME,
  `MITTENTE` VARCHAR(50),
  `TESTO` VARCHAR(50),
  `DATA_RICEZIONE` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `chiamata` (
  `ID_SESSIONE` INT,
  `USA_AUDIO` VARCHAR(50),
  `USA_VIDEO` VARCHAR(50),
  `DATA_INIZIO` DATETIME,
  `DATA_FINE` DATETIME,
  `ID` INT NOT NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ftp` (
  `ID_SESSIONE` INT,
  `DIREZIONE` VARCHAR(50),
  `DA_FILE` VARCHAR(50),
  `A_FILE` VARCHAR(50),
  `DATA_INIZIO` DATETIME,
  `DATA_FINE` DATETIME,
  `ID` INT NOT NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_050193_crea_db_20v04') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_050193_crea_db_20v04') AS relationships;
DROP DATABASE `db_050193_crea_db_20v04`;
UNINSTALL EXTENSION vsql_schematron;
