INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641409_vinculacionci_1.0.1
--echo #
CREATE DATABASE `db_641409_vinculacionci_1_0_1`;
USE `db_641409_vinculacionci_1_0_1`;
CREATE TABLE `provincias` (
  `Id` INT NOT NULL,
  `CodigoArea` VARCHAR(50),
  `Nombre` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `ciudades` (
  `Id` INT,
  `Nombre` VARCHAR(50),
  `IdProvincia` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641409_vinculacionci_1_0_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641409_vinculacionci_1_0_1') AS relationships;
DROP DATABASE `db_641409_vinculacionci_1_0_1`;
UNINSTALL EXTENSION vsql_schematron;
