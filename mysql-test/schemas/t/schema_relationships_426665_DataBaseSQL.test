INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 426665_DataBaseSQL
--echo #
CREATE DATABASE `db_426665_DataBaseSQL`;
USE `db_426665_DataBaseSQL`;
CREATE TABLE `Users` (
  `user_id` VARCHAR(50) NOT NULL,
  `user_email` VARCHAR(50),
  `user_password` VARCHAR(50),
  `user_point` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Submit` (
  `user_id` VARCHAR(50),
  `question_id` INT,
  `submit_time` TIME,
  `type` VARCHAR(50),
  `codeName` VARCHAR(50) NOT NULL,
  `result` VARCHAR(50),
  `time` INT,
  `ram` INT,
  PRIMARY KEY (`codeName`)
) CHARACTER SET latin1;
CREATE TABLE `TestData` (
  `question_id` INT,
  `test_data` VARCHAR(50),
  `result_data` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_426665_DataBaseSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_426665_DataBaseSQL') AS relationships;
DROP DATABASE `db_426665_DataBaseSQL`;
UNINSTALL EXTENSION vsql_schematron;
