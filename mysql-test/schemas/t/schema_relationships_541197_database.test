INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 541197_database
--echo #
CREATE DATABASE `db_541197_database`;
USE `db_541197_database`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `rol` VARCHAR(50),
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `content` TEXT,
  `priority` VARCHAR(50),
  `hours` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_541197_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_541197_database') AS relationships;
DROP DATABASE `db_541197_database`;
UNINSTALL EXTENSION vsql_schematron;
