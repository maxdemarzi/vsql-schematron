INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 274147_013_divs_and_depts.mysql
--echo #
CREATE DATABASE `db_274147_013_divs_and_depts_mysql`;
USE `db_274147_013_divs_and_depts_mysql`;
CREATE TABLE `ent_division_master` (
  `division_id` INT NOT NULL,
  `division_code` CHAR(50),
  `division_name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`division_id`)
) CHARACTER SET latin1;
CREATE TABLE `ent_department_master` (
  `department_id` INT NOT NULL,
  `department_code` CHAR(50),
  `department_name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `ent_divisions` (
  `entity_id` VARCHAR(50),
  `division_id` INT,
  `currency` CHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `ent_departments` (
  `entity_id` VARCHAR(50),
  `department_id` INT,
  `currency` CHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_274147_013_divs_and_depts_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_274147_013_divs_and_depts_mysql') AS relationships;
DROP DATABASE `db_274147_013_divs_and_depts_mysql`;
UNINSTALL EXTENSION vsql_schematron;
