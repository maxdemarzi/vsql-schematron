INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 285964_cree_biblio
--echo #
CREATE DATABASE `db_285964_cree_biblio`;
USE `db_285964_cree_biblio`;
CREATE TABLE `livre` (
  `isbn` VARCHAR(50) NOT NULL,
  `titre` VARCHAR(50),
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `auteur` (
  `id_auteur` INT NOT NULL,
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  PRIMARY KEY (`id_auteur`)
) CHARACTER SET latin1;
CREATE TABLE `ecrire` (
  `isbn` VARCHAR(50) NOT NULL,
  `id_auteur` INT NOT NULL,
  PRIMARY KEY (`isbn`, `id_auteur`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_285964_cree_biblio') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_285964_cree_biblio') AS relationships;
DROP DATABASE `db_285964_cree_biblio`;
UNINSTALL EXTENSION vsql_schematron;
