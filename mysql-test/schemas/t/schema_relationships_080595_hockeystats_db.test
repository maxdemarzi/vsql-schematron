INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 080595_hockeystats_db
--echo #
CREATE DATABASE `db_080595_hockeystats_db`;
USE `db_080595_hockeystats_db`;
CREATE TABLE `penalties` (
  `penalty_id` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`penalty_id`)
) CHARACTER SET latin1;
CREATE TABLE `infractions` (
  `infraction_id` INT NOT NULL,
  `player_id` INT,
  `penalty_id` INT,
  PRIMARY KEY (`infraction_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_080595_hockeystats_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_080595_hockeystats_db') AS relationships;
DROP DATABASE `db_080595_hockeystats_db`;
UNINSTALL EXTENSION vsql_schematron;
