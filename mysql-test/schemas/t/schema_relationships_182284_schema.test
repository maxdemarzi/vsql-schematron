INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 182284_schema
--echo #
CREATE DATABASE `db_182284_schema`;
USE `db_182284_schema`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `linkedid` VARCHAR(50),
  `serializedprofile` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `postal_address` VARCHAR(50),
  `favourite` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_182284_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_182284_schema') AS relationships;
DROP DATABASE `db_182284_schema`;
UNINSTALL EXTENSION vsql_schematron;
