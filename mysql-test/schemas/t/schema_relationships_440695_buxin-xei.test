INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 440695_buxin-xei
--echo #
CREATE DATABASE `db_440695_buxin_xei`;
USE `db_440695_buxin_xei`;
CREATE TABLE `establishments` (
  `id` INT NOT NULL,
  `image_url` TEXT,
  `name` TEXT,
  `address_id` INT,
  `phone` INT,
  `category_id` INT,
  `delivery` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `street` TEXT,
  `number` INT,
  `city` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_440695_buxin_xei') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_440695_buxin_xei') AS relationships;
DROP DATABASE `db_440695_buxin_xei`;
UNINSTALL EXTENSION vsql_schematron;
