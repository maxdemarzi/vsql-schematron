INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153593_V1__schema
--echo #
CREATE DATABASE `db_153593_V1__schema`;
USE `db_153593_V1__schema`;
CREATE TABLE `COVER` (
  `ID` VARCHAR(50) NOT NULL,
  `HEIGHT` INT,
  `URL` VARCHAR(50),
  `WIDTH` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TAG` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PODCAST` (
  `ID` VARCHAR(50) NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  `HAS_TO_BE_DELETED` BOOLEAN,
  `LAST_UPDATE` TIMESTAMP NULL,
  `SIGNATURE` VARCHAR(50),
  `TITLE` VARCHAR(50),
  `TYPE` VARCHAR(50),
  `URL` VARCHAR(50),
  `COVER_ID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
  `ID` VARCHAR(50) NOT NULL,
  `CREATION_DATE` TIMESTAMP NULL,
  `DESCRIPTION` TEXT,
  `DOWNLOAD_DATE` TIMESTAMP NULL,
  `FILE_NAME` VARCHAR(50),
  `LENGTH` BIGINT,
  `MIME_TYPE` VARCHAR(50),
  `NUMBER_OF_FAIL` INT,
  `PUB_DATE` TIMESTAMP NULL,
  `STATUS` VARCHAR(50),
  `TITLE` VARCHAR(50),
  `URL` VARCHAR(50),
  `COVER_ID` VARCHAR(50),
  `PODCAST_ID` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PODCAST_TAGS` (
  `PODCASTS_ID` VARCHAR(50) NOT NULL,
  `TAGS_ID` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`PODCASTS_ID`, `TAGS_ID`)
) CHARACTER SET latin1;
CREATE TABLE `WATCH_LIST` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `WATCH_LIST_ITEMS` (
  `WATCH_LISTS_ID` VARCHAR(50) NOT NULL,
  `ITEMS_ID` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`WATCH_LISTS_ID`, `ITEMS_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153593_V1__schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153593_V1__schema') AS relationships;
DROP DATABASE `db_153593_V1__schema`;
UNINSTALL EXTENSION vsql_schematron;
