INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663052_alexandria-schema
--echo #
CREATE DATABASE `db_663052_alexandria_schema`;
USE `db_663052_alexandria_schema`;
CREATE TABLE `writers` (
  `id` BIGINT NOT NULL,
  `full_name` VARCHAR(50),
  `nick_name` VARCHAR(50),
  `nationality` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
  `id` BIGINT NOT NULL,
  `title` VARCHAR(50),
  `synopsis` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `writers_books` (
  `writer_id` BIGINT,
  `book_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `editions` (
  `id` BIGINT NOT NULL,
  `book_id` BIGINT,
  `publishing_company` VARCHAR(50),
  `edition` SMALLINT,
  `year` SMALLINT,
  `language` VARCHAR(50),
  `pages` SMALLINT,
  `height` DOUBLE,
  `width` DOUBLE,
  `weight` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
  `id` BIGINT NOT NULL,
  `edition_id` BIGINT,
  `content_type` VARCHAR(50),
  `temporary` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookcase` (
  `id` BIGINT NOT NULL,
  `edition_id` BIGINT,
  `comments` VARCHAR(50),
  `read` BOOLEAN,
  `gender` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663052_alexandria_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663052_alexandria_schema') AS relationships;
DROP DATABASE `db_663052_alexandria_schema`;
UNINSTALL EXTENSION vsql_schematron;
