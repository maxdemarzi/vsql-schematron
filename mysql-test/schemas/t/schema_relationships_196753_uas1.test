INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 196753_uas1
--echo #
CREATE DATABASE `db_196753_uas1`;
USE `db_196753_uas1`;
CREATE TABLE `pegawai` (
  `id` INT NOT NULL,
  `nip` VARCHAR(50),
  `nama` VARCHAR(50),
  `jenis_kelamin` VARCHAR(50),
  `tanggal_lahir` DATE,
  `gaji` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kehadiran` (
  `id` INT NOT NULL,
  `id_pegawai` INT,
  `tanggal` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_196753_uas1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_196753_uas1') AS relationships;
DROP DATABASE `db_196753_uas1`;
UNINSTALL EXTENSION vsql_schematron;
