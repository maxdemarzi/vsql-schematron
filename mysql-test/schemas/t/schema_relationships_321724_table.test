INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 321724_table
--echo #
CREATE DATABASE `db_321724_table`;
USE `db_321724_table`;
CREATE TABLE `packages` (
  `id` INT NOT NULL,
  `parent_package_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_321724_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_321724_table') AS relationships;
DROP DATABASE `db_321724_table`;
UNINSTALL EXTENSION vsql_schematron;
