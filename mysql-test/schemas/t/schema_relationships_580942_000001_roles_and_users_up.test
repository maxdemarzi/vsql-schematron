INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580942_000001_roles_and_users.up
--echo #
CREATE DATABASE `db_580942_000001_roles_and_users_up`;
USE `db_580942_000001_roles_and_users_up`;
CREATE TABLE `user_roles` (
  `id_role` INT NOT NULL,
  `name_role` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_role`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id_user` BIGINT NOT NULL,
  `name_user` VARCHAR(50),
  `email_addr` VARCHAR(50),
  `pwd_hash` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `user_role` INT,
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580942_000001_roles_and_users_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580942_000001_roles_and_users_up') AS relationships;
DROP DATABASE `db_580942_000001_roles_and_users_up`;
UNINSTALL EXTENSION vsql_schematron;
