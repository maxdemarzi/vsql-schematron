INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 666031_database
--echo #
CREATE DATABASE `db_666031_database`;
USE `db_666031_database`;
CREATE TABLE `admins` (
  `username` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `ban` (
  `id` VARCHAR(50) NOT NULL,
  `ip` VARCHAR(50),
  `motivo` CHAR(50),
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chapters` (
  `number` VARCHAR(50),
  `year` INT,
  `title` VARCHAR(50),
  `image` VARCHAR(50),
  `imagedescr` VARCHAR(50),
  `titleeng` VARCHAR(50),
  `titleita` VARCHAR(50),
  `plot` TEXT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` VARCHAR(50),
  `news_id` VARCHAR(50),
  `nick` VARCHAR(50),
  `email` VARCHAR(50),
  `message` TEXT,
  `data` DATETIME,
  `ip` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `hidden` TINYINT,
  `data` DATETIME,
  `text` TEXT,
  `image` VARCHAR(50),
  `imgdescr` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_666031_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_666031_database') AS relationships;
DROP DATABASE `db_666031_database`;
UNINSTALL EXTENSION vsql_schematron;
