INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 471327_createALL
--echo #
CREATE DATABASE `db_471327_createALL`;
USE `db_471327_createALL`;
CREATE TABLE `NODE` (
  `node_name` VARCHAR(50) NOT NULL,
  `node_num` INT,
  `cluster` VARCHAR(50),
  PRIMARY KEY (`node_name`)
) CHARACTER SET latin1;
CREATE TABLE `GENDER` (
  `gender_name` VARCHAR(50) NOT NULL,
  `descrip` VARCHAR(50),
  PRIMARY KEY (`gender_name`)
) CHARACTER SET latin1;
CREATE TABLE `CONFIGURATION` (
  `config_id` VARCHAR(50) NOT NULL,
  `val` VARCHAR(50),
  `node_name` VARCHAR(50),
  `gender_name` VARCHAR(50),
  PRIMARY KEY (`config_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_471327_createALL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_471327_createALL') AS relationships;
DROP DATABASE `db_471327_createALL`;
UNINSTALL EXTENSION vsql_schematron;
