INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 497978_migration
--echo #
CREATE DATABASE `db_497978_migration`;
USE `db_497978_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` DATETIME,
  `name` TEXT,
  `lastname` TEXT,
  `username` TEXT,
  `userhash` TEXT,
  `cpf` TEXT,
  `email` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
  `id` INT NOT NULL,
  `userId` TEXT,
  `postalCode` TEXT,
  `city` TEXT,
  `state` TEXT,
  `street` TEXT,
  `number` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
  `id` INT NOT NULL,
  `itemId` TEXT,
  `one_star` TEXT,
  `two_star` TEXT,
  `three_star` TEXT,
  `four_star` TEXT,
  `five_star` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Image` (
  `id` INT NOT NULL,
  `itemId` TEXT,
  `link` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` DATETIME,
  `name` TEXT,
  `short_name` TEXT,
  `description` TEXT,
  `price` TEXT,
  `shipping_price` TEXT,
  `discount` TEXT,
  `category` TEXT,
  `orders` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_497978_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_497978_migration') AS relationships;
DROP DATABASE `db_497978_migration`;
UNINSTALL EXTENSION vsql_schematron;
