INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611948_database
--echo #
CREATE DATABASE `db_611948_database`;
USE `db_611948_database`;
CREATE TABLE `responders` (
  `responder_id` VARCHAR(50) NOT NULL,
  `client_id` VARCHAR(50),
  `responder_name` TEXT,
  `responder_email` TEXT,
  `responder_password` TEXT,
  `responder_cell` TEXT,
  `responder_location` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`responder_id`)
) CHARACTER SET latin1;
CREATE TABLE `panic_types` (
  `panic_type_id` INT NOT NULL,
  `panic_type_name` TEXT,
  PRIMARY KEY (`panic_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `panics` (
  `panic_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `panic_type_id` INT,
  `responder_id` VARCHAR(50),
  `user_ip` TEXT,
  `user_location` TEXT,
  `panic_location` TEXT,
  `created_at` TIMESTAMP NULL,
  `user_helped_at` TIMESTAMP NULL,
  `client_responded_at` TIMESTAMP NULL,
  `responder_completed_at` TIMESTAMP NULL,
  PRIMARY KEY (`panic_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611948_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611948_database') AS relationships;
DROP DATABASE `db_611948_database`;
UNINSTALL EXTENSION vsql_schematron;
