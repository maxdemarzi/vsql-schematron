INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 437113_tables
--echo #
CREATE DATABASE `db_437113_tables`;
USE `db_437113_tables`;
CREATE TABLE `TREINADOR` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  `SOBRENOME` VARCHAR(50),
  `IDADE` INT,
  `CIDADE` VARCHAR(50),
  `ID_POKEMON` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `POKEMON` (
  `ID` INT NOT NULL,
  `NOME` VARCHAR(50),
  `TIPO` VARCHAR(50),
  `ALTURA` DOUBLE,
  `PESO` DOUBLE,
  `CATEGORIA` VARCHAR(50),
  `HABILIDADE` VARCHAR(50),
  `HABILIDADE2` VARCHAR(50),
  `FRAQUEZA` VARCHAR(50),
  `FRAQUEZA2` VARCHAR(50),
  `DESCRICAO` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_437113_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_437113_tables') AS relationships;
DROP DATABASE `db_437113_tables`;
UNINSTALL EXTENSION vsql_schematron;
