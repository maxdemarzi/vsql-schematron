INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 205103_V0_0_5__example_structure_person
--echo #
CREATE DATABASE `db_205103_V0_0_5__example_structure_person`;
USE `db_205103_V0_0_5__example_structure_person`;
CREATE TABLE `example_geo` (
  `id` BIGINT NOT NULL,
  `created_by` VARCHAR(50),
  `created_date` DATETIME,
  `last_modified_by` VARCHAR(50),
  `last_modified_date` DATETIME,
  `lat` VARCHAR(50),
  `lng` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `example_address` (
  `id` BIGINT NOT NULL,
  `created_by` VARCHAR(50),
  `created_date` DATETIME,
  `last_modified_by` VARCHAR(50),
  `last_modified_date` DATETIME,
  `city` VARCHAR(50),
  `street` VARCHAR(50),
  `suite` VARCHAR(50),
  `zipcode` VARCHAR(50),
  `geo_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `example_person` (
  `id` BIGINT NOT NULL,
  `created_by` VARCHAR(50),
  `created_date` DATETIME,
  `last_modified_by` VARCHAR(50),
  `last_modified_date` DATETIME,
  `age` INT,
  `dob` DATE,
  `email_primary` VARCHAR(50),
  `email_secondary` VARCHAR(50),
  `gender` VARCHAR(50),
  `is_adult` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `phone` BIGINT,
  `username` VARCHAR(50),
  `address_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_205103_V0_0_5__example_structure_person') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_205103_V0_0_5__example_structure_person') AS relationships;
DROP DATABASE `db_205103_V0_0_5__example_structure_person`;
UNINSTALL EXTENSION vsql_schematron;
