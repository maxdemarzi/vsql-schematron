INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 464447_create_database_cars_shop
--echo #
CREATE DATABASE `db_464447_create_database_cars_shop`;
USE `db_464447_create_database_cars_shop`;
CREATE TABLE `marks` (
  `id` INT NOT NULL,
  `mark` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `id` INT NOT NULL,
  `mark_id` INT,
  `model` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `age` INT,
  `phone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `car_id` INT,
  `client_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_464447_create_database_cars_shop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_464447_create_database_cars_shop') AS relationships;
DROP DATABASE `db_464447_create_database_cars_shop`;
UNINSTALL EXTENSION vsql_schematron;
