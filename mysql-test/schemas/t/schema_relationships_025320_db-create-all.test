INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025320_db-create-all
--echo #
CREATE DATABASE `db_025320_db_create_all`;
USE `db_025320_db_create_all`;
CREATE TABLE `o_debpackage` (
  `id` BIGINT NOT NULL,
  `repository_id` BIGINT,
  `package_name` VARCHAR(50),
  `version` VARCHAR(50),
  `arch` VARCHAR(50),
  `dist` VARCHAR(50),
  `component` VARCHAR(50),
  `build_id` BIGINT,
  `build_type_id` VARCHAR(50),
  `filename` VARCHAR(50),
  `uri` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `o_repository` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `uuid` VARCHAR(50),
  `project_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025320_db_create_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025320_db_create_all') AS relationships;
DROP DATABASE `db_025320_db_create_all`;
UNINSTALL EXTENSION vsql_schematron;
