INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 542073_script
--echo #
CREATE DATABASE `db_542073_script`;
USE `db_542073_script`;
CREATE TABLE `Member` (
  `member_id` VARCHAR(50) NOT NULL,
  `nic` VARCHAR(50),
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `contact` VARCHAR(50),
  PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `Issue` (
  `member_id` VARCHAR(50),
  `book_id` VARCHAR(50),
  `issue_id` INT NOT NULL,
  `date` DATE,
  `detail` VARCHAR(50),
  PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `user_id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_542073_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_542073_script') AS relationships;
DROP DATABASE `db_542073_script`;
UNINSTALL EXTENSION vsql_schematron;
