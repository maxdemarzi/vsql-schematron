INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 252784_migration
--echo #
CREATE DATABASE `db_252784_migration`;
USE `db_252784_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `userId` TEXT,
  `username` TEXT,
  `ribbons` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Guild` (
  `id` INT NOT NULL,
  `guildId` TEXT,
  `prefix` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Shiritori` (
  `id` INT NOT NULL,
  `guildId` INT,
  `handSize` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Balloon` (
  `id` INT NOT NULL,
  `guildId` INT,
  `minVol` INT,
  `maxVol` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_252784_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_252784_migration') AS relationships;
DROP DATABASE `db_252784_migration`;
UNINSTALL EXTENSION vsql_schematron;
