INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 399389_1009
--echo #
CREATE DATABASE `db_399389_1009`;
USE `db_399389_1009`;
CREATE TABLE `album` (
  `id` CHAR(50),
  `title` VARCHAR(50),
  `artist` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `track` (
  `album` CHAR(50),
  `dsk` INT,
  `posn` INT,
  `song` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_399389_1009') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_399389_1009') AS relationships;
DROP DATABASE `db_399389_1009`;
UNINSTALL EXTENSION vsql_schematron;
