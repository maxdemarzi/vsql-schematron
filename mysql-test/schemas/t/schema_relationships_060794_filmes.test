INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060794_filmes
--echo #
CREATE DATABASE `db_060794_filmes`;
USE `db_060794_filmes`;
CREATE TABLE `Artista` (
  `codArt` INT NOT NULL,
  `nomeArt` VARCHAR(50),
  `cidade` VARCHAR(50),
  `pais` VARCHAR(50),
  `dataNasc` DATE,
  PRIMARY KEY (`codArt`)
) CHARACTER SET latin1;
CREATE TABLE `PERSONAGEM` (
  `nomePers` VARCHAR(50),
  `cache` DECIMAL(10,2),
  `codFilme` INT,
  `codArt` INT
) CHARACTER SET latin1;
CREATE TABLE `filme` (
  `codFilme` INT NOT NULL,
  `titulo` VARCHAR(50),
  `duracao` INT,
  `ano` INT,
  `codEst` INT,
  `codCateg` INT,
  PRIMARY KEY (`codFilme`)
) CHARACTER SET latin1;
CREATE TABLE `estudio` (
  `codEst` INT NOT NULL,
  `nomeEst` VARCHAR(50),
  PRIMARY KEY (`codEst`)
) CHARACTER SET latin1;
CREATE TABLE `categoria` (
  `codCateg` INT NOT NULL,
  `descCateg` VARCHAR(50),
  PRIMARY KEY (`codCateg`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060794_filmes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060794_filmes') AS relationships;
DROP DATABASE `db_060794_filmes`;
UNINSTALL EXTENSION vsql_schematron;
