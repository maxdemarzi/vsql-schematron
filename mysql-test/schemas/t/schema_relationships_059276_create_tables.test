INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 059276_create_tables
--echo #
CREATE DATABASE `db_059276_create_tables`;
USE `db_059276_create_tables`;
CREATE TABLE `Users` (
  `UserID` BIGINT NOT NULL,
  `Email` VARCHAR(50),
  `Password` VARCHAR(50),
  `Firstname` VARCHAR(50),
  `Lastname` VARCHAR(50),
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `Downloads` (
  `DownloadID` BIGINT NOT NULL,
  `UserID` BIGINT,
  `Title` VARCHAR(50),
  `URL` VARCHAR(50),
  `StartDate` DATETIME,
  `EndDate` DATETIME,
  PRIMARY KEY (`DownloadID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_059276_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_059276_create_tables') AS relationships;
DROP DATABASE `db_059276_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
