INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165094_schema
--echo #
CREATE DATABASE `db_165094_schema`;
USE `db_165094_schema`;
CREATE TABLE `mat_materia` (
  `mat_id` INT NOT NULL,
  `mat_nombre` VARCHAR(50),
  PRIMARY KEY (`mat_id`)
) CHARACTER SET latin1;
CREATE TABLE `grd_grado` (
  `grd_id` INT NOT NULL,
  `grd_nombre` VARCHAR(50),
  PRIMARY KEY (`grd_id`)
) CHARACTER SET latin1;
CREATE TABLE `mxg_materiasxgrado` (
  `mxg_id` INT NOT NULL,
  `mxg_id_grd` INT,
  `mxg_id_mat` INT,
  PRIMARY KEY (`mxg_id`)
) CHARACTER SET latin1;
CREATE TABLE `alm_alumno` (
  `alm_id` INT NOT NULL,
  `alm_nombre` VARCHAR(50),
  `alm_edad` INT,
  `alm_sexo` VARCHAR(50),
  `alm_id_grd` INT,
  `alm_observacion` VARCHAR(50),
  PRIMARY KEY (`alm_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165094_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165094_schema') AS relationships;
DROP DATABASE `db_165094_schema`;
UNINSTALL EXTENSION vsql_schematron;
