INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 591928_up
--echo #
CREATE DATABASE `db_591928_up`;
USE `db_591928_up`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `uuid` BLOB,
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organisations` (
  `id` INT NOT NULL,
  `uuid` BLOB,
  `name` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `crates` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `organisation_id` INT,
  `readme` TEXT,
  `description` VARCHAR(50),
  `repository` VARCHAR(50),
  `homepage` VARCHAR(50),
  `documentation` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_ssh_keys` (
  `id` INT NOT NULL,
  `uuid` BLOB,
  `name` VARCHAR(50),
  `user_id` INT,
  `ssh_key` BLOB,
  `created_at` DATETIME,
  `last_used_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_591928_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_591928_up') AS relationships;
DROP DATABASE `db_591928_up`;
UNINSTALL EXTENSION vsql_schematron;
