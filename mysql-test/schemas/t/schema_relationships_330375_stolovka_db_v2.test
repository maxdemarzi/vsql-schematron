INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 330375_stolovka_db_v2
--echo #
CREATE DATABASE `db_330375_stolovka_db_v2`;
USE `db_330375_stolovka_db_v2`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `token` VARCHAR(50),
  `email` VARCHAR(50),
  `card` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `canteens` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `worktime` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dishes` (
  `dish_id` VARCHAR(50) NOT NULL,
  `dish_name` VARCHAR(50),
  `dish_price` DECIMAL(10,2),
  `canteen_id` VARCHAR(50),
  PRIMARY KEY (`dish_id`)
) CHARACTER SET latin1;
CREATE TABLE `cashiers` (
  `id` VARCHAR(50) NOT NULL,
  `login` VARCHAR(50),
  `password_crypted` VARCHAR(50),
  `canteen_id` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
  `card_number_crypted` VARCHAR(50) NOT NULL,
  `recognizeable_name` VARCHAR(50),
  `added_at` TIMESTAMP NULL,
  PRIMARY KEY (`card_number_crypted`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `order_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `canteen_id` VARCHAR(50),
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `processed_at` TIMESTAMP NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_330375_stolovka_db_v2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_330375_stolovka_db_v2') AS relationships;
DROP DATABASE `db_330375_stolovka_db_v2`;
UNINSTALL EXTENSION vsql_schematron;
