INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 628922_database
--echo #
CREATE DATABASE `db_628922_database`;
USE `db_628922_database`;
CREATE TABLE `Groups` (
  `ID` INT NOT NULL,
  `groupname` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Gruppenteilnehmer` (
  `ID` INT NOT NULL,
  `Group_ID` INT,
  `Account_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Messages` (
  `ID` INT NOT NULL,
  `msg` TEXT,
  `datum` TIMESTAMP NULL,
  `ToGroup_ID` INT,
  `FROM_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_628922_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_628922_database') AS relationships;
DROP DATABASE `db_628922_database`;
UNINSTALL EXTENSION vsql_schematron;
