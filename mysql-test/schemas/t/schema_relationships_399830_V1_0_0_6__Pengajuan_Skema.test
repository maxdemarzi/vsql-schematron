INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 399830_V1.0.0.6__Pengajuan_Skema
--echo #
CREATE DATABASE `db_399830_V1_0_0_6__Pengajuan_Skema`;
USE `db_399830_V1_0_0_6__Pengajuan_Skema`;
CREATE TABLE `t_pengajuan_profile` (
  `id` VARCHAR(50) NOT NULL,
  `angka_kredit_dibutuhkan` INT,
  `angka_kredit_sekarang` INT,
  `angka_kredit_usulan` INT,
  `jenis_usulan` CHAR(50),
  `kategori_dosen` CHAR(50),
  `nomor_surat` CHAR(50),
  `pangkat` CHAR(50),
  `pendidikan_tertinggi_sebelumnya` CHAR(50),
  `pendidikan_tertinggi_sekarang` CHAR(50),
  `status` CHAR(50),
  `tanggal_surat` DATE,
  `tmt_pangkat` DATE,
  `tmt_jabatan` DATE,
  `usulan_menjadi` CHAR(50),
  `id_dosen` CHAR(50),
  `id_mata_kuliah` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m_jenis_pengajuan_dokumen` (
  `id` VARCHAR(50) NOT NULL,
  `keterangan` CHAR(50),
  `nama` CHAR(50),
  `required` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_pengajuan_document` (
  `id` VARCHAR(50) NOT NULL,
  `filename` CHAR(50),
  `status` CHAR(50),
  `id_jenis_dokumen` CHAR(50),
  `id_pengajuan_profile` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_399830_V1_0_0_6__Pengajuan_Skema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_399830_V1_0_0_6__Pengajuan_Skema') AS relationships;
DROP DATABASE `db_399830_V1_0_0_6__Pengajuan_Skema`;
UNINSTALL EXTENSION vsql_schematron;
