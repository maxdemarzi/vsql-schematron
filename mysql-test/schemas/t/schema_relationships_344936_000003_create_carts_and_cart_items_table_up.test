) CHARACTER SET latin1;
CREATE TABLE `public.cart_items` (
  `id` VARCHAR(50) NOT NULL,
  `cart_id` VARCHAR(50),
  `product_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
