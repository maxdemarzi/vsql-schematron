INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 450943_define_db
--echo #
CREATE DATABASE `db_450943_define_db`;
USE `db_450943_define_db`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `title` TEXT,
  `img` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibits` (
  `id` INT NOT NULL,
  `venue` TEXT,
  `theme` TEXT,
  `start_date` TEXT,
  `end_date` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `displays` (
  `id` INT NOT NULL,
  `product_id` INT,
  `exhibit_id` INT,
  `price` INT,
  `date_sold` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_450943_define_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_450943_define_db') AS relationships;
DROP DATABASE `db_450943_define_db`;
UNINSTALL EXTENSION vsql_schematron;
