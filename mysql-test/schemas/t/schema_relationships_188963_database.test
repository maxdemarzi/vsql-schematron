INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188963_database
--echo #
CREATE DATABASE `db_188963_database`;
USE `db_188963_database`;
CREATE TABLE `Caisse` (
  `IDCaisse` INT NOT NULL,
  `NumeroCaisse` VARCHAR(50),
  PRIMARY KEY (`IDCaisse`)
) CHARACTER SET latin1;
CREATE TABLE `Categorie` (
  `IDCategorie` INT NOT NULL,
  `NomCategorie` VARCHAR(50),
  PRIMARY KEY (`IDCategorie`)
) CHARACTER SET latin1;
CREATE TABLE `Produit` (
  `IDProduit` INT NOT NULL,
  `NomProduit` VARCHAR(50),
  `Prix` DOUBLE,
  `Source` VARCHAR(50),
  `IDCategorie` INT,
  `Description` TEXT,
  `Stock` INT,
  PRIMARY KEY (`IDProduit`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
  `IDAdmin` INT NOT NULL,
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  PRIMARY KEY (`IDAdmin`)
) CHARACTER SET latin1;
CREATE TABLE `Utilisateur` (
  `IDUtilisateur` INT NOT NULL,
  `Username` VARCHAR(50),
  `Password` VARCHAR(50),
  PRIMARY KEY (`IDUtilisateur`)
) CHARACTER SET latin1;
CREATE TABLE `Achat` (
  `IDAchat` INT NOT NULL,
  `IDCaisse` INT,
  `IDProduit` INT,
  `Quantite` INT,
  `IDUtilisateur` INT,
  PRIMARY KEY (`IDAchat`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188963_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188963_database') AS relationships;
DROP DATABASE `db_188963_database`;
UNINSTALL EXTENSION vsql_schematron;
