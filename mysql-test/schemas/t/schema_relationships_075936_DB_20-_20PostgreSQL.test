INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 075936_DB%20-%20PostgreSQL
--echo #
CREATE DATABASE `db_075936_DB_20__20PostgreSQL`;
USE `db_075936_DB_20__20PostgreSQL`;
CREATE TABLE `Report` (
  `ID` INT NOT NULL,
  `RVersion` VARCHAR(50),
  `RHost` VARCHAR(50),
  `RHostComment` VARCHAR(50),
  `RUser` VARCHAR(50),
  `RLocation` VARCHAR(50),
  `RDateTime` VARCHAR(50),
  `RComplete` SMALLINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `INum` INT,
  `IPage` VARCHAR(50),
  `IDevice` VARCHAR(50),
  `IGroup` VARCHAR(50),
  `IField` VARCHAR(50),
  `IValue` VARCHAR(50),
  `IIcon` INT,
  `IID` INT,
  `ReportID` INT
) CHARACTER SET latin1;
CREATE TABLE `NextID` (
  `TableName` VARCHAR(50) NOT NULL,
  `NextID` INT,
  PRIMARY KEY (`TableName`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_075936_DB_20__20PostgreSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_075936_DB_20__20PostgreSQL') AS relationships;
DROP DATABASE `db_075936_DB_20__20PostgreSQL`;
UNINSTALL EXTENSION vsql_schematron;
