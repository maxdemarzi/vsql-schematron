INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 052339_external_user_db
--echo #
CREATE DATABASE `db_052339_external_user_db`;
USE `db_052339_external_user_db`;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `employee_name` VARCHAR(50),
  `email` VARCHAR(50),
  `postal` VARCHAR(50),
  `profile_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `role_name` VARCHAR(50),
  `role_description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_roles` (
  `id` INT NOT NULL,
  `role_id` INT,
  `emp_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_052339_external_user_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_052339_external_user_db') AS relationships;
DROP DATABASE `db_052339_external_user_db`;
UNINSTALL EXTENSION vsql_schematron;
