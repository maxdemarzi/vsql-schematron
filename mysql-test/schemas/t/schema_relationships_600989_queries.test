INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 600989_queries
--echo #
CREATE DATABASE `db_600989_queries`;
USE `db_600989_queries`;
CREATE TABLE `LaborExchange.Qualification` (
  `id` INT NOT NULL,
  `profession` VARCHAR(50),
  `rank` INT,
  `course_name` VARCHAR(50),
  `duration` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LaborExchange.Applicant` (
  `id` INT NOT NULL,
  `qualification_id` INT,
  `expirience` INT,
  `benefit` INT,
  `contact_details` VARCHAR(50),
  `education` VARCHAR(50),
  `resume_posting_date` DATE,
  `benefit_start_date` DATE,
  `benefit_end_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LaborExchange.Employer` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `Email` VARCHAR(50),
  `contact_person` VARCHAR(50),
  `phone_number` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LaborExchange.Vacancy` (
  `id` INT NOT NULL,
  `employer_id` INT,
  `necessary_qualification_id` INT,
  `necessary_experience` INT,
  `necessary_education` VARCHAR(50),
  `posting_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LaborExchange.Hiring` (
  `id` INT NOT NULL,
  `applicant_id` INT,
  `vacancy_id` INT,
  `salary` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LaborExchange.Course_Passing` (
  `id` INT NOT NULL,
  `passing_date` VARCHAR(50),
  `qualification_id` INT,
  `applicant_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_600989_queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_600989_queries') AS relationships;
DROP DATABASE `db_600989_queries`;
UNINSTALL EXTENSION vsql_schematron;
