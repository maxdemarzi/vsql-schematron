INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 537918_2.One-To-Many%20Relationship
--echo #
CREATE DATABASE `db_537918_2_One_To_Many_20Relationship`;
USE `db_537918_2_One_To_Many_20Relationship`;
CREATE TABLE `manufacturers` (
  `manufacturer_id` INT,
  `name` VARCHAR(50),
  `established_on` DATE
) CHARACTER SET latin1;
CREATE TABLE `models` (
  `model_id` INT NOT NULL,
  `name` VARCHAR(50),
  `manufacturer_id` INT,
  PRIMARY KEY (`model_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_537918_2_One_To_Many_20Relationship') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_537918_2_One_To_Many_20Relationship') AS relationships;
DROP DATABASE `db_537918_2_One_To_Many_20Relationship`;
UNINSTALL EXTENSION vsql_schematron;
