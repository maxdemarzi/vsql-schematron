INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 473062_dump
--echo #
CREATE DATABASE `db_473062_dump`;
USE `db_473062_dump`;
CREATE TABLE `qualitys` (
  `quality_id` INT NOT NULL,
  `label` VARCHAR(50),
  `description` VARCHAR(50),
  `active` TINYINT,
  `created` DATETIME,
  PRIMARY KEY (`quality_id`)
) CHARACTER SET latin1;
CREATE TABLE `comunications` (
  `comunication_id` INT NOT NULL,
  `quality_id` INT,
  `user_id` INT,
  `title` VARCHAR(50),
  `message` VARCHAR(50),
  `href` VARCHAR(50),
  `read` TINYINT,
  `active` INT,
  `created` DATETIME,
  PRIMARY KEY (`comunication_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_473062_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_473062_dump') AS relationships;
DROP DATABASE `db_473062_dump`;
UNINSTALL EXTENSION vsql_schematron;
