INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 507463_starting_schema
--echo #
CREATE DATABASE `db_507463_starting_schema`;
USE `db_507463_starting_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `token` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallets` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `fk_user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `fk_wallet_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_507463_starting_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_507463_starting_schema') AS relationships;
DROP DATABASE `db_507463_starting_schema`;
UNINSTALL EXTENSION vsql_schematron;
