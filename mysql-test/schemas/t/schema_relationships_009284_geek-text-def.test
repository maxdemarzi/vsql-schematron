INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 009284_geek-text-def
--echo #
CREATE DATABASE `db_009284_geek_text_def`;
USE `db_009284_geek_text_def`;
CREATE TABLE `book` (
  `bookid` INT NOT NULL,
  `title` VARCHAR(50),
  `genre` VARCHAR(50),
  `author` VARCHAR(50),
  `rating` INT,
  `price` DOUBLE,
  `date` DATE,
  `sales` INT,
  `imagelink` VARCHAR(50),
  `topseller` BOOLEAN,
  PRIMARY KEY (`bookid`)
) CHARACTER SET latin1;
CREATE TABLE `credentials` (
  `userid` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `userinfo` (
  `userid` VARCHAR(50),
  `email` VARCHAR(50),
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `homestate` VARCHAR(50),
  `homecity` VARCHAR(50),
  `homeaddress` VARCHAR(50),
  `nickname` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `paymentinfo` (
  `userid` VARCHAR(50),
  `ccnum` INT,
  `cvv` INT,
  `name` VARCHAR(50),
  `zip` INT,
  `expdate` DATE
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `userid` VARCHAR(50),
  `state` VARCHAR(50),
  `city` VARCHAR(50),
  `address` VARCHAR(50),
  `zip` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_009284_geek_text_def') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_009284_geek_text_def') AS relationships;
DROP DATABASE `db_009284_geek_text_def`;
UNINSTALL EXTENSION vsql_schematron;
