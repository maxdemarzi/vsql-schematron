INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 564520_schema
--echo #
CREATE DATABASE `db_564520_schema`;
USE `db_564520_schema`;
CREATE TABLE `dream_session` (
  `id` VARCHAR(50) NOT NULL,
  `label` TEXT,
  `expires_at` DOUBLE,
  `payload` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_user` (
  `id` INT NOT NULL,
  `username` TEXT,
  `name` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `api_key` (
  `id` INT NOT NULL,
  `uuid` TEXT,
  `last_used` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `api_key` INT,
  `step` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor_reading` (
  `id` INT NOT NULL,
  `sensor` INT,
  `occurred` DATE,
  `readings` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_sensor` (
  `id` INT NOT NULL,
  `app_user` INT,
  `sensor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_564520_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_564520_schema') AS relationships;
DROP DATABASE `db_564520_schema`;
UNINSTALL EXTENSION vsql_schematron;
