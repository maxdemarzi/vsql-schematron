INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 320744_contacts
--echo #
CREATE DATABASE `db_320744_contacts`;
USE `db_320744_contacts`;
CREATE TABLE `contacts` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `active` TINYINT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phones` (
  `id` INT NOT NULL,
  `contacts_id` INT,
  `phone` VARCHAR(50),
  `phone_type` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone_types` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_320744_contacts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_320744_contacts') AS relationships;
DROP DATABASE `db_320744_contacts`;
UNINSTALL EXTENSION vsql_schematron;
