INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 522831_050_vendors.mysql
--echo #
CREATE DATABASE `db_522831_050_vendors_mysql`;
USE `db_522831_050_vendors_mysql`;
CREATE TABLE `pur_vendors` (
  `vendor_id` INT NOT NULL,
  `vendor_name` VARCHAR(50),
  `url` VARCHAR(50),
  `primary_address` VARCHAR(50),
  `billing_address` VARCHAR(50),
  `payment_address` VARCHAR(50),
  `gl_account_id` INT,
  `default_terms` INT,
  `status` CHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`vendor_id`)
) CHARACTER SET latin1;
CREATE TABLE `pur_vendor_notes` (
  `note_id` INT NOT NULL,
  `vendor_id` INT,
  `note_type_id` INT,
  `seq` INT,
  `note_text` VARCHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`note_id`)
) CHARACTER SET latin1;
CREATE TABLE `pur_vendor_attachments` (
  `vendor_id` INT,
  `attachment_id` INT
) CHARACTER SET latin1;
CREATE TABLE `pur_vendor_contacts` (
  `vendor_id` INT,
  `human_id` VARCHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `pur_vendor_catalog` (
  `vendor_catalog_id` INT NOT NULL,
  `vendor_id` INT,
  `currency` CHAR(50),
  `product_id` INT,
  `vendor_item_number` VARCHAR(50),
  `vendor_gtin` CHAR(50),
  `description` VARCHAR(50),
  `catalog_price` DECIMAL(10,2),
  `sale_price` DECIMAL(10,2),
  `sale_until` DATETIME,
  `discount_percent` DECIMAL(10,2),
  `discount_until` DATETIME,
  `product_url` VARCHAR(50),
  `status` CHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`vendor_catalog_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_522831_050_vendors_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_522831_050_vendors_mysql') AS relationships;
DROP DATABASE `db_522831_050_vendors_mysql`;
UNINSTALL EXTENSION vsql_schematron;
