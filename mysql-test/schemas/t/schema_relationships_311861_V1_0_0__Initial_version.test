INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 311861_V1_0_0__Initial_version
--echo #
CREATE DATABASE `db_311861_V1_0_0__Initial_version`;
USE `db_311861_V1_0_0__Initial_version`;
CREATE TABLE `gobblin_job_executions` (
  `job_name` VARCHAR(50),
  `job_id` VARCHAR(50) NOT NULL,
  `start_time` TIMESTAMP NULL,
  `end_time` TIMESTAMP NULL,
  `duration` BIGINT,
  `state` VARCHAR(50),
  `launched_tasks` INT,
  `completed_tasks` INT,
  `launcher_type` VARCHAR(50),
  `tracking_url` VARCHAR(50),
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `gobblin_task_executions` (
  `task_id` VARCHAR(50) NOT NULL,
  `job_id` VARCHAR(50),
  `start_time` TIMESTAMP NULL,
  `end_time` TIMESTAMP NULL,
  `duration` BIGINT,
  `state` VARCHAR(50),
  `failure_exception` TEXT,
  `low_watermark` BIGINT,
  `high_watermark` BIGINT,
  `table_namespace` VARCHAR(50),
  `table_name` VARCHAR(50),
  `table_type` VARCHAR(50),
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
CREATE TABLE `gobblin_job_metrics` (
  `metric_id` BIGINT NOT NULL,
  `job_id` VARCHAR(50),
  `metric_group` VARCHAR(50),
  `metric_name` VARCHAR(50),
  `metric_type` VARCHAR(50),
  `metric_value` VARCHAR(50),
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`metric_id`)
) CHARACTER SET latin1;
CREATE TABLE `gobblin_task_metrics` (
  `metric_id` BIGINT NOT NULL,
  `task_id` VARCHAR(50),
  `metric_group` VARCHAR(50),
  `metric_name` VARCHAR(50),
  `metric_type` VARCHAR(50),
  `metric_value` VARCHAR(50),
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`metric_id`)
) CHARACTER SET latin1;
CREATE TABLE `gobblin_job_properties` (
  `property_id` BIGINT NOT NULL,
  `job_id` VARCHAR(50),
  `property_key` VARCHAR(50),
  `property_value` TEXT,
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`property_id`)
) CHARACTER SET latin1;
CREATE TABLE `gobblin_task_properties` (
  `property_id` BIGINT NOT NULL,
  `task_id` VARCHAR(50),
  `property_key` VARCHAR(50),
  `property_value` TEXT,
  `created_ts` TIMESTAMP NULL,
  `last_modified_ts` TIMESTAMP NULL,
  PRIMARY KEY (`property_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_311861_V1_0_0__Initial_version') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_311861_V1_0_0__Initial_version') AS relationships;
DROP DATABASE `db_311861_V1_0_0__Initial_version`;
UNINSTALL EXTENSION vsql_schematron;
