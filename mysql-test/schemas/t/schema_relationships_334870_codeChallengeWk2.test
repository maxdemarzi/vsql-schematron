INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334870_codeChallengeWk2
--echo #
CREATE DATABASE `db_334870_codeChallengeWk2`;
USE `db_334870_codeChallengeWk2`;
CREATE TABLE `Products` (
  `product_id` INT,
  `product_name` VARCHAR(50),
  `price` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
  `customer_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `card_number` INT
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `order_id` INT,
  `product_id` INT,
  `customer_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334870_codeChallengeWk2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334870_codeChallengeWk2') AS relationships;
DROP DATABASE `db_334870_codeChallengeWk2`;
UNINSTALL EXTENSION vsql_schematron;
