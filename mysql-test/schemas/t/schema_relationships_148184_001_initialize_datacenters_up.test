INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148184_001_initialize_datacenters.up
--echo #
CREATE DATABASE `db_148184_001_initialize_datacenters_up`;
USE `db_148184_001_initialize_datacenters_up`;
CREATE TABLE `datacenters` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `racks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `datacenter_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `switches` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `ports` INT,
  `rack_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148184_001_initialize_datacenters_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148184_001_initialize_datacenters_up') AS relationships;
DROP DATABASE `db_148184_001_initialize_datacenters_up`;
UNINSTALL EXTENSION vsql_schematron;
