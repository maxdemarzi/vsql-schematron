INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095608_employee_tbl
--echo #
CREATE DATABASE `db_095608_employee_tbl`;
USE `db_095608_employee_tbl`;
CREATE TABLE `employee` (
  `id` BIGINT NOT NULL,
  `first_name` CHAR(50),
  `last_name` CHAR(50),
  `salary` DECIMAL(10,2),
  `start_date` DATE,
  `end_date` DATE,
  `manager_id` BIGINT,
  `address_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095608_employee_tbl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095608_employee_tbl') AS relationships;
DROP DATABASE `db_095608_employee_tbl`;
UNINSTALL EXTENSION vsql_schematron;
