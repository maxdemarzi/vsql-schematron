INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 631707_V1.0__Init
--echo #
CREATE DATABASE `db_631707_V1_0__Init`;
USE `db_631707_V1_0__Init`;
CREATE TABLE `parent` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `child` (
  `id` INT NOT NULL,
  `name` TEXT,
  `fk_parent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_631707_V1_0__Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_631707_V1_0__Init') AS relationships;
DROP DATABASE `db_631707_V1_0__Init`;
UNINSTALL EXTENSION vsql_schematron;
