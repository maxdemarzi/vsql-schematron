INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608977_data
--echo #
CREATE DATABASE `db_608977_data`;
USE `db_608977_data`;
CREATE TABLE `employee` (
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `department` VARCHAR(50),
  `email` VARCHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_image` (
  `id` INT NOT NULL,
  `profile_photo` VARCHAR(50),
  `employee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_file` (
  `id` INT NOT NULL,
  `file_name` TEXT,
  `employee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608977_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608977_data') AS relationships;
DROP DATABASE `db_608977_data`;
UNINSTALL EXTENSION vsql_schematron;
