INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103347_init
--echo #
CREATE DATABASE `db_103347_init`;
USE `db_103347_init`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` TEXT,
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory` (
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `customer_id` INT,
  `order_date` DATE,
  `pending` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_details` (
  `order_id` INT,
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103347_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103347_init') AS relationships;
DROP DATABASE `db_103347_init`;
UNINSTALL EXTENSION vsql_schematron;
