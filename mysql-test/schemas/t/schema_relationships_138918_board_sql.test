INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 138918_board_sql
--echo #
CREATE DATABASE `db_138918_board_sql`;
USE `db_138918_board_sql`;
CREATE TABLE `members` (
  `userid` VARCHAR(50) NOT NULL,
  `userpw` VARCHAR(50),
  `info` VARCHAR(50),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `board` (
  `idx` DECIMAL(10,2) NOT NULL,
  `title` VARCHAR(50),
  `cont` VARCHAR(50),
  `userid` VARCHAR(50),
  PRIMARY KEY (`idx`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_138918_board_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_138918_board_sql') AS relationships;
DROP DATABASE `db_138918_board_sql`;
UNINSTALL EXTENSION vsql_schematron;
