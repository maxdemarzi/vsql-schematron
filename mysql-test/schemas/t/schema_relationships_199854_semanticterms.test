INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 199854_semanticterms
--echo #
CREATE DATABASE `db_199854_semanticterms`;
USE `db_199854_semanticterms`;
CREATE TABLE `Allergens` (
  `AllergensD` INT NOT NULL,
  `AllergyCode` VARCHAR(50),
  `AllergyDesc` VARCHAR(50),
  `HealthcareEntitiesID` BIGINT,
  `PlatformAppsID` SMALLINT,
  `StatusID` SMALLINT,
  `CreatedDate` DATE,
  PRIMARY KEY (`AllergensD`)
) CHARACTER SET latin1;
CREATE TABLE `CWETermGroups` (
  `CWETermGroupId` VARCHAR(50) NOT NULL,
  `CWETermGroupDesc` VARCHAR(50),
  `CreatedDate` DATE,
  `StatusID` SMALLINT,
  PRIMARY KEY (`CWETermGroupId`)
) CHARACTER SET latin1;
CREATE TABLE `CWETerms` (
  `CWETermID` BIGINT NOT NULL,
  `Identifier` VARCHAR(50),
  `TermText` VARCHAR(50),
  `CWETermGroup` VARCHAR(50),
  `AlternativeID` VARCHAR(50),
  `AlternativeText` VARCHAR(50),
  `AlternativeTermGroup` VARCHAR(50),
  `CreatedDate` DATE,
  `StatusID` SMALLINT,
  PRIMARY KEY (`CWETermID`)
) CHARACTER SET latin1;
CREATE TABLE `Diagnosis` (
  `DiagnosisCode` VARCHAR(50) NOT NULL,
  `DiagnosisCodeShortDesc` VARCHAR(50),
  `DiagnosisCodeLongDesc` VARCHAR(50),
  `IndustryVersion` VARCHAR(50),
  `CreatedDate` DATE,
  `StatusID` SMALLINT,
  PRIMARY KEY (`DiagnosisCode`)
) CHARACTER SET latin1;
CREATE TABLE `LOINC` (
  `LOINCCodesetID` VARCHAR(50) NOT NULL,
  `CodesetDesc` VARCHAR(50),
  `CodesetStatus` VARCHAR(50),
  `CUILink` VARCHAR(50),
  `Occurence` VARCHAR(50),
  `Usage` VARCHAR(50),
  `CreatedDate` DATE,
  `Status` SMALLINT,
  PRIMARY KEY (`LOINCCodesetID`)
) CHARACTER SET latin1;
CREATE TABLE `Procedures` (
  `ProcedureCode` VARCHAR(50) NOT NULL,
  `ProcedureCodeShortDesc` VARCHAR(50),
  `ProcedureCodeLongDesc` VARCHAR(50),
  `IndustryVersion` VARCHAR(50),
  `CreatedDate` DATE,
  `StatusID` SMALLINT,
  PRIMARY KEY (`ProcedureCode`)
) CHARACTER SET latin1;
CREATE TABLE `RxNorms` (
  `RXNormId` VARCHAR(50) NOT NULL,
  `LAT` VARCHAR(50),
  `RxNormDesc` VARCHAR(50),
  `CreatedDate` DATE,
  `StatusID` SMALLINT,
  PRIMARY KEY (`RXNormId`)
) CHARACTER SET latin1;
CREATE TABLE `SnomedCodeset` (
  `SnomedCodesetID` VARCHAR(50) NOT NULL,
  `CodesetDesc` VARCHAR(50),
  `CodesetStatus` VARCHAR(50),
  `CUILink` VARCHAR(50),
  `Occurence` VARCHAR(50),
  `Usage` VARCHAR(50),
  `CreatedDate` DATE,
  `Status` SMALLINT,
  PRIMARY KEY (`SnomedCodesetID`)
) CHARACTER SET latin1;
CREATE TABLE `SnomedProblems` (
  `ProblemID` VARCHAR(50) NOT NULL,
  `ProblemDesc` VARCHAR(50),
  `ProblemIDStatus` VARCHAR(50),
  `CUILink` VARCHAR(50),
  `Occurence` VARCHAR(50),
  `Usage` VARCHAR(50),
  `CreatedDate` DATE,
  `Status` SMALLINT,
  PRIMARY KEY (`ProblemID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_199854_semanticterms') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_199854_semanticterms') AS relationships;
DROP DATABASE `db_199854_semanticterms`;
UNINSTALL EXTENSION vsql_schematron;
