INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580347_6_implement
--echo #
CREATE DATABASE `db_580347_6_implement`;
USE `db_580347_6_implement`;
CREATE TABLE `races` (
  `race_id` INT NOT NULL,
  `race_name` VARCHAR(50),
  `race_start` DATETIME,
  PRIMARY KEY (`race_id`)
) CHARACTER SET latin1;
CREATE TABLE `horses` (
  `horse_name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`horse_name`)
) CHARACTER SET latin1;
CREATE TABLE `bets` (
  `bet_id` INT NOT NULL,
  `bet_amount` SMALLINT,
  `race_id` INT,
  PRIMARY KEY (`bet_id`)
) CHARACTER SET latin1;
CREATE TABLE `run` (
  `race_id` INT,
  `horse_name` VARCHAR(50),
  `race_horse_number` TINYINT,
  `race_horse_rank` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `selected` (
  `bet_id` INT,
  `horse_name` VARCHAR(50),
  `bet_horse_placement` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580347_6_implement') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580347_6_implement') AS relationships;
DROP DATABASE `db_580347_6_implement`;
UNINSTALL EXTENSION vsql_schematron;
