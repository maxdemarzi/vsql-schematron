INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 212326_ProjetoPflics
--echo #
CREATE DATABASE `db_212326_ProjetoPflics`;
USE `db_212326_ProjetoPflics`;
CREATE TABLE `USUARIO` (
  `cpfUsuario` BIGINT NOT NULL,
  `FK_idPlano` INT,
  `nomeUsuario` CHAR(50),
  `sexoUsuario` CHAR(50),
  `telUsuario` CHAR(50),
  `emailUsuario` CHAR(50),
  `dataNascimento` CHAR(50),
  PRIMARY KEY (`cpfUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `PLANO` (
  `idPlano` INT NOT NULL,
  `nomePlano` CHAR(50),
  `beneficiosPlano` CHAR(50),
  `precoPlano` DOUBLE,
  PRIMARY KEY (`idPlano`)
) CHARACTER SET latin1;
CREATE TABLE `LOGIN` (
  `FK_idUsuario` BIGINT,
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `perfil` VARCHAR(50),
  `dataCriacao` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `ENDERECO` (
  `FK_cpfUsuario` BIGINT,
  `rua` CHAR(50),
  `num` INT,
  `cep` INT,
  `bairro` CHAR(50),
  `cidade` CHAR(50),
  `pais` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `CARTAO` (
  `FK_cpfUsuario` BIGINT,
  `ID_cartao` INT NOT NULL,
  `titularCartao` CHAR(50),
  `cpfTitular` BIGINT,
  `numero` BIGINT,
  `mesValidade` INT,
  `anoValidade` INT,
  `cvv` INT,
  PRIMARY KEY (`ID_cartao`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_212326_ProjetoPflics') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_212326_ProjetoPflics') AS relationships;
DROP DATABASE `db_212326_ProjetoPflics`;
UNINSTALL EXTENSION vsql_schematron;
