INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 465572_ddl
--echo #
CREATE DATABASE `db_465572_ddl`;
USE `db_465572_ddl`;
CREATE TABLE `track` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `low` SMALLINT,
  `high` SMALLINT,
  `percent_low` DOUBLE,
  `percent_high` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clip` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `probability_low` DOUBLE,
  `probability_high` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `facebook_id` BIGINT,
  `facebook_name` VARCHAR(50),
  `facebook_email` VARCHAR(50),
  `facebook_gender` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vote` (
  `id` BIGINT NOT NULL,
  `time` BIGINT,
  `user_id` BIGINT,
  `clip1_id` BIGINT,
  `clip2_id` BIGINT,
  `higher_arousal` SMALLINT,
  `higher_valence` SMALLINT,
  `higher_arousal_certainty` SMALLINT,
  `higher_valence_certainty` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_465572_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_465572_ddl') AS relationships;
DROP DATABASE `db_465572_ddl`;
UNINSTALL EXTENSION vsql_schematron;
