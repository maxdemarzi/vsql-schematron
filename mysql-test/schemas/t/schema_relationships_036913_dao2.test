INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036913_dao2
--echo #
CREATE DATABASE `db_036913_dao2`;
USE `db_036913_dao2`;
CREATE TABLE `author` (
  `author_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `pen_name` VARCHAR(50),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `editor` (
  `editor_id` BIGINT NOT NULL,
  `first_name` CHAR(50),
  `middle_name` CHAR(50),
  `last_name` CHAR(50),
  PRIMARY KEY (`editor_id`)
) CHARACTER SET latin1;
CREATE TABLE `title` (
  `title_id` BIGINT NOT NULL,
  `title_descr` CHAR(50),
  `title_cost` DOUBLE,
  `editor_id` BIGINT,
  PRIMARY KEY (`title_id`)
) CHARACTER SET latin1;
CREATE TABLE `title_author` (
  `title_id` BIGINT,
  `author_id` BIGINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036913_dao2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036913_dao2') AS relationships;
DROP DATABASE `db_036913_dao2`;
UNINSTALL EXTENSION vsql_schematron;
