INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 559988_script
--echo #
CREATE DATABASE `db_559988_script`;
USE `db_559988_script`;
CREATE TABLE `customer` (
  `customer_id` VARCHAR(50) NOT NULL,
  `customer_name` VARCHAR(50),
  `customer_address` VARCHAR(50),
  `customer_contact` VARCHAR(50),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
  `item_id` VARCHAR(50) NOT NULL,
  `item_name` VARCHAR(50),
  `item_stock` INT,
  `item_unit_price` DECIMAL(10,2),
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
  `order_id` VARCHAR(50) NOT NULL,
  `order_date` DATE,
  `customer_id` VARCHAR(50),
  `total` DECIMAL(10,2),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_detail` (
  `order_id` VARCHAR(50) NOT NULL,
  `item_id` VARCHAR(50) NOT NULL,
  `item_quantity` INT,
  `item_total` DECIMAL(10,2),
  PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_559988_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_559988_script') AS relationships;
DROP DATABASE `db_559988_script`;
UNINSTALL EXTENSION vsql_schematron;
