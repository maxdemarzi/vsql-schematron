INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663233_sistema_auxilio_tcc
--echo #
CREATE DATABASE `db_663233_sistema_auxilio_tcc`;
USE `db_663233_sistema_auxilio_tcc`;
CREATE TABLE `areas` (
  `id` SMALLINT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `professores` (
  `id` SMALLINT NOT NULL,
  `nome` VARCHAR(50),
  `matricula` VARCHAR(50),
  `fk_areas_id` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tema` (
  `id` SMALLINT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `fk_areas_id` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aluno_tema` (
  `id` SMALLINT NOT NULL,
  `fk_tema_id` SMALLINT,
  `fk_professores_id` SMALLINT,
  `fk_alunos_id` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alunos` (
  `id` SMALLINT NOT NULL,
  `nome` VARCHAR(50),
  `matricula` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663233_sistema_auxilio_tcc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663233_sistema_auxilio_tcc') AS relationships;
DROP DATABASE `db_663233_sistema_auxilio_tcc`;
UNINSTALL EXTENSION vsql_schematron;
