INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 627453_21.do.permissions
--echo #
CREATE DATABASE `db_627453_21_do_permissions`;
USE `db_627453_21_do_permissions`;
CREATE TABLE `permission_subject` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission_action` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles_permissions` (
  `role_id` INT NOT NULL,
  `permission_subject_id` INT NOT NULL,
  `permission_action_id` INT NOT NULL,
  PRIMARY KEY (`role_id`, `permission_subject_id`, `permission_action_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_627453_21_do_permissions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_627453_21_do_permissions') AS relationships;
DROP DATABASE `db_627453_21_do_permissions`;
UNINSTALL EXTENSION vsql_schematron;
