INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530678_Ex01
--echo #
CREATE DATABASE `db_530678_Ex01`;
USE `db_530678_Ex01`;
CREATE TABLE `product` (
  `prdNo` VARCHAR(50) NOT NULL,
  `prdName` VARCHAR(50),
  `prdPrice` DECIMAL(10,2),
  `prdCompany` VARCHAR(50),
  PRIMARY KEY (`prdNo`)
) CHARACTER SET latin1;
CREATE TABLE `publisher` (
  `pubNo` VARCHAR(50) NOT NULL,
  `pubName` VARCHAR(50),
  PRIMARY KEY (`pubNo`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `bookNo` VARCHAR(50) NOT NULL,
  `bookName` VARCHAR(50),
  `bookPrice` DECIMAL(10,2),
  `bookDate` DATE,
  `pubNo` VARCHAR(50),
  PRIMARY KEY (`bookNo`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
  `dptNo` VARCHAR(50) NOT NULL,
  `dptName` VARCHAR(50),
  PRIMARY KEY (`dptNo`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `stdNo` VARCHAR(50) NOT NULL,
  `stdName` VARCHAR(50),
  `stdYear` DECIMAL(10,2),
  `stdBirthDay` DATE,
  `dptNo` VARCHAR(50),
  PRIMARY KEY (`stdNo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530678_Ex01') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530678_Ex01') AS relationships;
DROP DATABASE `db_530678_Ex01`;
UNINSTALL EXTENSION vsql_schematron;
