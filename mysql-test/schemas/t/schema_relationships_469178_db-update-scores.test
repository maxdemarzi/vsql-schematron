INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 469178_db-update-scores
--echo #
CREATE DATABASE `db_469178_db_update_scores`;
USE `db_469178_db_update_scores`;
CREATE TABLE `tbl_score` (
  `id` BIGINT NOT NULL,
  `xml_data` TEXT,
  `name` CHAR(50),
  `timestamp` BIGINT,
  `branch_id` BIGINT,
  `slide_id` BIGINT,
  `task_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_test_score` (
  `test_id` BIGINT,
  `score_id` BIGINT NOT NULL,
  `rank` INT,
  PRIMARY KEY (`score_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_469178_db_update_scores') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_469178_db_update_scores') AS relationships;
DROP DATABASE `db_469178_db_update_scores`;
UNINSTALL EXTENSION vsql_schematron;
