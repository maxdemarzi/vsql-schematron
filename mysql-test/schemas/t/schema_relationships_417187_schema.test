INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 417187_schema
--echo #
CREATE DATABASE `db_417187_schema`;
USE `db_417187_schema`;
CREATE TABLE `author` (
  `id` INT NOT NULL,
  `fullname` VARCHAR(50),
  `photo` VARCHAR(50),
  `description` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `content` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_417187_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_417187_schema') AS relationships;
DROP DATABASE `db_417187_schema`;
UNINSTALL EXTENSION vsql_schematron;
