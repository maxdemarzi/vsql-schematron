INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094648_201909052257__Collection
--echo #
CREATE DATABASE `db_094648_201909052257__Collection`;
USE `db_094648_201909052257__Collection`;
CREATE TABLE `collection` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `owner` VARCHAR(50),
  `public` TINYINT,
  `created_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `collection_has_recipe` (
  `recipe` VARCHAR(50) NOT NULL,
  `collection` VARCHAR(50) NOT NULL,
  `added_at` VARCHAR(50),
  PRIMARY KEY (`recipe`, `collection`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094648_201909052257__Collection') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094648_201909052257__Collection') AS relationships;
DROP DATABASE `db_094648_201909052257__Collection`;
UNINSTALL EXTENSION vsql_schematron;
