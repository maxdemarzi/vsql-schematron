INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 228089_resource
--echo #
CREATE DATABASE `db_228089_resource`;
USE `db_228089_resource`;
CREATE TABLE `Sport` (
  `ID` INT NOT NULL,
  `Description` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Student_Sport` (
  `ID_Student` INT NOT NULL,
  `ID_Sport` INT NOT NULL,
  PRIMARY KEY (`ID_Student`, `ID_Sport`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_228089_resource') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_228089_resource') AS relationships;
DROP DATABASE `db_228089_resource`;
UNINSTALL EXTENSION vsql_schematron;
