INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 499908_slime-shop
--echo #
CREATE DATABASE `db_499908_slime_shop`;
USE `db_499908_slime_shop`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `uuid` VARCHAR(50),
  `full_name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` DECIMAL(10,2),
  `description` TEXT,
  `image` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `user_id` INT,
  `status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `order_id` INT,
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_499908_slime_shop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_499908_slime_shop') AS relationships;
DROP DATABASE `db_499908_slime_shop`;
UNINSTALL EXTENSION vsql_schematron;
