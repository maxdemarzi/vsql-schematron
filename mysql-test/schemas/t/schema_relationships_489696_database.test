INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 489696_database
--echo #
CREATE DATABASE `db_489696_database`;
USE `db_489696_database`;
CREATE TABLE `product` (
  `idProduct` INT NOT NULL,
  `title` TEXT,
  `optprice` INT,
  `rozprice` TEXT,
  `description` VARCHAR(50),
  PRIMARY KEY (`idProduct`)
) CHARACTER SET latin1;
CREATE TABLE `deal` (
  `idDeal` INT NOT NULL,
  `dealdate` DATE,
  `idProduct` INT,
  `kolvo` INT,
  `idCustomer` INT,
  `isOpt` BOOLEAN,
  PRIMARY KEY (`idDeal`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `idCustomer` INT NOT NULL,
  `phone` TEXT,
  `name` TEXT,
  `address` TEXT,
  PRIMARY KEY (`idCustomer`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_489696_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_489696_database') AS relationships;
DROP DATABASE `db_489696_database`;
UNINSTALL EXTENSION vsql_schematron;
