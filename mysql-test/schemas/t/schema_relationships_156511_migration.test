INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 156511_migration
--echo #
CREATE DATABASE `db_156511_migration`;
USE `db_156511_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `fullname` TEXT,
  `email` TEXT,
  `password` TEXT,
  `roles` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Mk` (
  `id` INT NOT NULL,
  `title` TEXT,
  `developer` TEXT,
  `publisher` TEXT,
  `release_year` TEXT,
  `platforms` VARCHAR(50),
  `story` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Secret` (
  `id` INT NOT NULL,
  `platforms` VARCHAR(50),
  `title` TEXT,
  `desc` TEXT,
  `mk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Character` (
  `id` INT NOT NULL,
  `name_char` TEXT,
  `img_char_link` TEXT,
  `mk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Move` (
  `id` INT NOT NULL,
  `char_id` INT,
  `spec_moves` VARCHAR(50),
  `fin_moves` VARCHAR(50),
  `combos` VARCHAR(50),
  `morphs` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_156511_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_156511_migration') AS relationships;
DROP DATABASE `db_156511_migration`;
UNINSTALL EXTENSION vsql_schematron;
