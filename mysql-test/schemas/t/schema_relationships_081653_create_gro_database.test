INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081653_create_gro_database
--echo #
CREATE DATABASE `db_081653_create_gro_database`;
USE `db_081653_create_gro_database`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `uuid` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groceries` (
  `id` INT NOT NULL,
  `barcode` VARCHAR(50),
  `name` VARCHAR(50),
  `amount` INT,
  `exp_date` DATE,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081653_create_gro_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081653_create_gro_database') AS relationships;
DROP DATABASE `db_081653_create_gro_database`;
UNINSTALL EXTENSION vsql_schematron;
