INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582024_setup_db
--echo #
CREATE DATABASE `db_582024_setup_db`;
USE `db_582024_setup_db`;
CREATE TABLE `USERS` (
  `USER_ID` BIGINT NOT NULL,
  `USERNAME` VARCHAR(50),
  `BALANCE` BIGINT,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TOURNAMENTS` (
  `TOURNAMENT_ID` BIGINT NOT NULL,
  `TOURNAMENT_NAME` VARCHAR(50),
  `TOURNAMENT_STATUS` VARCHAR(50),
  `DEPOSIT` BIGINT,
  `PRIZE` BIGINT,
  `WINNER_ID` BIGINT,
  PRIMARY KEY (`TOURNAMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MTM_USER_TOURNAMENT` (
  `ID` BIGINT NOT NULL,
  `TOURNAMENT_ID` BIGINT,
  `USER_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582024_setup_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582024_setup_db') AS relationships;
DROP DATABASE `db_582024_setup_db`;
UNINSTALL EXTENSION vsql_schematron;
