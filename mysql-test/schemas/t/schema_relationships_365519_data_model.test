INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 365519_data_model
--echo #
CREATE DATABASE `db_365519_data_model`;
USE `db_365519_data_model`;
CREATE TABLE `APP_USER` (
  `user_id` INT NOT NULL,
  `user_email` VARCHAR(50),
  `user_fname` VARCHAR(50),
  `user_lname` VARCHAR(50),
  `user_image` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `SURVEY` (
  `survey_id` INT NOT NULL,
  `user_id` INT,
  `survey_name` VARCHAR(50),
  `survey_desc` VARCHAR(50),
  `survey_type` VARCHAR(50),
  `survey_start_date` DATE,
  `survey_end_date` DATE,
  PRIMARY KEY (`survey_id`)
) CHARACTER SET latin1;
CREATE TABLE `SURVEY_QUESTION` (
  `question_id` INT NOT NULL,
  `survey_id` INT,
  `question_type` VARCHAR(50),
  `question_text` VARCHAR(50),
  PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
CREATE TABLE `SURVEY_QUESTION_CHOICE` (
  `choice_id` INT NOT NULL,
  `question_id` INT,
  `choice_text` VARCHAR(50),
  PRIMARY KEY (`choice_id`)
) CHARACTER SET latin1;
CREATE TABLE `SURVEY_RESPONSE` (
  `response_id` INT NOT NULL,
  `respondent_user_id` INT,
  `survey_id` INT,
  `question_id` INT,
  `choice_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`response_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_365519_data_model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_365519_data_model') AS relationships;
DROP DATABASE `db_365519_data_model`;
UNINSTALL EXTENSION vsql_schematron;
