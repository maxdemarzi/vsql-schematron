INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 281583_V2021.02.19.09.43.00__add_event_table
--echo #
CREATE DATABASE `db_281583_V2021_02_19_09_43_00__add_event_table`;
USE `db_281583_V2021_02_19_09_43_00__add_event_table`;
CREATE TABLE `aggregate_in_stream` (
  `aggregate_id` VARCHAR(50),
  `aggregate_name` VARCHAR(50),
  `aggregate_version` INT,
  `stream_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`stream_id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
  `id` VARCHAR(50) NOT NULL,
  `stream_id` VARCHAR(50),
  `aggregate_version` INT,
  `payload` VARCHAR(50),
  `order_of_occurrence` VARCHAR(50),
  `event_name` VARCHAR(50),
  `event_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_281583_V2021_02_19_09_43_00__add_event_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_281583_V2021_02_19_09_43_00__add_event_table') AS relationships;
DROP DATABASE `db_281583_V2021_02_19_09_43_00__add_event_table`;
