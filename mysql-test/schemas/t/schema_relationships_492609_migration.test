INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 492609_migration
--echo #
CREATE DATABASE `db_492609_migration`;
USE `db_492609_migration`;
CREATE TABLE `shortened_urls` (
  `short_base64` VARCHAR(50) NOT NULL,
  `url` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`short_base64`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
  `timestamp` TIMESTAMP NOT NULL,
  `shortened_url_base64` TEXT,
  PRIMARY KEY (`timestamp`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_492609_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_492609_migration') AS relationships;
DROP DATABASE `db_492609_migration`;
UNINSTALL EXTENSION vsql_schematron;
