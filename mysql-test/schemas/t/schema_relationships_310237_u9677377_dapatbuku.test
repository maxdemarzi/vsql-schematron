    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_310237_u9677377_dapatbuku') AS relationships;
DROP DATABASE `db_310237_u9677377_dapatbuku`;
