INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 480556_create-schema
--echo #
CREATE DATABASE `db_480556_create_schema`;
USE `db_480556_create_schema`;
CREATE TABLE `users` (
  `id_user` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `manufacturers` (
  `id_manufacturer` BIGINT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id_manufacturer`)
) CHARACTER SET latin1;
CREATE TABLE `models` (
  `id_model` BIGINT NOT NULL,
  `id_manufacturer` BIGINT,
  `title` VARCHAR(50),
  `yearstart` INT,
  `yearend` INT,
  PRIMARY KEY (`id_model`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_480556_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_480556_create_schema') AS relationships;
DROP DATABASE `db_480556_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
