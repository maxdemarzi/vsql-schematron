INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 284448_1
--echo #
CREATE DATABASE `db_284448_1`;
USE `db_284448_1`;
CREATE TABLE `scalaVersion` (
  `id` INT NOT NULL,
  `sha` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `compilerOption` (
  `id` INT NOT NULL,
  `opt` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scalaVersionCompilerOption` (
  `scalaVersionId` BIGINT NOT NULL,
  `compilerOptionId` BIGINT NOT NULL,
  `idx` INT,
  PRIMARY KEY (`scalaVersionId`, `compilerOptionId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_284448_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_284448_1') AS relationships;
DROP DATABASE `db_284448_1`;
UNINSTALL EXTENSION vsql_schematron;
