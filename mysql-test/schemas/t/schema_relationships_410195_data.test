INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 410195_data
--echo #
CREATE DATABASE `db_410195_data`;
USE `db_410195_data`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `phone_number` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vouchers` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_410195_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_410195_data') AS relationships;
DROP DATABASE `db_410195_data`;
UNINSTALL EXTENSION vsql_schematron;
