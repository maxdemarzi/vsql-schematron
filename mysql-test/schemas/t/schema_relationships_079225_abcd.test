INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079225_abcd
--echo #
CREATE DATABASE `db_079225_abcd`;
USE `db_079225_abcd`;
CREATE TABLE `AirlineCompany` (
  `AirlineCode` INT NOT NULL,
  `AirlineName` VARCHAR(50),
  PRIMARY KEY (`AirlineCode`)
) CHARACTER SET latin1;
CREATE TABLE `Flight` (
  `FlightID` INT NOT NULL,
  `PlaneType` VARCHAR(50),
  `AirlineCode` INT,
  PRIMARY KEY (`FlightID`)
) CHARACTER SET latin1;
CREATE TABLE `Country` (
  `CountryID` INT NOT NULL,
  `CountryName` VARCHAR(50),
  `FlightID` INT,
  PRIMARY KEY (`CountryID`)
) CHARACTER SET latin1;
CREATE TABLE `Airport` (
  `AirportID` INT NOT NULL,
  `AirportName` VARCHAR(50),
  `CountryID` INT,
  PRIMARY KEY (`AirportID`)
) CHARACTER SET latin1;
CREATE TABLE `Customer` (
  `CustomerID` INT NOT NULL,
  `CustomerFirstName` VARCHAR(50),
  `CustomerLastName` VARCHAR(50),
  `Username` VARCHAR(50),
  `CustomerPassword` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`CustomerID`)
) CHARACTER SET latin1;
CREATE TABLE `Payment` (
  `PaymentID` INT NOT NULL,
  `CardNo` VARCHAR(50),
  `CVV` INT,
  `Expiry` INT,
  `CustomerID` INT,
  PRIMARY KEY (`PaymentID`)
) CHARACTER SET latin1;
CREATE TABLE `Booking` (
  `BookingID` INT NOT NULL,
  `CustomerID` INT,
  `FlightID` INT,
  `AirlineCode` INT,
  `PaymentID` INT,
  PRIMARY KEY (`BookingID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079225_abcd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079225_abcd') AS relationships;
DROP DATABASE `db_079225_abcd`;
UNINSTALL EXTENSION vsql_schematron;
