INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 056431_dump
--echo #
CREATE DATABASE `db_056431_dump`;
USE `db_056431_dump`;
CREATE TABLE `produtos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `valor_unitario` DECIMAL(10,2),
  `qtde_estoque` INT,
  `data_criacao` DATETIME,
  `data_atualizacao` DATETIME,
  `data_exclusao` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transacoes` (
  `id` INT NOT NULL,
  `produto_id` INT,
  `valor_venda` DECIMAL(10,2),
  `data_venda` DATETIME,
  `estado` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_056431_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_056431_dump') AS relationships;
DROP DATABASE `db_056431_dump`;
UNINSTALL EXTENSION vsql_schematron;
