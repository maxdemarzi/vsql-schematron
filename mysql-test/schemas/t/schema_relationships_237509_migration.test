INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 237509_migration
--echo #
CREATE DATABASE `db_237509_migration`;
USE `db_237509_migration`;
CREATE TABLE `Product` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `price` INT,
  `image` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `subtotal` INT,
  `tax` INT,
  `total` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderItem` (
  `id` VARCHAR(50) NOT NULL,
  `price` INT,
  `orderId` TEXT,
  `productId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_237509_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_237509_migration') AS relationships;
DROP DATABASE `db_237509_migration`;
UNINSTALL EXTENSION vsql_schematron;
