INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 631365_V8__transaction
--echo #
CREATE DATABASE `db_631365_V8__transaction`;
USE `db_631365_V8__transaction`;
CREATE TABLE `shed_transactions` (
  `id` BIGINT NOT NULL,
  `identifier` VARCHAR(50),
  `account_identifier` VARCHAR(50),
  `routing_code` VARCHAR(50),
  `external_id` VARCHAR(50),
  `a_name` VARCHAR(50),
  `a_type` VARCHAR(50),
  `description` VARCHAR(50),
  `transaction_type` VARCHAR(50),
  `sub_txn_type` VARCHAR(50),
  `amount` DECIMAL(10,2),
  `fee_amount` DECIMAL(10,2),
  `state` VARCHAR(50),
  `customer_account_identifier` VARCHAR(50),
  `payable_account_identifier` VARCHAR(50),
  `nostro_account_identifier` VARCHAR(50),
  `transaction_date` TIMESTAMP NULL,
  `expiration_date` TIMESTAMP NULL,
  `parent_txn_id` BIGINT,
  `created_by` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `last_modified_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_631365_V8__transaction') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_631365_V8__transaction') AS relationships;
DROP DATABASE `db_631365_V8__transaction`;
UNINSTALL EXTENSION vsql_schematron;
