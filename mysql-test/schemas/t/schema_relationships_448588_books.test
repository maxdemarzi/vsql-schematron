INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 448588_books
--echo #
CREATE DATABASE `db_448588_books`;
USE `db_448588_books`;
CREATE TABLE `book_copies` (
  `id` INT NOT NULL,
  `library_branch_id` INT,
  `no_of_copies` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `library_branches` (
  `id` INT NOT NULL,
  `library_branch_name` VARCHAR(50),
  `address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_lendings` (
  `id` VARCHAR(50) NOT NULL,
  `library_branch_id` INT,
  `card_no` VARCHAR(50),
  `date_out` DATE,
  `due_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_448588_books') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_448588_books') AS relationships;
DROP DATABASE `db_448588_books`;
UNINSTALL EXTENSION vsql_schematron;
