INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334598_ddl_metflix
--echo #
CREATE DATABASE `db_334598_ddl_metflix`;
USE `db_334598_ddl_metflix`;
CREATE TABLE `director` (
  `id` VARCHAR(50) NOT NULL,
  `_name` VARCHAR(50),
  `nationality` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `nationality` VARCHAR(50),
  `production_company` VARCHAR(50),
  `year_release` VARCHAR(50),
  `id_director` VARCHAR(50),
  `budget` VARCHAR(50),
  `box_office` VARCHAR(50),
  `running_time` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `actor` (
  `id` VARCHAR(50) NOT NULL,
  `_name` VARCHAR(50),
  `nationality` VARCHAR(50),
  `born` DATE,
  `sex` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_actor` (
  `id_movie` VARCHAR(50) NOT NULL,
  `id_actor` VARCHAR(50) NOT NULL,
  `_role` VARCHAR(50),
  `is_main_character` BOOLEAN,
  PRIMARY KEY (`id_movie`, `id_actor`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334598_ddl_metflix') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334598_ddl_metflix') AS relationships;
DROP DATABASE `db_334598_ddl_metflix`;
UNINSTALL EXTENSION vsql_schematron;
