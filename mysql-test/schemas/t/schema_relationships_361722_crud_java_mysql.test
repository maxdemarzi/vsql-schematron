INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 361722_crud_java_mysql
--echo #
CREATE DATABASE `db_361722_crud_java_mysql`;
USE `db_361722_crud_java_mysql`;
CREATE TABLE `clientes` (
  `id` INT,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `endereco` VARCHAR(50),
  `telefone` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ordem_de_servicos` (
  `id` INT,
  `equipamento` VARCHAR(50),
  `defeito` VARCHAR(50),
  `servico` VARCHAR(50),
  `tecnico` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `criado_em` TIMESTAMP NULL,
  `id_cliente` INT
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id` INT,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  `telefone` VARCHAR(50),
  `admin` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_361722_crud_java_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_361722_crud_java_mysql') AS relationships;
DROP DATABASE `db_361722_crud_java_mysql`;
UNINSTALL EXTENSION vsql_schematron;
