INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142479_zaiko-arunke
--echo #
CREATE DATABASE `db_142479_zaiko_arunke`;
USE `db_142479_zaiko_arunke`;

CREATE TABLE `item` (
  `id` INT,
  `user_id` INT,
  `sort` INT,
  `name` VARCHAR(64),
  `unit` VARCHAR(64),
  `last_amount` INT,
  `total_amount` INT,
  `first_refill_time` DATETIME,
  `last_refill_time` DATETIME,
  `est_refill_time` DATETIME,
  `refill_frequency` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `refill` (
  `id` INT,
  `item_id` INT,
  `amount` INT,
  `refill_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142479_zaiko_arunke') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142479_zaiko_arunke') AS relationships;
DROP DATABASE `db_142479_zaiko_arunke`;
UNINSTALL EXTENSION vsql_schematron;
