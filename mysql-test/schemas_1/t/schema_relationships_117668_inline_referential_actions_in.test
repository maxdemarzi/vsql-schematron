INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 117668_inline_referential_actions.in
--echo #
CREATE DATABASE `db_117668_inline_referential_actions_in`;
USE `db_117668_inline_referential_actions_in`;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `user_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `id` INT NOT NULL,
  `order_id` INT,
  `product_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `price` DECIMAL(10,2),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `date_of_birth` DATETIME,
  `created_at` DATETIME,
  `country_code` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `code` INT NOT NULL,
  `name` VARCHAR(50),
  `continent_name` VARCHAR(50),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_117668_inline_referential_actions_in') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_117668_inline_referential_actions_in') AS relationships;
DROP DATABASE `db_117668_inline_referential_actions_in`;
UNINSTALL EXTENSION vsql_schematron;
