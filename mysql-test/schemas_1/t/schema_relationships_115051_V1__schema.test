INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115051_V1__schema
--echo #
CREATE DATABASE `db_115051_V1__schema`;
USE `db_115051_V1__schema`;
CREATE TABLE `song` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `author` VARCHAR(50),
  `album` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `verse` (
  `id` INT NOT NULL,
  `index` INT,
  `song_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quote` (
  `id` INT NOT NULL,
  `phrase` TEXT,
  `index` INT,
  `verse_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115051_V1__schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115051_V1__schema') AS relationships;
DROP DATABASE `db_115051_V1__schema`;
UNINSTALL EXTENSION vsql_schematron;
