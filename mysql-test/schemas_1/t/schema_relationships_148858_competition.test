INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148858_competition
--echo #
CREATE DATABASE `db_148858_competition`;
USE `db_148858_competition`;

CREATE TABLE `STUDIO` (
  `Name` VARCHAR(255),
  `Phone` VARCHAR(255),
  `Address` VARCHAR(255),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `TEACHER` (
  `TeacherID` VARCHAR(255),
  `LName` VARCHAR(255),
  `FName` VARCHAR(255),
  `Phone` VARCHAR(255),
  `StudioName` VARCHAR(255),
  PRIMARY KEY (`TeacherID`)
) CHARACTER SET latin1;

CREATE TABLE `COMPETITOR` (
  `CompetitorID` VARCHAR(255),
  `LName` VARCHAR(255),
  `FName` VARCHAR(255),
  `Age` INT,
  `Instrument` VARCHAR(255),
  `TeacherID` VARCHAR(255),
  PRIMARY KEY (`CompetitorID`)
) CHARACTER SET latin1;

CREATE TABLE `COMPOSITION` (
  `MusicID` VARCHAR(255),
  `Title` VARCHAR(255),
  `Composer` VARCHAR(255),
  `Genre` VARCHAR(255),
  PRIMARY KEY (`MusicID`)
) CHARACTER SET latin1;

CREATE TABLE `CATEGORY` (
  `CategoryID` VARCHAR(255),
  `Genre` VARCHAR(255),
  `AgeMin` INT,
  `AgeMax` INT,
  `CompDate` DATETIME,
  `CompTime` DATETIME,
  PRIMARY KEY (`CategoryID`)
) CHARACTER SET latin1;

CREATE TABLE `PERFORMANCE` (
  `CompetitorID` VARCHAR(255),
  `CategoryID` VARCHAR(255),
  `MusicID` VARCHAR(255),
  `Score` INT,
  PRIMARY KEY (`CompetitorID`, `CategoryID`, `MusicID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148858_competition') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148858_competition') AS relationships;
DROP DATABASE `db_148858_competition`;
UNINSTALL EXTENSION vsql_schematron;
