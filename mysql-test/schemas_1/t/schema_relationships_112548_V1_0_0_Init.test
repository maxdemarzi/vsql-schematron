INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 112548_V1_0_0_Init
--echo #
CREATE DATABASE `db_112548_V1_0_0_Init`;
USE `db_112548_V1_0_0_Init`;

CREATE TABLE `links` (
  `id` INT,
  `hash` VARCHAR(64),
  `alias` VARCHAR(64),
  `url` VARCHAR(64),
  `status` INT,
  `redirect_code` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `link_meta` (
  `id` INT,
  `link_id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `create_at` DATETIME,
  `update_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `link_analytics` (
  `link_id` INT,
  `platform` VARCHAR(64),
  `device` VARCHAR(64),
  `browser` VARCHAR(64),
  `location` VARCHAR(64),
  `ip` VARCHAR(64),
  `create_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `link_expiration` (
  `link_id` INT,
  `expire_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `link_user` (
  `user_id` INT,
  `link_hash` VARCHAR(64),
  `link_id` INT,
  `create_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_112548_V1_0_0_Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_112548_V1_0_0_Init') AS relationships;
DROP DATABASE `db_112548_V1_0_0_Init`;
UNINSTALL EXTENSION vsql_schematron;
