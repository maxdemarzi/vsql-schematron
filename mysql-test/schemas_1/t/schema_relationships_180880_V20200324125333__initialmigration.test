INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180880_V20200324125333__initialmigration
--echo #
CREATE DATABASE `db_180880_V20200324125333__initialmigration`;
USE `db_180880_V20200324125333__initialmigration`;
CREATE TABLE `instances` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `status` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `instance_id` VARCHAR(50),
  `name` TEXT,
  `email` VARCHAR(50),
  `auth_crypt` TEXT,
  `admin` BOOLEAN,
  `time_zone_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` VARCHAR(50) NOT NULL,
  `author_id` VARCHAR(50),
  `body` TEXT,
  `answer` TEXT,
  `rule_references` TEXT,
  `active_at` TIMESTAMP NULL,
  `closed_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `responses` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `question_id` VARCHAR(50),
  `response` TEXT,
  `rule_references` TEXT,
  `correct` BOOLEAN,
  `bonus` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `last_used_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180880_V20200324125333__initialmigration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180880_V20200324125333__initialmigration') AS relationships;
DROP DATABASE `db_180880_V20200324125333__initialmigration`;
UNINSTALL EXTENSION vsql_schematron;
