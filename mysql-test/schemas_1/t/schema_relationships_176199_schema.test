INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 176199_schema
--echo #
CREATE DATABASE `db_176199_schema`;
USE `db_176199_schema`;

CREATE TABLE `USER_ROLE` (
  `role_id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `USER_ACCOUNT` (
  `user_id` INT,
  `username` VARCHAR(64),
  `passkey` VARCHAR(64),
  `role_id` INT,
  `last_login` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `OLYMPICS` (
  `olympic_id` INT,
  `olympic_num` VARCHAR(64),
  `host_city` VARCHAR(64),
  `opening_date` DATETIME,
  `closing_date` DATETIME,
  `official_website` VARCHAR(64),
  PRIMARY KEY (`olympic_id`)
) CHARACTER SET latin1;

CREATE TABLE `SPORT` (
  `sport_id` INT,
  `sport_name` VARCHAR(64),
  `description` VARCHAR(64),
  `dob` DATETIME,
  `team_size` INT,
  PRIMARY KEY (`sport_id`)
) CHARACTER SET latin1;

CREATE TABLE `COUNTRY` (
  `country_id` INT,
  `country` VARCHAR(64),
  `country_code` VARCHAR(64),
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;

CREATE TABLE `PARTICIPANT` (
  `participant_id` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `nationality` VARCHAR(64),
  `birth_place` VARCHAR(64),
  `dob` DATETIME,
  PRIMARY KEY (`participant_id`)
) CHARACTER SET latin1;

CREATE TABLE `MEDAL` (
  `medal_id` INT,
  `medal_title` VARCHAR(64),
  `points` INT,
  PRIMARY KEY (`medal_id`)
) CHARACTER SET latin1;

CREATE TABLE `VENUE` (
  `venue_id` INT,
  `olympics_id` INT,
  `venue_name` VARCHAR(64),
  `capacity` INT,
  PRIMARY KEY (`venue_id`)
) CHARACTER SET latin1;

CREATE TABLE `EVENT` (
  `event_id` INT,
  `sport_id` INT,
  `venue_id` INT,
  `gender` INT,
  `event_time` DATETIME,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_176199_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_176199_schema') AS relationships;
DROP DATABASE `db_176199_schema`;
UNINSTALL EXTENSION vsql_schematron;
