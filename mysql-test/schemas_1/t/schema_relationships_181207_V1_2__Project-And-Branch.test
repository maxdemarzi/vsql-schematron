INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 181207_V1_2__Project-And-Branch
--echo #
CREATE DATABASE `db_181207_V1_2__Project_And_Branch`;
USE `db_181207_V1_2__Project_And_Branch`;
CREATE TABLE `project` (
  `id` VARCHAR(50) NOT NULL,
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `branch` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `project_id` VARCHAR(50),
  `active` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_181207_V1_2__Project_And_Branch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_181207_V1_2__Project_And_Branch') AS relationships;
DROP DATABASE `db_181207_V1_2__Project_And_Branch`;
UNINSTALL EXTENSION vsql_schematron;
