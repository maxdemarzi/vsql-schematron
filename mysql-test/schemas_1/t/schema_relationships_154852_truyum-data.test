INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 154852_truyum-data
--echo #
CREATE DATABASE `db_154852_truyum_data`;
USE `db_154852_truyum_data`;
CREATE TABLE `menu_item` (
  `menuItemId` INT NOT NULL,
  `title` VARCHAR(50),
  `price` DECIMAL(10,2),
  `isActive` BOOLEAN,
  `dateOfLaunch` DATE,
  `category` VARCHAR(50),
  `isFreeDelivery` BOOLEAN,
  PRIMARY KEY (`menuItemId`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
  `cart_id` INT NOT NULL,
  `user_id` INT,
  `menuItem_id` INT,
  PRIMARY KEY (`cart_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_154852_truyum_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_154852_truyum_data') AS relationships;
DROP DATABASE `db_154852_truyum_data`;
UNINSTALL EXTENSION vsql_schematron;
