INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195927_00_struct
--echo #
CREATE DATABASE `db_195927_00_struct`;
USE `db_195927_00_struct`;
CREATE TABLE `CONFIG` (
  `ID` INT NOT NULL,
  `LIBELLE` VARCHAR(50),
  `VALEUR` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLE` (
  `ID` INT NOT NULL,
  `LIBELLE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `UTILISATEUR` (
  `ID` INT NOT NULL,
  `NOM` VARCHAR(50),
  `PRENOM` VARCHAR(50),
  `LOGIN` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `ID_ROLE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACTIVITE` (
  `ID` INT NOT NULL,
  `NOM` VARCHAR(50),
  `LIEU` VARCHAR(50),
  `SHORT_DESCRIPTION` TEXT,
  `DESCRIPTION` TEXT,
  `ID_UTILISATEUR` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMMENTAIRE` (
  `ID` INT NOT NULL,
  `TEXTE` TEXT,
  `ID_ACTIVITE` INT,
  `ID_UTILISATEUR` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHOTO` (
  `ID` INT NOT NULL,
  `CHEMIN` VARCHAR(50),
  `ID_ACTIVITE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195927_00_struct') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195927_00_struct') AS relationships;
DROP DATABASE `db_195927_00_struct`;
UNINSTALL EXTENSION vsql_schematron;
