INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 189008_db_grh
--echo #
CREATE DATABASE `db_189008_db_grh`;
USE `db_189008_db_grh`;
CREATE TABLE `cv` (
  `id` INT,
  `file` VARCHAR(50),
  `poste_id` INT
) CHARACTER SET latin1;
CREATE TABLE `poste` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `etat` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `mdp` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_189008_db_grh') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_189008_db_grh') AS relationships;
DROP DATABASE `db_189008_db_grh`;
UNINSTALL EXTENSION vsql_schematron;
