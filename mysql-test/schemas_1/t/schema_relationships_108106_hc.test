INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108106_hc
--echo #
CREATE DATABASE `db_108106_hc`;
USE `db_108106_hc`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `is_admin` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `headcounts` (
  `id` INT,
  `user_id` INT,
  `submit_time` DATETIME,
  `entered_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `room_data` (
  `id` INT,
  `room` VARCHAR(255),
  `people_count` INT,
  `count_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108106_hc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108106_hc') AS relationships;
DROP DATABASE `db_108106_hc`;
UNINSTALL EXTENSION vsql_schematron;
