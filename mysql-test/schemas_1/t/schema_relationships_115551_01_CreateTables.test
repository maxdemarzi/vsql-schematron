INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115551_01-CreateTables
--echo #
CREATE DATABASE `db_115551_01_CreateTables`;
USE `db_115551_01_CreateTables`;

CREATE TABLE `cpUser` (
  `idUser` INT,
  `username` VARCHAR(64),
  `passwordHash` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `userBirthday` DATETIME,
  PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;

CREATE TABLE `cpCountry` (
  `idCountry` INT,
  `nameCountry` VARCHAR(64),
  PRIMARY KEY (`idCountry`)
) CHARACTER SET latin1;

CREATE TABLE `cpCity` (
  `idCity` INT,
  `nameCity` VARCHAR(64),
  `fkCountry` INT,
  PRIMARY KEY (`idCity`)
) CHARACTER SET latin1;

CREATE TABLE `cpSport` (
  `idSport` INT,
  `nameSport` VARCHAR(64),
  PRIMARY KEY (`idSport`)
) CHARACTER SET latin1;

CREATE TABLE `cpCourtType` (
  `idCourtType` INT,
  `courtType` VARCHAR(64),
  `isIndoor` BOOL,
  PRIMARY KEY (`idCourtType`)
) CHARACTER SET latin1;

CREATE TABLE `cpClub` (
  `idClub` INT,
  `nameClub` VARCHAR(64),
  `addressClub` VARCHAR(64),
  `fkCity` INT,
  PRIMARY KEY (`idClub`)
) CHARACTER SET latin1;

CREATE TABLE `cpPlayground` (
  `idPg` INT,
  `fkClub` INT,
  `fkSport` INT,
  `fkCourtType` INT,
  `nameCourt` VARCHAR(64),
  `isDoubleOk` BOOL,
  PRIMARY KEY (`idPg`)
) CHARACTER SET latin1;

CREATE TABLE `cpGame` (
  `idGame` INT,
  `fkPlayground` INT,
  `fkUserCreator` INT,
  `isSingle` BOOL,
  `isPrivate` BOOL,
  `duration` INT,
  `startDate` DATETIME,
  `startTime` DATETIME,
  `description` VARCHAR(64),
  PRIMARY KEY (`idGame`)
) CHARACTER SET latin1;

CREATE TABLE `cpJoin` (
  `fkUserJoin` INT,
  `fkGameJoin` INT,
  PRIMARY KEY (`fkUserJoin`, `fkGameJoin`)
) CHARACTER SET latin1;

CREATE TABLE `cpIsMember` (
  `fkUserIsM` INT,
  `fkClubIsM` INT,
  `isAdmin` BOOL,
  `endSubsctiption` DATETIME,
  PRIMARY KEY (`fkUserIsM`, `fkClubIsM`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115551_01_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115551_01_CreateTables') AS relationships;
DROP DATABASE `db_115551_01_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
