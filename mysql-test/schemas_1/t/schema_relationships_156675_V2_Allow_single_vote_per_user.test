INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 156675_V2__Allow_single_vote_per_user
--echo #
CREATE DATABASE `db_156675_V2_Allow_single_vote_per_user`;
USE `db_156675_V2_Allow_single_vote_per_user`;

CREATE TABLE `poll_option` (
  `poll_id` VARCHAR(64),
  `option_order` INT,
  `option_content` VARCHAR(64),
  PRIMARY KEY (`poll_id`, `option_order`)
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `poll_id` VARCHAR(64),
  `poll_option` INT,
  `user_id` VARCHAR(64),
  PRIMARY KEY (`poll_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_156675_V2_Allow_single_vote_per_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_156675_V2_Allow_single_vote_per_user') AS relationships;
DROP DATABASE `db_156675_V2_Allow_single_vote_per_user`;
UNINSTALL EXTENSION vsql_schematron;
