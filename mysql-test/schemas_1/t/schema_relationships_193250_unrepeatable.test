INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193250_unrepeatable
--echo #
CREATE DATABASE `db_193250_unrepeatable`;
USE `db_193250_unrepeatable`;

CREATE TABLE `m1397_unrepeatable.keys` (
  `id` INT,
  `secret` VARCHAR(64),
  `name` VARCHAR(64),
  `created` INT,
  `disabled` INT,
  `distance` DECIMAL(10,2),
  `seed_latitude` DECIMAL(10,2),
  `seed_longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m1397_unrepeatable.providers` (
  `id` INT,
  `identifier` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m1397_unrepeatable.users` (
  `id` INT,
  `fd_id` INT,
  `profile_picture` VARCHAR(64),
  `name` VARCHAR(64),
  `anonymous` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m1397_unrepeatable.posts` (
  `id` INT,
  `key_id` INT,
  `created_by` INT,
  `created` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `location_name` VARCHAR(64),
  `provider_id` INT,
  `provider_source` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`, `key_id`, `provider_id`, `created_by`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193250_unrepeatable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193250_unrepeatable') AS relationships;
DROP DATABASE `db_193250_unrepeatable`;
UNINSTALL EXTENSION vsql_schematron;
