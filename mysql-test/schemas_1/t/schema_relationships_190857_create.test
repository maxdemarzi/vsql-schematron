INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 190857_create
--echo #
CREATE DATABASE `db_190857_create`;
USE `db_190857_create`;

CREATE TABLE `dex_list` (
  `id` INT,
  `dex` INT,
  `name` VARCHAR(64),
  `shiny` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pkmn` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dex_entries` (
  `dex_NAT` INT,
  `dex_RBY` INT,
  `dex_FRLG` INT,
  `dex_LGPE` INT,
  `dex_GSC` INT,
  `dex_HGSS` INT,
  `dex_RSE` INT,
  `dex_ORAS` INT,
  `dex_DP` INT,
  `dex_PT` INT,
  `dex_BW` INT,
  `dex_B2W2` INT,
  `dex_XY_CENTRAL` INT,
  `dex_XY_COASTAL` INT,
  `dex_XY_MOUNTAIN` INT,
  `dex_SM` INT,
  `dex_SM_MELEMELE` INT,
  `dex_SM_AKALA` INT,
  `dex_SM_ULAULA` INT,
  `dex_SM_PONI` INT,
  `dex_USUM` INT,
  `dex_USUM_MELEMELE` INT,
  `dex_USUM_AKALA` INT,
  `dex_USUM_ULAULA` INT,
  `dex_USUM_PONI` INT,
  `dex_SWSH` INT,
  `dex_IOA` INT,
  `dex_CT` INT
) CHARACTER SET latin1;

CREATE TABLE `forms` (
  `id` INT,
  `form_id` INT,
  `form_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `id` INT,
  `slot_1` INT,
  `slot_2` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_190857_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_190857_create') AS relationships;
DROP DATABASE `db_190857_create`;
UNINSTALL EXTENSION vsql_schematron;
