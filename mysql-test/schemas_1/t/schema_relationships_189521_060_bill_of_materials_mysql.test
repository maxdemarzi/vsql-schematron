INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 189521_060_bill_of_materials_mysql
--echo #
CREATE DATABASE `db_189521_060_bill_of_materials_mysql`;
USE `db_189521_060_bill_of_materials_mysql`;

CREATE TABLE `bom_steps` (
  `bom_step_id` INT,
  `bom_step_name` VARCHAR(255),
  `description` VARCHAR(255),
  `rev_enabled` VARCHAR(255),
  `rev_number` INT,
  `created_by` INT,
  `creation_date` DATETIME,
  `last_update_by` INT,
  `last_update_date` DATETIME,
  PRIMARY KEY (`bom_step_id`)
) CHARACTER SET latin1;

CREATE TABLE `bom_header` (
  `bom_id` INT,
  `resulting_product_id` INT,
  `resulting_quantity` DECIMAL(10,2),
  `description` VARCHAR(255),
  `rev_enabled` VARCHAR(255),
  `rev_number` INT,
  `created_by` INT,
  `creation_date` DATETIME,
  `last_update_by` INT,
  `last_update_date` DATETIME,
  PRIMARY KEY (`bom_id`)
) CHARACTER SET latin1;

CREATE TABLE `bom_detail` (
  `bom_detail_id` INT,
  `bom_id` INT,
  `step_number` INT,
  `step_type` VARCHAR(255),
  `component_product_id` INT,
  `component_quantity_used` DECIMAL(10,2),
  `bom_step_id` INT,
  `seconds_to_process` DECIMAL(10,2),
  `sub_bom_id` INT,
  `description` VARCHAR(255),
  `rev_enabled` VARCHAR(255),
  `rev_number` INT,
  `created_by` INT,
  `creation_date` DATETIME,
  `last_update_by` INT,
  `last_update_date` DATETIME,
  PRIMARY KEY (`bom_detail_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_189521_060_bill_of_materials_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_189521_060_bill_of_materials_mysql') AS relationships;
DROP DATABASE `db_189521_060_bill_of_materials_mysql`;
UNINSTALL EXTENSION vsql_schematron;
