INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113005_schema
--echo #
CREATE DATABASE `db_113005_schema`;
USE `db_113005_schema`;

CREATE TABLE `Role` (
  `id` INT,
  `code` VARCHAR(64),
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Account` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` VARCHAR(64),
  `credentialsexpired` VARCHAR(64),
  `expired` VARCHAR(64),
  `locked` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Profile` (
  `id` INT,
  `account_id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `picture_link` VARCHAR(64),
  `date_of_registration` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_role` (
  `account_id` INT,
  `role_id` INT,
  PRIMARY KEY (`account_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `Category` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Service` (
  `id` INT,
  `name` VARCHAR(64),
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Rating` (
  `id` INT,
  `comment` VARCHAR(64),
  `customer_name` VARCHAR(64),
  `time_of_rating` DATETIME,
  `rating` INT,
  `deal_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113005_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113005_schema') AS relationships;
DROP DATABASE `db_113005_schema`;
UNINSTALL EXTENSION vsql_schematron;
