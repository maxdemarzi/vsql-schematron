INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158492_data
--echo #
CREATE DATABASE `db_158492_data`;
USE `db_158492_data`;
CREATE TABLE `account` (
  `account_id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `contents` (
  `contents_id` BIGINT NOT NULL,
  `create_at` DATETIME,
  `description` VARCHAR(50),
  `full_address` VARCHAR(50),
  `lat` DOUBLE,
  `lng` DOUBLE,
  `picture` VARCHAR(50),
  `tag` VARCHAR(50),
  `title` VARCHAR(50),
  `update_at` DATETIME,
  `account_id` BIGINT,
  PRIMARY KEY (`contents_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158492_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158492_data') AS relationships;
DROP DATABASE `db_158492_data`;
UNINSTALL EXTENSION vsql_schematron;
