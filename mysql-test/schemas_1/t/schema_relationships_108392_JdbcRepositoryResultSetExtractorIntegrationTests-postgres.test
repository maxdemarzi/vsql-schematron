INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108392_JdbcRepositoryResultSetExtractorIntegrationTests-postgres
--echo #
CREATE DATABASE `db_108392_JdbcRepositoryResultSetExtractorIntegrationTests_postg`;
USE `db_108392_JdbcRepositoryResultSetExtractorIntegrationTests_postg`;
CREATE TABLE `person` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `street` VARCHAR(50),
  `person_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108392_JdbcRepositoryResultSetExtractorIntegrationTests_postg') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108392_JdbcRepositoryResultSetExtractorIntegrationTests_postg') AS relationships;
DROP DATABASE `db_108392_JdbcRepositoryResultSetExtractorIntegrationTests_postg`;
UNINSTALL EXTENSION vsql_schematron;
