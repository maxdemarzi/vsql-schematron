INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 136582_V1__Create_Tables
--echo #
CREATE DATABASE `db_136582_V1_Create_Tables`;
USE `db_136582_V1_Create_Tables`;

CREATE TABLE `transaction_method` (
  `uuid` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_type` (
  `uuid` VARCHAR(64),
  `description` VARCHAR(64),
  `color` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_category` (
  `uuid` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `uuid` VARCHAR(64),
  `tx_date` DATETIME,
  `description` VARCHAR(64),
  `transaction_type_uuid` VARCHAR(64),
  `check_number` VARCHAR(64),
  `transaction_method_uuid` VARCHAR(64),
  `transaction_category_uuid` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `reconciled_date` DATETIME,
  `notes` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_136582_V1_Create_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_136582_V1_Create_Tables') AS relationships;
DROP DATABASE `db_136582_V1_Create_Tables`;
UNINSTALL EXTENSION vsql_schematron;
