INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107629_migration
--echo #
CREATE DATABASE `db_107629_migration`;
USE `db_107629_migration`;

CREATE TABLE `account` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `mobile` VARCHAR(64),
  `nickName` VARCHAR(64),
  `avatarUrl` VARCHAR(64),
  `gender` INT,
  `province` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `language` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_local_auth` (
  `aid` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`aid`)
) CHARACTER SET latin1;

CREATE TABLE `account_auth_log` (
  `id` VARCHAR(64),
  `aid` VARCHAR(64),
  `authType` VARCHAR(64),
  `ip` VARCHAR(64),
  `version` VARCHAR(64),
  `platform` VARCHAR(64),
  `screen` VARCHAR(64),
  `osFamily` VARCHAR(64),
  `osArchitecture` VARCHAR(64),
  `osVersion` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107629_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107629_migration') AS relationships;
DROP DATABASE `db_107629_migration`;
UNINSTALL EXTENSION vsql_schematron;
