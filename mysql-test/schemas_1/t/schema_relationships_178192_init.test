INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178192_init
--echo #
CREATE DATABASE `db_178192_init`;
USE `db_178192_init`;
CREATE TABLE `trans_metadata` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `amount` DECIMAL(10,2),
  `date` TIMESTAMP NULL,
  `mode_of_payment` VARCHAR(50),
  `essential` SMALLINT,
  `category_id` VARCHAR(50),
  `transaction_type_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `transaction_type_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction_type` (
  `id` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178192_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178192_init') AS relationships;
DROP DATABASE `db_178192_init`;
UNINSTALL EXTENSION vsql_schematron;
