INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107179_schema-001
--echo #
CREATE DATABASE `db_107179_schema_001`;
USE `db_107179_schema_001`;

CREATE TABLE `EXPERIMENTS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTAINERS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `SPOTS_WIDTH` INT,
  `SPOTS_HEIGHT` INT,
  `EXPE_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `SPOTS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `X` INT,
  `Y` INT,
  `CONT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATA_SETS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `IMAGES_DIRECTORY` VARCHAR(64),
  `FIELDS_WIDTH` INT,
  `FIELDS_HEIGHT` INT,
  `CONT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHANNELS` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `WAVELENGTH` INT,
  `DS_ID` VARCHAR(64),
  `EXP_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHANNEL_STACKS` (
  `ID` INT,
  `X` INT,
  `Y` INT,
  `Z_in_M` DECIMAL(10,2),
  `T_in_SEC` DECIMAL(10,2),
  `DS_ID` VARCHAR(64),
  `SPOT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `IMAGES` (
  `ID` INT,
  `PATH` VARCHAR(64),
  `PAGE` INT,
  `COLOR` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ACQUIRED_IMAGES` (
  `ID` INT,
  `IMG_ID` VARCHAR(64),
  `THUMBNAIL_ID` VARCHAR(64),
  `CHANNEL_STACK_ID` VARCHAR(64),
  `CHANNEL_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107179_schema_001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107179_schema_001') AS relationships;
DROP DATABASE `db_107179_schema_001`;
UNINSTALL EXTENSION vsql_schematron;
