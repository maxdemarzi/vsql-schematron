INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193583_SIMProx
--echo #
CREATE DATABASE `db_193583_SIMProx`;
USE `db_193583_SIMProx`;
CREATE TABLE `AuditLog` (
  `ID` INT NOT NULL,
  `TableName` VARCHAR(50),
  `PrimaryKeyColumn` VARCHAR(50),
  `PrimaryKeyValue` TEXT,
  `ColumnName` VARCHAR(50),
  `OriginalValue` TEXT,
  `NewValue` TEXT,
  `Deleted` TINYINT,
  `UpdatedBy` VARCHAR(50),
  `UpdatedOn` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ConfigurationEntity` (
  `SourceName` VARCHAR(50),
  `RuntimeName` VARCHAR(50),
  `Description` TEXT,
  `LoadOrder` INT,
  `Enabled` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `DataOperation` (
  `NodeID` VARCHAR(50),
  `Description` TEXT,
  `AssemblyName` TEXT,
  `TypeName` TEXT,
  `MethodName` VARCHAR(50),
  `Arguments` TEXT,
  `LoadOrder` INT,
  `Enabled` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `ImportedMeasurement` (
  `NodeID` VARCHAR(50),
  `SourceNodeID` VARCHAR(50),
  `SignalID` VARCHAR(50),
  `Source` VARCHAR(50),
  `PointID` BIGINT,
  `PointTag` VARCHAR(50),
  `AlternateTag` VARCHAR(50),
  `SignalTypeAcronym` VARCHAR(50),
  `SignalReference` TEXT,
  `FramesPerSecond` INT,
  `ProtocolAcronym` VARCHAR(50),
  `ProtocolType` VARCHAR(50),
  `PhasorID` INT,
  `PhasorType` VARCHAR(50),
  `Phase` VARCHAR(50),
  `Adder` DOUBLE,
  `Multiplier` DOUBLE,
  `CompanyAcronym` VARCHAR(50),
  `Longitude` DECIMAL(10,2),
  `Latitude` DECIMAL(10,2),
  `Description` TEXT,
  `Enabled` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `ApplicationRoleSecurityGroup` (
  `ApplicationRoleID` VARCHAR(50),
  `SecurityGroupID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ApplicationRoleUserAccount` (
  `ApplicationRoleID` VARCHAR(50),
  `UserAccountID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SecurityGroupUserAccount` (
  `SecurityGroupID` VARCHAR(50),
  `UserAccountID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `AlarmState` (
  `ID` INT NOT NULL,
  `State` VARCHAR(50),
  `Color` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AlarmDevice` (
  `ID` INT NOT NULL,
  `DeviceID` INT,
  `StateID` INT,
  `TimeStamp` DATETIME,
  `DisplayData` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193583_SIMProx') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193583_SIMProx') AS relationships;
DROP DATABASE `db_193583_SIMProx`;
UNINSTALL EXTENSION vsql_schematron;
