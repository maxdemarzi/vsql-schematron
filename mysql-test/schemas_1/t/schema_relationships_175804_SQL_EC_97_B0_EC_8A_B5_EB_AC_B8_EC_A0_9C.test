INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175804_SQL%EC%97%B0%EC%8A%B5%EB%AC%B8%EC%A0%9C
--echo #
CREATE DATABASE `db_175804_SQL_EC_97_B0_EC_8A_B5_EB_AC_B8_EC_A0_9C`;
USE `db_175804_SQL_EC_97_B0_EC_8A_B5_EB_AC_B8_EC_A0_9C`;
CREATE TABLE `employee` (
  `empNo` VARCHAR(50) NOT NULL,
  `empName` VARCHAR(50),
  `empPhone` VARCHAR(50),
  `empAddress` VARCHAR(50),
  `empBirth` DATE,
  `empGender` VARCHAR(50),
  PRIMARY KEY (`empNo`)
) CHARACTER SET latin1;
CREATE TABLE `class` (
  `classNo` VARCHAR(50) NOT NULL,
  `className` VARCHAR(50),
  PRIMARY KEY (`classNo`)
) CHARACTER SET latin1;
CREATE TABLE `room` (
  `roomNo` VARCHAR(50) NOT NULL,
  `roomName` VARCHAR(50),
  `roomType` VARCHAR(50),
  `roomPrice` DECIMAL(10,2),
  `classNo` VARCHAR(50),
  PRIMARY KEY (`roomNo`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
  `bNo` VARCHAR(50) NOT NULL,
  `bDate` DATE,
  `bInDate` DATE,
  `bStayDays` DECIMAL(10,2),
  `empNo` VARCHAR(50),
  `roomNo` VARCHAR(50),
  PRIMARY KEY (`bNo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175804_SQL_EC_97_B0_EC_8A_B5_EB_AC_B8_EC_A0_9C') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175804_SQL_EC_97_B0_EC_8A_B5_EB_AC_B8_EC_A0_9C') AS relationships;
DROP DATABASE `db_175804_SQL_EC_97_B0_EC_8A_B5_EB_AC_B8_EC_A0_9C`;
UNINSTALL EXTENSION vsql_schematron;
