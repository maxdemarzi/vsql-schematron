INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 118641_V10__Graphenee
--echo #
CREATE DATABASE `db_118641_V10__Graphenee`;
USE `db_118641_V10__Graphenee`;
CREATE TABLE `gx_access_key` (
  `oid` INT NOT NULL,
  `access_key` CHAR(50),
  `secret` VARCHAR(50),
  `is_active` BOOLEAN,
  `access_key_type` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_user_account_access_key_join` (
  `oid_user_account` INT,
  `oid_access_key` INT
) CHARACTER SET latin1;
CREATE TABLE `gx_access_key_security_group_join` (
  `oid_access_key` INT,
  `oid_security_group` INT
) CHARACTER SET latin1;
CREATE TABLE `gx_access_key_security_policy_join` (
  `oid_access_key` INT,
  `oid_security_policy` INT
) CHARACTER SET latin1;
CREATE TABLE `gx_resource` (
  `oid` INT NOT NULL,
  `resource_name` VARCHAR(50),
  `resource_desription` VARCHAR(50),
  `is_active` BOOLEAN,
  `oid_namespace` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_access_log` (
  `oid` INT NOT NULL,
  `oid_access_key` INT,
  `oid_resource` INT,
  `access_time` TIMESTAMP NULL,
  `is_success` BOOLEAN,
  `access_type` INT,
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_118641_V10__Graphenee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_118641_V10__Graphenee') AS relationships;
DROP DATABASE `db_118641_V10__Graphenee`;
UNINSTALL EXTENSION vsql_schematron;
