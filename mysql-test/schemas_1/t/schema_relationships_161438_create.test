INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161438_create
--echo #
CREATE DATABASE `db_161438_create`;
USE `db_161438_create`;

CREATE TABLE `file` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  `uploader` VARCHAR(64),
  `isprivate` INT,
  `uploaddate` DATETIME,
  `download` INT,
  `type` VARCHAR(64),
  `size` INT,
  `expiredate` DATETIME,
  `valid` INT
) CHARACTER SET latin1;

CREATE TABLE `guest` (
  `id` INT,
  `joinDate` DATETIME,
  `currentUse` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `request` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `setting` (
  `maxFileUpload` INT,
  PRIMARY KEY (`maxFileUpload`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `status` INT,
  `isadmin` INT,
  `canconfirm` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161438_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161438_create') AS relationships;
DROP DATABASE `db_161438_create`;
UNINSTALL EXTENSION vsql_schematron;
