CREATE DATABASE `db_186741_V20180213141919__edcr_core_ddl`;
USE `db_186741_V20180213141919__edcr_core_ddl`;
CREATE TABLE `EDCR_RULE` (
  `id` BIGINT NOT NULL,
  `name` CHAR(50),
  `clause` CHAR(50),
  `active` BOOLEAN,
  `version` DECIMAL(10,2),
  `createdBy` BIGINT,
  `createdDate` TIMESTAMP NULL,
  `lastModifiedBy` BIGINT,
  `lastModifiedDate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `EDCR_SUBRULE` (
  `id` BIGINT NOT NULL,
  `name` CHAR(50),
  `rule` BIGINT,
  `clause` CHAR(50),
  `active` BOOLEAN,
  `orderby` BIGINT,
  `version` DECIMAL(10,2),
  `createdBy` BIGINT,
  `createdDate` TIMESTAMP NULL,
  `lastModifiedBy` BIGINT,
  `lastModifiedDate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `EDCR_PLANRULE` (
  `id` BIGINT NOT NULL,
  `service` CHAR(50),
  `plotArea` BIGINT,
  `occupancy` CHAR(50),
  `nooffloors` BIGINT,
  `heightofbuilding` BIGINT,
  `active` BOOLEAN,
  `rule` BIGINT,
  `version` DECIMAL(10,2),
  `createdBy` BIGINT,
  `createdDate` TIMESTAMP NULL,
  `lastModifiedBy` BIGINT,
  `lastModifiedDate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186741_V20180213141919__edcr_core_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186741_V20180213141919__edcr_core_ddl') AS relationships;
DROP DATABASE `db_186741_V20180213141919__edcr_core_ddl`;
