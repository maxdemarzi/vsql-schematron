INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107577_poss
--echo #
CREATE DATABASE `db_107577_poss`;
USE `db_107577_poss`;

CREATE TABLE `customers` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `avatar` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `comment` VARCHAR(64),
  `company_name` VARCHAR(64),
  `account` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `discount` (
  `id` INT,
  `sale_id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost` DECIMAL(10,2),
  `total_selling` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `expense` (
  `id` INT,
  `title` VARCHAR(64),
  `price` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `inventories` (
  `id` INT,
  `item_id` INT,
  `user_id` INT,
  `in_out_qty` INT,
  `remarks` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `upc_ean_isbn` VARCHAR(64),
  `item_name` VARCHAR(64),
  `size` VARCHAR(64),
  `description` VARCHAR(64),
  `avatar` VARCHAR(64),
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `type` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_kit_items` (
  `id` INT,
  `item_kit_id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost_price` DECIMAL(10,2),
  `total_selling_price` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `item_kit_item_temps` (
  `id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost_price` DECIMAL(10,2),
  `total_selling_price` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `migration` VARCHAR(64),
  `batch` INT
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `receivings` (
  `id` INT,
  `supplier_id` INT,
  `user_id` INT,
  `payment_type` VARCHAR(64),
  `comments` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `paidAmount` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `receiving_items` (
  `id` INT,
  `receiving_id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `supplier_id` INT
) CHARACTER SET latin1;

CREATE TABLE `receiving_temps` (
  `id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `role` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `customer_id` INT,
  `user_id` INT,
  `payment_type` VARCHAR(64),
  `comments` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `discount` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `sale_items` (
  `id` INT,
  `sale_id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost` DECIMAL(10,2),
  `total_selling` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sale_temps` (
  `id` INT,
  `item_id` INT,
  `cost_price` DECIMAL(10,2),
  `selling_price` DECIMAL(10,2),
  `quantity` INT,
  `total_cost` DECIMAL(10,2),
  `total_selling` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `suppliers` (
  `id` INT,
  `company_name` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `avatar` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `comments` VARCHAR(64),
  `account` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tutapos_settings` (
  `id` INT,
  `languange` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `type` INT
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `id` INT,
  `user_id` INT,
  `role_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107577_poss') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107577_poss') AS relationships;
DROP DATABASE `db_107577_poss`;
UNINSTALL EXTENSION vsql_schematron;
