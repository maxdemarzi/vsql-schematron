INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193040_learntogether_SQL
--echo #
CREATE DATABASE `db_193040_learntogether_SQL`;
USE `db_193040_learntogether_SQL`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `passwrd` VARCHAR(50),
  `avatar` TEXT,
  `fullname` TEXT,
  `email` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `level_id` INT,
  `user_quote` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `levels` (
  `level_id` INT NOT NULL,
  `level_name` VARCHAR(50),
  PRIMARY KEY (`level_id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `tag_id` INT NOT NULL,
  `tag_name` VARCHAR(50),
  `tag_slug` VARCHAR(50),
  PRIMARY KEY (`tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments_news` (
  `comment_id` INT NOT NULL,
  `content` VARCHAR(50),
  `user_id` INT,
  `date` DATE,
  `like` INT,
  `dislike` INT,
  `news_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments_posts` (
  `comment_id` INT NOT NULL,
  `content` VARCHAR(50),
  `user_id` INT,
  `date` DATE,
  `scores` INT,
  `post_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments_courses` (
  `comment_id` INT NOT NULL,
  `content` VARCHAR(50),
  `user_id` INT,
  `date` DATE,
  `like` INT,
  `dislike` INT,
  `course_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `news_id` INT NOT NULL,
  `rating` INT,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `content` VARCHAR(50),
  `image` VARCHAR(50),
  `view_number` INT,
  `date` DATE,
  `tag_id` INT,
  `user_id` INT,
  PRIMARY KEY (`news_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `post_id` INT NOT NULL,
  `scores` INT,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `content` VARCHAR(50),
  `image` VARCHAR(50),
  `view_number` INT,
  `date` DATE,
  `tag_id` INT,
  `user_id` INT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
  `course_id` INT NOT NULL,
  `title` VARCHAR(50),
  `slug` VARCHAR(50),
  `content` VARCHAR(50),
  `image` VARCHAR(50),
  `view_number` INT,
  `date` DATE,
  `tag_id` INT,
  `user_id` INT,
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193040_learntogether_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193040_learntogether_SQL') AS relationships;
DROP DATABASE `db_193040_learntogether_SQL`;
UNINSTALL EXTENSION vsql_schematron;
