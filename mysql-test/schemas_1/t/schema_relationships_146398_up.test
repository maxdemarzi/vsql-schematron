INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 146398_up
--echo #
CREATE DATABASE `db_146398_up`;
USE `db_146398_up`;

CREATE TABLE `notifications` (
  `id` VARCHAR(255),
  `payload_title` VARCHAR(255),
  `payload_body` VARCHAR(255),
  `created` DATETIME,
  `recipients` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notification_properties` (
  `id` INT,
  `notification_id` VARCHAR(255),
  `property` VARCHAR(255),
  `property_value` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_notifications` (
  `notification_id` VARCHAR(255),
  `user_id` VARCHAR(255),
  `unread` VARCHAR(255),
  PRIMARY KEY (`notification_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_146398_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_146398_up') AS relationships;
DROP DATABASE `db_146398_up`;
UNINSTALL EXTENSION vsql_schematron;
