INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163314_cubrid
--echo #
CREATE DATABASE `db_163314_cubrid`;
USE `db_163314_cubrid`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profiles` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `create_time` DATETIME,
  `author_id` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `content` VARCHAR(64),
  `post_id` INT,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post_category` (
  `category_id` INT,
  `post_id` INT,
  PRIMARY KEY (`category_id`, `post_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `key1` INT,
  `key2` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`key1`, `key2`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `name` VARCHAR(64),
  `col1` INT,
  `col2` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `int_col` INT,
  `int_col2` INT,
  `char_col` VARCHAR(64),
  `char_col2` VARCHAR(64),
  `char_col3` VARCHAR(64),
  `float_col` DECIMAL(10,2),
  `float_col2` DECIMAL(10,2),
  `blob_col` VARCHAR(64),
  `numeric_col` DECIMAL(10,2),
  `time` DATETIME,
  `bool_col` VARCHAR(64),
  `bool_col2` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163314_cubrid') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163314_cubrid') AS relationships;
DROP DATABASE `db_163314_cubrid`;
UNINSTALL EXTENSION vsql_schematron;
