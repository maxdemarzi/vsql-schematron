INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 174537_Autobuses
--echo #
CREATE DATABASE `db_174537_Autobuses`;
USE `db_174537_Autobuses`;

CREATE TABLE `terminal` (
  `id` INT,
  `ubicacion` VARCHAR(64),
  `ciudad` VARCHAR(64),
  `autobuses_disponibles` INT,
  `cordinador` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `autobuses` (
  `id` INT,
  `tipo` VARCHAR(64),
  `capacidad_personas` INT,
  `operador` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `boletos` (
  `id` INT,
  `costo` INT,
  `terminal` INT,
  `destino` VARCHAR(64),
  `fecha_salida` VARCHAR(64),
  `fecha_compra` DATETIME,
  `tipo_viaje` VARCHAR(64),
  `autobus` INT,
  `estado` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `operadores` (
  `id` INT,
  `nombre` VARCHAR(64),
  `apellido_pater` VARCHAR(64),
  `apellido_mater` VARCHAR(64),
  `telefono` VARCHAR(64),
  `autobus` INT,
  `terminal` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_174537_Autobuses') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_174537_Autobuses') AS relationships;
DROP DATABASE `db_174537_Autobuses`;
UNINSTALL EXTENSION vsql_schematron;
