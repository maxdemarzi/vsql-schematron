INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175662_V_47__create_usr
--echo #
CREATE DATABASE `db_175662_V_47_create_usr`;
USE `db_175662_V_47_create_usr`;

CREATE TABLE `usr_schema_version` (
  `version_key` VARCHAR(64),
  `version_value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `usr_oguser` (
  `id` INT,
  `oid` INT,
  `ver_from_instant` DATETIME,
  `ver_to_instant` DATETIME,
  `corr_from_instant` DATETIME,
  `corr_to_instant` DATETIME,
  `userid` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `time_zone` VARCHAR(64),
  `email_address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usr_idkey` (
  `id` INT,
  `key_scheme` VARCHAR(64),
  `key_value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usr_oguser2idkey` (
  `oguser_id` INT,
  `idkey_id` INT,
  PRIMARY KEY (`oguser_id`, `idkey_id`)
) CHARACTER SET latin1;

CREATE TABLE `usr_entitlement` (
  `oguser_id` INT,
  `entitlement_index` INT,
  `entitlement_pattern` VARCHAR(64),
  PRIMARY KEY (`oguser_id`, `entitlement_index`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175662_V_47_create_usr') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175662_V_47_create_usr') AS relationships;
DROP DATABASE `db_175662_V_47_create_usr`;
UNINSTALL EXTENSION vsql_schematron;
