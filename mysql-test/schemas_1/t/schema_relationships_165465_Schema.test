INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165465_Schema
--echo #
CREATE DATABASE `db_165465_Schema`;
USE `db_165465_Schema`;

CREATE TABLE `conf_reports` (
  `id` VARCHAR(64),
  `cluster_id` VARCHAR(64),
  `report` VARCHAR(64),
  `namespace` VARCHAR(64),
  `resource_name` VARCHAR(64),
  `resource_kind` VARCHAR(64),
  `warning_count` INT,
  `danger_count` INT,
  `pass_count` INT,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `poll_cluster_jobs` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `status` VARCHAR(64),
  `last_error` VARCHAR(64),
  `attempts_count` INT,
  `locked_at` DATETIME,
  `locked_by` VARCHAR(64),
  `cluster_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cluster_connections` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  `sa_token` VARCHAR(64),
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165465_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165465_Schema') AS relationships;
DROP DATABASE `db_165465_Schema`;
UNINSTALL EXTENSION vsql_schematron;
