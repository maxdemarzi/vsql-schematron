  `uri` VARCHAR(64),
  `val1` INT,
  `val2` INT,
  `val3` INT,
  PRIMARY KEY (`uri`)
) CHARACTER SET latin1;

CREATE TABLE `TABLE2` (
  `URI2` VARCHAR(64),
  `VAL` INT,
  PRIMARY KEY (`URI2`)
) CHARACTER SET latin1;

CREATE TABLE `TABLE3` (
  `URI3` VARCHAR(64),
  `VAL` INT,
  PRIMARY KEY (`URI3`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_118403_tmapping_positions_create_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_118403_tmapping_positions_create_h2') AS relationships;
DROP DATABASE `db_118403_tmapping_positions_create_h2`;
