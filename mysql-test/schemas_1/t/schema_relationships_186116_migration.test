INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186116_migration
--echo #
CREATE DATABASE `db_186116_migration`;
USE `db_186116_migration`;

CREATE TABLE `Workspace` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `orbitId` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Member` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `orbitId` INT,
  `deletedAt` DATETIME,
  `activitiesCount` INT,
  `avatarUrl` VARCHAR(64),
  `bio` VARCHAR(64),
  `birthday` VARCHAR(64),
  `company` VARCHAR(64),
  `firstActivityOccurredAt` DATETIME,
  `lastActivityOccurredAt` DATETIME,
  `mergedAt` DATETIME,
  `location` VARCHAR(64),
  `name` VARCHAR(64),
  `orbitLevel` INT,
  `pronouns` VARCHAR(64),
  `reach` INT,
  `shippingAddress` VARCHAR(64),
  `slug` VARCHAR(64),
  `source` VARCHAR(64),
  `tagList` VARCHAR(64),
  `tags` VARCHAR(64),
  `teammate` BOOL,
  `tshirt` VARCHAR(64),
  `url` VARCHAR(64),
  `orbitUrl` VARCHAR(64),
  `created` BOOL,
  `love` DECIMAL(10,2),
  `twitter` VARCHAR(64),
  `github` VARCHAR(64),
  `discourse` VARCHAR(64),
  `email` VARCHAR(64),
  `devto` VARCHAR(64),
  `linkedin` VARCHAR(64),
  `githubFollowers` INT,
  `twitterFollowers` INT,
  `topics` VARCHAR(64),
  `languages` VARCHAR(64),
  `identitiesCount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Identity` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `identityType` INT,
  `memberId` VARCHAR(64),
  `orbitId` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `name` VARCHAR(64),
  `source` VARCHAR(64),
  `sourceHost` VARCHAR(64),
  `uid` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ActivityType` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `orbitId` INT,
  `name` VARCHAR(64),
  `shortName` VARCHAR(64),
  `key` VARCHAR(64),
  `category` VARCHAR(64),
  `deletedAt` DATETIME,
  `weight` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Activity` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `orbitId` INT,
  `activityTypeId` VARCHAR(64),
  `memberId` VARCHAR(64),
  `action` VARCHAR(64),
  `key` VARCHAR(64),
  `occurredAt` DATETIME,
  `type` VARCHAR(64),
  `orbitUrl` VARCHAR(64),
  `weight` DECIMAL(10,2),
  `gNumber` INT,
  `gHtmlUrl` VARCHAR(64),
  `gCreatedAt` DATETIME,
  `gId` INT,
  `repositoryId` VARCHAR(64),
  `gStarredAt` DATETIME,
  `gTitle` VARCHAR(64),
  `gMerged` BOOL,
  `gMergedAt` DATETIME,
  `gMergedBy` VARCHAR(64),
  `gBody` VARCHAR(64),
  `isPullRequest` BOOL,
  `tags` VARCHAR(64),
  `activityLink` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Repository` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orbitSyncAt` DATETIME,
  `orbitUpdatedAt` DATETIME,
  `orbitId` INT,
  `name` VARCHAR(64),
  `owner` VARCHAR(64),
  `fullName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_MemberToWorkspace` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_RepositoryToWorkspace` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186116_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186116_migration') AS relationships;
DROP DATABASE `db_186116_migration`;
UNINSTALL EXTENSION vsql_schematron;
