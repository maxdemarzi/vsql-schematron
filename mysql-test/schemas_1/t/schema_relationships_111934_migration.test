INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 111934_migration
--echo #
CREATE DATABASE `db_111934_migration`;
USE `db_111934_migration`;

CREATE TABLE `rooms` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `participants` (
  `roomId` INT,
  `userId` INT,
  PRIMARY KEY (`roomId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `chats` (
  `id` INT,
  `content` VARCHAR(64),
  `senderId` INT,
  `roomId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_111934_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_111934_migration') AS relationships;
DROP DATABASE `db_111934_migration`;
UNINSTALL EXTENSION vsql_schematron;
