INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152038_1_init
--echo #
CREATE DATABASE `db_152038_1_init`;
USE `db_152038_1_init`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `full_name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `verify` BOOL,
  `create_at` DATETIME,
  `update_at` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `link` VARCHAR(64),
  `name` VARCHAR(64),
  `tag` VARCHAR(64),
  PRIMARY KEY (`link`)
) CHARACTER SET latin1;

CREATE TABLE `bookmarks` (
  `bookmark_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `post_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`bookmark_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152038_1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152038_1_init') AS relationships;
DROP DATABASE `db_152038_1_init`;
UNINSTALL EXTENSION vsql_schematron;
