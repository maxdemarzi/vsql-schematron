INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 197276_ddl.mysql
--echo #
CREATE DATABASE `db_197276_ddl_mysql`;
USE `db_197276_ddl_mysql`;
CREATE TABLE `Usuarios` (
  `Id` INT NOT NULL,
  `Email` VARCHAR(50),
  `Senha` VARCHAR(50),
  `CPF` VARCHAR(50),
  `DataCadastro` DATETIME,
  `Logado` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Professores` (
  `Id` INT NOT NULL,
  `IdUsuario` INT,
  `Instituicao` VARCHAR(50),
  `Url` VARCHAR(50),
  `AreaAtuacao` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Alunos` (
  `Id` INT NOT NULL,
  `IdUsuario` INT,
  `NumeroRegistro` VARCHAR(50),
  `NivelEscolaridade` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Aulas` (
  `Id` INT NOT NULL,
  `IdProfessor` INT,
  `Codigo` VARCHAR(50),
  `Data` DATETIME,
  `Descricao` VARCHAR(50),
  `Aovivo` INT,
  `Transcript` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `AlunosAulas` (
  `Id` INT NOT NULL,
  `IdAluno` INT,
  `IdAula` INT,
  `Ativo` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Arquivos` (
  `Id` INT NOT NULL,
  `IdUsuario` INT,
  `IdAula` INT,
  `Descricao` VARCHAR(50),
  `DataCadastro` DATETIME,
  `Ativo` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_197276_ddl_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_197276_ddl_mysql') AS relationships;
DROP DATABASE `db_197276_ddl_mysql`;
UNINSTALL EXTENSION vsql_schematron;
