INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 194337_createUserTable
--echo #
CREATE DATABASE `db_194337_createUserTable`;
USE `db_194337_createUserTable`;
CREATE TABLE `bib_users` (
  `userid` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `userid` INT,
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_194337_createUserTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_194337_createUserTable') AS relationships;
DROP DATABASE `db_194337_createUserTable`;
UNINSTALL EXTENSION vsql_schematron;
