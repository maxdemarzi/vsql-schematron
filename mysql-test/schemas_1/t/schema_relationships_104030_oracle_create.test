INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 104030_oracle_create
--echo #
CREATE DATABASE `db_104030_oracle_create`;
USE `db_104030_oracle_create`;

CREATE TABLE `cpa` (
  `cpa_id` VARCHAR(255),
  `cpa` VARCHAR(255),
  PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;

CREATE TABLE `url` (
  `source` VARCHAR(255),
  `destination` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ebms_message` (
  `time_stamp` DATETIME,
  `cpa_id` VARCHAR(255),
  `conversation_id` VARCHAR(255),
  `message_id` VARCHAR(255),
  `message_nr` DECIMAL(10,2),
  `ref_to_message_id` VARCHAR(255),
  `time_to_live` DATETIME,
  `persist_time` DATETIME,
  `from_party_id` VARCHAR(255),
  `from_role` VARCHAR(255),
  `to_party_id` VARCHAR(255),
  `to_role` VARCHAR(255),
  `service` VARCHAR(255),
  `action` VARCHAR(255),
  `content` VARCHAR(255),
  `status` DECIMAL(10,2),
  `status_time` DATETIME,
  PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;

CREATE TABLE `ebms_attachment` (
  `message_id` VARCHAR(255),
  `message_nr` DECIMAL(10,2),
  `order_nr` DECIMAL(10,2),
  `name` VARCHAR(255),
  `content_id` VARCHAR(255),
  `content_type` VARCHAR(255),
  `content` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ebms_event` (
  `cpa_id` VARCHAR(255),
  `client_alias` VARCHAR(255),
  `channel_id` VARCHAR(255),
  `message_id` VARCHAR(255),
  `time_to_live` DATETIME,
  `time_stamp` DATETIME,
  `is_confidential` DECIMAL(10,2),
  `retries` DECIMAL(10,2),
  `server_id` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ebms_event_log` (
  `message_id` VARCHAR(255),
  `time_stamp` DATETIME,
  `uri` VARCHAR(255),
  `status` DECIMAL(10,2),
  `error_message` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ebms_message_event` (
  `message_id` VARCHAR(255),
  `event_type` DECIMAL(10,2),
  `time_stamp` DATETIME,
  `processed` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_104030_oracle_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_104030_oracle_create') AS relationships;
DROP DATABASE `db_104030_oracle_create`;
UNINSTALL EXTENSION vsql_schematron;
