INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139105_create_table
--echo #
CREATE DATABASE `db_139105_create_table`;
USE `db_139105_create_table`;

CREATE TABLE `Pages` (
  `page_id` VARCHAR(64),
  `page_name` VARCHAR(64),
  PRIMARY KEY (`page_id`)
) CHARACTER SET latin1;

CREATE TABLE `Page_contain_images` (
  `combination_id` VARCHAR(64),
  `page_id` INT,
  `image_id` INT,
  PRIMARY KEY (`combination_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139105_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139105_create_table') AS relationships;
DROP DATABASE `db_139105_create_table`;
UNINSTALL EXTENSION vsql_schematron;
