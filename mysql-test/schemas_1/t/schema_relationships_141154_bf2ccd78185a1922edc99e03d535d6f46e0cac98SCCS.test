INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS
--echo #
CREATE DATABASE `db_141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS`;
USE `db_141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS`;

CREATE TABLE `student` (
  `id` INT,
  `name` VARCHAR(64),
  `age` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_product` (
  `productId` INT,
  `name` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`productId`)
) CHARACTER SET latin1;

CREATE TABLE `tb_user` (
  `userId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `tb_order` (
  `orderId` INT,
  `orderTotalPrice` DECIMAL(10,2),
  `userId` INT,
  PRIMARY KEY (`orderId`)
) CHARACTER SET latin1;

CREATE TABLE `tb_orderitem` (
  `orderItemId` INT,
  `productId` INT,
  `amount` INT,
  `orderItemPrice` DECIMAL(10,2),
  `orderId` INT,
  PRIMARY KEY (`orderItemId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS') AS relationships;
DROP DATABASE `db_141154_bf2ccd78185a1922edc99e03d535d6f46e0cac98SCCS`;
UNINSTALL EXTENSION vsql_schematron;
