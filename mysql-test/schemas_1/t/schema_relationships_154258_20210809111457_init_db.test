INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 154258_20210809111457_init_db
--echo #
CREATE DATABASE `db_154258_20210809111457_init_db`;
USE `db_154258_20210809111457_init_db`;

CREATE TABLE `api_service` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `api_service_key` (
  `id` VARCHAR(255),
  `service_id` VARCHAR(255),
  `key` VARCHAR(255),
  `secret` VARCHAR(255),
  `whitelist` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `address` (
  `id` VARCHAR(255),
  `service_id` VARCHAR(255),
  `workchain_id` INT,
  `hex` VARCHAR(255),
  `base64url` VARCHAR(255),
  `public_key` VARCHAR(255),
  `private_key` VARCHAR(255),
  `account_type` VARCHAR(255),
  `custodians` INT,
  `confirmations` INT,
  `custodians_public_keys` VARCHAR(255),
  `balance` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `api_service_callback` (
  `id` VARCHAR(255),
  `service_id` VARCHAR(255),
  `callback` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_154258_20210809111457_init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_154258_20210809111457_init_db') AS relationships;
DROP DATABASE `db_154258_20210809111457_init_db`;
UNINSTALL EXTENSION vsql_schematron;
