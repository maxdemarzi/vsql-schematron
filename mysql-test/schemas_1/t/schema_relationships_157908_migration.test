INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 157908_migration
--echo #
CREATE DATABASE `db_157908_migration`;
USE `db_157908_migration`;
CREATE TABLE `Indicador` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `published` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `avatar` TEXT,
  `telefono` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario_indicador` (
  `id` INT NOT NULL,
  `indicadorId` INT,
  `usuarioId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_157908_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_157908_migration') AS relationships;
DROP DATABASE `db_157908_migration`;
UNINSTALL EXTENSION vsql_schematron;
