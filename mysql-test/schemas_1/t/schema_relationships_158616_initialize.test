INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158616_initialize
--echo #
CREATE DATABASE `db_158616_initialize`;
USE `db_158616_initialize`;

CREATE TABLE `common__user` (
  `id` VARCHAR(64),
  `type` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `registered` DATETIME,
  `last_activity` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `common__slug` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `common__comment_thread` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `common__comment` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `thread_id` VARCHAR(64),
  `created_on` DATETIME,
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `common__user_file_thread` (
  `id` INT,
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `common__user_file` (
  `id` INT,
  `filename` VARCHAR(64),
  `size` INT,
  `thread_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158616_initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158616_initialize') AS relationships;
DROP DATABASE `db_158616_initialize`;
UNINSTALL EXTENSION vsql_schematron;
