INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 112143_schema
--echo #
CREATE DATABASE `db_112143_schema`;
USE `db_112143_schema`;

CREATE TABLE `Food` (
  `ID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `ID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `ID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `User_device` (
  `ID` INT,
  `name` VARCHAR(64),
  `belongs_to` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Food_item` (
  `ID` INT,
  `eat_by` DATETIME,
  `of_type` INT,
  `stored_in` INT,
  `registers` INT,
  `buys` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Ticket` (
  `ID` INT,
  `ticket` VARCHAR(64),
  `belongs_device` INT,
  `created_on` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Updates` (
  `ID` INT,
  `table_name` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EAN_number` (
  `ID` INT,
  `number` VARCHAR(64),
  `identifies` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_112143_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_112143_schema') AS relationships;
DROP DATABASE `db_112143_schema`;
UNINSTALL EXTENSION vsql_schematron;
