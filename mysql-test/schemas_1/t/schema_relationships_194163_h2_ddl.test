INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 194163_h2_ddl
--echo #
CREATE DATABASE `db_194163_h2_ddl`;
USE `db_194163_h2_ddl`;

CREATE TABLE `apicurio` (
  `prop_name` VARCHAR(64),
  `prop_value` VARCHAR(64),
  PRIMARY KEY (`prop_name`)
) CHARACTER SET latin1;

CREATE TABLE `globalrules` (
  `tenantId` VARCHAR(64),
  `type` VARCHAR(64),
  `configuration` VARCHAR(64),
  PRIMARY KEY (`tenantId`, `type`)
) CHARACTER SET latin1;

CREATE TABLE `artifacts` (
  `tenantId` VARCHAR(64),
  `groupId` VARCHAR(64),
  `artifactId` VARCHAR(64),
  `type` VARCHAR(64),
  `createdBy` VARCHAR(64),
  `createdOn` DATETIME,
  `latest` INT,
  PRIMARY KEY (`tenantId`, `groupId`, `artifactId`)
) CHARACTER SET latin1;

CREATE TABLE `rules` (
  `tenantId` VARCHAR(64),
  `groupId` VARCHAR(64),
  `artifactId` VARCHAR(64),
  `type` VARCHAR(64),
  `configuration` VARCHAR(64),
  PRIMARY KEY (`tenantId`, `groupId`, `artifactId`, `type`)
) CHARACTER SET latin1;

CREATE TABLE `content` (
  `contentId` INT,
  `canonicalHash` VARCHAR(64),
  `contentHash` VARCHAR(64),
  `content` VARCHAR(64),
  PRIMARY KEY (`contentId`)
) CHARACTER SET latin1;

CREATE TABLE `versions` (
  `globalId` INT,
  `tenantId` VARCHAR(64),
  `groupId` VARCHAR(64),
  `artifactId` VARCHAR(64),
  `version` VARCHAR(64),
  `versionId` INT,
  `state` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `createdBy` VARCHAR(64),
  `createdOn` DATETIME,
  `labels` VARCHAR(64),
  `properties` VARCHAR(64),
  `contentId` INT,
  PRIMARY KEY (`globalId`)
) CHARACTER SET latin1;

CREATE TABLE `properties` (
  `globalId` INT,
  `pkey` VARCHAR(64),
  `pvalue` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `labels` (
  `globalId` INT,
  `label` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `logconfiguration` (
  `logger` VARCHAR(64),
  `loglevel` VARCHAR(64),
  PRIMARY KEY (`logger`)
) CHARACTER SET latin1;

CREATE TABLE `groups` (
  `tenantId` VARCHAR(64),
  `groupId` VARCHAR(64),
  `description` VARCHAR(64),
  `format` VARCHAR(64),
  `createdBy` VARCHAR(64),
  `createdOn` DATETIME,
  `modifiedBy` VARCHAR(64),
  `modifiedOn` DATETIME,
  `properties` VARCHAR(64),
  PRIMARY KEY (`tenantId`, `groupId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_194163_h2_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_194163_h2_ddl') AS relationships;
DROP DATABASE `db_194163_h2_ddl`;
UNINSTALL EXTENSION vsql_schematron;
