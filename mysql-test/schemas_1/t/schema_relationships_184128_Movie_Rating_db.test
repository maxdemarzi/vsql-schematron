INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184128_Movie_Rating.db
--echo #
CREATE DATABASE `db_184128_Movie_Rating_db`;
USE `db_184128_Movie_Rating_db`;
CREATE TABLE `Reviewer` (
  `rID` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`rID`)
) CHARACTER SET latin1;
CREATE TABLE `Movie` (
  `mID` INT NOT NULL,
  `title` TEXT,
  `year` TEXT,
  `director` TEXT,
  PRIMARY KEY (`mID`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
  `rID` INT,
  `mID` INT,
  `stars` INT,
  `ratingDate` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184128_Movie_Rating_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184128_Movie_Rating_db') AS relationships;
DROP DATABASE `db_184128_Movie_Rating_db`;
UNINSTALL EXTENSION vsql_schematron;
