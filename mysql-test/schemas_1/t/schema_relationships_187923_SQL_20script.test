INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187923_SQL%20script
--echo #
CREATE DATABASE `db_187923_SQL_20script`;
USE `db_187923_SQL_20script`;

CREATE TABLE `leilao` (
  `leilaoid` INT,
  `titulo` VARCHAR(64),
  `descricao` VARCHAR(64),
  `precominimo` DECIMAL(10,2),
  `limite` DATETIME,
  `fechado` BOOL,
  `vencedorid` INT,
  `users_userid` INT,
  `artigo_artigoid` INT,
  PRIMARY KEY (`leilaoid`)
) CHARACTER SET latin1;

CREATE TABLE `artigo` (
  `artigoid` INT,
  `nome_artigo` VARCHAR(64),
  `descricao` VARCHAR(64),
  `leiloado` BOOL,
  PRIMARY KEY (`artigoid`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `userid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `authtoken` VARCHAR(64),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

CREATE TABLE `mural` (
  `mensagem` VARCHAR(64),
  `leilao_leilaoid` INT,
  `users_userid` INT
) CHARACTER SET latin1;

CREATE TABLE `licitacao` (
  `licitacaoid` INT,
  `valor_licitado` DECIMAL(10,2),
  `users_userid` INT,
  `leilao_leilaoid` INT,
  PRIMARY KEY (`licitacaoid`)
) CHARACTER SET latin1;

CREATE TABLE `historico_versoes` (
  `versaoid` INT,
  `titulo` VARCHAR(64),
  `descricao` VARCHAR(64),
  `precominimo` DECIMAL(10,2),
  `limite` DATETIME,
  `leilao_leilaoid` INT,
  PRIMARY KEY (`versaoid`)
) CHARACTER SET latin1;

CREATE TABLE `inbox` (
  `mensagem` VARCHAR(64),
  `users_userid` INT,
  `leilao_leilaoid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187923_SQL_20script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187923_SQL_20script') AS relationships;
DROP DATABASE `db_187923_SQL_20script`;
UNINSTALL EXTENSION vsql_schematron;
