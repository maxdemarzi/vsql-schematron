CREATE TABLE `a` (
  `id` INT,
  `text` VARCHAR(64),
  `fkid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `b` (
  `id` INT,
  `text` VARCHAR(64),
  `fkid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185564_bug_bts_3696') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185564_bug_bts_3696') AS relationships;
DROP DATABASE `db_185564_bug_bts_3696`;
