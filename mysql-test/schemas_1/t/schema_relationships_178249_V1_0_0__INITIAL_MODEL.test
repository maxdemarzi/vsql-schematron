INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178249_V1.0.0__INITIAL_MODEL
--echo #
CREATE DATABASE `db_178249_V1_0_0__INITIAL_MODEL`;
USE `db_178249_V1_0_0__INITIAL_MODEL`;
CREATE TABLE `ORDERS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `ORDER_ID` VARCHAR(50),
  `CUSTOMER_ID` VARCHAR(50),
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `STATUS` VARCHAR(50),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEMS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `ORDER_ID` DECIMAL(10,2),
  `ITEM_ID` VARCHAR(50),
  `PRODUCT_ID` VARCHAR(50),
  `RESERVATION_ID` VARCHAR(50),
  `QUANTITY` DECIMAL(10,2),
  `STATUS` VARCHAR(50),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_178249_V1_0_0__INITIAL_MODEL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_178249_V1_0_0__INITIAL_MODEL') AS relationships;
DROP DATABASE `db_178249_V1_0_0__INITIAL_MODEL`;
UNINSTALL EXTENSION vsql_schematron;
