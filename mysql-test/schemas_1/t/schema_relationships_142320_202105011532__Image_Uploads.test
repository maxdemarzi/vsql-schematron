INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142320_202105011532__Image_Uploads
--echo #
CREATE DATABASE `db_142320_202105011532__Image_Uploads`;
USE `db_142320_202105011532__Image_Uploads`;
CREATE TABLE `image_upload` (
  `id` VARCHAR(50) NOT NULL,
  `file_name` VARCHAR(50),
  `hash` CHAR(50),
  `width` VARCHAR(50),
  `height` VARCHAR(50),
  `created_at` VARCHAR(50),
  `modified_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_has_image_upload` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `recipe` VARCHAR(50),
  `image_upload` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142320_202105011532__Image_Uploads') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142320_202105011532__Image_Uploads') AS relationships;
DROP DATABASE `db_142320_202105011532__Image_Uploads`;
UNINSTALL EXTENSION vsql_schematron;
