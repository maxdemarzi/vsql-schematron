INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 185395_script
--echo #
CREATE DATABASE `db_185395_script`;
USE `db_185395_script`;

CREATE TABLE `typeUser` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `cpf` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `typeUserID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book` (
  `id` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `publisher` VARCHAR(64),
  `cover` VARCHAR(64),
  `reservation` INT,
  `loan` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reservation` (
  `id` INT,
  `userID` INT,
  `booID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `loan` (
  `id` INT,
  `userID` INT,
  `booID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185395_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185395_script') AS relationships;
DROP DATABASE `db_185395_script`;
UNINSTALL EXTENSION vsql_schematron;
