INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163925_schema
--echo #
CREATE DATABASE `db_163925_schema`;
USE `db_163925_schema`;
CREATE TABLE `consumidor` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone` TEXT,
  `senha` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `id` INT NOT NULL,
  `consumidor_id` INT,
  `restaurante_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `detalhepedido` (
  `id` INT NOT NULL,
  `pedido_id` INT,
  `produto_id` INT,
  `quantidade_produto` INT,
  `valor_total_produto` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `id` INT NOT NULL,
  `consumidor_id` INT,
  `endereco` TEXT,
  `cep` TEXT,
  `complemento` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163925_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163925_schema') AS relationships;
DROP DATABASE `db_163925_schema`;
UNINSTALL EXTENSION vsql_schematron;
