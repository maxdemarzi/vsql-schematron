INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 140945_sql-eshop
--echo #
CREATE DATABASE `db_140945_sql_eshop`;
USE `db_140945_sql_eshop`;

CREATE TABLE `ProdCategory` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Product` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Prod2Cat` (
  `id` INT,
  `prod_id` INT,
  `cat_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `InvenShelf` (
  `shelf` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`shelf`)
) CHARACTER SET latin1;

CREATE TABLE `Inventory` (
  `id` INT,
  `prod_id` INT,
  `shelf_id` VARCHAR(64),
  `items` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `id` INT,
  `customer` INT,
  `created` DATETIME,
  `updated` DATETIME,
  `deleted` DATETIME,
  `delivery` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `OrderRow` (
  `id` INT,
  `order` INT,
  `product` INT,
  `items` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Invoice` (
  `id` INT,
  `order` INT,
  `customer` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `InvoiceRow` (
  `id` INT,
  `invoice` INT,
  `product` INT,
  `items` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_140945_sql_eshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_140945_sql_eshop') AS relationships;
DROP DATABASE `db_140945_sql_eshop`;
UNINSTALL EXTENSION vsql_schematron;
