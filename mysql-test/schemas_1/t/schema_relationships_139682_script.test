INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139682_script
--echo #
CREATE DATABASE `db_139682_script`;
USE `db_139682_script`;
CREATE TABLE `Route` (
  `id` INT NOT NULL,
  `name` TEXT,
  `origin` TEXT,
  `destination` TEXT,
  `description` TEXT,
  `imagename` TEXT,
  `directions` TEXT,
  `estimateddistance` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Log` (
  `id` INT NOT NULL,
  `startdate` TIMESTAMP NULL,
  `enddate` TIMESTAMP NULL,
  `origin` TEXT,
  `destination` TEXT,
  `distance` DOUBLE,
  `rating` DOUBLE,
  `note` TEXT,
  `movementmode` INT,
  `mood` INT,
  `bpm` INT,
  `route_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139682_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139682_script') AS relationships;
DROP DATABASE `db_139682_script`;
UNINSTALL EXTENSION vsql_schematron;
