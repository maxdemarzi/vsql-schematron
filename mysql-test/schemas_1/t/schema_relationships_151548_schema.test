INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151548_schema
--echo #
CREATE DATABASE `db_151548_schema`;
USE `db_151548_schema`;

CREATE TABLE `Users` (
  `HID` INT,
  `UserName` VARCHAR(64),
  `Password` VARCHAR(64),
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  PRIMARY KEY (`HID`)
) CHARACTER SET latin1;

CREATE TABLE `Events` (
  `EID` INT,
  `HostID` INT,
  `EventName` VARCHAR(64),
  `EventPassword` VARCHAR(64),
  `StartTime` DATETIME,
  `FinishTime` DATETIME,
  `EstimatedAttendeeNumber` INT,
  PRIMARY KEY (`EID`)
) CHARACTER SET latin1;

CREATE TABLE `Feedback` (
  `FID` INT,
  `EventID` INT,
  `AttendeeName` VARCHAR(64),
  `Feedback` VARCHAR(64),
  `Mood` INT,
  `Answer` VARCHAR(64),
  `Additionals` VARCHAR(64),
  PRIMARY KEY (`FID`)
) CHARACTER SET latin1;

CREATE TABLE `Template` (
  `TID` INT,
  `EventID` INT,
  `Question` VARCHAR(64),
  PRIMARY KEY (`TID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151548_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151548_schema') AS relationships;
DROP DATABASE `db_151548_schema`;
UNINSTALL EXTENSION vsql_schematron;
