INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 168907_20210318172317_initialmigration
--echo #
CREATE DATABASE `db_168907_20210318172317_initialmigration`;
USE `db_168907_20210318172317_initialmigration`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `target` VARCHAR(50),
  `code` VARCHAR(50),
  `author` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clicks` (
  `id` INT NOT NULL,
  `link` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_168907_20210318172317_initialmigration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_168907_20210318172317_initialmigration') AS relationships;
DROP DATABASE `db_168907_20210318172317_initialmigration`;
UNINSTALL EXTENSION vsql_schematron;
