INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172422_University
--echo #
CREATE DATABASE `db_172422_University`;
USE `db_172422_University`;

CREATE TABLE `majors` (
  `major_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`major_id`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `student_id` INT,
  `student_number` VARCHAR(64),
  `student_name` VARCHAR(64),
  `major_id` INT,
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `payment_id` INT,
  `payment_date` DATETIME,
  `payment_ammount` DECIMAL(10,2),
  `student_id` INT,
  PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `subject_id` INT,
  `subject_name` VARCHAR(64),
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;

CREATE TABLE `agenda` (
  `subject_id` INT,
  `student_id` INT,
  PRIMARY KEY (`subject_id`, `student_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172422_University') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172422_University') AS relationships;
DROP DATABASE `db_172422_University`;
UNINSTALL EXTENSION vsql_schematron;
