INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108979_redpoint_db
--echo #
CREATE DATABASE `db_108979_redpoint_db`;
USE `db_108979_redpoint_db`;
CREATE TABLE `certifications` (
  `id` VARCHAR(50) NOT NULL,
  `libelle` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contact_urgences` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `email` VARCHAR(50),
  `telephone` VARCHAR(50),
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `civilite` TINYINT,
  `adresse` VARCHAR(50),
  `ville_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
  `email` VARCHAR(50),
  `token` VARCHAR(50),
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `ip_address` VARCHAR(50),
  `user_agent` TEXT,
  `payload` TEXT,
  `last_activity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_alimentaires` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `allergie_alimentaire_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_certifications` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `certification_id` VARCHAR(50),
  `justificatif` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_medicaments` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `allergie_medicament_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_substances` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `substance_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108979_redpoint_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108979_redpoint_db') AS relationships;
DROP DATABASE `db_108979_redpoint_db`;
UNINSTALL EXTENSION vsql_schematron;
