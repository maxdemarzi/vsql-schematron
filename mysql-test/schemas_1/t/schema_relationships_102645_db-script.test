INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 102645_db-script
--echo #
CREATE DATABASE `db_102645_db_script`;
USE `db_102645_db_script`;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rewards` (
  `id` INT NOT NULL,
  `createdDate` DATE,
  `amount` DECIMAL(10,2),
  `description` VARCHAR(50),
  `payeeName` VARCHAR(50),
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_102645_db_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_102645_db_script') AS relationships;
DROP DATABASE `db_102645_db_script`;
UNINSTALL EXTENSION vsql_schematron;
