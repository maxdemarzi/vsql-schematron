INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105470_7
--echo #
CREATE DATABASE `db_105470_7`;
USE `db_105470_7`;

CREATE TABLE `play_theater_seat` (
  `play_id` VARCHAR(64),
  `c` VARCHAR(64),
  `x` INT,
  `y` INT,
  `w` INT,
  `h` INT,
  `t` VARCHAR(64),
  PRIMARY KEY (`play_id`, `c`)
) CHARACTER SET latin1;

CREATE TABLE `reservation` (
  `id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `city` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reservation_seat` (
  `reservation_id` VARCHAR(64),
  `play_id` VARCHAR(64),
  `play_c` VARCHAR(64),
  PRIMARY KEY (`reservation_id`, `play_id`, `play_c`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105470_7') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105470_7') AS relationships;
DROP DATABASE `db_105470_7`;
UNINSTALL EXTENSION vsql_schematron;
