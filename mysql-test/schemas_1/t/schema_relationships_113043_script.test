INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113043_script
--echo #
CREATE DATABASE `db_113043_script`;
USE `db_113043_script`;

CREATE TABLE `tasks` (
  `taskID` INT,
  `userID` INT,
  `TimeDate` DATETIME,
  `taskType` VARCHAR(255),
  PRIMARY KEY (`taskID`)
) CHARACTER SET latin1;

CREATE TABLE `discussions` (
  `discussionID` INT,
  `userID` INT,
  `fileID` INT,
  `taskID` INT,
  `logID` INT,
  `commentID` INT,
  `discussionName` VARCHAR(255),
  `discussionPermission` VARCHAR(255),
  PRIMARY KEY (`discussionID`)
) CHARACTER SET latin1;

CREATE TABLE `discussionmessages` (
  `messageID` INT,
  `userID` INT,
  `timeDate` DATETIME,
  `discussionID` INT,
  `messageType` VARCHAR(255),
  PRIMARY KEY (`messageID`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `fileID` INT,
  `userID` INT,
  `dateTime` DATETIME,
  `discussionID` INT,
  `fileType` VARCHAR(255),
  PRIMARY KEY (`fileID`)
) CHARACTER SET latin1;

CREATE TABLE `privatemessages` (
  `PMID` INT,
  `userID` INT,
  `description` VARCHAR(255),
  `fileID` INT,
  `dateTime` DATETIME,
  PRIMARY KEY (`PMID`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `commentID` INT,
  `userID` INT,
  `fileID` INT,
  `discussionID` INT,
  `description` VARCHAR(255),
  PRIMARY KEY (`commentID`)
) CHARACTER SET latin1;

CREATE TABLE `logs` (
  `logID` INT,
  `userID` INT,
  `logType` VARCHAR(255),
  `dateTime` DATETIME,
  `discussionID` INT,
  `description` VARCHAR(255),
  PRIMARY KEY (`logID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113043_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113043_script') AS relationships;
DROP DATABASE `db_113043_script`;
UNINSTALL EXTENSION vsql_schematron;
