INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195029_up
--echo #
CREATE DATABASE `db_195029_up`;
USE `db_195029_up`;

CREATE TABLE `nodes` (
  `id` INT,
  `public_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sensors` (
  `id` INT,
  `public_id` INT,
  `node_id` INT,
  `type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195029_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195029_up') AS relationships;
DROP DATABASE `db_195029_up`;
UNINSTALL EXTENSION vsql_schematron;
