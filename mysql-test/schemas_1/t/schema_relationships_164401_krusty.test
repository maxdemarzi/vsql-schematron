INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 164401_krusty
--echo #
CREATE DATABASE `db_164401_krusty`;
USE `db_164401_krusty`;

CREATE TABLE `units` (
  `unit` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`unit`)
) CHARACTER SET latin1;

CREATE TABLE `ingredients` (
  `id` INT,
  `ingredient` VARCHAR(64),
  `quantity` INT,
  `last_delivered_quantity` INT,
  `last_delivered_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `product` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipes` (
  `productId` INT,
  `ingredientId` INT,
  `quantity` INT,
  `unit` INT
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `customer` INT,
  `delivery_date` DATETIME,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_164401_krusty') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_164401_krusty') AS relationships;
DROP DATABASE `db_164401_krusty`;
UNINSTALL EXTENSION vsql_schematron;
