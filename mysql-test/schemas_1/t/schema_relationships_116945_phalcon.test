INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116945_phalcon
--echo #
CREATE DATABASE `db_116945_phalcon`;
USE `db_116945_phalcon`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `user_id` INT,
  `quantity` INT,
  `address` VARCHAR(50),
  `shippingDate` TIMESTAMP NULL,
  `orderCode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116945_phalcon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116945_phalcon') AS relationships;
DROP DATABASE `db_116945_phalcon`;
UNINSTALL EXTENSION vsql_schematron;
