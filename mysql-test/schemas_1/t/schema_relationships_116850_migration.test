INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116850_migration
--echo #
CREATE DATABASE `db_116850_migration`;
USE `db_116850_migration`;

CREATE TABLE `productoDeVenta` (
  `id` INT,
  `idVenta` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categoria` (
  `id` INT,
  `nombre` VARCHAR(64),
  `idOpcionCategoria` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `opcionCategoria` (
  `id` INT,
  `nombreOpcion` VARCHAR(64),
  `idOpcionValores` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `opcionValores` (
  `id` INT,
  `valor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `venta` (
  `id` INT,
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `domicilio` VARCHAR(64),
  `total` DECIMAL(10,2),
  `descuento` DECIMAL(10,2),
  `totalPagado` DECIMAL(10,2),
  `createdAt` DATETIME,
  `fechaTerminaPagar` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_opcionValoresToproducto` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116850_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116850_migration') AS relationships;
DROP DATABASE `db_116850_migration`;
UNINSTALL EXTENSION vsql_schematron;
