INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158254_schema
--echo #
CREATE DATABASE `db_158254_schema`;
USE `db_158254_schema`;
CREATE TABLE `bounce` (
  `event_id` VARCHAR(50) NOT NULL,
  `reason` TEXT,
  `type` VARCHAR(50),
  `status` VARCHAR(50),
  `smtp_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `click` (
  `event_id` VARCHAR(50) NOT NULL,
  `url` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `deferred` (
  `event_id` VARCHAR(50) NOT NULL,
  `reason` TEXT,
  `attempt_num` VARCHAR(50),
  `smtp_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `delivered` (
  `event_id` VARCHAR(50) NOT NULL,
  `response` TEXT,
  `smtp_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `dropped` (
  `event_id` VARCHAR(50) NOT NULL,
  `reason` VARCHAR(50),
  `smtp_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `open` (
  `event_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `processed` (
  `event_id` VARCHAR(50) NOT NULL,
  `smtp_id` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `spamreport` (
  `event_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `unsubscribe` (
  `event_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `instance` (
  `id` VARCHAR(50) NOT NULL,
  `install_class` VARCHAR(50),
  `servername` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` VARCHAR(50) NOT NULL,
  `instance_id` VARCHAR(50),
  `mailing_id` VARCHAR(50),
  `category` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `archive` (
  `event_id` VARCHAR(50) NOT NULL,
  `message_id` VARCHAR(50),
  `job_id` VARCHAR(50),
  `queue_id` VARCHAR(50),
  `event_type` VARCHAR(50),
  `result` VARCHAR(50),
  `email` VARCHAR(50),
  `is_test` BOOLEAN,
  `dt_created` DATETIME,
  `dt_received` DATETIME,
  `dt_processed` DATETIME,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158254_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158254_schema') AS relationships;
DROP DATABASE `db_158254_schema`;
UNINSTALL EXTENSION vsql_schematron;
