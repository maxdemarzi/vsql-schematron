INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139440_mFramework_db
--echo #
CREATE DATABASE `db_139440_mFramework_db`;
USE `db_139440_mFramework_db`;

CREATE TABLE `admin` (
  `uid` INT,
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `pwd` VARCHAR(64),
  `identity` INT,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `articleId` INT,
  `uid` INT,
  `time` DATETIME,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `personal` INT,
  `otherInfo` VARCHAR(64),
  PRIMARY KEY (`articleId`)
) CHARACTER SET latin1;

CREATE TABLE `private` (
  `code` VARCHAR(64),
  `state` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `uid` INT,
  `user` VARCHAR(64),
  `name` VARCHAR(64),
  `headPortrait` VARCHAR(64),
  `pwd` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `userMore` (
  `uid` INT,
  `signature` VARCHAR(64),
  `setting` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139440_mFramework_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139440_mFramework_db') AS relationships;
DROP DATABASE `db_139440_mFramework_db`;
UNINSTALL EXTENSION vsql_schematron;
