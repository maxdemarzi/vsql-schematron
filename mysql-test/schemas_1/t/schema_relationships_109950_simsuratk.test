INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 109950_simsuratk
--echo #
CREATE DATABASE `db_109950_simsuratk`;
USE `db_109950_simsuratk`;

CREATE TABLE `data` (
  `no_regist` VARCHAR(64),
  `kode_layanan` VARCHAR(64),
  `id_field` INT,
  `data` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `dokumen` (
  `no_regist` VARCHAR(64),
  `kode_layanan` VARCHAR(64),
  `id_syarat` INT,
  `nama_file` VARCHAR(64),
  `verifikasi` INT
) CHARACTER SET latin1;

CREATE TABLE `dosen_tendik` (
  `id_user` VARCHAR(64),
  `pangkat` VARCHAR(64),
  `golongan` VARCHAR(64),
  `jabatan` VARCHAR(64),
  `sub_bagian` VARCHAR(64),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `example` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `status_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `form_field` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `browse` INT,
  `read` INT,
  `edit` INT,
  `add` INT,
  `relation_table` VARCHAR(64),
  `relation_column` VARCHAR(64),
  `form_id` INT,
  `column_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `klasifikasi` (
  `kode_klasifikasi` VARCHAR(64),
  `klasifikasi` VARCHAR(64),
  PRIMARY KEY (`kode_klasifikasi`)
) CHARACTER SET latin1;

CREATE TABLE `layanan` (
  `kode_layanan` VARCHAR(64),
  `kode_sub` VARCHAR(64),
  `nama_layanan` VARCHAR(64),
  `template_file` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `menulist` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `name` VARCHAR(64),
  `href` VARCHAR(64),
  `icon` VARCHAR(64),
  `slug` VARCHAR(64),
  `parent_id` INT,
  `menu_id` INT,
  `sequence` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_role` (
  `id` INT,
  `role_name` VARCHAR(64),
  `menus_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_has_permissions` (
  `permission_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `model_has_roles` (
  `role_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `note_type` VARCHAR(64),
  `applies_to_date` DATETIME,
  `users_id` INT,
  `status_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `penandatangan` (
  `kode_layanan` VARCHAR(64),
  `id_user` VARCHAR(64),
  `status` INT,
  `urutan` INT
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_has_permissions` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `role_hierarchy` (
  `id` INT,
  `role_id` INT,
  `hierarchy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `status` (
  `id_status` INT,
  `name` VARCHAR(64),
  `class` VARCHAR(64),
  PRIMARY KEY (`id_status`)
) CHARACTER SET latin1;

CREATE TABLE `sub_klasifikasi` (
  `kode_sub` VARCHAR(64),
  `kode_klasifikasi` VARCHAR(64),
  `sub_klasifikasi` VARCHAR(64),
  `penomoran` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `surat_keluar` (
  `no_regist` VARCHAR(64),
  `kode_layanan` VARCHAR(64),
  `id_user` VARCHAR(64),
  `tgl_permohonan` DATETIME,
  `tujuan` VARCHAR(64),
  `tgl_surat` DATETIME,
  `no_surat` VARCHAR(64),
  `nama_file` VARCHAR(64),
  `keterangan` VARCHAR(64),
  `verifikasi` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `syarat` (
  `id_syarat` INT,
  `nama_syarat` VARCHAR(64),
  `tipe_file` INT,
  PRIMARY KEY (`id_syarat`)
) CHARACTER SET latin1;

CREATE TABLE `syarat_layanan` (
  `kode_layanan` VARCHAR(64),
  `id_syarat` INT
) CHARACTER SET latin1;

CREATE TABLE `template_field` (
  `id_field` INT,
  `kode_layanan` VARCHAR(64),
  `nama_field` VARCHAR(64),
  `tipe_field` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id_user` VARCHAR(64),
  `nama` VARCHAR(64),
  `tempat_lahir` VARCHAR(64),
  `tgl_lahir` DATETIME,
  `jekel` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `alamat` VARCHAR(64),
  `hp` VARCHAR(64),
  `agama` VARCHAR(64),
  `foto` VARCHAR(64),
  `sertifikat_digital` VARCHAR(64),
  `tanda_tangan` VARCHAR(64),
  `paraf` VARCHAR(64),
  `jenis_user` INT,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `menuroles` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_109950_simsuratk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_109950_simsuratk') AS relationships;
DROP DATABASE `db_109950_simsuratk`;
UNINSTALL EXTENSION vsql_schematron;
