while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145269_V76_6_0_add_competition_template_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145269_V76_6_0_add_competition_template_tables') AS relationships;
DROP DATABASE `db_145269_V76_6_0_add_competition_template_tables`;
