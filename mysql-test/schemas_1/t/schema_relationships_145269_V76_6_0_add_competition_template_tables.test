INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145269_V76_6_0__add_competition_template_tables
--echo #
CREATE DATABASE `db_145269_V76_6_0_add_competition_template_tables`;
USE `db_145269_V76_6_0_add_competition_template_tables`;

CREATE TABLE `form_input_template` (
  `id` INT,
  `form_input_type_id` INT,
  `guidance_question` VARCHAR(64),
  `guidance_answer` VARCHAR(64),
  `description` VARCHAR(64),
  `included_in_application_summary` INT,
  `priority` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `form_input_template_form_validator` (
  `form_input_template_id` INT,
  `form_validator_id` INT,
  PRIMARY KEY (`form_input_template_id`, `form_validator_id`)
) CHARACTER SET latin1;

CREATE TABLE `competition_template` (
  `id` INT,
  `competition_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `section_template` (
  `id` INT,
  `section_type` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `assessor_guidance_description` VARCHAR(64),
  `parent_section_template_id` INT,
  `competition_template_id` INT,
  `priority` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `question_template` (
  `id` INT,
  `section_template_id` INT,
  `name` VARCHAR(64),
  `short_name` VARCHAR(64),
  `question_number` VARCHAR(64),
  `description` VARCHAR(64),
  `assessor_guidance_question` VARCHAR(64),
  `assessor_guidance_answer` VARCHAR(64),
  `priority` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `question_template_form_input_template` (
  `question_template_id` INT,
  `form_input_template_id` INT,
  PRIMARY KEY (`question_template_id`, `form_input_template_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
