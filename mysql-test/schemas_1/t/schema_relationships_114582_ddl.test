INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 114582_ddl
--echo #
CREATE DATABASE `db_114582_ddl`;
USE `db_114582_ddl`;
CREATE TABLE `corbeau.roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.moderators` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `role_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.subjects` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.comments` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `email` VARCHAR(50),
  `content` VARCHAR(50),
  `post_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_114582_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_114582_ddl') AS relationships;
DROP DATABASE `db_114582_ddl`;
UNINSTALL EXTENSION vsql_schematron;
