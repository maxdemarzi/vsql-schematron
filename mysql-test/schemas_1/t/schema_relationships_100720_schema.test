INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 100720_schema
--echo #
CREATE DATABASE `db_100720_schema`;
USE `db_100720_schema`;
CREATE TABLE `polynomials` (
  `id` INT NOT NULL,
  `created` TIMESTAMP NULL,
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `p_members` (
  `id` INT NOT NULL,
  `poly_id` INT,
  `a_coefficient` INT,
  `x_pow` INT,
  `y_pow` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_100720_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_100720_schema') AS relationships;
DROP DATABASE `db_100720_schema`;
UNINSTALL EXTENSION vsql_schematron;
