INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158401_moviesDB
--echo #
CREATE DATABASE `db_158401_moviesDB`;
USE `db_158401_moviesDB`;

CREATE TABLE `Country` (
  `CountryID` INT,
  `CountryName` VARCHAR(255),
  PRIMARY KEY (`CountryID`)
) CHARACTER SET latin1;

CREATE TABLE `Director` (
  `DirectorID` INT,
  `DirectorName` VARCHAR(255),
  `DirectorDOB` DATETIME,
  `DirectorGender` VARCHAR(255),
  `DirectorCountryID` INT,
  PRIMARY KEY (`DirectorID`)
) CHARACTER SET latin1;

CREATE TABLE `Certificate` (
  `CertificateID` INT,
  `Certificate` VARCHAR(255),
  PRIMARY KEY (`CertificateID`)
) CHARACTER SET latin1;

CREATE TABLE `Actor` (
  `ActorID` INT,
  `ActorName` VARCHAR(255),
  `ActorDOB` DATETIME,
  `ActorGender` VARCHAR(255),
  `ActorCountryID` INT,
  PRIMARY KEY (`ActorID`)
) CHARACTER SET latin1;

CREATE TABLE `Studio` (
  `StudioID` INT,
  `StudioName` VARCHAR(255),
  PRIMARY KEY (`StudioID`)
) CHARACTER SET latin1;

CREATE TABLE `Language` (
  `LanguageID` INT,
  `Language` VARCHAR(255),
  PRIMARY KEY (`LanguageID`)
) CHARACTER SET latin1;

CREATE TABLE `Genre` (
  `GenreId` INT,
  `GenreName` VARCHAR(255),
  PRIMARY KEY (`GenreId`)
) CHARACTER SET latin1;

CREATE TABLE `Film` (
  `FilmID` INT,
  `FilmName` VARCHAR(255),
  `FilmReleaseDate` DATETIME,
  `FilmDirectorID` INT,
  `FilmLanguageID` INT,
  `FilmCountryID` INT,
  `FilmStudioID` INT,
  `FilmGenreID` INT,
  `FilmSynopsis` VARCHAR(255),
  `FilmRunTimeMinutes` INT,
  `FilmCertificateID` INT,
  `FilmBudgetDollars` INT,
  `FilmBoxOfficeDollars` INT,
  `FilmOscarNominations` INT,
  `FilmOscarWins` INT,
  PRIMARY KEY (`FilmID`)
) CHARACTER SET latin1;

CREATE TABLE `FilmCast` (
  `CastID` INT,
  `CastFilmID` INT,
  `CastActorID` INT,
  `CastCharacterName` VARCHAR(255),
  PRIMARY KEY (`CastID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158401_moviesDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158401_moviesDB') AS relationships;
DROP DATABASE `db_158401_moviesDB`;
UNINSTALL EXTENSION vsql_schematron;
