INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172031_dailycircular
--echo #
CREATE DATABASE `db_172031_dailycircular`;
USE `db_172031_dailycircular`;

CREATE TABLE `circular` (
  `circular_id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `created_by` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `fullname` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172031_dailycircular') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172031_dailycircular') AS relationships;
DROP DATABASE `db_172031_dailycircular`;
UNINSTALL EXTENSION vsql_schematron;
