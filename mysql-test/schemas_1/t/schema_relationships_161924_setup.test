INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161924_setup
--echo #
CREATE DATABASE `db_161924_setup`;
USE `db_161924_setup`;
CREATE TABLE `venue` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `category` VARCHAR(50),
  `url` VARCHAR(50),
  `date_added` TIMESTAMP NULL,
  `excerpt` VARCHAR(50),
  `thumbnail_url` VARCHAR(50),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `address` VARCHAR(50),
  `phone` VARCHAR(50),
  `twitter` VARCHAR(50),
  `stars_beer` DECIMAL(10,2),
  `stars_atmosphere` DECIMAL(10,2),
  `stars_amenities` DECIMAL(10,2),
  `stars_value` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `venue_tag` (
  `venue_id` BIGINT NOT NULL,
  `tag_id` BIGINT NOT NULL,
  PRIMARY KEY (`venue_id`, `tag_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161924_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161924_setup') AS relationships;
DROP DATABASE `db_161924_setup`;
UNINSTALL EXTENSION vsql_schematron;
