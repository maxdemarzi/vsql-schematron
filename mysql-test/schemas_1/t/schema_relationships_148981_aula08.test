INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148981_aula08
--echo #
CREATE DATABASE `db_148981_aula08`;
USE `db_148981_aula08`;

CREATE TABLE `EMPREGADO` (
  `codigo` INT,
  `nome` VARCHAR(64),
  `cpf` VARCHAR(64),
  `sexo` VARCHAR(64),
  `datanasc` DATETIME,
  `logradouro` VARCHAR(64),
  `nro` INT,
  `salario` DECIMAL(10,2),
  `depto_num` INT,
  `codigo_ger` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `DEPARTAMENTO` (
  `numero` INT,
  `nome` VARCHAR(64),
  `codigo_ger` INT,
  `data_inicio_ger` DATETIME,
  PRIMARY KEY (`numero`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148981_aula08') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148981_aula08') AS relationships;
DROP DATABASE `db_148981_aula08`;
UNINSTALL EXTENSION vsql_schematron;
