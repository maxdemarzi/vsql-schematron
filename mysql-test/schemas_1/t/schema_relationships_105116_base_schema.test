INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105116_base_schema
--echo #
CREATE DATABASE `db_105116_base_schema`;
USE `db_105116_base_schema`;
CREATE TABLE `provider_locations` (
  `id` VARCHAR(50) NOT NULL,
  `external_ids` VARCHAR(50),
  `provider` VARCHAR(50),
  `location_type` VARCHAR(50),
  `name` VARCHAR(50),
  `address_lines` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `postal_code` VARCHAR(50),
  `county` VARCHAR(50),
  `position` VARCHAR(50),
  `info_phone` VARCHAR(50),
  `info_url` TEXT,
  `booking_phone` VARCHAR(50),
  `booking_url` TEXT,
  `eligibility` TEXT,
  `description` TEXT,
  `requires_waitlist` BOOLEAN,
  `meta` VARCHAR(50),
  `is_public` BOOLEAN,
  `internal_notes` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `availability` (
  `id` VARCHAR(50) NOT NULL,
  `provider_location_id` VARCHAR(50),
  `source` VARCHAR(50),
  `updated_at` TIMESTAMP NULL,
  `checked_at` TIMESTAMP NULL,
  `available` VARCHAR(50),
  `meta` VARCHAR(50),
  `is_public` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105116_base_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105116_base_schema') AS relationships;
DROP DATABASE `db_105116_base_schema`;
UNINSTALL EXTENSION vsql_schematron;
