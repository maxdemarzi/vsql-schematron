INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 144607_projectweb
--echo #
CREATE DATABASE `db_144607_projectweb`;
USE `db_144607_projectweb`;
CREATE TABLE `JADWAL` (
  `NO` INT NOT NULL,
  `BULAN` VARCHAR(50),
  `TAHUN` INT,
  PRIMARY KEY (`NO`)
) CHARACTER SET latin1;
CREATE TABLE `MAHASISWA` (
  `NRP` INT NOT NULL,
  `NO_URUT_SKOR` INT,
  `NO` INT,
  `NAME` VARCHAR(50),
  `STUDY_PROGRAM` VARCHAR(50),
  `GENDER` BOOLEAN,
  `PHONE_NUMBER` VARCHAR(50),
  PRIMARY KEY (`NRP`)
) CHARACTER SET latin1;
CREATE TABLE `SCORE` (
  `NO_URUT_SKOR` INT NOT NULL,
  `NRP` INT,
  `NILAI` INT,
  PRIMARY KEY (`NO_URUT_SKOR`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_144607_projectweb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_144607_projectweb') AS relationships;
DROP DATABASE `db_144607_projectweb`;
UNINSTALL EXTENSION vsql_schematron;
