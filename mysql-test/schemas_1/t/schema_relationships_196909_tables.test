INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 196909_tables
--echo #
CREATE DATABASE `db_196909_tables`;
USE `db_196909_tables`;
CREATE TABLE `Subject` (
  `cSubjectId` VARCHAR(50) NOT NULL,
  `vName` VARCHAR(50),
  `vDescription` VARCHAR(50),
  PRIMARY KEY (`cSubjectId`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
  `cCourseId` VARCHAR(50) NOT NULL,
  `vName` VARCHAR(50),
  `vDescription` VARCHAR(50),
  `bUsed` DECIMAL(10,2),
  PRIMARY KEY (`cCourseId`)
) CHARACTER SET latin1;
CREATE TABLE `CourseSubject` (
  `cCourseId` CHAR(50),
  `cSubjectId` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Student` (
  `cStudentId` VARCHAR(50) NOT NULL,
  `vName` VARCHAR(50),
  `dDob` DATE,
  `cCourseId` CHAR(50),
  `vAddress` VARCHAR(50),
  `vEmailId` VARCHAR(50),
  `bCompleted` DECIMAL(10,2),
  `vPassword` VARCHAR(50),
  `vOtherSkills` VARCHAR(50),
  `cCCNumber` CHAR(50),
  PRIMARY KEY (`cStudentId`)
) CHARACTER SET latin1;
CREATE TABLE `Lecturer` (
  `cLecturerId` VARCHAR(50) NOT NULL,
  `vName` VARCHAR(50),
  `nDob` DATE,
  `cSubjectId` CHAR(50),
  `vAddress` VARCHAR(50),
  `vEmailId` VARCHAR(50),
  `vPassword` VARCHAR(50),
  `cCCNumber` CHAR(50),
  PRIMARY KEY (`cLecturerId`)
) CHARACTER SET latin1;
CREATE TABLE `Question` (
  `cSubjectId` CHAR(50),
  `vQuestion` VARCHAR(50),
  `vOption1` VARCHAR(50),
  `vOption2` VARCHAR(50),
  `vOption3` VARCHAR(50),
  `vOption4` VARCHAR(50),
  `nWeightage` DECIMAL(10,2),
  `nAnswer` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `Test` (
  `cTestId` VARCHAR(50) NOT NULL,
  `cSubjectId` CHAR(50),
  `cStudentId` CHAR(50),
  `nMarks` DECIMAL(10,2),
  PRIMARY KEY (`cTestId`)
) CHARACTER SET latin1;
CREATE TABLE `OnlineLecture` (
  `cOLectureId` VARCHAR(50) NOT NULL,
  `cLecturerId` CHAR(50),
  `vDescription` VARCHAR(50),
  `cType` CHAR(50),
  `vPath` CHAR(50),
  `vKeyword` VARCHAR(50),
  PRIMARY KEY (`cOLectureId`)
) CHARACTER SET latin1;
CREATE TABLE `ScheduledLecture` (
  `cSLectureId` VARCHAR(50) NOT NULL,
  `cLecturerId` CHAR(50),
  `vDescription` VARCHAR(50),
  `vPlace` VARCHAR(50),
  `dDate` VARCHAR(50),
  `tTime` VARCHAR(50),
  PRIMARY KEY (`cSLectureId`)
) CHARACTER SET latin1;
CREATE TABLE `SampleQuestionPaper` (
  `cSampleQuestionPaperId` VARCHAR(50) NOT NULL,
  `nQuestions` DECIMAL(10,2),
  PRIMARY KEY (`cSampleQuestionPaperId`)
) CHARACTER SET latin1;
CREATE TABLE `SampleQuestion` (
  `cSampleQuestionId` VARCHAR(50) NOT NULL,
  `vQuestion` VARCHAR(50),
  `vOption1` VARCHAR(50),
  `vOption2` VARCHAR(50),
  `vOption3` VARCHAR(50),
  `vOption4` VARCHAR(50),
  `nWeight` DECIMAL(10,2),
  `nAnswer` DECIMAL(10,2),
  PRIMARY KEY (`cSampleQuestionId`)
) CHARACTER SET latin1;
CREATE TABLE `SampleQuestionSamplePaper` (
  `cSampleQuestionId` CHAR(50),
  `cSampleQuestionPaperId` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SampleTest` (
  `cSampleTestId` VARCHAR(50) NOT NULL,
  `cSubjectId` CHAR(50),
  `cSampleQuestionPaperId` CHAR(50),
  PRIMARY KEY (`cSampleTestId`)
) CHARACTER SET latin1;
CREATE TABLE `admin_pass` (
  `vPassword` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_196909_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_196909_tables') AS relationships;
DROP DATABASE `db_196909_tables`;
UNINSTALL EXTENSION vsql_schematron;
