INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152369_schema
--echo #
CREATE DATABASE `db_152369_schema`;
USE `db_152369_schema`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified` DATETIME,
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `verification_requests` (
  `id` INT,
  `identifier` VARCHAR(64),
  `token` VARCHAR(64),
  `expires` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` INT,
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `event_date` DATETIME,
  `judges` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schools` (
  `id` INT,
  `school_name` VARCHAR(64),
  `contact_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `type` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `performances` (
  `id` INT,
  `dance_title` VARCHAR(64),
  `performance_link` VARCHAR(64),
  `performers` VARCHAR(64),
  `choreographers` VARCHAR(64),
  `competition_level` VARCHAR(64),
  `dance_size` VARCHAR(64),
  `dance_style` VARCHAR(64),
  `dance_size_id` INT,
  `dance_style_id` INT,
  `competition_level_id` INT,
  `event_id` INT,
  `school_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `adjudications` (
  `id` INT,
  `artistic_mark` DECIMAL(10,2),
  `technical_mark` DECIMAL(10,2),
  `cumulative_mark` DECIMAL(10,2),
  `audio_url` VARCHAR(64),
  `notes` VARCHAR(64),
  `performance_id` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `awards` (
  `id` INT,
  `title` VARCHAR(64),
  `type` VARCHAR(64),
  `is_finalized` BOOL,
  `event_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `awards_categories` (
  `id` INT,
  `award_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `awards_performances` (
  `id` INT,
  `award_id` INT,
  `performance_id` INT,
  `user_id` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152369_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152369_schema') AS relationships;
DROP DATABASE `db_152369_schema`;
UNINSTALL EXTENSION vsql_schematron;
