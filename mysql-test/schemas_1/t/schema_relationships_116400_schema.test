INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116400_schema
--echo #
CREATE DATABASE `db_116400_schema`;
USE `db_116400_schema`;
CREATE TABLE `parties` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candidates` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `party_id` INT,
  `industry_connected` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voters` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `create_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
  `id` INT NOT NULL,
  `voter_id` INT,
  `candidate_id` INT,
  `create_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116400_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116400_schema') AS relationships;
DROP DATABASE `db_116400_schema`;
UNINSTALL EXTENSION vsql_schematron;
