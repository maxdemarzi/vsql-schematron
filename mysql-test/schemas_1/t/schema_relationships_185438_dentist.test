INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 185438_dentist
--echo #
CREATE DATABASE `db_185438_dentist`;
USE `db_185438_dentist`;

CREATE TABLE `appointments` (
  `id` INT,
  `user_id` INT,
  `status` VARCHAR(64),
  `scheduled_on` DATETIME,
  `service_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `availabilities` (
  `id` INT,
  `day` VARCHAR(64),
  `start` DATETIME,
  `end` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blogs` (
  `id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `image_url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `galleries` (
  `id` INT,
  `image_url` VARCHAR(64),
  `is_banner` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_access_tokens` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `name` VARCHAR(64),
  `scopes` VARCHAR(64),
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_auth_codes` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `scopes` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_clients` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `secret` VARCHAR(64),
  `redirect` VARCHAR(64),
  `personal_access_client` INT,
  `password_client` INT,
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_personal_access_clients` (
  `id` INT,
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_refresh_tokens` (
  `id` VARCHAR(64),
  `access_token_id` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `weight` INT
) CHARACTER SET latin1;

CREATE TABLE `services` (
  `id` INT,
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `app_title` VARCHAR(64),
  `clinic_name` VARCHAR(64),
  `doctor_name` VARCHAR(64),
  `mobile_number` VARCHAR(64),
  `email` VARCHAR(64),
  `address` VARCHAR(64),
  `longitude` DECIMAL(10,2),
  `latitude` DECIMAL(10,2),
  `slot` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `about_1` VARCHAR(64),
  `about_2` VARCHAR(64),
  `about_count_1` VARCHAR(64),
  `about_count_2` VARCHAR(64),
  `about_count_3` VARCHAR(64),
  `service_title` VARCHAR(64),
  `service_body` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `social_accounts` (
  `id` INT,
  `user_id` INT,
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `token` VARCHAR(64),
  `avatar` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `supports` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `message` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `testimonials` (
  `id` INT,
  `testimonial` VARCHAR(64),
  `name` VARCHAR(64),
  `image_url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `mobile` VARCHAR(64),
  `password` VARCHAR(64),
  `fcm_registration_id` VARCHAR(64),
  `active` INT,
  `confirmation_code` VARCHAR(64),
  `confirmed` INT,
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_185438_dentist') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_185438_dentist') AS relationships;
DROP DATABASE `db_185438_dentist`;
UNINSTALL EXTENSION vsql_schematron;
