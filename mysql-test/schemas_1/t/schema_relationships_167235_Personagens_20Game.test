INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 167235_Personagens%20Game
--echo #
CREATE DATABASE `db_167235_Personagens_20Game`;
USE `db_167235_Personagens_20Game`;
CREATE TABLE `tb_classe` (
  `id` BIGINT NOT NULL,
  `classe` VARCHAR(50),
  `descricao` VARCHAR(50),
  `genero` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_personagem` (
  `id` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  `ataque` INT,
  `defesa` INT,
  `classe_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_167235_Personagens_20Game') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_167235_Personagens_20Game') AS relationships;
DROP DATABASE `db_167235_Personagens_20Game`;
UNINSTALL EXTENSION vsql_schematron;
