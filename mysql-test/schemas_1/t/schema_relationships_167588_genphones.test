INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 167588_genphones
--echo #
CREATE DATABASE `db_167588_genphones`;
USE `db_167588_genphones`;
CREATE TABLE `people` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phones` (
  `digits` INT NOT NULL,
  `make` VARCHAR(50),
  `model` VARCHAR(50),
  `owner` INT,
  PRIMARY KEY (`digits`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_167588_genphones') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_167588_genphones') AS relationships;
DROP DATABASE `db_167588_genphones`;
UNINSTALL EXTENSION vsql_schematron;
