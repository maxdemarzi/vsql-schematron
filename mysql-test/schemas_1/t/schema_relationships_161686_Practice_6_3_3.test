INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161686_Practice_6_3_3
--echo #
CREATE DATABASE `db_161686_Practice_6_3_3`;
USE `db_161686_Practice_6_3_3`;

CREATE TABLE `dept` (
  `dept_id` DECIMAL(10,2),
  `dept_name` VARCHAR(64),
  `loc_id` DECIMAL(10,2),
  PRIMARY KEY (`dept_id`, `loc_id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` DECIMAL(10,2),
  `suppliers_id` DECIMAL(10,2),
  `suppliers_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `suppliers` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `contact_name` DECIMAL(10,2),
  PRIMARY KEY (`id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `dept_sample` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `loc_id` DECIMAL(10,2),
  PRIMARY KEY (`id`, `name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161686_Practice_6_3_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161686_Practice_6_3_3') AS relationships;
DROP DATABASE `db_161686_Practice_6_3_3`;
UNINSTALL EXTENSION vsql_schematron;
