INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142472_20210410205752_initialize_schema.up
--echo #
CREATE DATABASE `db_142472_20210410205752_initialize_schema_up`;
USE `db_142472_20210410205752_initialize_schema_up`;

CREATE TABLE `customers` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_items` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `description` VARCHAR(64),
  `qty` VARCHAR(64),
  `unit` VARCHAR(64),
  `unit_price` VARCHAR(64),
  `order_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `description` VARCHAR(64),
  `delivery_date` VARCHAR(64),
  `invoice_number` VARCHAR(64),
  `currency` VARCHAR(64),
  `order_number` VARCHAR(64),
  `created_by` INT,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `quote_items` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `description` VARCHAR(64),
  `qty` VARCHAR(64),
  `unit` VARCHAR(64),
  `unit_price` VARCHAR(64),
  `quote_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `quotes` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `description` VARCHAR(64),
  `quote_number` VARCHAR(64),
  `created_by` INT,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `email` VARCHAR(64),
  `userName` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142472_20210410205752_initialize_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142472_20210410205752_initialize_schema_up') AS relationships;
DROP DATABASE `db_142472_20210410205752_initialize_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
