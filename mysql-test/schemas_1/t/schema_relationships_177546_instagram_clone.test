INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 177546_instagram_clone
--echo #
CREATE DATABASE `db_177546_instagram_clone`;
USE `db_177546_instagram_clone`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `photos` (
  `id` INT,
  `image_url` VARCHAR(64),
  `user_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `comment_text` VARCHAR(64),
  `user_id` INT,
  `photo_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `user_id` INT,
  `photo_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`user_id`, `photo_id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `tag_name` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `taggins` (
  `photo_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`photo_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_177546_instagram_clone') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_177546_instagram_clone') AS relationships;
DROP DATABASE `db_177546_instagram_clone`;
UNINSTALL EXTENSION vsql_schematron;
