INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 189420_DaseDatos
--echo #
CREATE DATABASE `db_189420_DaseDatos`;
USE `db_189420_DaseDatos`;

CREATE TABLE `Usuario` (
  `id_user` INT,
  `name` VARCHAR(64),
  `pass` VARCHAR(64),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `datos_user` (
  `id_datos` INT,
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `id_usurio` INT,
  `direccion` VARCHAR(64),
  PRIMARY KEY (`id_datos`)
) CHARACTER SET latin1;

CREATE TABLE `Menu` (
  `id_menu` INT,
  `nombre` VARCHAR(64),
  `precio` DECIMAL(10,2),
  `id_bebida` INT,
  PRIMARY KEY (`id_menu`)
) CHARACTER SET latin1;

CREATE TABLE `Bebida` (
  `Id_bebida` INT,
  `nombre` VARCHAR(64),
  `tipo` VARCHAR(64),
  `precio` DECIMAL(10,2),
  PRIMARY KEY (`Id_bebida`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_189420_DaseDatos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_189420_DaseDatos') AS relationships;
DROP DATABASE `db_189420_DaseDatos`;
UNINSTALL EXTENSION vsql_schematron;
