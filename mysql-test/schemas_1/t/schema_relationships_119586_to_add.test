INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 119586_to_add
--echo #
CREATE DATABASE `db_119586_to_add`;
USE `db_119586_to_add`;

CREATE TABLE `nodes_table` (
  `id_node` INT,
  `codStr` VARCHAR(64),
  `nodeName` VARCHAR(64),
  `country` VARCHAR(64),
  `region` VARCHAR(64),
  `province` VARCHAR(64),
  `city` VARCHAR(64),
  `street` VARCHAR(64),
  `streetNumber` VARCHAR(64),
  `ZipCode` VARCHAR(64),
  `Apos_min` INT,
  `Apos_max` INT,
  `Aneg_min` INT,
  `Aneg_max` INT,
  `Bpos_min` INT,
  `Bpos_max` INT,
  `Bneg_min` INT,
  `Bneg_max` INT,
  `ABpos_min` INT,
  `ABpos_max` INT,
  `ABneg_min` INT,
  `ABneg_max` INT,
  `ZEROpos_min` INT,
  `ZEROpos_max` INT,
  `ZEROneg_min` INT,
  `ZEROneg_max` INT,
  `endpoint` VARCHAR(64),
  PRIMARY KEY (`id_node`)
) CHARACTER SET latin1;

CREATE TABLE `BloodBags` (
  `idSerial` VARCHAR(64),
  `bloodgroup` VARCHAR(64),
  `creationDate` INT,
  `expiringDate` INT,
  `donatorCF` VARCHAR(64),
  `id_node` INT,
  `id_state` INT,
  `note` VARCHAR(64),
  PRIMARY KEY (`idSerial`)
) CHARACTER SET latin1;

CREATE TABLE `oldBloodBags` (
  `idSerial` VARCHAR(64),
  `bloodgroup` VARCHAR(64),
  `creationDate` INT,
  `expiringDate` INT,
  `donatorCF` VARCHAR(64),
  `id_node` INT,
  `id_state` INT,
  `note` VARCHAR(64),
  PRIMARY KEY (`idSerial`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `id_user` INT,
  `username` VARCHAR(64),
  `hiddenpassword` VARCHAR(64),
  `temppass` VARCHAR(64),
  `password_lastupdate` INT,
  `lastaccess` INT,
  `id_role` INT,
  `country` VARCHAR(64),
  `region` VARCHAR(64),
  `province` VARCHAR(64),
  `city` VARCHAR(64),
  `street` VARCHAR(64),
  `streetNumber` VARCHAR(64),
  `ZipCode` VARCHAR(64),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `Logger` (
  `id_logger` INT,
  `whenHappened` INT,
  `currentUser` VARCHAR(64),
  `operation` VARCHAR(64),
  `note_action` VARCHAR(64),
  `bloodbag_serial` VARCHAR(64),
  `note` VARCHAR(64),
  PRIMARY KEY (`id_logger`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_119586_to_add') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_119586_to_add') AS relationships;
DROP DATABASE `db_119586_to_add`;
UNINSTALL EXTENSION vsql_schematron;
