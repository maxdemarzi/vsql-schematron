INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145403_db
--echo #
CREATE DATABASE `db_145403_db`;
USE `db_145403_db`;

CREATE TABLE `enduro_totals` (
  `evento_id` VARCHAR(64),
  `equipe_id` INT,
  `lap_count` INT,
  `lap_time_avg` INT,
  `lap_time_min` INT,
  `lap_time_max` INT,
  PRIMARY KEY (`evento_id`, `equipe_id`)
) CHARACTER SET latin1;

CREATE TABLE `equipe` (
  `evento_id` VARCHAR(64),
  `equipe_id` INT,
  `escola` VARCHAR(64),
  `equipe` VARCHAR(64),
  `estado` VARCHAR(64),
  `presente` INT,
  `escola_curto` VARCHAR(64),
  `equipe_curto` VARCHAR(64),
  `cidade` VARCHAR(64),
  PRIMARY KEY (`evento_id`, `equipe_id`)
) CHARACTER SET latin1;

CREATE TABLE `evento` (
  `evento_id` VARCHAR(64),
  `titulo` VARCHAR(64),
  `nome` VARCHAR(64),
  `tipo` INT,
  `ano` INT,
  `menu` VARCHAR(64),
  `ativo` INT,
  `finalizado` INT,
  PRIMARY KEY (`evento_id`)
) CHARACTER SET latin1;

CREATE TABLE `prova` (
  `evento_id` VARCHAR(64),
  `prova_id` VARCHAR(64),
  `nome` VARCHAR(64),
  `status` INT,
  `tempo` INT,
  `modificado` DATETIME,
  `params` VARCHAR(64),
  `totals` VARCHAR(64),
  PRIMARY KEY (`prova_id`, `evento_id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `user_id` INT,
  `evento_id` VARCHAR(64),
  `prova_id` VARCHAR(64),
  `role` VARCHAR(64),
  `habilitado` INT,
  PRIMARY KEY (`user_id`, `evento_id`, `prova_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145403_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145403_db') AS relationships;
DROP DATABASE `db_145403_db`;
UNINSTALL EXTENSION vsql_schematron;
