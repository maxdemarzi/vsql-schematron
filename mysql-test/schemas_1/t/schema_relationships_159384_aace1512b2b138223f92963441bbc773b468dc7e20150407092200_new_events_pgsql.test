INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159384_aace1512b2b138223f92963441bbc773b468dc7e20150407092200_new_events_pgsql
--echo #
CREATE DATABASE `db_159384_aace1512b2b138223f92963441bbc773b468dc7e2015040709`;
USE `db_159384_aace1512b2b138223f92963441bbc773b468dc7e2015040709`;

CREATE TABLE `new_event_draft_information` (
  `id` INT,
  `site_id` INT,
  `slug` INT,
  `details` VARCHAR(255),
  `not_duplicate_events` VARCHAR(255),
  `event_id` INT,
  `was_existing_event_id` INT,
  `user_account_id` INT,
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `new_event_draft_history` (
  `new_event_draft_id` INT,
  `details` VARCHAR(255),
  `details_changed` INT,
  `not_duplicate_events` VARCHAR(255),
  `not_duplicate_events_changed` INT,
  `event_id` INT,
  `event_id_changed` INT,
  `was_existing_event_id` INT,
  `was_existing_event_id_changed` INT,
  `user_account_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`new_event_draft_id`, `created_at`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159384_aace1512b2b138223f92963441bbc773b468dc7e2015040709') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159384_aace1512b2b138223f92963441bbc773b468dc7e2015040709') AS relationships;
DROP DATABASE `db_159384_aace1512b2b138223f92963441bbc773b468dc7e2015040709`;
UNINSTALL EXTENSION vsql_schematron;
