INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 189436_dist_block_app_db
--echo #
CREATE DATABASE `db_189436_dist_block_app_db`;
USE `db_189436_dist_block_app_db`;

CREATE TABLE `customer_faults` (
  `id` INT,
  `fault_id` VARCHAR(64),
  `description` VARCHAR(64),
  `assigned_to` INT,
  `user_id` INT,
  `resolution` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dist_points` (
  `id` INT,
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `code` VARCHAR(64),
  `availableSlots` INT,
  `maxSlots` INT,
  `description` VARCHAR(64),
  `dpPairNo` VARCHAR(64),
  `dpNo` VARCHAR(64),
  `distributionSide` VARCHAR(64),
  `exchangeSide` VARCHAR(64),
  `cabinetNo` VARCHAR(64),
  `mdfPair` VARCHAR(64),
  `mdfBar` VARCHAR(64),
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `dp_applications` (
  `id` INT,
  `service` VARCHAR(64),
  `description` VARCHAR(64),
  `resolution` VARCHAR(64),
  `dist_block` INT,
  `client_id` INT,
  `assigned_to` INT,
  `sketchMap` VARCHAR(64),
  `assessment` VARCHAR(64),
  `applicationDate` DATETIME,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `migration` VARCHAR(64),
  `batch` INT
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `province` VARCHAR(64),
  `city` VARCHAR(64),
  `streetName` VARCHAR(64),
  `houseNumber` VARCHAR(64),
  `plotNumber` VARCHAR(64),
  `postal` VARCHAR(64),
  `physicalAddress` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_189436_dist_block_app_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_189436_dist_block_app_db') AS relationships;
DROP DATABASE `db_189436_dist_block_app_db`;
UNINSTALL EXTENSION vsql_schematron;
