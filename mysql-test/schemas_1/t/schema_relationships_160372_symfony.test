INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160372_symfony
--echo #
CREATE DATABASE `db_160372_symfony`;
USE `db_160372_symfony`;
CREATE TABLE `company` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `responsible` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `doctrine_migration_versions` (
  `version` VARCHAR(50) NOT NULL,
  `executed_at` DATETIME,
  `execution_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `option` (
  `id` INT,
  `company_id` INT,
  `name` VARCHAR(50),
  `value` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160372_symfony') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160372_symfony') AS relationships;
DROP DATABASE `db_160372_symfony`;
UNINSTALL EXTENSION vsql_schematron;
