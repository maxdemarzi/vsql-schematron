INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159674_test-exchange-rate
--echo #
CREATE DATABASE `db_159674_test_exchange_rate`;
USE `db_159674_test_exchange_rate`;
CREATE TABLE `EXCHANGE_REF` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EXCHANGE_RATE` (
  `ID` DECIMAL(10,2) NOT NULL,
  `REFERENCE_ID` DECIMAL(10,2),
  `FIRST_NAME` VARCHAR(50),
  `PREV_FIRST_NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159674_test_exchange_rate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159674_test_exchange_rate') AS relationships;
DROP DATABASE `db_159674_test_exchange_rate`;
UNINSTALL EXTENSION vsql_schematron;
