INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159745_mmq
--echo #
CREATE DATABASE `db_159745_mmq`;
USE `db_159745_mmq`;
CREATE TABLE `consumo_produto` (
  `quantidadeconsumida` INT,
  `produto_idProduto` INT,
  `periodo` DATE,
  `peso` INT
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `idProduto` INT,
  `nome` VARCHAR(50),
  `tipo` VARCHAR(50),
  `estoquemax` INT,
  `preco` INT,
  `descricao` VARCHAR(50),
  `quantidade` INT,
  `imagem` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `fornecedores` (
  `idFornecedor` INT,
  `nome` VARCHAR(50),
  `telefone` VARCHAR(50),
  `endereço` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `pais` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159745_mmq') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159745_mmq') AS relationships;
DROP DATABASE `db_159745_mmq`;
UNINSTALL EXTENSION vsql_schematron;
