INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107461_table_definitions
--echo #
CREATE DATABASE `db_107461_table_definitions`;
USE `db_107461_table_definitions`;
CREATE TABLE `public.credential` (
  `value` VARCHAR(50),
  `type` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`type`)
) CHARACTER SET latin1;
CREATE TABLE `public.problems` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `passwd` VARCHAR(50),
  `email` VARCHAR(50),
  `is_active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.results` (
  `id` INT NOT NULL,
  `problem_id` INT,
  `user_id` INT,
  `cleared` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107461_table_definitions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107461_table_definitions') AS relationships;
DROP DATABASE `db_107461_table_definitions`;
UNINSTALL EXTENSION vsql_schematron;
