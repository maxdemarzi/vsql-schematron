INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186623_000002_resources-table.up
--echo #
CREATE DATABASE `db_186623_000002_resources_table_up`;
USE `db_186623_000002_resources_table_up`;

CREATE TABLE `resources` (
  `item_id` VARCHAR(64),
  `resource_seq` INT,
  `fulltext_file` VARCHAR(64),
  `djvu_text_file` VARCHAR(64),
  `image` VARCHAR(64),
  `pdf` VARCHAR(64),
  `url` VARCHAR(64),
  `caption` VARCHAR(64),
  PRIMARY KEY (`item_id`, `resource_seq`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `item_id` VARCHAR(64),
  `resource_seq` INT,
  `file_seq` INT,
  `format_seq` INT,
  `mimetype` VARCHAR(64),
  `fulltext` VARCHAR(64),
  `fulltext_service` VARCHAR(64),
  `word_coordinates` VARCHAR(64),
  `url` VARCHAR(64),
  `info` VARCHAR(64),
  `use` VARCHAR(64),
  PRIMARY KEY (`item_id`, `resource_seq`, `file_seq`, `format_seq`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186623_000002_resources_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186623_000002_resources_table_up') AS relationships;
DROP DATABASE `db_186623_000002_resources_table_up`;
UNINSTALL EXTENSION vsql_schematron;
