INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188951_dump3
--echo #
CREATE DATABASE `db_188951_dump3`;
USE `db_188951_dump3`;

CREATE TABLE `CDMCriterionPossibleValue` (
  `id` VARCHAR(64),
  `key` VARCHAR(64),
  `name` VARCHAR(64),
  `orderNumber` INT,
  `CDMCriterion_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CDMScenario_has_CDMCriterionPossibleValue` (
  `CDMScenario_id` VARCHAR(64),
  `CDMCriterionPossibleValue_id` VARCHAR(64),
  PRIMARY KEY (`CDMScenario_id`, `CDMCriterionPossibleValue_id`)
) CHARACTER SET latin1;

CREATE TABLE `CloudDataHostingSolution` (
  `id` VARCHAR(64),
  `Project_id` VARCHAR(64),
  `CDHSCriterionPossibleValue_id` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LocalDBLCriterion` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `orderNumber` INT,
  `LocalDBLCategory_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Solution` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `LocalDBLCriterionPossibleValue_id` VARCHAR(64),
  `CDHSCriterionPossibleValue_id` VARCHAR(64),
  `CDMCriterionPossibleValue_id` VARCHAR(64),
  `CDMCriterionPossibleValue_id1` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `department` VARCHAR(64),
  `url` VARCHAR(64),
  `User_id` VARCHAR(64),
  `CloudDataStore_id` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CloudDataStoreProperty` (
  `id` VARCHAR(64),
  `CloudDataStore_id` VARCHAR(64),
  `CDHSCriterionPossibleValue_id` VARCHAR(64),
  `inputValue` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CloudDataStore` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `provider` VARCHAR(64),
  `website` VARCHAR(64),
  `description` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CDMCriterion` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `key` VARCHAR(64),
  `orderNumber` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project_has_CDMScenario` (
  `Project_id` VARCHAR(64),
  `CDMScenario_id` VARCHAR(64),
  PRIMARY KEY (`Project_id`, `CDMScenario_id`)
) CHARACTER SET latin1;

CREATE TABLE `CDHSCriterion` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `key` VARCHAR(64),
  `description` VARCHAR(64),
  `selectionType` VARCHAR(64),
  `orderNumber` INT,
  `CDHSCategory_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LocalDBLCriterionPossibleValue` (
  `id` VARCHAR(64),
  `key` VARCHAR(64),
  `name` VARCHAR(64),
  `orderNumber` INT,
  `LocalDBLCriterion_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CDHSCategory` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `orderNumber` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LocalDBLProperty` (
  `id` VARCHAR(64),
  `Project_id` VARCHAR(64),
  `LocalDBLCriterionPossibleValue_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CDHSCriterionPossibleValue` (
  `id` VARCHAR(64),
  `key` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `orderNumber` INT,
  `scale` VARCHAR(64),
  `CDHSCriterion_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CDMStrategy` (
  `Project_id` VARCHAR(64),
  `CDMCriterionPossibleValue_id` VARCHAR(64),
  PRIMARY KEY (`Project_id`, `CDMCriterionPossibleValue_id`)
) CHARACTER SET latin1;

CREATE TABLE `CDMScenario` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `orderNumber` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LocalDBLCategory` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `orderNumber` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188951_dump3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188951_dump3') AS relationships;
DROP DATABASE `db_188951_dump3`;
UNINSTALL EXTENSION vsql_schematron;
