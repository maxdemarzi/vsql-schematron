INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186113_002_04_tables_compte
--echo #
CREATE DATABASE `db_186113_002_04_tables_compte`;
USE `db_186113_002_04_tables_compte`;
CREATE TABLE `t_compte` (
  `t_compte_id` VARCHAR(50) NOT NULL,
  `nom` VARCHAR(50),
  `intitule` VARCHAR(50),
  `t_contact_id` VARCHAR(50),
  PRIMARY KEY (`t_compte_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_compte_adresse` (
  `t_compte_adresse_id` VARCHAR(50) NOT NULL,
  `t_compte_id` VARCHAR(50),
  `type_adresse` VARCHAR(50),
  `t_adresse_id` VARCHAR(50),
  PRIMARY KEY (`t_compte_adresse_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186113_002_04_tables_compte') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186113_002_04_tables_compte') AS relationships;
DROP DATABASE `db_186113_002_04_tables_compte`;
UNINSTALL EXTENSION vsql_schematron;
