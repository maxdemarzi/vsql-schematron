INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 136046_session_postgresql
--echo #
CREATE DATABASE `db_136046_session_postgresql`;
USE `db_136046_session_postgresql`;

CREATE TABLE `sessions` (
  `primary_id` VARCHAR(255),
  `session_id` VARCHAR(255),
  `creation_time` INT,
  `last_access_time` INT,
  `max_inactive_interval` INT,
  `expiry_time` INT,
  `principal_name` VARCHAR(255),
  PRIMARY KEY (`primary_id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions_attributes` (
  `session_primary_id` VARCHAR(255),
  `attribute_name` VARCHAR(255),
  `attribute_bytes` VARCHAR(255),
  PRIMARY KEY (`session_primary_id`, `attribute_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_136046_session_postgresql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_136046_session_postgresql') AS relationships;
DROP DATABASE `db_136046_session_postgresql`;
UNINSTALL EXTENSION vsql_schematron;
