INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187969_j2e8
--echo #
CREATE DATABASE `db_187969_j2e8`;
USE `db_187969_j2e8`;

CREATE TABLE `admin` (
  `admin_id` INT,
  PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;

CREATE TABLE `commity` (
  `commity_id` INT,
  `commity_content` VARCHAR(64),
  `commity_user_id` INT,
  `commity_time` DATETIME,
  `commity_like` INT,
  `commity_dislike` INT,
  `commity_shop_id` INT,
  PRIMARY KEY (`commity_id`)
) CHARACTER SET latin1;

CREATE TABLE `reply` (
  `reply_id` INT,
  `reply_content` VARCHAR(64),
  `reply_time` DATETIME,
  `reply_user_id` INT,
  `reply_commity_id` INT,
  PRIMARY KEY (`reply_id`)
) CHARACTER SET latin1;

CREATE TABLE `type` (
  `type_id` INT,
  `type_name` VARCHAR(64),
  PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;

CREATE TABLE `type_shop` (
  `type_id` INT,
  `shop_type_id` INT,
  PRIMARY KEY (`type_id`, `shop_type_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187969_j2e8') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187969_j2e8') AS relationships;
DROP DATABASE `db_187969_j2e8`;
UNINSTALL EXTENSION vsql_schematron;
