INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142848_pgsql-schema
--echo #
CREATE DATABASE `db_142848_pgsql_schema`;
USE `db_142848_pgsql_schema`;

CREATE TABLE `SAMPLE` (
  `id` INT,
  `val` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ORGANIZATION` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `PERSON` (
  `id` INT,
  `org_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `VALUE8` (
  `val1` INT,
  `val2` INT,
  `val3` INT,
  `val4` INT,
  `val5` INT,
  `val6` INT,
  `val7` INT,
  `val8` INT,
  PRIMARY KEY (`val1`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142848_pgsql_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142848_pgsql_schema') AS relationships;
DROP DATABASE `db_142848_pgsql_schema`;
UNINSTALL EXTENSION vsql_schematron;
