INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163733_schema
--echo #
CREATE DATABASE `db_163733_schema`;
USE `db_163733_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `subscription` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feeds` (
  `id` INT NOT NULL,
  `uri` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_feeds` (
  `id` INT NOT NULL,
  `user_id` INT,
  `feed_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
  `id` INT NOT NULL,
  `url` VARCHAR(50),
  `yays` INT,
  `nays` INT,
  `fakes` INT,
  `legits` INT,
  `ratings` INT,
  `rating_count` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `article_id` INT,
  `user_id` INT,
  `comment` VARCHAR(50),
  `yay` BOOLEAN,
  `nay` BOOLEAN,
  `fake` BOOLEAN,
  `legit` BOOLEAN,
  `rating` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_comments` (
  `id` INT NOT NULL,
  `user_id` INT,
  `comment_id` INT,
  `article_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163733_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163733_schema') AS relationships;
DROP DATABASE `db_163733_schema`;
UNINSTALL EXTENSION vsql_schematron;
