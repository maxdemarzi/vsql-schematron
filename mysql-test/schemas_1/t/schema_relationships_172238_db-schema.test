INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172238_db-schema
--echo #
CREATE DATABASE `db_172238_db_schema`;
USE `db_172238_db_schema`;
CREATE TABLE `users` (
  `user_name` VARCHAR(50) NOT NULL,
  `full_name` VARCHAR(50),
  `email_address` VARCHAR(50),
  PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` VARCHAR(50),
  `user_name` VARCHAR(50),
  `submit_date` TIMESTAMP NULL,
  `content` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172238_db_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172238_db_schema') AS relationships;
DROP DATABASE `db_172238_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
