INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 198239_dump_last1
--echo #
CREATE DATABASE `db_198239_dump_last1`;
USE `db_198239_dump_last1`;
CREATE TABLE `admin_user` (
  `id` INT NOT NULL,
  `username` CHAR(50),
  `email` CHAR(50),
  `password` CHAR(50),
  `roles` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  `is_active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration_versions` (
  `version` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `perm_id` INT NOT NULL,
  `perm_desc` CHAR(50),
  PRIMARY KEY (`perm_id`)
) CHARACTER SET latin1;
CREATE TABLE `role_permissions` (
  `perm_id` INT,
  `role_id` INT,
  `role_perm_id` INT NOT NULL,
  PRIMARY KEY (`role_perm_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `role_id` INT NOT NULL,
  `role_name` CHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_198239_dump_last1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_198239_dump_last1') AS relationships;
DROP DATABASE `db_198239_dump_last1`;
UNINSTALL EXTENSION vsql_schematron;
