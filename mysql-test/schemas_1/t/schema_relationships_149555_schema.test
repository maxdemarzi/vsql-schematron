INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 149555_schema
--echo #
CREATE DATABASE `db_149555_schema`;
USE `db_149555_schema`;
CREATE TABLE `repository` (
  `id` INT NOT NULL,
  `full_name` VARCHAR(50),
  `token` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `build` (
  `id` INT NOT NULL,
  `sha` VARCHAR(50),
  `repository_id` INT,
  `payload` TEXT,
  `output` TEXT,
  `status` INT,
  `execution_time` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_149555_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_149555_schema') AS relationships;
DROP DATABASE `db_149555_schema`;
UNINSTALL EXTENSION vsql_schematron;
