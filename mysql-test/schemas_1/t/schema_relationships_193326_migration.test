INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193326_migration
--echo #
CREATE DATABASE `db_193326_migration`;
USE `db_193326_migration`;

CREATE TABLE `Conversation` (
  `id` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Message` (
  `id` INT,
  `createdAt` DATETIME,
  `userId` INT,
  `conversationId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Feedback` (
  `id` INT,
  `conversationId` INT,
  `userId` INT,
  `survey` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ConversationToUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193326_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193326_migration') AS relationships;
DROP DATABASE `db_193326_migration`;
UNINSTALL EXTENSION vsql_schematron;
