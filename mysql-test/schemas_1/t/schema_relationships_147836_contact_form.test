INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147836_contact_form
--echo #
CREATE DATABASE `db_147836_contact_form`;
USE `db_147836_contact_form`;
CREATE TABLE `categories` (
  `category_id` INT NOT NULL,
  `category_name` VARCHAR(50),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `message_id` INT,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `message` VARCHAR(50),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `product_id` INT
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT,
  `product_name` TEXT,
  `product_description` VARCHAR(50),
  `product_price` DECIMAL(10,2),
  `date_created` DATE,
  `date_deleted` DATE,
  `product_category_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147836_contact_form') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147836_contact_form') AS relationships;
DROP DATABASE `db_147836_contact_form`;
UNINSTALL EXTENSION vsql_schematron;
