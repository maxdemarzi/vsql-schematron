INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110661_V0_0_0_create_tables
--echo #
CREATE DATABASE `db_110661_V0_0_0_create_tables`;
USE `db_110661_V0_0_0_create_tables`;

CREATE TABLE `m_user` (
  `id` INT,
  `user_handle` VARCHAR(255),
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email_address` VARCHAR(255),
  `password` VARCHAR(255),
  `pwauth_allowed` VARCHAR(255),
  `locked` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m_group` (
  `id` INT,
  `group_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m_authority` (
  `id` INT,
  `authority` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m_authenticator` (
  `id` INT,
  `name` VARCHAR(255),
  `user_id` INT,
  `counter` INT,
  `aa_guid` VARCHAR(255),
  `credential_id` VARCHAR(255),
  `credential_public_key` VARCHAR(255),
  `attestation_statement` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `r_user_group` (
  `user_id` INT,
  `group_id` INT
) CHARACTER SET latin1;

CREATE TABLE `r_user_authority` (
  `user_id` INT,
  `authority_id` INT
) CHARACTER SET latin1;

CREATE TABLE `r_group_authority` (
  `group_id` INT,
  `authority_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110661_V0_0_0_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110661_V0_0_0_create_tables') AS relationships;
DROP DATABASE `db_110661_V0_0_0_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
