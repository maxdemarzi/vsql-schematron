INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158552_up-00000-initial-structure
--echo #
CREATE DATABASE `db_158552_up_00000_initial_structure`;
USE `db_158552_up_00000_initial_structure`;

CREATE TABLE `node` (
  `nodeId` INT,
  `createdAt` DATETIME,
  `depth` INT,
  PRIMARY KEY (`nodeId`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `tagId` INT,
  `title` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`tagId`)
) CHARACTER SET latin1;

CREATE TABLE `nodeTag` (
  `nodeId` INT,
  `tagId` INT,
  PRIMARY KEY (`nodeId`, `tagId`)
) CHARACTER SET latin1;

CREATE TABLE `edit` (
  `editId` INT,
  `nodeId` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`editId`)
) CHARACTER SET latin1;

CREATE TABLE `dependency` (
  `nodeId` INT,
  `parentId` INT,
  `direct` BOOL,
  PRIMARY KEY (`nodeId`, `parentId`)
) CHARACTER SET latin1;

CREATE TABLE `dirtyNode` (
  `nodeId` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`nodeId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158552_up_00000_initial_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158552_up_00000_initial_structure') AS relationships;
DROP DATABASE `db_158552_up_00000_initial_structure`;
UNINSTALL EXTENSION vsql_schematron;
