INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 190385_hospital
--echo #
CREATE DATABASE `db_190385_hospital`;
USE `db_190385_hospital`;
CREATE TABLE `doctors` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `specialisation` VARCHAR(50),
  `phone` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
  `id` INT,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `id_doctor` INT,
  `notes` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_190385_hospital') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_190385_hospital') AS relationships;
DROP DATABASE `db_190385_hospital`;
UNINSTALL EXTENSION vsql_schematron;
