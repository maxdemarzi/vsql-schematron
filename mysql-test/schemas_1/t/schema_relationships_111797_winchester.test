INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 111797_winchester
--echo #
CREATE DATABASE `db_111797_winchester`;
USE `db_111797_winchester`;

CREATE TABLE `alembic_version` (
  `version_num` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `event_type` (
  `id` INT,
  `desc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event` (
  `id` INT,
  `message_id` VARCHAR(64),
  `generated` DECIMAL(10,2),
  `event_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `trait` (
  `event_id` INT,
  `name` VARCHAR(64),
  `type` INT,
  `t_string` VARCHAR(64),
  `t_float` DECIMAL(10,2),
  `t_int` INT,
  `t_datetime` DECIMAL(10,2),
  PRIMARY KEY (`event_id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `stream` (
  `id` INT,
  `first_event` DECIMAL(10,2),
  `last_event` DECIMAL(10,2),
  `expire_timestamp` DECIMAL(10,2),
  `fire_timestamp` DECIMAL(10,2),
  `name` VARCHAR(64),
  `state` INT,
  `state_serial_no` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dist_trait` (
  `stream_id` INT,
  `name` VARCHAR(64),
  `type` INT,
  `dt_string` VARCHAR(64),
  `dt_float` DECIMAL(10,2),
  `dt_int` INT,
  `dt_datetime` DECIMAL(10,2),
  `dt_timerange_begin` DECIMAL(10,2),
  `dt_timerange_end` DECIMAL(10,2),
  PRIMARY KEY (`stream_id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `streamevent` (
  `stream_id` INT,
  `event_id` INT,
  PRIMARY KEY (`stream_id`, `event_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_111797_winchester') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_111797_winchester') AS relationships;
DROP DATABASE `db_111797_winchester`;
UNINSTALL EXTENSION vsql_schematron;
