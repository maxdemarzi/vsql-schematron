INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160436_create_tables
--echo #
CREATE DATABASE `db_160436_create_tables`;
USE `db_160436_create_tables`;

CREATE TABLE `YEAR` (
  `id_year` INT,
  PRIMARY KEY (`id_year`)
) CHARACTER SET latin1;

CREATE TABLE `profesor` (
  `id_prof` INT,
  `nombre` VARCHAR(64),
  `apellidos` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id_prof`)
) CHARACTER SET latin1;

CREATE TABLE `asignatura` (
  `id_asig` INT,
  `id_prof` INT,
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id_asig`)
) CHARACTER SET latin1;

CREATE TABLE `cursadoEn` (
  `id_asig` INT,
  `id_year` INT,
  PRIMARY KEY (`id_asig`, `id_year`)
) CHARACTER SET latin1;

CREATE TABLE `examen` (
  `id_exam` INT,
  `id_asig` INT,
  `revision` VARCHAR(64),
  `titulo` VARCHAR(64),
  `fecha` DATETIME,
  `nota` DECIMAL(10,2),
  PRIMARY KEY (`id_exam`)
) CHARACTER SET latin1;

CREATE TABLE `actividad` (
  `id_act` INT,
  `id_asig` INT,
  `comentarios` VARCHAR(64),
  `titulo` VARCHAR(64),
  `fecha_limite` DATETIME,
  `fecha_entrega` DATETIME,
  `nota` DECIMAL(10,2),
  PRIMARY KEY (`id_act`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160436_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160436_create_tables') AS relationships;
DROP DATABASE `db_160436_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
