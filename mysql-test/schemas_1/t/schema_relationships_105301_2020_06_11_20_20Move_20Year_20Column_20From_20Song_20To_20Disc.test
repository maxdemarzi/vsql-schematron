INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song_20To_20Disc
--echo #
CREATE DATABASE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;
USE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;

CREATE TABLE `Folders` (
  `Id` INT,
  `ParentFolder_Id` INT,
  `Name` VARCHAR(255),
  `DeleteDate` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Discs` (
  `Id` INT,
  `Folder_Id` INT,
  `Year` INT,
  `Title` VARCHAR(255),
  `TreeTitle` VARCHAR(255),
  `AlbumTitle` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Artists` (
  `Id` INT,
  `Name` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Genres` (
  `Id` INT,
  `Name` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Songs` (
  `Id` INT,
  `Artist_Id` INT,
  `Disc_Id` INT,
  `Genre_Id` INT,
  `TrackNumber` INT,
  `Title` VARCHAR(255),
  `TreeTitle` VARCHAR(255),
  `Duration` DECIMAL(10,2),
  `Rating` INT,
  `FileSize` INT,
  `Checksum` INT,
  `Bitrate` INT,
  `LastPlaybackTime` DATETIME,
  `PlaybacksCount` INT,
  `DeleteDate` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Playbacks` (
  `Id` INT,
  `Song_Id` INT,
  `PlaybackTime` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `DiscImages` (
  `Id` INT,
  `Disc_Id` INT,
  `TreeTitle` VARCHAR(255),
  `ImageType` INT,
  `FileSize` INT,
  `Checksum` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song') AS relationships;
DROP DATABASE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;
UNINSTALL EXTENSION vsql_schematron;
