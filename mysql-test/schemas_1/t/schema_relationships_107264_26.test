INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107264_26
--echo #
CREATE DATABASE `db_107264_26`;
USE `db_107264_26`;
CREATE TABLE `chapter` (
  `id` INT NOT NULL,
  `num` INT,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `section` (
  `id` INT NOT NULL,
  `num` INT,
  `title` VARCHAR(50),
  `chapter_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entry` (
  `id` INT NOT NULL,
  `num` INT,
  `title` VARCHAR(50),
  `section_id` INT,
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107264_26') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107264_26') AS relationships;
DROP DATABASE `db_107264_26`;
UNINSTALL EXTENSION vsql_schematron;
