INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 118421_migration
--echo #
CREATE DATABASE `db_118421_migration`;
USE `db_118421_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `IsVoted` (
  `id` INT,
  `vorterId` VARCHAR(64),
  `votedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `VoteAggregate` (
  `id` INT,
  `isVotedWhere` INT,
  `voteId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Vote` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `leftImageTitle` VARCHAR(64),
  `rightImageTitle` VARCHAR(64),
  `endDateTime` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_118421_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_118421_migration') AS relationships;
DROP DATABASE `db_118421_migration`;
UNINSTALL EXTENSION vsql_schematron;
