INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 162549_V1__Init_DB
--echo #
CREATE DATABASE `db_162549_V1_Init_DB`;
USE `db_162549_V1_Init_DB`;

CREATE TABLE `usr` (
  `id` INT,
  `email` VARCHAR(64),
  `mobile` VARCHAR(64),
  `password` VARCHAR(64),
  `role` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `email` VARCHAR(64),
  `mobile` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ord` (
  `id` INT,
  `number` VARCHAR(64),
  `state` INT,
  `date_delivery` DATETIME,
  `id_client` INT,
  `address` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `task_call` (
  `id` INT,
  `state` INT,
  `description` VARCHAR(64),
  `date_create` DATETIME,
  `id_ord` INT,
  `id_courier` INT,
  `id_operator` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_162549_V1_Init_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_162549_V1_Init_DB') AS relationships;
DROP DATABASE `db_162549_V1_Init_DB`;
UNINSTALL EXTENSION vsql_schematron;
