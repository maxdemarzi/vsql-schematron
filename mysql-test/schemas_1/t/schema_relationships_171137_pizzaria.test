INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 171137_pizzaria
--echo #
CREATE DATABASE `db_171137_pizzaria`;
USE `db_171137_pizzaria`;
CREATE TABLE `tb_categoria` (
  `id` BIGINT NOT NULL,
  `tipo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pizza` (
  `id` BIGINT NOT NULL,
  `sabor` VARCHAR(50),
  `preço` DOUBLE,
  `categoria_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_171137_pizzaria') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_171137_pizzaria') AS relationships;
DROP DATABASE `db_171137_pizzaria`;
UNINSTALL EXTENSION vsql_schematron;
