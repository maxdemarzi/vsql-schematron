INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151415_hyperparameter
--echo #
CREATE DATABASE `db_151415_hyperparameter`;
USE `db_151415_hyperparameter`;

CREATE TABLE `data_repository` (
  `dataset_id` INT,
  `dataset_name` VARCHAR(64),
  PRIMARY KEY (`dataset_id`)
) CHARACTER SET latin1;

CREATE TABLE `predictors` (
  `dataset_id` INT,
  `predictor_name` VARCHAR(64),
  PRIMARY KEY (`dataset_id`, `predictor_name`)
) CHARACTER SET latin1;

CREATE TABLE `metadata` (
  `dataset_id` INT,
  `#project_name` VARCHAR(64),
  `#method` VARCHAR(64),
  `run_id` VARCHAR(64),
  `min_mem_size` INT,
  `scale` VARCHAR(64),
  `target` VARCHAR(64),
  `classification` VARCHAR(64),
  `execution_time` INT,
  `strat_time` DECIMAL(10,2),
  `project` VARCHAR(64),
  `end_time` DECIMAL(10,2),
  `nthreads` INT,
  `run_time` INT,
  `max_models` INT,
  `balance` VARCHAR(64),
  `balance_threshold` DECIMAL(10,2),
  PRIMARY KEY (`run_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151415_hyperparameter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151415_hyperparameter') AS relationships;
DROP DATABASE `db_151415_hyperparameter`;
UNINSTALL EXTENSION vsql_schematron;
