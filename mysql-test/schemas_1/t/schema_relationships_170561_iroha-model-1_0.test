INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 170561_iroha-model-1.0
--echo #
CREATE DATABASE `db_170561_iroha_model_1_0`;
USE `db_170561_iroha_model_1_0`;
CREATE TABLE `transaction` (
  `id` BIGINT NOT NULL,
  `creator_id` VARCHAR(50),
  `quorum` INT,
  `rejected` BOOLEAN,
  `batch_id` BIGINT,
  `block_number` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.command` (
  `dtype` VARCHAR(50),
  `id` BIGINT NOT NULL,
  `account_id` VARCHAR(50),
  `detail_key` VARCHAR(50),
  `detail_value` VARCHAR(50),
  `public_key` VARCHAR(50),
  `amount` DECIMAL(10,2),
  `asset_id` VARCHAR(50),
  `description` VARCHAR(50),
  `dest_account_id` VARCHAR(50),
  `src_account_id` VARCHAR(50),
  `quorum` INT,
  `asset_name` VARCHAR(50),
  `decimal_precision` INT,
  `domain_id` VARCHAR(50),
  `account_name` VARCHAR(50),
  `transaction_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_170561_iroha_model_1_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_170561_iroha_model_1_0') AS relationships;
DROP DATABASE `db_170561_iroha_model_1_0`;
UNINSTALL EXTENSION vsql_schematron;
