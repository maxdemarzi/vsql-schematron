INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152055_01-initial
--echo #
CREATE DATABASE `db_152055_01_initial`;
USE `db_152055_01_initial`;

CREATE TABLE `user` (
  `uuid` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`user`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `instance` (
  `uuid` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `user_otp` (
  `id` INT,
  `user` VARCHAR(64),
  `password` VARCHAR(64),
  `created` DATETIME,
  `deactivated` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user_instance` (
  `user` VARCHAR(64),
  `instance_id` VARCHAR(64),
  PRIMARY KEY (`user`, `instance_id`)
) CHARACTER SET latin1;

CREATE TABLE `token` (
  `id` INT,
  `token` VARCHAR(64),
  `user` VARCHAR(64),
  `created` DATETIME,
  `expires` DATETIME,
  `last_use` DATETIME,
  `deactivated` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_reset_token` (
  `id` INT,
  `token` VARCHAR(64),
  `user` VARCHAR(64),
  `created` DATETIME,
  `expires` DATETIME,
  `used` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152055_01_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152055_01_initial') AS relationships;
DROP DATABASE `db_152055_01_initial`;
UNINSTALL EXTENSION vsql_schematron;
