INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188855_create
--echo #
CREATE DATABASE `db_188855_create`;
USE `db_188855_create`;

CREATE TABLE `users1` (
  `id` INT,
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `age` INT,
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `news1` (
  `id` INT,
  `title` VARCHAR(64),
  `text` VARCHAR(64),
  `date` VARCHAR(64),
  `views` INT,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188855_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188855_create') AS relationships;
DROP DATABASE `db_188855_create`;
UNINSTALL EXTENSION vsql_schematron;
