INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 109324_patch10
--echo #
CREATE DATABASE `db_109324_patch10`;
USE `db_109324_patch10`;
CREATE TABLE `tag` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `color` VARCHAR(50),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `monitor_tag` (
  `id` INT NOT NULL,
  `monitor_id` INT,
  `tag_id` INT,
  `value` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_109324_patch10') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_109324_patch10') AS relationships;
DROP DATABASE `db_109324_patch10`;
UNINSTALL EXTENSION vsql_schematron;
