INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 140029_create_all_tables
--echo #
CREATE DATABASE `db_140029_create_all_tables`;
USE `db_140029_create_all_tables`;

CREATE TABLE `function` (
  `function_id` DECIMAL(10,2),
  `function_name` VARCHAR(64),
  `function_body_id` DECIMAL(10,2),
  PRIMARY KEY (`function_id`)
) CHARACTER SET latin1;

CREATE TABLE `function_body` (
  `function_body_id` DECIMAL(10,2),
  `body_content` VARCHAR(64),
  PRIMARY KEY (`function_body_id`)
) CHARACTER SET latin1;

CREATE TABLE `service` (
  `service_id` DECIMAL(10,2),
  `service_name` VARCHAR(64),
  `parent_service_id` DECIMAL(10,2),
  PRIMARY KEY (`service_id`)
) CHARACTER SET latin1;

CREATE TABLE `test_domain` (
  `id` DECIMAL(10,2),
  `code` VARCHAR(64),
  `libelle` VARCHAR(64),
  `a_do_date` DATETIME,
  `a_do_commentaire` VARCHAR(64),
  `a_do_fichier` VARCHAR(64),
  `a_do_libelle_court` VARCHAR(64),
  `a_do_libelle_long` VARCHAR(64),
  `a_do_mot_passe` VARCHAR(64),
  `a_do_nom` VARCHAR(64),
  `a_do_nombre_court` DECIMAL(10,2),
  `a_do_nombre_long` DECIMAL(10,2),
  `a_do_ordre_repartition` VARCHAR(64),
  `a_do_oui_non` DECIMAL(10,2),
  `a_do_texte_riche` VARCHAR(64),
  `a_do_date_heure` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` DECIMAL(10,2),
  `user_name` VARCHAR(64),
  `user_surname` VARCHAR(64),
  `workplace_service_id` DECIMAL(10,2),
  `service_id` DECIMAL(10,2),
  `type_id` DECIMAL(10,2),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_function_assoc` (
  `user_id` DECIMAL(10,2),
  `my_function_id` DECIMAL(10,2),
  PRIMARY KEY (`user_id`, `my_function_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_type` (
  `type_id` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;

CREATE TABLE `double_key` (
  `pk_one` DECIMAL(10,2),
  `pk_two` DECIMAL(10,2),
  `string_data` VARCHAR(64),
  PRIMARY KEY (`pk_one`, `pk_two`)
) CHARACTER SET latin1;

CREATE TABLE `parameter` (
  `param_id` DECIMAL(10,2),
  `version` DECIMAL(10,2),
  `pk_one` DECIMAL(10,2),
  `pk_two` DECIMAL(10,2),
  PRIMARY KEY (`param_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_140029_create_all_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_140029_create_all_tables') AS relationships;
DROP DATABASE `db_140029_create_all_tables`;
UNINSTALL EXTENSION vsql_schematron;
