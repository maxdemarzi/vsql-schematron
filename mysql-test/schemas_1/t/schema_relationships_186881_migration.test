INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186881_migration
--echo #
CREATE DATABASE `db_186881_migration`;
USE `db_186881_migration`;

CREATE TABLE `User` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `username` VARCHAR(64),
  `displayname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tweet` (
  `id` INT,
  `createdAt` DATETIME,
  `text` VARCHAR(64),
  `image` VARCHAR(64),
  `authorId` INT,
  `commentAmount` INT,
  `retweetAmount` INT,
  `likeAmount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Like` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LikesOnTweets` (
  `tweetId` INT,
  `userId` INT,
  `createdAt` DATETIME,
  `likeId` INT,
  PRIMARY KEY (`tweetId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `_UserFollows` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186881_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186881_migration') AS relationships;
DROP DATABASE `db_186881_migration`;
UNINSTALL EXTENSION vsql_schematron;
