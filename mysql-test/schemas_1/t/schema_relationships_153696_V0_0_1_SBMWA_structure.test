INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153696_V0_0_1_SBMWA_structure
--echo #
CREATE DATABASE `db_153696_V0_0_1_SBMWA_structure`;
USE `db_153696_V0_0_1_SBMWA_structure`;

CREATE TABLE `address` (
  `id` INT,
  `created_date` DATETIME,
  `last_modified_date` DATETIME,
  `city` VARCHAR(64),
  `zipcode` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `created_date` DATETIME,
  `last_modified_date` DATETIME,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `mobile_number` VARCHAR(64),
  `dob` DATETIME,
  `gender` VARCHAR(64),
  `is_adult` VARCHAR(64),
  `age` INT,
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `created_date` DATETIME,
  `last_modified_date` DATETIME,
  `title` VARCHAR(64),
  `person_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` INT,
  `created_date` DATETIME,
  `last_modified_date` DATETIME,
  `movie_details` VARCHAR(64),
  `person_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153696_V0_0_1_SBMWA_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153696_V0_0_1_SBMWA_structure') AS relationships;
DROP DATABASE `db_153696_V0_0_1_SBMWA_structure`;
UNINSTALL EXTENSION vsql_schematron;
