INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 102233_input
--echo #
CREATE DATABASE `db_102233_input`;
USE `db_102233_input`;
CREATE TABLE `ELECTION_TABLE` (
  `ELECTION_ID` DECIMAL(10,2) NOT NULL,
  `ELECTION_NAME` VARCHAR(50),
  `ELECTION_DESC` VARCHAR(50),
  `ELECTION_POINT` DECIMAL(10,2),
  PRIMARY KEY (`ELECTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MICRO_GAME_USER` (
  `USER_ID` INT NOT NULL,
  `USER_NAME` VARCHAR(50),
  `UPDATE_TIME` DATE,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `LATEST_RESULT_TABLE` (
  `USER_ID` INT,
  `USER_SCORE` VARCHAR(50),
  `UPDATE_TIME` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_102233_input') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_102233_input') AS relationships;
DROP DATABASE `db_102233_input`;
UNINSTALL EXTENSION vsql_schematron;
