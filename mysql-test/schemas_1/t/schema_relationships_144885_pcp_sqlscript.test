INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 144885_pcp-sqlscript
--echo #
CREATE DATABASE `db_144885_pcp_sqlscript`;
USE `db_144885_pcp_sqlscript`;

CREATE TABLE `users` (
  `uid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `computer` (
  `cid` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `picture` VARCHAR(64),
  `created` DATETIME,
  `entrycreatorfk` INT,
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_144885_pcp_sqlscript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_144885_pcp_sqlscript') AS relationships;
DROP DATABASE `db_144885_pcp_sqlscript`;
UNINSTALL EXTENSION vsql_schematron;
