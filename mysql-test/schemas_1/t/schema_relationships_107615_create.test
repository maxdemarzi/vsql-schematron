INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107615_create
--echo #
CREATE DATABASE `db_107615_create`;
USE `db_107615_create`;
CREATE TABLE `a03_title` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `body` TEXT,
  `words` VARCHAR(50),
  `updated` TIMESTAMP NULL,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `a03_title_to_tag` (
  `id` VARCHAR(50) NOT NULL,
  `title_id` VARCHAR(50),
  `tag_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `a03_tags` (
  `id` VARCHAR(50) NOT NULL,
  `tag` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107615_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107615_create') AS relationships;
DROP DATABASE `db_107615_create`;
UNINSTALL EXTENSION vsql_schematron;
