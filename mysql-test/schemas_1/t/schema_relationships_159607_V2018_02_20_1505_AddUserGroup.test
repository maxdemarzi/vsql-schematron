INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159607_V2018.02.20.1505__AddUserGroup
--echo #
CREATE DATABASE `db_159607_V2018_02_20_1505_AddUserGroup`;
USE `db_159607_V2018_02_20_1505_AddUserGroup`;

CREATE TABLE `user_group` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_group_membership` (
  `username` VARCHAR(64),
  `user_group` VARCHAR(64),
  PRIMARY KEY (`username`, `user_group`)
) CHARACTER SET latin1;

CREATE TABLE `user_group_role` (
  `user_group` VARCHAR(64),
  `role` INT,
  `scope_id` VARCHAR(64),
  PRIMARY KEY (`user_group`, `role`, `scope_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159607_V2018_02_20_1505_AddUserGroup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159607_V2018_02_20_1505_AddUserGroup') AS relationships;
DROP DATABASE `db_159607_V2018_02_20_1505_AddUserGroup`;
UNINSTALL EXTENSION vsql_schematron;
