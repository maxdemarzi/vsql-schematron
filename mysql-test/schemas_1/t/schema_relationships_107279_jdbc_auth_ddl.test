INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107279_jdbc-auth-ddl
--echo #
CREATE DATABASE `db_107279_jdbc_auth_ddl`;
USE `db_107279_jdbc_auth_ddl`;

CREATE TABLE `user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `password_salt` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `username` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`username`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `roles_perms` (
  `role` VARCHAR(64),
  `perm` VARCHAR(64),
  PRIMARY KEY (`role`, `perm`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107279_jdbc_auth_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107279_jdbc_auth_ddl') AS relationships;
DROP DATABASE `db_107279_jdbc_auth_ddl`;
UNINSTALL EXTENSION vsql_schematron;
