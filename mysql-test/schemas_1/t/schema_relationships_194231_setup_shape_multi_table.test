INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 194231_setup-shape-multi-table
--echo #
CREATE DATABASE `db_194231_setup_shape_multi_table`;
USE `db_194231_setup_shape_multi_table`;

CREATE TABLE `drawing` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shape` (
  `id` INT,
  `type` VARCHAR(64),
  `color` VARCHAR(64),
  `drawingId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shapecolorhistory` (
  `id` INT,
  `shapeId` INT,
  `dateChanged` DATETIME,
  `colorName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `circle` (
  `id` INT,
  `radius` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rectangle` (
  `id` INT,
  `width` INT,
  `height` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cornercoordinates` (
  `id` INT,
  `shapeId` INT,
  `x` INT,
  `y` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_194231_setup_shape_multi_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_194231_setup_shape_multi_table') AS relationships;
DROP DATABASE `db_194231_setup_shape_multi_table`;
UNINSTALL EXTENSION vsql_schematron;
