INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 198140_CreateTables
--echo #
CREATE DATABASE `db_198140_CreateTables`;
USE `db_198140_CreateTables`;
CREATE TABLE `Pages` (
  `PageID` INT NOT NULL,
  `PageName` TEXT,
  `BookName` TEXT,
  PRIMARY KEY (`PageID`)
) CHARACTER SET latin1;
CREATE TABLE `Content` (
  `ID` INT NOT NULL,
  `PageID` INT,
  `Valid` INT,
  `Body` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Linked` (
  `Name` TEXT,
  `Book` TEXT
) CHARACTER SET latin1;
CREATE TABLE `Dates` (
  `PageID` INT,
  `Year` INT,
  `EraName` INT,
  `EraOrder` INT,
  `Reversed` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_198140_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_198140_CreateTables') AS relationships;
DROP DATABASE `db_198140_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
