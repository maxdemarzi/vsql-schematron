INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 149338_saude_tec
--echo #
CREATE DATABASE `db_149338_saude_tec`;
USE `db_149338_saude_tec`;

CREATE TABLE `saude_tec.login` (
  `idlogin` INT,
  `login` VARCHAR(64),
  `senha` VARCHAR(64),
  PRIMARY KEY (`idlogin`)
) CHARACTER SET latin1;

CREATE TABLE `saude_tec.usuario` (
  `nome` VARCHAR(64),
  `email` VARCHAR(64),
  `peso` DECIMAL(10,2),
  `caloriasDiarias` INT,
  `login_idlogin` INT,
  PRIMARY KEY (`login_idlogin`)
) CHARACTER SET latin1;

CREATE TABLE `saude_tec.alimento` (
  `idalimento` INT,
  `qrcode` VARCHAR(64),
  `nome` VARCHAR(64),
  `calorias` INT,
  `foto` VARCHAR(64),
  PRIMARY KEY (`idalimento`)
) CHARACTER SET latin1;

CREATE TABLE `saude_tec.usuario_has_alimento` (
  `usuario_login_idlogin` INT,
  `alimento_idalimento` INT,
  `data` DATETIME,
  PRIMARY KEY (`usuario_login_idlogin`, `alimento_idalimento`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_149338_saude_tec') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_149338_saude_tec') AS relationships;
DROP DATABASE `db_149338_saude_tec`;
UNINSTALL EXTENSION vsql_schematron;
