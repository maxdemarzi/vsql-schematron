INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142518_1
--echo #
CREATE DATABASE `db_142518_1`;
USE `db_142518_1`;

CREATE TABLE `ACTOR` (
  `ID` DECIMAL(10,2),
  `FNAME` VARCHAR(64),
  `LNAME` VARCHAR(64),
  `GENDER` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MOVIE` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `YEAR` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DIRECTORS` (
  `ID` DECIMAL(10,2),
  `FNAME` VARCHAR(64),
  `LNAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CASTS` (
  `PID` DECIMAL(10,2),
  `MID` DECIMAL(10,2),
  `ROLE` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `MOVIE_DIRECTORS` (
  `DID` DECIMAL(10,2),
  `MID` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `GENRE` (
  `MID` DECIMAL(10,2),
  `GENRE` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142518_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142518_1') AS relationships;
DROP DATABASE `db_142518_1`;
UNINSTALL EXTENSION vsql_schematron;
