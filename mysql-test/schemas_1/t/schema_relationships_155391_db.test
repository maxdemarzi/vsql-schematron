INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 155391_db
--echo #
CREATE DATABASE `db_155391_db`;
USE `db_155391_db`;
CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(50),
  `ip` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `links` (
  `token` INT,
  `nickname` VARCHAR(50),
  `message` VARCHAR(50),
  `ip` TEXT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_155391_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_155391_db') AS relationships;
DROP DATABASE `db_155391_db`;
UNINSTALL EXTENSION vsql_schematron;
