INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160989_database
--echo #
CREATE DATABASE `db_160989_database`;
USE `db_160989_database`;

CREATE TABLE `users` (
  `id` INT,
  `sub` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `text` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `post_id` INT,
  `path` VARCHAR(64),
  PRIMARY KEY (`post_id`, `path`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`post_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `post_id` INT,
  `user_id` INT,
  `text` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160989_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160989_database') AS relationships;
DROP DATABASE `db_160989_database`;
UNINSTALL EXTENSION vsql_schematron;
