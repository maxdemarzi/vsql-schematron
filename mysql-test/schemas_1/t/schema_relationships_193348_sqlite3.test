INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193348_sqlite3
--echo #
CREATE DATABASE `db_193348_sqlite3`;
USE `db_193348_sqlite3`;
CREATE TABLE `product` (
  `id` INT NOT NULL,
  `name` TEXT,
  `type` INT,
  `user_id` INT,
  `description` TEXT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` TEXT,
  `age` INT,
  `message` TEXT,
  `icon_image` BLOB,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193348_sqlite3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193348_sqlite3') AS relationships;
DROP DATABASE `db_193348_sqlite3`;
UNINSTALL EXTENSION vsql_schematron;
