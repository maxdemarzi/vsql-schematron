INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 141948_up
--echo #
CREATE DATABASE `db_141948_up`;
USE `db_141948_up`;

CREATE TABLE `threads` (
  `id` INT,
  `last_reply_no` INT,
  `bump` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `thread_id` INT,
  `no` INT,
  `name` VARCHAR(64),
  `trip` VARCHAR(64),
  `sender` VARCHAR(64),
  `text` VARCHAR(64),
  `ts` DATETIME,
  PRIMARY KEY (`thread_id`, `no`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_141948_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_141948_up') AS relationships;
DROP DATABASE `db_141948_up`;
UNINSTALL EXTENSION vsql_schematron;
