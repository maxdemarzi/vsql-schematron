INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113732_Database
--echo #
CREATE DATABASE `db_113732_Database`;
USE `db_113732_Database`;
CREATE TABLE `KHACHHANG` (
  `MAKH` INT NOT NULL,
  `HOTEN` VARCHAR(50),
  `SOCMND` CHAR(50),
  `NGAYDEN` DATE,
  `MAPHONG` CHAR(50),
  `TinhTrangTT` VARCHAR(50),
  PRIMARY KEY (`MAKH`)
) CHARACTER SET latin1;
CREATE TABLE `PHONG` (
  `MAPHONG` VARCHAR(50) NOT NULL,
  `SOGIUONG` INT,
  `DONGIA` INT,
  `TINHTRANG` VARCHAR(50),
  PRIMARY KEY (`MAPHONG`)
) CHARACTER SET latin1;
CREATE TABLE `THONGKEGIAODICH` (
  `MAGD` INT NOT NULL,
  `MAKH` INT,
  `MAPHONG` CHAR(50),
  `NGAYDEN` DATETIME,
  `NGAYDI` DATE,
  `SOTIENDATHANHTOAN` INT,
  PRIMARY KEY (`MAGD`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
  `TaiKhoan` VARCHAR(50),
  `MatKhau` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113732_Database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113732_Database') AS relationships;
DROP DATABASE `db_113732_Database`;
UNINSTALL EXTENSION vsql_schematron;
