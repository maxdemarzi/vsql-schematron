INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 140149_hourglass
--echo #
CREATE DATABASE `db_140149_hourglass`;
USE `db_140149_hourglass`;

CREATE TABLE `boards` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tasks_notes` (
  `tnid` INT,
  `id` INT,
  `description` VARCHAR(64),
  `date` VARCHAR(64),
  `due_date` VARCHAR(64),
  `completed` INT,
  `type` VARCHAR(64),
  `recurring` INT,
  `repeat` INT,
  `board` VARCHAR(64),
  PRIMARY KEY (`tnid`)
) CHARACTER SET latin1;

CREATE TABLE `archives` (
  `id` INT,
  `description` VARCHAR(64),
  `date` VARCHAR(64),
  `type` VARCHAR(64),
  `board` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_140149_hourglass') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_140149_hourglass') AS relationships;
DROP DATABASE `db_140149_hourglass`;
UNINSTALL EXTENSION vsql_schematron;
