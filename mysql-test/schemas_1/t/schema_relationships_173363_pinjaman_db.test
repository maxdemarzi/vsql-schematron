INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 173363_pinjaman-db
--echo #
CREATE DATABASE `db_173363_pinjaman_db`;
USE `db_173363_pinjaman_db`;

CREATE TABLE `admins` (
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `transactions` (
  `id` INT,
  `nik` VARCHAR(64),
  `jumlah` INT,
  `tenggat_waktu` DATETIME,
  `biaya_admin` INT,
  `total_pinjaman` INT,
  `bank` VARCHAR(64),
  `no_rekening` VARCHAR(64),
  `status` VARCHAR(64),
  `waktu_pembayaran` DATETIME,
  `date_created` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `nik` VARCHAR(64),
  `nama` VARCHAR(64),
  `no_telepon` VARCHAR(64),
  `email` VARCHAR(64),
  `nama_orang_tua` VARCHAR(64),
  `pendidikan_terakhir` VARCHAR(64),
  `status_perkawinan` VARCHAR(64),
  `alamat` VARCHAR(64),
  `nama_perusahaan` VARCHAR(64),
  `status_pekerjaan` VARCHAR(64),
  `posisi` VARCHAR(64),
  `lama_bekerja` INT,
  `penghasilan_per_bulan` INT,
  `pin` VARCHAR(64),
  `role` VARCHAR(64),
  `limit_pinjaman` INT,
  `sisa_limit` INT,
  `status` VARCHAR(64),
  `otp` VARCHAR(64),
  `otp_expired` DATETIME,
  `date_created` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_173363_pinjaman_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_173363_pinjaman_db') AS relationships;
DROP DATABASE `db_173363_pinjaman_db`;
UNINSTALL EXTENSION vsql_schematron;
