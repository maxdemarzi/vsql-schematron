INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145266_laba3
--echo #
CREATE DATABASE `db_145266_laba3`;
USE `db_145266_laba3`;
CREATE TABLE `AirCarrier` (
  `idAirCarrier` INT NOT NULL,
  `name` TEXT,
  `workers` INT,
  PRIMARY KEY (`idAirCarrier`)
) CHARACTER SET latin1;
CREATE TABLE `Plane` (
  `idPlane` INT NOT NULL,
  `Stamp` VARCHAR(50),
  `Places` INT,
  `Type` VARCHAR(50),
  `Speed` DOUBLE,
  `AirCarrier_idAirCarrier` INT,
  PRIMARY KEY (`idPlane`)
) CHARACTER SET latin1;
CREATE TABLE `Trip` (
  `idTrip` INT NOT NULL,
  `pointdeparture` VARCHAR(50),
  `Destination` VARCHAR(50),
  `Date_departure` DATE,
  `Date_destination` DATE,
  `Distance` DOUBLE,
  `Tickets_sold` INT,
  PRIMARY KEY (`idTrip`)
) CHARACTER SET latin1;
CREATE TABLE `Member` (
  `idMember` INT NOT NULL,
  `Name` VARCHAR(50),
  `Age` INT,
  `Role` VARCHAR(50),
  `Age_experience` INT,
  PRIMARY KEY (`idMember`)
) CHARACTER SET latin1;
CREATE TABLE `Crew` (
  `idCrew` INT NOT NULL,
  `Staff` INT,
  `Member_idMember` INT,
  PRIMARY KEY (`idCrew`)
) CHARACTER SET latin1;
CREATE TABLE `Transit_landings` (
  `idTransit_landings` INT NOT NULL,
  `Point_landings` VARCHAR(50),
  `Date_landings` DATE,
  PRIMARY KEY (`idTransit_landings`)
) CHARACTER SET latin1;
CREATE TABLE `Fly` (
  `Plane_idPlane` INT NOT NULL,
  `Trip_idTrip` INT NOT NULL,
  `Route` VARCHAR(50),
  `Transit_landings_idTransit_landings` INT,
  `Crew_idCrew` INT,
  PRIMARY KEY (`Plane_idPlane`, `Trip_idTrip`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145266_laba3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145266_laba3') AS relationships;
DROP DATABASE `db_145266_laba3`;
UNINSTALL EXTENSION vsql_schematron;
