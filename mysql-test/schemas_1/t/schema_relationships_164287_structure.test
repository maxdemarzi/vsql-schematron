INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 164287_structure
--echo #
CREATE DATABASE `db_164287_structure`;
USE `db_164287_structure`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` TEXT,
  `key` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emails` (
  `id` INT NOT NULL,
  `user_id` INT,
  `email` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_164287_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_164287_structure') AS relationships;
DROP DATABASE `db_164287_structure`;
UNINSTALL EXTENSION vsql_schematron;
