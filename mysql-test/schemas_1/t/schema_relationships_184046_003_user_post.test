INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184046_003-user-post
--echo #
CREATE DATABASE `db_184046_003_user_post`;
USE `db_184046_003_user_post`;

CREATE TABLE `user` (
  `id` VARCHAR(64),
  `authKey` VARCHAR(64),
  `email` VARCHAR(64),
  `nickName` VARCHAR(64),
  `isCool` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `id` VARCHAR(64),
  `writer` VARCHAR(64),
  `body` VARCHAR(64),
  `title` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184046_003_user_post') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184046_003_user_post') AS relationships;
DROP DATABASE `db_184046_003_user_post`;
UNINSTALL EXTENSION vsql_schematron;
