INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106593_V2_0__create_model_and_process_tables
--echo #
CREATE DATABASE `db_106593_V2_0_create_model_and_process_tables`;
USE `db_106593_V2_0_create_model_and_process_tables`;

CREATE TABLE `T_MODEL_STATE` (
  `ID` INT,
  `STATE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_MODEL_EDGE` (
  `ID` INT,
  `FROM_ID` INT,
  `TO_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_MODEL_ACTION` (
  `ID` INT,
  `ACTION` VARCHAR(64),
  `TYPE` VARCHAR(64),
  `EDGE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_MODEL_GUARD` (
  `ID` INT,
  `GUARD` VARCHAR(64),
  `EDGE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_PROCESS_STATE` (
  `ID` INT,
  `DOMAINOBJECT_NAME` VARCHAR(64),
  `DOMAINOBJECT_ID` INT,
  `PARENT_ID` INT,
  `STATE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106593_V2_0_create_model_and_process_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106593_V2_0_create_model_and_process_tables') AS relationships;
DROP DATABASE `db_106593_V2_0_create_model_and_process_tables`;
UNINSTALL EXTENSION vsql_schematron;
