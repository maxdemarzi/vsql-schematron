INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159313_1_4
--echo #
CREATE DATABASE `db_159313_1_4`;
USE `db_159313_1_4`;

CREATE TABLE `P` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `C` (
  `A` INT,
  `B` INT,
  PRIMARY KEY (`A`, `B`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159313_1_4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159313_1_4') AS relationships;
DROP DATABASE `db_159313_1_4`;
UNINSTALL EXTENSION vsql_schematron;
