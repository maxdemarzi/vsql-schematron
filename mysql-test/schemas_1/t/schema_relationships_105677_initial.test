INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 105677_initial
--echo #
CREATE DATABASE `db_105677_initial`;
USE `db_105677_initial`;
CREATE TABLE `forum` (
  `id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT,
  `name` TEXT
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT,
  `data` TEXT,
  `user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT,
  `data` TEXT,
  `user_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_105677_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_105677_initial') AS relationships;
DROP DATABASE `db_105677_initial`;
UNINSTALL EXTENSION vsql_schematron;
