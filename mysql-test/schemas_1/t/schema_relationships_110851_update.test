INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110851_update
--echo #
CREATE DATABASE `db_110851_update`;
USE `db_110851_update`;

CREATE TABLE `assignments` (
  `assignment_id` VARCHAR(64),
  `title` VARCHAR(64),
  `teacher_id` INT,
  `class_id` INT,
  `fileID` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `description` VARCHAR(64),
  `due_date` DATETIME,
  `subject_id` INT,
  PRIMARY KEY (`assignment_id`)
) CHARACTER SET latin1;

CREATE TABLE `classes` (
  `class_id` INT,
  `name` VARCHAR(64),
  `teacher_id` INT,
  `prefect_id` INT,
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `message_id` INT,
  `body` VARCHAR(64),
  `destination` VARCHAR(64),
  `origin` VARCHAR(64),
  `read_status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted` INT,
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;

CREATE TABLE `schedule` (
  `schedule_id` INT,
  `DAY` VARCHAR(64),
  `start_time` DATETIME,
  `class_id` INT,
  `subject_id` INT,
  `teacher_id` INT,
  PRIMARY KEY (`schedule_id`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `student_id` INT,
  `name` VARCHAR(64),
  `hash` VARCHAR(64),
  `birthday` VARCHAR(64),
  `sex` VARCHAR(64),
  `religion` VARCHAR(64),
  `blood_group` VARCHAR(64),
  `address` VARCHAR(64),
  `parent_phone` VARCHAR(64),
  `parent_email` VARCHAR(64),
  `password` VARCHAR(64),
  `father_name` VARCHAR(64),
  `mother_name` VARCHAR(64),
  `class_id` INT,
  `role` VARCHAR(64),
  `profileUrl` VARCHAR(64),
  `authentication_key` VARCHAR(64),
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `subject_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjectteacher` (
  `subject_id` INT,
  `teacher_id` INT
) CHARACTER SET latin1;

CREATE TABLE `submissions` (
  `submission_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `fileID` VARCHAR(64),
  `student_id` INT,
  `assignment_id` VARCHAR(64),
  PRIMARY KEY (`submission_id`)
) CHARACTER SET latin1;

CREATE TABLE `teacherclass` (
  `class_id` INT,
  `teacher_id` INT
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `teacher_id` INT,
  `hash` VARCHAR(64),
  `name` VARCHAR(64),
  `birthday` VARCHAR(64),
  `sex` VARCHAR(64),
  `religion` VARCHAR(64),
  `profileUrl` VARCHAR(64),
  `blood_group` VARCHAR(64),
  `role` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `country` VARCHAR(64),
  `county` VARCHAR(64),
  `subjects` VARCHAR(64),
  `authentication_key` VARCHAR(64),
  PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110851_update') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110851_update') AS relationships;
DROP DATABASE `db_110851_update`;
UNINSTALL EXTENSION vsql_schematron;
