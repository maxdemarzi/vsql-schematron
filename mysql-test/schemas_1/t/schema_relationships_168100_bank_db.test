INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 168100_bank_db
--echo #
CREATE DATABASE `db_168100_bank_db`;
USE `db_168100_bank_db`;

CREATE TABLE `department` (
  `dept_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `branch_id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  PRIMARY KEY (`branch_id`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `emp_id` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `superior_emp_id` INT,
  `dept_id` INT,
  `title` VARCHAR(64),
  `assigned_branch_id` INT,
  PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;

CREATE TABLE `product_type` (
  `product_type_cd` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`product_type_cd`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `product_cd` VARCHAR(64),
  `name` VARCHAR(64),
  `product_type_cd` VARCHAR(64),
  `date_offered` DATETIME,
  `date_retired` DATETIME,
  PRIMARY KEY (`product_cd`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `cust_id` INT,
  `fed_id` VARCHAR(64),
  `cust_type_cd` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `postal_code` VARCHAR(64),
  PRIMARY KEY (`cust_id`)
) CHARACTER SET latin1;

CREATE TABLE `individual` (
  `cust_id` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `birth_date` DATETIME,
  PRIMARY KEY (`cust_id`)
) CHARACTER SET latin1;

CREATE TABLE `business` (
  `cust_id` INT,
  `name` VARCHAR(64),
  `state_id` VARCHAR(64),
  `incorp_date` DATETIME,
  PRIMARY KEY (`cust_id`)
) CHARACTER SET latin1;

CREATE TABLE `officer` (
  `officer_id` INT,
  `cust_id` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `title` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  PRIMARY KEY (`officer_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_168100_bank_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_168100_bank_db') AS relationships;
DROP DATABASE `db_168100_bank_db`;
UNINSTALL EXTENSION vsql_schematron;
