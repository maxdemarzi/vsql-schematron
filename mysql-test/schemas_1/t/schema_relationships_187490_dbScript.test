INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187490_dbScript
--echo #
CREATE DATABASE `db_187490_dbScript`;
USE `db_187490_dbScript`;
CREATE TABLE `USER` (
  `ID` INT NOT NULL,
  `PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `OFFERINGS` (
  `ID` INT NOT NULL,
  `CLASS_ID` INT,
  `SEMESTER` DATE,
  `DONE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENTS` (
  `ID` INT NOT NULL,
  `OFFERING_ID` INT,
  `OPENING` DATE,
  `CLOSE` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSOCIATIONS` (
  `DOCUMENT1` INT,
  `DOCUMENT2` INT,
  `INDEX1` INT,
  `INDEX2` INT,
  `SIMILARITY` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187490_dbScript') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187490_dbScript') AS relationships;
DROP DATABASE `db_187490_dbScript`;
UNINSTALL EXTENSION vsql_schematron;
