INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193044_chika_medika
--echo #
CREATE DATABASE `db_193044_chika_medika`;
USE `db_193044_chika_medika`;
CREATE TABLE `konsultasi` (
  `tanggal` TIMESTAMP NULL,
  `anamnese` VARCHAR(50),
  `nomenklatur` VARCHAR(50),
  `diagnosa` VARCHAR(50),
  `tindakan` VARCHAR(50),
  `resep` VARCHAR(50),
  `keterangan` VARCHAR(50),
  `visit` INT,
  `id_pasien` INT
) CHARACTER SET latin1;
CREATE TABLE `pasien` (
  `id_pasien` INT NOT NULL,
  `nama_pasien` VARCHAR(50),
  `tgl_lahir` DATE,
  `jk` CHAR(50),
  `alamat` VARCHAR(50),
  `no_telp` VARCHAR(50),
  PRIMARY KEY (`id_pasien`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `nama_depan` VARCHAR(50),
  `nama_belakang` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193044_chika_medika') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193044_chika_medika') AS relationships;
DROP DATABASE `db_193044_chika_medika`;
UNINSTALL EXTENSION vsql_schematron;
