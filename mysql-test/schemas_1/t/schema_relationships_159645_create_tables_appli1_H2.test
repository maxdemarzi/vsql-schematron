INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159645_create_tables_appli1_H2
--echo #
CREATE DATABASE `db_159645_create_tables_appli1_H2`;
USE `db_159645_create_tables_appli1_H2`;

CREATE TABLE `AW_PERSONNE` (
  `PERSONNE_ID` DECIMAL(10,2),
  `NOM` VARCHAR(64),
  `PRENOM` VARCHAR(64),
  `CIVIL` DECIMAL(10,2),
  `DATE_NAISSANCE` DATETIME,
  `SALAIRE` DECIMAL(10,2),
  `VERSION` DATETIME,
  `GRADE_ID` DECIMAL(10,2),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`PERSONNE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_COMPETENCE_ID` (
  `PERSONNE_ID` DECIMAL(10,2),
  `COMPETENCE_ID` DECIMAL(10,2),
  PRIMARY KEY (`PERSONNE_ID`, `COMPETENCE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_ADRESSE` (
  `adresse_id` DECIMAL(10,2),
  `RUE` VARCHAR(64),
  `CODEPOSTAL` DECIMAL(10,2),
  `VILLE` VARCHAR(64),
  `PERSONNE_ID` DECIMAL(10,2),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`adresse_id`)
) CHARACTER SET latin1;

CREATE TABLE `AW_COMPETENCE` (
  `COMPETENCE_ID` DECIMAL(10,2),
  `LIBELLE` VARCHAR(64),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`COMPETENCE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_COMPETENCE_PERSO` (
  `COMPETENCE_PERSO_ID` DECIMAL(10,2),
  `LIBELLE` VARCHAR(64),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`COMPETENCE_PERSO_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_PERSONNE_N_COMPETENCE_PERSO` (
  `PERSONNE_N_COMPETENCE_PERSO_ID` DECIMAL(10,2),
  `COMPETENCEPERSO_ID` DECIMAL(10,2),
  `PERSONNE_ID` DECIMAL(10,2),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`PERSONNE_N_COMPETENCE_PERSO_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_TELEPHONE` (
  `TELEPHONE_ID` DECIMAL(10,2),
  `PRO` DECIMAL(10,2),
  `NUMERO` VARCHAR(64),
  `PERSONNE_ID` DECIMAL(10,2),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`TELEPHONE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_MAIL` (
  `MAIL_ID` DECIMAL(10,2),
  `PRO` DECIMAL(10,2),
  `MAIL` VARCHAR(64),
  `PERSONNE_ID` DECIMAL(10,2),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`MAIL_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_UTILISATEUR` (
  `UTILISATEUR_ID` DECIMAL(10,2),
  `IDENTIFIANT` VARCHAR(64),
  `MDP` VARCHAR(64),
  `NOM` VARCHAR(64),
  `PRENOM` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `MDPH` VARCHAR(64),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`UTILISATEUR_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_ROLE_UTILISATEUR` (
  `UTILISATEUR_ID` DECIMAL(10,2),
  `ROLE_ID` DECIMAL(10,2),
  PRIMARY KEY (`UTILISATEUR_ID`, `ROLE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_ROLE` (
  `ROLE_ID` DECIMAL(10,2),
  `NOM_ROLE` VARCHAR(64),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`ROLE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_ROLEPERMISSION` (
  `ROLE_ID` DECIMAL(10,2),
  `PERMISSION_ID` DECIMAL(10,2),
  PRIMARY KEY (`ROLE_ID`, `PERMISSION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AW_PERMISSION` (
  `PERMISSION_ID` DECIMAL(10,2),
  `NomPERMISSION` VARCHAR(64),
  `XDMAJ` DATETIME,
  `XTOPSUP` DECIMAL(10,2),
  PRIMARY KEY (`PERMISSION_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159645_create_tables_appli1_H2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159645_create_tables_appli1_H2') AS relationships;
DROP DATABASE `db_159645_create_tables_appli1_H2`;
UNINSTALL EXTENSION vsql_schematron;
