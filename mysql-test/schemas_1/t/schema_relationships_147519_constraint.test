INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147519_constraint
--echo #
CREATE DATABASE `db_147519_constraint`;
USE `db_147519_constraint`;

CREATE TABLE `human` (
  `id` VARCHAR(64),
  `sname` VARCHAR(64),
  `age` INT,
  `sex` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `car` (
  `id` VARCHAR(64),
  `mark` VARCHAR(64),
  `price` DECIMAL(10,2),
  `hid` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147519_constraint') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147519_constraint') AS relationships;
DROP DATABASE `db_147519_constraint`;
UNINSTALL EXTENSION vsql_schematron;
