CREATE DATABASE `db_169096_VsMyProjects_GuiPython_20210511`;
USE `db_169096_VsMyProjects_GuiPython_20210511`;

CREATE TABLE `auth_group` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_group_permissions` (
  `id` INT,
  `group_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_permission` (
  `id` INT,
  `name` VARCHAR(64),
  `content_type_id` INT,
  `codename` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_user` (
  `id` INT,
  `password` VARCHAR(64),
  `last_login` DATETIME,
  `is_superuser` INT,
  `username` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `is_staff` INT,
  `is_active` INT,
  `date_joined` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `auth_user_groups` (
  `id` INT,
  `user_id` INT,
  `group_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_user_user_permissions` (
  `id` INT,
  `user_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

CREATE TABLE `django_admin_log` (
  `id` INT,
  `action_time` DATETIME,
  `object_id` VARCHAR(64),
  `object_repr` VARCHAR(64),
  `action_flag` INT,
  `change_message` VARCHAR(64),
  `content_type_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `django_content_type` (
  `id` INT,
  `app_label` VARCHAR(64),
  `model` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `django_migrations` (
  `id` INT,
  `app` VARCHAR(64),
  `name` VARCHAR(64),
  `applied` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_session` (
  `session_key` VARCHAR(64),
  `session_data` VARCHAR(64),
  `expire_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `myprojects_comment` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `website` VARCHAR(64),
  `content` VARCHAR(64),
  `created_on` DATETIME,
  `post_id` INT
) CHARACTER SET latin1;

CREATE TABLE `myprojects_post` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `created_on` DATETIME,
  `author` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
