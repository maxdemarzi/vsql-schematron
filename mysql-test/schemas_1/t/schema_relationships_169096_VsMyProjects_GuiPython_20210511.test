    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169096_VsMyProjects_GuiPython_20210511') AS relationships;
DROP DATABASE `db_169096_VsMyProjects_GuiPython_20210511`;
