INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188569_structure
--echo #
CREATE DATABASE `db_188569_structure`;
USE `db_188569_structure`;

CREATE TABLE `admin_notifications` (
  `id` INT,
  `reason` INT,
  `post` INT,
  `type` INT,
  `user` INT,
  `created_at` DATETIME,
  `notif_read` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bans` (
  `id` INT,
  `user` INT,
  `ip` VARCHAR(64),
  `cidr` INT,
  `until` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `community_favorites` (
  `id` INT,
  `community` INT,
  `favorite_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `conversations` (
  `id` INT,
  `source` INT,
  `target` INT,
  `created_at` DATETIME,
  `is_rm` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `emotes` (
  `id` INT,
  `name` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_members` (
  `id` INT,
  `user` INT,
  `conversation` INT,
  `unread_messages` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `value` VARCHAR(64),
  `hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `imports` (
  `id` INT,
  `user` INT,
  `migration` INT,
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `login_tokens` (
  `id` INT,
  `value` VARCHAR(64),
  `user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrated_communities` (
  `id` INT,
  `migrated_id` VARCHAR(64),
  `icon` VARCHAR(64),
  `title` VARCHAR(64),
  `migration` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `image` VARCHAR(64),
  `script` VARCHAR(64),
  `url` VARCHAR(64),
  `is_rm` INT,
  `password_required` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` INT,
  `notif_type` INT,
  `notif_by` INT,
  `notif_to` INT,
  `notif_post` INT,
  `merged` INT,
  `notif_date` DATETIME,
  `notif_read` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `options` (
  `id` INT,
  `post` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `id` INT,
  `token` VARCHAR(64),
  `user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profiles` (
  `user` INT,
  `comment` VARCHAR(64),
  `created_at` DATETIME,
  `nnid` VARCHAR(64),
  `mh` VARCHAR(64),
  `region` VARCHAR(64),
  `gender` INT,
  `nnid_visibility` INT,
  `yeah_visibility` INT,
  `reply_visibility` INT,
  `discord` VARCHAR(64),
  `steam` VARCHAR(64),
  `psn` VARCHAR(64),
  `switch_code` VARCHAR(64),
  `twitter` VARCHAR(64),
  `youtube` VARCHAR(64),
  `allow_friend` INT,
  `favorite` INT,
  `avatar_image` VARCHAR(64),
  `avatar_id` INT,
  PRIMARY KEY (`user`)
) CHARACTER SET latin1;

CREATE TABLE `reports` (
  `id` INT,
  `type` INT,
  `pid` INT,
  `message` VARCHAR(64),
  `user` INT,
  `reason` INT,
  `is_rm` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `image` VARCHAR(64),
  `organization` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` VARCHAR(64),
  `user` INT
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `id` INT,
  `option_id` INT,
  `user` INT,
  `poll` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188569_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188569_structure') AS relationships;
DROP DATABASE `db_188569_structure`;
UNINSTALL EXTENSION vsql_schematron;
