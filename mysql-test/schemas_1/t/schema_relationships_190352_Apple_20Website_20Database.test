INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 190352_Apple%20Website%20Database
--echo #
CREATE DATABASE `db_190352_Apple_20Website_20Database`;
USE `db_190352_Apple_20Website_20Database`;

CREATE TABLE `users` (
  `user_id` INT,
  `username` VARCHAR(64),
  `city` VARCHAR(64),
  `password` INT,
  `full_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `cities` (
  `city_id` INT,
  `city_name` VARCHAR(64),
  `rate` INT,
  `postal_code` INT
) CHARACTER SET latin1;

CREATE TABLE `product_type` (
  `type_id` INT,
  `city_id` INT,
  `type_name` VARCHAR(64),
  `base_shipping` INT
) CHARACTER SET latin1;

CREATE TABLE `specifications` (
  `spec_id` INT,
  `spec_name` VARCHAR(64),
  `price` INT,
  `type_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_190352_Apple_20Website_20Database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_190352_Apple_20Website_20Database') AS relationships;
DROP DATABASE `db_190352_Apple_20Website_20Database`;
UNINSTALL EXTENSION vsql_schematron;
