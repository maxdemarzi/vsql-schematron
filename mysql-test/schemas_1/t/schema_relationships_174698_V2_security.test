INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 174698_V2_security
--echo #
CREATE DATABASE `db_174698_V2_security`;
USE `db_174698_V2_security`;

CREATE TABLE `app_role` (
  `id` INT,
  `description` VARCHAR(255),
  `role_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `app_user` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `password` VARCHAR(255),
  `username` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_174698_V2_security') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_174698_V2_security') AS relationships;
DROP DATABASE `db_174698_V2_security`;
UNINSTALL EXTENSION vsql_schematron;
