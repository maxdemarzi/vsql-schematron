INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184890_db
--echo #
CREATE DATABASE `db_184890_db`;
USE `db_184890_db`;

CREATE TABLE `Client` (
  `Id` INT,
  `Name` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Phone` VARCHAR(64),
  `Address` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Invoice` (
  `Id` INT,
  `TotalPrice` DECIMAL(10,2),
  `Requisites` DECIMAL(10,2),
  `IsPaid` VARCHAR(64),
  `FinalOrderId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Item` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Image` VARCHAR(64),
  `Description` VARCHAR(64),
  `Price` DECIMAL(10,2),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Manager` (
  `Id` INT,
  `Name` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Phone` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `FinalOrder` (
  `Id` INT,
  `Address` VARCHAR(64),
  `Status` VARCHAR(64),
  `HasInvoice` VARCHAR(64),
  `ClientId` INT,
  `ManagerId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `OrderLine` (
  `Quantity` DECIMAL(10,2),
  `FinalOrderId` INT,
  `ItemId` INT,
  PRIMARY KEY (`FinalOrderId`, `ItemId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184890_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184890_db') AS relationships;
DROP DATABASE `db_184890_db`;
UNINSTALL EXTENSION vsql_schematron;
