INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186791_InvoiceDatabase
--echo #
CREATE DATABASE `db_186791_InvoiceDatabase`;
USE `db_186791_InvoiceDatabase`;

CREATE TABLE `billing` (
  `purchase_id` INT,
  `item_id` INT,
  `invoice_id` INT,
  `quantity` INT,
  `price` INT
) CHARACTER SET latin1;

CREATE TABLE `clientinvoice` (
  `invoice_id` INT,
  `total` INT,
  `paid` INT,
  `due_pay` INT,
  `client_Id` INT,
  `created_By` VARCHAR(64),
  `created_Date` DATETIME,
  `clientName` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `address` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `clientmaster` (
  `ClientID` INT,
  `clientName` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `created_Date` DATETIME,
  `created_By` VARCHAR(64),
  PRIMARY KEY (`ClientID`)
) CHARACTER SET latin1;

CREATE TABLE `itemmaster` (
  `itemId` INT,
  `itemName` VARCHAR(64),
  `price` INT,
  `img` VARCHAR(64),
  `link` VARCHAR(64),
  `created_By` VARCHAR(64),
  `created_Date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `usermaster` (
  `USERID` INT,
  `userName` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `pass` VARCHAR(64),
  `created_Date` DATETIME,
  `created_By` VARCHAR(64),
  PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;

CREATE TABLE `video` (
  `id` INT,
  `path` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186791_InvoiceDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186791_InvoiceDatabase') AS relationships;
DROP DATABASE `db_186791_InvoiceDatabase`;
UNINSTALL EXTENSION vsql_schematron;
