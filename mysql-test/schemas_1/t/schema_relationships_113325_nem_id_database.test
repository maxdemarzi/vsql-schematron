INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113325_nem_id_database
--echo #
CREATE DATABASE `db_113325_nem_id_database`;
USE `db_113325_nem_id_database`;
CREATE TABLE `user` (
  `Id` INT NOT NULL,
  `CPR` TEXT,
  `NemID` TEXT,
  `Password` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_log` (
  `Id` INT NOT NULL,
  `UserId` INT,
  `Code` TEXT,
  `Timestamp` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113325_nem_id_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113325_nem_id_database') AS relationships;
DROP DATABASE `db_113325_nem_id_database`;
UNINSTALL EXTENSION vsql_schematron;
