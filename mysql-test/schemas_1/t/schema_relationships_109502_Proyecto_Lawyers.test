INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 109502_Proyecto_Lawyers
--echo #
CREATE DATABASE `db_109502_Proyecto_Lawyers`;
USE `db_109502_Proyecto_Lawyers`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `city_user` VARCHAR(50),
  `phone_number_user` VARCHAR(50),
  `login_user` VARCHAR(50),
  `email_user` VARCHAR(50),
  `password` VARCHAR(50),
  `picture_user` VARCHAR(50),
  `role` VARCHAR(50),
  `low_reason` VARCHAR(50),
  `active` BOOLEAN,
  `registration_code` VARCHAR(50),
  `creation_date` DATETIME,
  `update_date` DATETIME,
  `last_auth_update` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lawyers` (
  `id` VARCHAR(50) NOT NULL,
  `law_firm` VARCHAR(50),
  `street` VARCHAR(50),
  `zip` VARCHAR(50),
  `city_lawyer` VARCHAR(50),
  `phone_number_lawyer` VARCHAR(50),
  `login_lawyer` VARCHAR(50),
  `email_lawyer` VARCHAR(50),
  `password` VARCHAR(50),
  `picture_lawyer` VARCHAR(50),
  `low_reason` VARCHAR(50),
  `active` BOOLEAN,
  `registration_code` VARCHAR(50),
  `description` VARCHAR(50),
  `urgency` VARCHAR(50),
  `creation_date` DATETIME,
  `update_date` DATETIME,
  `last_auth_update` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `processes` (
  `id` VARCHAR(50) NOT NULL,
  `message_process` TEXT,
  `observations` VARCHAR(50),
  `status_process` VARCHAR(50),
  `active` BOOLEAN,
  `id_user` VARCHAR(50),
  `id_lawyer` VARCHAR(50),
  `creation_date` DATETIME,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `budgets` (
  `id` VARCHAR(50) NOT NULL,
  `status_budget` VARCHAR(50),
  `message_budget` TEXT,
  `price` INT,
  `rating` INT,
  `opinion` VARCHAR(50),
  `id_lawyer` VARCHAR(50),
  `id_process` VARCHAR(50),
  `creation_date` DATETIME,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialities` (
  `id` VARCHAR(50) NOT NULL,
  `id_lawyer` VARCHAR(50),
  `speciality` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_109502_Proyecto_Lawyers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_109502_Proyecto_Lawyers') AS relationships;
DROP DATABASE `db_109502_Proyecto_Lawyers`;
UNINSTALL EXTENSION vsql_schematron;
