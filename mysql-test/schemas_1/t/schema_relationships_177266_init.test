INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 177266_init
--echo #
CREATE DATABASE `db_177266_init`;
USE `db_177266_init`;
CREATE TABLE `cart` (
  `id` VARCHAR(50) NOT NULL,
  `buyer_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_line` (
  `id` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  `cart_id` VARCHAR(50),
  `name` TEXT,
  `price` DOUBLE,
  `qty` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_177266_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_177266_init') AS relationships;
DROP DATABASE `db_177266_init`;
UNINSTALL EXTENSION vsql_schematron;
