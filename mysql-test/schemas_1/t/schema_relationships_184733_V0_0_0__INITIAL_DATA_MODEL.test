INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184733_V0.0.0__INITIAL_DATA_MODEL
--echo #
CREATE DATABASE `db_184733_V0_0_0__INITIAL_DATA_MODEL`;
USE `db_184733_V0_0_0__INITIAL_DATA_MODEL`;
CREATE TABLE `GROUPS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOXES` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `GROUP_ID` DECIMAL(10,2),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VERSIONS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `BOX_ID` DECIMAL(10,2),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROVIDERS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `PROVIDER_TYPE` VARCHAR(50),
  `SIZE` DECIMAL(10,2),
  `CHECKSUM_TYPE` VARCHAR(50),
  `CHECKSUM` VARCHAR(50),
  `VERSION_ID` DECIMAL(10,2),
  `CREATED` TIMESTAMP NULL,
  `MODIFIED` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184733_V0_0_0__INITIAL_DATA_MODEL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184733_V0_0_0__INITIAL_DATA_MODEL') AS relationships;
DROP DATABASE `db_184733_V0_0_0__INITIAL_DATA_MODEL`;
UNINSTALL EXTENSION vsql_schematron;
