INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151917_schema
--echo #
CREATE DATABASE `db_151917_schema`;
USE `db_151917_schema`;

CREATE TABLE `players` (
  `id` VARCHAR(64),
  `balance` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournaments` (
  `id` VARCHAR(64),
  `deposit` INT,
  `winner` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournament_participants` (
  `tournamentId` VARCHAR(64),
  `participantId` VARCHAR(64),
  `parentId` VARCHAR(64),
  PRIMARY KEY (`tournamentId`, `participantId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151917_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151917_schema') AS relationships;
DROP DATABASE `db_151917_schema`;
UNINSTALL EXTENSION vsql_schematron;
