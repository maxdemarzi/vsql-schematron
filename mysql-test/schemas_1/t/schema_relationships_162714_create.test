INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 162714_create
--echo #
CREATE DATABASE `db_162714_create`;
USE `db_162714_create`;

CREATE TABLE `users` (
  `id` DECIMAL(10,2),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `rank` DECIMAL(10,2),
  `birth_date` DATETIME,
  `entry_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournament_systems` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournaments` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `price` DECIMAL(10,2),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `system_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `game_debutes` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournament_payments` (
  `id` DECIMAL(10,2),
  `created_at` DATETIME,
  `user_id` DECIMAL(10,2),
  `tournament_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `membership_fees` (
  `id` DECIMAL(10,2),
  `created_at` DATETIME,
  `user_id` DECIMAL(10,2),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_discounts_mapper` (
  `id` DECIMAL(10,2),
  `user_id` DECIMAL(10,2),
  `discount_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_162714_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_162714_create') AS relationships;
DROP DATABASE `db_162714_create`;
UNINSTALL EXTENSION vsql_schematron;
