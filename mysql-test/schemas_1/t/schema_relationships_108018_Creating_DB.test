INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108018_Creating_DB
--echo #
CREATE DATABASE `db_108018_Creating_DB`;
USE `db_108018_Creating_DB`;

CREATE TABLE `users` (
  `username` VARCHAR(64),
  `name` VARCHAR(64),
  `pwd` VARCHAR(64),
  `dp` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `videos` (
  `video_id` INT,
  `description` VARCHAR(64),
  `upload_date` DATETIME,
  `username` VARCHAR(64),
  `title` VARCHAR(64),
  `video_path` VARCHAR(64),
  `thumbnail` VARCHAR(64),
  PRIMARY KEY (`video_id`)
) CHARACTER SET latin1;

CREATE TABLE `video_ratings` (
  `username` VARCHAR(64),
  `video_id` INT,
  `rating` INT,
  PRIMARY KEY (`username`, `video_id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `comment_id` INT,
  `username` VARCHAR(64),
  `video_id` INT,
  `comment` VARCHAR(64),
  `comment_date` DATETIME,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

CREATE TABLE `replies` (
  `reply_id` INT,
  `comment_id` INT,
  `username` VARCHAR(64),
  `reply_text` VARCHAR(64),
  `reply_date` DATETIME,
  PRIMARY KEY (`reply_id`)
) CHARACTER SET latin1;

CREATE TABLE `subscriptions` (
  `username` VARCHAR(64),
  `subscriber` VARCHAR(64),
  PRIMARY KEY (`username`, `subscriber`)
) CHARACTER SET latin1;

CREATE TABLE `feedback` (
  `username` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `video_views` (
  `video_id` INT,
  `views` INT,
  PRIMARY KEY (`video_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108018_Creating_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108018_Creating_DB') AS relationships;
DROP DATABASE `db_108018_Creating_DB`;
UNINSTALL EXTENSION vsql_schematron;
