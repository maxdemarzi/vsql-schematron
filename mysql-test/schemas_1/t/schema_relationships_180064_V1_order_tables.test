INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180064_V1_order_tables
--echo #
CREATE DATABASE `db_180064_V1_order_tables`;
USE `db_180064_V1_order_tables`;

CREATE TABLE `buy_order` (
  `id` INT,
  `quantity` INT,
  `remain` INT,
  `price` DECIMAL(10,2),
  `created` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sell_order` (
  `id` INT,
  `quantity` INT,
  `remain` INT,
  `price` DECIMAL(10,2),
  `created` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `execution` (
  `id` INT,
  `buy_order_id` INT,
  `sell_order_id` INT,
  `quantity` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180064_V1_order_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180064_V1_order_tables') AS relationships;
DROP DATABASE `db_180064_V1_order_tables`;
UNINSTALL EXTENSION vsql_schematron;
