INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 118754_V0001__initial
--echo #
CREATE DATABASE `db_118754_V0001__initial`;
USE `db_118754_V0001__initial`;
CREATE TABLE `app_user` (
  `id` BIGINT NOT NULL,
  `email` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `authority` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_session` (
  `id` VARCHAR(50) NOT NULL,
  `app_user_id` BIGINT,
  `valid_until` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_118754_V0001__initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_118754_V0001__initial') AS relationships;
DROP DATABASE `db_118754_V0001__initial`;
UNINSTALL EXTENSION vsql_schematron;
