INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188634_Schema
--echo #
CREATE DATABASE `db_188634_Schema`;
USE `db_188634_Schema`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `birth` DATE,
  `register` DATETIME,
  `address` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `email` (
  `id` BIGINT NOT NULL,
  `address` VARCHAR(50),
  `user` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
  `id` BIGINT NOT NULL,
  `code` BIGINT,
  `estate` CHAR(50),
  `city` VARCHAR(50),
  `district` VARCHAR(50),
  `address` VARCHAR(50),
  `number` INT,
  `complement` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188634_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188634_Schema') AS relationships;
DROP DATABASE `db_188634_Schema`;
UNINSTALL EXTENSION vsql_schematron;
