INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 137569_05-relations-lab
--echo #
CREATE DATABASE `db_137569_05_relations_lab`;
USE `db_137569_05_relations_lab`;
CREATE TABLE `mountains` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peaks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `mountain_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_137569_05_relations_lab') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_137569_05_relations_lab') AS relationships;
DROP DATABASE `db_137569_05_relations_lab`;
UNINSTALL EXTENSION vsql_schematron;
