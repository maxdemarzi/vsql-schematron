INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107441_etecgames
--echo #
CREATE DATABASE `db_107441_etecgames`;
USE `db_107441_etecgames`;

CREATE TABLE `categoriasjogos_tb` (
  `codcatjogo` INT,
  `nomeCatjogo` VARCHAR(64),
  PRIMARY KEY (`codcatjogo`)
) CHARACTER SET latin1;

CREATE TABLE `cliente_tb` (
  `CpfCli` INT,
  `codusu_FK` INT,
  `nomeCli` VARCHAR(64),
  `foneCli` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `fornecedor_tb` (
  `codForn` INT,
  `nomeForn` VARCHAR(64),
  `emailForn` VARCHAR(64),
  `foneForn` VARCHAR(64),
  PRIMARY KEY (`codForn`)
) CHARACTER SET latin1;

CREATE TABLE `funcionario_tb` (
  `codFun` INT,
  `codusu_FK` INT,
  `nomeFun` VARCHAR(64),
  `foneFun` INT
) CHARACTER SET latin1;

CREATE TABLE `jogos_tb` (
  `codJogo` INT,
  `nomeJogo` VARCHAR(64),
  `codcatjogo_Fk` INT,
  `codFonecedor_FK` INT,
  `valorJogo` DECIMAL(10,2),
  `classificacaoJogo` INT,
  `avaliacaoJogo` INT,
  `dataLancamentoJogo` DATETIME,
  `imgJogo1` VARCHAR(64),
  `imgJogo2` VARCHAR(64),
  `imgJogo3` VARCHAR(64),
  `tamanhoJogo` INT,
  `descricaoJogo` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `usuario_tb` (
  `codusu` INT,
  `emailUsu` VARCHAR(64),
  `SenhaUsu` VARCHAR(64),
  PRIMARY KEY (`codusu`)
) CHARACTER SET latin1;

CREATE TABLE `venda_tb` (
  `codVenda` INT,
  `codjogo_FK` INT,
  `codFun_FK` INT,
  `CpfCli_FK` INT,
  `qtdVenda` INT,
  `dataVenda` INT,
  `vlVenda` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107441_etecgames') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107441_etecgames') AS relationships;
DROP DATABASE `db_107441_etecgames`;
UNINSTALL EXTENSION vsql_schematron;
