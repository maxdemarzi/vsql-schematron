INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139261_Security.CREATE.Activity
--echo #
CREATE DATABASE `db_139261_Security_CREATE_Activity`;
USE `db_139261_Security_CREATE_Activity`;
CREATE TABLE `AspNetActivity` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `AspNetActivityRoles` (
  `ActivityId` VARCHAR(50) NOT NULL,
  `RoleId` VARCHAR(50) NOT NULL,
  `Operations` VARCHAR(50),
  PRIMARY KEY (`ActivityId`, `RoleId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139261_Security_CREATE_Activity') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139261_Security_CREATE_Activity') AS relationships;
DROP DATABASE `db_139261_Security_CREATE_Activity`;
UNINSTALL EXTENSION vsql_schematron;
