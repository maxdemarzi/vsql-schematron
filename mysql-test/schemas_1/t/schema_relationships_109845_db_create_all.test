INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 109845_db-create-all
--echo #
CREATE DATABASE `db_109845_db_create_all`;
USE `db_109845_db_create_all`;

CREATE TABLE `client` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_parent` (
  `client_id` INT,
  `parent_id` INT,
  PRIMARY KEY (`client_id`, `parent_id`)
) CHARACTER SET latin1;

CREATE TABLE `parent` (
  `dtype` VARCHAR(64),
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_109845_db_create_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_109845_db_create_all') AS relationships;
DROP DATABASE `db_109845_db_create_all`;
UNINSTALL EXTENSION vsql_schematron;
