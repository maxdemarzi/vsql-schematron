INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 107180_arrange_ausgangszustand
--echo #
CREATE DATABASE `db_107180_arrange_ausgangszustand`;
USE `db_107180_arrange_ausgangszustand`;

CREATE TABLE `tab_uk` (
  `tab_a_id` DECIMAL(10,2),
  `tab_a_bezeichner` VARCHAR(255),
  `tab_b_daten` VARCHAR(255),
  PRIMARY KEY (`tab_a_id`)
) CHARACTER SET latin1;

CREATE TABLE `tab_fk_ref_uk` (
  `tab_b_id` DECIMAL(10,2),
  `tab_b_bezeichner` VARCHAR(255),
  `tab_b_daten` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `tab_comment` (
  `tab_comment` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_107180_arrange_ausgangszustand') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_107180_arrange_ausgangszustand') AS relationships;
DROP DATABASE `db_107180_arrange_ausgangszustand`;
UNINSTALL EXTENSION vsql_schematron;
