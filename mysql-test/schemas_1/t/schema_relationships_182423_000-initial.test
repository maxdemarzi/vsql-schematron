INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 182423_000-initial
--echo #
CREATE DATABASE `db_182423_000_initial`;
USE `db_182423_000_initial`;
CREATE TABLE `player` (
  `playerid` INT NOT NULL,
  `emailaddress` VARCHAR(50),
  `player_name` VARCHAR(50),
  `losses` INT,
  `wins` INT,
  PRIMARY KEY (`playerid`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
  `gameid` INT NOT NULL,
  `playera_id` INT,
  `playerb_id` INT,
  `playerc_id` INT,
  `playerd_id` INT,
  `gamedate` TIMESTAMP NULL,
  `postedby` VARCHAR(50),
  `teamabscore` INT,
  `teamcdscore` INT,
  PRIMARY KEY (`gameid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_182423_000_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_182423_000_initial') AS relationships;
DROP DATABASE `db_182423_000_initial`;
UNINSTALL EXTENSION vsql_schematron;
