INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 164376_dropDDL
--echo #
CREATE DATABASE `db_164376_dropDDL`;
USE `db_164376_dropDDL`;

CREATE TABLE `profile` (
  `id` INT,
  `alias` VARCHAR(64),
  `parisType` INT,
  `lookingFor` INT,
  `birthday` DATETIME,
  `starSign` INT,
  `height` INT,
  `weight` INT,
  `bodyType` INT,
  `eyeColor` INT,
  `hairColor` INT,
  `hairLength` INT,
  `ethnicity` INT,
  `maritalStatus` INT,
  `education` INT,
  `occupation` VARCHAR(64),
  `countryId` INT,
  `regionId` INT,
  `cityId` INT,
  `sport` INT,
  `party` INT,
  `smoking` INT,
  `drinking` INT,
  `albumId` INT,
  `mainPhotoId` INT,
  `description` VARCHAR(64),
  `seen` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `album` (
  `ownerId` INT,
  `selfId` INT,
  `creationTS` DATETIME,
  `name` VARCHAR(64),
  `privacy` INT,
  `photoCount` INT,
  `lastPhotoTS` DATETIME,
  `mainPhotoId` INT,
  PRIMARY KEY (`ownerId`, `selfId`)
) CHARACTER SET latin1;

CREATE TABLE `photo` (
  `ownerId` INT,
  `parentId` INT,
  `selfId` INT,
  `creationTS` DATETIME,
  `name` VARCHAR(64),
  `width` INT,
  `height` INT,
  PRIMARY KEY (`ownerId`, `parentId`, `selfId`)
) CHARACTER SET latin1;

CREATE TABLE `conversation` (
  `id` INT,
  `creationTS` DATETIME,
  `lastMessageTS` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `conversationId` INT,
  `creationTS` DATETIME,
  `ownerId` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`conversationId`, `creationTS`, `ownerId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_164376_dropDDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_164376_dropDDL') AS relationships;
DROP DATABASE `db_164376_dropDDL`;
UNINSTALL EXTENSION vsql_schematron;
