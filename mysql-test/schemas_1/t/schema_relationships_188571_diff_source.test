INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188571_diff_source
--echo #
CREATE DATABASE `db_188571_diff_source`;
USE `db_188571_diff_source`;

CREATE TABLE `bar` (
  `idbar` INT,
  `barcol` INT,
  `barcol1` INT,
  PRIMARY KEY (`idbar`)
) CHARACTER SET latin1;

CREATE TABLE `foobar` (
  `idfoobar` INT,
  `foobarcol` VARCHAR(64),
  `foobarcol1` VARCHAR(64),
  `foobarcol2` INT,
  PRIMARY KEY (`idfoobar`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188571_diff_source') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188571_diff_source') AS relationships;
DROP DATABASE `db_188571_diff_source`;
UNINSTALL EXTENSION vsql_schematron;
