INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 100778_1
--echo #
CREATE DATABASE `db_100778_1`;
USE `db_100778_1`;

CREATE TABLE `yarn_app_result` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `queue_name` VARCHAR(64),
  `start_time` INT,
  `finish_time` INT,
  `tracking_url` VARCHAR(64),
  `job_type` VARCHAR(64),
  `severity` INT,
  `score` INT,
  `workflow_depth` INT,
  `scheduler` VARCHAR(64),
  `job_name` VARCHAR(64),
  `job_exec_id` VARCHAR(64),
  `flow_exec_id` VARCHAR(64),
  `job_def_id` VARCHAR(64),
  `flow_def_id` VARCHAR(64),
  `job_exec_url` VARCHAR(64),
  `flow_exec_url` VARCHAR(64),
  `job_def_url` VARCHAR(64),
  `flow_def_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `yarn_app_heuristic_result` (
  `id` INT,
  `yarn_app_result_id` VARCHAR(64),
  `heuristic_class` VARCHAR(64),
  `heuristic_name` VARCHAR(64),
  `severity` INT,
  `score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `yarn_app_heuristic_result_details` (
  `yarn_app_heuristic_result_id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `details` VARCHAR(64),
  PRIMARY KEY (`yarn_app_heuristic_result_id`, `name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_100778_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_100778_1') AS relationships;
DROP DATABASE `db_100778_1`;
UNINSTALL EXTENSION vsql_schematron;
