INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 154410_create_tables
--echo #
CREATE DATABASE `db_154410_create_tables`;
USE `db_154410_create_tables`;

CREATE TABLE `Branch` (
  `branchname` VARCHAR(64),
  `branchcity` VARCHAR(64),
  `assets` DECIMAL(10,2),
  PRIMARY KEY (`branchname`)
) CHARACTER SET latin1;

CREATE TABLE `BankAccount` (
  `accno` INT,
  `branchname` VARCHAR(64),
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`accno`)
) CHARACTER SET latin1;

CREATE TABLE `BankCustomer` (
  `customername` VARCHAR(64),
  `customerstreet` VARCHAR(64),
  `customercity` VARCHAR(64),
  PRIMARY KEY (`customername`)
) CHARACTER SET latin1;

CREATE TABLE `Depositer` (
  `customername` VARCHAR(64),
  `accno` INT,
  PRIMARY KEY (`customername`, `accno`)
) CHARACTER SET latin1;

CREATE TABLE `Loan` (
  `loannumber` INT,
  `branchname` VARCHAR(64),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`loannumber`)
) CHARACTER SET latin1;

CREATE TABLE `Borrower` (
  `customername` VARCHAR(64),
  `loannumber` INT,
  PRIMARY KEY (`customername`, `loannumber`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_154410_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_154410_create_tables') AS relationships;
DROP DATABASE `db_154410_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
