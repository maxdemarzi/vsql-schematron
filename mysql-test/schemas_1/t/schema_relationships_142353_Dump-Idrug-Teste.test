INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142353_Dump-Idrug-Teste
--echo #
CREATE DATABASE `db_142353_Dump_Idrug_Teste`;
USE `db_142353_Dump_Idrug_Teste`;
CREATE TABLE `aspnetroleclaims` (
  `Id` INT NOT NULL,
  `RoleId` VARCHAR(50),
  `ClaimType` TEXT,
  `ClaimValue` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `aspnetroles` (
  `Id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  `NormalizedName` VARCHAR(50),
  `ConcurrencyStamp` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `aspnetuserclaims` (
  `Id` INT NOT NULL,
  `UserId` VARCHAR(50),
  `ClaimType` TEXT,
  `ClaimValue` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `aspnetuserlogins` (
  `LoginProvider` VARCHAR(50) NOT NULL,
  `ProviderKey` VARCHAR(50) NOT NULL,
  `ProviderDisplayName` TEXT,
  `UserId` VARCHAR(50),
  PRIMARY KEY (`LoginProvider`, `ProviderKey`)
) CHARACTER SET latin1;
CREATE TABLE `aspnetusers` (
  `Id` VARCHAR(50) NOT NULL,
  `UserName` VARCHAR(50),
  `NormalizedUserName` VARCHAR(50),
  `Email` VARCHAR(50),
  `NormalizedEmail` VARCHAR(50),
  `EmailConfirmed` VARCHAR(50),
  `PasswordHash` TEXT,
  `SecurityStamp` TEXT,
  `ConcurrencyStamp` TEXT,
  `PhoneNumber` TEXT,
  `PhoneNumberConfirmed` VARCHAR(50),
  `TwoFactorEnabled` VARCHAR(50),
  `LockoutEnd` TIMESTAMP NULL,
  `LockoutEnabled` VARCHAR(50),
  `AccessFailedCount` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142353_Dump_Idrug_Teste') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142353_Dump_Idrug_Teste') AS relationships;
DROP DATABASE `db_142353_Dump_Idrug_Teste`;
UNINSTALL EXTENSION vsql_schematron;
