INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 100904_CreateTables
--echo #
CREATE DATABASE `db_100904_CreateTables`;
USE `db_100904_CreateTables`;

CREATE TABLE `a_Customer` (
  `CustomerId` INT,
  `ZipCode` INT,
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Address` VARCHAR(64),
  `Email` VARCHAR(64),
  `PrimaryPhone` VARCHAR(64),
  PRIMARY KEY (`CustomerId`)
) CHARACTER SET latin1;

CREATE TABLE `a_Employee` (
  `EmpId` INT,
  `ZipCode` INT,
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Address` VARCHAR(64),
  `Email` VARCHAR(64),
  `PhoneNumber` VARCHAR(64),
  PRIMARY KEY (`EmpId`)
) CHARACTER SET latin1;

CREATE TABLE `a_Distributor` (
  `DistributorId` INT,
  `ZipCode` INT,
  `Name` VARCHAR(64),
  `Address` VARCHAR(64),
  `Email` VARCHAR(64),
  `PhoneNumber` VARCHAR(64),
  PRIMARY KEY (`DistributorId`)
) CHARACTER SET latin1;

CREATE TABLE `a_Model` (
  `ModelNumber` INT,
  `MSRP` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`ModelNumber`)
) CHARACTER SET latin1;

CREATE TABLE `a_Unit` (
  `SerialNumber` INT,
  `ModelNumber` INT,
  `DateReturned` DATETIME,
  PRIMARY KEY (`SerialNumber`)
) CHARACTER SET latin1;

CREATE TABLE `Employee_a_TestForm_Audit` (
  `Emp_name` VARCHAR(64),
  `Audit_Action` VARCHAR(64),
  `Audit_Timestamp` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_100904_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_100904_CreateTables') AS relationships;
DROP DATABASE `db_100904_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
