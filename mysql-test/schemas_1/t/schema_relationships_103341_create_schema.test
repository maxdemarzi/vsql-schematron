INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103341_create_schema
--echo #
CREATE DATABASE `db_103341_create_schema`;
USE `db_103341_create_schema`;

CREATE TABLE `userType` (
  `id` INT,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `realtyType` (
  `id` INT,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `userTypeId` INT,
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `cpf` VARCHAR(64),
  `birth` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `realty` (
  `id` INT,
  `name` VARCHAR(64),
  `monthlyPrice` DECIMAL(10,2),
  `totalPrice` DECIMAL(10,2),
  `city` VARCHAR(64),
  `neighborhood` VARCHAR(64),
  `street` VARCHAR(64),
  `created_at` DATETIME,
  `ended_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `report` (
  `id` INT,
  `userId` INT,
  `realtyId` INT,
  `subject` VARCHAR(64),
  `message` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bills` (
  `id` INT,
  `electricityBill` DECIMAL(10,2),
  `gasBill` DECIMAL(10,2),
  `waterBill` DECIMAL(10,2),
  `internetBill` DECIMAL(10,2),
  `addBill` DECIMAL(10,2),
  `totalBill` DECIMAL(10,2),
  `isPaid` BOOL,
  `created_at` DATETIME,
  `due_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `userStatus` (
  `id` INT,
  `userStatusBillId` INT,
  `userStatusUserId` INT,
  `userStatusRealtyId` INT,
  `isPaid` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `realtyStatus` (
  `id` INT,
  `realtyStatusUserId` INT,
  `realtyStatusId` INT,
  `isRented` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103341_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103341_create_schema') AS relationships;
DROP DATABASE `db_103341_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
