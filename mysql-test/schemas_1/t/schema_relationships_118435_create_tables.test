INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 118435_create_tables
--echo #
CREATE DATABASE `db_118435_create_tables`;
USE `db_118435_create_tables`;
CREATE TABLE `Flights` (
  `flno` INT NOT NULL,
  `ffrom` VARCHAR(50),
  `tto` VARCHAR(50),
  `distance` INT,
  `departs` DATE,
  `arrives` DATE,
  `price` DOUBLE,
  PRIMARY KEY (`flno`)
) CHARACTER SET latin1;
CREATE TABLE `Aircraft` (
  `aid` INT NOT NULL,
  `aname` VARCHAR(50),
  `cruisingrange` INT,
  PRIMARY KEY (`aid`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
  `eid` INT NOT NULL,
  `ename` VARCHAR(50),
  `salary` DOUBLE,
  PRIMARY KEY (`eid`)
) CHARACTER SET latin1;
CREATE TABLE `Certified` (
  `eid` INT NOT NULL,
  `aid` INT NOT NULL,
  PRIMARY KEY (`eid`, `aid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_118435_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_118435_create_tables') AS relationships;
DROP DATABASE `db_118435_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
