INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 191339_20158_hint
--echo #
CREATE DATABASE `db_191339_20158_hint`;
USE `db_191339_20158_hint`;

CREATE TABLE `t1` (
  `id` INT,
  `a` VARCHAR(64),
  `b` VARCHAR(64),
  `c` INT,
  `d` INT,
  `e` INT,
  `f` VARCHAR(64),
  `g` INT,
  `h` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `t2` (
  `id` INT,
  `a` VARCHAR(64),
  `b` VARCHAR(64),
  `c` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `t` (
  `i` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `u` (
  `i` VARCHAR(64),
  `j` VARCHAR(64),
  `k` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_191339_20158_hint') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_191339_20158_hint') AS relationships;
DROP DATABASE `db_191339_20158_hint`;
UNINSTALL EXTENSION vsql_schematron;
