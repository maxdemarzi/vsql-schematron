INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188863_up
--echo #
CREATE DATABASE `db_188863_up`;
USE `db_188863_up`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `name` VARCHAR(64),
  `number` VARCHAR(64),
  PRIMARY KEY (`name`, `number`)
) CHARACTER SET latin1;

CREATE TABLE `prereqs` (
  `course_name` VARCHAR(64),
  `course_number` VARCHAR(64),
  `prereq_name` VARCHAR(64),
  `prereq_number` VARCHAR(64),
  PRIMARY KEY (`course_name`, `course_number`, `prereq_name`, `prereq_number`)
) CHARACTER SET latin1;

CREATE TABLE `enrollments` (
  `user_id` INT,
  `course_name` VARCHAR(64),
  `course_number` VARCHAR(64),
  PRIMARY KEY (`user_id`, `course_name`, `course_number`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188863_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188863_up') AS relationships;
DROP DATABASE `db_188863_up`;
UNINSTALL EXTENSION vsql_schematron;
