INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 168863_hackathon
--echo #
CREATE DATABASE `db_168863_hackathon`;
USE `db_168863_hackathon`;

CREATE TABLE `User` (
  `id` INT,
  `phone_number` VARCHAR(64),
  `user_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Provider` (
  `id` INT,
  `display_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ProviderContent` (
  `id` INT,
  `provider_id` INT,
  `content` VARCHAR(64),
  `title` VARCHAR(64),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserProviderRelationTable` (
  `provider_id` INT,
  `user_id` INT,
  PRIMARY KEY (`provider_id`)
) CHARACTER SET latin1;

CREATE TABLE `ChatRoom` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserChatRoomRelationTable` (
  `chatroom_id` INT,
  `user_id` INT,
  PRIMARY KEY (`chatroom_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_168863_hackathon') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_168863_hackathon') AS relationships;
DROP DATABASE `db_168863_hackathon`;
UNINSTALL EXTENSION vsql_schematron;
