INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 179181_DDL_DML_Productos
--echo #
CREATE DATABASE `db_179181_DDL_DML_Productos`;
USE `db_179181_DDL_DML_Productos`;
CREATE TABLE `Empresa` (
  `ID_Empresa` INT NOT NULL,
  `Nombre` VARCHAR(50),
  `NIT` VARCHAR(50),
  `Fecha_Inicio` DATETIME,
  `Antiguedad` INT,
  PRIMARY KEY (`ID_Empresa`)
) CHARACTER SET latin1;
CREATE TABLE `Proveedor` (
  `ID_Proveedor` INT NOT NULL,
  `Nombre` VARCHAR(50),
  `Direccion` VARCHAR(50),
  `NIT` VARCHAR(50),
  PRIMARY KEY (`ID_Proveedor`)
) CHARACTER SET latin1;
CREATE TABLE `Producto` (
  `ID_Producto` INT NOT NULL,
  `Nombre` VARCHAR(50),
  `Codigo` VARCHAR(50),
  `Precio_Unitario` INT,
  `NIT` VARCHAR(50),
  `Impuesto` DOUBLE,
  `ID_Empresa` INT,
  `ID_Proveedor` INT,
  PRIMARY KEY (`ID_Producto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_179181_DDL_DML_Productos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_179181_DDL_DML_Productos') AS relationships;
DROP DATABASE `db_179181_DDL_DML_Productos`;
UNINSTALL EXTENSION vsql_schematron;
