INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 137075_stylish_backend
--echo #
CREATE DATABASE `db_137075_stylish_backend`;
USE `db_137075_stylish_backend`;

CREATE TABLE `campaign` (
  `id` INT,
  `product_id` INT,
  `picture` VARCHAR(64),
  `story` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hot` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hot_product` (
  `hot_id` INT,
  `product_id` INT,
  PRIMARY KEY (`hot_id`, `product_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_table` (
  `id` INT,
  `number` VARCHAR(64),
  `time` INT,
  `status` INT,
  `details` VARCHAR(64),
  `user_id` INT,
  `total` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `id` INT,
  `order_id` INT,
  `details` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `category` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `price` INT,
  `texture` VARCHAR(64),
  `wash` VARCHAR(64),
  `place` VARCHAR(64),
  `note` VARCHAR(64),
  `story` VARCHAR(64),
  `main_image` VARCHAR(64),
  `images` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `role_id` INT,
  `provider` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `picture` VARCHAR(64),
  `access_token` VARCHAR(64),
  `access_expired` INT,
  `login_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `variant` (
  `id` INT,
  `color_code` VARCHAR(64),
  `color_name` VARCHAR(64),
  `size` VARCHAR(64),
  `stock` INT,
  `product_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_137075_stylish_backend') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_137075_stylish_backend') AS relationships;
DROP DATABASE `db_137075_stylish_backend`;
UNINSTALL EXTENSION vsql_schematron;
