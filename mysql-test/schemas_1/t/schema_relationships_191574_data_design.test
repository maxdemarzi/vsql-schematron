INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 191574_data_design
--echo #
CREATE DATABASE `db_191574_data_design`;
USE `db_191574_data_design`;

CREATE TABLE `profile` (
  `profileId` VARCHAR(255),
  `profileName` VARCHAR(255),
  `profileFirstName` VARCHAR(255),
  `profileLastName` VARCHAR(255),
  `profilePhone` VARCHAR(255),
  `profileEmail` VARCHAR(255),
  `profilePassword` VARCHAR(255),
  `profileHash` VARCHAR(255),
  `profileSalt` VARCHAR(255),
  PRIMARY KEY (`profileId`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `articleId` VARCHAR(255),
  `articleProfileId` VARCHAR(255),
  `articleContent` VARCHAR(255),
  `articleTitle` VARCHAR(255),
  `articleDateTime` DATETIME,
  PRIMARY KEY (`articleId`)
) CHARACTER SET latin1;

CREATE TABLE `clap` (
  `clapId` VARCHAR(255),
  `clapProfileId` VARCHAR(255),
  `clapArticleId` VARCHAR(255),
  `clapDate` DATETIME,
  PRIMARY KEY (`clapId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_191574_data_design') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_191574_data_design') AS relationships;
DROP DATABASE `db_191574_data_design`;
UNINSTALL EXTENSION vsql_schematron;
