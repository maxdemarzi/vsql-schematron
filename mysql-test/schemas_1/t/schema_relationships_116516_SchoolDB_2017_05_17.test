) CHARACTER SET latin1;

CREATE TABLE `apply_testsapply` (
  `id` INT,
  `answer` INT,
  `applyApp_id_id` INT,
  `subject_id_id` INT,
  `tests_id_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chat_message` (
  `id` INT,
  `message` VARCHAR(64),
  `date` DATETIME,
  `room_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chat_room` (
  `id` INT,
  `title` VARCHAR(64),
  `staff_only` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_admin_log` (
  `id` INT,
  `action_time` DATETIME,
  `object_id` VARCHAR(64),
  `object_repr` VARCHAR(64),
  `action_flag` INT,
  `change_message` VARCHAR(64),
  `content_type_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_messages_message` (
  `id` INT,
  `subject` VARCHAR(64),
  `body` VARCHAR(64),
  `sent_at` DATETIME,
  `read_at` DATETIME,
  `replied_at` DATETIME,
  `sender_deleted_at` DATETIME,
  `recipient_deleted_at` DATETIME,
  `parent_msg_id` INT,
  `recipient_id` INT,
  `sender_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_migrations` (
  `id` INT,
  `app` VARCHAR(64),
  `name` VARCHAR(64),
  `applied` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_session` (
  `session_key` VARCHAR(64),
  `session_data` VARCHAR(64),
  `expire_date` DATETIME,
  PRIMARY KEY (`session_key`)
) CHARACTER SET latin1;

CREATE TABLE `forum_attachments_attachment` (
  `id` INT,
  `file` VARCHAR(64),
