CREATE DATABASE `db_116516_SchoolDB_2017_05_17`;
USE `db_116516_SchoolDB_2017_05_17`;

CREATE TABLE `aboutus_aboutus` (
  `id` INT,
  `image` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `apply_applyapplication` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `image` VARCHAR(64),
  `gender` VARCHAR(64),
  `dateOfBirth` DATETIME,
  `country` VARCHAR(64),
  `city` VARCHAR(64),
  `email` VARCHAR(64),
  `placeOfWorkOrStudy` VARCHAR(64),
  `speciality` VARCHAR(64),
  `motivationMessage` VARCHAR(64),
  `behanceLink` VARCHAR(64),
  `faceBookLink` VARCHAR(64),
  `googlePlusLink` VARCHAR(64),
  `instagrammLink` VARCHAR(64),
  `linkedInLink` VARCHAR(64),
  `skypeLink` VARCHAR(64),
  `telegrammLink` VARCHAR(64),
  `twitterLink` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `apply_destribution` (
  `id` INT,
  `CF_max` INT,
  `member_id_id` INT,
  `project_id_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `apply_projectpriority` (
  `id` INT,
  `priority` INT,
  `applyApp_id_id` INT,
  `project_id_id` INT,
