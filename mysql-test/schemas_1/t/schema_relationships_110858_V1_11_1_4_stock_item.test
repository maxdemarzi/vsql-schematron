INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110858_V1_11_1_4__stock_item
--echo #
CREATE DATABASE `db_110858_V1_11_1_4_stock_item`;
USE `db_110858_V1_11_1_4_stock_item`;

CREATE TABLE `STOCK_ITEM` (
  `ID` INT,
  `CODE` VARCHAR(64),
  `SN` VARCHAR(64),
  `USING_COUNT` INT,
  `USER_ID` VARCHAR(64),
  `STATUS` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `TENANT_ID` VARCHAR(64),
  `INFO_ID` INT,
  `ITEM_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110858_V1_11_1_4_stock_item') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110858_V1_11_1_4_stock_item') AS relationships;
DROP DATABASE `db_110858_V1_11_1_4_stock_item`;
UNINSTALL EXTENSION vsql_schematron;
