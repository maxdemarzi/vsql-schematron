INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 186715_animadio
--echo #
CREATE DATABASE `db_186715_animadio`;
USE `db_186715_animadio`;

CREATE TABLE `Breakpoint` (
  `id` INT,
  `media` VARCHAR(64),
  `width` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `AnimationCat` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `VariableCat` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ClassCat` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ClassState` (
  `id` INT,
  `state` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Animation` (
  `id` INT,
  `category_id` INT,
  `name` VARCHAR(64),
  `effect` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Variable` (
  `id` INT,
  `category_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Class` (
  `id` INT,
  `category_id` INT,
  `media` INT,
  `concat` INT,
  `state_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Element` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  `definition` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Theme` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  `definition` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Template` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  `definition` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_186715_animadio') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_186715_animadio') AS relationships;
DROP DATABASE `db_186715_animadio`;
UNINSTALL EXTENSION vsql_schematron;
