INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142976_pim
--echo #
CREATE DATABASE `db_142976_pim`;
USE `db_142976_pim`;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `created_on` DATE,
  `title` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hashtags` (
  `id` INT NOT NULL,
  `tag` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
  `id` INT NOT NULL,
  `notes_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142976_pim') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142976_pim') AS relationships;
DROP DATABASE `db_142976_pim`;
UNINSTALL EXTENSION vsql_schematron;
