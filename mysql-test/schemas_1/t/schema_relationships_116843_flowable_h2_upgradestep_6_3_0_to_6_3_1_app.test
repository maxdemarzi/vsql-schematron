INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116843_flowable.h2.upgradestep.6.3.0.to.6.3.1.app
--echo #
CREATE DATABASE `db_116843_flowable_h2_upgradestep_6_3_0_to_6_3_1_app`;
USE `db_116843_flowable_h2_upgradestep_6_3_0_to_6_3_1_app`;

CREATE TABLE `ACT_APP_DATABASECHANGELOGLOCK` (
  `ID` INT,
  `LOCKED` BOOL,
  `LOCKGRANTED` DATETIME,
  `LOCKEDBY` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_APP_DATABASECHANGELOG` (
  `ID` VARCHAR(64),
  `AUTHOR` VARCHAR(64),
  `FILENAME` VARCHAR(64),
  `DATEEXECUTED` DATETIME,
  `ORDEREXECUTED` INT,
  `EXECTYPE` VARCHAR(64),
  `MD5SUM` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `COMMENTS` VARCHAR(64),
  `TAG` VARCHAR(64),
  `LIQUIBASE` VARCHAR(64),
  `CONTEXTS` VARCHAR(64),
  `LABELS` VARCHAR(64),
  `DEPLOYMENT_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ACT_APP_DEPLOYMENT` (
  `ID_` VARCHAR(64),
  `NAME_` VARCHAR(64),
  `CATEGORY_` VARCHAR(64),
  `KEY_` VARCHAR(64),
  `DEPLOY_TIME_` DATETIME,
  `TENANT_ID_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_APP_DEPLOYMENT_RESOURCE` (
  `ID_` VARCHAR(64),
  `NAME_` VARCHAR(64),
  `DEPLOYMENT_ID_` VARCHAR(64),
  `RESOURCE_BYTES_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_APP_APPDEF` (
  `ID_` VARCHAR(64),
  `REV_` INT,
  `NAME_` VARCHAR(64),
  `KEY_` VARCHAR(64),
  `VERSION_` INT,
  `CATEGORY_` VARCHAR(64),
  `DEPLOYMENT_ID_` VARCHAR(64),
  `RESOURCE_NAME_` VARCHAR(64),
  `DESCRIPTION_` VARCHAR(64),
  `TENANT_ID_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116843_flowable_h2_upgradestep_6_3_0_to_6_3_1_app') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116843_flowable_h2_upgradestep_6_3_0_to_6_3_1_app') AS relationships;
DROP DATABASE `db_116843_flowable_h2_upgradestep_6_3_0_to_6_3_1_app`;
UNINSTALL EXTENSION vsql_schematron;
