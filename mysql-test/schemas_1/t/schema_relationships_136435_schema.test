INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 136435_schema
--echo #
CREATE DATABASE `db_136435_schema`;
USE `db_136435_schema`;
CREATE TABLE `admin_tb` (
  `admin_id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `role_name` VARCHAR(50),
  PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tb` (
  `post_id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `admin_id` INT,
  `create_date` DATE,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `dept_tb` (
  `dept_id` INT NOT NULL,
  `dept_name` VARCHAR(50),
  `dept_description` VARCHAR(50),
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `position_tb` (
  `pos_id` INT NOT NULL,
  `pos_name` VARCHAR(50),
  `pos_description` VARCHAR(50),
  PRIMARY KEY (`pos_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_tb` (
  `emp_id` VARCHAR(50) NOT NULL,
  `emp_name` VARCHAR(50),
  `sex` VARCHAR(50),
  `phone` VARCHAR(50),
  `email` VARCHAR(50),
  `address` VARCHAR(50),
  `education` VARCHAR(50),
  `birthday` DATE,
  `dept_id` INT,
  `pos_id` INT,
  PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_136435_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_136435_schema') AS relationships;
DROP DATABASE `db_136435_schema`;
UNINSTALL EXTENSION vsql_schematron;
