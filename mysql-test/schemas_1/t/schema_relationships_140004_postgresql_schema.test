INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 140004_postgresql_schema
--echo #
CREATE DATABASE `db_140004_postgresql_schema`;
USE `db_140004_postgresql_schema`;

CREATE TABLE `workspaces` (
  `name` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `cards` (
  `id` VARCHAR(255),
  `workspace_name` VARCHAR(255),
  `question` VARCHAR(255),
  `response` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `learn_cards` (
  `id` VARCHAR(255),
  `workspace_name` VARCHAR(255),
  `last_review` DATETIME,
  `next_review` DATETIME,
  `repetitions` INT,
  `ease_factor` DECIMAL(10,2),
  `interval_days` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_140004_postgresql_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_140004_postgresql_schema') AS relationships;
DROP DATABASE `db_140004_postgresql_schema`;
UNINSTALL EXTENSION vsql_schematron;
