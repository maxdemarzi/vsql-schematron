INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151255_28-index-on
--echo #
CREATE DATABASE `db_151255_28_index_on`;
USE `db_151255_28_index_on`;

CREATE TABLE `aaa` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bbb` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ccc` (
  `a` INT,
  `b` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151255_28_index_on') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151255_28_index_on') AS relationships;
DROP DATABASE `db_151255_28_index_on`;
UNINSTALL EXTENSION vsql_schematron;
