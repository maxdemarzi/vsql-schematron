INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 140467_sakai_user
--echo #
CREATE DATABASE `db_140467_sakai_user`;
USE `db_140467_sakai_user`;

CREATE TABLE `SAKAI_USER_PROPERTY` (
  `USER_ID` VARCHAR(255),
  `NAME` VARCHAR(255),
  `VALUE` VARCHAR(255),
  PRIMARY KEY (`USER_ID`, `NAME`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_USER` (
  `USER_ID` VARCHAR(255),
  `EMAIL` VARCHAR(255),
  `EMAIL_LC` VARCHAR(255),
  `FIRST_NAME` VARCHAR(255),
  `LAST_NAME` VARCHAR(255),
  `TYPE` VARCHAR(255),
  `PW` VARCHAR(255),
  `CREATEDBY` VARCHAR(255),
  `MODIFIEDBY` VARCHAR(255),
  `CREATEDON` DATETIME,
  `MODIFIEDON` DATETIME,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_USER_ID_MAP` (
  `USER_ID` VARCHAR(255),
  `EID` VARCHAR(255),
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_140467_sakai_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_140467_sakai_user') AS relationships;
DROP DATABASE `db_140467_sakai_user`;
UNINSTALL EXTENSION vsql_schematron;
