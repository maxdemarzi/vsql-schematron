INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 116776_Create_Table
--echo #
CREATE DATABASE `db_116776_Create_Table`;
USE `db_116776_Create_Table`;
CREATE TABLE `tweet` (
  `TweetID` VARCHAR(50) NOT NULL,
  `TweetText` TEXT,
  `UserID` TEXT,
  `TweetTime` TEXT,
  PRIMARY KEY (`TweetID`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `UserID` VARCHAR(50) NOT NULL,
  `UserName` TEXT,
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_116776_Create_Table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_116776_Create_Table') AS relationships;
DROP DATABASE `db_116776_Create_Table`;
UNINSTALL EXTENSION vsql_schematron;
