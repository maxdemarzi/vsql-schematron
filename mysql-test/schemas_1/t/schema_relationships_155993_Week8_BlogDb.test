INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 155993_Week8-BlogDb
--echo #
CREATE DATABASE `db_155993_Week8_BlogDb`;
USE `db_155993_Week8_BlogDb`;

CREATE TABLE `tags` (
  `id` INT,
  `tagname` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blogpost` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blogposttags` (
  `tagid` INT,
  `blogpostid` INT,
  PRIMARY KEY (`tagid`, `blogpostid`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `blogpostid` INT,
  `author` VARCHAR(64),
  `comment` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_155993_Week8_BlogDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_155993_Week8_BlogDb') AS relationships;
DROP DATABASE `db_155993_Week8_BlogDb`;
UNINSTALL EXTENSION vsql_schematron;
