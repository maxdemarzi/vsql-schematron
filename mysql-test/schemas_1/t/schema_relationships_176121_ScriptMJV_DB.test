INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 176121_ScriptMJV_DB
--echo #
CREATE DATABASE `db_176121_ScriptMJV_DB`;
USE `db_176121_ScriptMJV_DB`;
CREATE TABLE `endereco` (
  `id_endereco` INT NOT NULL,
  `logradouro` VARCHAR(50),
  `numero` VARCHAR(50),
  `complemento` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `uf` VARCHAR(50),
  `cep` VARCHAR(50),
  PRIMARY KEY (`id_endereco`)
) CHARACTER SET latin1;
CREATE TABLE `cadastro` (
  `codigo` INT NOT NULL,
  `pf_pj` CHAR(50),
  `razao_social` VARCHAR(50),
  `cpf_cnpj` VARCHAR(50),
  `telefone1` DECIMAL(10,2),
  `telefone2` DECIMAL(10,2),
  `email` VARCHAR(50),
  `obs` VARCHAR(50),
  `site_instagram` VARCHAR(50),
  `fk_endereco` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_176121_ScriptMJV_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_176121_ScriptMJV_DB') AS relationships;
DROP DATABASE `db_176121_ScriptMJV_DB`;
UNINSTALL EXTENSION vsql_schematron;
