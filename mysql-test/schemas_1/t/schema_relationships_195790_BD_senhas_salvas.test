INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195790_BD_senhas_salvas
--echo #
CREATE DATABASE `db_195790_BD_senhas_salvas`;
USE `db_195790_BD_senhas_salvas`;

CREATE TABLE `db_senhas_usuarios.tbCadastro` (
  `id` INT,
  `nome_usuario` VARCHAR(64),
  `email_usuario` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `db_senhas_usuarios.tb_senhas` (
  `id_senha` INT,
  `id_usuario` INT,
  `senha` VARCHAR(64),
  PRIMARY KEY (`id_senha`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195790_BD_senhas_salvas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195790_BD_senhas_salvas') AS relationships;
DROP DATABASE `db_195790_BD_senhas_salvas`;
UNINSTALL EXTENSION vsql_schematron;
