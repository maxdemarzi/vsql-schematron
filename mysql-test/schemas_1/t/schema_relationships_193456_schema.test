INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 193456_schema
--echo #
CREATE DATABASE `db_193456_schema`;
USE `db_193456_schema`;
CREATE TABLE `news_art_works` (
  `news_id` INT,
  `art_works_id` INT
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `id` INT,
  `title_en` TEXT,
  `title_uk` TEXT,
  `slug` TEXT,
  `type` TEXT,
  `picture` TEXT,
  `images` TEXT,
  `text_en` TEXT,
  `text_uk` TEXT,
  `date` TEXT,
  `date_unix` INT
) CHARACTER SET latin1;
CREATE TABLE `art_works` (
  `id` INT,
  `title_en` TEXT,
  `title_uk` TEXT,
  `description_en` TEXT,
  `description_uk` TEXT,
  `slug` TEXT,
  `price` INT,
  `in_stock` INT,
  `on_front` INT,
  `picture` TEXT,
  `images` TEXT,
  `width` INT,
  `height` INT,
  `date` TEXT,
  `date_unix` INT,
  `materials_en` TEXT,
  `materials_uk` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_193456_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_193456_schema') AS relationships;
DROP DATABASE `db_193456_schema`;
UNINSTALL EXTENSION vsql_schematron;
