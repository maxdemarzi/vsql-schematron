INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175971_database
--echo #
CREATE DATABASE `db_175971_database`;
USE `db_175971_database`;

CREATE TABLE `object_types` (
  `object_type_id` INT,
  `parent_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`object_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute_types` (
  `attr_type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`attr_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `attributes` (
  `attr_id` INT,
  `attr_type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`attr_id`)
) CHARACTER SET latin1;

CREATE TABLE `object_type_attributes` (
  `object_type_id` INT,
  `attr_id` INT,
  PRIMARY KEY (`object_type_id`, `attr_id`)
) CHARACTER SET latin1;

CREATE TABLE `objects` (
  `object_id` INT,
  `parent_id` INT,
  `object_type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`object_id`)
) CHARACTER SET latin1;

CREATE TABLE `values` (
  `object_id` INT,
  `attr_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`object_id`, `attr_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175971_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175971_database') AS relationships;
DROP DATABASE `db_175971_database`;
UNINSTALL EXTENSION vsql_schematron;
