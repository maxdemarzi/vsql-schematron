INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180190_V1__Initial
--echo #
CREATE DATABASE `db_180190_V1_Initial`;
USE `db_180190_V1_Initial`;

CREATE TABLE `account` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `is_enabled` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_role` (
  `email` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`email`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `account_profile` (
  `account_id` INT,
  `title` VARCHAR(64),
  `forename` VARCHAR(64),
  `surname` VARCHAR(64),
  `institution` VARCHAR(64),
  `city` VARCHAR(64),
  `research_area` VARCHAR(64),
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;

CREATE TABLE `media` (
  `id` INT,
  `original_name` VARCHAR(64),
  `mime_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `wiki_page` (
  `id` INT,
  `type` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `media_id` INT,
  `reference` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `device_availability` (
  `id` INT,
  `device_id` INT,
  `comment` VARCHAR(64),
  `german_postal_code` VARCHAR(64),
  `institution` VARCHAR(64),
  `research_group` VARCHAR(64),
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `paper` (
  `icebreaker_id` INT,
  `doi` VARCHAR(64),
  `core_id` VARCHAR(64),
  `title` VARCHAR(64),
  `abstract` VARCHAR(64),
  `has_full_text` BOOL,
  `year` INT,
  `topics` VARCHAR(64),
  `subjects` VARCHAR(64),
  `language_detected_most_likely` VARCHAR(64),
  `language_detected_probabilities` VARCHAR(64),
  PRIMARY KEY (`icebreaker_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180190_V1_Initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180190_V1_Initial') AS relationships;
DROP DATABASE `db_180190_V1_Initial`;
UNINSTALL EXTENSION vsql_schematron;
