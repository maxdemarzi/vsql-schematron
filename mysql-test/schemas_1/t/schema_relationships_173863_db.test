INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 173863_db
--echo #
CREATE DATABASE `db_173863_db`;
USE `db_173863_db`;
CREATE TABLE `sets` (
  `setID` INT NOT NULL,
  `setName` VARCHAR(50),
  PRIMARY KEY (`setID`)
) CHARACTER SET latin1;
CREATE TABLE `card` (
  `cardID` INT NOT NULL,
  `setID` INT,
  `cardQuestion` VARCHAR(50),
  `cardAnswer` VARCHAR(50),
  PRIMARY KEY (`cardID`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `filesID` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_173863_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_173863_db') AS relationships;
DROP DATABASE `db_173863_db`;
UNINSTALL EXTENSION vsql_schematron;
