INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184110_migration
--echo #
CREATE DATABASE `db_184110_migration`;
USE `db_184110_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `fullName` TEXT,
  `username` TEXT,
  `mobile` TEXT,
  `email` TEXT,
  `registeredAt` TIMESTAMP NULL,
  `lastLogin` TIMESTAMP NULL,
  `intro` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` INT NOT NULL,
  `title` TEXT,
  `published` BOOLEAN,
  `authorId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184110_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184110_migration') AS relationships;
DROP DATABASE `db_184110_migration`;
UNINSTALL EXTENSION vsql_schematron;
