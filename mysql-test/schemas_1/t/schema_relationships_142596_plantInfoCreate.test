INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142596_plantInfoCreate
--echo #
CREATE DATABASE `db_142596_plantInfoCreate`;
USE `db_142596_plantInfoCreate`;

CREATE TABLE `users` (
  `_id` INT,
  `email` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `plants` (
  `_id` INT,
  `user_id` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `session` (
  `_id` INT,
  `user_id` INT,
  `session_id` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `_id` INT,
  `plant_id` INT,
  `url` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `relationships` (
  `_id` INT,
  `follower_id` INT,
  `followed_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142596_plantInfoCreate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142596_plantInfoCreate') AS relationships;
DROP DATABASE `db_142596_plantInfoCreate`;
UNINSTALL EXTENSION vsql_schematron;
