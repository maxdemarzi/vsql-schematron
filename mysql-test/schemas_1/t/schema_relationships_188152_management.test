INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 188152_management
--echo #
CREATE DATABASE `db_188152_management`;
USE `db_188152_management`;

CREATE TABLE `terminalinfo` (
  `terminalno` VARCHAR(64),
  `terminalip` VARCHAR(64),
  `terminalstatus` INT,
  `terminalid` VARCHAR(64),
  `terminaladdr` VARCHAR(64),
  `terminalcall` VARCHAR(64),
  PRIMARY KEY (`terminalno`)
) CHARACTER SET latin1;

CREATE TABLE `terminaldevice` (
  `terminalno` VARCHAR(64),
  `printerstate` INT,
  `inicstate` INT,
  `keyboardstate` INT,
  `magstate` INT,
  PRIMARY KEY (`terminalno`)
) CHARACTER SET latin1;

CREATE TABLE `terminalmgr` (
  `name` VARCHAR(64),
  `credentials` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_188152_management') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_188152_management') AS relationships;
DROP DATABASE `db_188152_management`;
UNINSTALL EXTENSION vsql_schematron;
