INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 176519_ddl
--echo #
CREATE DATABASE `db_176519_ddl`;
USE `db_176519_ddl`;

CREATE TABLE `CUSTOMERS` (
  `c_ID` VARCHAR(64),
  `c_FName` VARCHAR(64),
  `c_LName` VARCHAR(64),
  `c_Username` VARCHAR(64),
  `c_Password` VARCHAR(64),
  PRIMARY KEY (`c_ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMPLOYEES` (
  `e_ID` VARCHAR(64),
  `e_FName` VARCHAR(64),
  `e_LName` VARCHAR(64),
  `e_Username` VARCHAR(64),
  `e_Password` VARCHAR(64),
  PRIMARY KEY (`e_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ADMINS` (
  `a_ID` VARCHAR(64),
  `a_FName` VARCHAR(64),
  `a_LName` VARCHAR(64),
  `a_Username` VARCHAR(64),
  `a_Password` VARCHAR(64),
  PRIMARY KEY (`a_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CUSTOMERBANKCONN` (
  `c_ID` VARCHAR(64),
  `b_ID` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_176519_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_176519_ddl') AS relationships;
DROP DATABASE `db_176519_ddl`;
UNINSTALL EXTENSION vsql_schematron;
