INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 117080_mybatis
--echo #
CREATE DATABASE `db_117080_mybatis`;
USE `db_117080_mybatis`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teacher` (
  `id` INT,
  `teacher_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `id` INT,
  `student_name` VARCHAR(64),
  `tid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `blog` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `create_time` DATETIME,
  `views` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_117080_mybatis') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_117080_mybatis') AS relationships;
DROP DATABASE `db_117080_mybatis`;
UNINSTALL EXTENSION vsql_schematron;
