INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 144944_creacionTablas
--echo #
CREATE DATABASE `db_144944_creacionTablas`;
USE `db_144944_creacionTablas`;
CREATE TABLE `estado_morosidad` (
  `id` INT NOT NULL,
  `descripcion` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `morosidad_estudiante` (
  `id` INT NOT NULL,
  `idEstudiante` INT,
  `idEstadoMorosidad` INT,
  `valor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `morosidad_profesor` (
  `id` INT NOT NULL,
  `idProfesor` INT,
  `idEstadoMorosidad` INT,
  `valor` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_144944_creacionTablas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_144944_creacionTablas') AS relationships;
DROP DATABASE `db_144944_creacionTablas`;
UNINSTALL EXTENSION vsql_schematron;
