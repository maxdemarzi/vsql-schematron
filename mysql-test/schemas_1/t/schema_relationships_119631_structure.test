INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 119631_structure
--echo #
CREATE DATABASE `db_119631_structure`;
USE `db_119631_structure`;

CREATE TABLE `SystemUser` (
  `systemUserId` INT,
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `fullName` VARCHAR(64),
  PRIMARY KEY (`systemUserId`)
) CHARACTER SET latin1;

CREATE TABLE `SystemGroup` (
  `systemGroupId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`systemGroupId`)
) CHARACTER SET latin1;

CREATE TABLE `SystemGroupSystemUser` (
  `systemGroupId` INT,
  `systemUserId` INT,
  PRIMARY KEY (`systemGroupId`, `systemUserId`)
) CHARACTER SET latin1;

CREATE TABLE `SystemSession` (
  `systemSessionId` INT,
  `systemUserId` INT,
  `token` VARCHAR(64),
  `ip` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`systemSessionId`)
) CHARACTER SET latin1;

CREATE TABLE `Country` (
  `countryId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`countryId`)
) CHARACTER SET latin1;

CREATE TABLE `City` (
  `cityId` INT,
  `name` VARCHAR(64),
  `countryId` INT,
  PRIMARY KEY (`cityId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_119631_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_119631_structure') AS relationships;
DROP DATABASE `db_119631_structure`;
UNINSTALL EXTENSION vsql_schematron;
