INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180655_project_db
--echo #
CREATE DATABASE `db_180655_project_db`;
USE `db_180655_project_db`;
CREATE TABLE `et_poa` (
  `user_id` INT NOT NULL,
  `resourceServerId` VARCHAR(50),
  `metadata` VARCHAR(50),
  `clientId` VARCHAR(50),
  `password` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `et_categories` (
  `category_id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `et_transactions` (
  `transaction_id` INT NOT NULL,
  `category_id` INT,
  `user_id` INT,
  `amount` DECIMAL(10,2),
  `note` VARCHAR(50),
  `transaction_date` BIGINT,
  PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180655_project_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180655_project_db') AS relationships;
DROP DATABASE `db_180655_project_db`;
UNINSTALL EXTENSION vsql_schematron;
