INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 110381_estore
--echo #
CREATE DATABASE `db_110381_estore`;
USE `db_110381_estore`;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `user_email` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `user_password` VARCHAR(50),
  `activation_code` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `types` (
  `type_id` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `brands` (
  `brand_id` INT NOT NULL,
  `brand` VARCHAR(50),
  PRIMARY KEY (`brand_id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
  `item_id` INT NOT NULL,
  `user_id` INT,
  `type_id` INT,
  `brand_id` INT,
  `model` VARCHAR(50),
  `price` DOUBLE,
  `quantity` INT,
  `post_date` DATETIME,
  `item_img` VARCHAR(50),
  `description` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `message_id` INT NOT NULL,
  `msg_text` TEXT,
  `msg_date` DATETIME,
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_messages` (
  `user_message_id` INT NOT NULL,
  `message_id` INT,
  `user_id` INT,
  `other_user_id` INT,
  `folder` VARCHAR(50),
  `unread` BOOLEAN,
  `deleted` VARCHAR(50),
  PRIMARY KEY (`user_message_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_110381_estore') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_110381_estore') AS relationships;
DROP DATABASE `db_110381_estore`;
UNINSTALL EXTENSION vsql_schematron;
