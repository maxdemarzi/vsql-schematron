INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 149318_DDL
--echo #
CREATE DATABASE `db_149318_DDL`;
USE `db_149318_DDL`;

CREATE TABLE `produto` (
  `prd_id` VARCHAR(64),
  PRIMARY KEY (`prd_id`)
) CHARACTER SET latin1;

CREATE TABLE `sugerir` (
  `sug_percept` VARCHAR(64),
  `sug_sugestao` VARCHAR(64),
  PRIMARY KEY (`sug_percept`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_149318_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_149318_DDL') AS relationships;
DROP DATABASE `db_149318_DDL`;
UNINSTALL EXTENSION vsql_schematron;
