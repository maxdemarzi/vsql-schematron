INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106329_create_db
--echo #
CREATE DATABASE `db_106329_create_db`;
USE `db_106329_create_db`;
CREATE TABLE `profiles` (
  `profile_id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`profile_id`)
) CHARACTER SET latin1;
CREATE TABLE `activities` (
  `activity_id` INT NOT NULL,
  `profile_id` INT,
  `name` TEXT,
  `enabled` BOOLEAN,
  PRIMARY KEY (`activity_id`)
) CHARACTER SET latin1;
CREATE TABLE `activity_attributes` (
  `activity_attribute_id` INT NOT NULL,
  `activity_id` INT,
  `type` INT,
  `name` TEXT,
  `default_value` TEXT,
  `enabled` BOOLEAN,
  PRIMARY KEY (`activity_attribute_id`)
) CHARACTER SET latin1;
CREATE TABLE `activity_logs` (
  `activity_log_id` INT NOT NULL,
  `activity_id` INT,
  `create_date` TEXT,
  PRIMARY KEY (`activity_log_id`)
) CHARACTER SET latin1;
CREATE TABLE `activity_attribute_logs` (
  `activity_attribute_log_id` INT NOT NULL,
  `activity_log_id` INT,
  `activity_attribute_id` INT,
  `value` TEXT,
  PRIMARY KEY (`activity_attribute_log_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106329_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106329_create_db') AS relationships;
DROP DATABASE `db_106329_create_db`;
UNINSTALL EXTENSION vsql_schematron;
