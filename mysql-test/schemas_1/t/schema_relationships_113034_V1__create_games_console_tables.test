INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113034_V1__create_games_console_tables
--echo #
CREATE DATABASE `db_113034_V1__create_games_console_tables`;
USE `db_113034_V1__create_games_console_tables`;
CREATE TABLE `console` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `year` INT,
  `console_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113034_V1__create_games_console_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113034_V1__create_games_console_tables') AS relationships;
DROP DATABASE `db_113034_V1__create_games_console_tables`;
UNINSTALL EXTENSION vsql_schematron;
