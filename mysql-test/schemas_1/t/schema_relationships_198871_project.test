INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 198871_project
--echo #
CREATE DATABASE `db_198871_project`;
USE `db_198871_project`;
CREATE TABLE `THEATER_COMPANY` (
  `theater_company_id` DECIMAL(10,2) NOT NULL,
  `hall_capacity` DECIMAL(10,2),
  `name_company` VARCHAR(50),
  `budget` DOUBLE,
  `city` VARCHAR(50),
  `balance` DOUBLE,
  PRIMARY KEY (`theater_company_id`)
) CHARACTER SET latin1;
CREATE TABLE `CREATIONS` (
  `creation_id` DECIMAL(10,2) NOT NULL,
  `creation_cost` DOUBLE,
  `promotion_creations` DOUBLE,
  `theater_company_id` DECIMAL(10,2),
  PRIMARY KEY (`creation_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_198871_project') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_198871_project') AS relationships;
DROP DATABASE `db_198871_project`;
UNINSTALL EXTENSION vsql_schematron;
