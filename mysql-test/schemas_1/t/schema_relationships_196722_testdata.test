INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 196722_testdata
--echo #
CREATE DATABASE `db_196722_testdata`;
USE `db_196722_testdata`;
CREATE TABLE `people` (
  `id` INT NOT NULL,
  `name` TEXT,
  `job` TEXT,
  `alive` BOOLEAN,
  `employer` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `publications` (
  `id` INT NOT NULL,
  `title` TEXT,
  `year` INT,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_196722_testdata') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_196722_testdata') AS relationships;
DROP DATABASE `db_196722_testdata`;
UNINSTALL EXTENSION vsql_schematron;
