INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172896_DB
--echo #
CREATE DATABASE `db_172896_DB`;
USE `db_172896_DB`;
CREATE TABLE `VIDEO` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `DURATION` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ALQUILER` (
  `ID` DECIMAL(10,2) NOT NULL,
  `VIDEO_ID2` DECIMAL(10,2),
  `USER_NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172896_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172896_DB') AS relationships;
DROP DATABASE `db_172896_DB`;
UNINSTALL EXTENSION vsql_schematron;
