INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 191519_crebas
--echo #
CREATE DATABASE `db_191519_crebas`;
USE `db_191519_crebas`;

CREATE TABLE `AJOUTER` (
  `IDQ` INT,
  `ID_QUEST` INT,
  PRIMARY KEY (`IDQ`, `ID_QUEST`)
) CHARACTER SET latin1;

CREATE TABLE `APPARIER` (
  `REP_ID_REPONSE` INT,
  `ID_REPONSE` INT,
  PRIMARY KEY (`REP_ID_REPONSE`, `ID_REPONSE`)
) CHARACTER SET latin1;

CREATE TABLE `APPARTENIR` (
  `IDRC` INT,
  `ID_REPONSE` INT,
  PRIMARY KEY (`IDRC`, `ID_REPONSE`)
) CHARACTER SET latin1;

CREATE TABLE `PARTICIPER` (
  `ID` INT,
  `IDQ` INT,
  `DATE_PARTICIPATION` DATETIME,
  `CLASSEMENT` INT,
  PRIMARY KEY (`ID`, `IDQ`)
) CHARACTER SET latin1;

CREATE TABLE `QUESTION` (
  `INTITULE` VARCHAR(64),
  `ID_QUEST` INT,
  `TYPEQ` VARCHAR(64),
  `TEMPS_MAXIMAL` INT,
  PRIMARY KEY (`ID_QUEST`)
) CHARACTER SET latin1;

CREATE TABLE `QUESTIONNAIRE` (
  `IDQ` INT,
  `ID` INT,
  `TITRE` VARCHAR(64),
  `ID_REGLES_QUEST` INT,
  `DESCRIPTION` VARCHAR(64),
  `ETAT` VARCHAR(64),
  `DATE_OUVERTURE` DATETIME,
  `DATE_FERMETURE` DATETIME,
  `MODE_ACCES` VARCHAR(64),
  `LIEN_HTTP` VARCHAR(64),
  PRIMARY KEY (`IDQ`)
) CHARACTER SET latin1;

CREATE TABLE `REGLES_GENERATION` (
  `REGLE` VARCHAR(64),
  `ID_REGLE` INT,
  PRIMARY KEY (`ID_REGLE`)
) CHARACTER SET latin1;

CREATE TABLE `REGLES_QUESTIONNAIRE` (
  `TEMPS_TOTALE` INT,
  `REVENIR_ARRIERE` BOOL,
  `ID_REGLES_QUEST` INT,
  `PLUS` INT,
  `MOINS` INT,
  `NEUTRE` INT,
  PRIMARY KEY (`ID_REGLES_QUEST`)
) CHARACTER SET latin1;

CREATE TABLE `REPONSES_POSSIBLES` (
  `ID_REPONSE` INT,
  `ID_QUEST` INT,
  `ENONCE` VARCHAR(64),
  `CORRECT` BOOL,
  `COLONNE1OU2` INT,
  PRIMARY KEY (`ID_REPONSE`)
) CHARACTER SET latin1;

CREATE TABLE `REPONSE_CHOISIE` (
  `ID_QUEST` INT,
  `IDRC` INT,
  `ID` INT,
  `OKPASOK` BOOL,
  PRIMARY KEY (`IDRC`)
) CHARACTER SET latin1;

CREATE TABLE `SPECIFIER` (
  `IDQ` INT,
  `ID_REGLE` INT,
  PRIMARY KEY (`IDQ`, `ID_REGLE`)
) CHARACTER SET latin1;

CREATE TABLE `TAG` (
  `TAG` VARCHAR(64),
  PRIMARY KEY (`TAG`)
) CHARACTER SET latin1;

CREATE TABLE `TAGGER` (
  `ID_QUEST` INT,
  `TAG` VARCHAR(64),
  PRIMARY KEY (`ID_QUEST`, `TAG`)
) CHARACTER SET latin1;

CREATE TABLE `TYPE` (
  `TYPEQ` VARCHAR(64),
  PRIMARY KEY (`TYPEQ`)
) CHARACTER SET latin1;

CREATE TABLE `UTILISATEUR` (
  `NOM` VARCHAR(64),
  `PRENOM` VARCHAR(64),
  `TYPE_UTILISATEUR` VARCHAR(64),
  `ID` INT,
  `MATRICULE` VARCHAR(64),
  `STATUT` VARCHAR(64),
  `MAIL_ENSEIGNANT` VARCHAR(64),
  `PROMO` VARCHAR(64),
  `ANNEE_DE_SORTIE` INT,
  `MAIL_ETUDIANT` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_191519_crebas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_191519_crebas') AS relationships;
DROP DATABASE `db_191519_crebas`;
UNINSTALL EXTENSION vsql_schematron;
