INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 167461_node_task
--echo #
CREATE DATABASE `db_167461_node_task`;
USE `db_167461_node_task`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `is_deleted` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` INT NOT NULL,
  `category_id` INT,
  `name` VARCHAR(50),
  `is_deleted` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_167461_node_task') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_167461_node_task') AS relationships;
DROP DATABASE `db_167461_node_task`;
UNINSTALL EXTENSION vsql_schematron;
