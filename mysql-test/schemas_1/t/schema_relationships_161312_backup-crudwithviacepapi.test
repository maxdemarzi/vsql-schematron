INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161312_backup-crudwithviacepapi
--echo #
CREATE DATABASE `db_161312_backup_crudwithviacepapi`;
USE `db_161312_backup_crudwithviacepapi`;
CREATE TABLE `cliente` (
  `idCliente` INT,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `dataNasc` DATE,
  `email` VARCHAR(50),
  `endereco_idEndereco` INT
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
  `idEndereco` INT NOT NULL,
  `logradouro` VARCHAR(50),
  `numero` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `uf` VARCHAR(50),
  `cep` VARCHAR(50),
  PRIMARY KEY (`idEndereco`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161312_backup_crudwithviacepapi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161312_backup_crudwithviacepapi') AS relationships;
DROP DATABASE `db_161312_backup_crudwithviacepapi`;
UNINSTALL EXTENSION vsql_schematron;
