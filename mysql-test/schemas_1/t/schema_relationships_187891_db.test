INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 187891_db
--echo #
CREATE DATABASE `db_187891_db`;
USE `db_187891_db`;
CREATE TABLE `auth` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `key` CHAR(50),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_187891_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_187891_db') AS relationships;
DROP DATABASE `db_187891_db`;
UNINSTALL EXTENSION vsql_schematron;
