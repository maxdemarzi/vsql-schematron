INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 136853_5_edits.up
--echo #
CREATE DATABASE `db_136853_5_edits_up`;
USE `db_136853_5_edits_up`;
CREATE TABLE `edits` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `operation` VARCHAR(50),
  `target_type` VARCHAR(50),
  `data` VARCHAR(50),
  `votes` INT,
  `status` VARCHAR(50),
  `applied` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `edit_comments` (
  `id` VARCHAR(50) NOT NULL,
  `edit_id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `performer_edits` (
  `edit_id` VARCHAR(50),
  `performer_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `studio_edits` (
  `edit_id` VARCHAR(50),
  `studio_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tag_edits` (
  `edit_id` VARCHAR(50),
  `tag_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `scene_edits` (
  `edit_id` VARCHAR(50),
  `scene_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_136853_5_edits_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_136853_5_edits_up') AS relationships;
DROP DATABASE `db_136853_5_edits_up`;
UNINSTALL EXTENSION vsql_schematron;
