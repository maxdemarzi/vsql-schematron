INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 180132_kearsipandpm
--echo #
CREATE DATABASE `db_180132_kearsipandpm`;
USE `db_180132_kearsipandpm`;
CREATE TABLE `admin` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `foto` VARCHAR(50),
  `level` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `berkas_proposal` (
  `id` INT,
  `id_penomoran` INT,
  `nama_kegiatan` VARCHAR(50),
  `link` TEXT,
  `tanggal_kegiatan` DATE
) CHARACTER SET latin1;
CREATE TABLE `konstitusi` (
  `id` INT,
  `id_penomoran` INT,
  `nama_konstitusi` VARCHAR(50),
  `berkas` VARCHAR(50),
  `tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `penomoran` (
  `id` INT NOT NULL,
  `nomor` VARCHAR(50),
  `nama_kegiatan` VARCHAR(50),
  `penomoran` TEXT,
  `jumlah` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rapat_besar` (
  `id` INT,
  `id_admin` INT,
  `nama` VARCHAR(50),
  `notulen` TEXT,
  `tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `rapat_koordinasi` (
  `id` INT,
  `id_admin` INT,
  `nama` VARCHAR(50),
  `notulen` TEXT,
  `tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `rapat_pleno` (
  `id` INT,
  `id_admin` INT,
  `nama` VARCHAR(50),
  `notulen` TEXT,
  `tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `rekap_anggota` (
  `id` INT,
  `id_admin` INT,
  `nama` VARCHAR(50),
  `tunggakan` VARCHAR(50),
  `total` VARCHAR(50),
  `status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `rekap_organisasi` (
  `id` INT,
  `id_admin` INT,
  `bulan` VARCHAR(50),
  `berkas` VARCHAR(50),
  `keterangan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `surat_keluar` (
  `id` INT,
  `id_penomoran` INT,
  `nama_dikirim` VARCHAR(50),
  `jenis_kegiatan` VARCHAR(50),
  `link` TEXT,
  `tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `surat_masuk` (
  `id` INT NOT NULL,
  `nama_pengirim` VARCHAR(50),
  `jenis_kegiatan` VARCHAR(50),
  `link` TEXT,
  `tanggal` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `template_surat` (
  `id` INT NOT NULL,
  `jenis_kegiatan` VARCHAR(50),
  `berkas` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_180132_kearsipandpm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_180132_kearsipandpm') AS relationships;
DROP DATABASE `db_180132_kearsipandpm`;
UNINSTALL EXTENSION vsql_schematron;
