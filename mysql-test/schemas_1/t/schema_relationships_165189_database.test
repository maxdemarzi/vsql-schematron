INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165189_database
--echo #
CREATE DATABASE `db_165189_database`;
USE `db_165189_database`;

CREATE TABLE `user_info` (
  `username` VARCHAR(255),
  `name` VARCHAR(255),
  `surname` VARCHAR(255),
  `date_of_birth` DATETIME,
  `receive_newsletter` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_login_history` (
  `username` VARCHAR(255),
  `date_time` DATETIME,
  `ip_address` VARCHAR(255),
  PRIMARY KEY (`username`, `date_time`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `enabled` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165189_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165189_database') AS relationships;
DROP DATABASE `db_165189_database`;
UNINSTALL EXTENSION vsql_schematron;
