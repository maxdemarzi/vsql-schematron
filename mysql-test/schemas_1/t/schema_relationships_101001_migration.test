INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 101001_migration
--echo #
CREATE DATABASE `db_101001_migration`;
USE `db_101001_migration`;

CREATE TABLE `Admin` (
  `id` INT,
  `createdAt` DATETIME,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Log` (
  `id` INT,
  `title` VARCHAR(64),
  `authorId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_101001_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_101001_migration') AS relationships;
DROP DATABASE `db_101001_migration`;
UNINSTALL EXTENSION vsql_schematron;
