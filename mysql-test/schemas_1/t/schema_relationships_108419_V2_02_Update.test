INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 108419_V2.02__Update
--echo #
CREATE DATABASE `db_108419_V2_02_Update`;
USE `db_108419_V2_02_Update`;

CREATE TABLE `rds_ec2_security_group` (
  `rds_ec2_security_group_id` INT,
  `rds_sec_grp_id` INT,
  `ec2_security_group_owner_id` VARCHAR(64),
  `ec2_security_group_name` VARCHAR(64),
  `status` VARCHAR(64),
  PRIMARY KEY (`rds_ec2_security_group_id`)
) CHARACTER SET latin1;

CREATE TABLE `rds_security_group` (
  `rds_db_security_group_id` INT,
  `dbsecurityGroupDescription` VARCHAR(64),
  `dbsecurityGroupName` VARCHAR(64),
  `internals` VARCHAR(64),
  `port` INT,
  `stackId` VARCHAR(64),
  `status` VARCHAR(64),
  `transcendOnly` BOOL,
  `account_id` INT,
  PRIMARY KEY (`rds_db_security_group_id`)
) CHARACTER SET latin1;

CREATE TABLE `zones` (
  `id` VARCHAR(64),
  `accountId` INT,
  `callerReference` VARCHAR(64),
  `comment` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `changes` (
  `ID` VARCHAR(64),
  `status` VARCHAR(64),
  `submit_time` VARCHAR(64),
  `zone_table` VARCHAR(64),
  `request` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `rrSet` (
  `rrSet_id` INT,
  `name` VARCHAR(64),
  `rdata` VARCHAR(64),
  `rdtype` VARCHAR(64),
  `sid` VARCHAR(64),
  `ttl` INT,
  `weight` INT,
  `zoneId` VARCHAR(64),
  `zoneName` VARCHAR(64),
  PRIMARY KEY (`rrSet_id`)
) CHARACTER SET latin1;

CREATE TABLE `cf_stack` (
  `id` INT,
  `disableRollBack` BOOL,
  `notifications` VARCHAR(64),
  `parameters` VARCHAR(64),
  `region` VARCHAR(64),
  `stackId` VARCHAR(64),
  `stackName` VARCHAR(64),
  `templateBody` VARCHAR(64),
  `templateURL` VARCHAR(64),
  `timeoutInMins` INT,
  `urn` VARCHAR(64),
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `elasticache_node` (
  `id` INT,
  `elasticache_node_address` VARCHAR(64),
  `cluster_id` INT,
  `created_time` DATETIME,
  `instance_id` VARCHAR(64),
  `status` VARCHAR(64),
  `parameter_group_status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_JOB_DETAILS` (
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `JOB_CLASS_NAME` VARCHAR(64),
  `IS_DURABLE` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `IS_STATEFUL` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_JOB_LISTENERS` (
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `JOB_LISTENER` VARCHAR(64),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`, `JOB_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `NEXT_FIRE_TIME` INT,
  `PREV_FIRE_TIME` INT,
  `PRIORITY` INT,
  `TRIGGER_STATE` VARCHAR(64),
  `TRIGGER_TYPE` VARCHAR(64),
  `START_TIME` INT,
  `END_TIME` INT,
  `CALENDAR_NAME` VARCHAR(64),
  `MISFIRE_INSTR` INT,
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SIMPLE_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `REPEAT_COUNT` INT,
  `REPEAT_INTERVAL` INT,
  `TIMES_TRIGGERED` INT,
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CRON_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `CRON_EXPRESSION` VARCHAR(64),
  `TIME_ZONE_ID` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_BLOB_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `BLOB_DATA` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_TRIGGER_LISTENERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `TRIGGER_LISTENER` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`, `TRIGGER_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CALENDARS` (
  `CALENDAR_NAME` VARCHAR(64),
  `CALENDAR` VARCHAR(64),
  PRIMARY KEY (`CALENDAR_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_PAUSED_TRIGGER_GRPS` (
  `TRIGGER_GROUP` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_FIRED_TRIGGERS` (
  `ENTRY_ID` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `INSTANCE_NAME` VARCHAR(64),
  `FIRED_TIME` INT,
  `PRIORITY` INT,
  `STATE` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `IS_STATEFUL` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  PRIMARY KEY (`ENTRY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SCHEDULER_STATE` (
  `INSTANCE_NAME` VARCHAR(64),
  `LAST_CHECKIN_TIME` INT,
  `CHECKIN_INTERVAL` INT,
  PRIMARY KEY (`INSTANCE_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_LOCKS` (
  `LOCK_NAME` VARCHAR(64),
  PRIMARY KEY (`LOCK_NAME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_108419_V2_02_Update') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_108419_V2_02_Update') AS relationships;
DROP DATABASE `db_108419_V2_02_Update`;
UNINSTALL EXTENSION vsql_schematron;
