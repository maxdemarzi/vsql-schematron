INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 100783_fpl
--echo #
CREATE DATABASE `db_100783_fpl`;
USE `db_100783_fpl`;
CREATE TABLE `Clubs` (
  `ID` INT,
  `Name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SquadMembers` (
  `Squad` INT,
  `Player` INT
) CHARACTER SET latin1;
CREATE TABLE `Squads` (
  `ID` INT,
  `Name` VARCHAR(50),
  `Value` DECIMAL(10,2),
  `Owner` INT
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `ID` INT,
  `Name` VARCHAR(50),
  `Email` VARCHAR(50),
  `Password` VARCHAR(50),
  `FavTeam` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_100783_fpl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_100783_fpl') AS relationships;
DROP DATABASE `db_100783_fpl`;
UNINSTALL EXTENSION vsql_schematron;
