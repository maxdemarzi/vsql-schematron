INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113099_table_referencing_itself
--echo #
CREATE DATABASE `db_113099_table_referencing_itself`;
USE `db_113099_table_referencing_itself`;

CREATE TABLE `test_table` (
  `id` INT,
  `self_reference_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113099_table_referencing_itself') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113099_table_referencing_itself') AS relationships;
DROP DATABASE `db_113099_table_referencing_itself`;
UNINSTALL EXTENSION vsql_schematron;
