INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 178181_V4.026__create_unified_user
--echo #
CREATE DATABASE `db_178181_V4_026__create_unified_user`;
USE `db_178181_V4_026__create_unified_user`;
CREATE TABLE `scopes` (
  `id` INT NOT NULL,
  `source` VARCHAR(50),
  `parent_id` INT,
  `parent_path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organizations` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `kind` VARCHAR(50),
  `parent_id` INT,
  `scope_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scope_domains` (
  `id` INT NOT NULL,
  `scope_id` INT,
  `domain` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `systems` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resources` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `system_id` INT,
  `description` TEXT,
  `actions` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `id` INT NOT NULL,
  `scope_id` INT,
  `resource_id` INT,
  `actions` VARCHAR(50),
  `frn` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `scope_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_permissions` (
  `id` INT NOT NULL,
  `role_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `ratchet` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_roles` (
  `id` INT NOT NULL,
  `account_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_access_methods` (
  `id` INT NOT NULL,
  `account_id` INT,
  `name` VARCHAR(50),
  `hashed_password` VARCHAR(50),
  `algorithm` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_organizations` (
  `id` INT NOT NULL,
  `account_id` INT,
  `organization_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `account_id` INT,
  `email` VARCHAR(50),
  `is_disabled` BOOLEAN,
  `disabled_by` INT,
  `is_blacklisted` BOOLEAN,
  `blacklisted_by` INT,
  `name` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
