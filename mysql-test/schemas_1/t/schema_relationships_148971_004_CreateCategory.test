INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148971_004-CreateCategory
--echo #
CREATE DATABASE `db_148971_004_CreateCategory`;
USE `db_148971_004_CreateCategory`;

CREATE TABLE `category` (
  `category_id` INT,
  `category_name` VARCHAR(64),
  `owner_id` INT,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148971_004_CreateCategory') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148971_004_CreateCategory') AS relationships;
DROP DATABASE `db_148971_004_CreateCategory`;
UNINSTALL EXTENSION vsql_schematron;
