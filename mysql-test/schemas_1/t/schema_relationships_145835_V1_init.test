INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145835_V1__init
--echo #
CREATE DATABASE `db_145835_V1_init`;
USE `db_145835_V1_init`;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_account` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `idrole` INT,
  `deleted` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permission` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `deleted` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_permission` (
  `idrole` INT,
  `idpermission` INT,
  PRIMARY KEY (`idrole`, `idpermission`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145835_V1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145835_V1_init') AS relationships;
DROP DATABASE `db_145835_V1_init`;
UNINSTALL EXTENSION vsql_schematron;
