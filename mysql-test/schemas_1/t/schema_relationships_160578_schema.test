INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 160578_schema
--echo #
CREATE DATABASE `db_160578_schema`;
USE `db_160578_schema`;

CREATE TABLE `mailing_lists` (
  `id` INT,
  `title` VARCHAR(64),
  `email` VARCHAR(64),
  `enabled` VARCHAR(64),
  `language` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `list_id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` VARCHAR(64),
  PRIMARY KEY (`list_id`, `email`)
) CHARACTER SET latin1;

CREATE TABLE `subscriptions` (
  `uuid` VARCHAR(64),
  `list_id` INT,
  `email` VARCHAR(64),
  `timestamp` DATETIME,
  `request` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_160578_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_160578_schema') AS relationships;
DROP DATABASE `db_160578_schema`;
UNINSTALL EXTENSION vsql_schematron;
