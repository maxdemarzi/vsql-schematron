INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163595_V1__initial_migration
--echo #
CREATE DATABASE `db_163595_V1_initial_migration`;
USE `db_163595_V1_initial_migration`;

CREATE TABLE `lead_sources` (
  `id` INT,
  `name` VARCHAR(64),
  `incoming_number_national` VARCHAR(64),
  `incoming_number_international` VARCHAR(64),
  `forwarding_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `leads` (
  `id` INT,
  `phone_number` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `lead_source_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163595_V1_initial_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163595_V1_initial_migration') AS relationships;
DROP DATABASE `db_163595_V1_initial_migration`;
UNINSTALL EXTENSION vsql_schematron;
