INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 176985_soccer_academy
--echo #
CREATE DATABASE `db_176985_soccer_academy`;
USE `db_176985_soccer_academy`;

CREATE TABLE `achievements` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `image_path` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `coaches` (
  `id` INT,
  `name` VARCHAR(64),
  `image_path` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `galleries` (
  `id` INT,
  `name` VARCHAR(64),
  `image_path` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genders` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `leagues` (
  `id` INT,
  `name` VARCHAR(64),
  `date` DATETIME,
  `location` VARCHAR(64),
  `image_path` VARCHAR(64),
  `status` VARCHAR(64),
  `results` VARCHAR(64),
  `extras` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `managers` (
  `id` INT,
  `name` VARCHAR(64),
  `image_path` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `matches` (
  `id` INT,
  `participant` VARCHAR(64),
  `date` DATETIME,
  `time` VARCHAR(64),
  `tournament_id` INT,
  `extras` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `members` (
  `id` INT,
  `name` VARCHAR(64),
  `nisn` INT,
  `birth_date` DATETIME,
  `birth_place` VARCHAR(64),
  `class_type` VARCHAR(64),
  `gender_id` INT,
  `religion` VARCHAR(64),
  `address` VARCHAR(64),
  `height` VARCHAR(64),
  `weight` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `image_path` VARCHAR(64),
  `position` VARCHAR(64),
  `reason` VARCHAR(64),
  `notes` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `news` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `date` DATETIME,
  `images` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schedules` (
  `id` INT,
  `team_id1` INT,
  `score_team_id1` INT,
  `score_team_id2` INT,
  `team_id2` INT,
  `date` DATETIME,
  `time` DATETIME,
  `location` VARCHAR(64),
  `league_id` INT,
  `extras` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `scores` (
  `id` INT,
  `matches_id` INT,
  `teams_id` INT,
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `structures` (
  `id` INT,
  `name` VARCHAR(64),
  `position` VARCHAR(64),
  `image_path` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `manager_id` VARCHAR(64),
  `coach_id` VARCHAR(64),
  `licenses` VARCHAR(64),
  `email` VARCHAR(64),
  `telp` VARCHAR(64),
  `photo` VARCHAR(64),
  `registration_number` VARCHAR(64),
  `status` VARCHAR(64),
  `type` VARCHAR(64),
  `created_at` VARCHAR(64),
  `updated_at` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `team_has_leagues` (
  `team_id` INT,
  `league_id` INT
) CHARACTER SET latin1;

CREATE TABLE `team_has_tournaments` (
  `team_id` INT,
  `tournament_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tournaments` (
  `id` INT,
  `name` VARCHAR(64),
  `date` DATETIME,
  `location` VARCHAR(64),
  `image_path` VARCHAR(64),
  `status` VARCHAR(64),
  `results` VARCHAR(64),
  `extras` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_176985_soccer_academy') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_176985_soccer_academy') AS relationships;
DROP DATABASE `db_176985_soccer_academy`;
UNINSTALL EXTENSION vsql_schematron;
