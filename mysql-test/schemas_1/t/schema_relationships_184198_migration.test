INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184198_migration
--echo #
CREATE DATABASE `db_184198_migration`;
USE `db_184198_migration`;

CREATE TABLE `elections` (
  `id` INT,
  `code` VARCHAR(64),
  `numbe_of_joined` INT,
  `voter_count` INT,
  `last_used` DATETIME,
  `type` VARCHAR(64),
  `data` VARCHAR(64),
  `photoId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `photos` (
  `id` INT,
  `data` VARCHAR(64),
  `electionId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184198_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184198_migration') AS relationships;
DROP DATABASE `db_184198_migration`;
UNINSTALL EXTENSION vsql_schematron;
