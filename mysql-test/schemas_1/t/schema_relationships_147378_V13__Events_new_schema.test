INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147378_V13__Events_new_schema
--echo #
CREATE DATABASE `db_147378_V13__Events_new_schema`;
USE `db_147378_V13__Events_new_schema`;
CREATE TABLE `participant_events` (
  `event_id` VARCHAR(50) NOT NULL,
  `event_offset` BIGINT,
  `contract_id` VARCHAR(50),
  `transaction_id` VARCHAR(50),
  `ledger_effective_time` TIMESTAMP NULL,
  `template_package_id` VARCHAR(50),
  `template_name` VARCHAR(50),
  `node_index` INT,
  `is_root` BOOLEAN,
  `command_id` VARCHAR(50),
  `workflow_id` VARCHAR(50),
  `application_id` VARCHAR(50),
  `submitter` VARCHAR(50),
  `create_argument` VARCHAR(50),
  `create_signatories` VARCHAR(50),
  `create_observers` VARCHAR(50),
  `create_agreement_text` VARCHAR(50),
  `create_consumed_at` VARCHAR(50),
  `create_key_value` VARCHAR(50),
  `exercise_consuming` BOOLEAN,
  `exercise_choice` VARCHAR(50),
  `exercise_argument` VARCHAR(50),
  `exercise_result` VARCHAR(50),
  `exercise_actors` VARCHAR(50),
  `exercise_child_event_ids` VARCHAR(50),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `participant_event_flat_transaction_witnesses` (
  `event_id` VARCHAR(50),
  `event_witness` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `participant_event_witnesses_complement` (
  `event_id` VARCHAR(50),
  `event_witness` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147378_V13__Events_new_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147378_V13__Events_new_schema') AS relationships;
DROP DATABASE `db_147378_V13__Events_new_schema`;
UNINSTALL EXTENSION vsql_schematron;
