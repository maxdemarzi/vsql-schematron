INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165597_000002_plants_and_user_plants.up
--echo #
CREATE DATABASE `db_165597_000002_plants_and_user_plants_up`;
USE `db_165597_000002_plants_and_user_plants_up`;
CREATE TABLE `plants` (
  `id_plant` BIGINT NOT NULL,
  `name_plant` VARCHAR(50),
  `photo_url` VARCHAR(50),
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_plant`)
) CHARACTER SET latin1;
CREATE TABLE `user_plants` (
  `id_user_plant` BIGINT NOT NULL,
  `id_user` BIGINT,
  `id_plant` BIGINT,
  `planting_time` TIMESTAMP NULL,
  `watering_interval` INT,
  `last_watering` TIMESTAMP NULL,
  `next_watering` TIMESTAMP NULL,
  `photo_url` VARCHAR(50),
  `name_user_plant` VARCHAR(50),
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id_user_plant`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165597_000002_plants_and_user_plants_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165597_000002_plants_and_user_plants_up') AS relationships;
DROP DATABASE `db_165597_000002_plants_and_user_plants_up`;
UNINSTALL EXTENSION vsql_schematron;
