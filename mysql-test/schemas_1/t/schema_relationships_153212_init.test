INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153212_init
--echo #
CREATE DATABASE `db_153212_init`;
USE `db_153212_init`;

CREATE TABLE `dict` (
  `id` INT,
  `name` VARCHAR(64),
  `language` VARCHAR(64),
  `enabled` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `word` (
  `id` INT,
  `word` VARCHAR(64),
  `bitmap` INT,
  `unique_char` INT,
  `frequency` DECIMAL(10,2),
  `definition` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `game` (
  `id` INT,
  `letters` VARCHAR(64),
  `game_key` VARCHAR(64),
  `score` INT,
  `max_score` INT,
  `created_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `game_word` (
  `id` INT,
  `game_id` INT,
  `word_id` INT,
  `found_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dict_word` (
  `id` INT,
  `word_id` INT,
  `dict_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dict_game` (
  `id` INT,
  `game_id` INT,
  `dict_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153212_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153212_init') AS relationships;
DROP DATABASE `db_153212_init`;
UNINSTALL EXTENSION vsql_schematron;
