INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 104529_0_712021
--echo #
CREATE DATABASE `db_104529_0_712021`;
USE `db_104529_0_712021`;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `post_id` INT,
  `comment` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `txt` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_104529_0_712021') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_104529_0_712021') AS relationships;
DROP DATABASE `db_104529_0_712021`;
UNINSTALL EXTENSION vsql_schematron;
