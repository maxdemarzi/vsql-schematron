CREATE TABLE `egw_contractor_grade` (
  `id` BIGINT NOT NULL,
  `grade` CHAR(50),
  `description` CHAR(50),
  `min_amount` DOUBLE,
  `max_amount` DOUBLE,
  `createdby` BIGINT,
  `modifiedby` BIGINT,
  `createddate` TIMESTAMP NULL,
  `modifieddate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `egw_typeofwork` (
  `id` BIGINT NOT NULL,
  `code` CHAR(50),
  `parentid` BIGINT,
  `description` CHAR(50),
  `createdby` BIGINT,
  `createddate` TIMESTAMP NULL,
  `lastmodifiedby` BIGINT,
  `lastmodifieddate` TIMESTAMP NULL,
  `partytypeid` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_176041_V20151013120810__commons_incremental_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_176041_V20151013120810__commons_incremental_DDL') AS relationships;
DROP DATABASE `db_176041_V20151013120810__commons_incremental_DDL`;
