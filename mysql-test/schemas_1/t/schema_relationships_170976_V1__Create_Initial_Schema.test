INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 170976_V1__Create_Initial_Schema
--echo #
CREATE DATABASE `db_170976_V1__Create_Initial_Schema`;
USE `db_170976_V1__Create_Initial_Schema`;
CREATE TABLE `event` (
  `id` BIGINT NOT NULL,
  `bundle_id` VARCHAR(50),
  `message_id` VARCHAR(50),
  `event_type` VARCHAR(50),
  `bundle_timestamp` TIMESTAMP NULL,
  `recorded` TIMESTAMP NULL,
  `source` VARCHAR(50),
  `data` TEXT,
  `data_type` VARCHAR(50),
  `data_bytes` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `destination` (
  `id` INT NOT NULL,
  `event_id` BIGINT,
  `endpoint` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_170976_V1__Create_Initial_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_170976_V1__Create_Initial_Schema') AS relationships;
DROP DATABASE `db_170976_V1__Create_Initial_Schema`;
UNINSTALL EXTENSION vsql_schematron;
