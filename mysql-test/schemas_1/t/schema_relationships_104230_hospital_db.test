INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 104230_hospital_db
--echo #
CREATE DATABASE `db_104230_hospital_db`;
USE `db_104230_hospital_db`;

CREATE TABLE `admins` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `role` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `doctors` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `specialist` VARCHAR(64),
  `role` INT,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nurses` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `role` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `patients` (
  `id` INT,
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `gender` INT,
  `health_condition` VARCHAR(64),
  `doctor_id` INT,
  `nurse_id` INT,
  `created` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `patient_id` INT,
  `note` VARCHAR(64),
  `cancerous` INT,
  `url` VARCHAR(64),
  `created` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_104230_hospital_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_104230_hospital_db') AS relationships;
DROP DATABASE `db_104230_hospital_db`;
UNINSTALL EXTENSION vsql_schematron;
