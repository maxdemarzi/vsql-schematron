INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 192259_queries
--echo #
CREATE DATABASE `db_192259_queries`;
USE `db_192259_queries`;

CREATE TABLE `clients` (
  `client_id` INT,
  `name` VARCHAR(255),
  `user_name` VARCHAR(255),
  `age` INT,
  `registered` DATETIME,
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `item_id` INT,
  `name` VARCHAR(255),
  `price` DECIMAL(10,2),
  `quantity` INT,
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `clientID` INT,
  `itemID` INT,
  `quantity` INT,
  `ordered_at` DATETIME,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `fulfilled_orders` (
  `fulfilled_order_id` INT,
  `clientID` INT,
  `itemID` INT,
  `quantity` INT,
  `fulfilled_at` DATETIME,
  PRIMARY KEY (`fulfilled_order_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_192259_queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_192259_queries') AS relationships;
DROP DATABASE `db_192259_queries`;
UNINSTALL EXTENSION vsql_schematron;
