INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113083_201901060312_migration
--echo #
CREATE DATABASE `db_113083_201901060312_migration`;
USE `db_113083_201901060312_migration`;
CREATE TABLE `author` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  `status` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `isbn` VARCHAR(50),
  `about` VARCHAR(50),
  `edition` SMALLINT,
  `page_number` SMALLINT,
  `release_date` TIMESTAMP NULL,
  `author_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  `status` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113083_201901060312_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113083_201901060312_migration') AS relationships;
DROP DATABASE `db_113083_201901060312_migration`;
UNINSTALL EXTENSION vsql_schematron;
