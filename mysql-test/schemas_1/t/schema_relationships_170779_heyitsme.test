INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 170779_heyitsme
--echo #
CREATE DATABASE `db_170779_heyitsme`;
USE `db_170779_heyitsme`;
CREATE TABLE `blog` (
  `id` INT NOT NULL,
  `title` TEXT,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favourite_songs` (
  `id` INT,
  `ost_id` INT
) CHARACTER SET latin1;
CREATE TABLE `heyitsme` (
  `id` VARCHAR(50) NOT NULL,
  `body` VARCHAR(50),
  `date` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `migration` VARCHAR(50),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `head` TEXT,
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ost` (
  `id` INT,
  `name` VARCHAR(50),
  `path` VARCHAR(50),
  `season` INT
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
  `email` VARCHAR(50),
  `token` VARCHAR(50),
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` VARCHAR(50) NOT NULL,
  `body` VARCHAR(50),
  `date` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `seasons` (
  `season_id` INT NOT NULL,
  `season` VARCHAR(50),
  PRIMARY KEY (`season_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50),
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `email_verified_at` TIMESTAMP NULL,
  `password` VARCHAR(50),
  `remember_token` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_170779_heyitsme') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_170779_heyitsme') AS relationships;
DROP DATABASE `db_170779_heyitsme`;
UNINSTALL EXTENSION vsql_schematron;
