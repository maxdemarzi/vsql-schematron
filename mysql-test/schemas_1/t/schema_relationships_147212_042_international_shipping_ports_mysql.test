INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 147212_042_international_shipping_ports.mysql
--echo #
CREATE DATABASE `db_147212_042_international_shipping_ports_mysql`;
USE `db_147212_042_international_shipping_ports_mysql`;

CREATE TABLE `fv_ports` (
  `fv_port_id` INT,
  `fv_port_code` VARCHAR(64),
  `fv_port_name` VARCHAR(64),
  `fv_port_country` VARCHAR(64),
  `maidenhead` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`fv_port_id`)
) CHARACTER SET latin1;

CREATE TABLE `fv_transits` (
  `fv_transit_id` INT,
  `from_port` INT,
  `to_port` INT,
  `ship_mode` INT,
  `transit_time` DECIMAL(10,2),
  `transit_uom` VARCHAR(64),
  PRIMARY KEY (`fv_transit_id`)
) CHARACTER SET latin1;

CREATE TABLE `fv_entity_transits` (
  `fv_transit_id` INT,
  `fv_port_id` INT,
  `entity_id` INT,
  `ship_mode` INT,
  `transit_time` DECIMAL(10,2),
  `transit_uom` VARCHAR(64),
  PRIMARY KEY (`fv_transit_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_147212_042_international_shipping_ports_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_147212_042_international_shipping_ports_mysql') AS relationships;
DROP DATABASE `db_147212_042_international_shipping_ports_mysql`;
UNINSTALL EXTENSION vsql_schematron;
