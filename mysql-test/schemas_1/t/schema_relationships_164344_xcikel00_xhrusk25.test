INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 164344_xcikel00_xhrusk25
--echo #
CREATE DATABASE `db_164344_xcikel00_xhrusk25`;
USE `db_164344_xcikel00_xhrusk25`;

CREATE TABLE `AIRLINE` (
  `AIRLINE_ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `COUNTRY` VARCHAR(64),
  PRIMARY KEY (`AIRLINE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AIRPORT` (
  `AIRPORT_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `COUNTRY` VARCHAR(64),
  PRIMARY KEY (`AIRPORT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `GATE` (
  `GATE_ID` VARCHAR(64),
  `TERMINAL` VARCHAR(64),
  PRIMARY KEY (`GATE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FLIGHT` (
  `FLIGHT_ID` DECIMAL(10,2),
  `DEPARTURE_TIME` DATETIME,
  `ARRIVAL_TIME` DATETIME,
  `AIRLINE` DECIMAL(10,2),
  `DESTINATION` VARCHAR(64),
  `GATE` VARCHAR(64),
  PRIMARY KEY (`FLIGHT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `GATE_COMPATIBILITY` (
  `GATE` VARCHAR(64),
  `AIRCRAFT_TYPE` VARCHAR(64),
  PRIMARY KEY (`GATE`, `AIRCRAFT_TYPE`)
) CHARACTER SET latin1;

CREATE TABLE `AIRCRAFT_TYPE` (
  `AIRCRAFT_TYPE_ID` VARCHAR(64),
  `MANUFACTURER` VARCHAR(64),
  PRIMARY KEY (`AIRCRAFT_TYPE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `AIRCRAFT` (
  `AIRCRAFT_ID` DECIMAL(10,2),
  `MANUFACTURING_DATE` DATETIME,
  `REVISION_DATE` DATETIME,
  `CREW_NUM` DECIMAL(10,2),
  `AIRCRAFT_TYPE` VARCHAR(64),
  PRIMARY KEY (`AIRCRAFT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SEAT` (
  `AIRCRAFT_ID` DECIMAL(10,2),
  `SEAT_NUMBER` DECIMAL(10,2),
  `CLASS` VARCHAR(64),
  `POSITION` VARCHAR(64),
  PRIMARY KEY (`AIRCRAFT_ID`, `SEAT_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `PERSON` (
  `PASSPORT_ID` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `NATIONALITY` VARCHAR(64),
  `EMPLOYEE_ID` DECIMAL(10,2),
  PRIMARY KEY (`PASSPORT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMPLOYEE` (
  `EMPLOYEE_ID` DECIMAL(10,2),
  `POSITION` VARCHAR(64),
  PRIMARY KEY (`EMPLOYEE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `TICKET` (
  `TICKET_ID` DECIMAL(10,2),
  `FLIGHT_ID` DECIMAL(10,2),
  `PASSPORT_ID` VARCHAR(64),
  PRIMARY KEY (`TICKET_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BOARDING_TICKET` (
  `TICKET_ID` DECIMAL(10,2),
  `AIRCRAFT_ID` DECIMAL(10,2),
  `SEAT_NUMBER` DECIMAL(10,2),
  `BOARDING_TIME` DATETIME,
  PRIMARY KEY (`TICKET_ID`, `BOARDING_TIME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_164344_xcikel00_xhrusk25') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_164344_xcikel00_xhrusk25') AS relationships;
DROP DATABASE `db_164344_xcikel00_xhrusk25`;
UNINSTALL EXTENSION vsql_schematron;
