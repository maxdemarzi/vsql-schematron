INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 149601_migration
--echo #
CREATE DATABASE `db_149601_migration`;
USE `db_149601_migration`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `avatarUrl` TEXT,
  `username` TEXT,
  `password` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gists` (
  `id` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `isPrivate` BOOLEAN,
  `authorId` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gist_files` (
  `id` VARCHAR(50) NOT NULL,
  `gistId` TEXT,
  `filename` TEXT,
  `snippet` TEXT,
  `language` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` VARCHAR(50) NOT NULL,
  `comment` TEXT,
  `userId` TEXT,
  `gistId` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_149601_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_149601_migration') AS relationships;
DROP DATABASE `db_149601_migration`;
UNINSTALL EXTENSION vsql_schematron;
