INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172403_gerenciadordispositivos
--echo #
CREATE DATABASE `db_172403_gerenciadordispositivos`;
USE `db_172403_gerenciadordispositivos`;
CREATE TABLE `categoria` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dispositivos` (
  `id` INT,
  `categoria_estrangeira` INT,
  `cor` VARCHAR(50),
  `partNumber` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172403_gerenciadordispositivos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172403_gerenciadordispositivos') AS relationships;
DROP DATABASE `db_172403_gerenciadordispositivos`;
UNINSTALL EXTENSION vsql_schematron;
