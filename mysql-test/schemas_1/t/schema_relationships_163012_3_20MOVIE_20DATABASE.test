INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163012_3.%20MOVIE%20DATABASE
--echo #
CREATE DATABASE `db_163012_3_20MOVIE_20DATABASE`;
USE `db_163012_3_20MOVIE_20DATABASE`;

CREATE TABLE `ACTOR` (
  `ACTID` DECIMAL(10,2),
  `ACTNAME` VARCHAR(64),
  `ACTGENDER` VARCHAR(64),
  PRIMARY KEY (`ACTID`)
) CHARACTER SET latin1;

CREATE TABLE `DIRECTOR` (
  `DIRID` DECIMAL(10,2),
  `DIRNAME` VARCHAR(64),
  `DIRPHONE` DECIMAL(10,2),
  PRIMARY KEY (`DIRID`)
) CHARACTER SET latin1;

CREATE TABLE `MOVIES` (
  `MOVID` DECIMAL(10,2),
  `MOVTITLE` VARCHAR(64),
  `MOVYEAR` DECIMAL(10,2),
  `MOVLANG` VARCHAR(64),
  `DIRID` DECIMAL(10,2),
  PRIMARY KEY (`MOVID`)
) CHARACTER SET latin1;

CREATE TABLE `MOVIECAST` (
  `ACTID` DECIMAL(10,2),
  `MOVID` DECIMAL(10,2),
  `ROLE` VARCHAR(64),
  PRIMARY KEY (`ACTID`, `MOVID`)
) CHARACTER SET latin1;

CREATE TABLE `RATING` (
  `MOVID` DECIMAL(10,2),
  `REVSTARS` VARCHAR(64),
  PRIMARY KEY (`MOVID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163012_3_20MOVIE_20DATABASE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163012_3_20MOVIE_20DATABASE') AS relationships;
DROP DATABASE `db_163012_3_20MOVIE_20DATABASE`;
UNINSTALL EXTENSION vsql_schematron;
