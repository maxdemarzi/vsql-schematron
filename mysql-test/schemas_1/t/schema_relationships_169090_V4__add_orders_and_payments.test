INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 169090_V4__add_orders_and_payments
--echo #
CREATE DATABASE `db_169090_V4__add_orders_and_payments`;
USE `db_169090_V4__add_orders_and_payments`;
CREATE TABLE `orders` (
  `id` BIGINT NOT NULL,
  `number` VARCHAR(50),
  `placed_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `line_items` (
  `id` BIGINT NOT NULL,
  `item_number` VARCHAR(50),
  `item_unit_price` DECIMAL(10,2),
  `quantity` SMALLINT,
  `order_id` BIGINT,
  `order_line` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
  `id` BIGINT NOT NULL,
  `order_id` BIGINT,
  `date` DATE,
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_169090_V4__add_orders_and_payments') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169090_V4__add_orders_and_payments') AS relationships;
DROP DATABASE `db_169090_V4__add_orders_and_payments`;
UNINSTALL EXTENSION vsql_schematron;
