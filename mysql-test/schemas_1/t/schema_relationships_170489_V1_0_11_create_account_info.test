  `name` VARCHAR(64),
  `memo` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `account_info` (
  `type` VARCHAR(64),
  `value` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`type`)
) CHARACTER SET latin1;

