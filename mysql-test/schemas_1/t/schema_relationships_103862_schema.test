INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103862_schema
--echo #
CREATE DATABASE `db_103862_schema`;
USE `db_103862_schema`;

CREATE TABLE `securrity.users` (
  `user_id` VARCHAR(255),
  `name` VARCHAR(255),
  `encrypted_password` VARCHAR(255),
  `status` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.sessions` (
  `session_id` VARCHAR(255),
  `started_at` DATETIME,
  `ended_at` DATETIME,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.operations` (
  `operation_id` VARCHAR(255),
  `code` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `locked` VARCHAR(255),
  PRIMARY KEY (`operation_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.objects` (
  `object_id` VARCHAR(255),
  `code` VARCHAR(255),
  `display_name` VARCHAR(255),
  `type` VARCHAR(255),
  `definition` VARCHAR(255),
  `functional_model` VARCHAR(255),
  `source` VARCHAR(255),
  `locked` VARCHAR(255),
  PRIMARY KEY (`object_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.roles` (
  `role_id` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.user_roles` (
  `user_id` VARCHAR(255),
  `role_id` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `securrity.session_role` (
  `session_id` VARCHAR(255),
  `role_id` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `securrity.permissions` (
  `permission_id` VARCHAR(255),
  `code` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `object_id` VARCHAR(255),
  `operation_id` VARCHAR(255),
  PRIMARY KEY (`permission_id`)
) CHARACTER SET latin1;

CREATE TABLE `securrity.role_permissions` (
  `role_id` VARCHAR(255),
  `permission_id` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103862_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103862_schema') AS relationships;
DROP DATABASE `db_103862_schema`;
UNINSTALL EXTENSION vsql_schematron;
