INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 175626_ddl
--echo #
CREATE DATABASE `db_175626_ddl`;
USE `db_175626_ddl`;

CREATE TABLE `Groups` (
  `group_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;

CREATE TABLE `Students` (
  `student_id` INT,
  `name` VARCHAR(64),
  `group_id` INT,
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;

CREATE TABLE `Subjects` (
  `subject_id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;

CREATE TABLE `Marks` (
  `student_id` INT,
  `subject_id` INT,
  `value` VARCHAR(64),
  `date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `Teachers` (
  `teacher_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;

CREATE TABLE `TeachersSubjects` (
  `teacher_id` INT,
  `subject_id` INT,
  PRIMARY KEY (`teacher_id`, `subject_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_175626_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_175626_ddl') AS relationships;
DROP DATABASE `db_175626_ddl`;
UNINSTALL EXTENSION vsql_schematron;
