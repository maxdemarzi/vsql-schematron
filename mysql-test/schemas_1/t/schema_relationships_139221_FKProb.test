INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139221_FKProb
--echo #
CREATE DATABASE `db_139221_FKProb`;
USE `db_139221_FKProb`;

CREATE TABLE `OT` (
  `Name` VARCHAR(64),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `VTP` (
  `VTName` VARCHAR(64),
  `Name` VARCHAR(64),
  PRIMARY KEY (`VTName`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `VTPRestriction` (
  `VTName` VARCHAR(64),
  `VTPVTName` VARCHAR(64),
  `VTPName` VARCHAR(64),
  PRIMARY KEY (`VTName`, `VTPVTName`, `VTPName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139221_FKProb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139221_FKProb') AS relationships;
DROP DATABASE `db_139221_FKProb`;
UNINSTALL EXTENSION vsql_schematron;
