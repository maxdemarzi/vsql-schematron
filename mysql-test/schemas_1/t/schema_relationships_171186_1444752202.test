INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 171186_1444752202
--echo #
CREATE DATABASE `db_171186_1444752202`;
USE `db_171186_1444752202`;
CREATE TABLE `tb_account` (
  `id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `user_id` INT,
  `currency_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_currency` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `short_name` VARCHAR(50),
  `iso_code` VARCHAR(50),
  `currency_rate` DECIMAL(10,2),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_migration` (
  `version` VARCHAR(50) NOT NULL,
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `tb_role` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `create_time` TIMESTAMP NULL,
  `update_time` TIMESTAMP NULL,
  `can_admin` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_171186_1444752202') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_171186_1444752202') AS relationships;
DROP DATABASE `db_171186_1444752202`;
UNINSTALL EXTENSION vsql_schematron;
