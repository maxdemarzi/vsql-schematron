INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 196562_ScriptAlimentationBDD_v2
--echo #
CREATE DATABASE `db_196562_ScriptAlimentationBDD_v2`;
USE `db_196562_ScriptAlimentationBDD_v2`;

CREATE TABLE `cart` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart_items` (
  `id` INT,
  `id_ingredient_id` INT,
  `id_cart_id` INT,
  `quantity` INT,
  `price_when_bought` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `grocery_list` (
  `id` INT,
  `id_ingredient_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ratings` (
  `id` INT,
  `rating` INT,
  `date_rating` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_ingredients` (
  `users_id` INT,
  `ingredients_id` INT,
  PRIMARY KEY (`users_id`, `ingredients_id`)
) CHARACTER SET latin1;

CREATE TABLE `users_recipes` (
  `users_id` INT,
  `recipes_id` INT,
  PRIMARY KEY (`users_id`, `recipes_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_196562_ScriptAlimentationBDD_v2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_196562_ScriptAlimentationBDD_v2') AS relationships;
DROP DATABASE `db_196562_ScriptAlimentationBDD_v2`;
UNINSTALL EXTENSION vsql_schematron;
