INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 106720_library_scheme
--echo #
CREATE DATABASE `db_106720_library_scheme`;
USE `db_106720_library_scheme`;

CREATE TABLE `public.author` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.book` (
  `id` INT,
  `title` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.author_book` (
  `author_id` INT,
  `book_id` INT,
  PRIMARY KEY (`author_id`, `book_id`)
) CHARACTER SET latin1;

CREATE TABLE `public.reader` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.reader_book` (
  `reader_id` INT,
  `book_id` INT,
  PRIMARY KEY (`reader_id`, `book_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_106720_library_scheme') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_106720_library_scheme') AS relationships;
DROP DATABASE `db_106720_library_scheme`;
UNINSTALL EXTENSION vsql_schematron;
