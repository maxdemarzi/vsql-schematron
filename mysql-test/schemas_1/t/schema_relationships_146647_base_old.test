INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 146647_base_old
--echo #
CREATE DATABASE `db_146647_base_old`;
USE `db_146647_base_old`;

CREATE TABLE `messenger_name` (
  `messenger_id` INT,
  `messenger_title` VARCHAR(64),
  PRIMARY KEY (`messenger_id`)
) CHARACTER SET latin1;

CREATE TABLE `uploadmax` (
  `uploadmax_id` INT,
  `uploadmax_mb` VARCHAR(64),
  PRIMARY KEY (`uploadmax_id`)
) CHARACTER SET latin1;

CREATE TABLE `os_sup` (
  `os_sup_id` INT,
  `os_sup_title` VARCHAR(64),
  PRIMARY KEY (`os_sup_id`)
) CHARACTER SET latin1;

CREATE TABLE `yesorno` (
  `yesorno_id` INT,
  `yesorno_title` VARCHAR(64),
  PRIMARY KEY (`yesorno_id`)
) CHARACTER SET latin1;

CREATE TABLE `all_messengers` (
  `name` VARCHAR(64),
  `upmax` INT,
  `supos` INT,
  `supvideo` INT,
  `supvs` INT,
  `supgc` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_146647_base_old') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_146647_base_old') AS relationships;
DROP DATABASE `db_146647_base_old`;
UNINSTALL EXTENSION vsql_schematron;
