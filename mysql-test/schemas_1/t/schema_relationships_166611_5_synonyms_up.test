INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 166611_5_synonyms.up
--echo #
CREATE DATABASE `db_166611_5_synonyms_up`;
USE `db_166611_5_synonyms_up`;
CREATE TABLE `synonyms` (
  `id` INT NOT NULL,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `synonym_words` (
  `synonymID` INT,
  `word` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_166611_5_synonyms_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_166611_5_synonyms_up') AS relationships;
DROP DATABASE `db_166611_5_synonyms_up`;
UNINSTALL EXTENSION vsql_schematron;
