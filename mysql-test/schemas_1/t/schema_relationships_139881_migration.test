INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139881_migration
--echo #
CREATE DATABASE `db_139881_migration`;
USE `db_139881_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Post` (
  `id` VARCHAR(64),
  `slug` VARCHAR(64),
  `authorId` VARCHAR(64),
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `published` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Topic` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Image` (
  `id` VARCHAR(64),
  `postId` VARCHAR(64),
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_PostToTag` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_PostToTopic` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139881_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139881_migration') AS relationships;
DROP DATABASE `db_139881_migration`;
UNINSTALL EXTENSION vsql_schematron;
