INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151910_tables
--echo #
CREATE DATABASE `db_151910_tables`;
USE `db_151910_tables`;

CREATE TABLE `adminDetails` (
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `album` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `artist` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `about` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `song` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `album_id` VARCHAR(64),
  `genre` VARCHAR(64),
  `play_count` INT,
  `song_num` INT,
  `wav` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `song_artist` (
  `song_id` VARCHAR(64),
  `artist_id` VARCHAR(64),
  PRIMARY KEY (`song_id`, `artist_id`)
) CHARACTER SET latin1;

CREATE TABLE `album_artist` (
  `album_id` VARCHAR(64),
  `artist_id` VARCHAR(64),
  PRIMARY KEY (`album_id`, `artist_id`)
) CHARACTER SET latin1;

CREATE TABLE `history` (
  `user_id` VARCHAR(64),
  `song_id` VARCHAR(64),
  `last_played` DATETIME,
  PRIMARY KEY (`user_id`, `song_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151910_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151910_tables') AS relationships;
DROP DATABASE `db_151910_tables`;
UNINSTALL EXTENSION vsql_schematron;
