INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172607_skripsi
--echo #
CREATE DATABASE `db_172607_skripsi`;
USE `db_172607_skripsi`;
CREATE TABLE `barang` (
  `id_barang` INT,
  `nama_barang` VARCHAR(50),
  `jumlah` INT,
  `harga` INT
) CHARACTER SET latin1;
CREATE TABLE `penjualan` (
  `id_penjualan` INT,
  `id_barang` INT,
  `jumlah_terjual` INT,
  `kas` INT,
  `bulan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `level` INT,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172607_skripsi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172607_skripsi') AS relationships;
DROP DATABASE `db_172607_skripsi`;
UNINSTALL EXTENSION vsql_schematron;
