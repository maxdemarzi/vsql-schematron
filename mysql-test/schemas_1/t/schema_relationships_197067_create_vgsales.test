INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 197067_create_vgsales
--echo #
CREATE DATABASE `db_197067_create_vgsales`;
USE `db_197067_create_vgsales`;

CREATE TABLE `publishers` (
  `id` INT,
  `publisher` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `platforms` (
  `id` INT,
  `platform` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `games` (
  `id` INT,
  `rank` INT,
  `name` VARCHAR(64),
  `year` VARCHAR(64),
  `globalsales` VARCHAR(64),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `id` INT,
  `genre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres_of_games` (
  `game_id` INT,
  `genre_id` INT
) CHARACTER SET latin1;

CREATE TABLE `publishers_of_games` (
  `game_id` INT,
  `publisher_id` INT,
  `platform_id` INT
) CHARACTER SET latin1;

CREATE TABLE `platforms_of_games` (
  `game_id` INT,
  `platform_id` INT
) CHARACTER SET latin1;

CREATE TABLE `creditcards` (
  `id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `expiration` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `cc_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `customer_id` INT,
  `salesdate` DATETIME,
  `game_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_197067_create_vgsales') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_197067_create_vgsales') AS relationships;
DROP DATABASE `db_197067_create_vgsales`;
UNINSTALL EXTENSION vsql_schematron;
