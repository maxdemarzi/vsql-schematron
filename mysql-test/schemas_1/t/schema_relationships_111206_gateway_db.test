INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 111206_gateway_db
--echo #
CREATE DATABASE `db_111206_gateway_db`;
USE `db_111206_gateway_db`;
CREATE TABLE `gateway` (
  `gwid` VARCHAR(50) NOT NULL,
  `bd` VARCHAR(50),
  `flr` VARCHAR(50),
  `lct` VARCHAR(50),
  `rt` TIMESTAMP NULL,
  PRIMARY KEY (`gwid`)
) CHARACTER SET latin1;
CREATE TABLE `homeappliance` (
  `haid` VARCHAR(50),
  `hanm` VARCHAR(50),
  `hat` DECIMAL(10,2),
  `hafc` VARCHAR(50),
  `hamf` VARCHAR(50),
  `gwid` VARCHAR(50),
  `rt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `phone` (
  `phnb` VARCHAR(50),
  `lat` DOUBLE,
  `lng` DOUBLE,
  `addr` VARCHAR(50),
  `phst` VARCHAR(50),
  `sdst` VARCHAR(50),
  `rt` TIMESTAMP NULL,
  `mphnb` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `schedule` (
  `scdid` INT NOT NULL,
  `scdtl` VARCHAR(50),
  `scddt` VARCHAR(50),
  `scdtm` VARCHAR(50),
  `scdmm` TEXT,
  `rt` TIMESTAMP NULL,
  `mphnb` VARCHAR(50),
  PRIMARY KEY (`scdid`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
  `ssid` VARCHAR(50),
  `ssnm` VARCHAR(50),
  `sst` DECIMAL(10,2),
  `ssst` VARCHAR(50),
  `ssmf` VARCHAR(50),
  `gwid` VARCHAR(50),
  `rt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `service` (
  `svid` VARCHAR(50),
  `svnm` VARCHAR(50),
  `svvs` VARCHAR(50),
  `svif` VARCHAR(50),
  `ctg` VARCHAR(50),
  `rt` TIMESTAMP NULL,
  `svtp` VARCHAR(50),
  `gwid` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `mphnb` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `afl` VARCHAR(50),
  `ofc` VARCHAR(50),
  `type` VARCHAR(50),
  `crst` VARCHAR(50),
  `crlt` VARCHAR(50),
  `rt` TIMESTAMP NULL,
  `tagid` INT,
  `gwid` VARCHAR(50),
  PRIMARY KEY (`mphnb`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_111206_gateway_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_111206_gateway_db') AS relationships;
DROP DATABASE `db_111206_gateway_db`;
UNINSTALL EXTENSION vsql_schematron;
