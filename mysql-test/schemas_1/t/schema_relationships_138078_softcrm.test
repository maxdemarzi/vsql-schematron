INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 138078_softcrm
--echo #
CREATE DATABASE `db_138078_softcrm`;
USE `db_138078_softcrm`;

CREATE TABLE `admins` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `role_type` INT,
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `clients` (
  `id` INT,
  `full_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `section` VARCHAR(64),
  `budget` VARCHAR(64),
  `location` VARCHAR(64),
  `zip` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `companies` (
  `id` INT,
  `name` VARCHAR(64),
  `tax_number` VARCHAR(64),
  `phone` VARCHAR(64),
  `city` VARCHAR(64),
  `billing_address` VARCHAR(64),
  `country` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `employees_size` VARCHAR(64),
  `fax` VARCHAR(64),
  `description` VARCHAR(64),
  `is_active` INT,
  `client_id` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `countryzone` (
  `id` INT,
  `name` VARCHAR(64),
  `is_active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `deals` (
  `id` INT,
  `name` VARCHAR(64),
  `start_time` VARCHAR(64),
  `end_time` VARCHAR(64),
  `companies_id` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `deals_terms` (
  `id` INT,
  `body` VARCHAR(64),
  `deal_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `full_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `job` VARCHAR(64),
  `note` VARCHAR(64),
  `client_id` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `finances` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `category` VARCHAR(64),
  `type` VARCHAR(64),
  `gross` INT,
  `net` INT,
  `vat` INT,
  `date` DATETIME,
  `companies_id` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `category` VARCHAR(64),
  `count` INT,
  `price` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `reports` (
  `id` INT,
  `name` VARCHAR(64),
  `companies_id` INT,
  `clients_id` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `name` VARCHAR(64),
  `quantity` INT,
  `price` INT,
  `date_of_payment` DATETIME,
  `product_id` INT,
  `is_active` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `systemlogs` (
  `id` INT,
  `user_id` VARCHAR(64),
  `actions` VARCHAR(64),
  `status_code` INT,
  `ip_address` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `date` DATETIME,
  `admin_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `name` VARCHAR(64),
  `employee_id` INT,
  `duration` INT,
  `is_active` INT,
  `completed` INT,
  `admin_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_138078_softcrm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_138078_softcrm') AS relationships;
DROP DATABASE `db_138078_softcrm`;
UNINSTALL EXTENSION vsql_schematron;
