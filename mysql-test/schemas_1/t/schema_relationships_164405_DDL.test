INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 164405_DDL
--echo #
CREATE DATABASE `db_164405_DDL`;
USE `db_164405_DDL`;
CREATE TABLE `job_defs` (
  `id` INT NOT NULL,
  `job_link` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job_runs` (
  `id` INT NOT NULL,
  `job_id` INT,
  `job_run_id` INT,
  `params` VARCHAR(50),
  `display_name` VARCHAR(50),
  `full_job_url` VARCHAR(50),
  `job_causer` VARCHAR(50),
  `job_duration` INT,
  `job_timestamp` BIGINT,
  `job_result` VARCHAR(50),
  `job_timings` VARCHAR(50),
  `job_git_dets` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_164405_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_164405_DDL') AS relationships;
DROP DATABASE `db_164405_DDL`;
UNINSTALL EXTENSION vsql_schematron;
