INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 163492_bbdd
--echo #
CREATE DATABASE `db_163492_bbdd`;
USE `db_163492_bbdd`;

CREATE TABLE `users` (
  `id` INT,
  `role` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `password` VARCHAR(64),
  `nick` VARCHAR(64),
  `bio` VARCHAR(64),
  `active` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `publications` (
  `id` INT,
  `user_id` INT,
  `text` VARCHAR(64),
  `document` VARCHAR(64),
  `image` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `following` (
  `id` INT,
  `user` INT,
  `followed` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `private_messages` (
  `id` INT,
  `message` VARCHAR(64),
  `emitter` INT,
  `receiver` INT,
  `file` VARCHAR(64),
  `image` VARCHAR(64),
  `readed` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `id` INT,
  `user` INT,
  `publication` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` INT,
  `user_id` INT,
  `type` VARCHAR(64),
  `type_id` INT,
  `readed` VARCHAR(64),
  `created_at` DATETIME,
  `extra` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_163492_bbdd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_163492_bbdd') AS relationships;
DROP DATABASE `db_163492_bbdd`;
UNINSTALL EXTENSION vsql_schematron;
