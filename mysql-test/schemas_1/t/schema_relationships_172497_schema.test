INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 172497_schema
--echo #
CREATE DATABASE `db_172497_schema`;
USE `db_172497_schema`;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `slogan` VARCHAR(64),
  `description` VARCHAR(64),
  `category` VARCHAR(64),
  `defauLt_price` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `related` (
  `id` INT,
  `product_id` INT,
  `related_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `features` (
  `feature_id` INT,
  `product_id` INT,
  `feature` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`feature_id`)
) CHARACTER SET latin1;

CREATE TABLE `styles` (
  `style_id` INT,
  `product_id` INT,
  `name` VARCHAR(64),
  `sale_price` VARCHAR(64),
  `original_price` INT,
  `default_style` BOOL,
  PRIMARY KEY (`style_id`)
) CHARACTER SET latin1;

CREATE TABLE `photos` (
  `id` INT,
  `style_id` INT,
  `url` VARCHAR(64),
  `thumbnail_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `skus` (
  `id` INT,
  `styles_id` INT,
  `size` VARCHAR(64),
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products_temp` (
  `product_id` INT,
  `name` VARCHAR(64),
  `slogan` VARCHAR(64),
  `description` VARCHAR(64),
  `category` VARCHAR(64),
  `defauLt_price` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `related_temp` (
  `id` INT,
  `product_id` INT,
  `related_id` INT
) CHARACTER SET latin1;

CREATE TABLE `features_temp` (
  `feature_id` INT,
  `product_id` INT,
  `feature` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `styles_temp` (
  `style_id` INT,
  `product_id` INT,
  `name` VARCHAR(64),
  `sale_price` INT,
  `original_price` INT,
  `default_price` BOOL
) CHARACTER SET latin1;

CREATE TABLE `photos_temp` (
  `id` INT,
  `style_id` INT,
  `thumbnail_url` VARCHAR(64),
  `url` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `skus_temp` (
  `id` INT,
  `styles_id` INT,
  `quantity` INT,
  `size` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_172497_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_172497_schema') AS relationships;
DROP DATABASE `db_172497_schema`;
UNINSTALL EXTENSION vsql_schematron;
