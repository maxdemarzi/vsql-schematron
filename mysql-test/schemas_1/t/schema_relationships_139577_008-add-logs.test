INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139577_008-add-logs
--echo #
CREATE DATABASE `db_139577_008_add_logs`;
USE `db_139577_008_add_logs`;
CREATE TABLE `logs` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` DATETIME,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `log_values` (
  `log_id` VARCHAR(50) NOT NULL,
  `parameter` VARCHAR(50) NOT NULL,
  `value_int` INT,
  `value_text` TEXT,
  PRIMARY KEY (`log_id`, `parameter`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139577_008_add_logs') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139577_008_add_logs') AS relationships;
DROP DATABASE `db_139577_008_add_logs`;
UNINSTALL EXTENSION vsql_schematron;
