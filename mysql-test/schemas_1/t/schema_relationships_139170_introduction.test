INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 139170_introduction
--echo #
CREATE DATABASE `db_139170_introduction`;
USE `db_139170_introduction`;

CREATE TABLE `DEPARTMENTS` (
  `deptno` DECIMAL(10,2),
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  PRIMARY KEY (`deptno`)
) CHARACTER SET latin1;

CREATE TABLE `EMPLOYEES` (
  `empno` DECIMAL(10,2),
  `name` VARCHAR(64),
  `job` VARCHAR(64),
  `manager` DECIMAL(10,2),
  `hiredate` DATETIME,
  `salary` DECIMAL(10,2),
  `commission` DECIMAL(10,2),
  `deptno` DECIMAL(10,2),
  PRIMARY KEY (`empno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_139170_introduction') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_139170_introduction') AS relationships;
DROP DATABASE `db_139170_introduction`;
UNINSTALL EXTENSION vsql_schematron;
