INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 152916_lab1_create
--echo #
CREATE DATABASE `db_152916_lab1_create`;
USE `db_152916_lab1_create`;

CREATE TABLE `skills` (
  `ID` DECIMAL(10,2),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `companies` (
  `ID` DECIMAL(10,2),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `employee_number` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `ID` DECIMAL(10,2),
  `first_name` VARCHAR(64),
  `second_name` VARCHAR(64),
  `lang_level` VARCHAR(64),
  `country` VARCHAR(64),
  `company_id` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `ID` DECIMAL(10,2),
  `first_id` DECIMAL(10,2),
  `second_id` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `accounts` (
  `ID` DECIMAL(10,2),
  `profile_id` DECIMAL(10,2),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `is_stuff` DECIMAL(10,2),
  `is_active` DECIMAL(10,2),
  `last_login` DATETIME,
  `date_joined` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `jobs` (
  `ID` DECIMAL(10,2),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `company_id` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `jobskills` (
  `ID` DECIMAL(10,2),
  `first_id` DECIMAL(10,2),
  `second_id` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_152916_lab1_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_152916_lab1_create') AS relationships;
DROP DATABASE `db_152916_lab1_create`;
UNINSTALL EXTENSION vsql_schematron;
