INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 161663_schema
--echo #
CREATE DATABASE `db_161663_schema`;
USE `db_161663_schema`;

CREATE TABLE `roles` (
  `id` INT,
  `type_role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `pass` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `roles_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `id` INT,
  `price` DECIMAL(10,2),
  `room_capacity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `booking` (
  `id` INT,
  `start_booking` DATETIME,
  `end_booking` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `bill` DECIMAL(10,2),
  `account_type` VARCHAR(64),
  `room_id` INT,
  `booking_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_161663_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_161663_schema') AS relationships;
DROP DATABASE `db_161663_schema`;
UNINSTALL EXTENSION vsql_schematron;
