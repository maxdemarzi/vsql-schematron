INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 184776_V1__create_order_and_payment
--echo #
CREATE DATABASE `db_184776_V1__create_order_and_payment`;
USE `db_184776_V1__create_order_and_payment`;
CREATE TABLE `orders` (
  `id` BIGINT NOT NULL,
  `date` TIMESTAMP NULL,
  `amount` DECIMAL(10,2),
  `paid` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
  `id` BIGINT NOT NULL,
  `order_id` BIGINT,
  `credit_card_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_184776_V1__create_order_and_payment') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_184776_V1__create_order_and_payment') AS relationships;
DROP DATABASE `db_184776_V1__create_order_and_payment`;
UNINSTALL EXTENSION vsql_schematron;
