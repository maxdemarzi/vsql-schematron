INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 102892_tables
--echo #
CREATE DATABASE `db_102892_tables`;
USE `db_102892_tables`;

CREATE TABLE `blog_posts` (
  `post_id` INT,
  `content` VARCHAR(64),
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_dt` DATETIME,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_tags` (
  `tag_id` INT,
  `descr` VARCHAR(64),
  PRIMARY KEY (`tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_post_tags` (
  `post_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`post_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_comments` (
  `comment_id` INT,
  `post_id` INT,
  `user_name` VARCHAR(64),
  `user_email` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_102892_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_102892_tables') AS relationships;
DROP DATABASE `db_102892_tables`;
UNINSTALL EXTENSION vsql_schematron;
