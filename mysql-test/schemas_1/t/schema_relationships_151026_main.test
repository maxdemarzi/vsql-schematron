INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 151026_main
--echo #
CREATE DATABASE `db_151026_main`;
USE `db_151026_main`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `nick` TEXT,
  `password` TEXT,
  `salt` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `canvasses` (
  `id` INT NOT NULL,
  `title` TEXT,
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `canvas_id` INT,
  `owner_id` INT,
  `coordinate_x` INT,
  `coordinate_y` INT,
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_151026_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_151026_main') AS relationships;
DROP DATABASE `db_151026_main`;
UNINSTALL EXTENSION vsql_schematron;
