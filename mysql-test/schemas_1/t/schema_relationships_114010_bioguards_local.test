INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 114010_bioguards_local
--echo #
CREATE DATABASE `db_114010_bioguards_local`;
USE `db_114010_bioguards_local`;

CREATE TABLE `usuario` (
  `dni` VARCHAR(64),
  `password` VARCHAR(64),
  `rol` VARCHAR(64),
  PRIMARY KEY (`dni`)
) CHARACTER SET latin1;

CREATE TABLE `clinico` (
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `dni` VARCHAR(64),
  `fechaNacimiento` VARCHAR(64),
  `email` VARCHAR(64),
  `telefono` INT,
  `ciudad` VARCHAR(64),
  `provincia` VARCHAR(64),
  `codPostal` INT,
  `direccion` VARCHAR(64),
  `especialidad` VARCHAR(64),
  PRIMARY KEY (`dni`)
) CHARACTER SET latin1;

CREATE TABLE `cuidador_familiar` (
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `dni` VARCHAR(64),
  `fechaNacimiento` VARCHAR(64),
  `email` VARCHAR(64),
  `telefono` INT,
  `ciudad` VARCHAR(64),
  `provincia` VARCHAR(64),
  `codPostal` INT,
  `direccion` VARCHAR(64),
  PRIMARY KEY (`dni`)
) CHARACTER SET latin1;

CREATE TABLE `asiste` (
  `dni_pac` VARCHAR(64),
  `dni_fam` VARCHAR(64),
  PRIMARY KEY (`dni_pac`, `dni_fam`)
) CHARACTER SET latin1;

CREATE TABLE `paciente` (
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `dni` VARCHAR(64),
  `fechaNacimiento` VARCHAR(64),
  `email` VARCHAR(64),
  `telefono` INT,
  `ciudad` VARCHAR(64),
  `provincia` VARCHAR(64),
  `codPostal` INT,
  `direccion` VARCHAR(64),
  `dni_clinico` VARCHAR(64),
  PRIMARY KEY (`dni`)
) CHARACTER SET latin1;

CREATE TABLE `admin` (
  `nombre` VARCHAR(64),
  `apellido` VARCHAR(64),
  `dni` VARCHAR(64),
  `fechaNacimiento` VARCHAR(64),
  `email` VARCHAR(64),
  `telefono` INT,
  `ciudad` VARCHAR(64),
  `provincia` VARCHAR(64),
  `codPostal` INT,
  `direccion` VARCHAR(64),
  `tipo` INT,
  PRIMARY KEY (`dni`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_114010_bioguards_local') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_114010_bioguards_local') AS relationships;
DROP DATABASE `db_114010_bioguards_local`;
UNINSTALL EXTENSION vsql_schematron;
