INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103337_db_schema_v1
--echo #
CREATE DATABASE `db_103337_db_schema_v1`;
USE `db_103337_db_schema_v1`;

CREATE TABLE `meta` (
  `schema_version` INT
) CHARACTER SET latin1;

CREATE TABLE `objects` (
  `id` INT,
  `name` VARCHAR(64),
  `type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `raw_data` (
  `id` INT,
  `raw_value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `kv_data` (
  `id` INT,
  `kv_key` VARCHAR(64),
  `kv_value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `array_data` (
  `id` INT,
  `array_index` INT,
  `array_value` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103337_db_schema_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103337_db_schema_v1') AS relationships;
DROP DATABASE `db_103337_db_schema_v1`;
UNINSTALL EXTENSION vsql_schematron;
