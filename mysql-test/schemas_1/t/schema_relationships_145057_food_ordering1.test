INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 145057_food_ordering1
--echo #
CREATE DATABASE `db_145057_food_ordering1`;
USE `db_145057_food_ordering1`;

CREATE TABLE `customer` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email` VARCHAR(255),
  `contact_no` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `price` DECIMAL(10,2),
  `photo` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `customer_id` INT,
  `date_time` DATETIME,
  `status` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_details` (
  `id` INT,
  `order_id` INT,
  `item_id` INT,
  `quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `shop` (
  `id` INT,
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `role` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_145057_food_ordering1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_145057_food_ordering1') AS relationships;
DROP DATABASE `db_145057_food_ordering1`;
UNINSTALL EXTENSION vsql_schematron;
