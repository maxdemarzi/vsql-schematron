INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113424_st1
--echo #
CREATE DATABASE `db_113424_st1`;
USE `db_113424_st1`;
CREATE TABLE `cliente` (
  `id_cliente` INT,
  `nome` VARCHAR(50),
  `id_tipo_cliente` INT
) CHARACTER SET latin1;
CREATE TABLE `tipo` (
  `id_tipo` INT NOT NULL,
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id_tipo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113424_st1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113424_st1') AS relationships;
DROP DATABASE `db_113424_st1`;
UNINSTALL EXTENSION vsql_schematron;
