INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 197333_bbs
--echo #
CREATE DATABASE `db_197333_bbs`;
USE `db_197333_bbs`;
CREATE TABLE `messages` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `message` TEXT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password_hash` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_197333_bbs') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_197333_bbs') AS relationships;
DROP DATABASE `db_197333_bbs`;
UNINSTALL EXTENSION vsql_schematron;
