INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 171667_migration
--echo #
CREATE DATABASE `db_171667_migration`;
USE `db_171667_migration`;

CREATE TABLE `Cars` (
  `plate` VARCHAR(64),
  `brand` VARCHAR(64),
  `model` VARCHAR(64),
  `colour` VARCHAR(64),
  `fuel` VARCHAR(64),
  `transmission` VARCHAR(64),
  `pricePerDay` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`plate`)
) CHARACTER SET latin1;

CREATE TABLE `CarsDetails` (
  `id` VARCHAR(64),
  `carId` VARCHAR(64),
  `maxSpeed` INT,
  `topSeed` INT,
  `hp` INT,
  `people` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_171667_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_171667_migration') AS relationships;
DROP DATABASE `db_171667_migration`;
UNINSTALL EXTENSION vsql_schematron;
