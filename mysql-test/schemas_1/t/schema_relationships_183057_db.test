INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 183057_db
--echo #
CREATE DATABASE `db_183057_db`;
USE `db_183057_db`;
CREATE TABLE `Usuario` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `correo` VARCHAR(50),
  `contrasenia` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Categoria` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Evento` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `ubicacion` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `fecha` DATETIME,
  `categoriaId` INT,
  `usuarioId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_183057_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_183057_db') AS relationships;
DROP DATABASE `db_183057_db`;
UNINSTALL EXTENSION vsql_schematron;
