INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 191536_01-consolidated
--echo #
CREATE DATABASE `db_191536_01_consolidated`;
USE `db_191536_01_consolidated`;

CREATE TABLE `members` (
  `id` INT,
  `role` INT,
  `pub_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fallback_passwords` (
  `id` INT,
  `login` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `member_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `invites` (
  `id` INT,
  `hashed_token` VARCHAR(64),
  `created_by` INT,
  `created_at` DATETIME,
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `aliases` (
  `id` INT,
  `name` VARCHAR(64),
  `member_id` INT,
  `signature` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `denied_keys` (
  `id` INT,
  `pub_key` VARCHAR(64),
  `comment` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_191536_01_consolidated') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_191536_01_consolidated') AS relationships;
DROP DATABASE `db_191536_01_consolidated`;
UNINSTALL EXTENSION vsql_schematron;
