INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 115811_V86_12_0__Create_Notes_And_Queries_tables
--echo #
CREATE DATABASE `db_115811_V86_12_0__Create_Notes_And_Queries_tables`;
USE `db_115811_V86_12_0__Create_Notes_And_Queries_tables`;
CREATE TABLE `thread` (
  `id` BIGINT NOT NULL,
  `class_pk` BIGINT,
  `class_name` VARCHAR(50),
  `thread_type` VARCHAR(50),
  `title` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `section` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` BIGINT NOT NULL,
  `thread_id` BIGINT,
  `author_id` BIGINT,
  `body` TEXT,
  `created_on` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_attachment` (
  `post_id` BIGINT NOT NULL,
  `file_entry_id` BIGINT NOT NULL,
  PRIMARY KEY (`post_id`, `file_entry_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_115811_V86_12_0__Create_Notes_And_Queries_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_115811_V86_12_0__Create_Notes_And_Queries_tables') AS relationships;
DROP DATABASE `db_115811_V86_12_0__Create_Notes_And_Queries_tables`;
UNINSTALL EXTENSION vsql_schematron;
