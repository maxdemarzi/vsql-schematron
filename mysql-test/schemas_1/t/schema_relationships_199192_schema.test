INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 199192_schema
--echo #
CREATE DATABASE `db_199192_schema`;
USE `db_199192_schema`;
CREATE TABLE `City` (
  `city_id` BIGINT NOT NULL,
  `city_name` VARCHAR(50),
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `GeoLocation` (
  `geo_id` BIGINT NOT NULL,
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  PRIMARY KEY (`geo_id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
  `address_id` BIGINT NOT NULL,
  `street` VARCHAR(50),
  `house_number` VARCHAR(50),
  `postal_code` VARCHAR(50),
  `city_id` BIGINT,
  `geo_id` BIGINT,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `Atm` (
  `atm_id` BIGINT NOT NULL,
  `distance` BIGINT,
  `atm_type` VARCHAR(50),
  `address_id` BIGINT,
  PRIMARY KEY (`atm_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_199192_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_199192_schema') AS relationships;
DROP DATABASE `db_199192_schema`;
UNINSTALL EXTENSION vsql_schematron;
