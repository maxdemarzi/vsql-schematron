INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 148624_sispensi
--echo #
CREATE DATABASE `db_148624_sispensi`;
USE `db_148624_sispensi`;

CREATE TABLE `campaign` (
  `id` INT,
  `nama_campaign` VARCHAR(255),
  `gambar_campaign` VARCHAR(255),
  `deskripsi_campaign` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `keluhan` (
  `id_keluhan` INT,
  `id_warga` INT,
  `keluhan` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `kk_baru` (
  `id` INT,
  `id_warga` INT,
  `nik` INT,
  `nama` VARCHAR(255),
  `tempat_lahir` VARCHAR(255),
  `tanggal_lahir` DATETIME,
  `umur` INT,
  `jenis_kelamin` VARCHAR(255),
  `tgl_permohonan` DATETIME,
  `tgl_pengambilan` DATETIME,
  `pengantar` VARCHAR(255),
  `surat_nikah` VARCHAR(255),
  `sk_pindah` VARCHAR(255),
  `status` INT
) CHARACTER SET latin1;

CREATE TABLE `sk_kematian` (
  `id` INT,
  `id_warga` INT,
  `nik` INT,
  `nama` VARCHAR(255),
  `tempat_lahir` VARCHAR(255),
  `tanggal_lahir` DATETIME,
  `umur` INT,
  `jenis_kelamin` VARCHAR(255),
  `pekerjaan` VARCHAR(255),
  `tanggal_kematian` DATETIME,
  `tgl_permohonan` DATETIME,
  `tgl_pengambilan` DATETIME,
  `foto_ktp` VARCHAR(255),
  `surat_nikah` VARCHAR(255),
  `sk_lahir` VARCHAR(255),
  `status` INT
) CHARACTER SET latin1;

CREATE TABLE `sk_tempat_tinggal` (
  `id` INT,
  `id_warga` INT,
  `nik` INT,
  `nama` VARCHAR(255),
  `tempat_lahir` VARCHAR(255),
  `tanggal_lahir` DATETIME,
  `umur` INT,
  `jenis_kelamin` VARCHAR(255),
  `tgl_permohonan` DATETIME,
  `tgl_pengambilan` DATETIME,
  `pengantar` VARCHAR(255),
  `foto_ktp` VARCHAR(255),
  `foto_kk` VARCHAR(255),
  `surat_penjamin` VARCHAR(255),
  `status` INT
) CHARACTER SET latin1;

CREATE TABLE `sp_akte_lahir` (
  `id` INT,
  `id_warga` INT,
  `nik` INT,
  `nama` VARCHAR(255),
  `tempat_lahir` VARCHAR(255),
  `tanggal_lahir` DATETIME,
  `umur` INT,
  `jenis_kelamin` VARCHAR(255),
  `tgl_permohonan` DATETIME,
  `tgl_pengambilan` DATETIME,
  `pengantar` VARCHAR(255),
  `foto_ktp` VARCHAR(255),
  `foto_kk` VARCHAR(255),
  `surat_nikah` VARCHAR(255),
  `sk_lahir` VARCHAR(255),
  `status` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id_user` INT,
  `nama` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `warga` (
  `id` INT,
  `nik` VARCHAR(255),
  `nama_lengkap` VARCHAR(255),
  `tempat_lahir` VARCHAR(255),
  `tanggal_lahir` DATETIME,
  `no_tlp` VARCHAR(255),
  `email` VARCHAR(255),
  `alamat` VARCHAR(255),
  `jenis_kelamin` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_148624_sispensi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_148624_sispensi') AS relationships;
DROP DATABASE `db_148624_sispensi`;
UNINSTALL EXTENSION vsql_schematron;
