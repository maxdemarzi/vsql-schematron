INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 156673_create
--echo #
CREATE DATABASE `db_156673_create`;
USE `db_156673_create`;

CREATE TABLE `table_b` (
  `b_id` INT,
  `b_value` INT
) CHARACTER SET latin1;

CREATE TABLE `table_a` (
  `a_id` INT,
  `a_value1` VARCHAR(64),
  `a_value2` INT,
  PRIMARY KEY (`a_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_156673_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_156673_create') AS relationships;
DROP DATABASE `db_156673_create`;
UNINSTALL EXTENSION vsql_schematron;
