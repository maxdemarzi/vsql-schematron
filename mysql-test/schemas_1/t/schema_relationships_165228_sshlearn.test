INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 165228_sshlearn
--echo #
CREATE DATABASE `db_165228_sshlearn`;
USE `db_165228_sshlearn`;

CREATE TABLE `Qu` (
  `dno` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`dno`)
) CHARACTER SET latin1;

CREATE TABLE `Jiedao` (
  `sno` VARCHAR(64),
  `dno` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`sno`)
) CHARACTER SET latin1;

CREATE TABLE `THouseType` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Thouse` (
  `hid` DECIMAL(10,2),
  `sno` VARCHAR(64),
  `htid` DECIMAL(10,2),
  `hdesc` VARCHAR(64),
  `hprice` DECIMAL(10,2),
  PRIMARY KEY (`hid`)
) CHARACTER SET latin1;

CREATE TABLE `Tuser` (
  `uname` VARCHAR(64),
  `pwd` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`uname`)
) CHARACTER SET latin1;

CREATE TABLE `THouseRent` (
  `id` DECIMAL(10,2),
  `hid` DECIMAL(10,2),
  `uname` VARCHAR(64),
  `price` DECIMAL(10,2),
  `rdesc` VARCHAR(64),
  `rdate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_165228_sshlearn') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_165228_sshlearn') AS relationships;
DROP DATABASE `db_165228_sshlearn`;
UNINSTALL EXTENSION vsql_schematron;
