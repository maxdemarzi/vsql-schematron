INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 113549_schema
--echo #
CREATE DATABASE `db_113549_schema`;
USE `db_113549_schema`;
CREATE TABLE `USERS` (
  `USER_ID` INT NOT NULL,
  `USERNAME` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `ENABLED` INT,
  `NAME` VARCHAR(50),
  `DEPT` VARCHAR(50),
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLES` (
  `USER_ROLE_ID` INT NOT NULL,
  `USER_ID` INT,
  `AUTHORITY` VARCHAR(50),
  PRIMARY KEY (`USER_ROLE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ACCESS_AUDIT` (
  `USER_ID` VARCHAR(50),
  `DATE_TIME` TIMESTAMP NULL,
  `ACTION_TYPE` VARCHAR(50),
  `SESSION_ID` VARCHAR(50),
  `REMARK` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_113549_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_113549_schema') AS relationships;
DROP DATABASE `db_113549_schema`;
UNINSTALL EXTENSION vsql_schematron;
