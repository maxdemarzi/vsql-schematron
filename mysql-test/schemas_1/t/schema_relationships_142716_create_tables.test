INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 142716_create_tables
--echo #
CREATE DATABASE `db_142716_create_tables`;
USE `db_142716_create_tables`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `modmails` (
  `id` INT,
  `author` INT,
  `time` DATETIME,
  `body` VARCHAR(64),
  `subreddit` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `actions` (
  `id` INT,
  `target_type` INT,
  `target_id` INT,
  `action_summary` VARCHAR(64),
  `action_details` VARCHAR(64),
  `author` INT,
  `moderator` INT,
  `time` DATETIME,
  `subreddit` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subreddits` (
  `id` INT,
  `display_name` VARCHAR(64),
  `subscribers` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subreddit_moderator` (
  `subreddit_id` INT,
  `moderator_id` INT,
  PRIMARY KEY (`subreddit_id`, `moderator_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_142716_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_142716_create_tables') AS relationships;
DROP DATABASE `db_142716_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
