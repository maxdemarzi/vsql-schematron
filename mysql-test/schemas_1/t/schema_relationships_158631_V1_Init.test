INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 158631_V1_Init
--echo #
CREATE DATABASE `db_158631_V1_Init`;
USE `db_158631_V1_Init`;

CREATE TABLE `asset_request` (
  `id` VARCHAR(64),
  `host_name` VARCHAR(64),
  `resource_id` VARCHAR(64),
  `ip_address` VARCHAR(64),
  `asset_provider_id` VARCHAR(64),
  `server_id` VARCHAR(64),
  `received_on` DATETIME,
  `model_id` VARCHAR(64),
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `module_status` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `installed` VARCHAR(64),
  `configured` VARCHAR(64),
  `asset_request_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_158631_V1_Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_158631_V1_Init') AS relationships;
DROP DATABASE `db_158631_V1_Init`;
UNINSTALL EXTENSION vsql_schematron;
