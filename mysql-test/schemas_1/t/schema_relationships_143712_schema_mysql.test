INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 143712_schema_mysql
--echo #
CREATE DATABASE `db_143712_schema_mysql`;
USE `db_143712_schema_mysql`;

CREATE TABLE `pet` (
  `id` INT,
  `name` VARCHAR(64),
  `sex` VARCHAR(64),
  `vaccinated` VARCHAR(64),
  `adopted` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_pet_ref` (
  `id` INT,
  `pet_id` INT,
  `client_id` INT,
  `registered` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_143712_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_143712_schema_mysql') AS relationships;
DROP DATABASE `db_143712_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
