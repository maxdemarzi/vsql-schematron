INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159303_migration
--echo #
CREATE DATABASE `db_159303_migration`;
USE `db_159303_migration`;
CREATE TABLE `benchmarking_sessions` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `title` TEXT,
  `num_parties` INT,
  `inputTitles` VARCHAR(50),
  `inputComputations` VARCHAR(50),
  `processorHostnames` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submissions` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `sessionId` TEXT,
  `submitter` TEXT,
  `integerValues` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159303_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159303_migration') AS relationships;
DROP DATABASE `db_159303_migration`;
UNINSTALL EXTENSION vsql_schematron;
