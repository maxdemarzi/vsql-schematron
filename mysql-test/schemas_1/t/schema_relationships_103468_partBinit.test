INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 103468_partBinit
--echo #
CREATE DATABASE `db_103468_partBinit`;
USE `db_103468_partBinit`;
CREATE TABLE `branch` (
  `code` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `assets` INT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `ssn` INT NOT NULL,
  `custname` VARCHAR(50),
  `place` VARCHAR(50),
  PRIMARY KEY (`ssn`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
  `accno` VARCHAR(50) NOT NULL,
  `ssn` INT,
  `code` VARCHAR(50),
  `balance` INT,
  PRIMARY KEY (`accno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_103468_partBinit') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_103468_partBinit') AS relationships;
DROP DATABASE `db_103468_partBinit`;
UNINSTALL EXTENSION vsql_schematron;
