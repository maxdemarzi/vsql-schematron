INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 138177_1.create-some-stuff
--echo #
CREATE DATABASE `db_138177_1_create_some_stuff`;
USE `db_138177_1_create_some_stuff`;
CREATE TABLE `COMPANY` (
  `ID` INT NOT NULL,
  `NAME` TEXT,
  `AGE` INT,
  `ADDRESS` CHAR(50),
  `SALARY` DOUBLE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEPARTMENT` (
  `ID` INT NOT NULL,
  `DEPT` CHAR(50),
  `EMP_ID` INT,
  `COMPANY_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_138177_1_create_some_stuff') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_138177_1_create_some_stuff') AS relationships;
DROP DATABASE `db_138177_1_create_some_stuff`;
UNINSTALL EXTENSION vsql_schematron;
