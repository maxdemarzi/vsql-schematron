INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 138258_back_schema_sqlite
--echo #
CREATE DATABASE `db_138258_back_schema_sqlite`;
USE `db_138258_back_schema_sqlite`;
CREATE TABLE `notes` (
  `id` INT NOT NULL,
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  `note_title` VARCHAR(50),
  `note` TEXT,
  `note_markdown` TEXT,
  `tags` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `registered_at` TIMESTAMP NULL,
  `last_login` TIMESTAMP NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `tag` TEXT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_138258_back_schema_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_138258_back_schema_sqlite') AS relationships;
DROP DATABASE `db_138258_back_schema_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
