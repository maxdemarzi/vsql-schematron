CREATE TABLE `experienciaprofissional` (
  `idexperienciaprofissional` INT,
  `idusuario` INT,
  `inicio` DATE,
  `fim` DATE,
  `empresa` VARCHAR(50),
  `descricao` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `formacaoacademica` (
  `idformacaoAcademica` INT,
  `idusuario` INT,
  `inicio` DATE,
  `fim` DATE,
  `descricao` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `idusuario` INT,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `dataNascimento` DATE,
  `email` VARCHAR(50),
  `senha` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
