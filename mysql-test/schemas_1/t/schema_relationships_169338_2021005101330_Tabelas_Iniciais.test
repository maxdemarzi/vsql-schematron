    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_169338_2021005101330_Tabelas_Iniciais') AS relationships;
DROP DATABASE `db_169338_2021005101330_Tabelas_Iniciais`;
