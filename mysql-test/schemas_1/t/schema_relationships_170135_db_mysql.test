INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 170135_db_mysql
--echo #
CREATE DATABASE `db_170135_db_mysql`;
USE `db_170135_db_mysql`;

CREATE TABLE `author` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `date_of_birth` DATETIME,
  `year_of_birth` INT,
  `address` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book` (
  `id` INT,
  `author_id` INT,
  `co_author_id` INT,
  `details_id` INT,
  `title` VARCHAR(255),
  `published_in` INT,
  `language_id` INT,
  `content_text` VARCHAR(255),
  `content_pdf` VARCHAR(255),
  `rec_version` INT,
  `rec_timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book_store` (
  `name` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `book_to_book_store` (
  `book_store_name` VARCHAR(255),
  `book_id` INT,
  `stock` INT,
  PRIMARY KEY (`book_store_name`, `book_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_170135_db_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_170135_db_mysql') AS relationships;
DROP DATABASE `db_170135_db_mysql`;
UNINSTALL EXTENSION vsql_schematron;
