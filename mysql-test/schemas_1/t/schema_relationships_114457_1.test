INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 114457_1
--echo #
CREATE DATABASE `db_114457_1`;
USE `db_114457_1`;

CREATE TABLE `authorizations` (
  `authorization_key` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`authorization_key`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `id` INT,
  `licence_plate` VARCHAR(64),
  `convertible` VARCHAR(64),
  `rating` INT,
  `engine_type` VARCHAR(64),
  `colour` VARCHAR(64),
  `model` VARCHAR(64),
  `seat_count` INT,
  `speed_limit` VARCHAR(64),
  `manufacturer_id` VARCHAR(64),
  `driver_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drivers` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `contact_number` VARCHAR(64),
  `gender` VARCHAR(64),
  `age` INT,
  `online_status` VARCHAR(64),
  `deleted` VARCHAR(64),
  `date_created` DATETIME,
  `date_modified` DATETIME,
  `car_assigned_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `manufacturers` (
  `id` VARCHAR(64),
  `location` VARCHAR(64),
  `date_established` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_114457_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_114457_1') AS relationships;
DROP DATABASE `db_114457_1`;
UNINSTALL EXTENSION vsql_schematron;
