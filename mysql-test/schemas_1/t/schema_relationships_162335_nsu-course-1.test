INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 162335_nsu-course-1
--echo #
CREATE DATABASE `db_162335_nsu_course_1`;
USE `db_162335_nsu_course_1`;
CREATE TABLE `university_group` (
  `group_num` INT NOT NULL,
  `average_mark` DECIMAL(10,2),
  PRIMARY KEY (`group_num`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `record` INT NOT NULL,
  `first_name` VARCHAR(50),
  `second_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `average_mark` DECIMAL(10,2),
  `group_num` INT,
  PRIMARY KEY (`record`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_162335_nsu_course_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_162335_nsu_course_1') AS relationships;
DROP DATABASE `db_162335_nsu_course_1`;
UNINSTALL EXTENSION vsql_schematron;
