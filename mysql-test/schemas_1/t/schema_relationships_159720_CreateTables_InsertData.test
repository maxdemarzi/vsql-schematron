INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 159720_CreateTables_InsertData
--echo #
CREATE DATABASE `db_159720_CreateTables_InsertData`;
USE `db_159720_CreateTables_InsertData`;
CREATE TABLE `rooms_type` (
  `id` INT NOT NULL,
  `fname` VARCHAR(50),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `id` INT NOT NULL,
  `number` INT,
  `type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
  `id` INT NOT NULL,
  `booking_date` DATE,
  `check_in_date` DATE,
  `check_out_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms_booked` (
  `id` INT NOT NULL,
  `rooms_id` INT,
  `bookings_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `capacity` (
  `id` INT NOT NULL,
  `type_id` INT,
  `total_rooms` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_159720_CreateTables_InsertData') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_159720_CreateTables_InsertData') AS relationships;
DROP DATABASE `db_159720_CreateTables_InsertData`;
UNINSTALL EXTENSION vsql_schematron;
