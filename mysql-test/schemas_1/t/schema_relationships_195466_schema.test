INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 195466_schema
--echo #
CREATE DATABASE `db_195466_schema`;
USE `db_195466_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `game` VARCHAR(50),
  `score` INT,
  `email` VARCHAR(50),
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `user_id` INT,
  `comment` VARCHAR(50),
  `post` VARCHAR(50),
  `date` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_195466_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_195466_schema') AS relationships;
DROP DATABASE `db_195466_schema`;
UNINSTALL EXTENSION vsql_schematron;
