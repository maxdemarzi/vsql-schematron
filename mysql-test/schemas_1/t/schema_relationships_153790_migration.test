INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 153790_migration
--echo #
CREATE DATABASE `db_153790_migration`;
USE `db_153790_migration`;

CREATE TABLE `users` (
  `uuid` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `email` VARCHAR(255),
  `picture` VARCHAR(255),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `cryptocurrencies` (
  `uuid` VARCHAR(255),
  `name` VARCHAR(255),
  `abbreviation` VARCHAR(255),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `wallets` (
  `uuid` VARCHAR(255),
  `user_uuid` VARCHAR(255),
  `cryptocurrency_uuid` VARCHAR(255),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_153790_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_153790_migration') AS relationships;
DROP DATABASE `db_153790_migration`;
UNINSTALL EXTENSION vsql_schematron;
