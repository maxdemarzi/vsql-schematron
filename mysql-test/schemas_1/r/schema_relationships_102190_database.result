INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 102190_database
#
CREATE DATABASE `db_102190_database`;
USE `db_102190_database`;
CREATE TABLE `usuario` (
`nombre` VARCHAR(50),
`apellido` VARCHAR(50),
`usuario` VARCHAR(50) NOT NULL,
`placa` VARCHAR(50),
`capacidadCarro` INT,
`bio` VARCHAR(50),
`imagenRuta` VARCHAR(50),
PRIMARY KEY (`usuario`)
) CHARACTER SET latin1;
CREATE TABLE `seguidores_siguiendo` (
`idSeguidorSiguiente` INT NOT NULL,
`idUsuario1Siguiendo` VARCHAR(50),
`idUsuario2Seguidor` VARCHAR(50),
PRIMARY KEY (`idSeguidorSiguiente`)
) CHARACTER SET latin1;
CREATE TABLE `mensaje` (
`idMensaje` INT NOT NULL,
`idUsuarioRemitente` INT,
`idUsuarioRemisor` INT,
`contenido` VARCHAR(50),
`fecha` DATE,
`hora` INT,
`ubicacionActual` VARCHAR(50),
`tipo` INT,
`leido` INT,
PRIMARY KEY (`idMensaje`)
) CHARACTER SET latin1;
CREATE TABLE `viaje` (
`idViaje` INT NOT NULL,
`idUsuario` VARCHAR(50),
`idRuta` INT,
`fecha` VARCHAR(50),
PRIMARY KEY (`idViaje`)
) CHARACTER SET latin1;
CREATE TABLE `pasajero` (
`idPasajero` INT NOT NULL,
`idUsuario` VARCHAR(50),
`idViaje` INT,
PRIMARY KEY (`idPasajero`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_102190_database') AS relationships;
relationships
Database: db_102190_database

Table Connections:
------------------
[Implied]  pasajero.idUsuario -> usuario.usuario
[Implied]  pasajero.idViaje -> viaje.idViaje
[Implied]  seguidores_siguiendo.idUsuario1Siguiendo -> usuario.usuario
[Implied]  seguidores_siguiendo.idUsuario2Seguidor -> usuario.usuario
[Implied]  viaje.idUsuario -> usuario.usuario

DROP DATABASE `db_102190_database`;
UNINSTALL EXTENSION vsql_schematron;
