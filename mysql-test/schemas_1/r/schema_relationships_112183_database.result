INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 112183_database
#
CREATE DATABASE `db_112183_database`;
USE `db_112183_database`;
CREATE TABLE `patient` (
`id` INT NOT NULL,
`имя` VARCHAR(50),
`фамилия` VARCHAR(50),
`отчество` VARCHAR(50),
`телефон` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `doctor` (
`id` INT NOT NULL,
`имя` VARCHAR(50),
`фамилия` VARCHAR(50),
`отчество` VARCHAR(50),
`специализация` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
`id` INT NOT NULL,
`описание` VARCHAR(50),
`дата_создания` INT,
`срок_действия` INT,
`приоритет` VARCHAR(50),
`doctorid` INT,
`patientid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_112183_database') AS relationships;
relationships
Database: db_112183_database

Table Connections:
