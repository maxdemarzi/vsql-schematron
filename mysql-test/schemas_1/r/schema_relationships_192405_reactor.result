CREATE DATABASE `db_192405_reactor`;
USE `db_192405_reactor`;
CREATE TABLE `suite_result` (
`SUITE_RESULT_ID` VARCHAR(64),
`SUITE_NAME` VARCHAR(64),
`PROJECT_NAME` VARCHAR(64),
`JOB_NAME` VARCHAR(64),
`JOB_BUILD_NUMBER` INT,
`JOB_BUILD_URL` VARCHAR(64),
`EXECUTION_RESULT` VARCHAR(64),
`START_TIME` INT,
`STOP_TIME` INT,
`NUMBER_OF_CASES` INT,
`NUMBER_OF_FAILURE` INT,
`INVISIBLE_ENTRY` INT,
`PRODUCT_UNDER_TASK` VARCHAR(64),
PRIMARY KEY (`SUITE_RESULT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `case_result` (
`CASE_RESULT_ID` VARCHAR(64),
`SUITE_RESULT` VARCHAR(64),
`TASK_CASE_ID` INT,
`EXECUTION_RESULT` VARCHAR(64),
`AUT` VARCHAR(64),
`START_TIME` INT,
`STOP_TIME` INT,
`RETRY` INT,
`CASE_STATION` VARCHAR(64),
`LOG_DIR` VARCHAR(64),
`EXTERNAL_ID` VARCHAR(64),
`CASE_ENV` VARCHAR(64),
PRIMARY KEY (`CASE_RESULT_ID`)
) CHARACTER SET latin1;
