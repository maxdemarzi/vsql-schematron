INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 154852_truyum-data
#
CREATE DATABASE `db_154852_truyum_data`;
USE `db_154852_truyum_data`;
CREATE TABLE `menu_item` (
`menuItemId` INT NOT NULL,
`title` VARCHAR(50),
`price` DECIMAL(10,2),
`isActive` BOOLEAN,
`dateOfLaunch` DATE,
`category` VARCHAR(50),
`isFreeDelivery` BOOLEAN,
PRIMARY KEY (`menuItemId`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`user_name` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
`cart_id` INT NOT NULL,
`user_id` INT,
`menuItem_id` INT,
PRIMARY KEY (`cart_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_154852_truyum_data') AS relationships;
relationships
