INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 194065_Order
#
CREATE DATABASE `db_194065_Order`;
USE `db_194065_Order`;
CREATE TABLE `SALESMAN` (
`SALESMAN_ID` VARCHAR(50) NOT NULL,
`NAME` VARCHAR(50),
`CITY` VARCHAR(50),
`COMMISSION` VARCHAR(50),
PRIMARY KEY (`SALESMAN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`CUSTOMER_ID` VARCHAR(50) NOT NULL,
`CUST_NAME` VARCHAR(50),
`CITY` VARCHAR(50),
`GRADE` DECIMAL(10,2),
`SALESMAN_ID` VARCHAR(50),
PRIMARY KEY (`CUSTOMER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
`ORD_NO` VARCHAR(50) NOT NULL,
`PURCHASE_AMT` DECIMAL(10,2),
`ORD_DATE` DATE,
`CUSTOMER_ID` VARCHAR(50),
`SALESMAN_ID` VARCHAR(50),
PRIMARY KEY (`ORD_NO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_194065_Order') AS relationships;
relationships
Database: db_194065_Order

Table Connections:
------------------
[Implied]  CUSTOMER.SALESMAN_ID -> SALESMAN.SALESMAN_ID
