PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m1397_unrepeatable.users` (
`id` INT,
`fd_id` INT,
`profile_picture` VARCHAR(64),
`name` VARCHAR(64),
`anonymous` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m1397_unrepeatable.posts` (
`id` INT,
`key_id` INT,
`created_by` INT,
`created` INT,
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
`location_name` VARCHAR(64),
`provider_id` INT,
`provider_source` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`, `key_id`, `provider_id`, `created_by`)
) CHARACTER SET latin1;
