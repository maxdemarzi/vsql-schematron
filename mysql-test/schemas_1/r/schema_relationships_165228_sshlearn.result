INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 165228_sshlearn
#
CREATE DATABASE `db_165228_sshlearn`;
USE `db_165228_sshlearn`;
CREATE TABLE `Qu` (
`dno` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`dno`)
) CHARACTER SET latin1;
CREATE TABLE `Jiedao` (
`sno` VARCHAR(64),
`dno` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`sno`)
) CHARACTER SET latin1;
CREATE TABLE `THouseType` (
`id` DECIMAL(10,2),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Thouse` (
`hid` DECIMAL(10,2),
`sno` VARCHAR(64),
`htid` DECIMAL(10,2),
`hdesc` VARCHAR(64),
`hprice` DECIMAL(10,2),
PRIMARY KEY (`hid`)
) CHARACTER SET latin1;
CREATE TABLE `Tuser` (
`uname` VARCHAR(64),
`pwd` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`uname`)
) CHARACTER SET latin1;
CREATE TABLE `THouseRent` (
`id` DECIMAL(10,2),
`hid` DECIMAL(10,2),
`uname` VARCHAR(64),
`price` DECIMAL(10,2),
`rdesc` VARCHAR(64),
`rdate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_165228_sshlearn') AS relationships;
relationships
Database: db_165228_sshlearn

Table Connections:
