INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 149555_schema
#
CREATE DATABASE `db_149555_schema`;
USE `db_149555_schema`;
CREATE TABLE `repository` (
`id` INT NOT NULL,
`full_name` VARCHAR(50),
`token` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `build` (
`id` INT NOT NULL,
`sha` VARCHAR(50),
`repository_id` INT,
`payload` TEXT,
`output` TEXT,
`status` INT,
`execution_time` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_149555_schema') AS relationships;
