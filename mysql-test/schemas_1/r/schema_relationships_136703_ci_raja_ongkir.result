CREATE TABLE `buku` (
`buku_id` INT,
`kategori_id` INT,
`judul` VARCHAR(50),
`author` VARCHAR(50),
`image` VARCHAR(50),
`deskripsi` TEXT,
`harga` INT
) CHARACTER SET latin1;
CREATE TABLE `kategori` (
`kategori_id` INT NOT NULL,
`kategori_code` VARCHAR(50),
`kategori_name` VARCHAR(50),
PRIMARY KEY (`kategori_id`)
) CHARACTER SET latin1;
