[Implied]  plot_checks.plot -> plots.plot
[Implied]  plots.lab_id -> labs.id
[Implied]  plots.plot -> plot_checks.plot

DROP DATABASE `db_181423_create_db`;
UNINSTALL EXTENSION vsql_schematron;
