[Implied]  dict_game.dict_id -> dict.id
[Implied]  dict_game.game_id -> game.id
[Implied]  dict_word.dict_id -> dict.id
[Implied]  dict_word.word_id -> word.id
[Implied]  game.created_by -> user.id
[Implied]  game_word.found_by -> user.id
[Implied]  game_word.game_id -> game.id
[Implied]  game_word.word_id -> word.id

DROP DATABASE `db_153212_init`;
UNINSTALL EXTENSION vsql_schematron;
