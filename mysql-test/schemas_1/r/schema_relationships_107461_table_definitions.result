INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 107461_table_definitions
#
CREATE DATABASE `db_107461_table_definitions`;
USE `db_107461_table_definitions`;
CREATE TABLE `public.credential` (
`value` VARCHAR(50),
`type` VARCHAR(50) NOT NULL,
PRIMARY KEY (`type`)
) CHARACTER SET latin1;
CREATE TABLE `public.problems` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`passwd` VARCHAR(50),
`email` VARCHAR(50),
`is_active` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.results` (
`id` INT NOT NULL,
`problem_id` INT,
`user_id` INT,
`cleared` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_107461_table_definitions') AS relationships;
relationships
