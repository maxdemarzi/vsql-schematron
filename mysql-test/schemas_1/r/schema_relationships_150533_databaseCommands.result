CREATE DATABASE `db_150533_databaseCommands`;
USE `db_150533_databaseCommands`;
CREATE TABLE `individuals` (
`id` INT NOT NULL,
`name` TEXT,
`nickname` TEXT,
`created_at` TIMESTAMP NULL,
`species_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sightings` (
`id` INT NOT NULL,
`date_of_sighting` DATE,
`location` VARCHAR(50),
`healty` BOOLEAN,
`email_of_sighter` TEXT,
`individual_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_150533_databaseCommands') AS relationships;
