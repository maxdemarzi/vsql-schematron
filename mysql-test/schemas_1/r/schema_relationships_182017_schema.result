INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 182017_schema
#
CREATE DATABASE `db_182017_schema`;
USE `db_182017_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `staff_role` (
`role_id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_182017_schema') AS relationships;
relationships
Database: db_182017_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.employee_id
[Implied]  employee.role_id -> staff_role.role_id
[Implied]  staff_role.department_id -> department.id

DROP DATABASE `db_182017_schema`;
UNINSTALL EXTENSION vsql_schematron;
