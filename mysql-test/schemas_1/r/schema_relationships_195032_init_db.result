[Implied]  retired_user_stats.team_id -> teams.team_id
[Implied]  retired_user_stats.user_id -> users.user_id
[Implied]  user_initial_stats.user_id -> users.user_id
[Implied]  user_initial_stats.utc_timestamp -> monthly_results.utc_timestamp
[Implied]  user_offset_tc_stats.user_id -> users.user_id
[Implied]  user_offset_tc_stats.utc_timestamp -> monthly_results.utc_timestamp
[Implied]  user_tc_stats_hourly.user_id -> users.user_id
[Implied]  user_tc_stats_hourly.utc_timestamp -> monthly_results.utc_timestamp
[Implied]  user_total_stats.user_id -> users.user_id
[Implied]  user_total_stats.utc_timestamp -> monthly_results.utc_timestamp
[Implied]  users.hardware_id -> hardware.hardware_id
[Implied]  users.team_id -> teams.team_id

DROP DATABASE `db_195032_init_db`;
UNINSTALL EXTENSION vsql_schematron;
