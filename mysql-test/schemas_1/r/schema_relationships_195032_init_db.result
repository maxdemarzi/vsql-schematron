INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 195032_init_db
#
CREATE DATABASE `db_195032_init_db`;
USE `db_195032_init_db`;
CREATE TABLE `hardware` (
`hardware_id` INT,
`hardware_name` VARCHAR(64),
`display_name` VARCHAR(64),
`hardware_make` VARCHAR(64),
`hardware_type` VARCHAR(64),
`average_ppd` DECIMAL(10,2),
`multiplier` DECIMAL(10,2),
PRIMARY KEY (`hardware_id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`team_id` INT,
`team_name` VARCHAR(64),
`team_description` VARCHAR(64),
`forum_link` VARCHAR(64),
PRIMARY KEY (`team_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`folding_username` VARCHAR(64),
`display_username` VARCHAR(64),
`passkey` VARCHAR(64),
`category` VARCHAR(64),
`profile_link` VARCHAR(64),
`live_stats_link` VARCHAR(64),
`hardware_id` INT,
`team_id` INT,
`is_captain` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_initial_stats` (
`user_id` INT,
`utc_timestamp` DATETIME,
`initial_points` INT,
`initial_units` INT,
PRIMARY KEY (`user_id`, `utc_timestamp`)
) CHARACTER SET latin1;
CREATE TABLE `user_offset_tc_stats` (
`user_id` INT,
`utc_timestamp` DATETIME,
`offset_points` INT,
`offset_multiplied_points` INT,
`offset_units` INT,
PRIMARY KEY (`user_id`, `utc_timestamp`)
) CHARACTER SET latin1;
CREATE TABLE `user_total_stats` (
`user_id` INT,
`utc_timestamp` DATETIME,
`total_points` INT,
`total_units` INT,
PRIMARY KEY (`user_id`, `utc_timestamp`)
) CHARACTER SET latin1;
CREATE TABLE `retired_user_stats` (
`retired_user_id` INT,
`team_id` INT,
`user_id` INT,
`display_username` VARCHAR(64),
`utc_timestamp` DATETIME,
`final_points` INT,
`final_multiplied_points` INT,
`final_units` INT,
PRIMARY KEY (`retired_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_tc_stats_hourly` (
`user_id` INT,
`utc_timestamp` DATETIME,
`tc_points` INT,
`tc_points_multiplied` INT,
`tc_units` INT,
PRIMARY KEY (`user_id`, `utc_timestamp`)
) CHARACTER SET latin1;
CREATE TABLE `monthly_results` (
`utc_timestamp` DATETIME,
`json_result` VARCHAR(64),
PRIMARY KEY (`utc_timestamp`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_195032_init_db') AS relationships;
relationships
Database: db_195032_init_db

