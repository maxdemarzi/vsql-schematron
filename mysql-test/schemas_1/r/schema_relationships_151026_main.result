INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 151026_main
#
CREATE DATABASE `db_151026_main`;
USE `db_151026_main`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`nick` TEXT,
`password` TEXT,
`salt` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `canvasses` (
`id` INT NOT NULL,
`title` TEXT,
`owner_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`canvas_id` INT,
`owner_id` INT,
`coordinate_x` INT,
`coordinate_y` INT,
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_151026_main') AS relationships;
relationships
