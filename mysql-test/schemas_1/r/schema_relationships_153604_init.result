INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 153604_init
#
CREATE DATABASE `db_153604_init`;
USE `db_153604_init`;
CREATE TABLE `domains` (
`name` VARCHAR(64),
`domain_suffix` VARCHAR(64),
`provisioning_cert` VARCHAR(64),
`provisioning_cert_storage_format` VARCHAR(64),
`provisioning_cert_key` VARCHAR(64),
`creation_date` DATETIME,
`created_by` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ciraconfigs` (
`cira_config_name` VARCHAR(64),
`mps_server_address` VARCHAR(64),
`mps_port` INT,
`user_name` VARCHAR(64),
`password` VARCHAR(64),
`common_name` VARCHAR(64),
`server_address_format` INT,
`auth_method` INT,
`mps_root_certificate` VARCHAR(64),
`proxydetails` VARCHAR(64),
PRIMARY KEY (`cira_config_name`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
`profile_name` VARCHAR(64),
`activation` VARCHAR(64),
`amt_password` VARCHAR(64),
`cira_config_name` VARCHAR(64),
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`mebx_password` VARCHAR(64),
`tags` VARCHAR(64),
`dhcp_enabled` VARCHAR(64),
PRIMARY KEY (`profile_name`)
) CHARACTER SET latin1;
CREATE TABLE `profiles_wirelessconfigs` (
`wireless_profile_name` VARCHAR(64),
`profile_name` VARCHAR(64),
`priority` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
PRIMARY KEY (`wireless_profile_name`, `profile_name`, `priority`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_153604_init') AS relationships;
relationships
