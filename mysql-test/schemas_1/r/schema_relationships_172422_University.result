INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 172422_University
#
CREATE DATABASE `db_172422_University`;
USE `db_172422_University`;
CREATE TABLE `majors` (
`major_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`major_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`student_id` INT,
`student_number` VARCHAR(64),
`student_name` VARCHAR(64),
`major_id` INT,
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`payment_id` INT,
`payment_date` DATETIME,
`payment_ammount` DECIMAL(10,2),
`student_id` INT,
PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
`subject_id` INT,
`subject_name` VARCHAR(64),
PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `agenda` (
`subject_id` INT,
`student_id` INT,
PRIMARY KEY (`subject_id`, `student_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172422_University') AS relationships;
relationships
Database: db_172422_University

Table Connections:
------------------
[Implied]  agenda.student_id -> students.student_id
[Implied]  agenda.subject_id -> subjects.subject_id
[Implied]  payments.student_id -> students.student_id
[Implied]  students.major_id -> majors.major_id

DROP DATABASE `db_172422_University`;
UNINSTALL EXTENSION vsql_schematron;
