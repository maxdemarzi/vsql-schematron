CREATE TABLE `Voucher` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`type` VARCHAR(50),
`begin_date` TIMESTAMP NULL,
`end_date` TIMESTAMP NULL,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_deleted` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Place` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`short_name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_deleted` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Stock` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`place_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_deleted` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `StockInProduct` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`stock_id` INT,
`product_id` INT,
`quantity` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_deleted` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
