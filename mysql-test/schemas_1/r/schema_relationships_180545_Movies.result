INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 180545_Movies
#
CREATE DATABASE `db_180545_Movies`;
USE `db_180545_Movies`;
CREATE TABLE `ACTOR` (
`ACT_ID` DECIMAL(10,2),
`ACT_NAME` VARCHAR(64),
`ACT_GENDER` VARCHAR(64),
PRIMARY KEY (`ACT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DIRECTOR` (
`DIR_ID` DECIMAL(10,2),
`DIR_NAME` VARCHAR(64),
`DIR_PHONE` DECIMAL(10,2),
PRIMARY KEY (`DIR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIES` (
`MOV_ID` DECIMAL(10,2),
`MOV_TITLE` VARCHAR(64),
`MOV_YEAR` DECIMAL(10,2),
`MOV_LANG` VARCHAR(64),
`DIR_ID` DECIMAL(10,2),
PRIMARY KEY (`MOV_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIE_CAST` (
`ACT_ID` DECIMAL(10,2),
`MOV_ID` DECIMAL(10,2),
`ROLE` VARCHAR(64),
PRIMARY KEY (`ACT_ID`, `MOV_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RATING` (
`MOV_ID` DECIMAL(10,2),
`REV_STARS` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_180545_Movies') AS relationships;
relationships
Database: db_180545_Movies

Table Connections:
------------------
[Implied]  MOVIES.DIR_ID -> DIRECTOR.DIR_ID
[Implied]  MOVIE_CAST.ACT_ID -> ACTOR.ACT_ID
[Implied]  MOVIE_CAST.MOV_ID -> MOVIES.MOV_ID
[Implied]  RATING.MOV_ID -> MOVIES.MOV_ID

DROP DATABASE `db_180545_Movies`;
UNINSTALL EXTENSION vsql_schematron;
