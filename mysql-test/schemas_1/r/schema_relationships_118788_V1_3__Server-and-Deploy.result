CREATE DATABASE `db_118788_V1_3__Server_and_Deploy`;
USE `db_118788_V1_3__Server_and_Deploy`;
CREATE TABLE `server` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `deploy` (
`id` BIGINT NOT NULL,
`deployed_at` DATETIME,
`build_id` BIGINT,
`server_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `deploy_label` (
`id` BIGINT NOT NULL,
`label_key` VARCHAR(50),
`label_value` VARCHAR(50),
`deploy_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_118788_V1_3__Server_and_Deploy') AS relationships;
