INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 168535_V1__Init_DB
#
CREATE DATABASE `db_168535_V1_Init_DB`;
USE `db_168535_V1_Init_DB`;
CREATE TABLE `home_work` (
`homework_id` INT,
`filename` VARCHAR(64),
`solution` VARCHAR(64),
`title` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`homework_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`roles` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `usr` (
`user_id` INT,
`active` VARCHAR(64),
`username` VARCHAR(64),
`email` VARCHAR(64),
`activation_code` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `learning_group` (
`group_id` INT,
`group_name` VARCHAR(64),
`group_leader_name` INT,
PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_group` (
`user_id` INT,
`group_id` INT,
PRIMARY KEY (`group_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `solution` (
`solution_id` INT,
`filename` VARCHAR(64),
`user_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_168535_V1_Init_DB') AS relationships;
relationships
Database: db_168535_V1_Init_DB

Table Connections:
------------------
[Implied]  home_work.user_id -> usr.user_id
[Implied]  solution.user_id -> usr.user_id
