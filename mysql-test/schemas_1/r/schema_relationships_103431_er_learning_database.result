INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 103431_er-learning-database
#
CREATE DATABASE `db_103431_er_learning_database`;
USE `db_103431_er_learning_database`;
CREATE TABLE `tblClasses` (
`classId` INT,
`className` VARCHAR(64),
`teacherId` INT,
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`classId`)
) CHARACTER SET latin1;
CREATE TABLE `tblStudents` (
`studentId` INT,
`studentFirstName` VARCHAR(64),
`studentLastName` VARCHAR(64),
`number` INT,
`notes` VARCHAR(64),
`classId` INT,
`familyId` INT,
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`studentId`)
) CHARACTER SET latin1;
CREATE TABLE `tblFamilies` (
`familyId` INT,
`familyName` VARCHAR(64),
`telephone` VARCHAR(64),
`address` VARCHAR(64),
`email` VARCHAR(64),
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`familyId`)
) CHARACTER SET latin1;
CREATE TABLE `tblTeachers` (
`teacherId` INT,
`teacherName` VARCHAR(64),
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`teacherId`)
) CHARACTER SET latin1;
CREATE TABLE `tblHomeworks` (
`homeworkId` INT,
`homeworkName` VARCHAR(64),
`lessonId` INT,
`teacherId` INT,
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`homeworkId`)
) CHARACTER SET latin1;
CREATE TABLE `tblLessons` (
`lessonId` INT,
`lessonName` VARCHAR(64),
`teacherId` INT,
PRIMARY KEY (`lessonId`)
) CHARACTER SET latin1;
CREATE TABLE `tblLessonContents` (
`lessonContentId` INT,
`lessonContentName` VARCHAR(64),
`contentType` INT,
`lessonId` INT,
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`lessonContentId`)
) CHARACTER SET latin1;
CREATE TABLE `tblHomeworkGrades` (
`homeworkGradeId` INT,
`homeworkId` INT,
`studentId` INT,
`studentNotes` VARCHAR(64),
`familyNotes` VARCHAR(64),
`createdTime` DATETIME,
`updateTime` DATETIME,
PRIMARY KEY (`homeworkGradeId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_103431_er_learning_database') AS relationships;
relationships
Database: db_103431_er_learning_database

Table Connections:
------------------
[Implied]  tblClasses.teacherId -> tblTeachers.teacherId
[Implied]  tblHomeworkGrades.homeworkId -> tblHomeworks.homeworkId
[Implied]  tblHomeworkGrades.studentId -> tblStudents.studentId
[Implied]  tblHomeworks.lessonId -> tblLessons.lessonId
[Implied]  tblHomeworks.teacherId -> tblTeachers.teacherId
[Implied]  tblLessonContents.lessonId -> tblLessons.lessonId
[Implied]  tblLessons.teacherId -> tblTeachers.teacherId
[Implied]  tblStudents.classId -> tblClasses.classId
[Implied]  tblStudents.familyId -> tblFamilies.familyId

DROP DATABASE `db_103431_er_learning_database`;
UNINSTALL EXTENSION vsql_schematron;
