CREATE DATABASE `db_165865_1402685362`;
USE `db_165865_1402685362`;
CREATE TABLE `leagues` (
`leagueid` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`tournament_url` VARCHAR(64),
`itemdef` INT,
`is_finished` INT,
PRIMARY KEY (`leagueid`)
) CHARACTER SET latin1;
CREATE TABLE `matches` (
`match_id` INT,
`season` INT,
`radiant_win` INT,
`duration` INT,
`first_blood_time` INT,
`start_time` DATETIME,
`match_seq_num` INT,
`game_mode` INT,
`tower_status_radiant` INT,
`tower_status_dire` INT,
`barracks_status_radiant` INT,
`barracks_status_dire` INT,
`replay_salt` INT,
`lobby_type` INT,
`human_players` INT,
`leagueid` INT,
`cluster` INT,
`positive_votes` INT,
`negative_votes` INT,
`radiant_team_id` INT,
`radiant_name` VARCHAR(64),
`radiant_logo` VARCHAR(64),
`radiant_team_complete` INT,
`dire_team_id` INT,
`dire_name` VARCHAR(64),
`dire_logo` VARCHAR(64),
`dire_team_complete` INT,
PRIMARY KEY (`match_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`account_id` INT,
`personaname` VARCHAR(64),
`steamid` VARCHAR(64),
`avatar` VARCHAR(64),
`profileurl` VARCHAR(64),
`is_personaname_real` INT,
PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `ability_upgrades` (
`slot_id` INT,
`ability` INT,
`time` INT,
`level` INT,
PRIMARY KEY (`slot_id`, `level`)
) CHARACTER SET latin1;
CREATE TABLE `additional_units` (
`slot_id` INT,
`unitname` VARCHAR(64),
`item_0` INT,
`item_1` INT,
`item_2` INT,
`item_3` INT,
`item_4` INT,
`item_5` INT
) CHARACTER SET latin1;
