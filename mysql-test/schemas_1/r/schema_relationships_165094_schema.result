) CHARACTER SET latin1;
CREATE TABLE `alm_alumno` (
`alm_id` INT NOT NULL,
`alm_nombre` VARCHAR(50),
`alm_edad` INT,
`alm_sexo` VARCHAR(50),
`alm_id_grd` INT,
`alm_observacion` VARCHAR(50),
PRIMARY KEY (`alm_id`)
) CHARACTER SET latin1;
