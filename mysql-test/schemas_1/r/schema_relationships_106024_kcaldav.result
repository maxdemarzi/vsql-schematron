INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 106024_kcaldav
#
CREATE DATABASE `db_106024_kcaldav`;
USE `db_106024_kcaldav`;
CREATE TABLE `resource` (
`collection` INT,
`url` VARCHAR(64),
`etag` VARCHAR(64),
`data` VARCHAR(64),
`id` INT,
`flags` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `collection` (
`principal` INT,
`url` VARCHAR(64),
`displayname` VARCHAR(64),
`colour` VARCHAR(64),
`description` VARCHAR(64),
`ctag` INT,
`id` INT,
`flags` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `proxy` (
`principal` INT,
`proxy` INT,
`bits` INT,
`id` INT,
`flags` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nonce` (
`nonce` VARCHAR(64),
`count` INT,
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `principal` (
`name` VARCHAR(64),
`hash` VARCHAR(64),
`email` VARCHAR(64),
`flags` INT,
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `database` (
`owneruid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_106024_kcaldav') AS relationships;
relationships
Database: db_106024_kcaldav

Table Connections:
