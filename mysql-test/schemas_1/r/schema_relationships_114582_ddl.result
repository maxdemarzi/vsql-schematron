CREATE DATABASE `db_114582_ddl`;
USE `db_114582_ddl`;
CREATE TABLE `corbeau.roles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.moderators` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`role_id` INT,
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.subjects` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_by` VARCHAR(50),
`updated_by` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.tags` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_by` VARCHAR(50),
`updated_by` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `corbeau.comments` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`email` VARCHAR(50),
`content` VARCHAR(50),
`post_id` INT,
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
