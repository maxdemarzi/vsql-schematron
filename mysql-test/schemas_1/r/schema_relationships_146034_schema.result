INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 146034_schema
#
CREATE DATABASE `db_146034_schema`;
USE `db_146034_schema`;
CREATE TABLE `app_user` (
`id` INT,
`username` VARCHAR(255),
`name` VARCHAR(255),
`password` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_role` (
`id` INT,
`role_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_146034_schema') AS relationships;
