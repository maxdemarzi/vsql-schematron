CREATE DATABASE `db_146614_modelofisicoframboesa`;
USE `db_146614_modelofisicoframboesa`;
CREATE TABLE `rua` (
`id_rua` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id_rua`)
) CHARACTER SET latin1;
CREATE TABLE `cacho` (
`id` INT NOT NULL,
`tag_rfid` VARCHAR(50),
`nome` VARCHAR(50),
`data_inicio` VARCHAR(50),
`data_fim` VARCHAR(50),
`id_rua` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `umidade` (
`id` INT NOT NULL,
`estado` INT,
`id_rua` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `temperatura` (
`id` INT NOT NULL,
`temperatura` DOUBLE,
`id_rua` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_146614_modelofisicoframboesa') AS relationships;
