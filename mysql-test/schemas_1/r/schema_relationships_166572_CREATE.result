CREATE DATABASE `db_166572_CREATE`;
USE `db_166572_CREATE`;
CREATE TABLE `LOCALIZACAO` (
`ID_LOCALIZACAO` INT,
`TIPO_LOCALIZACAO` INT,
`NOME_LOCALIZACAO` VARCHAR(64),
PRIMARY KEY (`ID_LOCALIZACAO`)
) CHARACTER SET latin1;
CREATE TABLE `RESTAURANTE` (
`ID_RESTAURANTE` INT,
`ID_LOCALIZACAO` INT,
`NOME_RESTAURANTE` VARCHAR(64),
PRIMARY KEY (`ID_RESTAURANTE`)
) CHARACTER SET latin1;
CREATE TABLE `ADMINISTRADOR` (
`ID_ADMINISTRADOR` INT,
`ID_RESTAURANTE` INT,
`USERNAME_ADMINISTRADOR` VARCHAR(64),
`EMAIL_ADMINISTRADOR` VARCHAR(64),
`PASSWORD_ADMINISTRADOR` VARCHAR(64),
PRIMARY KEY (`ID_ADMINISTRADOR`)
) CHARACTER SET latin1;
CREATE TABLE `EMENTA` (
`ID_EMENTA` INT,
`DIA_DA_SEMANA` INT,
`ID_RESTAURANTE` INT,
PRIMARY KEY (`ID_EMENTA`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
`ID_CLIENTE` INT,
`NOME_CLIENTE` VARCHAR(64),
`DATA_REGISTO_CLIENTE` DATETIME,
PRIMARY KEY (`ID_CLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `LUGAR` (
`ID_LUGAR` INT,
`TIPO_LUGAR` INT,
PRIMARY KEY (`ID_LUGAR`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTO` (
`ID_PRODUTO` INT,
`TIPO_PRODUTO` INT,
`NOME_PRODUTO` VARCHAR(64),
`DESIGNACAO_PRODUTO` VARCHAR(64),
`PRECO_PRODUTO` VARCHAR(64),
`ALERGIA_PRODUTO` VARCHAR(64),
`QUANTIDADE_PRODUTO` INT,
PRIMARY KEY (`ID_PRODUTO`)
) CHARACTER SET latin1;
CREATE TABLE `CARTAO` (
`ID_CARTAO` INT,
`ID_RESTAURANTE` INT,
`ID_CLIENTE` INT,
`DATA_CRIACAO_CARTAO` DATETIME,
PRIMARY KEY (`ID_CARTAO`)
) CHARACTER SET latin1;
CREATE TABLE `CONSUMO` (
`ID_CONSUMO` INT,
`ID_CARTAO` INT,
`ID_LUGAR` INT,
PRIMARY KEY (`ID_CONSUMO`)
) CHARACTER SET latin1;
CREATE TABLE `CONSUMO_PODE_TER_PRODUTO` (
`ID_CONSUMO` INT,
`ID_PRODUTO` INT,
PRIMARY KEY (`ID_CONSUMO`, `ID_PRODUTO`)
) CHARACTER SET latin1;
CREATE TABLE `EMPREGADO` (
`ID_EMPREGADO` INT,
`ID_RESTAURANTE` INT,
`NOME_EMPREGADO` VARCHAR(64),
PRIMARY KEY (`ID_EMPREGADO`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTO_NA_EMENTA` (
`ID_EMENTA` INT,
`ID_PRODUTO` INT,
PRIMARY KEY (`ID_EMENTA`, `ID_PRODUTO`)
) CHARACTER SET latin1;
CREATE TABLE `TRANSACAO` (
`ID_RESTAURANTE` INT,
`ID_CONSUMO` INT,
`ID_TRANSACAO` INT,
`VALOR_TRANSACAO` INT,
`DATA_TRANSACAO` DATETIME
) CHARACTER SET latin1;
