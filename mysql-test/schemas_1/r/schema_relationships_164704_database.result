[Implied]  Course.department_id -> Department.id
[Implied]  CoursePeople.course_id -> Course.id
[Implied]  CoursePeople.people_id -> People.id
[Implied]  People.department_id -> Department.id
[Implied]  PeopleRole.people_id -> People.id
[Implied]  PeopleRole.role_id -> Role.id

DROP DATABASE `db_164704_database`;
UNINSTALL EXTENSION vsql_schematron;
