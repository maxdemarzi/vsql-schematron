INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 160989_database
#
CREATE DATABASE `db_160989_database`;
USE `db_160989_database`;
CREATE TABLE `users` (
`id` INT,
`sub` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`user_id` INT,
`text` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`post_id` INT,
`path` VARCHAR(64),
PRIMARY KEY (`post_id`, `path`)
) CHARACTER SET latin1;
CREATE TABLE `likes` (
`post_id` INT,
`user_id` INT,
PRIMARY KEY (`post_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`post_id` INT,
`user_id` INT,
`text` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_160989_database') AS relationships;
relationships
Database: db_160989_database

Table Connections:
