[Implied]  compra.estado -> estado.id
[Implied]  compra.finca -> fincas.id
[Implied]  deposito.estado -> estado.id
[Implied]  deposito.finca -> fincas.id

DROP DATABASE `db_105336_cafe`;
UNINSTALL EXTENSION vsql_schematron;
