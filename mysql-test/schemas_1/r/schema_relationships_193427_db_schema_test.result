INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 193427_db_schema_test
#
CREATE DATABASE `db_193427_db_schema_test`;
USE `db_193427_db_schema_test`;
CREATE TABLE `test.rooms` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test.messages` (
`id` INT,
`message` VARCHAR(255),
`room_id` INT,
`sender_id` INT,
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test.user_room` (
`users_id` INT,
`rooms_id` INT,
PRIMARY KEY (`users_id`, `rooms_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_193427_db_schema_test') AS relationships;
