`numero_usua` VARCHAR(50),
`complemento_usua` VARCHAR(50),
PRIMARY KEY (`id_usua`)
) CHARACTER SET latin1;
CREATE TABLE `cartao` (
`id_cart` INT NOT NULL,
`codigo_cart` VARCHAR(50),
`numero_cart` VARCHAR(50),
`nome_cart` VARCHAR(50),
`vencimento_cart` DATE,
