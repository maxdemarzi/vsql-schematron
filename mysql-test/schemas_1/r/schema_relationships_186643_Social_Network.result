INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 186643_Social_Network
#
CREATE DATABASE `db_186643_Social_Network`;
USE `db_186643_Social_Network`;
CREATE TABLE `UserData` (
`address` VARCHAR(64),
`name` VARCHAR(64),
`about_me` VARCHAR(64),
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Social` (
`views` INT,
`reactions` INT,
`shares` DECIMAL(10,2),
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`id` VARCHAR(64),
`message` VARCHAR(64),
`post_id` VARCHAR(64),
`user_id` VARCHAR(64),
`created_time` DATETIME,
`last_activity_date` DATETIME,
`upvotes` INT,
`downvotes` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
`id` VARCHAR(64),
`message` VARCHAR(64),
`social` INT,
`title` VARCHAR(64),
`user_id` VARCHAR(64),
`created_time` DATETIME,
`last_activity_date` DATETIME,
`upvotes` INT,
`downvotes` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tags` (
`id` INT,
`tags` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post_Tags` (
`id1` VARCHAR(64),
`id2` INT,
PRIMARY KEY (`id1`, `id2`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_186643_Social_Network') AS relationships;
relationships
