INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 140004_postgresql_schema
#
CREATE DATABASE `db_140004_postgresql_schema`;
USE `db_140004_postgresql_schema`;
CREATE TABLE `workspaces` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
`id` VARCHAR(255),
`workspace_name` VARCHAR(255),
`question` VARCHAR(255),
`response` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `learn_cards` (
`id` VARCHAR(255),
`workspace_name` VARCHAR(255),
`last_review` DATETIME,
`next_review` DATETIME,
`repetitions` INT,
`ease_factor` DECIMAL(10,2),
`interval_days` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_140004_postgresql_schema') AS relationships;
relationships
