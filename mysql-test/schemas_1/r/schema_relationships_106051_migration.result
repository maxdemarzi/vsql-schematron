`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`challengeId` TEXT,
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Vote` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`entryId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
