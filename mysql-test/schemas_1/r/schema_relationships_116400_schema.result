INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 116400_schema
#
CREATE DATABASE `db_116400_schema`;
USE `db_116400_schema`;
CREATE TABLE `parties` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candidates` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`party_id` INT,
`industry_connected` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voters` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`create_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`id` INT NOT NULL,
`voter_id` INT,
`candidate_id` INT,
`create_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_116400_schema') AS relationships;
relationships
Database: db_116400_schema

Table Connections:
------------------
[Implied]  candidates.party_id -> parties.id
[Implied]  votes.candidate_id -> candidates.id
[Implied]  votes.voter_id -> voters.id

DROP DATABASE `db_116400_schema`;
UNINSTALL EXTENSION vsql_schematron;
