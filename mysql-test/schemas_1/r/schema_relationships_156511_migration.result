INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 156511_migration
#
CREATE DATABASE `db_156511_migration`;
USE `db_156511_migration`;
CREATE TABLE `User` (
`id` INT NOT NULL,
`fullname` TEXT,
`email` TEXT,
`password` TEXT,
`roles` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Mk` (
`id` INT NOT NULL,
`title` TEXT,
`developer` TEXT,
`publisher` TEXT,
`release_year` TEXT,
`platforms` VARCHAR(50),
`story` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Secret` (
`id` INT NOT NULL,
`platforms` VARCHAR(50),
`title` TEXT,
`desc` TEXT,
`mk_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Character` (
`id` INT NOT NULL,
`name_char` TEXT,
`img_char_link` TEXT,
`mk_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Move` (
`id` INT NOT NULL,
`char_id` INT,
`spec_moves` VARCHAR(50),
`fin_moves` VARCHAR(50),
`combos` VARCHAR(50),
`morphs` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_156511_migration') AS relationships;
