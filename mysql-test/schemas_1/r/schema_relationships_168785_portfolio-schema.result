INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 168785_portfolio-schema
#
CREATE DATABASE `db_168785_portfolio_schema`;
USE `db_168785_portfolio_schema`;
CREATE TABLE `Portfolio` (
`owner` VARCHAR(50) NOT NULL,
`total` DOUBLE,
`loyalty` VARCHAR(50),
`balance` DOUBLE,
`commissions` DOUBLE,
`free` INT,
`sentiment` VARCHAR(50),
PRIMARY KEY (`owner`)
) CHARACTER SET latin1;
CREATE TABLE `Stock` (
`owner` VARCHAR(50) NOT NULL,
`symbol` VARCHAR(50) NOT NULL,
`shares` INT,
`price` DOUBLE,
`total` DOUBLE,
`dateQuoted` DATE,
`commission` DOUBLE,
PRIMARY KEY (`owner`, `symbol`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_168785_portfolio_schema') AS relationships;
relationships
Database: db_168785_portfolio_schema

Table Connections:
------------------
[Implied]  Stock.owner -> Portfolio.owner

DROP DATABASE `db_168785_portfolio_schema`;
UNINSTALL EXTENSION vsql_schematron;
