INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 170135_db_mysql
#
CREATE DATABASE `db_170135_db_mysql`;
USE `db_170135_db_mysql`;
CREATE TABLE `author` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`date_of_birth` DATETIME,
`year_of_birth` INT,
`address` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT,
`author_id` INT,
`co_author_id` INT,
`details_id` INT,
`title` VARCHAR(255),
`published_in` INT,
`language_id` INT,
`content_text` VARCHAR(255),
`content_pdf` VARCHAR(255),
`rec_version` INT,
`rec_timestamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_store` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `book_to_book_store` (
`book_store_name` VARCHAR(255),
`book_id` INT,
`stock` INT,
PRIMARY KEY (`book_store_name`, `book_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_170135_db_mysql') AS relationships;
relationships
Database: db_170135_db_mysql

Table Connections:
