CREATE DATABASE `db_189754_01_rm_base`;
USE `db_189754_01_rm_base`;
CREATE TABLE `RM_AFFIX` (
`ID` BIGINT NOT NULL,
`BS_KEYWORD` VARCHAR(50),
`RECORD_ID` VARCHAR(50),
`ORDER_NUMBER` INT,
`TITLE` VARCHAR(50),
`OLD_NAME` VARCHAR(50),
`SAVE_NAME` VARCHAR(50),
`SAVE_SIZE` BIGINT,
`MIME_TYPE` VARCHAR(50),
`ENCODING` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`AUTHOR` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RM_CODE_DATA` (
`ID` BIGINT NOT NULL,
`CODE_TYPE_ID` BIGINT,
`DATA_KEY` VARCHAR(50),
`ENABLE_STATUS` CHAR(50),
`DATA_VALUE` VARCHAR(50),
`TOTAL_CODE` VARCHAR(50),
`REMARK` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RM_CODE_TYPE` (
`ID` BIGINT NOT NULL,
`TYPE_KEYWORD` VARCHAR(50),
`NAME` VARCHAR(50),
`REMARK` VARCHAR(50),
`MULTI_VALUE_DESC` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RM_NODE_HEARTBEAT` (
`ID` VARCHAR(50) NOT NULL,
`VERSION` BIGINT,
`SHARDING_PREFIX` BIGINT,
`LAST_HEARTBEAT` TIMESTAMP NULL,
`BASE_URL` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
