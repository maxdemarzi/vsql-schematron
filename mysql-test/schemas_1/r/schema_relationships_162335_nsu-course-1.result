) CHARACTER SET latin1;
CREATE TABLE `student` (
`record` INT NOT NULL,
`first_name` VARCHAR(50),
`second_name` VARCHAR(50),
`middle_name` VARCHAR(50),
`average_mark` DECIMAL(10,2),
`group_num` INT,
PRIMARY KEY (`record`)
) CHARACTER SET latin1;
