[Implied]  CourseSubject.cCourseId -> Course.cCourseId
[Implied]  CourseSubject.cSubjectId -> Subject.cSubjectId
[Implied]  Lecturer.cSubjectId -> Subject.cSubjectId
[Implied]  OnlineLecture.cLecturerId -> Lecturer.cLecturerId
[Implied]  Question.cSubjectId -> Subject.cSubjectId
[Implied]  SampleQuestionSamplePaper.cSampleQuestionId -> SampleQuestion.cSampleQuestionId
[Implied]  SampleQuestionSamplePaper.cSampleQuestionPaperId -> SampleQuestionPaper.cSampleQuestionPaperId
[Implied]  SampleTest.cSampleQuestionPaperId -> SampleQuestionPaper.cSampleQuestionPaperId
[Implied]  SampleTest.cSubjectId -> Subject.cSubjectId
[Implied]  ScheduledLecture.cLecturerId -> Lecturer.cLecturerId
[Implied]  Student.cCourseId -> Course.cCourseId
[Implied]  Test.cStudentId -> Student.cStudentId
[Implied]  Test.cSubjectId -> Subject.cSubjectId

DROP DATABASE `db_196909_tables`;
UNINSTALL EXTENSION vsql_schematron;
