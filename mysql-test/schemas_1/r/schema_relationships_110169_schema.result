INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 110169_schema
#
CREATE DATABASE `db_110169_schema`;
USE `db_110169_schema`;
CREATE TABLE `doctors` (
`doctorID` VARCHAR(50) NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`date_of_birth` DATE,
`phone_number` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`doctorID`)
) CHARACTER SET latin1;
CREATE TABLE `owners` (
`SSN` VARCHAR(50) NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`date_of_birth` DATE,
`phone_number` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
`petID` VARCHAR(50) NOT NULL,
`pet_name` VARCHAR(50),
`date_of_birth` DATE,
`pet_type` CHAR(50),
`owner_SSN` VARCHAR(50),
PRIMARY KEY (`petID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_110169_schema') AS relationships;
