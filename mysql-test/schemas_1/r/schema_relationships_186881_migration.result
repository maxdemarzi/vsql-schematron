`text` VARCHAR(64),
`image` VARCHAR(64),
`authorId` INT,
`commentAmount` INT,
`retweetAmount` INT,
`likeAmount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Like` (
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LikesOnTweets` (
`tweetId` INT,
`userId` INT,
`createdAt` DATETIME,
`likeId` INT,
PRIMARY KEY (`tweetId`, `userId`)
) CHARACTER SET latin1;
CREATE TABLE `_UserFollows` (
