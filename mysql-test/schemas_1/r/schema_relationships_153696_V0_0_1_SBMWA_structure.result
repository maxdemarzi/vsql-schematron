CREATE DATABASE `db_153696_V0_0_1_SBMWA_structure`;
USE `db_153696_V0_0_1_SBMWA_structure`;
CREATE TABLE `address` (
`id` INT,
`created_date` DATETIME,
`last_modified_date` DATETIME,
`city` VARCHAR(255),
`zipcode` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT,
`created_date` DATETIME,
`last_modified_date` DATETIME,
`name` VARCHAR(255),
`email` VARCHAR(255),
`mobile_number` VARCHAR(255),
`dob` DATETIME,
`gender` VARCHAR(255),
`is_adult` VARCHAR(255),
`age` INT,
`address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`created_date` DATETIME,
`last_modified_date` DATETIME,
`title` VARCHAR(255),
`person_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT,
`created_date` DATETIME,
`last_modified_date` DATETIME,
`movie_details` VARCHAR(255),
`person_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_153696_V0_0_1_SBMWA_structure') AS relationships;
