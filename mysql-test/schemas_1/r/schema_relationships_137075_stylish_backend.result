INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 137075_stylish_backend
#
CREATE DATABASE `db_137075_stylish_backend`;
USE `db_137075_stylish_backend`;
CREATE TABLE `campaign` (
`id` INT,
`product_id` INT,
`picture` VARCHAR(64),
`story` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hot` (
`id` INT,
`title` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hot_product` (
`hot_id` INT,
`product_id` INT,
PRIMARY KEY (`hot_id`, `product_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_table` (
`id` INT,
`number` VARCHAR(64),
`time` INT,
`status` INT,
`details` VARCHAR(64),
`user_id` INT,
`total` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`id` INT,
`order_id` INT,
`details` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`category` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`price` INT,
`texture` VARCHAR(64),
`wash` VARCHAR(64),
`place` VARCHAR(64),
`note` VARCHAR(64),
`story` VARCHAR(64),
`main_image` VARCHAR(64),
`images` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`role_id` INT,
`provider` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
`picture` VARCHAR(64),
`access_token` VARCHAR(64),
`access_expired` INT,
`login_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `variant` (
`id` INT,
`color_code` VARCHAR(64),
`color_name` VARCHAR(64),
`size` VARCHAR(64),
`stock` INT,
`product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_137075_stylish_backend') AS relationships;
relationships
Database: db_137075_stylish_backend

Table Connections:
------------------
[Implied]  campaign.product_id -> product.id
[Implied]  hot_product.hot_id -> hot.id
[Implied]  hot_product.product_id -> product.id
[Implied]  order_table.user_id -> user.id
[Implied]  payment.order_id -> order_table.id
[Implied]  user.provider -> user.email
[Implied]  user.role_id -> role.id
[Implied]  variant.product_id -> product.id

DROP DATABASE `db_137075_stylish_backend`;
UNINSTALL EXTENSION vsql_schematron;
