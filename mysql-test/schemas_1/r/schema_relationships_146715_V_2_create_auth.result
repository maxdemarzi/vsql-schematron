CREATE DATABASE `db_146715_V_2_create_auth`;
USE `db_146715_V_2_create_auth`;
CREATE TABLE `auth_schema_version` (
`version_key` VARCHAR(64),
`version_value` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `audit_log` (
`id` INT,
`user_id` VARCHAR(64),
`originatingSystem` VARCHAR(64),
`object_id` VARCHAR(64),
`operation` VARCHAR(64),
`description` VARCHAR(64),
`success` VARCHAR(64),
`timestamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authority` (
`id` INT,
`regex` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_group` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_group_to_authority` (
`group_id` INT,
`authority_id` INT,
PRIMARY KEY (`group_id`, `authority_id`)
) CHARACTER SET latin1;
CREATE TABLE `og_user` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`lastLogin` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_to_user_group` (
`user_id` INT,
`user_group_id` INT,
PRIMARY KEY (`user_id`, `user_group_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_hibernate_sequence` (
`next_val` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_146715_V_2_create_auth') AS relationships;
