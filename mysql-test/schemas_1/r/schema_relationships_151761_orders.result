INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 151761_orders
#
CREATE DATABASE `db_151761_orders`;
USE `db_151761_orders`;
CREATE TABLE `salesmen` (
`salesman_id` INT NOT NULL,
`name` VARCHAR(50),
`city` VARCHAR(50),
`commission` DECIMAL(10,2),
PRIMARY KEY (`salesman_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`name` VARCHAR(50),
`city` VARCHAR(50),
`grade` VARCHAR(50),
`salesman_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT NOT NULL,
`purchase_amount` DECIMAL(10,2),
`order_date` DATE,
`customer_id` INT,
`salesman_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_151761_orders') AS relationships;
relationships
Database: db_151761_orders

Table Connections:
------------------
[Implied]  customers.salesman_id -> salesmen.salesman_id
[Implied]  orders.customer_id -> customers.customer_id
[Implied]  orders.salesman_id -> salesmen.salesman_id

DROP DATABASE `db_151761_orders`;
UNINSTALL EXTENSION vsql_schematron;
