INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 114010_bioguards_local
#
CREATE DATABASE `db_114010_bioguards_local`;
USE `db_114010_bioguards_local`;
CREATE TABLE `usuario` (
`dni` VARCHAR(64),
`password` VARCHAR(64),
`rol` VARCHAR(64),
PRIMARY KEY (`dni`)
) CHARACTER SET latin1;
CREATE TABLE `clinico` (
`nombre` VARCHAR(64),
`apellido` VARCHAR(64),
`dni` VARCHAR(64),
`fechaNacimiento` VARCHAR(64),
`email` VARCHAR(64),
`telefono` INT,
`ciudad` VARCHAR(64),
`provincia` VARCHAR(64),
`codPostal` INT,
`direccion` VARCHAR(64),
`especialidad` VARCHAR(64),
PRIMARY KEY (`dni`)
) CHARACTER SET latin1;
CREATE TABLE `cuidador_familiar` (
`nombre` VARCHAR(64),
`apellido` VARCHAR(64),
`dni` VARCHAR(64),
`fechaNacimiento` VARCHAR(64),
`email` VARCHAR(64),
`telefono` INT,
`ciudad` VARCHAR(64),
`provincia` VARCHAR(64),
`codPostal` INT,
`direccion` VARCHAR(64),
PRIMARY KEY (`dni`)
) CHARACTER SET latin1;
CREATE TABLE `asiste` (
`dni_pac` VARCHAR(64),
`dni_fam` VARCHAR(64),
PRIMARY KEY (`dni_pac`, `dni_fam`)
) CHARACTER SET latin1;
CREATE TABLE `paciente` (
`nombre` VARCHAR(64),
`apellido` VARCHAR(64),
`dni` VARCHAR(64),
`fechaNacimiento` VARCHAR(64),
`email` VARCHAR(64),
`telefono` INT,
`ciudad` VARCHAR(64),
`provincia` VARCHAR(64),
`codPostal` INT,
`direccion` VARCHAR(64),
`dni_clinico` VARCHAR(64),
PRIMARY KEY (`dni`)
) CHARACTER SET latin1;
CREATE TABLE `admin` (
`nombre` VARCHAR(64),
`apellido` VARCHAR(64),
`dni` VARCHAR(64),
`fechaNacimiento` VARCHAR(64),
`email` VARCHAR(64),
`telefono` INT,
`ciudad` VARCHAR(64),
`provincia` VARCHAR(64),
`codPostal` INT,
`direccion` VARCHAR(64),
`tipo` INT,
PRIMARY KEY (`dni`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_114010_bioguards_local') AS relationships;
