INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 164313_schema
#
CREATE DATABASE `db_164313_schema`;
USE `db_164313_schema`;
CREATE TABLE `titles` (
`title_id` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`title_id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`emp_no` INT,
`emp_title_id` VARCHAR(64),
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`sex` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
PRIMARY KEY (`dept_no`, `emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(64),
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_164313_schema') AS relationships;
relationships
