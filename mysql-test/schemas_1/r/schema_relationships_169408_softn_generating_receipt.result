INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 169408_softn-generating-receipt
#
CREATE DATABASE `db_169408_softn_generating_receipt`;
USE `db_169408_softn_generating_receipt`;
CREATE TABLE `clients` (
`id` INT,
`client_name` VARCHAR(64),
`client_address` VARCHAR(64),
`client_identification_document` VARCHAR(64),
`client_city` VARCHAR(64),
`client_number_receipts` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`product_name` VARCHAR(64),
`product_price_unit` DECIMAL(10,2),
`product_reference` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `receipts` (
`id` INT,
`receipt_type` VARCHAR(64),
`receipt_number` INT,
`receipt_date` DATETIME,
`receipt_license_plate` VARCHAR(64),
`client_id` INT,
PRIMARY KEY (`id`, `client_id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
`id` INT,
`option_key` VARCHAR(64),
`option_value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `receipts_has_products` (
`receipt_id` INT,
`product_id` INT,
`receipt_product_unit` INT,
PRIMARY KEY (`receipt_id`, `product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_169408_softn_generating_receipt') AS relationships;
relationships
Database: db_169408_softn_generating_receipt

Table Connections:
------------------
[Implied]  receipts.client_id -> clients.id
[Implied]  receipts_has_products.product_id -> products.id

DROP DATABASE `db_169408_softn_generating_receipt`;
UNINSTALL EXTENSION vsql_schematron;
