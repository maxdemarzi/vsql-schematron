CREATE DATABASE `db_158984_up`;
USE `db_158984_up`;
CREATE TABLE `users` (
`user_id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`password_hash` VARCHAR(64),
`given_name` VARCHAR(64),
`surname` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `organizations` (
`organization_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`organization_id`)
) CHARACTER SET latin1;
CREATE TABLE `topics` (
`topic_id` INT,
`name` VARCHAR(64),
`url_slug` VARCHAR(64),
`is_deleted` BOOL,
`original_topic` INT,
`created_by` INT,
`created_date` DATETIME,
PRIMARY KEY (`topic_id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`event_id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`url_slug` VARCHAR(64),
`is_deleted` BOOL,
`is_latest` BOOL,
`original_event` INT,
`created_by` INT,
`created_date` DATETIME,
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `perspectives` (
`perspective_id` INT,
`url_slug` VARCHAR(64),
`name` VARCHAR(64),
`is_deleted` BOOL,
`is_latest` BOOL,
`original_perspective` INT,
`parent_perspective` INT,
`created_by` INT,
`created_date` DATETIME,
PRIMARY KEY (`perspective_id`)
) CHARACTER SET latin1;
CREATE TABLE `actors` (
`actor_id` INT,
`url_slug` VARCHAR(64),
`mononymous_name` VARCHAR(64),
`given_name` VARCHAR(64),
`surname` VARCHAR(64),
`user_id` INT,
`is_latest` BOOL,
`original_actor` INT,
`created_by` INT,
`created_date` DATETIME,
PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
