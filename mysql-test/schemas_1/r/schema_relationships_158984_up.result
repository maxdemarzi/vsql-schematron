PRIMARY KEY (`perspective_event_id`)
) CHARACTER SET latin1;
CREATE TABLE `event_sources` (
`event_id` INT,
`perspective_id` INT,
`url` VARCHAR(64),
`description` VARCHAR(64),
`source_type` VARCHAR(64),
PRIMARY KEY (`event_id`, `perspective_id`)
) CHARACTER SET latin1;
CREATE TABLE `event_actors` (
`event_id` INT,
`actor_id` INT,
`perspective_id` INT,
`organization_id` INT,
PRIMARY KEY (`event_id`, `actor_id`)
) CHARACTER SET latin1;
CREATE TABLE `event_locations` (
`event_id` INT,
`location_id` INT,
`perspective_id` INT,
PRIMARY KEY (`event_id`, `location_id`)
) CHARACTER SET latin1;
CREATE TABLE `event_dates` (
`event_date_id` INT,
`event_id` INT,
`perspective_id` INT,
`exact_date` DATETIME,
`range_date_start` DATETIME,
`range_date_end` DATETIME,
PRIMARY KEY (`event_date_id`)
) CHARACTER SET latin1;
