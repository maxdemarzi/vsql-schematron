INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 105285_DDL_PG
#
CREATE DATABASE `db_105285_DDL_PG`;
USE `db_105285_DDL_PG`;
CREATE TABLE `ARTISTS` (
`ARTISTID` INT,
`STAGENAME` VARCHAR(64),
`AGE` INT,
PRIMARY KEY (`ARTISTID`)
) CHARACTER SET latin1;
CREATE TABLE `BANDS` (
`BANDID` INT,
`BANDNAME` VARCHAR(64),
PRIMARY KEY (`BANDID`)
) CHARACTER SET latin1;
CREATE TABLE `BANDMEMBERS` (
`BANDID` INT,
`ARTISTID` INT,
PRIMARY KEY (`BANDID`, `ARTISTID`)
) CHARACTER SET latin1;
CREATE TABLE `GENRES` (
`GENREID` INT,
`GENRENAME` VARCHAR(64),
PRIMARY KEY (`GENREID`)
) CHARACTER SET latin1;
CREATE TABLE `ALBUMS` (
`ALBUMID` INT,
`ALBUMNAME` VARCHAR(64),
`AUTHOR` INT,
`GENRE` INT,
`RELEASEYEAR` INT,
`DURATION` INT,
PRIMARY KEY (`ALBUMID`)
) CHARACTER SET latin1;
CREATE TABLE `SONGS` (
`SONGID` INT,
`SONGNAME` VARCHAR(64),
`LENGTH` INT,
`ALBUM` INT,
PRIMARY KEY (`SONGID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_105285_DDL_PG') AS relationships;
relationships
Database: db_105285_DDL_PG

Table Connections:
------------------
[Implied]  ALBUMS.GENRE -> GENRES.GENREID
[Implied]  BANDMEMBERS.ARTISTID -> ARTISTS.ARTISTID
[Implied]  BANDMEMBERS.BANDID -> BANDS.BANDID
[Implied]  SONGS.ALBUM -> ALBUMS.ALBUMID

DROP DATABASE `db_105285_DDL_PG`;
UNINSTALL EXTENSION vsql_schematron;
