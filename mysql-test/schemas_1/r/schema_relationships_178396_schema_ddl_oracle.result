CREATE DATABASE `db_178396_schema_ddl_oracle`;
USE `db_178396_schema_ddl_oracle`;
CREATE TABLE `BATCH_JOB_INSTANCE` (
`JOB_INSTANCE_ID` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
`JOB_NAME` VARCHAR(64),
`JOB_KEY` VARCHAR(64),
PRIMARY KEY (`JOB_INSTANCE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BATCH_JOB_EXECUTION` (
`JOB_EXECUTION_ID` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
`JOB_INSTANCE_ID` DECIMAL(10,2),
`CREATE_TIME` DATETIME,
`START_TIME` DATETIME,
`END_TIME` DATETIME,
`STATUS` VARCHAR(64),
`EXIT_CODE` VARCHAR(64),
`EXIT_MESSAGE` VARCHAR(64),
`LAST_UPDATED` DATETIME,
`JOB_CONFIGURATION_LOCATION` VARCHAR(64),
PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BATCH_JOB_EXECUTION_PARAMS` (
`JOB_EXECUTION_ID` DECIMAL(10,2),
`TYPE_CD` VARCHAR(64),
`KEY_NAME` VARCHAR(64),
`STRING_VAL` VARCHAR(64),
`DATE_VAL` DATETIME,
`LONG_VAL` DECIMAL(10,2),
`DOUBLE_VAL` DECIMAL(10,2),
`IDENTIFYING` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `BATCH_STEP_EXECUTION` (
`STEP_EXECUTION_ID` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
`STEP_NAME` VARCHAR(64),
`JOB_EXECUTION_ID` DECIMAL(10,2),
`START_TIME` DATETIME,
`END_TIME` DATETIME,
`STATUS` VARCHAR(64),
`COMMIT_COUNT` DECIMAL(10,2),
`READ_COUNT` DECIMAL(10,2),
`FILTER_COUNT` DECIMAL(10,2),
`WRITE_COUNT` DECIMAL(10,2),
`READ_SKIP_COUNT` DECIMAL(10,2),
`WRITE_SKIP_COUNT` DECIMAL(10,2),
`PROCESS_SKIP_COUNT` DECIMAL(10,2),
`ROLLBACK_COUNT` DECIMAL(10,2),
`EXIT_CODE` VARCHAR(64),
`EXIT_MESSAGE` VARCHAR(64),
`LAST_UPDATED` DATETIME,
PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BATCH_STEP_EXECUTION_CONTEXT` (
`STEP_EXECUTION_ID` DECIMAL(10,2),
`SHORT_CONTEXT` VARCHAR(64),
`SERIALIZED_CONTEXT` VARCHAR(64),
PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BATCH_JOB_EXECUTION_CONTEXT` (
`JOB_EXECUTION_ID` DECIMAL(10,2),
`SHORT_CONTEXT` VARCHAR(64),
`SERIALIZED_CONTEXT` VARCHAR(64),
PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`ID` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
`NAME` VARCHAR(64),
`CREDIT` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ERROR_LOG` (
`JOB_NAME` VARCHAR(64),
`STEP_NAME` VARCHAR(64),
`MESSAGE` VARCHAR(64)
) CHARACTER SET latin1;
