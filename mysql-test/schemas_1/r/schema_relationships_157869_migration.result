CREATE DATABASE `db_157869_migration`;
USE `db_157869_migration`;
CREATE TABLE `categories` (
`category_id` INT,
`category_name` VARCHAR(255),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT,
`item_name` VARCHAR(255),
`description` VARCHAR(255),
`imageUrl` VARCHAR(255),
`category_id` INT,
`totalAvailable` INT,
`maxRequestQty` INT,
`price` DECIMAL(10,2),
`hidden` VARCHAR(255),
`returnRequired` VARCHAR(255),
`approvalRequired` VARCHAR(255),
`owner` VARCHAR(255),
`location_id` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
`location_id` INT,
`location_name` VARCHAR(255),
`location_hidden` VARCHAR(255),
PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `requests` (
`request_id` INT,
`request_item_id` INT,
`quantity` INT,
`user_id` VARCHAR(255),
`status` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`request_id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`sid` VARCHAR(255),
`sess` VARCHAR(255),
`expire` DATETIME,
PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `settings` (
`name` VARCHAR(255),
`value` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`uuid` VARCHAR(255),
`token` VARCHAR(255),
`name` VARCHAR(255),
`email` VARCHAR(255),
`phone` VARCHAR(255),
`slackUsername` VARCHAR(255),
`haveID` VARCHAR(255),
`admin` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
