[Implied]  PACKAGE_PICK.order_id -> USER_ORDER.order_id
[Implied]  PACKAGE_PICK.prize_id -> PRIZE.prize_id
[Implied]  PRIZE.package_id -> PRIZE_PACKAGE.prize_package_id
[Implied]  PRIZE.package_id -> TICKET_PACKAGE.ticket_package_id
[Implied]  PRIZE.sponsor_id -> SPONSOR.sponsor_id
[Implied]  USER_ORDER.ticket_package_id -> TICKET_PACKAGE.ticket_package_id
[Implied]  USER_ORDER.user_id -> USER.user_id

DROP DATABASE `db_186919_aucs_database_simple`;
UNINSTALL EXTENSION vsql_schematron;
