INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 142829_customer
#
CREATE DATABASE `db_142829_customer`;
USE `db_142829_customer`;
CREATE TABLE `country` (
`id` INT NOT NULL,
`country` VARCHAR(50),
`last_update` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
`id` INT NOT NULL,
`city` VARCHAR(50),
`country_id` INT,
`last_update` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` INT NOT NULL,
`address` VARCHAR(50),
`address2` VARCHAR(50),
`district` VARCHAR(50),
`city_id` INT,
`postal_code` VARCHAR(50),
`phone` VARCHAR(50),
`last_update` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`id` INT NOT NULL,
`store_id` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`address_id` INT,
`active` BOOLEAN,
`create_Date` TIMESTAMP NULL,
`last_update` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_142829_customer') AS relationships;
relationships
Database: db_142829_customer

Table Connections:
------------------
[Implied]  address.city_id -> city.id
[Implied]  city.country_id -> country.id
[Implied]  customer.address_id -> address.id

DROP DATABASE `db_142829_customer`;
UNINSTALL EXTENSION vsql_schematron;
