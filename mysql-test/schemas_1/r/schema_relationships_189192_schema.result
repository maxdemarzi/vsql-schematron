INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 189192_schema
#
CREATE DATABASE `db_189192_schema`;
USE `db_189192_schema`;
CREATE TABLE `basket_items` (
`user_id` INT,
`item_id` INT,
PRIMARY KEY (`user_id`, `item_id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` INT,
`name` VARCHAR(64),
`parent_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT,
`confirmation_code` VARCHAR(64),
`email` VARCHAR(64),
`first_name` VARCHAR(64),
`is_non_locked` BOOL,
`last_name` VARCHAR(64),
`login` VARCHAR(64),
`password` VARCHAR(64),
`patronymic` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client_item` (
`id` INT,
`quantity` INT,
`item_id` INT,
`order_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client_roles` (
`client_id` INT,
`roles` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`id` INT,
`image` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`id` INT,
`characteristics` VARCHAR(64),
`code` VARCHAR(64),
`count` INT,
`created_on` DATETIME,
`description` VARCHAR(64),
`image` VARCHAR(64),
`name` VARCHAR(64),
`price` DECIMAL(10,2),
`weight` DECIMAL(10,2),
`category_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item_additional_images` (
`item_id` INT,
`additional_images_id` INT,
PRIMARY KEY (`item_id`, `additional_images_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`city` VARCHAR(64),
`country` VARCHAR(64),
`phone_number` VARCHAR(64),
`street` VARCHAR(64),
`zip_code` VARCHAR(64),
`created_on` DATETIME,
`last_update` DATETIME,
`order_status` VARCHAR(64),
`payment_method` VARCHAR(64),
`track_number` VARCHAR(64),
`client_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_189192_schema') AS relationships;
relationships
