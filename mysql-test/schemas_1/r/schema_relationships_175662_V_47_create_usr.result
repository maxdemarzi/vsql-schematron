CREATE TABLE `usr_schema_version` (
`version_key` VARCHAR(64),
`version_value` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `usr_oguser` (
`id` INT,
`oid` INT,
`ver_from_instant` DATETIME,
`ver_to_instant` DATETIME,
`corr_from_instant` DATETIME,
`corr_to_instant` DATETIME,
`userid` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
`time_zone` VARCHAR(64),
`email_address` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usr_idkey` (
`id` INT,
`key_scheme` VARCHAR(64),
`key_value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usr_oguser2idkey` (
`oguser_id` INT,
`idkey_id` INT,
PRIMARY KEY (`oguser_id`, `idkey_id`)
) CHARACTER SET latin1;
CREATE TABLE `usr_entitlement` (
`oguser_id` INT,
`entitlement_index` INT,
`entitlement_pattern` VARCHAR(64),
PRIMARY KEY (`oguser_id`, `entitlement_index`)
) CHARACTER SET latin1;
