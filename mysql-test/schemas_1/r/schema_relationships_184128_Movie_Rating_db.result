INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 184128_Movie_Rating.db
#
CREATE DATABASE `db_184128_Movie_Rating_db`;
USE `db_184128_Movie_Rating_db`;
CREATE TABLE `Reviewer` (
`rID` INT NOT NULL,
`name` TEXT,
PRIMARY KEY (`rID`)
) CHARACTER SET latin1;
CREATE TABLE `Movie` (
`mID` INT NOT NULL,
`title` TEXT,
`year` TEXT,
`director` TEXT,
PRIMARY KEY (`mID`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
`rID` INT,
`mID` INT,
`stars` INT,
`ratingDate` TEXT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_184128_Movie_Rating_db') AS relationships;
relationships
