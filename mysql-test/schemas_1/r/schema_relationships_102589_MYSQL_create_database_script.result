[Implied]  Products.ProductCategoryID -> ProductCategories.ProductCategoryID
[Implied]  Products.SupplierID -> Suppliers.SupplierID

DROP DATABASE `db_102589_MYSQL_create_database_script`;
UNINSTALL EXTENSION vsql_schematron;
