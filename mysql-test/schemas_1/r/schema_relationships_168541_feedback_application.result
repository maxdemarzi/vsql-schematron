INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 168541_feedback_application
#
CREATE DATABASE `db_168541_feedback_application`;
USE `db_168541_feedback_application`;
CREATE TABLE `candidates` (
`candidate_id` INT,
`candidate_name` VARCHAR(255),
`candidate_mail` VARCHAR(255),
`candidate_company` VARCHAR(255),
`candidate_position` VARCHAR(255),
`candidate_resume` VARCHAR(255),
`candidate_status` VARCHAR(255),
PRIMARY KEY (`candidate_id`)
) CHARACTER SET latin1;
CREATE TABLE `generated_feedbacks` (
`user_id` INT,
`generated_feedback_id` INT,
`template_id` INT,
`candidate_mail_id` VARCHAR(255),
`feedback_document` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `interviewer` (
`interviewer_id` INT,
`interviewer_name` VARCHAR(255),
`interviewer_mail_id` VARCHAR(255),
`user_id` INT,
PRIMARY KEY (`interviewer_id`)
) CHARACTER SET latin1;
CREATE TABLE `position` (
`position_id` INT,
`company_name` VARCHAR(255),
`position_name` VARCHAR(255),
`number_of_positions` INT,
`user_id` INT,
`position_description` VARCHAR(255),
PRIMARY KEY (`position_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `role_users` (
`role_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `template` (
`template_id` INT,
`template_name` VARCHAR(255),
`user_id` INT,
`interviewer_id` INT,
`position_id` INT,
`feedback_sections` VARCHAR(255),
`candidate_mail` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`email_id` VARCHAR(255),
`password` VARCHAR(255),
`company` VARCHAR(255),
`login_attempts` INT,
`account_disabled` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_168541_feedback_application') AS relationships;
relationships
Database: db_168541_feedback_application

