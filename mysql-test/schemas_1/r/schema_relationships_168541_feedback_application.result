[Implied]  role_users.role_id -> roles.role_id
[Implied]  role_users.user_id -> users.user_id
[Implied]  template.interviewer_id -> interviewer.interviewer_id
[Implied]  template.position_id -> position.position_id
[Implied]  template.user_id -> users.user_id

DROP DATABASE `db_168541_feedback_application`;
UNINSTALL EXTENSION vsql_schematron;
