CREATE TABLE `tb_ender` (
`cep` VARCHAR(50) NOT NULL,
`cidade` VARCHAR(50),
`uf` CHAR(50),
PRIMARY KEY (`cep`)
) CHARACTER SET latin1;
CREATE TABLE `tb_item_compra` (
`qtd_item_compra` INT,
`vl_item_compra` DECIMAL(10,2),
`cod_compra` VARCHAR(50),
`cod_prod` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_login` (
`senha_login` VARCHAR(50),
`cpf_func` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_prod` (
`cod_prod` VARCHAR(50) NOT NULL,
`nome_prod` VARCHAR(50),
`tam_prod` VARCHAR(50),
`vlun_prod` DECIMAL(10,2),
`prcusto_prod` DECIMAL(10,2),
`dtcad_prod` DATE,
`est_prod` INT,
`cod_fornec` VARCHAR(50),
`cod_tipo_prod` VARCHAR(50),
PRIMARY KEY (`cod_prod`)
) CHARACTER SET latin1;
