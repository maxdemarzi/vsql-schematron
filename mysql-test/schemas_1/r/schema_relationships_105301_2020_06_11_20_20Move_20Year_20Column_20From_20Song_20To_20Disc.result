INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song_20To_20Disc
#
CREATE DATABASE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;
USE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;
CREATE TABLE `Folders` (
`Id` INT,
`ParentFolder_Id` INT,
`Name` VARCHAR(255),
`DeleteDate` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Discs` (
`Id` INT,
`Folder_Id` INT,
`Year` INT,
`Title` VARCHAR(255),
`TreeTitle` VARCHAR(255),
`AlbumTitle` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Artists` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Genres` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Songs` (
`Id` INT,
`Artist_Id` INT,
`Disc_Id` INT,
`Genre_Id` INT,
`TrackNumber` INT,
`Title` VARCHAR(255),
`TreeTitle` VARCHAR(255),
`Duration` DECIMAL(10,2),
`Rating` INT,
`FileSize` INT,
`Checksum` INT,
`Bitrate` INT,
`LastPlaybackTime` DATETIME,
`PlaybacksCount` INT,
`DeleteDate` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Playbacks` (
`Id` INT,
`Song_Id` INT,
`PlaybackTime` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `DiscImages` (
`Id` INT,
`Disc_Id` INT,
`TreeTitle` VARCHAR(255),
`ImageType` INT,
`FileSize` INT,
`Checksum` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song') AS relationships;
relationships
Database: db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song

Table Connections:
------------------
[Implied]  DiscImages.Disc_Id -> Discs.Id
[Implied]  Discs.Folder_Id -> Folders.Id
[Implied]  Folders.ParentFolder_Id -> Folders.Id
[Implied]  Playbacks.Song_Id -> Songs.Id
[Implied]  Songs.Artist_Id -> Artists.Id
[Implied]  Songs.Disc_Id -> Discs.Id
[Implied]  Songs.Genre_Id -> Genres.Id

DROP DATABASE `db_105301_2020_06_11_20_20Move_20Year_20Column_20From_20Song`;
UNINSTALL EXTENSION vsql_schematron;
