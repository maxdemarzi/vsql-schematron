INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 141948_up
#
CREATE DATABASE `db_141948_up`;
USE `db_141948_up`;
CREATE TABLE `threads` (
`id` INT,
`last_reply_no` INT,
`bump` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`thread_id` INT,
`no` INT,
`name` VARCHAR(64),
`trip` VARCHAR(64),
`sender` VARCHAR(64),
`text` VARCHAR(64),
`ts` DATETIME,
PRIMARY KEY (`thread_id`, `no`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_141948_up') AS relationships;
relationships
