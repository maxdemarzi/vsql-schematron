INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 147476_schema
#
CREATE DATABASE `db_147476_schema`;
USE `db_147476_schema`;
CREATE TABLE `bedrooms` (
`id` VARCHAR(50) NOT NULL,
`description` VARCHAR(50),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`id` VARCHAR(50) NOT NULL,
`bedroom_id` VARCHAR(50),
`customer_id` VARCHAR(50),
`period_from` TIMESTAMP NULL,
`period_to` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
`id` VARCHAR(50) NOT NULL,
`status` VARCHAR(50),
`output_field` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_147476_schema') AS relationships;
