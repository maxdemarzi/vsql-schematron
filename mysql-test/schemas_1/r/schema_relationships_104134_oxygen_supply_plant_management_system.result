INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 104134_oxygen_supply_plant_management_system
#
CREATE DATABASE `db_104134_oxygen_supply_plant_management_system`;
USE `db_104134_oxygen_supply_plant_management_system`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64),
PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `customer_files` (
`id` INT,
`customer_id` INT,
`file_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_104134_oxygen_supply_plant_management_system') AS relationships;
relationships
