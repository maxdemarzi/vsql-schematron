CREATE DATABASE `db_160660_4`;
USE `db_160660_4`;
CREATE TABLE `PARTT` (
`PNO` VARCHAR(50) NOT NULL,
`PNAME` VARCHAR(50),
`COLOUR` VARCHAR(50),
PRIMARY KEY (`PNO`)
) CHARACTER SET latin1;
CREATE TABLE `WAREHOUSE` (
`WNO` VARCHAR(50) NOT NULL,
`WNAME` VARCHAR(50),
`CITY` VARCHAR(50),
PRIMARY KEY (`WNO`)
) CHARACTER SET latin1;
CREATE TABLE `SHIPMENT` (
`PNO` VARCHAR(50),
`WNO` VARCHAR(50),
`QUANTITY` DECIMAL(10,2),
`DATEE` DATE
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_160660_4') AS relationships;
