`sporsmal_key` VARCHAR(50),
`sporsmal` VARCHAR(50),
`tips_key` VARCHAR(50),
`tips` VARCHAR(50),
PRIMARY KEY (`besvarelse_id`)
) CHARACTER SET latin1;
CREATE TABLE `SVARALTERNATIV` (
`svaralternativ_id` DECIMAL(10,2) NOT NULL,
`besvarelse_id` DECIMAL(10,2),
`svaralternativ_key` VARCHAR(50),
`svaralternativ` VARCHAR(50),
PRIMARY KEY (`svaralternativ_id`)
) CHARACTER SET latin1;
CREATE TABLE `RAAD` (
`raad_id` DECIMAL(10,2) NOT NULL,
`kartlegging_id` DECIMAL(10,2),
`raad_key` VARCHAR(50),
`raad_tittel` VARCHAR(50),
`raad_ingress` VARCHAR(50),
PRIMARY KEY (`raad_id`)
) CHARACTER SET latin1;
CREATE TABLE `AKTIVITET` (
`aktivitet_id` DECIMAL(10,2) NOT NULL,
`raad_id` DECIMAL(10,2),
`tittel` VARCHAR(50),
`innhold` VARCHAR(50),
PRIMARY KEY (`aktivitet_id`)
) CHARACTER SET latin1;
