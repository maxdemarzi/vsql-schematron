INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 149344_iEnergy
#
CREATE DATABASE `db_149344_iEnergy`;
USE `db_149344_iEnergy`;
CREATE TABLE `iEnergyDatabase.user` (
`iduser` INT,
`name` VARCHAR(64),
`login` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.devices` (
`iddevices` INT,
`name` VARCHAR(64),
`activePower` DECIMAL(10,2),
`apparentPower` DECIMAL(10,2),
`model` VARCHAR(64),
`manufacturer` VARCHAR(64),
`type` INT,
`phasesNumber` INT,
`description` VARCHAR(64),
`iduser` INT,
PRIMARY KEY (`iddevices`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.consumption` (
`idConsumption` INT,
`dateTime` DATETIME,
`type` INT,
`value` DECIMAL(10,2),
`phaseId` INT,
`iddevices` INT,
PRIMARY KEY (`idConsumption`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.varData` (
`idvarData` INT,
`type` INT,
`value` DECIMAL(10,2),
`phaseId` INT,
`dateTime` DATETIME,
`iddevices` INT,
PRIMARY KEY (`idvarData`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.potential` (
`idpotential` INT,
`type` INT,
`value` DECIMAL(10,2),
`phaseId` INT,
`dateTime` DATETIME,
`iddevices` INT,
PRIMARY KEY (`idpotential`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.current` (
`idcurrent` INT,
`type` INT,
`value` DECIMAL(10,2),
`phaseId` INT,
`dateTime` DATETIME,
`iddevices` INT,
PRIMARY KEY (`idcurrent`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.userData` (
`iduserData` INT,
`address` VARCHAR(64),
`zipcode` VARCHAR(64),
`state` VARCHAR(64),
`city` VARCHAR(64),
`country` VARCHAR(64),
`phone` VARCHAR(64),
`mobile` VARCHAR(64),
`email` VARCHAR(64),
`iduser` INT,
PRIMARY KEY (`iduserData`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.logInfoMessages` (
`idlogInfoMessages` INT,
`type` INT,
`payload` VARCHAR(64),
`iddevices` INT,
PRIMARY KEY (`idlogInfoMessages`)
) CHARACTER SET latin1;
CREATE TABLE `iEnergyDatabase.powerFactor` (
`idpowerFactor` INT,
`value` DECIMAL(10,2),
`phaseId` INT,
`dateTime` DATETIME,
`iddevices` INT,
PRIMARY KEY (`idpowerFactor`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_149344_iEnergy') AS relationships;
