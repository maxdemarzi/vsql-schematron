[Implied]  ingredients.recipeId -> recipes.id
[Implied]  recipe_images.recipeId -> recipes.id
[Implied]  recipes.userId -> users.id
[Implied]  reset_password.userId -> users.id

DROP DATABASE `db_113846_db`;
UNINSTALL EXTENSION vsql_schematron;
