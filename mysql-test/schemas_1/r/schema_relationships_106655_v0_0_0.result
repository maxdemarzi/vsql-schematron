CREATE DATABASE `db_106655_v0_0_0`;
USE `db_106655_v0_0_0`;
CREATE TABLE `user` (
`id` INT,
`created` DATETIME,
`username` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT,
`created` DATETIME,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__user` (
`project_id` INT,
`user_id` INT,
`admin` INT
) CHARACTER SET latin1;
CREATE TABLE `access_key` (
`id` INT,
`name` VARCHAR(64),
`type` VARCHAR(64),
`project_id` INT,
`key` VARCHAR(64),
`secret` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__repository` (
`id` INT,
`project_id` INT,
`git_url` VARCHAR(64),
`ssh_key_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__inventory` (
`id` INT,
`project_id` INT,
`type` VARCHAR(64),
`key_id` INT,
`inventory` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__environment` (
`id` INT,
`project_id` INT,
`password` VARCHAR(64),
`json` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__template` (
`id` INT,
`ssh_key_id` INT,
`project_id` INT,
`inventory_id` INT,
`repository_id` INT,
`environment_id` INT,
`playbook` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project__template_schedule` (
`template_id` INT,
`cron_format` VARCHAR(64),
PRIMARY KEY (`template_id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
`id` INT,
`template_id` INT,
`status` VARCHAR(64),
`playbook` VARCHAR(64),
`environment` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task__output` (
`task_id` INT,
`task` VARCHAR(64),
`time` DATETIME,
`output` VARCHAR(64)
) CHARACTER SET latin1;
