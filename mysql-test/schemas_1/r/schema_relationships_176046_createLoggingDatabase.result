INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 176046_createLoggingDatabase
#
CREATE DATABASE `db_176046_createLoggingDatabase`;
USE `db_176046_createLoggingDatabase`;
CREATE TABLE `RequestInfo` (
`Id` INT NOT NULL,
`Referer` TEXT,
`Url` TEXT,
`QueryString` TEXT,
`Host` VARCHAR(50),
`UserAgent` TEXT,
`RemoteAddress` VARCHAR(50),
`ScriptName` VARCHAR(50),
`TimeStamp` TIMESTAMP NULL,
`Method` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `LogEntry` (
`Id` INT NOT NULL,
`RequestId` INT,
`LoggerName` VARCHAR(50),
`TimeStamp` TIMESTAMP NULL,
`Message` VARCHAR(50),
`Thread` VARCHAR(50),
`Level` VARCHAR(50),
`Host` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Exception` (
`Id` INT NOT NULL,
`LogEntryId` INT,
`Level` INT,
`Type` VARCHAR(50),
`Message` TEXT,
`Source` VARCHAR(50),
`TargetSite` VARCHAR(50),
`StackTrace` TEXT,
`TimeStamp` TIMESTAMP NULL,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_176046_createLoggingDatabase') AS relationships;
