) CHARACTER SET latin1;
CREATE TABLE `VIZO_DATASOURCES` (
`ID` INT,
`NAME` VARCHAR(64),
`CONNECTION_DETAILS` VARCHAR(64),
`TYPE` VARCHAR(64),
`IS_ACTIVE` VARCHAR(64),
`IS_CONNECTED` VARCHAR(64),
`QUERIES` INT,
`CREATED_ON` DATETIME,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
