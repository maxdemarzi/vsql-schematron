CREATE TABLE `VIZO_ROLES` (
`ID` INT,
`DESCRIPTION` VARCHAR(64),
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VIZO_USERS` (
