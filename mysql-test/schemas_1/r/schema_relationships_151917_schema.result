INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 151917_schema
#
CREATE DATABASE `db_151917_schema`;
USE `db_151917_schema`;
CREATE TABLE `players` (
`id` VARCHAR(64),
`balance` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tournaments` (
`id` VARCHAR(64),
`deposit` INT,
`winner` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tournament_participants` (
`tournamentId` VARCHAR(64),
`participantId` VARCHAR(64),
`parentId` VARCHAR(64),
PRIMARY KEY (`tournamentId`, `participantId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_151917_schema') AS relationships;
relationships
Database: db_151917_schema

Table Connections:
------------------
[Implied]  tournament_participants.parentId -> players.id
[Implied]  tournament_participants.participantId -> players.id
[Implied]  tournament_participants.tournamentId -> tournaments.id

DROP DATABASE `db_151917_schema`;
UNINSTALL EXTENSION vsql_schematron;
