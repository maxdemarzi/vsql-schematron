CREATE DATABASE `db_142526_mercado`;
USE `db_142526_mercado`;
CREATE TABLE `produtos` (
`referencia` VARCHAR(50) NOT NULL,
`descricao` VARCHAR(50),
`estoque` INT,
PRIMARY KEY (`referencia`)
) CHARACTER SET latin1;
CREATE TABLE `itensVenda` (
`venda` INT NOT NULL,
`produto` VARCHAR(50),
`quantidade` INT,
PRIMARY KEY (`venda`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_142526_mercado') AS relationships;
