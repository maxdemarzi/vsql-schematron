`unit` VARCHAR(64),
`last_amount` INT,
`total_amount` INT,
`first_refill_time` DATETIME,
`last_refill_time` DATETIME,
`est_refill_time` DATETIME,
`refill_frequency` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `refill` (
`id` INT,
`item_id` INT,
`amount` INT,
`refill_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
