INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 149478_V1__Init_DB
#
CREATE DATABASE `db_149478_V1__Init_DB`;
USE `db_149478_V1__Init_DB`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`is_moderator` BOOLEAN,
`reg_time` TIMESTAMP NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`code` VARCHAR(50),
`photo` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` BIGINT NOT NULL,
`is_active` BOOLEAN,
`moderation_status` VARCHAR(50),
`moderator_id` BIGINT,
`user_id` BIGINT,
`time` TIMESTAMP NULL,
`title` VARCHAR(50),
`text` TEXT,
`view_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_votes` (
`id` BIGINT NOT NULL,
`user_id` INT,
`post_id` INT,
`time` TIMESTAMP NULL,
`value` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag2post` (
`id` BIGINT NOT NULL,
`post_id` INT,
`tag_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_comments` (
`id` BIGINT NOT NULL,
`parent_id` INT,
`post_id` INT,
`user_id` INT,
`time` TIMESTAMP NULL,
`text` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `captcha_codes` (
`id` BIGINT NOT NULL,
`time` TIMESTAMP NULL,
`code` SMALLINT,
`secret_code` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `global_settings` (
`id` BIGINT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
`value` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_149478_V1__Init_DB') AS relationships;
relationships
Database: db_149478_V1__Init_DB

Table Connections:
