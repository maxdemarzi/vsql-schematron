[Implied]  post_comments.parent_id -> post_comments.id
[Implied]  post_comments.post_id -> posts.id
[Implied]  post_comments.user_id -> users.id
[Implied]  post_votes.post_id -> posts.id
[Implied]  post_votes.user_id -> users.id
[Implied]  posts.user_id -> users.id
[Implied]  tag2post.post_id -> posts.id
[Implied]  tag2post.tag_id -> tags.id

DROP DATABASE `db_149478_V1__Init_DB`;
UNINSTALL EXTENSION vsql_schematron;
