INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 154010_LilNurse.ddl
#
CREATE DATABASE `db_154010_LilNurse_ddl`;
USE `db_154010_LilNurse_ddl`;
CREATE TABLE `Patient` (
`pno` INT NOT NULL,
`pname` VARCHAR(50),
`hospital` VARCHAR(50),
`docName` VARCHAR(50),
PRIMARY KEY (`pno`)
) CHARACTER SET latin1;
CREATE TABLE `Medication` (
`medName` VARCHAR(50) NOT NULL,
`dosage` VARCHAR(50),
`reason` VARCHAR(50),
`refillNum` INT,
`refillDate` DATE,
`quantity` VARCHAR(50),
`specialInstructions` VARCHAR(50),
`pno` INT,
PRIMARY KEY (`medName`)
) CHARACTER SET latin1;
CREATE TABLE `Prescription` (
`dateIssued` DATE,
`medName` VARCHAR(50),
`pName` VARCHAR(50),
`prescNo` INT NOT NULL,
PRIMARY KEY (`prescNo`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_154010_LilNurse_ddl') AS relationships;
relationships
Database: db_154010_LilNurse_ddl

Table Connections:
------------------
[Implied]  Medication.pno -> Patient.pno
[Implied]  Prescription.medName -> Medication.medName

DROP DATABASE `db_154010_LilNurse_ddl`;
UNINSTALL EXTENSION vsql_schematron;
