CREATE DATABASE `db_186562_V3__compliance_questions`;
USE `db_186562_V3__compliance_questions`;
CREATE TABLE `compliance_group` (
`id` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`deleted` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `compliance_question` (
`id` DECIMAL(10,2) NOT NULL,
`compliance_group_id` DECIMAL(10,2),
`question` VARCHAR(50),
`requester` VARCHAR(50),
`updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
