INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 167588_genphones
#
CREATE DATABASE `db_167588_genphones`;
USE `db_167588_genphones`;
CREATE TABLE `people` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phones` (
`digits` INT NOT NULL,
`make` VARCHAR(50),
`model` VARCHAR(50),
`owner` INT,
PRIMARY KEY (`digits`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_167588_genphones') AS relationships;
