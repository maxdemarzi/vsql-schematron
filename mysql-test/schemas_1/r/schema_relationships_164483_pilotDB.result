INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 164483_pilotDB
#
CREATE DATABASE `db_164483_pilotDB`;
USE `db_164483_pilotDB`;
CREATE TABLE `personnel_table` (
`id` INT,
`name` VARCHAR(64),
`surnamee` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `machine_table` (
`id` INT,
`name` VARCHAR(64),
`brand` VARCHAR(64),
`modelDate` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cut_table` (
`id` INT,
`personnel1_id` INT,
`personnel2_id` INT,
`processDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sew_table` (
`id` INT,
`personnel1_id` INT,
`machine_id` INT,
`processDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `knit_table` (
`id` INT,
`personnel1_id` INT,
`personnel2_id` INT,
`machine_id` INT,
`processDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`cut_id` INT,
`sew_id` INT,
`knit_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test` (
`id` INT,
`tarih` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_164483_pilotDB') AS relationships;
