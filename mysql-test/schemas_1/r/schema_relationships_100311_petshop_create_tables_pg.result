[Implied]  Product.SupplierId -> Supplier.Id
[Implied]  Purchase.CustomerId -> Customer.Id
[Implied]  PurchaseItem.ProductId -> Product.Id
[Implied]  PurchaseItem.PurchaseId -> Purchase.Id

DROP DATABASE `db_100311_petshop_create_tables_pg`;
