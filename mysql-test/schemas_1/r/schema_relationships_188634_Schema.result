INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 188634_Schema
#
CREATE DATABASE `db_188634_Schema`;
USE `db_188634_Schema`;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`birth` DATE,
`register` DATETIME,
`address` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `email` (
`id` BIGINT NOT NULL,
`address` VARCHAR(50),
`user` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` BIGINT NOT NULL,
`code` BIGINT,
`estate` CHAR(50),
`city` VARCHAR(50),
`district` VARCHAR(50),
`address` VARCHAR(50),
`number` INT,
`complement` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_188634_Schema') AS relationships;
relationships
