INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 117034_script
#
CREATE DATABASE `db_117034_script`;
USE `db_117034_script`;
CREATE TABLE `cliente` (
`cpf` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
`nascimento` DATE,
`cidade` VARCHAR(50),
`uf` VARCHAR(50),
PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `servico` (
`cod_servico` INT NOT NULL,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`preco` DECIMAL(10,2),
PRIMARY KEY (`cod_servico`)
) CHARACTER SET latin1;
CREATE TABLE `modelo_veiculo` (
`cod_modelo` INT NOT NULL,
`moto` BOOLEAN,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
PRIMARY KEY (`cod_modelo`)
) CHARACTER SET latin1;
CREATE TABLE `veiculo` (
`placa` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
`marca` VARCHAR(50),
`cod_modelo` INT,
`cod_cliente` VARCHAR(50),
PRIMARY KEY (`placa`)
) CHARACTER SET latin1;
CREATE TABLE `manutencao` (
`cod_manutencao` INT NOT NULL,
`descricao` VARCHAR(50),
`dia` DATE,
`inicio` TIME,
`fim` TIME,
`cod_veiculo` VARCHAR(50),
PRIMARY KEY (`cod_manutencao`)
) CHARACTER SET latin1;
CREATE TABLE `manutencao_servico` (
`codigo_ms` INT NOT NULL,
`cod_manutencao` INT,
`cod_servico` INT,
PRIMARY KEY (`codigo_ms`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_117034_script') AS relationships;
relationships
Database: db_117034_script

Table Connections:
------------------
[Implied]  manutencao.cod_veiculo -> veiculo.placa
[Implied]  manutencao_servico.cod_manutencao -> manutencao.cod_manutencao
[Implied]  manutencao_servico.cod_servico -> servico.cod_servico
[Implied]  veiculo.cod_cliente -> cliente.cpf
[Implied]  veiculo.cod_modelo -> modelo_veiculo.cod_modelo

DROP DATABASE `db_117034_script`;
UNINSTALL EXTENSION vsql_schematron;
