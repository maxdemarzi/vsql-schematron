CREATE DATABASE `db_188152_management`;
USE `db_188152_management`;
CREATE TABLE `terminalinfo` (
`terminalno` VARCHAR(64),
`terminalip` VARCHAR(64),
`terminalstatus` INT,
`terminalid` VARCHAR(64),
`terminaladdr` VARCHAR(64),
`terminalcall` VARCHAR(64),
PRIMARY KEY (`terminalno`)
) CHARACTER SET latin1;
CREATE TABLE `terminaldevice` (
`terminalno` VARCHAR(64),
`printerstate` INT,
`inicstate` INT,
`keyboardstate` INT,
`magstate` INT,
PRIMARY KEY (`terminalno`)
) CHARACTER SET latin1;
CREATE TABLE `terminalmgr` (
`name` VARCHAR(64),
`credentials` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
