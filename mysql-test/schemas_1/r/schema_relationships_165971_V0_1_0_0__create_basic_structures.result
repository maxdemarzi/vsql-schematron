`id` BIGINT NOT NULL,
`topic_id` BIGINT,
`description` VARCHAR(50),
`end_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vote` (
`voter_id` BIGINT NOT NULL,
`poll_id` BIGINT NOT NULL,
`poll_option` CHAR(50),
PRIMARY KEY (`voter_id`, `poll_id`)
) CHARACTER SET latin1;
