INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 155993_Week8-BlogDb
#
CREATE DATABASE `db_155993_Week8_BlogDb`;
USE `db_155993_Week8_BlogDb`;
CREATE TABLE `tags` (
`id` INT,
`tagname` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogpost` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogposttags` (
`tagid` INT,
`blogpostid` INT,
PRIMARY KEY (`tagid`, `blogpostid`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`blogpostid` INT,
`author` VARCHAR(64),
`comment` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_155993_Week8_BlogDb') AS relationships;
relationships
Database: db_155993_Week8_BlogDb

Table Connections:
------------------
[Implied]  blogposttags.blogpostid -> blogpost.id
[Implied]  blogposttags.tagid -> tags.id
[Implied]  comments.blogpostid -> blogpost.id

DROP DATABASE `db_155993_Week8_BlogDb`;
UNINSTALL EXTENSION vsql_schematron;
