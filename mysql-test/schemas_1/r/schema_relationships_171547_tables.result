[Implied]  ordered_items.product_id -> products.product_id
[Implied]  orders.address_id -> address.address_id
[Implied]  orders.user_id -> users.user_id
[Implied]  products.supplier_id -> suppliers.supplier_id
[Implied]  suppliers.catagory_id -> catagory.catagory_id
[Implied]  suppliers.city_id -> city.city_id
[Implied]  user_address.address_id -> address.address_id
[Implied]  user_address.user_id -> users.user_id

DROP DATABASE `db_171547_tables`;
UNINSTALL EXTENSION vsql_schematron;
