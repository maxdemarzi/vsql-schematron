INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 152792_init
#
CREATE DATABASE `db_152792_init`;
USE `db_152792_init`;
CREATE TABLE `club` (
`id` INT NOT NULL,
`club` VARCHAR(50),
`club_country` VARCHAR(50),
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match` (
`id` INT NOT NULL,
`comment` VARCHAR(50),
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `club_match` (
`idclub_match` INT NOT NULL,
`idclub` INT,
`idmatch` INT,
`points` INT,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`idclub_match`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_152792_init') AS relationships;
relationships
