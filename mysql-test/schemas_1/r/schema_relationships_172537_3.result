INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 172537_3
#
CREATE DATABASE `db_172537_3`;
USE `db_172537_3`;
CREATE TABLE `boat` (
`bid` INT NOT NULL,
`bname` VARCHAR(50),
`colour` VARCHAR(50),
PRIMARY KEY (`bid`)
) CHARACTER SET latin1;
CREATE TABLE `sailor` (
`sid` INT NOT NULL,
`sname` VARCHAR(50),
`age` INT,
`rating` INT,
PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `reserves` (
`bid` INT NOT NULL,
`sid` INT NOT NULL,
`day` INT,
PRIMARY KEY (`sid`, `bid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172537_3') AS relationships;
