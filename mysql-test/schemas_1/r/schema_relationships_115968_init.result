INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 115968_init
#
CREATE DATABASE `db_115968_init`;
USE `db_115968_init`;
CREATE TABLE `play_stat` (
`chain_id` VARCHAR(64),
`height` INT,
PRIMARY KEY (`chain_id`)
) CHARACTER SET latin1;
CREATE TABLE `asset_stat` (
`chain_id` VARCHAR(64),
`active_coins` VARCHAR(64),
`stakes` VARCHAR(64),
`delegates` VARCHAR(64),
PRIMARY KEY (`chain_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_accounts` (
`chain_id` VARCHAR(64),
`address` VARCHAR(64),
`balance` VARCHAR(64),
`stake` VARCHAR(64),
`stake_locked` VARCHAR(64),
`val_addr` VARCHAR(64),
`delegate` VARCHAR(64),
`del_addr` VARCHAR(64),
`val_pubkey` VARCHAR(64),
`val_power` VARCHAR(64),
`eff_stake` VARCHAR(64),
PRIMARY KEY (`chain_id`, `address`)
) CHARACTER SET latin1;
CREATE TABLE `s_protocol` (
`chain_id` VARCHAR(64),
`height` INT,
`version` INT,
PRIMARY KEY (`chain_id`, `height`, `version`)
) CHARACTER SET latin1;
CREATE TABLE `s_incentives` (
`chain_id` VARCHAR(64),
`height` INT,
`address` VARCHAR(64),
`amount` VARCHAR(64),
PRIMARY KEY (`chain_id`, `height`, `address`)
) CHARACTER SET latin1;
CREATE TABLE `s_penalties` (
`chain_id` VARCHAR(64),
`height` INT,
`address` VARCHAR(64),
`amount` VARCHAR(64),
PRIMARY KEY (`chain_id`, `height`, `address`)
) CHARACTER SET latin1;
CREATE TABLE `s_storages` (
`chain_id` VARCHAR(64),
`storage_id` INT,
`url` VARCHAR(64),
`registration_fee` VARCHAR(64),
`hosting_fee` VARCHAR(64),
`owner` VARCHAR(64),
`active` INT,
PRIMARY KEY (`chain_id`, `storage_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_udc_balances` (
`chain_id` VARCHAR(64),
`udc_id` INT,
`address` VARCHAR(64),
`balance` VARCHAR(64),
`balance_lock` VARCHAR(64),
PRIMARY KEY (`chain_id`, `udc_id`, `address`)
) CHARACTER SET latin1;
CREATE TABLE `r_account_block` (
`seq` INT,
`chain_id` VARCHAR(64),
`address` VARCHAR(64),
`height` INT,
`amount` VARCHAR(64),
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `r_account_tx` (
`seq` INT,
`chain_id` VARCHAR(64),
`address` VARCHAR(64),
`height` INT,
`index` INT,
`amount` VARCHAR(64),
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `r_balance_tx` (
`seq` INT,
`chain_id` VARCHAR(64),
`address` VARCHAR(64),
`height` INT,
`index` INT,
`amount` VARCHAR(64),
`udc_id` INT,
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `r_parcel_tx` (
`seq` INT,
`chain_id` VARCHAR(64),
`parcel_id` VARCHAR(64),
`height` INT,
`index` INT,
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `r_did_tx` (
`seq` INT,
`chain_id` VARCHAR(64),
`id` VARCHAR(64),
`height` INT,
`index` INT,
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `r_vc_tx` (
`seq` INT,
`chain_id` VARCHAR(64),
`id` VARCHAR(64),
`height` INT,
`index` INT,
PRIMARY KEY (`seq`)
) CHARACTER SET latin1;
CREATE TABLE `nodes` (
`chain_id` VARCHAR(64),
`node_id` VARCHAR(64),
`timestamp` DATETIME,
`moniker` VARCHAR(64),
`ip_addr` INT,
PRIMARY KEY (`chain_id`, `node_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_115968_init') AS relationships;
