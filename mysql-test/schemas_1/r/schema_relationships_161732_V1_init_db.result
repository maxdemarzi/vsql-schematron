[Implied]  bans.banned_ipv4_addr -> anons.ipv4_addr
[Implied]  bans.ipv4_addr -> anons.ipv4_addr
[Implied]  bans.post_id -> posts.id
[Implied]  bans.report_id -> reports.id
[Implied]  posts.board_id -> boards.id
[Implied]  posts.ipv4_addr -> anons.ipv4_addr
[Implied]  reports.ipv4_addr -> anons.ipv4_addr
[Implied]  reports.post_id -> posts.id

DROP DATABASE `db_161732_V1_init_db`;
UNINSTALL EXTENSION vsql_schematron;
