CREATE DATABASE `db_184475_Pojeto_escola`;
USE `db_184475_Pojeto_escola`;
CREATE TABLE `alunos` (
`matricula_alu` INT,
`nome_alu` VARCHAR(64),
`CPF_alu` VARCHAR(64),
`endereço` VARCHAR(64),
`pai_alu_nome` VARCHAR(64),
`mae_alu_nome` VARCHAR(64),
`turma_alu` INT,
PRIMARY KEY (`matricula_alu`)
) CHARACTER SET latin1;
CREATE TABLE `professores` (
`id_prof` INT,
`nome_prof` VARCHAR(64),
`CPF_prof` VARCHAR(64),
`turma_prof` INT,
PRIMARY KEY (`id_prof`)
) CHARACTER SET latin1;
