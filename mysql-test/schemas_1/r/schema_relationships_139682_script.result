CREATE DATABASE `db_139682_script`;
USE `db_139682_script`;
CREATE TABLE `Route` (
`id` INT NOT NULL,
`name` TEXT,
`origin` TEXT,
`destination` TEXT,
`description` TEXT,
`imagename` TEXT,
`directions` TEXT,
`estimateddistance` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Log` (
`id` INT NOT NULL,
`startdate` TIMESTAMP NULL,
`enddate` TIMESTAMP NULL,
`origin` TEXT,
`destination` TEXT,
`distance` DOUBLE,
`rating` DOUBLE,
`note` TEXT,
`movementmode` INT,
`mood` INT,
`bpm` INT,
`route_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_139682_script') AS relationships;
