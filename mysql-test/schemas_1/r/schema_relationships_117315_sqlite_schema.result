INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 117315_sqlite_schema
#
CREATE DATABASE `db_117315_sqlite_schema`;
USE `db_117315_sqlite_schema`;
CREATE TABLE `notebooks` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`parent_id` INT,
`description` VARCHAR(50),
`updated_at` TIMESTAMP NULL,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `note_tags` (
`id` INT NOT NULL,
`tag_id` INT,
`note_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notes` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`note_tag_id` INT,
`notebook_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`is_markdown` INT,
`local_uuid` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`content` VARCHAR(50),
`remark` VARCHAR(50),
`finished_at` DATETIME,
`is_finished` INT,
`note_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`group` VARCHAR(50),
`priority` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_117315_sqlite_schema') AS relationships;
relationships
Database: db_117315_sqlite_schema

Table Connections:
------------------
[Implied]  note_tags.note_id -> notes.id
[Implied]  note_tags.tag_id -> tags.id
[Implied]  notebooks.parent_id -> notebooks.id
[Implied]  notes.note_tag_id -> note_tags.id
[Implied]  notes.notebook_id -> notebooks.id
[Implied]  todos.note_id -> notes.id

DROP DATABASE `db_117315_sqlite_schema`;
UNINSTALL EXTENSION vsql_schematron;
