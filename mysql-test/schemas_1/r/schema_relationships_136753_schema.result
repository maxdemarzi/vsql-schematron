INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 136753_schema
#
CREATE DATABASE `db_136753_schema`;
USE `db_136753_schema`;
CREATE TABLE `department` (
`department_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`role_id` INT,
`title` VARCHAR(64),
`salary` VARCHAR(64),
`department_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_136753_schema') AS relationships;
relationships
Database: db_136753_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> role.role_id
[Implied]  role.department_id -> department.department_id

DROP DATABASE `db_136753_schema`;
UNINSTALL EXTENSION vsql_schematron;
