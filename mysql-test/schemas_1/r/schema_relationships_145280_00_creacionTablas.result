CREATE DATABASE `db_145280_00_creacionTablas`;
USE `db_145280_00_creacionTablas`;
CREATE TABLE `Cliente` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellidos` VARCHAR(50),
`fechaNacimiento` DATE,
`usuario` VARCHAR(50),
`pass` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cupon` (
`id` INT NOT NULL,
`idCliente` INT,
`idSucursal` INT,
`fechaEntrega` DATE,
`fechaVencimiento` DATE,
`utilizado` VARCHAR(50),
`valor` DOUBLE,
`descripcion` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Telefono` (
`id` INT NOT NULL,
`idCliente` INT,
`telefono` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Correo` (
`id` INT NOT NULL,
`idCliente` INT,
`correo` VARCHAR(50),
`descripcion` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_145280_00_creacionTablas') AS relationships;
