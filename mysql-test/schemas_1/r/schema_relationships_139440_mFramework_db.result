CREATE DATABASE `db_139440_mFramework_db`;
USE `db_139440_mFramework_db`;
CREATE TABLE `admin` (
`uid` INT,
`name` VARCHAR(64),
`phone` VARCHAR(64),
`pwd` VARCHAR(64),
`identity` INT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
`articleId` INT,
`uid` INT,
`time` DATETIME,
`title` VARCHAR(64),
`content` VARCHAR(64),
`personal` INT,
`otherInfo` VARCHAR(64),
PRIMARY KEY (`articleId`)
) CHARACTER SET latin1;
CREATE TABLE `private` (
`code` VARCHAR(64),
`state` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`uid` INT,
`user` VARCHAR(64),
`name` VARCHAR(64),
`headPortrait` VARCHAR(64),
`pwd` VARCHAR(64),
`phone` VARCHAR(64),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `userMore` (
`uid` INT,
`signature` VARCHAR(64),
`setting` VARCHAR(64),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_139440_mFramework_db') AS relationships;
