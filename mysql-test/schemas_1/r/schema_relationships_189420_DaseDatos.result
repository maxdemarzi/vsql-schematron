`nombre` VARCHAR(64),
`apellido` VARCHAR(64),
`id_usurio` INT,
`direccion` VARCHAR(64),
PRIMARY KEY (`id_datos`)
) CHARACTER SET latin1;
CREATE TABLE `Menu` (
`id_menu` INT,
`nombre` VARCHAR(64),
`precio` DECIMAL(10,2),
`id_bebida` INT,
PRIMARY KEY (`id_menu`)
) CHARACTER SET latin1;
CREATE TABLE `Bebida` (
