INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 145057_food_ordering1
#
CREATE DATABASE `db_145057_food_ordering1`;
USE `db_145057_food_ordering1`;
CREATE TABLE `customer` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`contact_no` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`price` DECIMAL(10,2),
`photo` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`customer_id` INT,
`date_time` DATETIME,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_details` (
`id` INT,
`order_id` INT,
`item_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `shop` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_145057_food_ordering1') AS relationships;
relationships
Database: db_145057_food_ordering1

