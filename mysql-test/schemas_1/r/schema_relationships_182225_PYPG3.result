`Contrasena` VARCHAR(64),
`Salt` VARCHAR(64),
`FechaRegistro` DATETIME,
`Activo` BOOL,
`IDRol` INT,
PRIMARY KEY (`PK_IDUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `Cliente` (
`Nombre` VARCHAR(64),
`Apellido` VARCHAR(64),
`FechaNacimiento` DATETIME,
`PK_IDCliente` INT,
`Activo` BOOL,
PRIMARY KEY (`PK_IDCliente`)
) CHARACTER SET latin1;
CREATE TABLE `Proveedor` (
`NombreEmpresa` VARCHAR(64),
`Activo` BOOL,
`PK_IDProveedor` INT,
`URL` VARCHAR(64),
`NombrePersonaConacto` VARCHAR(64),
`EmailPersonaContacto` VARCHAR(64),
PRIMARY KEY (`PK_IDProveedor`)
) CHARACTER SET latin1;
CREATE TABLE `TipoSoftware` (
`PK_IDTipoSoftware` INT,
`DescripcionTipoSoftware` VARCHAR(64),
PRIMARY KEY (`PK_IDTipoSoftware`)
) CHARACTER SET latin1;
CREATE TABLE `Software` (
`PK_IDSoftware` INT,
`NombreSoftware` VARCHAR(64),
`DescripcionSoftware` VARCHAR(64),
`Activo` BOOL,
`TipoSoftware` INT,
`IDProveedor` INT,
PRIMARY KEY (`PK_IDSoftware`)
) CHARACTER SET latin1;
CREATE TABLE `TipoIncidente` (
`PK_IDTipoIncidente` INT,
