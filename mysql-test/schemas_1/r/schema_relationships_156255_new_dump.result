INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 156255_new_dump
#
CREATE DATABASE `db_156255_new_dump`;
USE `db_156255_new_dump`;
CREATE TABLE `migrations` (
`id` INT,
`migration` VARCHAR(64),
`batch` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified_at` DATETIME,
`password` VARCHAR(64),
`remember_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`phone_num` VARCHAR(64),
`current_member` INT,
`position_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `failed_jobs` (
`id` INT,
`connection` VARCHAR(64),
`queue` VARCHAR(64),
`payload` VARCHAR(64),
`exception` VARCHAR(64),
`failed_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
`id` INT,
`name` VARCHAR(64),
`quantity` INT,
`capacity` INT,
`low_threshold` INT,
`is_food` INT,
`refrigerated` INT,
`removed` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Member_Position` (
`id` INT,
`position` VARCHAR(64),
`privilege` INT,
`description` VARCHAR(64),
`email` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order_Transaction` (
`id` INT,
`member_id` INT,
`item_id` INT,
`item_quantity_change` INT,
`comment` VARCHAR(64),
`transaction_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
