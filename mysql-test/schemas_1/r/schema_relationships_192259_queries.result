INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 192259_queries
#
CREATE DATABASE `db_192259_queries`;
USE `db_192259_queries`;
CREATE TABLE `clients` (
`client_id` INT,
`name` VARCHAR(255),
`user_name` VARCHAR(255),
`age` INT,
`registered` DATETIME,
PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT,
`name` VARCHAR(255),
`price` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`clientID` INT,
`itemID` INT,
`quantity` INT,
`ordered_at` DATETIME,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `fulfilled_orders` (
`fulfilled_order_id` INT,
`clientID` INT,
`itemID` INT,
`quantity` INT,
`fulfilled_at` DATETIME,
PRIMARY KEY (`fulfilled_order_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_192259_queries') AS relationships;
relationships
Database: db_192259_queries

Table Connections:
------------------
[Implied]  fulfilled_orders.clientID -> clients.client_id
[Implied]  fulfilled_orders.itemID -> items.item_id
[Implied]  orders.clientID -> clients.client_id
[Implied]  orders.itemID -> items.item_id

DROP DATABASE `db_192259_queries`;
UNINSTALL EXTENSION vsql_schematron;
