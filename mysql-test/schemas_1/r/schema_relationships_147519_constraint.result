CREATE DATABASE `db_147519_constraint`;
USE `db_147519_constraint`;
CREATE TABLE `human` (
`id` VARCHAR(64),
`sname` VARCHAR(64),
`age` INT,
`sex` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
`id` VARCHAR(64),
`mark` VARCHAR(64),
`price` DECIMAL(10,2),
`hid` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_147519_constraint') AS relationships;
