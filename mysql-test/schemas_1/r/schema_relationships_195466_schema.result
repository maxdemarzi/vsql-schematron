INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 195466_schema
#
CREATE DATABASE `db_195466_schema`;
USE `db_195466_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`game` VARCHAR(50),
`score` INT,
`email` VARCHAR(50),
`username` VARCHAR(50),
`password_hash` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`user_id` INT,
`comment` VARCHAR(50),
`post` VARCHAR(50),
`date` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_195466_schema') AS relationships;
