INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 153989_databaseschema
#
CREATE DATABASE `db_153989_databaseschema`;
USE `db_153989_databaseschema`;
CREATE TABLE `PROBLEM` (
`ID` BIGINT NOT NULL,
`NAME` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`PROBLEMTYPE` BIGINT,
`CREATEDBY` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FOLDER` (
`ID` BIGINT NOT NULL,
`LONGDESCRIPTION` VARCHAR(50),
`COURSEID` BIGINT,
`CREATEDBY` BIGINT,
`ISVISIBLE` BOOLEAN,
`ENDDATE` TIMESTAMP NULL,
`STARTDATE` TIMESTAMP NULL,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EXERCISE` (
`ID` BIGINT NOT NULL,
`REFERENCEDPROBLEMID` BIGINT,
`COURSEID` BIGINT,
`FOLDERID` BIGINT,
`ALLOWEDATTEMPTS` BIGINT,
`MAXGRADE` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_153989_databaseschema') AS relationships;
