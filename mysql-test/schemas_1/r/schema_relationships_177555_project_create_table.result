INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 177555_project_create_table
#
CREATE DATABASE `db_177555_project_create_table`;
USE `db_177555_project_create_table`;
CREATE TABLE `locations` (
`location_id` INT,
`city` VARCHAR(255),
PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT,
`name` VARCHAR(255),
`email` VARCHAR(255),
`phone_number` VARCHAR(255),
`location_id` INT,
`gender` VARCHAR(255),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `hotels` (
`hotel_id` INT,
`location_id` INT,
`hotel_name` VARCHAR(255),
PRIMARY KEY (`hotel_id`)
) CHARACTER SET latin1;
CREATE TABLE `sections` (
`hotel_id` INT,
`section_id` INT,
`room_type` VARCHAR(255),
PRIMARY KEY (`hotel_id`, `section_id`)
) CHARACTER SET latin1;
CREATE TABLE `sales` (
`sale_id` INT,
`apply_month` INT,
`sale_percent` INT,
PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
`room_id` INT,
`hotel_id` INT,
`section_id` INT,
`sale_id` INT,
`floor` INT,
PRIMARY KEY (`hotel_id`, `section_id`, `room_id`)
) CHARACTER SET latin1;
CREATE TABLE `reservations` (
`reservation_id` INT,
`customer_id` INT,
`hotel_id` INT,
`section_id` INT,
`room_id` INT,
`day_start` DATETIME,
`day_end` DATETIME,
`price` INT,
PRIMARY KEY (`reservation_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_177555_project_create_table') AS relationships;
