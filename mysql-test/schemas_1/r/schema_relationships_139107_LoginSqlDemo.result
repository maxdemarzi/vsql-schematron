INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 139107_LoginSqlDemo
#
CREATE DATABASE `db_139107_LoginSqlDemo`;
USE `db_139107_LoginSqlDemo`;
CREATE TABLE `Cashiers` (
`cashier_ID` INT NOT NULL,
`cashier_name` VARCHAR(50),
`user_name` VARCHAR(50),
`user_pass` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`cashier_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
`customer_ID` INT NOT NULL,
`customer_name` VARCHAR(50),
`customer_phone` CHAR(50),
`customer_address` VARCHAR(50),
PRIMARY KEY (`customer_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Brands` (
`brand_ID` INT NOT NULL,
`brand_name` VARCHAR(50),
`brand_description` VARCHAR(50),
PRIMARY KEY (`brand_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Perfumes` (
`perfume_ID` INT NOT NULL,
`perfume_name` VARCHAR(50),
`fragrance_family` VARCHAR(50),
`classification` VARCHAR(50),
`volume` VARCHAR(50),
`top_notes` VARCHAR(50),
`heart_notes` VARCHAR(50),
`base_notes` VARCHAR(50),
`gender` VARCHAR(50),
`ingredients` VARCHAR(50),
`form` VARCHAR(50),
`year_launched` CHAR(50),
`strength` VARCHAR(50),
`origin` VARCHAR(50),
`price` DECIMAL(10,2),
`total_quantity` INT,
`product_status` TINYINT,
`perfume_description` VARCHAR(50),
`brand_ID` INT,
PRIMARY KEY (`perfume_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Invoices` (
`invoice_ID` INT NOT NULL,
`invoice_date` DATETIME,
`invoice_status` TINYINT,
`customer_ID` INT,
PRIMARY KEY (`invoice_ID`)
) CHARACTER SET latin1;
CREATE TABLE `InvoiceLineItems` (
`invoice_ID` INT NOT NULL,
`perfume_ID` INT NOT NULL,
`unit_price` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`invoice_ID`, `perfume_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_139107_LoginSqlDemo') AS relationships;
relationships
Database: db_139107_LoginSqlDemo

Table Connections:
------------------
[Implied]  InvoiceLineItems.invoice_ID -> Invoices.invoice_ID
[Implied]  InvoiceLineItems.perfume_ID -> Perfumes.perfume_ID
[Implied]  Invoices.customer_ID -> Customers.customer_ID
[Implied]  Perfumes.brand_ID -> Brands.brand_ID

DROP DATABASE `db_139107_LoginSqlDemo`;
UNINSTALL EXTENSION vsql_schematron;
