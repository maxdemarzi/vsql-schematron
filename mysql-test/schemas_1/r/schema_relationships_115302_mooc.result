INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 115302_mooc
#
CREATE DATABASE `db_115302_mooc`;
USE `db_115302_mooc`;
CREATE TABLE `videos` (
`id` VARCHAR(50) NOT NULL,
`type` VARCHAR(50),
`title` VARCHAR(50),
`url` VARCHAR(50),
`course_id` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`total_videos_created` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
`id` VARCHAR(50) NOT NULL,
`type` VARCHAR(50),
`lesson_id` CHAR(50),
`title` VARCHAR(50),
`estimated_duration` INT,
`step_order` INT,
`creation_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_challenges` (
`id` VARCHAR(50) NOT NULL,
`statement` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_quiz` (
`id` VARCHAR(50) NOT NULL,
`questions` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_video` (
`id` VARCHAR(50) NOT NULL,
`url` VARCHAR(50),
`text` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_115302_mooc') AS relationships;
relationships
Database: db_115302_mooc

Table Connections:
------------------
[Implied]  step_challenges.id -> steps.id
[Implied]  step_quiz.id -> steps.id
[Implied]  step_video.id -> steps.id

DROP DATABASE `db_115302_mooc`;
UNINSTALL EXTENSION vsql_schematron;
