CREATE DATABASE `db_156327_create_table`;
USE `db_156327_create_table`;
CREATE TABLE `context` (
`id` INT,
`last_updated` DATETIME,
`explanation` VARCHAR(64),
`name` VARCHAR(64),
`parent_name` VARCHAR(64),
`parent_path` VARCHAR(64),
`parent_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `paragraph` (
`id` INT,
`last_updated` DATETIME,
`remarks` VARCHAR(64),
`text` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `term` (
`id` INT,
`last_updated` DATETIME,
`explanation` VARCHAR(64),
`name` VARCHAR(64),
`reading` VARCHAR(64),
`translation` VARCHAR(64),
`context_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `word` (
`id` INT,
`last_updated` DATETIME,
`abbreviation` VARCHAR(64),
`conversion` VARCHAR(64),
`notation` VARCHAR(64),
`note` VARCHAR(64),
`reading` VARCHAR(64),
`context_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `term_paragraph` (
`paragraph_id` INT,
`term_id` INT,
PRIMARY KEY (`paragraph_id`, `term_id`)
) CHARACTER SET latin1;
CREATE TABLE `term_word` (
`word_id` INT,
`term_id` INT,
PRIMARY KEY (`word_id`, `term_id`)
) CHARACTER SET latin1;
