) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password_hash` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
