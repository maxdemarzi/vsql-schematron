CREATE DATABASE `db_197294_002_06_tables_historiques`;
USE `db_197294_002_06_tables_historiques`;
CREATE TABLE `t_historique_vente` (
`t_historique_vente_id` INT,
`t_produit_id` VARCHAR(64),
`mois` INT,
`annee` INT,
`quantite_vendue` INT,
`nombre_ventes` INT,
PRIMARY KEY (`t_historique_vente_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_histo_delivrance` (
`t_histo_delivrance_id` INT,
`numero_facture` INT,
`operateur` VARCHAR(64),
`t_client_id` VARCHAR(64),
`t_praticien_id` VARCHAR(64),
`prescription` DATETIME,
`delivrance` DATETIME,
`type_facturation` INT,
PRIMARY KEY (`t_histo_delivrance_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_histo_delivrance_ligne` (
`t_histo_delivrance_ligne_id` INT,
`t_histo_delivrance_id` INT,
`t_produit_id` VARCHAR(64),
`quantite` INT,
`prix_vente` DECIMAL(10,2),
`prix_achat` DECIMAL(10,2),
PRIMARY KEY (`t_histo_delivrance_ligne_id`)
) CHARACTER SET latin1;
