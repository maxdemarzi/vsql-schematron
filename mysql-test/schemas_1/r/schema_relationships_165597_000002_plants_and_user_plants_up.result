CREATE DATABASE `db_165597_000002_plants_and_user_plants_up`;
USE `db_165597_000002_plants_and_user_plants_up`;
CREATE TABLE `plants` (
`id_plant` BIGINT NOT NULL,
`name_plant` VARCHAR(50),
`photo_url` VARCHAR(50),
`description` TEXT,
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
PRIMARY KEY (`id_plant`)
) CHARACTER SET latin1;
CREATE TABLE `user_plants` (
`id_user_plant` BIGINT NOT NULL,
`id_user` BIGINT,
`id_plant` BIGINT,
`planting_time` TIMESTAMP NULL,
`watering_interval` INT,
`last_watering` TIMESTAMP NULL,
`next_watering` TIMESTAMP NULL,
`photo_url` VARCHAR(50),
`name_user_plant` VARCHAR(50),
`description` TEXT,
`created_at` TIMESTAMP NULL,
`modified_at` TIMESTAMP NULL,
PRIMARY KEY (`id_user_plant`)
) CHARACTER SET latin1;
