INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 180677_eshop1
#
CREATE DATABASE `db_180677_eshop1`;
USE `db_180677_eshop1`;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`price` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`tel` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders2` (
`id` INT,
`date` DATETIME,
`customers_id` INT,
`total_price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `eshop1.orders2_details` (
`id` INT,
`orders2_id` INT,
`products_id` INT,
`price` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_180677_eshop1') AS relationships;
relationships
Database: db_180677_eshop1

Table Connections:
------------------
[Implied]  eshop1.orders2_details.orders2_id -> orders2.id
[Implied]  eshop1.orders2_details.products_id -> products.id
[Implied]  orders2.customers_id -> customers.id

DROP DATABASE `db_180677_eshop1`;
UNINSTALL EXTENSION vsql_schematron;
