INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 105020_sample_table_data
#
CREATE DATABASE `db_105020_sample_table_data`;
USE `db_105020_sample_table_data`;
CREATE TABLE `teacher` (
`teacher_id` DECIMAL(10,2),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`subject` VARCHAR(64),
PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;
CREATE TABLE `guardian` (
`guardian_id` DECIMAL(10,2),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`relationship` VARCHAR(64),
`phone` VARCHAR(64),
`adm_no` DECIMAL(10,2),
PRIMARY KEY (`guardian_id`, `adm_no`)
) CHARACTER SET latin1;
CREATE TABLE `sponsor_table` (
`sponsor_id` DECIMAL(10,2),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`country` VARCHAR(64),
`province_or_state` VARCHAR(64),
`street_address` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`adm_no` DECIMAL(10,2),
PRIMARY KEY (`sponsor_id`, `adm_no`)
) CHARACTER SET latin1;
CREATE TABLE `student_table` (
`adm_no` DECIMAL(10,2),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`hometown` VARCHAR(64),
`district` VARCHAR(64),
`mentor` DECIMAL(10,2),
`guardian_id` DECIMAL(10,2),
`sponsor_id` DECIMAL(10,2),
PRIMARY KEY (`adm_no`)
) CHARACTER SET latin1;
CREATE TABLE `grade_level` (
`grade` VARCHAR(64),
`academic_year` VARCHAR(64),
`adm_no` DECIMAL(10,2),
`percentage` DECIMAL(10,2),
`class_rank` DECIMAL(10,2),
`teacher_id` DECIMAL(10,2),
PRIMARY KEY (`grade`, `academic_year`, `adm_no`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_105020_sample_table_data') AS relationships;
relationships
Database: db_105020_sample_table_data

Table Connections:
------------------
[Implied]  grade_level.adm_no -> student_table.adm_no
[Implied]  grade_level.teacher_id -> teacher.teacher_id
[Implied]  guardian.adm_no -> student_table.adm_no
[Implied]  sponsor_table.adm_no -> student_table.adm_no
[Implied]  student_table.guardian_id -> guardian.guardian_id
[Implied]  student_table.sponsor_id -> sponsor_table.sponsor_id

DROP DATABASE `db_105020_sample_table_data`;
UNINSTALL EXTENSION vsql_schematron;
