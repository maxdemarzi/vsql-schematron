`ID` INT,
`name` VARCHAR(64),
`adress` VARCHAR(64),
`phoneNumber` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DocumentType` (
`ID` INT,
