INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 172398_dbs
#
CREATE DATABASE `db_172398_dbs`;
USE `db_172398_dbs`;
CREATE TABLE `user` (
`id` INT,
`first` VARCHAR(64),
`last` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_recipe` (
`id` INT,
`recipe_id` INT,
`recipe_title` VARCHAR(64),
`day` VARCHAR(64),
`week` VARCHAR(64),
`quantity` INT,
PRIMARY KEY (`id`, `recipe_id`, `day`, `week`)
) CHARACTER SET latin1;
CREATE TABLE `user_activity` (
`id` INT,
`lastWeekNo` INT,
`recentSearch` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
`recipe_id` INT,
`recipe_title` VARCHAR(64),
`data` VARCHAR(64),
PRIMARY KEY (`recipe_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172398_dbs') AS relationships;
