INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 163012_3.%20MOVIE%20DATABASE
#
CREATE DATABASE `db_163012_3_20MOVIE_20DATABASE`;
USE `db_163012_3_20MOVIE_20DATABASE`;
CREATE TABLE `ACTOR` (
`ACTID` DECIMAL(10,2),
`ACTNAME` VARCHAR(64),
`ACTGENDER` VARCHAR(64),
PRIMARY KEY (`ACTID`)
) CHARACTER SET latin1;
CREATE TABLE `DIRECTOR` (
`DIRID` DECIMAL(10,2),
`DIRNAME` VARCHAR(64),
`DIRPHONE` DECIMAL(10,2),
PRIMARY KEY (`DIRID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIES` (
`MOVID` DECIMAL(10,2),
`MOVTITLE` VARCHAR(64),
`MOVYEAR` DECIMAL(10,2),
`MOVLANG` VARCHAR(64),
`DIRID` DECIMAL(10,2),
PRIMARY KEY (`MOVID`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIECAST` (
`ACTID` DECIMAL(10,2),
`MOVID` DECIMAL(10,2),
`ROLE` VARCHAR(64),
PRIMARY KEY (`ACTID`, `MOVID`)
) CHARACTER SET latin1;
CREATE TABLE `RATING` (
`MOVID` DECIMAL(10,2),
`REVSTARS` VARCHAR(64),
PRIMARY KEY (`MOVID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_163012_3_20MOVIE_20DATABASE') AS relationships;
relationships
Database: db_163012_3_20MOVIE_20DATABASE

Table Connections:
------------------
[Implied]  MOVIECAST.ACTID -> ACTOR.ACTID
[Implied]  MOVIECAST.MOVID -> MOVIES.MOVID
[Implied]  MOVIECAST.MOVID -> RATING.MOVID
[Implied]  MOVIES.DIRID -> DIRECTOR.DIRID
[Implied]  RATING.MOVID -> MOVIES.MOVID

DROP DATABASE `db_163012_3_20MOVIE_20DATABASE`;
