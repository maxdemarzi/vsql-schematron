INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 136088_mysql_schema
#
CREATE DATABASE `db_136088_mysql_schema`;
USE `db_136088_mysql_schema`;
CREATE TABLE `authors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`country` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_authors` (
`id` INT NOT NULL,
`author_id` INT,
`book_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_136088_mysql_schema') AS relationships;
relationships
