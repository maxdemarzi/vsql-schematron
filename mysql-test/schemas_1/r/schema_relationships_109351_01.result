INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 109351_01
#
CREATE DATABASE `db_109351_01`;
USE `db_109351_01`;
CREATE TABLE `Category` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
`id` INT,
`name` VARCHAR(64),
`location` VARCHAR(64),
`startTime` DATETIME,
`endTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Group` (
`id` INT,
`primaryImageId` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Location` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PriceGroup` (
`id` INT,
`name` VARCHAR(64),
`regularName` VARCHAR(64),
`specialName` VARCHAR(64),
`priceTypeName` VARCHAR(64),
`canPostSpecial` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Image` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`width` INT,
`height` INT,
`exposure` DECIMAL(10,2),
`focalLength` INT,
`aperture` DECIMAL(10,2),
`iso` INT,
`cameraModel` VARCHAR(64),
`timeTaken` DATETIME,
`locationId` INT,
`priceGroupId` INT,
`groupId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Price` (
`id` INT,
`name` VARCHAR(64),
`costRegular` DECIMAL(10,2),
`costSpecial` DECIMAL(10,2),
`costPostage` DECIMAL(10,2),
`priceGroupId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `_CategoryToImage` (
`A` INT,
`B` INT
) CHARACTER SET latin1;
CREATE TABLE `_ImageToTag` (
`A` INT,
`B` INT
) CHARACTER SET latin1;
CREATE TABLE `_prisma_migrations` (
`id` VARCHAR(64),
`checksum` VARCHAR(64),
`finished_at` DATETIME,
`migration_name` VARCHAR(64),
`logs` VARCHAR(64),
`rolled_back_at` DATETIME,
`started_at` DATETIME,
`applied_steps_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT,
`compound_id` VARCHAR(64),
`user_id` INT,
`provider_type` VARCHAR(64),
`provider_id` VARCHAR(64),
`provider_account_id` VARCHAR(64),
`refresh_token` VARCHAR(64),
`access_token` VARCHAR(64),
`access_token_expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`id` INT,
`user_id` INT,
`expires` DATETIME,
`session_token` VARCHAR(64),
`access_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified` DATETIME,
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `verification_requests` (
`id` INT,
`identifier` VARCHAR(64),
`token` VARCHAR(64),
`expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_109351_01') AS relationships;
relationships
