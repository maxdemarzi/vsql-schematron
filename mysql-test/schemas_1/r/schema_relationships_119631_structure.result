CREATE DATABASE `db_119631_structure`;
USE `db_119631_structure`;
CREATE TABLE `SystemUser` (
`systemUserId` INT,
`login` VARCHAR(64),
`password` VARCHAR(64),
`fullName` VARCHAR(64),
PRIMARY KEY (`systemUserId`)
) CHARACTER SET latin1;
CREATE TABLE `SystemGroup` (
`systemGroupId` INT,
`name` VARCHAR(64),
PRIMARY KEY (`systemGroupId`)
) CHARACTER SET latin1;
CREATE TABLE `SystemGroupSystemUser` (
`systemGroupId` INT,
`systemUserId` INT,
PRIMARY KEY (`systemGroupId`, `systemUserId`)
) CHARACTER SET latin1;
CREATE TABLE `SystemSession` (
`systemSessionId` INT,
`systemUserId` INT,
`token` VARCHAR(64),
`ip` VARCHAR(64),
`data` VARCHAR(64),
PRIMARY KEY (`systemSessionId`)
) CHARACTER SET latin1;
CREATE TABLE `Country` (
`countryId` INT,
`name` VARCHAR(64),
PRIMARY KEY (`countryId`)
) CHARACTER SET latin1;
CREATE TABLE `City` (
`cityId` INT,
`name` VARCHAR(64),
`countryId` INT,
PRIMARY KEY (`cityId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_119631_structure') AS relationships;
