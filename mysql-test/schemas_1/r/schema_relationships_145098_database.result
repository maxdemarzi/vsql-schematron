[Implied]  user_info.type_no -> user_type.type_no
[Implied]  user_wallet.currency_type_id -> currency_type.currency_type_id
[Implied]  user_wallet.user_no -> user_info.user_no

DROP DATABASE `db_145098_database`;
UNINSTALL EXTENSION vsql_schematron;
