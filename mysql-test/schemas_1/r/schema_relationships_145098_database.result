INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 145098_database
#
CREATE DATABASE `db_145098_database`;
USE `db_145098_database`;
CREATE TABLE `user_type` (
`type_no` INT,
`name` VARCHAR(64),
PRIMARY KEY (`type_no`)
) CHARACTER SET latin1;
CREATE TABLE `user_info` (
`user_no` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`type_no` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`age` INT,
`birthday` DATETIME,
`gender` VARCHAR(64),
`address` VARCHAR(64),
`mobile_number` VARCHAR(64),
`img_source` VARCHAR(64),
`peso_address` VARCHAR(64),
`create_date` DATETIME,
`is_online` BOOL,
`verify` BOOL,
PRIMARY KEY (`user_no`)
) CHARACTER SET latin1;
CREATE TABLE `currency_type` (
`currency_type_id` INT,
`name` VARCHAR(64),
`icon` VARCHAR(64),
PRIMARY KEY (`currency_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_wallet` (
`user_no` INT,
`currency_type_id` INT,
`amount` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `ads_type` (
`ads_type_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ads_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction_type` (
`transaction_type_id` INT,
`code` VARCHAR(64),
`ads_type_id` INT,
`currency_type_id` INT,
`duration` INT,
`duration_unit` VARCHAR(64),
`amount` DECIMAL(10,2),
`url` VARCHAR(64),
`content` VARCHAR(64),
PRIMARY KEY (`transaction_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `deposit_transactions` (
`transaction_id` INT,
`user_no` INT,
`transaction_type_id` INT,
`deposit_date` DATETIME,
`end_time` DATETIME,
PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
CREATE TABLE `days` (
`_day` INT
) CHARACTER SET latin1;
CREATE TABLE `refer` (
`refer_id` INT,
`referedBy` INT,
`user_no` INT,
PRIMARY KEY (`refer_id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
`event_no` INT,
`event_name` VARCHAR(64),
`started_date` DATETIME,
`ended_date` DATETIME,
`created_by` INT,
PRIMARY KEY (`event_no`)
) CHARACTER SET latin1;
CREATE TABLE `participant` (
`event_no` INT,
`user_no` INT
) CHARACTER SET latin1;
CREATE TABLE `raffle` (
`raffle_id` INT,
`code` VARCHAR(64),
`image` VARCHAR(64),
`prize` VARCHAR(64),
`description` VARCHAR(64),
`max_winner` INT,
`raffle_draw` DATETIME,
`date_created` DATETIME,
`date_updated` DATETIME,
`created_by` INT,
PRIMARY KEY (`raffle_id`)
) CHARACTER SET latin1;
CREATE TABLE `raffle_participant` (
`p_no` INT,
`raffle_id` INT,
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`fb_profile` VARCHAR(64),
`email_address` VARCHAR(64),
`date_created` DATETIME,
PRIMARY KEY (`p_no`)
) CHARACTER SET latin1;
CREATE TABLE `raffle_winner` (
`p_no` INT,
`date_created` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_145098_database') AS relationships;
relationships
