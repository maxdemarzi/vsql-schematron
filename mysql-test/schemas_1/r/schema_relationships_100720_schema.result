INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 100720_schema
#
CREATE DATABASE `db_100720_schema`;
USE `db_100720_schema`;
CREATE TABLE `polynomials` (
`id` INT NOT NULL,
`created` TIMESTAMP NULL,
`body` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `p_members` (
`id` INT NOT NULL,
`poly_id` INT,
`a_coefficient` INT,
`x_pow` INT,
`y_pow` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_100720_schema') AS relationships;
