INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 143608_schema
#
CREATE DATABASE `db_143608_schema`;
USE `db_143608_schema`;
CREATE TABLE `Locations` (
`locId` INT,
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
PRIMARY KEY (`locId`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`userId` INT,
`cognitoSub` VARCHAR(64),
`userName` VARCHAR(64),
`email` VARCHAR(64),
`emailVerified` VARCHAR(64),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `Categories` (
`categoryId` INT,
`categoryName` VARCHAR(64),
PRIMARY KEY (`categoryId`)
) CHARACTER SET latin1;
CREATE TABLE `UserPosts` (
`postId` INT,
`locId` INT,
`userId` INT,
`postTitle` VARCHAR(64),
`postContent` VARCHAR(64),
`createdAt` DATETIME,
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
CREATE TABLE `UserReplies` (
`replyId` INT,
`userId` INT,
`postId` INT,
`replyContent` VARCHAR(64),
`createdAt` DATETIME,
PRIMARY KEY (`replyId`)
) CHARACTER SET latin1;
CREATE TABLE `PostCategories` (
`postId` INT,
`categoryId` INT,
PRIMARY KEY (`postId`, `categoryId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_143608_schema') AS relationships;
relationships
Database: db_143608_schema

Table Connections:
------------------
[Implied]  PostCategories.categoryId -> Categories.categoryId
[Implied]  PostCategories.postId -> UserPosts.postId
[Implied]  UserPosts.locId -> Locations.locId
[Implied]  UserPosts.userId -> Users.userId
[Implied]  UserReplies.postId -> PostCategories.postId
[Implied]  UserReplies.userId -> Users.userId

DROP DATABASE `db_143608_schema`;
UNINSTALL EXTENSION vsql_schematron;
