INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 182964_Untitled
#
CREATE DATABASE `db_182964_Untitled`;
USE `db_182964_Untitled`;
CREATE TABLE `chefs` (
`id` INT NOT NULL,
`name` TEXT,
`file_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`id` INT NOT NULL,
`chef_id` INT,
`title` TEXT,
`information` TEXT,
`ingredients` VARCHAR(50),
`preparation` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT NOT NULL,
`name` TEXT,
`path` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_files` (
`id` INT NOT NULL,
`recipe_id` INT,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_182964_Untitled') AS relationships;
relationships
Database: db_182964_Untitled

Table Connections:
