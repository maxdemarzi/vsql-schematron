[Implied]  dist_trait.stream_id -> stream.id
[Implied]  event.event_type_id -> event_type.id
[Implied]  streamevent.event_id -> event.id
[Implied]  streamevent.stream_id -> stream.id
[Implied]  trait.event_id -> event.id

DROP DATABASE `db_111797_winchester`;
UNINSTALL EXTENSION vsql_schematron;
