PRIMARY KEY (`IdSensor`)
) CHARACTER SET latin1;
CREATE TABLE `local` (
`IdLocal` INT,
`Nome` VARCHAR(64),
`IdSensor` INT,
`DataCriacao` DATETIME,
PRIMARY KEY (`IdLocal`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`IdItem` INT,
`Nome` VARCHAR(64),
`DataCriacao` DATETIME,
PRIMARY KEY (`IdItem`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`IdUsuario` INT,
`Nome` VARCHAR(64),
`DataCriacao` DATETIME,
`Idade` INT,
PRIMARY KEY (`IdUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `rota` (
`IdRota` INT,
`IdSensorInicial` INT,
`IdSensorFinal` INT,
`Rota` VARCHAR(64),
PRIMARY KEY (`IdRota`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
`IdPedido` INT,
`IdUsuario` INT,
`DataCriacao` DATETIME,
`IdRota` INT,
PRIMARY KEY (`IdPedido`)
) CHARACTER SET latin1;
CREATE TABLE `PedidoXItem` (
`IdPedidoxItem` INT,
`IdPedido` INT,
`IdItem` INT,
`Quantidade` INT,
PRIMARY KEY (`IdPedidoxItem`)
) CHARACTER SET latin1;
