INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 199192_schema
#
CREATE DATABASE `db_199192_schema`;
USE `db_199192_schema`;
CREATE TABLE `City` (
`city_id` BIGINT NOT NULL,
`city_name` VARCHAR(50),
PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `GeoLocation` (
`geo_id` BIGINT NOT NULL,
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
PRIMARY KEY (`geo_id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
`address_id` BIGINT NOT NULL,
`street` VARCHAR(50),
`house_number` VARCHAR(50),
`postal_code` VARCHAR(50),
`city_id` BIGINT,
`geo_id` BIGINT,
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `Atm` (
`atm_id` BIGINT NOT NULL,
`distance` BIGINT,
`atm_type` VARCHAR(50),
`address_id` BIGINT,
PRIMARY KEY (`atm_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_199192_schema') AS relationships;
relationships
Database: db_199192_schema

Table Connections:
------------------
[Implied]  Address.city_id -> City.city_id
[Implied]  Address.geo_id -> GeoLocation.geo_id
[Implied]  Atm.address_id -> Address.address_id

DROP DATABASE `db_199192_schema`;
UNINSTALL EXTENSION vsql_schematron;
