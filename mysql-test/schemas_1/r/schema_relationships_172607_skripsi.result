CREATE DATABASE `db_172607_skripsi`;
USE `db_172607_skripsi`;
CREATE TABLE `barang` (
`id_barang` INT,
`nama_barang` VARCHAR(50),
`jumlah` INT,
`harga` INT
) CHARACTER SET latin1;
CREATE TABLE `penjualan` (
`id_penjualan` INT,
`id_barang` INT,
`jumlah_terjual` INT,
`kas` INT,
`bulan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`level` INT,
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172607_skripsi') AS relationships;
