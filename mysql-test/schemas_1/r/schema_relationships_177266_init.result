CREATE DATABASE `db_177266_init`;
USE `db_177266_init`;
CREATE TABLE `cart` (
`id` VARCHAR(50) NOT NULL,
`buyer_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_line` (
`id` VARCHAR(50) NOT NULL,
`product_id` VARCHAR(50),
`cart_id` VARCHAR(50),
`name` TEXT,
`price` DOUBLE,
`qty` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_177266_init') AS relationships;
