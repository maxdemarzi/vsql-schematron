CREATE DATABASE `db_162482_schema`;
USE `db_162482_schema`;
CREATE TABLE `sec_user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sec_role` (
`id` INT NOT NULL,
`rolename` VARCHAR(50),
`prompt` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sec_role_user` (
`id` INT NOT NULL,
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_162482_schema') AS relationships;
