INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 143072_ojt_yii2
#
CREATE DATABASE `db_143072_ojt_yii2`;
USE `db_143072_ojt_yii2`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` INT,
PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64),
PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `maintence` (
`id` INT,
`date` DATETIME,
`vehicle_type` INT,
`licence_plat` VARCHAR(64),
`explanation` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `schedule` (
`id` INT,
`id_booking` INT,
`id_vehicle` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `statusorder` (
`id` INT,
`des` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicle` (
`id` INT,
`licence_plat` VARCHAR(64),
`vehicle_type` VARCHAR(64),
`vehicle_status` VARCHAR(64),
`partner` VARCHAR(64),
`id_driver` INT,
`status_schedule` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_143072_ojt_yii2') AS relationships;
relationships
Database: db_143072_ojt_yii2

