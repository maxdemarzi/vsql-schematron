`oid_security_policy` INT
) CHARACTER SET latin1;
CREATE TABLE `gx_resource` (
`oid` INT NOT NULL,
`resource_name` VARCHAR(50),
`resource_desription` VARCHAR(50),
`is_active` BOOLEAN,
`oid_namespace` INT,
PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
CREATE TABLE `gx_access_log` (
`oid` INT NOT NULL,
`oid_access_key` INT,
`oid_resource` INT,
`access_time` TIMESTAMP NULL,
`is_success` BOOLEAN,
`access_type` INT,
PRIMARY KEY (`oid`)
) CHARACTER SET latin1;
