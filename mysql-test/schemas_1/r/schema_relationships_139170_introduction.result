INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 139170_introduction
#
CREATE DATABASE `db_139170_introduction`;
USE `db_139170_introduction`;
CREATE TABLE `DEPARTMENTS` (
`deptno` DECIMAL(10,2),
`name` VARCHAR(64),
`location` VARCHAR(64),
PRIMARY KEY (`deptno`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEES` (
`empno` DECIMAL(10,2),
`name` VARCHAR(64),
`job` VARCHAR(64),
`manager` DECIMAL(10,2),
`hiredate` DATETIME,
`salary` DECIMAL(10,2),
`commission` DECIMAL(10,2),
`deptno` DECIMAL(10,2),
PRIMARY KEY (`empno`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_139170_introduction') AS relationships;
relationships
Database: db_139170_introduction

