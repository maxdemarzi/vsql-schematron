INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 169919_schema
#
CREATE DATABASE `db_169919_schema`;
USE `db_169919_schema`;
CREATE TABLE `emails` (
`id` INT NOT NULL,
`view_uuid` TEXT,
`admin_uuid` TEXT,
`sentfrom` TEXT,
`subject` TEXT,
`content` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `views` (
`email` INT,
`viewed` INT,
`ip` TEXT,
`user_agent` TEXT,
`cookie_uuid` TEXT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_169919_schema') AS relationships;
