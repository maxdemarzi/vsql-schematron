CREATE DATABASE `db_104617_06_job_center`;
USE `db_104617_06_job_center`;
CREATE TABLE `xxl_job_qrtz_calendars` (
`sched_name` VARCHAR(64),
`calendar_name` VARCHAR(64),
`calendar` VARCHAR(64),
PRIMARY KEY (`sched_name`, `calendar_name`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_fired_triggers` (
`sched_name` VARCHAR(64),
`entry_id` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`instance_name` VARCHAR(64),
`fired_time` INT,
`sched_time` INT,
`priority` INT,
`state` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`is_nonconcurrent` VARCHAR(64),
`requests_recovery` VARCHAR(64),
PRIMARY KEY (`sched_name`, `entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_job_details` (
`sched_name` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`description` VARCHAR(64),
`job_class_name` VARCHAR(64),
`is_durable` VARCHAR(64),
`is_nonconcurrent` VARCHAR(64),
`is_update_data` VARCHAR(64),
`requests_recovery` VARCHAR(64),
`job_data` VARCHAR(64),
PRIMARY KEY (`sched_name`, `job_name`, `job_group`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_locks` (
`sched_name` VARCHAR(64),
`lock_name` VARCHAR(64),
PRIMARY KEY (`sched_name`, `lock_name`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_paused_trigger_grps` (
`sched_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_scheduler_state` (
`sched_name` VARCHAR(64),
`instance_name` VARCHAR(64),
`last_checkin_time` INT,
`checkin_interval` INT,
PRIMARY KEY (`sched_name`, `instance_name`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_trigger_logglue` (
`id` INT,
`job_id` INT,
`glue_type` VARCHAR(64),
`glue_source` VARCHAR(64),
`glue_remark` VARCHAR(64),
`add_time` DATETIME,
`update_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_triggers` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`description` VARCHAR(64),
`next_fire_time` INT,
`prev_fire_time` INT,
`priority` INT,
`trigger_state` VARCHAR(64),
`trigger_type` VARCHAR(64),
`start_time` INT,
`end_time` INT,
`calendar_name` VARCHAR(64),
`misfire_instr` INT,
`job_data` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_simprop_triggers` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`str_prop_1` VARCHAR(64),
`str_prop_2` VARCHAR(64),
`str_prop_3` VARCHAR(64),
`int_prop_1` INT,
`int_prop_2` INT,
`long_prop_1` INT,
`long_prop_2` INT,
`dec_prop_1` DECIMAL(10,2),
`dec_prop_2` DECIMAL(10,2),
`bool_prop_1` VARCHAR(64),
`bool_prop_2` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `xxl_job_qrtz_simple_triggers` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`repeat_count` INT,
`repeat_interval` INT,
