`type_ds` VARCHAR(64),
`acceptable_fl` INT,
`previewable_fl` INT,
`file_cmd_regex` VARCHAR(64),
`changed_dt` DATETIME,
PRIMARY KEY (`type_cd`)
) CHARACTER SET latin1;
CREATE TABLE `version` (
`version_id` INT,
`file_id` INT,
`uuid_fn` VARCHAR(64),
`content_tp` VARCHAR(64),
`upload_dt` DATETIME,
`upload_user_id` INT,
`original_fn` VARCHAR(64),
`original_dt` DATETIME,
PRIMARY KEY (`version_id`)
) CHARACTER SET latin1;
