USE `db_165964_NewTrulyDocs`;
CREATE TABLE `file` (
`file_id` INT,
`document_id` INT,
`file_st` VARCHAR(64),
`uuid_fn` VARCHAR(64),
`content_tp` VARCHAR(64),
`file_ds` VARCHAR(64),
`first_upload_dt` DATETIME,
`first_upload_user_id` INT,
`last_upload_dt` DATETIME,
`last_upload_user_id` INT,
`original_fn` VARCHAR(64),
`original_dt` DATETIME,
PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
CREATE TABLE `file_extension` (
`extension_cd` VARCHAR(64),
`type_cd` VARCHAR(64),
`extension_fn` VARCHAR(64),
PRIMARY KEY (`extension_cd`)
) CHARACTER SET latin1;
CREATE TABLE `file_type` (
