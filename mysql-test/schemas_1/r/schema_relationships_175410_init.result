INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 175410_init
#
CREATE DATABASE `db_175410_init`;
USE `db_175410_init`;
CREATE TABLE `ciraconfigs` (
`cira_config_name` VARCHAR(64),
`mps_server_address` VARCHAR(64),
`mps_port` INT,
`user_name` VARCHAR(64),
`password` VARCHAR(64),
`common_name` VARCHAR(64),
`server_address_format` INT,
`auth_method` INT,
`mps_root_certificate` VARCHAR(64),
`proxydetails` VARCHAR(64),
`tenant_id` VARCHAR(64),
PRIMARY KEY (`cira_config_name`, `tenant_id`)
) CHARACTER SET latin1;
CREATE TABLE `wirelessconfigs` (
`wireless_profile_name` VARCHAR(64),
`authentication_method` INT,
`encryption_method` INT,
`ssid` VARCHAR(64),
`psk_value` INT,
`psk_passphrase` VARCHAR(64),
`link_policy` VARCHAR(64),
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`tenant_id` VARCHAR(64),
PRIMARY KEY (`wireless_profile_name`, `tenant_id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
`profile_name` VARCHAR(64),
`activation` VARCHAR(64),
`amt_password` VARCHAR(64),
`generate_random_password` VARCHAR(64),
`cira_config_name` VARCHAR(64),
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`mebx_password` VARCHAR(64),
`generate_random_mebx_password` VARCHAR(64),
`tags` VARCHAR(64),
`dhcp_enabled` VARCHAR(64),
`tenant_id` VARCHAR(64),
PRIMARY KEY (`profile_name`, `tenant_id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles_wirelessconfigs` (
`wireless_profile_name` VARCHAR(64),
`profile_name` VARCHAR(64),
`priority` INT,
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`tenant_id` VARCHAR(64),
PRIMARY KEY (`wireless_profile_name`, `profile_name`, `priority`, `tenant_id`)
) CHARACTER SET latin1;
CREATE TABLE `domains` (
`name` VARCHAR(64),
`domain_suffix` VARCHAR(64),
`provisioning_cert` VARCHAR(64),
`provisioning_cert_storage_format` VARCHAR(64),
`provisioning_cert_key` VARCHAR(64),
`creation_date` DATETIME,
`created_by` VARCHAR(64),
`tenant_id` VARCHAR(64),
PRIMARY KEY (`name`, `tenant_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_175410_init') AS relationships;
relationships
