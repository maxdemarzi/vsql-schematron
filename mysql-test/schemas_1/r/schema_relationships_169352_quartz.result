`INT_PROP_1` INT,
`INT_PROP_2` INT,
`LONG_PROP_1` INT,
`LONG_PROP_2` INT,
`DEC_PROP_1` VARCHAR(64),
`DEC_PROP_2` VARCHAR(64),
`BOOL_PROP_1` INT,
`BOOL_PROP_2` INT,
`TIME_ZONE_ID` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
