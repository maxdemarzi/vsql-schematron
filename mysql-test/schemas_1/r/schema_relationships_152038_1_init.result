CREATE DATABASE `db_152038_1_init`;
USE `db_152038_1_init`;
CREATE TABLE `users` (
`user_id` VARCHAR(64),
`full_name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`verify` BOOL,
`create_at` DATETIME,
`update_at` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`link` VARCHAR(64),
`name` VARCHAR(64),
`tag` VARCHAR(64),
PRIMARY KEY (`link`)
) CHARACTER SET latin1;
CREATE TABLE `bookmarks` (
`bookmark_id` VARCHAR(64),
`user_id` VARCHAR(64),
`post_name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`bookmark_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_152038_1_init') AS relationships;
