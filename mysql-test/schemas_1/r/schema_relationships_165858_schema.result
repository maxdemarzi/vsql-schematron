INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 165858_schema
#
CREATE DATABASE `db_165858_schema`;
USE `db_165858_schema`;
CREATE TABLE `departments` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_165858_schema') AS relationships;
relationships
Database: db_165858_schema

Table Connections:
