`Image` VARCHAR(64),
`idHotel` DECIMAL(10,2),
PRIMARY KEY (`Identifiant`)
) CHARACTER SET latin1;
CREATE TABLE `Client` (
`Identifiant` DECIMAL(10,2),
`Nom` VARCHAR(64),
`Prenom` VARCHAR(64),
PRIMARY KEY (`Identifiant`)
) CHARACTER SET latin1;
CREATE TABLE `Agence` (
