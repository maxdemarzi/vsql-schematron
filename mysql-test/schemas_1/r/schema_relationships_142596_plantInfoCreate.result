) CHARACTER SET latin1;
CREATE TABLE `posts` (
`_id` INT,
`plant_id` INT,
`url` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `relationships` (
`_id` INT,
`follower_id` INT,
`followed_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
