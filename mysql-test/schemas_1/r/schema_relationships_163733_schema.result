INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 163733_schema
#
CREATE DATABASE `db_163733_schema`;
USE `db_163733_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`subscription` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feeds` (
`id` INT NOT NULL,
`uri` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_feeds` (
`id` INT NOT NULL,
`user_id` INT,
`feed_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
`id` INT NOT NULL,
`url` VARCHAR(50),
`yays` INT,
`nays` INT,
`fakes` INT,
`legits` INT,
`ratings` INT,
`rating_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`article_id` INT,
`user_id` INT,
`comment` VARCHAR(50),
`yay` BOOLEAN,
`nay` BOOLEAN,
`fake` BOOLEAN,
`legit` BOOLEAN,
`rating` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_comments` (
`id` INT NOT NULL,
`user_id` INT,
`comment_id` INT,
`article_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_163733_schema') AS relationships;
relationships
Database: db_163733_schema

Table Connections:
------------------
[Implied]  article_comments.article_id -> article.id
[Implied]  article_comments.comment_id -> comments.id
[Implied]  article_comments.user_id -> users.id
[Implied]  comments.article_id -> article.id
[Implied]  comments.user_id -> users.id
[Implied]  users_feeds.feed_id -> feeds.id
[Implied]  users_feeds.user_id -> users.id

DROP DATABASE `db_163733_schema`;
UNINSTALL EXTENSION vsql_schematron;
