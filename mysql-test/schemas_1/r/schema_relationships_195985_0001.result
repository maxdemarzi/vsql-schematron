CREATE DATABASE `db_195985_0001`;
USE `db_195985_0001`;
CREATE TABLE `company` (
`companyid` VARCHAR(64),
`phonenumber` VARCHAR(64),
`invoicingemailaddress` VARCHAR(64),
`created` DATETIME,
`salesemailaddress` VARCHAR(64),
`companyname` VARCHAR(64),
`supportemailaddress` VARCHAR(64),
`companycode` VARCHAR(64),
`modified` DATETIME,
`deliveryaddress_postaladdressid` VARCHAR(64),
`invoicingaddress_postaladdressid` VARCHAR(64),
`iban` VARCHAR(64),
`bic` VARCHAR(64),
`host` VARCHAR(64),
`termsandconditions` VARCHAR(64),
PRIMARY KEY (`companyid`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`customerid` VARCHAR(64),
`lastname` VARCHAR(64),
`phonenumber` VARCHAR(64),
`created` DATETIME,
`company` VARCHAR(64),
`emailaddress` VARCHAR(64),
`firstname` VARCHAR(64),
`companyname` VARCHAR(64),
`modified` DATETIME,
`companycode` VARCHAR(64),
`deliveryaddress_postaladdressid` VARCHAR(64),
`invoicingaddress_postaladdressid` VARCHAR(64),
`owner_companyid` VARCHAR(64),
PRIMARY KEY (`customerid`)
) CHARACTER SET latin1;
CREATE TABLE `group_` (
`groupid` VARCHAR(64),
`created` DATETIME,
`description` VARCHAR(64),
`name` VARCHAR(64),
`modified` DATETIME,
`owner_companyid` VARCHAR(64),
PRIMARY KEY (`groupid`)
) CHARACTER SET latin1;
CREATE TABLE `groupmember` (
`groupmemberid` VARCHAR(64),
`created` DATETIME,
`group_groupid` VARCHAR(64),
`user_userid` VARCHAR(64),
PRIMARY KEY (`groupmemberid`)
) CHARACTER SET latin1;
CREATE TABLE `postaladdress` (
`postaladdressid` VARCHAR(64),
`addresslinetwo` VARCHAR(64),
`addresslinethree` VARCHAR(64),
`postalcode` VARCHAR(64),
`addresslineone` VARCHAR(64),
`city` VARCHAR(64),
`country` VARCHAR(64),
PRIMARY KEY (`postaladdressid`)
) CHARACTER SET latin1;
CREATE TABLE `privilege` (
`privilegeid` VARCHAR(64),
`created` DATETIME,
`dataid` VARCHAR(64),
`key` VARCHAR(64),
`user_userid` VARCHAR(64),
`group_groupid` VARCHAR(64),
PRIMARY KEY (`privilegeid`)
) CHARACTER SET latin1;
CREATE TABLE `user_` (
`userid` VARCHAR(64),
`lastname` VARCHAR(64),
`phonenumber` VARCHAR(64),
`created` DATETIME,
`emailaddress` VARCHAR(64),
`firstname` VARCHAR(64),
`modified` DATETIME,
`owner_companyid` VARCHAR(64),
`passwordhash` VARCHAR(64),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `schemaversion` (
`created` DATETIME,
`schemaname` VARCHAR(64),
`schemaversion` VARCHAR(64),
PRIMARY KEY (`created`)
) CHARACTER SET latin1;
