CREATE DATABASE `db_184046_003_user_post`;
USE `db_184046_003_user_post`;
CREATE TABLE `user` (
`id` VARCHAR(64),
`authKey` VARCHAR(64),
`email` VARCHAR(64),
`nickName` VARCHAR(64),
`isCool` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` VARCHAR(64),
`writer` VARCHAR(64),
`body` VARCHAR(64),
`title` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
