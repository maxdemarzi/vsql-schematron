INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 153790_migration
#
CREATE DATABASE `db_153790_migration`;
USE `db_153790_migration`;
CREATE TABLE `users` (
`uuid` VARCHAR(255),
`username` VARCHAR(255),
`password` VARCHAR(255),
`email` VARCHAR(255),
`picture` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `cryptocurrencies` (
`uuid` VARCHAR(255),
`name` VARCHAR(255),
`abbreviation` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `wallets` (
`uuid` VARCHAR(255),
`user_uuid` VARCHAR(255),
`cryptocurrency_uuid` VARCHAR(255),
`amount` DECIMAL(10,2),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_153790_migration') AS relationships;
