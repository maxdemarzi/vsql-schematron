CREATE DATABASE `db_179533_database`;
USE `db_179533_database`;
CREATE TABLE `char_comics` (
`id_character` INT,
`id_comic` INT,
PRIMARY KEY (`id_character`, `id_comic`)
) CHARACTER SET latin1;
CREATE TABLE `char_events` (
`id_character` INT,
`id_event` INT,
PRIMARY KEY (`id_character`, `id_event`)
) CHARACTER SET latin1;
CREATE TABLE `char_series` (
`id_character` INT,
`id_serie` INT,
PRIMARY KEY (`id_character`, `id_serie`)
) CHARACTER SET latin1;
CREATE TABLE `char_stories` (
`id_character` INT,
`id_story` INT,
PRIMARY KEY (`id_character`, `id_story`)
) CHARACTER SET latin1;
CREATE TABLE `characters` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`modified` DATETIME,
`resourceURI` VARCHAR(64),
`urls` VARCHAR(64),
`thumbnail` VARCHAR(64),
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comics` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `series` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stories` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
