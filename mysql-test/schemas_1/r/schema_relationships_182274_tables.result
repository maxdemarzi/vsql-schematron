INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 182274_tables
#
CREATE DATABASE `db_182274_tables`;
USE `db_182274_tables`;
CREATE TABLE `data` (
`id` VARCHAR(64),
`user_id` INT,
`site_id` VARCHAR(64),
`date` DATETIME,
`temperature` DECIMAL(10,2),
`temp_standard` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `site_statistics` (
`statistics_id` VARCHAR(64),
`site_id` VARCHAR(64),
`date` DATETIME,
`week_max` DECIMAL(10,2),
`week_min` DECIMAL(10,2),
`week_avg` DECIMAL(10,2),
`week_deviation` DECIMAL(10,2),
`month_max` DECIMAL(10,2),
`month_min` DECIMAL(10,2),
`month_avg` DECIMAL(10,2),
`month_deviation` DECIMAL(10,2),
`year_max` DECIMAL(10,2),
`year_min` DECIMAL(10,2),
`year_avg` DECIMAL(10,2),
`year_deviation` DECIMAL(10,2),
`all_max` DECIMAL(10,2),
`all_min` DECIMAL(10,2),
`all_avg` DECIMAL(10,2),
`all_deviation` DECIMAL(10,2),
PRIMARY KEY (`statistics_id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `upload_history` (
`id` VARCHAR(64),
`site_id` VARCHAR(64),
`date` DATETIME,
`duration` VARCHAR(64),
`description` VARCHAR(64),
`error` INT,
`viewed` INT,
`user_id` INT,
`records` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`middle_initial` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`enabled` VARCHAR(64),
`temp_standard` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_182274_tables') AS relationships;
relationships
Database: db_182274_tables

Table Connections:
------------------
[Implied]  data.site_id -> site_statistics.statistics_id
[Implied]  data.user_id -> user.id
[Implied]  upload_history.site_id -> site_statistics.statistics_id
[Implied]  upload_history.user_id -> user.id
[Implied]  user_role.role_id -> role.id
[Implied]  user_role.user_id -> user.id

DROP DATABASE `db_182274_tables`;
UNINSTALL EXTENSION vsql_schematron;
