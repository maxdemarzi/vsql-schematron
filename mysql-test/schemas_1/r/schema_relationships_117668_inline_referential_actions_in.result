INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 117668_inline_referential_actions.in
#
CREATE DATABASE `db_117668_inline_referential_actions_in`;
USE `db_117668_inline_referential_actions_in`;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`user_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`id` INT NOT NULL,
`order_id` INT,
`product_id` INT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`price` DECIMAL(10,2),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`date_of_birth` DATETIME,
`created_at` DATETIME,
`country_code` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
`code` INT NOT NULL,
`name` VARCHAR(50),
`continent_name` VARCHAR(50),
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_117668_inline_referential_actions_in') AS relationships;
relationships
