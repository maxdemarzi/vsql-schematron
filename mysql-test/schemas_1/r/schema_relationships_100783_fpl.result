INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 100783_fpl
#
CREATE DATABASE `db_100783_fpl`;
USE `db_100783_fpl`;
CREATE TABLE `Clubs` (
`ID` INT,
`Name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SquadMembers` (
`Squad` INT,
`Player` INT
) CHARACTER SET latin1;
CREATE TABLE `Squads` (
`ID` INT,
`Name` VARCHAR(50),
`Value` DECIMAL(10,2),
`Owner` INT
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`ID` INT,
`Name` VARCHAR(50),
`Email` VARCHAR(50),
`Password` VARCHAR(50),
`FavTeam` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_100783_fpl') AS relationships;
relationships
Database: db_100783_fpl

Table Connections:
------------------
[Implied]  SquadMembers.Squad -> Squads.ID
[Implied]  Squads.Owner -> Users.ID

DROP DATABASE `db_100783_fpl`;
UNINSTALL EXTENSION vsql_schematron;
