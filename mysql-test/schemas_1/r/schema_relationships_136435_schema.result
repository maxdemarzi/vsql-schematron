INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 136435_schema
#
CREATE DATABASE `db_136435_schema`;
USE `db_136435_schema`;
CREATE TABLE `admin_tb` (
`admin_id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`role_name` VARCHAR(50),
PRIMARY KEY (`admin_id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tb` (
`post_id` INT NOT NULL,
`title` VARCHAR(50),
`content` TEXT,
`admin_id` INT,
`create_date` DATE,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `dept_tb` (
`dept_id` INT NOT NULL,
`dept_name` VARCHAR(50),
`dept_description` VARCHAR(50),
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `position_tb` (
`pos_id` INT NOT NULL,
`pos_name` VARCHAR(50),
`pos_description` VARCHAR(50),
PRIMARY KEY (`pos_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_tb` (
`emp_id` VARCHAR(50) NOT NULL,
`emp_name` VARCHAR(50),
`sex` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`address` VARCHAR(50),
`education` VARCHAR(50),
`birthday` DATE,
`dept_id` INT,
`pos_id` INT,
PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_136435_schema') AS relationships;
relationships
Database: db_136435_schema

Table Connections:
------------------
[Implied]  employee_tb.dept_id -> dept_tb.dept_id
[Implied]  employee_tb.pos_id -> position_tb.pos_id
[Implied]  post_tb.admin_id -> admin_tb.admin_id

DROP DATABASE `db_136435_schema`;
UNINSTALL EXTENSION vsql_schematron;
