INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 175112_wearable_tech
#
CREATE DATABASE `db_175112_wearable_tech`;
USE `db_175112_wearable_tech`;
CREATE TABLE `researcher` (
`researcher_id` INT NOT NULL,
`email` VARCHAR(50),
`passwrd` VARCHAR(50),
`f_name` VARCHAR(50),
`m_initial` CHAR(50),
`l_name` VARCHAR(50),
`institution` VARCHAR(50),
PRIMARY KEY (`researcher_id`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
`subject_id` INT NOT NULL,
`researcher_id` INT,
`age` INT,
`weight` INT,
`height` DECIMAL(10,2),
`bmi` DECIMAL(10,2),
`ethnicity` VARCHAR(50),
`fitzpatrick` VARCHAR(50),
`gender` VARCHAR(50),
PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `processed_data` (
`body_location` VARCHAR(50) NOT NULL,
`subject_id` INT NOT NULL,
`wave_length` DECIMAL(10,2),
`absorbance` DECIMAL(10,2),
`time_date` TIMESTAMP NULL,
PRIMARY KEY (`body_location`, `subject_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_175112_wearable_tech') AS relationships;
relationships
Database: db_175112_wearable_tech

Table Connections:
------------------
[Implied]  processed_data.subject_id -> subject.subject_id
[Implied]  subject.researcher_id -> researcher.researcher_id

