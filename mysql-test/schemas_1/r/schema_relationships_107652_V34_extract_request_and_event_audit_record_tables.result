CREATE DATABASE `db_107652_V34_extract_request_and_event_audit_record_tables`;
USE `db_107652_V34_extract_request_and_event_audit_record_tables`;
CREATE TABLE `request_audit_record` (
`uuid` VARCHAR(255),
`host_name` VARCHAR(255),
`now` INT,
`path` VARCHAR(255),
`requester_ip` VARCHAR(255),
`auth_valid_from` INT,
`auth_valid_until` INT,
`uaa_url` VARCHAR(255),
`user_id` VARCHAR(255),
`user_name` VARCHAR(255),
`x_forwarded_for` VARCHAR(255),
`scope` VARCHAR(255),
`grant_type` VARCHAR(255),
`client_id` VARCHAR(255),
`method` VARCHAR(255),
`status_code` INT,
`query_parameters` VARCHAR(255),
`auth_method` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `event_audit_record` (
`uuid` VARCHAR(255),
`request_uuid` VARCHAR(255),
`now` INT,
`operation` VARCHAR(255),
`credential_name` VARCHAR(255),
`actor` VARCHAR(255),
`success` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
