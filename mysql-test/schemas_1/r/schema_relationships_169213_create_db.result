CREATE DATABASE `db_169213_create_db`;
USE `db_169213_create_db`;
CREATE TABLE `person` (
`ID` INT,
`birthdate` DATETIME,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`age` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`ID` INT,
`birthdate` DATETIME,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`age` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `school` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `manufacturer` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`ID` INT,
`person_id` INT,
`postal_code` INT,
`city` VARCHAR(64),
`street` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`ID` INT,
`person_id` INT,
`school_id` INT,
`name` VARCHAR(64),
`difficulty` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `all_types` (
`ID` INT,
`rating` INT,
`hash` INT,
`age` DECIMAL(10,2),
`price` DECIMAL(10,2),
`taxes` DECIMAL(10,2),
`newdate` DATETIME,
