`created` DATETIME,
`active` BOOL,
`country` VARCHAR(64),
`model` VARCHAR(64),
`brand` VARCHAR(64),
`description` VARCHAR(64),
`contract` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
