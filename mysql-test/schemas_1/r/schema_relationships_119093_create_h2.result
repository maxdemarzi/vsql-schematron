CREATE DATABASE `db_119093_create_h2`;
USE `db_119093_create_h2`;
CREATE TABLE `signal_queue` (
`seq_num` INT,
`cls` VARCHAR(64),
`id` VARCHAR(64),
`event_cls` VARCHAR(64),
`event_bytes` VARCHAR(64),
PRIMARY KEY (`seq_num`)
) CHARACTER SET latin1;
CREATE TABLE `entity` (
`cls` VARCHAR(64),
`id` VARCHAR(64),
`state` VARCHAR(64),
`bytes` VARCHAR(64),
PRIMARY KEY (`cls`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `entity_property` (
`cls` VARCHAR(64),
`id` VARCHAR(64),
`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`cls`, `id`, `name`, `value`)
) CHARACTER SET latin1;
CREATE TABLE `entity_prop_range_int` (
`cls` VARCHAR(64),
`id` VARCHAR(64),
`name` VARCHAR(64),
`value` VARCHAR(64),
`range_name` VARCHAR(64),
`range_value` INT,
PRIMARY KEY (`cls`, `id`, `name`, `value`)
) CHARACTER SET latin1;
CREATE TABLE `signal_store` (
`seq_num` INT,
`cls` VARCHAR(64),
`id` VARCHAR(64),
`event_cls` VARCHAR(64),
`event_bytes` VARCHAR(64),
PRIMARY KEY (`seq_num`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_119093_create_h2') AS relationships;
