INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 156575_migration
#
CREATE DATABASE `db_156575_migration`;
USE `db_156575_migration`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`pk` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`email` TEXT,
`username` TEXT,
`displayName` TEXT,
`password` TEXT,
`role` VARCHAR(50),
`avatarUrl` TEXT,
`university` TEXT,
`department` TEXT,
`semester` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` VARCHAR(50) NOT NULL,
`pk` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`userId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Friendship` (
`id` VARCHAR(50) NOT NULL,
`pk` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`firstUserId` TEXT,
`secondUserId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `FriendRequest` (
`id` VARCHAR(50) NOT NULL,
`pk` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`fromUserId` TEXT,
`toUserId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_156575_migration') AS relationships;
