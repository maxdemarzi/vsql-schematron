CREATE DATABASE `db_111134_create`;
USE `db_111134_create`;
CREATE TABLE `cities` (
`id` INT NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
`id` INT NOT NULL,
`time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guesses` (
`game` INT,
`city` INT,
`lat` DOUBLE,
`lng` DOUBLE,
`duration` DOUBLE,
`points` INT,
`distance` INT
) CHARACTER SET latin1;
