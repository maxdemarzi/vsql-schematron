CREATE TABLE `Flights` (
`flno` INT NOT NULL,
`ffrom` VARCHAR(50),
`tto` VARCHAR(50),
`distance` INT,
`departs` DATE,
`arrives` DATE,
`price` DOUBLE,
PRIMARY KEY (`flno`)
) CHARACTER SET latin1;
CREATE TABLE `Aircraft` (
`aid` INT NOT NULL,
`aname` VARCHAR(50),
`cruisingrange` INT,
PRIMARY KEY (`aid`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
`eid` INT NOT NULL,
`ename` VARCHAR(50),
`salary` DOUBLE,
PRIMARY KEY (`eid`)
) CHARACTER SET latin1;
CREATE TABLE `Certified` (
`eid` INT NOT NULL,
`aid` INT NOT NULL,
PRIMARY KEY (`eid`, `aid`)
) CHARACTER SET latin1;
