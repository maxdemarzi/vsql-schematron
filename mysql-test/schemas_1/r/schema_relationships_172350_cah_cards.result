INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 172350_cah_cards
#
CREATE DATABASE `db_172350_cah_cards`;
USE `db_172350_cah_cards`;
CREATE TABLE `black_cards` (
`id` INT,
`text` VARCHAR(64),
`draw` INT,
`pick` INT,
`watermark` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `card_set` (
`id` INT,
`active` VARCHAR(64),
`name` VARCHAR(64),
`base_deck` VARCHAR(64),
`description` VARCHAR(64),
`weight` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `card_set_black_card` (
`card_set_id` INT,
`black_card_id` INT,
PRIMARY KEY (`card_set_id`, `black_card_id`)
) CHARACTER SET latin1;
CREATE TABLE `card_set_white_card` (
`card_set_id` INT,
`white_card_id` INT,
PRIMARY KEY (`card_set_id`, `white_card_id`)
) CHARACTER SET latin1;
CREATE TABLE `white_cards` (
`id` INT,
`text` VARCHAR(64),
`watermark` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_172350_cah_cards') AS relationships;
relationships
Database: db_172350_cah_cards

Table Connections:
------------------
[Implied]  card_set_black_card.black_card_id -> black_cards.id
[Implied]  card_set_black_card.card_set_id -> card_set.id
[Implied]  card_set_white_card.card_set_id -> card_set.id
[Implied]  card_set_white_card.white_card_id -> white_cards.id

DROP DATABASE `db_172350_cah_cards`;
UNINSTALL EXTENSION vsql_schematron;
