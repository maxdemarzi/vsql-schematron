INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 106571_schema
#
CREATE DATABASE `db_106571_schema`;
USE `db_106571_schema`;
CREATE TABLE `users` (
`uuid` INT,
`names` VARCHAR(64),
`surnames` VARCHAR(64),
`alias` VARCHAR(64),
`email` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ars_balances` (
`uuid` INT,
`balance` INT,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `usdt_balances` (
`uuid` INT,
`balance` INT,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `btc_balances` (
`uuid` INT,
`balance` INT,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` INT,
`uuid` INT,
`timestamp` INT,
`operation` INT,
`currency` INT,
`amount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_106571_schema') AS relationships;
