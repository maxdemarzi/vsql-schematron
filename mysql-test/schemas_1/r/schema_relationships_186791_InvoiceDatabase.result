CREATE DATABASE `db_186791_InvoiceDatabase`;
USE `db_186791_InvoiceDatabase`;
CREATE TABLE `billing` (
`purchase_id` INT,
`item_id` INT,
`invoice_id` INT,
`quantity` INT,
`price` INT
) CHARACTER SET latin1;
CREATE TABLE `clientinvoice` (
`invoice_id` INT,
`total` INT,
`paid` INT,
`due_pay` INT,
`client_Id` INT,
`created_By` VARCHAR(64),
`created_Date` DATETIME,
`clientName` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`address` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `clientmaster` (
`ClientID` INT,
`clientName` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`address` VARCHAR(64),
`created_Date` DATETIME,
`created_By` VARCHAR(64),
PRIMARY KEY (`ClientID`)
) CHARACTER SET latin1;
CREATE TABLE `itemmaster` (
`itemId` INT,
`itemName` VARCHAR(64),
`price` INT,
`img` VARCHAR(64),
`link` VARCHAR(64),
`created_By` VARCHAR(64),
`created_Date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `usermaster` (
`USERID` INT,
`userName` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`pass` VARCHAR(64),
`created_Date` DATETIME,
`created_By` VARCHAR(64),
PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
CREATE TABLE `video` (
`id` INT,
`path` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
