CREATE TABLE `notes` (
`id` INT NOT NULL,
`created_on` DATE,
`title` TEXT,
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hashtags` (
`id` INT NOT NULL,
`tag` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
`id` INT NOT NULL,
`notes_id` INT,
`tag_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
