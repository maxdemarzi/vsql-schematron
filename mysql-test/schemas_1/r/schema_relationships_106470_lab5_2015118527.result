CREATE DATABASE `db_106470_lab5_2015118527`;
USE `db_106470_lab5_2015118527`;
CREATE TABLE `EMPLOYEE` (
`Fname` VARCHAR(64),
`Minit` VARCHAR(64),
`Lname` VARCHAR(64),
`Ssn` VARCHAR(64),
`Bdate` DATETIME,
`Address` VARCHAR(64),
`Sex` VARCHAR(64),
`Salary` DECIMAL(10,2),
`Super_ssn` VARCHAR(64),
`Dno` DECIMAL(10,2),
PRIMARY KEY (`Ssn`)
) CHARACTER SET latin1;
CREATE TABLE `DEPARTMENT` (
`Dname` VARCHAR(64),
`Dnumber` DECIMAL(10,2),
`Mgr_ssn` VARCHAR(64),
`Mgr_start_date` DATETIME,
PRIMARY KEY (`Dnumber`)
) CHARACTER SET latin1;
CREATE TABLE `DEPT_LOCATIONS` (
`Dnumber` DECIMAL(10,2),
`Dlocation` VARCHAR(64),
PRIMARY KEY (`Dnumber`, `Dlocation`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT` (
`Pname` VARCHAR(64),
`Pnumber` DECIMAL(10,2),
`Plocation` VARCHAR(64),
`Dnum` DECIMAL(10,2),
PRIMARY KEY (`Pnumber`)
) CHARACTER SET latin1;
CREATE TABLE `DEPENDENT` (
`Essn` VARCHAR(64),
`Dependent_name` VARCHAR(64),
`Sex` VARCHAR(64),
`Bdate` DATETIME,
`Relationship` VARCHAR(64),
PRIMARY KEY (`Essn`, `Dependent_name`)
) CHARACTER SET latin1;
CREATE TABLE `WORKS_ON` (
`Essn` VARCHAR(64),
`Pno` DECIMAL(10,2),
`Hours` DECIMAL(10,2),
PRIMARY KEY (`Essn`, `Pno`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_106470_lab5_2015118527') AS relationships;
