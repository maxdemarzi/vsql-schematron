INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 191921_EmployeeManager-Schema
#
CREATE DATABASE `db_191921_EmployeeManager_Schema`;
USE `db_191921_EmployeeManager_Schema`;
CREATE TABLE `Departments` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_191921_EmployeeManager_Schema') AS relationships;
relationships
Database: db_191921_EmployeeManager_Schema

Table Connections:
------------------
[Implied]  Employees.manager_id -> Employees.id
[Implied]  Employees.role_id -> Roles.id
[Implied]  Roles.department_id -> Departments.id

DROP DATABASE `db_191921_EmployeeManager_Schema`;
