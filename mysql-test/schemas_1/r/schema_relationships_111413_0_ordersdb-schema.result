CREATE DATABASE `db_111413_0_ordersdb_schema`;
USE `db_111413_0_ordersdb_schema`;
CREATE TABLE `booking` (
`id` BIGINT NOT NULL,
`cancellation_code` VARCHAR(50),
`contact_email` VARCHAR(50),
`created_on` DATETIME,
`performance_id` BIGINT,
`performance_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ticket` (
`id` BIGINT NOT NULL,
`price` DOUBLE,
`number` INT,
`row_number` INT,
`section_id` BIGINT,
`ticket_category_id` BIGINT,
`booking_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `id_generator` (
`IDKEY` CHAR(50),
`IDVALUE` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_111413_0_ordersdb_schema') AS relationships;
