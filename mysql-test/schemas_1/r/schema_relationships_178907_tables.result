INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 178907_tables
#
CREATE DATABASE `db_178907_tables`;
USE `db_178907_tables`;
CREATE TABLE `USERS` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`ip` VARCHAR(50),
`last_login` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `MESSAGES` (
`id` INT NOT NULL,
`message` VARCHAR(50),
`from_handle` VARCHAR(50),
`post_date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `UNDELIVERED` (
`user_id` INT,
`message_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_178907_tables') AS relationships;
