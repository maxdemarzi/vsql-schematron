USE `db_175466_dankicode`;
CREATE TABLE `categoria` (
`id` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`nascimento` DATE,
`sexo` VARCHAR(50),
`peso` DECIMAL(10,2),
`altura` DECIMAL(10,2),
`nacionalidade` VARCHAR(50),
`hora` TIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT,
`idCategoria` VARCHAR(50),
`titulo` VARCHAR(50),
`texto` TEXT
) CHARACTER SET latin1;
