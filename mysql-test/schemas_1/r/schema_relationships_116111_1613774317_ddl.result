CREATE DATABASE `db_116111_1613774317_ddl`;
USE `db_116111_1613774317_ddl`;
CREATE TABLE `rol_roles` (
`rol_id` VARCHAR(64),
`rol_name` VARCHAR(64),
PRIMARY KEY (`rol_id`)
) CHARACTER SET latin1;
CREATE TABLE `usr_users` (
`usr_id` VARCHAR(64),
`rol_id` VARCHAR(64),
`usr_name` VARCHAR(64),
`usr_email` VARCHAR(64),
`usr_password` VARCHAR(64),
`usr_avatar_link` VARCHAR(64),
PRIMARY KEY (`usr_id`)
) CHARACTER SET latin1;
CREATE TABLE `adm_admins` (
`adm_id` VARCHAR(64),
PRIMARY KEY (`adm_id`)
) CHARACTER SET latin1;
CREATE TABLE `com_companies` (
`com_id` VARCHAR(64),
`com_cnpj` VARCHAR(64),
`com_name` VARCHAR(64),
PRIMARY KEY (`com_id`)
) CHARACTER SET latin1;
CREATE TABLE `fre_freelancers` (
`fre_id` VARCHAR(64),
`fre_bio` VARCHAR(64),
`fre_price_per_hour` DECIMAL(10,2),
PRIMARY KEY (`fre_id`)
) CHARACTER SET latin1;
CREATE TABLE `res_resumes` (
`res_id` VARCHAR(64),
`fre_id` VARCHAR(64),
`res_linkedin_link` VARCHAR(64),
`res_professional_experience` VARCHAR(64),
`res_academic_experience` VARCHAR(64),
`res_skills` VARCHAR(64),
PRIMARY KEY (`res_id`)
) CHARACTER SET latin1;
CREATE TABLE `job_jobs` (
`job_id` VARCHAR(64),
`com_id` VARCHAR(64),
`job_title` VARCHAR(64),
`job_description` VARCHAR(64),
`job_is_open` BOOL,
PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `jap_job_applications` (
`job_id` VARCHAR(64),
`fre_id` VARCHAR(64),
PRIMARY KEY (`job_id`, `fre_id`)
) CHARACTER SET latin1;
