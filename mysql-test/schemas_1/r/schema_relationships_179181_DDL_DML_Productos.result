INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 179181_DDL_DML_Productos
#
CREATE DATABASE `db_179181_DDL_DML_Productos`;
USE `db_179181_DDL_DML_Productos`;
CREATE TABLE `Empresa` (
`ID_Empresa` INT NOT NULL,
`Nombre` VARCHAR(50),
`NIT` VARCHAR(50),
`Fecha_Inicio` DATETIME,
`Antiguedad` INT,
PRIMARY KEY (`ID_Empresa`)
) CHARACTER SET latin1;
CREATE TABLE `Proveedor` (
`ID_Proveedor` INT NOT NULL,
`Nombre` VARCHAR(50),
`Direccion` VARCHAR(50),
`NIT` VARCHAR(50),
PRIMARY KEY (`ID_Proveedor`)
) CHARACTER SET latin1;
CREATE TABLE `Producto` (
`ID_Producto` INT NOT NULL,
`Nombre` VARCHAR(50),
`Codigo` VARCHAR(50),
`Precio_Unitario` INT,
`NIT` VARCHAR(50),
`Impuesto` DOUBLE,
`ID_Empresa` INT,
`ID_Proveedor` INT,
PRIMARY KEY (`ID_Producto`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_179181_DDL_DML_Productos') AS relationships;
relationships
Database: db_179181_DDL_DML_Productos

Table Connections:
------------------
[Implied]  Producto.ID_Empresa -> Empresa.ID_Empresa
[Implied]  Producto.ID_Proveedor -> Proveedor.ID_Proveedor

DROP DATABASE `db_179181_DDL_DML_Productos`;
