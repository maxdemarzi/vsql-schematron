INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 163925_schema
#
CREATE DATABASE `db_163925_schema`;
USE `db_163925_schema`;
CREATE TABLE `consumidor` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`telefone` TEXT,
`senha` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
`id` INT NOT NULL,
`consumidor_id` INT,
`restaurante_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `detalhepedido` (
`id` INT NOT NULL,
`pedido_id` INT,
`produto_id` INT,
`quantidade_produto` INT,
`valor_total_produto` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
`id` INT NOT NULL,
`consumidor_id` INT,
`endereco` TEXT,
`cep` TEXT,
`complemento` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_163925_schema') AS relationships;
