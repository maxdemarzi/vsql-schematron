) CHARACTER SET latin1;
CREATE TABLE `account` (
`accno` VARCHAR(50) NOT NULL,
`ssn` INT,
`code` VARCHAR(50),
`balance` INT,
PRIMARY KEY (`accno`)
) CHARACTER SET latin1;
