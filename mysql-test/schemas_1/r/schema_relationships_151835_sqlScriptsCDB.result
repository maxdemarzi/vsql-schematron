CREATE DATABASE `db_151835_sqlScriptsCDB`;
USE `db_151835_sqlScriptsCDB`;
CREATE TABLE `DRUGS` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`PRICE` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PATIENTS` (
`ID` DECIMAL(10,2),
`DOB` DATETIME,
`EMAIL` VARCHAR(64),
`GENDER` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`PHONE` VARCHAR(64),
`SSN` VARCHAR(64),
`STATUS` VARCHAR(64),
`USERNAME` VARCHAR(64),
`VERSION` DECIMAL(10,2),
`CITY` VARCHAR(64),
`COUNTRY` VARCHAR(64),
`STATE` VARCHAR(64),
`STREET1` VARCHAR(64),
`STREET2` VARCHAR(64),
`ZIP` VARCHAR(64),
`FIRSTNAME` VARCHAR(64),
`LASTNAME` VARCHAR(64),
`MIDDLENAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHYSICIANS` (
`ID` DECIMAL(10,2),
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`PHONE` VARCHAR(64),
`USERNAME` VARCHAR(64),
`VERSION` DECIMAL(10,2),
`FIRSTNAME` VARCHAR(64),
`LASTNAME` VARCHAR(64),
`MIDDLENAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RECORDS` (
`ID` DECIMAL(10,2),
`CREATE_DATE` DATETIME,
`DIAGNOSIS` VARCHAR(64),
`NOTES` VARCHAR(64),
`SYMPTOMS` VARCHAR(64),
`VERSION` DECIMAL(10,2),
`DIASTOLIC_BLOOD_PRESSURE` DECIMAL(10,2),
`HEIGHT` DECIMAL(10,2),
`PULSE` DECIMAL(10,2),
`SYSTOLIC_BLOOD_PRESSURE` DECIMAL(10,2),
`TEMPERATURE` DECIMAL(10,2),
`WEIGHT` DECIMAL(10,2),
`PATIENT_ID` DECIMAL(10,2),
`PHYSICIAN_ID` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PATIENTS_RECORDS` (
`PATIENT_ID` DECIMAL(10,2),
`RECORDS_ID` DECIMAL(10,2),
PRIMARY KEY (`PATIENT_ID`, `RECORDS_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRESCRIPTIONS` (
`ID` DECIMAL(10,2),
`DATE_PRESCRIBED` DATETIME,
`DOSAGE` DECIMAL(10,2),
`FREQUENCY` VARCHAR(64),
`INSTRUCTIONS` VARCHAR(64),
`REFILLS_REMAINING` DECIMAL(10,2),
`VERSION` DECIMAL(10,2),
`DRUG_ID` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `RECORDS_PRESCRIPTIONS` (
`RECORD_ID` DECIMAL(10,2),
`PRESCRIPTIONS_ID` DECIMAL(10,2),
PRIMARY KEY (`RECORD_ID`, `PRESCRIPTIONS_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SEQUENCE` (
`SEQ_NAME` VARCHAR(64),
`SEQ_COUNT` DECIMAL(10,2),
PRIMARY KEY (`SEQ_NAME`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_151835_sqlScriptsCDB') AS relationships;
