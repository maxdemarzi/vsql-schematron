CREATE DATABASE `db_185122_backup`;
USE `db_185122_backup`;
CREATE TABLE `master_users` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`birthday` VARCHAR(64),
`full_name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_auths` (
`user_id` INT,
`password` VARCHAR(64),
`device_id` VARCHAR(64),
`last_login` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_diaries` (
`id` INT,
`user_id` INT,
`title` VARCHAR(64),
`body_text` VARCHAR(64),
`date_post` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_185122_backup') AS relationships;
