CREATE DATABASE `db_190385_hospital`;
USE `db_190385_hospital`;
CREATE TABLE `doctors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`specialisation` VARCHAR(50),
`phone` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
`id` INT,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`id_doctor` INT,
`notes` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_190385_hospital') AS relationships;
