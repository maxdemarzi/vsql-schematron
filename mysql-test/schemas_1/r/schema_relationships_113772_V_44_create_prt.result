`parent_node_oid` INT,
`depth` INT,
`tree_left` INT,
`tree_right` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `prt_position` (
`node_id` INT,
`key_scheme` VARCHAR(64),
`key_value` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `prt_portfolio_attribute` (
`id` INT,
`portfolio_id` INT,
`portfolio_oid` INT,
`key` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
