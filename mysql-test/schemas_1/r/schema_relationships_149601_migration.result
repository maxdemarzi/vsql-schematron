INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 149601_migration
#
CREATE DATABASE `db_149601_migration`;
USE `db_149601_migration`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`avatarUrl` TEXT,
`username` TEXT,
`password` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gists` (
`id` VARCHAR(50) NOT NULL,
`description` TEXT,
`isPrivate` BOOLEAN,
`authorId` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gist_files` (
`id` VARCHAR(50) NOT NULL,
`gistId` TEXT,
`filename` TEXT,
`snippet` TEXT,
`language` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` VARCHAR(50) NOT NULL,
`comment` TEXT,
`userId` TEXT,
`gistId` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_149601_migration') AS relationships;
