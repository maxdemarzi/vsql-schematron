CREATE DATABASE `db_105677_initial`;
USE `db_105677_initial`;
CREATE TABLE `forum` (
`id` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`name` TEXT
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT,
`data` TEXT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT,
`data` TEXT,
`user_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_105677_initial') AS relationships;
