INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 154301_schema
#
CREATE DATABASE `db_154301_schema`;
USE `db_154301_schema`;
CREATE TABLE `books` (
`id` INT,
`title` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`nickname` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
`id` INT,
`name` VARCHAR(64),
`url` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_authors` (
`book_id` INT,
`author_id` INT
) CHARACTER SET latin1;
CREATE TABLE `episodes` (
`id` INT,
`title` VARCHAR(64),
`book_id` INT,
`indexnum` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_154301_schema') AS relationships;
relationships
Database: db_154301_schema

Table Connections:
