INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 165189_database
#
CREATE DATABASE `db_165189_database`;
USE `db_165189_database`;
CREATE TABLE `user_info` (
`username` VARCHAR(64),
`name` VARCHAR(64),
`surname` VARCHAR(64),
`date_of_birth` DATETIME,
`receive_newsletter` INT,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `user_login_history` (
`username` VARCHAR(64),
`date_time` DATETIME,
`ip_address` VARCHAR(64),
PRIMARY KEY (`username`, `date_time`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`username` VARCHAR(64),
`password` VARCHAR(64),
`enabled` INT,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_165189_database') AS relationships;
