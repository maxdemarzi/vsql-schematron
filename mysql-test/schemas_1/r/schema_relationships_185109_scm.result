[Implied]  participacao.idpes -> pessoa.idpes
[Implied]  participacao.idpes -> piloto.idpes
[Implied]  pessoa.idequ -> equipe.idequ

DROP DATABASE `db_185109_scm`;
UNINSTALL EXTENSION vsql_schematron;
