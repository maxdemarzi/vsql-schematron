INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 112143_schema
#
CREATE DATABASE `db_112143_schema`;
USE `db_112143_schema`;
CREATE TABLE `Food` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Location` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `User_device` (
`ID` INT,
`name` VARCHAR(64),
`belongs_to` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Food_item` (
`ID` INT,
`eat_by` DATETIME,
`of_type` INT,
`stored_in` INT,
`registers` INT,
`buys` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Ticket` (
`ID` INT,
`ticket` VARCHAR(64),
`belongs_device` INT,
`created_on` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Updates` (
`ID` INT,
`table_name` VARCHAR(64),
`last_update` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EAN_number` (
`ID` INT,
`number` VARCHAR(64),
`identifies` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_112143_schema') AS relationships;
relationships
Database: db_112143_schema

Table Connections:
------------------
[Implied]  Ticket.belongs_device -> User_device.ID
[Implied]  User_device.ID -> User.ID
[Implied]  User_device.belongs_to -> User_device.ID

DROP DATABASE `db_112143_schema`;
UNINSTALL EXTENSION vsql_schematron;
