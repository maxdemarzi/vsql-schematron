INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 178346_mysql_sample_model
#
CREATE DATABASE `db_178346_mysql_sample_model`;
USE `db_178346_mysql_sample_model`;
CREATE TABLE `customer` (
`Id` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`City` VARCHAR(64),
`Country` VARCHAR(64),
`Phone` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
`Id` INT,
`OrderDate` DATETIME,
`OrderNumber` VARCHAR(64),
`CustomerId` INT,
`TotalAmount` DECIMAL(10,2),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
`Id` INT,
`OrderId` INT,
`ProductId` INT,
`UnitPrice` DECIMAL(10,2),
`Quantity` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`Id` INT,
`ProductName` VARCHAR(64),
`SupplierId` INT,
`UnitPrice` DECIMAL(10,2),
`Package` VARCHAR(64),
`IsDiscontinued` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `supplier` (
`Id` INT,
`CompanyName` VARCHAR(64),
`ContactName` VARCHAR(64),
`ContactTitle` VARCHAR(64),
`City` VARCHAR(64),
`Country` VARCHAR(64),
`Phone` VARCHAR(64),
`Fax` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_178346_mysql_sample_model') AS relationships;
relationships
Database: db_178346_mysql_sample_model

Table Connections:
------------------
[Implied]  order.CustomerId -> customer.Id
[Implied]  order_item.OrderId -> order.Id
[Implied]  order_item.ProductId -> product.Id
[Implied]  product.SupplierId -> supplier.Id

DROP DATABASE `db_178346_mysql_sample_model`;
UNINSTALL EXTENSION vsql_schematron;
