INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 114457_1
#
CREATE DATABASE `db_114457_1`;
USE `db_114457_1`;
CREATE TABLE `authorizations` (
`authorization_key` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`authorization_key`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT,
`licence_plate` VARCHAR(64),
`convertible` VARCHAR(64),
`rating` INT,
`engine_type` VARCHAR(64),
`colour` VARCHAR(64),
`model` VARCHAR(64),
`seat_count` INT,
`speed_limit` VARCHAR(64),
`manufacturer_id` VARCHAR(64),
`driver_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `drivers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`contact_number` VARCHAR(64),
`gender` VARCHAR(64),
`age` INT,
`online_status` VARCHAR(64),
`deleted` VARCHAR(64),
`date_created` DATETIME,
`date_modified` DATETIME,
`car_assigned_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `manufacturers` (
`id` VARCHAR(64),
`location` VARCHAR(64),
`date_established` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_114457_1') AS relationships;
relationships
Database: db_114457_1

Table Connections:
