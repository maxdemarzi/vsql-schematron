INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 138258_back_schema_sqlite
#
CREATE DATABASE `db_138258_back_schema_sqlite`;
USE `db_138258_back_schema_sqlite`;
CREATE TABLE `notes` (
`id` INT NOT NULL,
`created` TIMESTAMP NULL,
`updated` TIMESTAMP NULL,
`note_title` VARCHAR(50),
`note` TEXT,
`note_markdown` TEXT,
`tags` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`registered_at` TIMESTAMP NULL,
`last_login` TIMESTAMP NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT NOT NULL,
`tag` TEXT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_138258_back_schema_sqlite') AS relationships;
