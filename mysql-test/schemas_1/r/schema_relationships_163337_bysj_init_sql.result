`TEACHENVIRONMENT` VARCHAR(64),
`TEACHOUTLINE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `t_courseclass` (
`id` INT,
