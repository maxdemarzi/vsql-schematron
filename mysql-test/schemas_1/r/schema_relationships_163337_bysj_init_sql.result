CREATE DATABASE `db_163337_bysj_init_sql`;
USE `db_163337_bysj_init_sql`;
CREATE TABLE `t_attach` (
`ID` INT,
`FILETYPE` VARCHAR(64),
`CREATETIME` DATETIME,
`FILEPATH` VARCHAR(64),
`FILENAME` VARCHAR(64),
`downloadCount` INT,
`fileImages` VARCHAR(64),
`fromName` VARCHAR(64),
`FROMID` INT,
`FROMSUBID` INT,
`CREATEUSER` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `t_bbsblock` (
`ID` INT,
`NAME` VARCHAR(64),
`BLOCKRULES` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`PARENT` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `t_bbscontent` (
