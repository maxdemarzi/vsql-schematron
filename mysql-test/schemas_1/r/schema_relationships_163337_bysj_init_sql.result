`ATTACHIDS` VARCHAR(64),
`CREATEUSER` INT,
`BBSBLOCK` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `t_bbscontentcomments` (
`ID` INT,
`CONTENT` VARCHAR(64),
`CREATETIME` DATETIME,
`MODIFYTIME` DATETIME,
`ACCESS` BOOL,
`BBSCONTENT` INT,
`CREATEUSER` INT,
`BBSBLOCK` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `t_classdetail` (
`ID` INT,
