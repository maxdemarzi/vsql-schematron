CREATE TABLE `public.author` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.book` (
`id` INT,
