CREATE DATABASE `db_185892_taskme`;
USE `db_185892_taskme`;
CREATE TABLE `tasks` (
`idTask` INT,
`user` INT,
`what` VARCHAR(50),
`status` VARCHAR(50),
`time_creation` TIME,
`time_start` TIME,
`time_done` TIME,
`repeating` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`idUser` INT NOT NULL,
`fname` VARCHAR(50),
`name` VARCHAR(50),
`isAdmin` TINYINT,
PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
