INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 142217_plsqlobj
#
CREATE DATABASE `db_142217_plsqlobj`;
USE `db_142217_plsqlobj`;
CREATE TABLE `s_customer` (
`customer_id` DECIMAL(10,2),
`customer_name` VARCHAR(64),
`phone` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`country` VARCHAR(64),
`zip_code` VARCHAR(64),
`credit_rating` VARCHAR(64),
`sales_rep_id` DECIMAL(10,2),
`region_id` DECIMAL(10,2),
`comments` VARCHAR(64),
`preferred_customer` VARCHAR(64),
`shipping_method` VARCHAR(64),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_department` (
`department_id` DECIMAL(10,2),
`department_name` VARCHAR(64),
`region_id` DECIMAL(10,2),
PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_employee` (
`employee_id` DECIMAL(10,2),
`employee_last_name` VARCHAR(64),
`employee_first_name` VARCHAR(64),
`userid` VARCHAR(64),
`start_date` DATETIME,
`comments` VARCHAR(64),
`manager_id` DECIMAL(10,2),
`title` VARCHAR(64),
`department_id` DECIMAL(10,2),
`salary` DECIMAL(10,2),
`commission_pct` DECIMAL(10,2),
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_inventory` (
`product_id` DECIMAL(10,2),
`warehouse_id` DECIMAL(10,2),
`amount_in_stock` DECIMAL(10,2),
`reorder_point` DECIMAL(10,2),
`max_in_stock` DECIMAL(10,2),
`out_of_stock_explanation` VARCHAR(64),
`restock_date` DATETIME,
PRIMARY KEY (`product_id`, `warehouse_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_item` (
`order_id` DECIMAL(10,2),
`item_id` DECIMAL(10,2),
`product_id` DECIMAL(10,2),
`price` DECIMAL(10,2),
`quantity` DECIMAL(10,2),
`quantity_shipped` DECIMAL(10,2),
PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_longtext` (
`longtext_id` DECIMAL(10,2),
`use_filename` VARCHAR(64),
`filename` VARCHAR(64),
`text` VARCHAR(64),
PRIMARY KEY (`longtext_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_order` (
`order_id` DECIMAL(10,2),
`customer_id` DECIMAL(10,2),
`date_ordered` DATETIME,
`date_shipped` DATETIME,
`sales_rep_id` DECIMAL(10,2),
`total` DECIMAL(10,2),
`payment_type` VARCHAR(64),
`order_filled` VARCHAR(64),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_product` (
`product_id` DECIMAL(10,2),
`product_name` VARCHAR(64),
`short_desc` VARCHAR(64),
`longtext_id` DECIMAL(10,2),
`image_id` DECIMAL(10,2),
`suggested_wholesale_price` DECIMAL(10,2),
`wholesale_units` VARCHAR(64),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_region` (
`region_id` DECIMAL(10,2),
`region_name` VARCHAR(64),
PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `s_title` (
`title` VARCHAR(64),
PRIMARY KEY (`title`)
) CHARACTER SET latin1;
CREATE TABLE `s_warehouse` (
`warehouse_id` DECIMAL(10,2),
`region_id` DECIMAL(10,2),
`phone` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`country` VARCHAR(64),
`zip_code` VARCHAR(64),
`manager_id` DECIMAL(10,2),
PRIMARY KEY (`warehouse_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_142217_plsqlobj') AS relationships;
relationships
