CREATE TABLE `mydb.teacher` (
`teacher_id` INT,
`type` INT,
`title` VARCHAR(64),
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`ability` VARCHAR(64),
`adviser` INT,
`committee` INT,
PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.lockbook` (
`lock_id` INT,
`type` VARCHAR(64),
PRIMARY KEY (`lock_id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.student` (
`student_id` INT,
`title` VARCHAR(64),
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`lockbook_lock_id` INT,
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.request` (
`request_id` INT,
`req_1` INT,
`req_2` VARCHAR(64),
`req_3` INT,
`req_4` INT,
PRIMARY KEY (`request_id`)
) CHARACTER SET latin1;
