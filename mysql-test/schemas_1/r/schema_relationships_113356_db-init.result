INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 113356_db-init
#
CREATE DATABASE `db_113356_db_init`;
USE `db_113356_db_init`;
CREATE TABLE `role` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password_hash` VARCHAR(50),
`email` VARCHAR(50),
`access_granted` BOOLEAN,
`role_id` INT,
`last_seen` TIMESTAMP NULL,
`creation_date` TIMESTAMP NULL,
`failed_login_attempts` INT,
`pass_change_req` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`details` VARCHAR(50),
`time_creation` TIMESTAMP NULL,
`all_day_event` BOOLEAN,
`time_event_start` TIMESTAMP NULL,
`time_event_stop` TIMESTAMP NULL,
`to_notify` BOOLEAN,
`time_notify` TIMESTAMP NULL,
`author_uid` INT,
`notification_sent` BOOLEAN,
`is_active` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `log` (
`id` INT NOT NULL,
`log_name` VARCHAR(50),
`level` VARCHAR(50),
`msg` VARCHAR(50),
`time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notification` (
`id` INT NOT NULL,
`notify_unit` VARCHAR(50),
`notify_interval` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_to_event` (
`user_id` INT,
`event_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_113356_db_init') AS relationships;
relationships
Database: db_113356_db_init

Table Connections:
------------------
[Implied]  event.author_uid -> user.id
[Implied]  user.role_id -> role.id
[Implied]  user_to_event.event_id -> event.id
[Implied]  user_to_event.user_id -> user.id

DROP DATABASE `db_113356_db_init`;
UNINSTALL EXTENSION vsql_schematron;
