#
# Test relationships for schema 144559_05.Project_Management_DB
#
CREATE DATABASE `db_144559_05_Project_Management_DB`;
USE `db_144559_05_Project_Management_DB`;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT,
`client_id` INT,
`project_lead_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
`id` INT,
`client_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_144559_05_Project_Management_DB') AS relationships;
