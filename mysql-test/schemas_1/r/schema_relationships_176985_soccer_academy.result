CREATE TABLE `team_has_leagues` (
`team_id` INT,
`league_id` INT
) CHARACTER SET latin1;
CREATE TABLE `team_has_tournaments` (
`team_id` INT,
`tournament_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tournaments` (
`id` INT,
`name` VARCHAR(255),
`date` DATETIME,
`location` VARCHAR(255),
`image_path` VARCHAR(255),
`status` VARCHAR(255),
`results` VARCHAR(255),
`extras` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
