CREATE DATABASE `db_176985_soccer_academy`;
USE `db_176985_soccer_academy`;
CREATE TABLE `achievements` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
`image_path` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `coaches` (
`id` INT,
`name` VARCHAR(255),
`image_path` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `galleries` (
`id` INT,
`name` VARCHAR(255),
`image_path` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genders` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `leagues` (
`id` INT,
`name` VARCHAR(255),
`date` DATETIME,
`location` VARCHAR(255),
`image_path` VARCHAR(255),
`status` VARCHAR(255),
`results` VARCHAR(255),
`extras` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `managers` (
`id` INT,
`name` VARCHAR(255),
`image_path` VARCHAR(255),
`phone_number` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `matches` (
`id` INT,
`participant` VARCHAR(255),
`date` DATETIME,
`time` VARCHAR(255),
`tournament_id` INT,
`extras` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`id` INT,
`name` VARCHAR(255),
`nisn` INT,
`birth_date` DATETIME,
`birth_place` VARCHAR(255),
`class_type` VARCHAR(255),
`gender_id` INT,
`religion` VARCHAR(255),
`address` VARCHAR(255),
`height` VARCHAR(255),
`weight` VARCHAR(255),
`phone_number` VARCHAR(255),
`image_path` VARCHAR(255),
`position` VARCHAR(255),
`reason` VARCHAR(255),
`notes` VARCHAR(255),
`status` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
`date` DATETIME,
`images` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedules` (
`id` INT,
`team_id1` INT,
`score_team_id1` INT,
`score_team_id2` INT,
`team_id2` INT,
`date` DATETIME,
`time` DATETIME,
`location` VARCHAR(255),
`league_id` INT,
`extras` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scores` (
`id` INT,
`matches_id` INT,
`teams_id` INT,
`value` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `structures` (
`id` INT,
`name` VARCHAR(255),
`position` VARCHAR(255),
`image_path` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`id` INT,
`name` VARCHAR(255),
`address` VARCHAR(255),
`manager_id` VARCHAR(255),
`coach_id` VARCHAR(255),
`licenses` VARCHAR(255),
`email` VARCHAR(255),
`telp` VARCHAR(255),
`photo` VARCHAR(255),
`registration_number` VARCHAR(255),
`status` VARCHAR(255),
`type` VARCHAR(255),
