`VERSION` DATETIME,
`GRADE_ID` DECIMAL(10,2),
`XDMAJ` DATETIME,
`XTOPSUP` DECIMAL(10,2),
PRIMARY KEY (`PERSONNE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `AW_COMPETENCE_ID` (
