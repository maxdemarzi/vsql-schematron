INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 178003_schema
#
CREATE DATABASE `db_178003_schema`;
USE `db_178003_schema`;
CREATE TABLE `users_roles` (
`user_id` BIGINT,
`role_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` BIGINT NOT NULL,
`role` VARCHAR(50),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `spring_users` (
`user_id` BIGINT NOT NULL,
`login` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`active` BOOLEAN,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_178003_schema') AS relationships;
