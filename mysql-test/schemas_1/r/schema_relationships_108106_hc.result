INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 108106_hc
#
CREATE DATABASE `db_108106_hc`;
USE `db_108106_hc`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(255),
`is_admin` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `headcounts` (
`id` INT,
`user_id` INT,
`submit_time` DATETIME,
`entered_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room_data` (
`id` INT,
`room` VARCHAR(255),
`people_count` INT,
`count_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_108106_hc') AS relationships;
