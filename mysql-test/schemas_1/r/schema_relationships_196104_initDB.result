INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 196104_initDB
#
CREATE DATABASE `db_196104_initDB`;
USE `db_196104_initDB`;
CREATE TABLE `Hero` (
`idHero` VARCHAR(50) NOT NULL,
`firstName` VARCHAR(50),
`rankLvl` VARCHAR(50),
`skillPoint` VARCHAR(50),
`health` VARCHAR(50),
`attack` VARCHAR(50),
`defense` VARCHAR(50),
`magik` VARCHAR(50),
`idUser` VARCHAR(50),
PRIMARY KEY (`idHero`)
) CHARACTER SET latin1;
CREATE TABLE `Fight` (
`idFight` VARCHAR(50) NOT NULL,
`idHero` CHAR(50),
`opponentName` VARCHAR(50),
`result` SMALLINT,
`dateFight` DATETIME,
PRIMARY KEY (`idFight`)
) CHARACTER SET latin1;
CREATE TABLE `Turn` (
`idTurn` VARCHAR(50) NOT NULL,
`turnNumber` VARCHAR(50),
`attackHeroA` VARCHAR(50),
`loosedHealthHeroB` VARCHAR(50),
`attackHeroB` VARCHAR(50),
`loosedHealthHeroA` VARCHAR(50),
`idFight` CHAR(50),
PRIMARY KEY (`idTurn`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_196104_initDB') AS relationships;
relationships
Database: db_196104_initDB

Table Connections:
