CREATE DATABASE `db_171667_migration`;
USE `db_171667_migration`;
CREATE TABLE `Cars` (
`plate` VARCHAR(64),
`brand` VARCHAR(64),
`model` VARCHAR(64),
`colour` VARCHAR(64),
`fuel` VARCHAR(64),
`transmission` VARCHAR(64),
`pricePerDay` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`plate`)
) CHARACTER SET latin1;
CREATE TABLE `CarsDetails` (
`id` VARCHAR(64),
`carId` VARCHAR(64),
`maxSpeed` INT,
`topSeed` INT,
`hp` INT,
`people` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_171667_migration') AS relationships;
