# Enable schema cache worker
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log

# Wait for the schema cache to be populated
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('austin_waste') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}

# Retrieve schema relationships
SELECT vsql_schema_relationships('austin_waste') AS schema_relationships;

# Retrieve data relationships
SELECT vsql_data_relationships('austin_waste') AS data_relationships;

--echo #
--echo # Cleanup
--echo #

UNINSTALL EXTENSION vsql_schematron;
DROP DATABASE austin_waste;
