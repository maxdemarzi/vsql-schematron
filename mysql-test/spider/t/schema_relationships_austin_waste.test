# Install extension
INSTALL EXTENSION vsql_schematron;

--echo #
--echo # Test relationships auto-detection for database: austin_waste
--echo #

CREATE DATABASE austin_waste;
USE austin_waste;

# Setup tables
CREATE TABLE `WASTE_AND_DIVERSION` (
  `load_id` BIGINT PRIMARY KEY,
  `report_date` DATE,
  `load_type` VARCHAR(255),
  `load_time` BIGINT,
  `load_weight` DOUBLE,
  `dropoff_site` TEXT,
  `route_type` VARCHAR(255),
  `route_number` TEXT
);

