# Install extension
INSTALL EXTENSION vsql_schematron;

--echo #
--echo # Test relationships auto-detection for database: austin_crime
--echo #

CREATE DATABASE austin_crime;
USE austin_crime;

# Setup tables
CREATE TABLE `CRIME` (
  `unique_key` BIGINT PRIMARY KEY,
  `address` TEXT,
  `census_tract` DOUBLE,
  `clearance_date` BIGINT,
  `clearance_status` VARCHAR(255),
  `council_district_code` BIGINT,
  `description` TEXT,
  `district` TEXT,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  `location` TEXT,
  `location_description` TEXT,
  `primary_type` VARCHAR(255),
  `timestamp` BIGINT,
  `x_coordinate` BIGINT,
  `y_coordinate` BIGINT,
  `year` BIGINT,
  `zipcode` VARCHAR(255)
);

