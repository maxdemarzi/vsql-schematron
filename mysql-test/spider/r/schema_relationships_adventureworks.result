INSTALL EXTENSION vsql_schematron;
#
# Test relationships auto-detection for database: adventureworks
#
CREATE DATABASE adventureworks;
USE adventureworks;
CREATE TABLE `COUNTRYREGIONCURRENCY` (
`countryregioncode` VARCHAR(255) PRIMARY KEY,
`currencycode` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `SALESORDERDETAIL` (
`salesorderid` BIGINT,
`salesorderdetailid` BIGINT PRIMARY KEY,
`carriertrackingnumber` TEXT,
`orderqty` BIGINT,
`productid` BIGINT,
`specialofferid` BIGINT,
`unitprice` DOUBLE,
`unitpricediscount` DOUBLE,
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `CURRENCYRATE` (
`currencyrateid` BIGINT PRIMARY KEY,
`currencyratedate` VARCHAR(255),
`fromcurrencycode` VARCHAR(255),
`tocurrencycode` VARCHAR(255),
`averagerate` DOUBLE,
`endofdayrate` DOUBLE,
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCTREVIEW` (
`productreviewid` BIGINT PRIMARY KEY,
`productid` BIGINT,
`reviewername` VARCHAR(255),
`reviewdate` VARCHAR(255),
`emailaddress` VARCHAR(255),
`rating` BIGINT,
`comments` TEXT,
`modifeddate` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `SALESTERRITORY` (
`territoryid` BIGINT PRIMARY KEY,
`name` VARCHAR(255),
`countryregioncode` VARCHAR(255),
`group` TEXT,
`salesytd` DOUBLE,
`saleslastyear` DOUBLE,
`costytd` DOUBLE,
`costlastyear` DOUBLE,
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCTCATEGORY` (
`productcategoryid` BIGINT PRIMARY KEY,
`name` VARCHAR(255),
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `SALESORDERHEADER` (
`salesorderid` BIGINT PRIMARY KEY,
`revisionnumber` BIGINT,
`orderdate` VARCHAR(255),
`duedate` VARCHAR(255),
`shipdate` VARCHAR(255),
`STATUS` VARCHAR(255),
`onlineorderflag` TEXT,
`purchaseordernumber` TEXT,
`accountnumber` TEXT,
`customerid` BIGINT,
`salespersonid` VARCHAR(255),
`territoryid` BIGINT,
`billtoaddressid` BIGINT,
`shiptoaddressid` BIGINT,
`shipmethodid` BIGINT,
`creditcardid` VARCHAR(255),
`creditcardapprovalcode` VARCHAR(255),
`currencyrateid` VARCHAR(255),
`subtotal` DOUBLE,
`taxamt` DOUBLE,
`freight` DOUBLE,
`totaldue` DOUBLE,
`comment` TEXT,
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCT` (
`productid` BIGINT PRIMARY KEY,
`NAME` VARCHAR(255),
`productnumber` TEXT,
`makeflag` TEXT,
`finishedgoodsflag` TEXT,
`color` TEXT,
`safetystocklevel` BIGINT,
`reorderpoint` BIGINT,
`standardcost` DOUBLE,
`listprice` DOUBLE,
`size` TEXT,
`sizeunitmeasurecode` VARCHAR(255),
`weightunitmeasurecode` VARCHAR(255),
`weight` TEXT,
`daystomanufacture` BIGINT,
`productline` TEXT,
`class` TEXT,
`style` TEXT,
`productsubcategoryid` VARCHAR(255),
`productmodelid` VARCHAR(255),
`sellstartdate` VARCHAR(255),
`sellenddate` VARCHAR(255),
`discontinueddate` VARCHAR(255),
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCTDESCRIPTION` (
`productdescriptionid` BIGINT PRIMARY KEY,
`description` TEXT,
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCTMODELPRODUCTDESCRIPTIONCULTURE` (
`productmodelid` BIGINT,
`productdescriptionid` BIGINT PRIMARY KEY,
`cultureid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `PRODUCTSUBCATEGORY` (
`productsubcategoryid` BIGINT PRIMARY KEY,
`productcategoryid` BIGINT,
`name` VARCHAR(255),
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
CREATE TABLE `SALESPERSONQUOTAHISTORY` (
`BusinessEntityID` BIGINT,
`QuotaDate` VARCHAR(255),
`SalesQuota` DOUBLE,
`rowguid` VARCHAR(255) PRIMARY KEY,
`ModifiedDate` VARCHAR(255)
);
CREATE TABLE `SALESPERSON` (
`businessentityid` BIGINT PRIMARY KEY,
`territoryid` VARCHAR(255),
`salesquota` TEXT,
`bonus` BIGINT,
`commissionpct` DOUBLE,
`salesytd` DOUBLE,
`saleslastyear` DOUBLE,
`rowguid` VARCHAR(255),
`modifieddate` VARCHAR(255)
);
