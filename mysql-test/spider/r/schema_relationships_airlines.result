INSTALL EXTENSION vsql_schematron;
#
# Test relationships auto-detection for database: airlines
#
CREATE DATABASE airlines;
USE airlines;
CREATE TABLE `FLIGHTS` (
`flight_id` BIGINT PRIMARY KEY,
`flight_no` VARCHAR(255),
`scheduled_departure` TEXT,
`scheduled_arrival` TEXT,
`departure_airport` TEXT,
`arrival_airport` TEXT,
`status` VARCHAR(255),
`aircraft_code` VARCHAR(255),
`actual_departure` TEXT,
`actual_arrival` TEXT
);
CREATE TABLE `SEATS` (
`aircraft_code` VARCHAR(255),
`seat_no` VARCHAR(255) PRIMARY KEY,
`fare_conditions` TEXT
);
CREATE TABLE `TICKETS` (
`ticket_no` VARCHAR(255),
`book_ref` VARCHAR(255),
`passenger_id` VARCHAR(255) PRIMARY KEY
);
CREATE TABLE `BOOKINGS` (
`book_ref` VARCHAR(255) PRIMARY KEY,
`book_date` VARCHAR(255),
`total_amount` BIGINT
);
CREATE TABLE `AIRCRAFTS_DATA` (
`aircraft_code` VARCHAR(255) PRIMARY KEY,
`model` TEXT,
`range` BIGINT
);
CREATE TABLE `AIRPORTS_DATA` (
`airport_code` VARCHAR(255) PRIMARY KEY,
`airport_name` VARCHAR(255),
`city` TEXT,
`coordinates` TEXT,
`timezone` VARCHAR(255)
);
CREATE TABLE `BOARDING_PASSES` (
`ticket_no` VARCHAR(255) PRIMARY KEY,
`flight_id` BIGINT,
`boarding_no` BIGINT,
`seat_no` VARCHAR(255)
);
CREATE TABLE `TICKET_FLIGHTS` (
`ticket_no` VARCHAR(255) PRIMARY KEY,
`flight_id` BIGINT,
`fare_conditions` TEXT,
`amount` BIGINT
);
