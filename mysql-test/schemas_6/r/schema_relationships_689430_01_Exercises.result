INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 689430_01_Exercises
#
CREATE DATABASE `db_689430_01_Exercises`;
USE `db_689430_01_Exercises`;
CREATE TABLE `towns` (
`town_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`town_id`)
) CHARACTER SET latin1;
CREATE TABLE `directors` (
`id` INT,
`director_name` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`id` INT,
`genre_name` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`category` VARCHAR(64),
`daily_rate` DECIMAL(10,2),
`weekly_rate` DECIMAL(10,2),
`monthly_rate` DECIMAL(10,2),
`weekend_rate` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT,
`plate_number` VARCHAR(64),
`make` VARCHAR(64),
`model` VARCHAR(64),
`car_year` VARCHAR(64),
`category_id` INT,
`doors` INT,
`picture` VARCHAR(64),
`car_condition` VARCHAR(64),
`available` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`job_title` VARCHAR(64),
`department_id` INT,
`hire_date` DATETIME,
`salary` DECIMAL(10,2),
`address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT,
`driver_licence_number` INT,
`full_name` VARCHAR(64),
`address` VARCHAR(64),
`city` VARCHAR(64),
`zip_code` INT,
`notes` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`id` INT,
`address_text` VARCHAR(64),
`town_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_689430_01_Exercises') AS relationships;
relationships
Database: db_689430_01_Exercises

Table Connections:
