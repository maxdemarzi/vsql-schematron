INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 632553_sentences
#
CREATE DATABASE `db_632553_sentences`;
USE `db_632553_sentences`;
CREATE TABLE `categories` (
`category_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`product_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`unit` VARCHAR(50),
`content` VARCHAR(50),
`category_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `costumers` (
`costumer_id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`surnames` VARCHAR(50),
`email` VARCHAR(50),
`pass` VARCHAR(50),
`phone` VARCHAR(50),
`address` VARCHAR(50),
`birthdate` DATE,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`costumer_id`)
) CHARACTER SET latin1;
CREATE TABLE `product_by_purchase` (
`purchase_id` VARCHAR(50),
`product_id` VARCHAR(50),
`amount` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_632553_sentences') AS relationships;
relationships
Database: db_632553_sentences

