CREATE DATABASE `db_636158_migration`;
USE `db_636158_migration`;
CREATE TABLE `BloodPressure` (
`id` INT NOT NULL,
`diastolic` INT,
`systolic` INT,
`vitalID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WaterIntake` (
`id` INT NOT NULL,
`measurement` VARCHAR(50),
`intake` INT,
`vitalID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` INT NOT NULL,
`password` TEXT,
`email` TEXT,
`firstName` TEXT,
`lastName` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Vital` (
`id` INT NOT NULL,
`notes` TEXT,
`pulse` INT,
`bodyTemperature` TEXT,
`userId` INT,
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
