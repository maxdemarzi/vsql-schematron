INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 637147_schema
#
CREATE DATABASE `db_637147_schema`;
USE `db_637147_schema`;
CREATE TABLE `customer` (
`id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `credit_card` (
`id` INT,
`name` VARCHAR(64),
`number` VARCHAR(64),
`expiration` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer_credit_card` (
`customer_id` INT,
`credit_card_id` INT
) CHARACTER SET latin1;
CREATE TABLE `customer_order` (
`id` INT,
`customer_id` INT,
`credit_card_id` INT,
`total_price` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer_order_preference` (
`customer_id` INT,
`customer_order_id` INT
) CHARACTER SET latin1;
CREATE TABLE `drinks` (
`name` VARCHAR(64),
`price` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `pizzas` (
`id` INT,
`size` VARCHAR(64),
`topping_1` VARCHAR(64),
`topping_2` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer_pizzas` (
`customer_order_id` INT,
`pizza_id` INT
) CHARACTER SET latin1;
CREATE TABLE `toppings` (
`name` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `customer_drinks` (
`customer_order_id` INT,
`drink` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `sizes` (
`name` VARCHAR(64),
`price` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_637147_schema') AS relationships;
