INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 604374_schema
#
CREATE DATABASE `db_604374_schema`;
USE `db_604374_schema`;
CREATE TABLE `languages` (
`id` INT,
`language` VARCHAR(64),
`region` VARCHAR(64),
`variant` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`enabled` BOOL,
`language_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
`id` INT,
`username` VARCHAR(64),
`authority` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_604374_schema') AS relationships;
