INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 676505_dataDefinitions
#
CREATE DATABASE `db_676505_dataDefinitions`;
USE `db_676505_dataDefinitions`;
CREATE TABLE `clinics` (
`clinicID` INT,
`clinicName` VARCHAR(64),
`specialty` VARCHAR(64),
`providerCapacity` INT,
`examRooms` INT,
`primaryCare` BOOL,
PRIMARY KEY (`clinicID`)
) CHARACTER SET latin1;
CREATE TABLE `providers` (
`providerID` INT,
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`licenseType` VARCHAR(64),
`licenseNumber` INT,
`specialty` VARCHAR(64),
`primaryCare` BOOL,
PRIMARY KEY (`providerID`)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
`medicalRecordNumber` INT,
`birthdate` DATETIME,
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`primaryCarePhysician` INT,
`preferredPharmacy` VARCHAR(64),
PRIMARY KEY (`medicalRecordNumber`)
) CHARACTER SET latin1;
CREATE TABLE `procedures` (
`procedureCode` VARCHAR(64),
`procedureName` VARCHAR(64),
PRIMARY KEY (`procedureCode`)
) CHARACTER SET latin1;
CREATE TABLE `diagnoses` (
`diagnosisCode` VARCHAR(64),
`diagnosisName` VARCHAR(64),
PRIMARY KEY (`diagnosisCode`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
`accountNumber` INT,
`visitDate` DATETIME,
`chiefComplaint` VARCHAR(64),
`diagnosisCode` VARCHAR(64),
`procedureCode` VARCHAR(64),
`patient` INT,
`provider` INT,
`providerNotes` VARCHAR(64),
`clinic` INT,
PRIMARY KEY (`accountNumber`)
) CHARACTER SET latin1;
CREATE TABLE `providersClinics` (
`providerID` INT,
`clinicID` INT
) CHARACTER SET latin1;
CREATE TABLE `patientsClinics` (
`patientID` INT,
`clinicID` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_676505_dataDefinitions') AS relationships;
relationships
