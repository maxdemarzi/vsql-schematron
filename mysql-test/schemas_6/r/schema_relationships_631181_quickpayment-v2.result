INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 631181_quickpayment-v2
#
CREATE DATABASE `db_631181_quickpayment_v2`;
USE `db_631181_quickpayment_v2`;
CREATE TABLE `usergroups` (
`ID_UG` VARCHAR(50) NOT NULL,
`Name_UG` VARCHAR(50),
PRIMARY KEY (`ID_UG`)
) CHARACTER SET latin1;
CREATE TABLE `workplaces` (
`ID_WP` VARCHAR(50) NOT NULL,
`description` VARCHAR(50),
PRIMARY KEY (`ID_WP`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`id_member` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`name` VARCHAR(50),
`sex` VARCHAR(50),
`dayofbirth` DATE,
`phone` INT,
`ID_UG` VARCHAR(50),
`ID_WP` VARCHAR(50),
`balance` INT,
PRIMARY KEY (`id_member`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`date_time` TIMESTAMP NOT NULL,
`id_pay_member` VARCHAR(50) NOT NULL,
`id_collect_member` VARCHAR(50),
`amountofmoney` INT,
`type_payment` VARCHAR(50),
PRIMARY KEY (`date_time`, `id_pay_member`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
`id_Card` VARCHAR(50) NOT NULL,
`id_member` VARCHAR(50),
PRIMARY KEY (`id_Card`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_631181_quickpayment_v2') AS relationships;
relationships
Database: db_631181_quickpayment_v2

Table Connections:
------------------
[Implied]  cards.id_member -> members.id_member
[Implied]  members.ID_UG -> usergroups.ID_UG
[Implied]  members.ID_WP -> workplaces.ID_WP
[Implied]  payments.id_collect_member -> members.id_member
[Implied]  payments.id_pay_member -> members.id_member

DROP DATABASE `db_631181_quickpayment_v2`;
