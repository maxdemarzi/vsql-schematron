INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 677867_shop
#
CREATE DATABASE `db_677867_shop`;
USE `db_677867_shop`;
CREATE TABLE `categories` (
`cat_id` INT,
`cat_name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`user_name` VARCHAR(255),
`salt` VARCHAR(255),
`digest` VARCHAR(255),
`totalPrice` DECIMAL(10,2),
`transactionId` VARCHAR(255),
`p_id` VARCHAR(255),
`quantity` VARCHAR(255),
`payment_status` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`payment_id` INT,
`txn_id` VARCHAR(255),
`digest` VARCHAR(255),
`p_id` VARCHAR(255),
`quantity` VARCHAR(255),
`payment_amount` DECIMAL(10,2),
`payment_status` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`p_id` INT,
`p_name` VARCHAR(255),
`cat_id` INT,
`p_price` DECIMAL(10,2),
`p_description` VARCHAR(255),
`p_image` VARCHAR(255),
`p_keyword` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`user_email` VARCHAR(255),
`user_name` VARCHAR(255),
`user_password` VARCHAR(255),
`salt` VARCHAR(255),
`adminFlag` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_677867_shop') AS relationships;
