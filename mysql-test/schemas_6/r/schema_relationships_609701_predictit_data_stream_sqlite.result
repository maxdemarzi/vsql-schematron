[Implied]  contract.imageUrl -> image.imageUrl
[Implied]  contract.marketId -> market.marketId
[Implied]  market.imageUrl -> image.imageUrl
[Implied]  marketChartData.contractId -> contract.contractId
[Implied]  marketChartData.marketId -> market.marketId
[Implied]  marketChartData.querySourceId -> querySource.querySourceId
[Implied]  marketNotExist.marketId -> market.marketId
[Implied]  marketNotExist.querySourceId -> querySource.querySourceId
[Implied]  marketObservation.contractId -> contract.contractId
[Implied]  marketObservation.marketId -> market.marketId
[Implied]  marketObservation.querySourceId -> querySource.querySourceId

DROP DATABASE `db_609701_predictit_data_stream_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
