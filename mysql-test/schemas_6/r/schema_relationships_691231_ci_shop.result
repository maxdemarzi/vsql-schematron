INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 691231_ci_shop
#
CREATE DATABASE `db_691231_ci_shop`;
USE `db_691231_ci_shop`;
CREATE TABLE `customers` (
`id` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`order_id` VARCHAR(64),
`product_id` INT,
`amount` DECIMAL(10,2),
`currency` VARCHAR(64),
`receipt` VARCHAR(64),
`status` VARCHAR(64),
`payment_id` VARCHAR(64),
`attempts` INT,
`signature_id` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`id` INT,
`payment_id` VARCHAR(64),
`amount` DECIMAL(10,2),
`currency` VARCHAR(64),
`status` VARCHAR(64),
`order_id` VARCHAR(64),
`method` VARCHAR(64),
`captured` INT,
`description` VARCHAR(64),
`card_id` VARCHAR(64),
`email` VARCHAR(64),
`contact` DECIMAL(10,2),
`shipping_address` VARCHAR(64),
`additional_notes` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`, `payment_id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`name` VARCHAR(64),
`price` DECIMAL(10,2),
`description` VARCHAR(64),
`img` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reset_links` (
`id` INT,
`account_id` INT,
`email` VARCHAR(64),
`link` VARCHAR(64),
`expired` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` VARCHAR(64),
`customer_id` VARCHAR(64),
`product` VARCHAR(64),
`amount` VARCHAR(64),
`currency` VARCHAR(64),
`status` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`mobile_number` DECIMAL(10,2),
`password` VARCHAR(64),
`gender` VARCHAR(64),
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_691231_ci_shop') AS relationships;
relationships
Database: db_691231_ci_shop

Table Connections:
------------------
[Implied]  orders.payment_id -> payment.payment_id
[Implied]  orders.product_id -> product.id
[Implied]  transactions.customer_id -> customers.id

DROP DATABASE `db_691231_ci_shop`;
