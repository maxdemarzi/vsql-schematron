[Implied]  journey.user_id -> fleet_user.user_id
[Implied]  journey.user_id -> log.user_id
[Implied]  log.user_id -> fleet_user.user_id

DROP DATABASE `db_639535_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
