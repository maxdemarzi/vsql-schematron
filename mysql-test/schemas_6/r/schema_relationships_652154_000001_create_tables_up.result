CREATE DATABASE `db_652154_000001_create_tables_up`;
USE `db_652154_000001_create_tables_up`;
CREATE TABLE `import_statuses` (
`ulid` INT,
`val` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`ulid` VARCHAR(64),
`title` VARCHAR(64),
`duration` INT,
`import_status_ulid` INT,
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
`ulid` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `book_authors` (
`ulid` VARCHAR(64),
`book_ulid` VARCHAR(64),
`author_ulid` VARCHAR(64),
`meta` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`ulid` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `book_genres` (
`ulid` VARCHAR(64),
`book_ulid` VARCHAR(64),
`genre_ulid` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`ulid` VARCHAR(64),
`username` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `lists` (
`ulid` VARCHAR(64),
`name` VARCHAR(64),
`user_ulid` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
CREATE TABLE `list_books` (
`ulid` VARCHAR(64),
`list_ulid` VARCHAR(64),
`book_ulid` VARCHAR(64),
PRIMARY KEY (`ulid`)
) CHARACTER SET latin1;
