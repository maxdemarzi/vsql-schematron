CREATE DATABASE `db_617242_sample_db`;
USE `db_617242_sample_db`;
CREATE TABLE `Persons` (
`P_Id` INT NOT NULL,
`LastName` VARCHAR(50),
`FirstName` VARCHAR(50),
`Address` VARCHAR(50),
`City` VARCHAR(50),
PRIMARY KEY (`P_Id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`O_Id` INT NOT NULL,
`OrderNo` INT,
`P_Id` INT,
PRIMARY KEY (`O_Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_617242_sample_db') AS relationships;
