CREATE DATABASE `db_690296_evotingbem`;
USE `db_690296_evotingbem`;
CREATE TABLE `admin` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kandidat` (
`id` INT NOT NULL,
`no_urut` VARCHAR(50),
`ketua` VARCHAR(50),
`wakil` VARCHAR(50),
`semester` VARCHAR(50),
`visi` TEXT,
`misi` TEXT,
`proker` TEXT,
`periode` VARCHAR(50),
`prestasi` TEXT,
`suara` INT,
`gambar` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pemilih` (
`id` INT NOT NULL,
`gid` VARCHAR(50),
`nama` VARCHAR(50),
`status` VARCHAR(50),
`periode` VARCHAR(50),
`prodi` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pemilihan` (
`id` INT,
`pemilih_id` INT,
`pilihan` VARCHAR(50),
`tanggal` DATE
) CHARACTER SET latin1;
CREATE TABLE `peraturan` (
`id` INT NOT NULL,
`judul` VARCHAR(50),
`isi` TEXT,
`tahun` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
