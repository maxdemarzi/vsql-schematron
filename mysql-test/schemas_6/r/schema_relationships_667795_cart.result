INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 667795_cart
#
CREATE DATABASE `db_667795_cart`;
USE `db_667795_cart`;
CREATE TABLE `addresses` (
`address_id` INT,
`address_streetname` VARCHAR(255),
`address_housenumber` VARCHAR(255),
`address_country` VARCHAR(255),
`address_postcode` VARCHAR(255),
PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`category_id` INT,
`category_name` VARCHAR(255),
`category_description` VARCHAR(255),
`category_image` VARCHAR(255),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT,
`customer_firstname` VARCHAR(255),
`customer_lastname` VARCHAR(255),
`customer_email` VARCHAR(255),
`customer_registered` VARCHAR(255),
`customer_phone` VARCHAR(255),
`address_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `logins` (
`login_id` INT,
`customer_id` INT,
`login_username` VARCHAR(255),
`login_password` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`customer_id` INT,
`address_id` INT,
`order_payment_type` VARCHAR(255),
`order_date` DATETIME,
`order_status` VARCHAR(255),
`order_total` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_items_id` INT,
`order_id` INT,
`product_id` INT,
`order_item_quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `products` (
`product_id` INT,
`category_id` INT,
`product_name` VARCHAR(255),
`product_description` VARCHAR(255),
`product_image` VARCHAR(255),
`product_price` DECIMAL(10,2),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_667795_cart') AS relationships;
relationships
Database: db_667795_cart

Table Connections:
------------------
[Implied]  customers.address_id -> addresses.address_id
[Implied]  logins.customer_id -> customers.customer_id
[Implied]  order_items.order_id -> orders.order_id
[Implied]  order_items.product_id -> products.product_id
[Implied]  orders.address_id -> addresses.address_id
[Implied]  orders.customer_id -> customers.customer_id
[Implied]  products.category_id -> categories.category_id

DROP DATABASE `db_667795_cart`;
UNINSTALL EXTENSION vsql_schematron;
