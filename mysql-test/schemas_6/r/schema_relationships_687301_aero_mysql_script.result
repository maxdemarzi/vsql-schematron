CREATE DATABASE `db_687301_aero_mysql_script`;
USE `db_687301_aero_mysql_script`;
CREATE TABLE `Company` (
`ID_comp` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID_comp`)
) CHARACTER SET latin1;
CREATE TABLE `Pass_in_trip` (
`trip_no` INT,
`date` DATETIME,
`ID_psg` INT,
`place` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Passenger` (
`ID_psg` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Trip` (
`trip_no` INT,
`ID_comp` INT,
`plane` VARCHAR(64),
`town_from` VARCHAR(64),
`town_to` VARCHAR(64),
`time_out` DATETIME,
`time_in` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_687301_aero_mysql_script') AS relationships;
