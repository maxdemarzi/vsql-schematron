CREATE DATABASE `db_653989_dsr`;
USE `db_653989_dsr`;
CREATE TABLE `scanned_codes` (
`id` INT,
`serial_number` VARCHAR(64),
`department` VARCHAR(64),
`reference_number` VARCHAR(64),
`product_type` VARCHAR(64),
`date_of_purchase` VARCHAR(64),
`product_cost` VARCHAR(64),
`code_format` VARCHAR(64),
`id_of_scanner` INT,
`share_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`share_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
