INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 677296_SQL_Basico
#
CREATE DATABASE `db_677296_SQL_Basico`;
USE `db_677296_SQL_Basico`;
CREATE TABLE `books` (
`book_id` VARCHAR(50) NOT NULL,
`book_category_id` VARCHAR(50),
`title` VARCHAR(50),
`date_publish` DATE,
`date_acquisition` DATE,
`book_comments` VARCHAR(50),
`price` DECIMAL(10,2),
`author_id` VARCHAR(50),
PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `consumers` (
`consumer_id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`gender` CHAR(50),
`age` INT,
`date_cadastro` TIMESTAMP NULL,
`city` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`consumer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` VARCHAR(50) NOT NULL,
`consumer_id` VARCHAR(50),
`order_date` TIMESTAMP NULL,
`order_value` VARCHAR(50),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_category` (
`book_category_id` VARCHAR(50) NOT NULL,
`category_type` VARCHAR(50),
`book_description` VARCHAR(50),
PRIMARY KEY (`book_category_id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
`author_id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`gender` CHAR(50),
`date_of_birth` DATE,
`email` VARCHAR(50),
PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`item_id` VARCHAR(50) NOT NULL,
`order_id` VARCHAR(50),
`book_id` VARCHAR(50),
`item_price` DECIMAL(10,2),
`item_comment` VARCHAR(50),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_677296_SQL_Basico') AS relationships;
relationships
Database: db_677296_SQL_Basico

Table Connections:
