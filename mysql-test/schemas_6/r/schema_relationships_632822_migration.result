`userId` VARCHAR(64),
`providerType` VARCHAR(64),
`providerId` VARCHAR(64),
`providerAccountId` INT,
`refreshToken` VARCHAR(64),
`accessToken` VARCHAR(64),
`accessTokenExpires` DATETIME,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` VARCHAR(64),
`userId` VARCHAR(64),
`expires` DATETIME,
`sessionToken` VARCHAR(64),
`accessToken` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`emailVerified` DATETIME,
`image` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `VerificationRequest` (
`id` VARCHAR(64),
`identifier` VARCHAR(64),
`token` VARCHAR(64),
`expires` DATETIME,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
