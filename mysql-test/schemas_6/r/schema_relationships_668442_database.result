INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 668442_database
#
CREATE DATABASE `db_668442_database`;
USE `db_668442_database`;
CREATE TABLE `user` (
`id` INT,
`full_name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`date_of_birth` DATETIME,
`phone_number` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_has_permission` (
`permission_id` INT,
`role_id` INT,
PRIMARY KEY (`permission_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_has_role` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `drafted_request` (
`id` INT,
`request_date` DATETIME,
`title` VARCHAR(64),
`details` VARCHAR(64),
`quantity` INT,
`cost_per_unit` DECIMAL(10,2),
`total_cost` DECIMAL(10,2),
`workflow_status` VARCHAR(64),
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `request` (
`id` INT,
`request_date` DATETIME,
`title` VARCHAR(64),
`details` VARCHAR(64),
`quantity` INT,
`cost_per_unit` DECIMAL(10,2),
`total_cost` DECIMAL(10,2),
`workflow_status` VARCHAR(64),
`user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `request_transition` (
`id` INT,
`request_id` VARCHAR(64),
`user_id` INT,
`transition` VARCHAR(64),
`from_step` VARCHAR(64),
`to_step` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `system_registry` (
`id` INT,
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_668442_database') AS relationships;
