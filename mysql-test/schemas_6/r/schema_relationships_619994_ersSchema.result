CREATE TABLE `ReimbursementRequest` (
`id` INT,
`employeeId` INT,
`image` VARCHAR(64),
`amount` DECIMAL(10,2),
`description` VARCHAR(64),
`resolver` INT,
`hasImage` BOOL,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`accountType` INT,
`managerId` INT,
`isManager` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
