INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 604494_data
#
CREATE DATABASE `db_604494_data`;
USE `db_604494_data`;
CREATE TABLE `users` (
`username` VARCHAR(64),
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`email_confirmed` INT,
`password` VARCHAR(64),
`uploads_id` INT,
`location` VARCHAR(64),
`study` VARCHAR(64),
`bio` VARCHAR(64),
`relationship_status` VARCHAR(64),
`phone_number` VARCHAR(64),
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `uploads` (
`id` INT,
`filename` VARCHAR(64),
`location` VARCHAR(64),
`filesize` INT,
`type` VARCHAR(64),
`sha256` VARCHAR(64),
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`body` VARCHAR(64),
`title` VARCHAR(64),
`username` VARCHAR(64),
`uploads_id` INT,
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`post_id` INT,
`username` VARCHAR(64),
`comment` VARCHAR(64),
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
`id` INT,
`username` VARCHAR(64),
`friend` VARCHAR(64),
`accepted` INT,
`sender` INT,
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hobbies` (
`id` INT,
`username` VARCHAR(64),
`title` VARCHAR(64),
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skills` (
`id` INT,
`username` VARCHAR(64),
`title` VARCHAR(64),
`skill_level` INT,
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `languages` (
`id` INT,
`username` VARCHAR(64),
`title` VARCHAR(64),
`skill_level` INT,
`creation_date` DATETIME,
`last_edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
