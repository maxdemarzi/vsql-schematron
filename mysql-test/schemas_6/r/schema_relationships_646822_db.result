INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 646822_db
#
CREATE DATABASE `db_646822_db`;
USE `db_646822_db`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`created_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `followers` (
`user_id` INT,
`follower_id` INT,
PRIMARY KEY (`user_id`, `follower_id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`author_id` INT,
`likes` INT,
`created_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_646822_db') AS relationships;
