CREATE DATABASE `db_647795_0_0_1`;
USE `db_647795_0_0_1`;
CREATE TABLE `events` (
`id` INT,
`name` VARCHAR(64),
`startDate` INT,
`endDate` INT,
`description` VARCHAR(64),
`uuid` VARCHAR(64),
`recurringEvent` VARCHAR(64),
`type` VARCHAR(64),
`locationName` VARCHAR(64),
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`id` INT,
`uuid` VARCHAR(64),
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`height` VARCHAR(64),
`weight` VARCHAR(64),
`extra` VARCHAR(64),
`roles` VARCHAR(64),
`type` VARCHAR(64),
`email` VARCHAR(64),
`contact` VARCHAR(64),
`code` VARCHAR(64),
`activated` INT,
`subscribed` INT,
`deleted` INT,
`language` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `participation` (
`member_uuid` INT,
`event_uuid` INT,
`answer` VARCHAR(64),
`presence` VARCHAR(64),
PRIMARY KEY (`member_uuid`, `event_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `recurring_events` (
`uuid` VARCHAR(64),
`name` VARCHAR(64),
`description` VARCHAR(64),
`interval` VARCHAR(64),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `notifications` (
`id` INT,
`notificationType` VARCHAR(64),
`authorUUID` VARCHAR(64),
`objectUUID` VARCHAR(64),
`sendDate` INT,
`delivered` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_647795_0_0_1') AS relationships;
