CREATE TABLE `accounts` (
`id` VARCHAR(50) NOT NULL,
`created_at` TIMESTAMP NULL,
`tos_agreed_at` TIMESTAMP NULL,
`status` VARCHAR(50),
`public_key` VARCHAR(50),
`eab_id` VARCHAR(50),
`eab_protected_header` VARCHAR(50),
`eab_payload` VARCHAR(50),
`eab_sig` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_contacts` (
`id` VARCHAR(50) NOT NULL,
`account` VARCHAR(50),
`contact_type` VARCHAR(50),
`contact_value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
