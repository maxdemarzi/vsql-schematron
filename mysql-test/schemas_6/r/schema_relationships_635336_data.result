CREATE DATABASE `db_635336_data`;
USE `db_635336_data`;
CREATE TABLE `USERS` (
`ID` INT,
`FIRST_NAME` VARCHAR(64),
`LAST_NAME` VARCHAR(64),
`USER_NAME` VARCHAR(64),
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`ENCRYPTION_TYPE` VARCHAR(64),
`FAILED_LOGIN_ATTEMPTS` INT,
`LAST_SUCCESS_LOGIN` DATETIME,
`ENABLED` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLES` (
