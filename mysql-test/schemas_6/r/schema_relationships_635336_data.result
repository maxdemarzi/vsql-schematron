PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLES_FEATURES` (
`ID` INT,
`ROLES_ID` INT,
`FEATURES_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ACCOUNT` (
`ID` INT,
`USER_ID` INT,
`ACCOUNT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ADAPTER_CONFIG` (
`ID` INT,
`DATA` VARCHAR(64),
`HREF` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REPORTS` (
`ID` INT,
`NAME` VARCHAR(64),
`ACCOUNT_ID` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
