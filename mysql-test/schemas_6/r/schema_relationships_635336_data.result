PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNTS` (
`ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLES` (
