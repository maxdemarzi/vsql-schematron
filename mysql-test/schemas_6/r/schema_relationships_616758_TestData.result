CREATE DATABASE `db_616758_TestData`;
USE `db_616758_TestData`;
CREATE TABLE `Publisher` (
`Id` INT,
`Name` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Author` (
`Id` INT,
`Name` VARCHAR(64),
`Sex` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Reader` (
`Id` INT,
`Name` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`Id` INT,
`ReaderId` INT,
`BookId` INT,
`Content` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `WriteBook` (
`AuthorId` INT,
`BookId` INT,
PRIMARY KEY (`AuthorId`, `BookId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_616758_TestData') AS relationships;
