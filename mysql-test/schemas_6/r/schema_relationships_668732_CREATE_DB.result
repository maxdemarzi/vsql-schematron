CREATE DATABASE `db_668732_CREATE_DB`;
USE `db_668732_CREATE_DB`;
CREATE TABLE `opp_block_day` (
`uid_day` INT,
`day` DATETIME,
PRIMARY KEY (`uid_day`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`uid_group` INT,
