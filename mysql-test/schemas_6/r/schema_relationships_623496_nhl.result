INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 623496_nhl
#
CREATE DATABASE `db_623496_nhl`;
USE `db_623496_nhl`;
CREATE TABLE `team` (
`team_id` INT,
`team_name` VARCHAR(64),
`city` VARCHAR(64),
`coach_name` VARCHAR(64),
PRIMARY KEY (`team_id`)
) CHARACTER SET latin1;
CREATE TABLE `players` (
`pid` INT,
`p_name` VARCHAR(64),
`position` VARCHAR(64),
`skill` VARCHAR(64),
`dob` DATETIME,
`team_id` INT,
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `injury` (
`inj_name` VARCHAR(64),
`pid` INT,
`I_date` DATETIME,
`physician` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`inj_name`, `pid`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
`tid1` INT,
`tid2` INT,
`score` VARCHAR(64),
`guest` INT,
`g_date` DATETIME,
`venue` VARCHAR(64),
PRIMARY KEY (`tid1`, `tid2`, `guest`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_623496_nhl') AS relationships;
relationships
Database: db_623496_nhl

Table Connections:
