INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 627232_schema
#
CREATE DATABASE `db_627232_schema`;
USE `db_627232_schema`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`tags` VARCHAR(50),
`path` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_file` (
`user_id` INT NOT NULL,
`file_id` INT NOT NULL,
PRIMARY KEY (`user_id`, `file_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_627232_schema') AS relationships;
relationships
