CREATE DATABASE `db_621397_0001`;
USE `db_621397_0001`;
CREATE TABLE `project` (
`created_at` DATETIME,
`deleted_at` DATETIME,
`id` VARCHAR(64),
`name` VARCHAR(64),
`modified_at` DATETIME,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
`cover_image_id` VARCHAR(64),
`created_at` DATETIME,
`deleted_at` DATETIME,
`id` VARCHAR(64),
`modified_at` DATETIME,
`project_id` VARCHAR(64),
`title` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_block` (
`article_id` VARCHAR(64),
`created_at` DATETIME,
`data` VARCHAR(64),
`deleted_at` DATETIME,
`id` VARCHAR(64),
`modified_at` DATETIME,
`sort_rank` VARCHAR(64),
`type` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`created_at` DATETIME,
`deleted_at` DATETIME,
`id` VARCHAR(64),
`name` VARCHAR(64),
`modified_at` DATETIME,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article_tag` (
`article_id` VARCHAR(64),
`created_at` DATETIME,
`id` VARCHAR(64),
`modified_at` DATETIME,
`sort_rank` VARCHAR(64),
`tag_id` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`created_at` DATETIME,
`deleted_at` DATETIME,
`type` VARCHAR(64),
`height` INT,
`id` VARCHAR(64),
`modified_at` DATETIME,
`version` INT,
`width` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
