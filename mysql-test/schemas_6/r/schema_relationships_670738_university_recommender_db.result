INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 670738_university_recommender_db
#
CREATE DATABASE `db_670738_university_recommender_db`;
USE `db_670738_university_recommender_db`;
CREATE TABLE `admission_details` (
`admission_id` INT,
`university_id` INT,
`season` VARCHAR(255),
`start_date` DATETIME,
`end_date` DATETIME,
`details` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `programs` (
`program_id` INT,
`program_name` VARCHAR(255),
PRIMARY KEY (`program_id`)
) CHARACTER SET latin1;
CREATE TABLE `program_university` (
`id` INT,
`university_id` INT,
`program_id` INT,
`merit` INT,
`duration` VARCHAR(255),
`fee` VARCHAR(255),
`best_for` VARCHAR(255),
`program_link` VARCHAR(255),
`details` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `search_list` (
`list_id` INT,
`user_id` INT,
`inter_subject` VARCHAR(255),
`inter_percentage` INT,
`interested_program` VARCHAR(255),
`fee_start` VARCHAR(255),
`fee_end` VARCHAR(255),
`admission_date` VARCHAR(255),
`season` VARCHAR(255),
`save_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `universities` (
`university_id` INT,
`university_name` VARCHAR(255),
`founded` VARCHAR(255),
`website` VARCHAR(255),
`phone` VARCHAR(255),
`location` VARCHAR(255),
`campus` VARCHAR(255),
`hours` VARCHAR(255),
`details` VARCHAR(255),
`image` VARCHAR(255),
`created_at` DATETIME,
PRIMARY KEY (`university_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`username` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`gender` VARCHAR(255),
`date_of_birth` VARCHAR(255),
`cnic` VARCHAR(255),
`profile_image` VARCHAR(255),
`address` VARCHAR(255),
`email` VARCHAR(255),
`phone` VARCHAR(255),
`university_name` VARCHAR(255),
`study_program` VARCHAR(255),
`current_semester` VARCHAR(255),
`password` VARCHAR(255),
`status` VARCHAR(255),
`user_role` VARCHAR(255),
`join_date` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_670738_university_recommender_db') AS relationships;
relationships
Database: db_670738_university_recommender_db

Table Connections:
------------------
[Implied]  admission_details.university_id -> universities.university_id
[Implied]  program_university.program_id -> programs.program_id
[Implied]  program_university.university_id -> universities.university_id
[Implied]  search_list.user_id -> users.user_id

DROP DATABASE `db_670738_university_recommender_db`;
UNINSTALL EXTENSION vsql_schematron;
