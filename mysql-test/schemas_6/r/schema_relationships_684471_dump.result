INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 684471_dump
#
CREATE DATABASE `db_684471_dump`;
USE `db_684471_dump`;
CREATE TABLE `car` (
`id` INT,
`make` VARCHAR(64),
`model` VARCHAR(64),
`year` INT,
`consumption` INT,
`km` INT,
`lastTechInspection` DATETIME,
`priceTechInspection` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `costs` (
`id` INT,
`fuelCosts` INT,
`techInspectionCosts` INT,
`status` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`payment_id` INT,
`employee_id` INT
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`phoneNumber` INT,
`email` VARCHAR(64),
`kmLimit` INT,
`car_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`id` INT,
`sum` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_684471_dump') AS relationships;
relationships
