[Implied]  Bookings.RentalId -> Rentals.RentalId
[Implied]  Comments.RentalId -> Rentals.RentalId
[Implied]  Comments.UserId -> Users.UserId
[Implied]  Locations.ParentId -> Locations.LocationId
[Implied]  RentalDescriptions.RentalId -> Rentals.RentalId
[Implied]  RentalPhotos.RentalDescriptionId -> RentalDescriptions.RentalDescriptionId
[Implied]  Rentals.LocationId -> Locations.LocationId
[Implied]  Transactions.BookingId -> Bookings.BookingId
[Implied]  Users.LocationId -> Locations.LocationId

DROP DATABASE `db_641086_g16_vacation_rental_system_tables`;
UNINSTALL EXTENSION vsql_schematron;
