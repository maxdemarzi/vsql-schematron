`post_image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`is_admin` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
