INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 638530_setup
#
CREATE DATABASE `db_638530_setup`;
USE `db_638530_setup`;
CREATE TABLE `Descript` (
`shortname` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`fileurl` VARCHAR(50),
PRIMARY KEY (`shortname`)
) CHARACTER SET latin1;
CREATE TABLE `Adresses` (
`shortname` VARCHAR(50) NOT NULL,
`street` VARCHAR(50),
`campus` VARCHAR(50),
`nr` VARCHAR(50),
PRIMARY KEY (`shortname`)
) CHARACTER SET latin1;
CREATE TABLE `meta` (
`setting` VARCHAR(50) NOT NULL,
`val` VARCHAR(50),
PRIMARY KEY (`setting`)
) CHARACTER SET latin1;
CREATE TABLE `OSMBuildings` (
`id` INT NOT NULL,
`adress` VARCHAR(50),
`descript` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_638530_setup') AS relationships;
