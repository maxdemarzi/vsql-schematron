INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 637678_schema_mysql
#
CREATE DATABASE `db_637678_schema_mysql`;
USE `db_637678_schema_mysql`;
CREATE TABLE `account` (
`id` INT,
`email` VARCHAR(64),
`email_check_token` VARCHAR(64),
`email_check_token_generated_at` DATETIME,
`email_verified` VARCHAR(64),
`joined_at` DATETIME,
`login_id` VARCHAR(64),
`nickname` VARCHAR(64),
`password` VARCHAR(64),
`profile_image` VARCHAR(64),
`comment_notification` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `persistent_logins` (
`series` VARCHAR(64),
`last_used` DATETIME,
`token` VARCHAR(64),
`username` VARCHAR(64),
PRIMARY KEY (`series`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT,
`account_id` INT,
`contents` VARCHAR(64),
`created_at` DATETIME,
`hits` INT,
`post_type` VARCHAR(64),
`title` VARCHAR(64),
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT,
`contents` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`account_id` INT,
`post_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `notification` (
`id` INT,
`checked` VARCHAR(64),
`created_at` DATETIME,
`link` VARCHAR(64),
`message` VARCHAR(64),
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_637678_schema_mysql') AS relationships;
