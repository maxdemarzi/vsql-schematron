[Implied]  Instruction.recipe_id -> Recipe.recipe_id
[Implied]  Profile.account_id -> Account.account_id
[Implied]  SupermarketList.mid -> Mealplan.mid
[Implied]  adds.profile_id -> Profile.profile_id
[Implied]  generates.account_id -> Account.account_id
[Implied]  generates.profile_id -> Profile.profile_id
[Implied]  hasInStock.account_id -> Account.account_id
[Implied]  hasInStock.ingredient_id -> Ingredients.ingredient_id
[Implied]  hasInStock.profile_id -> Profile.profile_id
[Implied]  has_a.ingredient_id -> Ingredients.ingredient_id
[Implied]  has_a.recipe_id -> Recipe.recipe_id
[Implied]  madeupof.mid -> Mealplan.mid
[Implied]  uses.meal_id -> Meal.meal_id

DROP DATABASE `db_660735_OnlineMealPlanner`;
UNINSTALL EXTENSION vsql_schematron;
