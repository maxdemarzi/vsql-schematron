CREATE DATABASE `db_620784_b13_grp3_moneyapp`;
USE `db_620784_b13_grp3_moneyapp`;
CREATE TABLE `Users` (
`user_id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`mobile` VARCHAR(50),
`ic_number` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Transactions` (
`transaction_id` VARCHAR(50) NOT NULL,
`transaction_type` VARCHAR(50),
`user_id` VARCHAR(50),
`transaction_title` VARCHAR(50),
`amount` DECIMAL(10,2),
PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
