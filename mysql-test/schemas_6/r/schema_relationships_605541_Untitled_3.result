CREATE DATABASE `db_605541_Untitled_3`;
USE `db_605541_Untitled_3`;
CREATE TABLE `housingComplex` (
`complex_id` INT,
`boretslag_name` VARCHAR(255),
`adress` VARCHAR(255),
`anno` INT,
PRIMARY KEY (`complex_id`)
) CHARACTER SET latin1;
CREATE TABLE `houses` (
`house_id` INT,
`complex_id` INT,
`numApartments` INT,
`numFloors` INT,
PRIMARY KEY (`house_id`)
) CHARACTER SET latin1;
CREATE TABLE `apartments` (
`apt_id` INT,
`apt_nr` INT,
`house_id` INT,
`member_id` INT,
`numRooms` INT,
`squareFeet` INT,
PRIMARY KEY (`apt_id`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`member_id` INT,
`firstname` VARCHAR(255),
`lastname` VARCHAR(255),
`share` INT,
PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605541_Untitled_3') AS relationships;
