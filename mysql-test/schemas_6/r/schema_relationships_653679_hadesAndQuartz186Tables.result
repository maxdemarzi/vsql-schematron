`FIRED_TIME` DECIMAL(10,2),
`PRIORITY` DECIMAL(10,2),
`STATE` VARCHAR(64),
`JOB_NAME` VARCHAR(64),
`JOB_GROUP` VARCHAR(64),
`IS_STATEFUL` VARCHAR(64),
`REQUESTS_RECOVERY` VARCHAR(64),
PRIMARY KEY (`ENTRY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `HADES_SCHEDULER_STATE` (
