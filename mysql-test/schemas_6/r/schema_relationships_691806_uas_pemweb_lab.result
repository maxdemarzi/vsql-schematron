CREATE DATABASE `db_691806_uas_pemweb_lab`;
USE `db_691806_uas_pemweb_lab`;
CREATE TABLE `facilities` (
`facility_id` VARCHAR(64),
`facility_name` VARCHAR(64),
PRIMARY KEY (`facility_id`)
) CHARACTER SET latin1;
CREATE TABLE `hotel_bookings` (
`id` INT,
`user_id` VARCHAR(64),
`booking_id` VARCHAR(64),
`hotel_id` INT,
`full_name` VARCHAR(64),
`phone_number` VARCHAR(64),
`email` VARCHAR(64),
`number_of_rooms` INT,
`duration` INT,
`check_in` DATETIME,
`check_out` DATETIME,
`price_per_day` INT,
`total_price` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `hotel_facilities` (
`id` INT,
`hotel_id` INT,
`facility_id` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `hotel_list` (
`id` INT,
`name` VARCHAR(64),
`star_rating` INT,
`number_of_rooms` INT,
`price_per_day` INT,
`address` VARCHAR(64),
`city` VARCHAR(64),
`province` VARCHAR(64),
`postal_code` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_accounts` (
`id` INT,
`uid` VARCHAR(64),
`role_id` VARCHAR(64),
`full_name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`birth_date` DATETIME,
`phone_number` VARCHAR(64),
`gender` VARCHAR(64),
`avatar` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`role_id` VARCHAR(64),
`role_name` VARCHAR(64),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_691806_uas_pemweb_lab') AS relationships;
