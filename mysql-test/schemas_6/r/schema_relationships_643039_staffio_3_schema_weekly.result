CREATE DATABASE `db_643039_staffio_3_schema_weekly`;
USE `db_643039_staffio_3_schema_weekly`;
CREATE TABLE `weekly_report` (
`id` INT,
`uid` VARCHAR(64),
`iso_year` INT,
`iso_week` INT,
`content` VARCHAR(64),
`up_count` INT,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weekly_report_up` (
`id` INT,
`report_id` INT,
`uid` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weekly_problem` (
`id` INT,
`uid` VARCHAR(64),
`iso_year` INT,
`iso_week` INT,
`content` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weekly_status` (
`id` INT,
`uid` VARCHAR(64),
`iso_year` INT,
`iso_week` INT,
`status` INT,
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
