`password_hash` TEXT,
`given_name` TEXT,
`family_name` TEXT,
`name` TEXT,
`nickname` TEXT,
`picture` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `refresh_tokens` (
`id` VARCHAR(50) NOT NULL,
`token_hash` TEXT,
