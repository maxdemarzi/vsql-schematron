`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`expires_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `todos` (
`id` VARCHAR(50) NOT NULL,
`text` TEXT,
`user_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
