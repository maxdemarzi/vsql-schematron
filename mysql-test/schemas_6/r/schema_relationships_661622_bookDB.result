INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 661622_bookDB
#
CREATE DATABASE `db_661622_bookDB`;
USE `db_661622_bookDB`;
CREATE TABLE `t_user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_order` (
`order_id` VARCHAR(50) NOT NULL,
`create_time` DATETIME,
`price` DECIMAL(10,2),
`status` INT,
`user_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_order_item` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`count` INT,
`price` DECIMAL(10,2),
`total_price` DECIMAL(10,2),
`order_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_661622_bookDB') AS relationships;
relationships
Database: db_661622_bookDB

