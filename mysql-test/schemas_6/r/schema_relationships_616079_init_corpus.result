INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 616079_init_corpus
#
CREATE DATABASE `db_616079_init_corpus`;
USE `db_616079_init_corpus`;
CREATE TABLE `corpus` (
`ID` INT,
`name` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `document` (
`ID` INT,
`name` VARCHAR(64),
`title` VARCHAR(64),
`lang` VARCHAR(64),
`corpusID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `sentence` (
`ID` INT,
`ident` VARCHAR(64),
`text` VARCHAR(64),
`docID` INT,
`flag` INT,
`comment` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `token` (
`ID` INT,
`sid` INT,
`widx` INT,
`cfrom` INT,
`cto` INT,
`text` VARCHAR(64),
`lemma` VARCHAR(64),
`pos` VARCHAR(64),
`comment` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `concept` (
`ID` INT,
`sid` INT,
`cidx` INT,
`clemma` VARCHAR(64),
`tag` VARCHAR(64),
`flag` VARCHAR(64),
`comment` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`ID` INT,
`sid` INT,
`wid` INT,
`cfrom` INT,
`cto` INT,
`value` VARCHAR(64),
`source` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `cwl` (
`sid` INT,
`cid` INT,
`wid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_616079_init_corpus') AS relationships;
relationships
Database: db_616079_init_corpus

Table Connections:
------------------
[Implied]  document.corpusID -> corpus.ID
[Implied]  sentence.docID -> document.ID

DROP DATABASE `db_616079_init_corpus`;
UNINSTALL EXTENSION vsql_schematron;
