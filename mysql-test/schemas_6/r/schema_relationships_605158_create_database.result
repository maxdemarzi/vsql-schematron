INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 605158_create_database
#
CREATE DATABASE `db_605158_create_database`;
USE `db_605158_create_database`;
CREATE TABLE `privacy_settings` (
`privacyID` INT,
`option` VARCHAR(64),
PRIMARY KEY (`privacyID`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`userID` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`dob` DATETIME,
`gender` VARCHAR(64),
`location` VARCHAR(64),
`profilephotoURL` VARCHAR(64),
`privacyID` INT,
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `friendship` (
`userID1` INT,
`userID2` INT,
`status` VARCHAR(64),
`originUserID` INT,
PRIMARY KEY (`userID1`, `userID2`)
) CHARACTER SET latin1;
CREATE TABLE `photo_collection` (
`collectionID` INT,
`userID` INT,
`name` VARCHAR(64),
`privacyID` INT,
`date` DATETIME,
PRIMARY KEY (`collectionID`)
) CHARACTER SET latin1;
CREATE TABLE `circle` (
`circleID` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`privacyID` INT,
PRIMARY KEY (`circleID`)
) CHARACTER SET latin1;
CREATE TABLE `circle_participants` (
`circleID` INT,
`userID` INT,
`userStatus` INT,
PRIMARY KEY (`circleID`, `userID`)
) CHARACTER SET latin1;
CREATE TABLE `photo` (
`photoID` INT,
`collectionID` INT,
`photoURL` VARCHAR(64),
`date` DATETIME,
PRIMARY KEY (`photoID`)
) CHARACTER SET latin1;
CREATE TABLE `photo_comment` (
`commentID` INT,
`photoID` INT,
`userID` INT,
`comment` VARCHAR(64),
`date` DATETIME,
PRIMARY KEY (`commentID`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
`messageID` INT,
`circleID` INT,
`userID` INT,
`message` VARCHAR(64),
`date` DATETIME,
PRIMARY KEY (`messageID`)
) CHARACTER SET latin1;
CREATE TABLE `photo_annotation` (
`photoID` INT,
`userID` INT,
`annotationType` INT,
`date` DATETIME,
PRIMARY KEY (`photoID`, `userID`)
) CHARACTER SET latin1;
CREATE TABLE `blog_entry` (
`entryID` INT,
`userID` INT,
`entry` VARCHAR(64),
`date` DATETIME,
PRIMARY KEY (`entryID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605158_create_database') AS relationships;
