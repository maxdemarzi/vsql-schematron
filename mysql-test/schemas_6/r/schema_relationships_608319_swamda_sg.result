) CHARACTER SET latin1;
CREATE TABLE `rol` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`realname` VARCHAR(64),
`realsurname` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`auth_date` DATETIME,
`rol` INT,
`color` VARCHAR(64),
`flag_activo` INT
) CHARACTER SET latin1;
CREATE TABLE `userlogin` (
`id` INT,
`id_user` INT,
`date_login` DATETIME,
`time_login` DATETIME
) CHARACTER SET latin1;
