CREATE DATABASE `db_662480_ams`;
USE `db_662480_ams`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` INT,
PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64),
PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_params` (
`tp_id` INT,
`tp_name` VARCHAR(64),
`tp_value` VARCHAR(64),
PRIMARY KEY (`tp_id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_user_additional` (
`tua_phone_number` VARCHAR(64),
`tua_user_id` INT
) CHARACTER SET latin1;
