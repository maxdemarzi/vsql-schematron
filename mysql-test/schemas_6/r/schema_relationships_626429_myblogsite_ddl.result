INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 626429_myblogsite.ddl
#
CREATE DATABASE `db_626429_myblogsite_ddl`;
USE `db_626429_myblogsite_ddl`;
CREATE TABLE `User` (
`userId` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`phoneNum` VARCHAR(50),
`address` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`postalCode` VARCHAR(50),
`country` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`isAdmin` VARCHAR(50),
`enabled` VARCHAR(50),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
`postId` INT NOT NULL,
`postTitle` VARCHAR(50),
`content` VARCHAR(50),
`postDate` DATE,
`likeCount` INT,
`postImage` VARCHAR(50),
`userId` INT,
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`tagId` INT NOT NULL,
`tagName` VARCHAR(50),
PRIMARY KEY (`tagId`)
) CHARACTER SET latin1;
CREATE TABLE `Related` (
`tagId` INT,
`postId` INT
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`commentId` INT NOT NULL,
`content` VARCHAR(50),
`commentDate` DATE,
`postId` INT,
`userId` INT,
PRIMARY KEY (`commentId`)
) CHARACTER SET latin1;
CREATE TABLE `ContactUs` (
`contactId` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`message` VARCHAR(50),
PRIMARY KEY (`contactId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_626429_myblogsite_ddl') AS relationships;
relationships
Database: db_626429_myblogsite_ddl

Table Connections:
------------------
[Implied]  Comment.postId -> Post.postId
[Implied]  Comment.userId -> User.userId
[Implied]  Post.userId -> User.userId
[Implied]  Related.postId -> Post.postId
[Implied]  Related.tagId -> Tag.tagId

DROP DATABASE `db_626429_myblogsite_ddl`;
UNINSTALL EXTENSION vsql_schematron;
