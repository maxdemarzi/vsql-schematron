CREATE DATABASE `db_649124_db`;
USE `db_649124_db`;
CREATE TABLE `company_email` (
`email_address` VARCHAR(64),
`email_password` VARCHAR(64),
`email_smtp_address` VARCHAR(64),
`email_port` INT,
`email_starttls` INT
) CHARACTER SET latin1;
CREATE TABLE `company_login` (
`login_id` INT,
`login_username` VARCHAR(64),
`login_email` VARCHAR(64),
`login_password` VARCHAR(64),
PRIMARY KEY (`login_id`)
) CHARACTER SET latin1;
CREATE TABLE `company_users` (
`user_id` INT,
`user_name` VARCHAR(64),
`user_lastname` VARCHAR(64),
`user_cp` INT,
`user_address` VARCHAR(64),
`user_home_number` INT,
`user_phone` VARCHAR(64)
) CHARACTER SET latin1;
