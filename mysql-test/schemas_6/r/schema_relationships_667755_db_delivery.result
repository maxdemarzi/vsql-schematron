INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 667755_db_delivery
#
CREATE DATABASE `db_667755_db_delivery`;
USE `db_667755_db_delivery`;
CREATE TABLE `tb_analytics` (
`idAnalytic` INT NOT NULL,
`views` INT,
`url` VARCHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`idAnalytic`)
) CHARACTER SET latin1;
CREATE TABLE `tb_auth` (
`id_user` INT NOT NULL,
`username` VARCHAR(50),
`pass` VARCHAR(50),
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `tb_category` (
`idCategory` INT NOT NULL,
`nameCategory` VARCHAR(50),
PRIMARY KEY (`idCategory`)
) CHARACTER SET latin1;
CREATE TABLE `tb_order` (
`idOrder` INT,
`idProduct` INT,
`idSession` VARCHAR(50),
`qtd` INT,
`address` VARCHAR(50),
`district` VARCHAR(50),
`city` VARCHAR(50),
`number` INT,
`complement` VARCHAR(50),
`payment` VARCHAR(50),
`order_status` VARCHAR(50),
`created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `tb_photos` (
`idPhoto` INT,
`idProduct` INT,
`namePhoto` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_product` (
`idProduct` INT,
`idCategory` INT,
`nameProduct` VARCHAR(50),
`price` VARCHAR(50),
`description` VARCHAR(50),
`stock` INT,
`mainPhoto` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_settings` (
`idSet` INT NOT NULL,
`companyName` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`address` VARCHAR(50),
`district` VARCHAR(50),
`state` VARCHAR(50),
`number` INT,
`logo` VARCHAR(50),
PRIMARY KEY (`idSet`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_667755_db_delivery') AS relationships;
relationships
Database: db_667755_db_delivery

Table Connections:
------------------
[Implied]  tb_order.idProduct -> tb_product.idProduct
[Implied]  tb_photos.idProduct -> tb_product.idProduct
[Implied]  tb_product.idCategory -> tb_category.idCategory

DROP DATABASE `db_667755_db_delivery`;
UNINSTALL EXTENSION vsql_schematron;
