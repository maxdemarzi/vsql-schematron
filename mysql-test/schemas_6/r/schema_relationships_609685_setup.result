INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 609685_setup
#
CREATE DATABASE `db_609685_setup`;
USE `db_609685_setup`;
CREATE TABLE `users` (
`name` VARCHAR(64),
`passwordHash` VARCHAR(64),
`secret` VARCHAR(64),
`crypter` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`name` VARCHAR(64),
`author` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `passwords` (
`id` INT,
`title` VARCHAR(64),
`name` VARCHAR(64),
`mail` VARCHAR(64),
`passwordValue` VARCHAR(64),
`url` VARCHAR(64),
`backupCode` VARCHAR(64),
`notes` VARCHAR(64),
`category` INT,
`author` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_609685_setup') AS relationships;
