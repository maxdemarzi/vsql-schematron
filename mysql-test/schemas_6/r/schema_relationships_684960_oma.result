CREATE DATABASE `db_684960_oma`;
USE `db_684960_oma`;
CREATE TABLE `sys_acl` (
`id` VARCHAR(50) NOT NULL,
`create_date` DATETIME,
`creator` VARCHAR(50),
`del` VARCHAR(50),
`description` VARCHAR(50),
`order_no` INT,
`update_date` DATETIME,
`updater` VARCHAR(50),
`principal_type` VARCHAR(50),
`principal_id` VARCHAR(50),
`resource_type` VARCHAR(50),
`resource_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_group` (
`id` VARCHAR(50) NOT NULL,
`create_date` DATETIME,
`creator` VARCHAR(50),
`del` VARCHAR(50),
`description` VARCHAR(50),
`order_no` INT,
`update_date` DATETIME,
`updater` VARCHAR(50),
`group_code` VARCHAR(50),
`group_name` VARCHAR(50),
`status` VARCHAR(50),
`parent_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_module` (
`id` VARCHAR(50) NOT NULL,
`create_date` DATETIME,
`creator` VARCHAR(50),
`del` VARCHAR(50),
`description` VARCHAR(50),
`order_no` INT,
`update_date` DATETIME,
`updater` VARCHAR(50),
`code` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_role` (
`id` VARCHAR(50) NOT NULL,
`create_date` DATETIME,
`creator` VARCHAR(50),
`del` VARCHAR(50),
`description` VARCHAR(50),
`order_no` INT,
`update_date` DATETIME,
`updater` VARCHAR(50),
`role_code` VARCHAR(50),
`role_name` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sys_user_roles` (
`users_id` VARCHAR(50) NOT NULL,
`roles_id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`users_id`, `roles_id`)
) CHARACTER SET latin1;
