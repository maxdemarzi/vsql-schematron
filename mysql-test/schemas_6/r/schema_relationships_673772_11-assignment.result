INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 673772_11-assignment
#
CREATE DATABASE `db_673772_11_assignment`;
USE `db_673772_11_assignment`;
CREATE TABLE `mediatype` (
`mediatypeID` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`mediatypeID`)
) CHARACTER SET latin1;
CREATE TABLE `genre` (
`genreID` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`genreID`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
`artistID` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`artistID`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
`albumID` DECIMAL(10,2) NOT NULL,
`title` VARCHAR(50),
`artistID` DECIMAL(10,2),
PRIMARY KEY (`albumID`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
`trackID` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`albumID` DECIMAL(10,2),
`mediatypeID` DECIMAL(10,2),
`genreID` DECIMAL(10,2),
`composer` VARCHAR(50),
`milliseconds` DECIMAL(10,2),
`bytes` DECIMAL(10,2),
`unitprice` DECIMAL(10,2),
PRIMARY KEY (`trackID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_673772_11_assignment') AS relationships;
relationships
Database: db_673772_11_assignment

Table Connections:
