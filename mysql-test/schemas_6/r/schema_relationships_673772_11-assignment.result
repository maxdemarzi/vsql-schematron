[Implied]  album.artistID -> artist.artistID
[Implied]  track.albumID -> album.albumID
[Implied]  track.genreID -> genre.genreID
[Implied]  track.mediatypeID -> mediatype.mediatypeID

DROP DATABASE `db_673772_11_assignment`;
UNINSTALL EXTENSION vsql_schematron;
