CREATE DATABASE `db_622807_sample_05`;
USE `db_622807_sample_05`;
CREATE TABLE `e_authtype` (
`id` VARCHAR(50) NOT NULL,
`Value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `e_person` (
`id` VARCHAR(50) NOT NULL,
`NameFirst` VARCHAR(50),
`NameLast` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `r_person_authtype` (
`id` VARCHAR(50) NOT NULL,
`person` VARCHAR(50),
`authtype` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `r_person_phone_auth` (
`id` VARCHAR(50) NOT NULL,
`person` VARCHAR(50),
`phone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_622807_sample_05') AS relationships;
