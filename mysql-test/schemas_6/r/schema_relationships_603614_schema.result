CREATE DATABASE `db_603614_schema`;
USE `db_603614_schema`;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`nome_usuario` VARCHAR(50),
`senha` VARCHAR(50),
`nome` VARCHAR(50),
`ultimo_acesso` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entrada` (
`id` INT NOT NULL,
`horario` DATETIME,
`descricao` VARCHAR(50),
`prioridade` CHAR(50),
`id_usuario` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_603614_schema') AS relationships;
