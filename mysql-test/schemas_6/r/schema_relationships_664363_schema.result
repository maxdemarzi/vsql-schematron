INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 664363_schema
#
CREATE DATABASE `db_664363_schema`;
USE `db_664363_schema`;
CREATE TABLE `projects` (
`id` VARCHAR(50) NOT NULL,
`github_id` INT,
`name` VARCHAR(50),
`full_name` VARCHAR(50),
`description` TEXT,
`language` VARCHAR(50),
`git_url` VARCHAR(50),
`watcher_count` INT,
`stars_count` INT,
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
`id` VARCHAR(50) NOT NULL,
`github_id` INT,
`project_id` VARCHAR(50),
`number` INT,
`title` VARCHAR(50),
`body` VARCHAR(50),
`user` VARCHAR(50),
`state` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` VARCHAR(50) NOT NULL,
`github_id` INT,
`issue_id` VARCHAR(50),
`body` TEXT,
`user` VARCHAR(50),
`created_at` VARCHAR(50),
`updated_at` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_664363_schema') AS relationships;
relationships
