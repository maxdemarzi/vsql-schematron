INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 672881_mfs
#
CREATE DATABASE `db_672881_mfs`;
USE `db_672881_mfs`;
CREATE TABLE `cart` (
`id` INT,
`user_id` INT,
`product_id` INT,
`product_type` VARCHAR(255),
`product_name` VARCHAR(255),
`product_rate` INT,
`quantity` INT,
`image` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `order_product` (
`id` INT,
`user_id` INT,
`product_id` INT,
`email` VARCHAR(255),
`delivery_address` VARCHAR(255),
`mobile_number` INT,
`order_date` DATETIME,
`qty` INT,
`rate` INT
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`pname` VARCHAR(255),
`ptype` VARCHAR(255),
`rate` VARCHAR(255),
`details` VARCHAR(255),
`image` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `register` (
`id` INT,
`fname` VARCHAR(255),
`lname` VARCHAR(255),
`email` VARCHAR(255),
`address` VARCHAR(255),
`phone` VARCHAR(255),
`password` VARCHAR(255),
`type` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_672881_mfs') AS relationships;
