INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 652547_machine_storage
#
CREATE DATABASE `db_652547_machine_storage`;
USE `db_652547_machine_storage`;
CREATE TABLE `engine` (
`id` INT NOT NULL,
`engine_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
`id` INT NOT NULL,
`trans_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
`id` INT NOT NULL,
`model` VARCHAR(50),
`car_body_id` INT,
`engine_id` INT,
`transmission_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_652547_machine_storage') AS relationships;
relationships
