CREATE DATABASE `db_615072_hw02q02`;
USE `db_615072_hw02q02`;
CREATE TABLE `ACTORS` (
`actor_id` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`nationality` VARCHAR(50),
PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;
CREATE TABLE `MOVIES` (
`movie_id` DECIMAL(10,2) NOT NULL,
`title` VARCHAR(50),
`year` DECIMAL(10,2),
`studio` VARCHAR(50),
PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;
CREATE TABLE `STARSIN` (
`actor_id` DECIMAL(10,2) NOT NULL,
`movie_id` DECIMAL(10,2) NOT NULL,
`character` VARCHAR(50),
PRIMARY KEY (`actor_id`, `movie_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_615072_hw02q02') AS relationships;
