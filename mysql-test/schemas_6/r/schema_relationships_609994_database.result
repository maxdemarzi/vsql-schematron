INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 609994_database
#
CREATE DATABASE `db_609994_database`;
USE `db_609994_database`;
CREATE TABLE `Order` (
`Oid` INT NOT NULL,
`Uid` INT,
`Pid` INT,
`Canceled` BOOLEAN,
PRIMARY KEY (`Oid`)
) CHARACTER SET latin1;
CREATE TABLE `Notification` (
`Oid` INT,
`Received` BOOLEAN,
`NotiDate` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Seats` (
`Oid` INT,
`SeatNo` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_609994_database') AS relationships;
relationships
