`job_title` VARCHAR(64),
`description` VARCHAR(64),
`reference` VARCHAR(64),
`exp_date` DATETIME,
`job_zone` VARCHAR(64),
`training` VARCHAR(64),
`contract_type` VARCHAR(64),
`published_at` DATETIME,
`salary` INT,
`sector` VARCHAR(64),
`study_level_required` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job_seeker` (
`id` INT,
`roles` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`gender` VARCHAR(64),
`birthday_date` DATETIME,
`address` VARCHAR(64),
`mobility` VARCHAR(64),
`handicap` INT,
`diploma` VARCHAR(64),
`skills` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `search_bar` (
`id` INT,
`search_content` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
