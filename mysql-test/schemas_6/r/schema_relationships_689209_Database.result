INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 689209_Database
#
CREATE DATABASE `db_689209_Database`;
USE `db_689209_Database`;
CREATE TABLE `CONVENIO` (
`CID` VARCHAR(50) NOT NULL,
`CNOME` VARCHAR(50),
`CATIVADO` VARCHAR(50),
PRIMARY KEY (`CID`)
) CHARACTER SET latin1;
CREATE TABLE `CONVENIO_PLANOS` (
`CPID` VARCHAR(50) NOT NULL,
`CPNOME` VARCHAR(50),
`CID` VARCHAR(50),
`CPATIVADO` VARCHAR(50),
PRIMARY KEY (`CPID`)
) CHARACTER SET latin1;
CREATE TABLE `HOSPITAIS` (
`HID` VARCHAR(50) NOT NULL,
`HNOME` VARCHAR(50),
`HUF` CHAR(50),
`HCIDADE` VARCHAR(50),
`HCEP` CHAR(50),
`HENDERECO` VARCHAR(50),
`HCOMPLEMENTO` VARCHAR(50),
`HTELEFONE` VARCHAR(50),
`HISPRONTOSOCORRO` TINYINT,
`HATIVADO` VARCHAR(50),
PRIMARY KEY (`HID`)
) CHARACTER SET latin1;
CREATE TABLE `HOSPITAIS_PLANOS_CONVENIOS` (
`CPID` VARCHAR(50),
`HID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `MEDICOS` (
`MID` VARCHAR(50) NOT NULL,
`MNOME` VARCHAR(50),
`EID` VARCHAR(50),
`HID` VARCHAR(50),
`MATIVADO` VARCHAR(50),
PRIMARY KEY (`MID`)
) CHARACTER SET latin1;
CREATE TABLE `HOSPITAIS_FAVORITOS` (
`HID` VARCHAR(50),
`UID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `DEPENDENTES` (
`DID` VARCHAR(50) NOT NULL,
`UID` VARCHAR(50),
`DNOME` VARCHAR(50),
`DNASCIMENTO` DATE,
`DSEXO` VARCHAR(50),
`DATIVADO` VARCHAR(50),
PRIMARY KEY (`DID`)
) CHARACTER SET latin1;
CREATE TABLE `AGENDAMENTOS` (
`AID` VARCHAR(50) NOT NULL,
`UID` VARCHAR(50),
`DID` VARCHAR(50),
`MID` VARCHAR(50),
`ADATA` DATETIME,
`AATIVADO` VARCHAR(50),
PRIMARY KEY (`AID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_689209_Database') AS relationships;
relationships
Database: db_689209_Database

Table Connections:
