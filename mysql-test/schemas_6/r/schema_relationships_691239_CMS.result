INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 691239_CMS
#
CREATE DATABASE `db_691239_CMS`;
USE `db_691239_CMS`;
CREATE TABLE `admins` (
`adminID` VARCHAR(64),
`adminName` VARCHAR(64),
`adminPassword` VARCHAR(64),
PRIMARY KEY (`adminID`)
) CHARACTER SET latin1;
CREATE TABLE `assetsUnit` (
`assetsUnitID` INT,
`managerID` INT,
`assetsUnitShortname` VARCHAR(64),
`assetsBalance` DECIMAL(10,2),
PRIMARY KEY (`assetsUnitID`, `managerID`)
) CHARACTER SET latin1;
CREATE TABLE `assetsunitmanager` (
`managerID` INT,
`managerNname` VARCHAR(64),
`managerShortname` VARCHAR(64),
`managerState` VARCHAR(64),
PRIMARY KEY (`managerID`)
) CHARACTER SET latin1;
CREATE TABLE `cms` (
`numberID` VARCHAR(64),
`name` VARCHAR(64),
`nickname` VARCHAR(64),
`password` VARCHAR(64),
`ID` VARCHAR(64),
`phone` DECIMAL(10,2),
`belong` VARCHAR(64),
`user_number` VARCHAR(64),
`role` DECIMAL(10,2),
`status` VARCHAR(64),
PRIMARY KEY (`numberID`)
) CHARACTER SET latin1;
CREATE TABLE `connection` (
`adminID` VARCHAR(64),
`operatorID` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `log` (
`adminID` VARCHAR(64),
`userID` VARCHAR(64),
`role` VARCHAR(64),
`time` VARCHAR(64),
`way` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `operators` (
`operatorID` VARCHAR(64),
`operatorName` VARCHAR(64),
`operatorNickname` VARCHAR(64),
`operatorPassword` VARCHAR(64),
`operatorPhone` VARCHAR(64),
`ID` VARCHAR(64),
`operatorRole` VARCHAR(64),
`operatorStatus` VARCHAR(64),
`assetID` INT,
`tradeID` INT,
PRIMARY KEY (`operatorID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_691239_CMS') AS relationships;
relationships
Database: db_691239_CMS

Table Connections:
