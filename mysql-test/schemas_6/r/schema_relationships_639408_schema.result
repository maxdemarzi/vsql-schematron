INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 639408_schema
#
CREATE DATABASE `db_639408_schema`;
USE `db_639408_schema`;
CREATE TABLE `review` (
`id` INT,
`product_id` INT,
`rating` INT,
`date` INT,
`summary` VARCHAR(255),
`body` VARCHAR(255),
`recommend` VARCHAR(255),
`reported` VARCHAR(255),
`reviewer_name` VARCHAR(255),
`reviewer_email` VARCHAR(255),
`response` VARCHAR(255),
`helpfulness` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviewPhotos` (
`id` INT,
`review_id` INT,
`url` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characteristics` (
`id` INT,
`product_id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characteristic_reviews` (
`id` INT,
`characteristic_id` INT,
`review_id` INT,
`value` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_639408_schema') AS relationships;
relationships
Database: db_639408_schema

Table Connections:
