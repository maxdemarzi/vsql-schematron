CREATE DATABASE `db_612170_V1_1_2_Initialize_Spring_Batch_tables`;
USE `db_612170_V1_1_2_Initialize_Spring_Batch_tables`;
CREATE TABLE `batch.JOB_INSTANCE` (
`JOB_INSTANCE_ID` INT,
`VERSION` INT,
`JOB_NAME` VARCHAR(64),
`JOB_KEY` VARCHAR(64),
PRIMARY KEY (`JOB_INSTANCE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `batch.JOB_EXECUTION` (
`JOB_EXECUTION_ID` INT,
`VERSION` INT,
`JOB_INSTANCE_ID` INT,
`CREATE_TIME` DATETIME,
`START_TIME` DATETIME,
`END_TIME` DATETIME,
`STATUS` VARCHAR(64),
`EXIT_CODE` VARCHAR(64),
`EXIT_MESSAGE` VARCHAR(64),
`LAST_UPDATED` DATETIME,
`JOB_CONFIGURATION_LOCATION` VARCHAR(64),
PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `batch.JOB_EXECUTION_PARAMS` (
`JOB_EXECUTION_ID` INT,
`TYPE_CD` VARCHAR(64),
`KEY_NAME` VARCHAR(64),
`STRING_VAL` VARCHAR(64),
`DATE_VAL` DATETIME,
`LONG_VAL` INT,
`DOUBLE_VAL` DECIMAL(10,2),
`IDENTIFYING` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `batch.STEP_EXECUTION` (
`STEP_EXECUTION_ID` INT,
`VERSION` INT,
`STEP_NAME` VARCHAR(64),
`JOB_EXECUTION_ID` INT,
`START_TIME` DATETIME,
`END_TIME` DATETIME,
`STATUS` VARCHAR(64),
`COMMIT_COUNT` INT,
`READ_COUNT` INT,
`FILTER_COUNT` INT,
`WRITE_COUNT` INT,
`READ_SKIP_COUNT` INT,
`WRITE_SKIP_COUNT` INT,
`PROCESS_SKIP_COUNT` INT,
`ROLLBACK_COUNT` INT,
`EXIT_CODE` VARCHAR(64),
`EXIT_MESSAGE` VARCHAR(64),
`LAST_UPDATED` DATETIME,
PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `batch.STEP_EXECUTION_CONTEXT` (
`STEP_EXECUTION_ID` INT,
`SHORT_CONTEXT` VARCHAR(64),
`SERIALIZED_CONTEXT` VARCHAR(64),
PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `batch.JOB_EXECUTION_CONTEXT` (
`JOB_EXECUTION_ID` INT,
`SHORT_CONTEXT` VARCHAR(64),
`SERIALIZED_CONTEXT` VARCHAR(64),
PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;
