INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 641561_schema
#
CREATE DATABASE `db_641561_schema`;
USE `db_641561_schema`;
CREATE TABLE `user` (
`id` INT,
`name` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`image_url` VARCHAR(64),
`created_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exam` (
`id` INT,
`course_id` INT,
`number` VARCHAR(64),
`text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exam_answer` (
`id` INT,
`exam_id` INT,
`label` VARCHAR(64),
`text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exam_progress` (
`id` INT,
`exam_id` INT,
`exam_answer_id` INT,
`answer_by` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exam_solution` (
`id` INT,
`exam_id` INT,
`exam_answer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_641561_schema') AS relationships;
relationships
Database: db_641561_schema

Table Connections:
