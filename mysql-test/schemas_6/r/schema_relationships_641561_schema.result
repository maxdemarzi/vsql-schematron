[Implied]  course.created_by -> user.id
[Implied]  exam.course_id -> course.id
[Implied]  exam_answer.exam_id -> exam.id
[Implied]  exam_progress.answer_by -> exam_answer.id
[Implied]  exam_progress.answer_by -> user.id
[Implied]  exam_progress.exam_answer_id -> exam_answer.id
[Implied]  exam_progress.exam_id -> exam.id
[Implied]  exam_solution.exam_answer_id -> exam_answer.id
[Implied]  exam_solution.exam_id -> exam.id

DROP DATABASE `db_641561_schema`;
UNINSTALL EXTENSION vsql_schematron;
