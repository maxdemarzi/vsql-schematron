INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 605675_ddl
#
CREATE DATABASE `db_605675_ddl`;
USE `db_605675_ddl`;
CREATE TABLE `book` (
`id` INT,
`ISBN` VARCHAR(64),
`Name` VARCHAR(64),
`Author` VARCHAR(64),
`Price` VARCHAR(64),
`Description` VARCHAR(64),
`Link` VARCHAR(64),
`PicturePath` VARCHAR(64),
`IsRentedOut` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`Name` VARCHAR(64),
`Birthday` DATETIME,
`Gender` VARCHAR(64),
`Email` VARCHAR(64),
`Telno` VARCHAR(64),
`PicturePath` VARCHAR(64),
`CanRent` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookrental` (
`ID` INT,
`UserId` INT,
`BookId` INT,
`RentalDate` DATETIME,
`ReturnDate` DATETIME,
`isRentOut` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `leaveduser` (
`id` INT,
`Name` VARCHAR(64),
`Birthday` DATETIME,
`Gender` VARCHAR(64),
`Email` VARCHAR(64),
`Telno` VARCHAR(64),
`PicturePath` VARCHAR(64),
`LeaveDate` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605675_ddl') AS relationships;
relationships
Database: db_605675_ddl

Table Connections:
------------------
[Implied]  bookrental.BookId -> book.id
[Implied]  bookrental.UserId -> user.id
[Implied]  user.id -> leaveduser.id

DROP DATABASE `db_605675_ddl`;
UNINSTALL EXTENSION vsql_schematron;
