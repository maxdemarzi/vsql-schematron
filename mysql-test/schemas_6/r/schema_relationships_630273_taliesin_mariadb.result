`tic_id` INT,
PRIMARY KEY (`tpl_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_playlist_element` (
`tpe_id` INT,
`tpl_id` INT,
`tm_id` INT,
PRIMARY KEY (`tpe_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_media_history` (
