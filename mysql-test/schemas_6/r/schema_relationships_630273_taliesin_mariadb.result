`tic_cover_original` VARCHAR(255),
`tic_cover_thumbnail` VARCHAR(255),
`tic_fingerprint` VARCHAR(255),
PRIMARY KEY (`tic_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_folder` (
`tf_id` INT,
`tds_id` INT,
`tf_name` VARCHAR(255),
`tf_path` VARCHAR(255),
`tf_parent_id` INT,
`tf_refresh_status` INT,
`tic_id` INT,
PRIMARY KEY (`tf_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_media` (
`tm_id` INT,
`tds_id` INT,
`tm_name` VARCHAR(255),
`tm_path` VARCHAR(255),
`tm_duration` INT,
`tf_id` INT,
`tm_type` VARCHAR(255),
`tm_last_updated` DATETIME,
`tm_refresh_status` INT,
`tic_id` INT,
PRIMARY KEY (`tm_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_meta_data` (
`tmd_id` INT,
`tm_id` INT,
`tmd_key` VARCHAR(255),
`tmd_value` VARCHAR(255),
`tmd_internal` INT,
PRIMARY KEY (`tmd_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_playlist` (
`tpl_id` INT,
`tpl_username` VARCHAR(255),
`tpl_name` VARCHAR(255),
