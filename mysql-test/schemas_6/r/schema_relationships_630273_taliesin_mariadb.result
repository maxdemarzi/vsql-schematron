CREATE DATABASE `db_630273_taliesin_mariadb`;
USE `db_630273_taliesin_mariadb`;
CREATE TABLE `t_data_source` (
`tds_id` INT,
`tds_username` VARCHAR(255),
`tds_name` VARCHAR(255),
`tds_description` VARCHAR(255),
`tds_path` VARCHAR(255),
`tds_icon` VARCHAR(255),
`tds_last_updated` DATETIME,
`tds_refresh_status` INT,
PRIMARY KEY (`tds_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_image_cover` (
`tic_id` INT,
