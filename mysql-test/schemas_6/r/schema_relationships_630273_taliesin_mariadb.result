`ts_channels` INT,
`ts_sample_rate` INT,
`ts_bitrate` INT,
PRIMARY KEY (`ts_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_stream_element` (
`tse_id` INT,
`ts_id` INT,
`tm_id` INT,
PRIMARY KEY (`tse_id`)
) CHARACTER SET latin1;
