INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 635510_db_aeroclube
#
CREATE DATABASE `db_635510_db_aeroclube`;
USE `db_635510_db_aeroclube`;
CREATE TABLE `tb_socio` (
`id_socio` INT NOT NULL,
`nome_socio` VARCHAR(50),
`end_socio` VARCHAR(50),
`email_socio` VARCHAR(50),
`idade_socio` INT,
PRIMARY KEY (`id_socio`)
) CHARACTER SET latin1;
CREATE TABLE `tb_telefone` (
`id_telefone` INT NOT NULL,
`id_socio` INT,
`ddd_telefone` INT,
`nm_telefone` INT,
PRIMARY KEY (`id_telefone`)
) CHARACTER SET latin1;
CREATE TABLE `tb_alunos` (
`id_aluno` INT NOT NULL,
`id_socio` INT,
PRIMARY KEY (`id_aluno`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pilotos` (
`id_piloto` INT NOT NULL,
`id_socio` INT,
`nm_breve_piloto` BIGINT,
PRIMARY KEY (`id_piloto`)
) CHARACTER SET latin1;
CREATE TABLE `tb_formacao` (
`id_formacao` INT NOT NULL,
`id_piloto` INT,
`nome_curso_formacao` VARCHAR(50),
`dt_diploma_formacao` DATE,
`instituicao_formacao` VARCHAR(50),
PRIMARY KEY (`id_formacao`)
) CHARACTER SET latin1;
CREATE TABLE `tb_aula` (
`id_aula` INT NOT NULL,
`id_aluno` INT,
`dt_aula` DATE,
`id_formacao` INT,
`hr_saida_aula` VARCHAR(50),
`hr_chegada_aula` VARCHAR(50),
`parecer_inst_aula` VARCHAR(50),
PRIMARY KEY (`id_aula`)
) CHARACTER SET latin1;
CREATE TABLE `tb_contato` (
`id_contato` INT NOT NULL,
`nome_contato` VARCHAR(50),
`email_contato` VARCHAR(50),
`nm_celular_contato` BIGINT,
`mensagem_contato` VARCHAR(50),
PRIMARY KEY (`id_contato`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_635510_db_aeroclube') AS relationships;
relationships
Database: db_635510_db_aeroclube

