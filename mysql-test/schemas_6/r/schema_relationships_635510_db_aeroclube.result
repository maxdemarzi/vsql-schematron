[Implied]  tb_formacao.id_piloto -> tb_pilotos.id_piloto
[Implied]  tb_pilotos.id_socio -> tb_socio.id_socio
[Implied]  tb_telefone.id_socio -> tb_socio.id_socio

DROP DATABASE `db_635510_db_aeroclube`;
