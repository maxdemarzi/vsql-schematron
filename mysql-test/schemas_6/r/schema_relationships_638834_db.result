) CHARACTER SET latin1;
CREATE TABLE `answer` (
`id` INT,
`question_id` INT,
`text` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`email` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_quiz` (
`user_id` INT,
`quiz_id` INT,
`score` INT
) CHARACTER SET latin1;
