INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 640215_schema
#
CREATE DATABASE `db_640215_schema`;
USE `db_640215_schema`;
CREATE TABLE `menu` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`category` VARCHAR(50),
`short_description` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dish` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`prep_time` VARCHAR(50),
`total_time` VARCHAR(50),
`servings` INT,
`yield` INT,
`menu_fk_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredient` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`quantity` INT,
`measurment_unit` VARCHAR(50),
`measurment_descriptor` VARCHAR(50),
`dish_fk_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `directions` (
`id` INT NOT NULL,
`order_number` INT,
`description` VARCHAR(50),
`dish_fk_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_640215_schema') AS relationships;
relationships
Database: db_640215_schema

Table Connections:
------------------
[Implied]  directions.dish_fk_id -> dish.id
[Implied]  dish.menu_fk_id -> menu.id
[Implied]  ingredient.dish_fk_id -> dish.id

DROP DATABASE `db_640215_schema`;
UNINSTALL EXTENSION vsql_schematron;
