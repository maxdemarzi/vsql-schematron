INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 644192_db_pos
#
CREATE DATABASE `db_644192_db_pos`;
USE `db_644192_db_pos`;
CREATE TABLE `karyawans` (
`id` VARCHAR(50) NOT NULL,
`nip` VARCHAR(50),
`password` VARCHAR(50),
`nama` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pakets` (
`id` VARCHAR(50) NOT NULL,
`tanggal_datang` DATE,
`penghunis_id` VARCHAR(50),
`karyawans_id` VARCHAR(50),
`isi_paket` TEXT,
`tanggal_ambil` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penghunis` (
`id` VARCHAR(50) NOT NULL,
`nama` VARCHAR(50),
`foto` VARCHAR(50),
`unit` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_644192_db_pos') AS relationships;
