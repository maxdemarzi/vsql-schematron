INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 602494_init
#
CREATE DATABASE `db_602494_init`;
USE `db_602494_init`;
CREATE TABLE `data` (
`data_id` INT,
`label` INT,
PRIMARY KEY (`data_id`)
) CHARACTER SET latin1;
CREATE TABLE `attr` (
`data_id` INT,
`attr_id` INT,
`val` DECIMAL(10,2),
PRIMARY KEY (`data_id`, `attr_id`)
) CHARACTER SET latin1;
CREATE TABLE `model` (
`attr_id` DECIMAL(10,2),
`val` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_602494_init') AS relationships;
relationships
