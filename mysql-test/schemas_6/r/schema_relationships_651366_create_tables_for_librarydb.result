CREATE DATABASE `db_651366_create_tables_for_librarydb`;
USE `db_651366_create_tables_for_librarydb`;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
`enabled` BOOLEAN,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`book_id` INT NOT NULL,
`name` VARCHAR(50),
`isbn` VARCHAR(50),
`author` VARCHAR(50),
`date_released` DATE,
`published_by` VARCHAR(50),
PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `books_lent` (
`lent_id` INT NOT NULL,
`user_id` INT,
`book_id` INT,
`lent_from` DATE,
`lent_until` DATE,
PRIMARY KEY (`lent_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_651366_create_tables_for_librarydb') AS relationships;
