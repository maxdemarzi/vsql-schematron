CREATE DATABASE `db_648451_V1_0_0_create_tables`;
USE `db_648451_V1_0_0_create_tables`;
CREATE TABLE `movie` (
`id` INT,
`title` VARCHAR(64),
`imdb_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`role` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room` (
`id` INT,
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_room` (
`movie_id` INT,
`room_id` INT,
`price` DECIMAL(10,2),
`time` VARCHAR(64),
PRIMARY KEY (`movie_id`, `room_id`)
) CHARACTER SET latin1;
CREATE TABLE `review` (
`id` INT,
`rate` DECIMAL(10,2),
`comment` VARCHAR(64),
`movie_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reservation` (
`id` INT,
`ticket_number` INT,
`user_id` INT,
`movie_id` INT,
`room_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_648451_V1_0_0_create_tables') AS relationships;
