CREATE DATABASE `db_608882_migration`;
USE `db_608882_migration`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`email` TEXT,
`password` TEXT,
`name` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`title` VARCHAR(50),
`content` TEXT,
`published` BOOLEAN,
`authorId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Like` (
`id` VARCHAR(50) NOT NULL,
`userId` TEXT,
`postId` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Token` (
`id` VARCHAR(50) NOT NULL,
`userId` TEXT,
`token` TEXT,
`type` VARCHAR(50),
`ExpiresAt` INT,
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
