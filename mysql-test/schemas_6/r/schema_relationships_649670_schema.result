INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 649670_schema
#
CREATE DATABASE `db_649670_schema`;
USE `db_649670_schema`;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`dept_head_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `designation` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
`department_id` INT,
`designation_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_649670_schema') AS relationships;
relationships
