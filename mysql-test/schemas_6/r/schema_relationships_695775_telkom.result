INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 695775_telkom
#
CREATE DATABASE `db_695775_telkom`;
USE `db_695775_telkom`;
CREATE TABLE `admin` (
`id_admin` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
PRIMARY KEY (`id_admin`)
) CHARACTER SET latin1;
CREATE TABLE `data_cacti` (
`nomor` INT,
`status` INT,
PRIMARY KEY (`nomor`)
) CHARACTER SET latin1;
CREATE TABLE `data_karyawan` (
`id_karyawan` INT,
`nama` VARCHAR(255),
`posisi_kerja` VARCHAR(255),
`telp` VARCHAR(255),
`shift_kerja` VARCHAR(255),
`Alamat` VARCHAR(255),
`email` VARCHAR(255),
`status_user` INT,
PRIMARY KEY (`id_karyawan`)
) CHARACTER SET latin1;
CREATE TABLE `data_latlng` (
`id` INT,
`Nama` VARCHAR(255),
`Lat` DECIMAL(10,2),
`Lng` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `data_rating` (
`id_rating` INT,
`id_karyawan` INT,
`points` INT
) CHARACTER SET latin1;
CREATE TABLE `login` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`nama` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`idUser` INT,
`idKaryawan` INT,
`tgl_daftar` DATETIME,
`status` VARCHAR(255),
`username` VARCHAR(255),
`password` VARCHAR(255),
`kategori_user` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_695775_telkom') AS relationships;
relationships
