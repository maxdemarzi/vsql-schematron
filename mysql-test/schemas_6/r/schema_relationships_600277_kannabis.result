) CHARACTER SET latin1;
CREATE TABLE `business_trips` (
`id` INT,
`bt_group_id` INT,
`start_date` DATETIME,
`finish_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
