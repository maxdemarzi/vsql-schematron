`text_complaints` VARCHAR(64),
`comp_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`prod_name` VARCHAR(64),
`agronom_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_items` (
`product_id` INT,
`hemp_id` INT
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`customer_id` INT,
`agronom_id` INT,
`order_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
