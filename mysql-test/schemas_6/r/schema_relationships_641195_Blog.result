INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 641195_Blog
#
CREATE DATABASE `db_641195_Blog`;
USE `db_641195_Blog`;
CREATE TABLE `Author` (
`AuthorId` BIGINT NOT NULL,
`AuthorName` VARCHAR(50),
PRIMARY KEY (`AuthorId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
`PostId` BIGINT NOT NULL,
`AuthorId` BIGINT,
`TopicId` BIGINT,
PRIMARY KEY (`PostId`)
) CHARACTER SET latin1;
CREATE TABLE `Topic` (
`TopicId` BIGINT NOT NULL,
`TopicName` VARCHAR(50),
`ParentTopicId` BIGINT,
PRIMARY KEY (`TopicId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_641195_Blog') AS relationships;
relationships
