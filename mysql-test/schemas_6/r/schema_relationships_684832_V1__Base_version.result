CREATE DATABASE `db_684832_V1__Base_version`;
USE `db_684832_V1__Base_version`;
CREATE TABLE `Backers` (
`id` BIGINT NOT NULL,
`playerId` BIGINT,
`supportPlayerId` BIGINT,
`tournamentId` BIGINT,
`share` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Players` (
`id` BIGINT NOT NULL,
`playerName` TEXT,
`points` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Status` (
`id` BIGINT NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TournamentPlayers` (
`id` BIGINT NOT NULL,
`playerId` BIGINT,
`tournamentId` BIGINT,
`share` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tournaments` (
`id` BIGINT NOT NULL,
`tournamentNumber` BIGINT,
`deposit` DECIMAL(10,2),
`statusId` BIGINT,
`winnerId` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_684832_V1__Base_version') AS relationships;
