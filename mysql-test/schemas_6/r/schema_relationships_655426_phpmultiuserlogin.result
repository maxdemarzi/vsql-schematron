CREATE DATABASE `db_655426_phpmultiuserlogin`;
USE `db_655426_phpmultiuserlogin`;
CREATE TABLE `announcement` (
`id` INT NOT NULL,
`message` VARCHAR(50),
`date` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `centre_of_studies` (
`id` INT,
`cos_name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
`id` INT NOT NULL,
`doc_name` VARCHAR(50),
`doc_sender` VARCHAR(50),
`doc_responsibility` VARCHAR(50),
`doc_kulliyah` VARCHAR(50),
`doc_description` VARCHAR(50),
`doc_receive` DATETIME,
`doc_due` DATETIME,
`doc_location` VARCHAR(50),
`doc_attention` VARCHAR(50),
`doc_characteristic` VARCHAR(50),
`doc_status` VARCHAR(50),
`doc_comment` VARCHAR(50),
`owner` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `doc_category` (
`doc_cat_id` INT,
`doc_cat_name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
`id` INT,
`doc_id` INT,
`date_logged` TIMESTAMP NULL,
`doc_name` VARCHAR(50),
`doc_sender` VARCHAR(50),
`doc_responsibility` VARCHAR(50),
`doc_kulliyah` VARCHAR(50),
`doc_description` VARCHAR(50),
`doc_receive` DATETIME,
`doc_due` DATETIME,
`doc_location` VARCHAR(50),
`doc_attention` VARCHAR(50),
`doc_characteristic` VARCHAR(50),
`doc_status` VARCHAR(50),
`doc_comment` VARCHAR(50),
`owner` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(50),
`login` VARCHAR(50),
`password` VARCHAR(50),
`role` INT,
`role_name` VARCHAR(50),
`staff_id` VARCHAR(50)
) CHARACTER SET latin1;
