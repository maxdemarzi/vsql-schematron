CREATE DATABASE `db_671390_Datos`;
USE `db_671390_Datos`;
CREATE TABLE `CARRERAS` (
`CODIGO` DECIMAL(10,2),
`NOMBRE` VARCHAR(64),
`TITULO` VARCHAR(64),
PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `CURSOS` (
`CODIGO` DECIMAL(10,2),
`NOMBRE` VARCHAR(64),
`CREDITOS` DECIMAL(10,2),
`HORAS` DECIMAL(10,2),
PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `CARRERACURSOS` (
`CODCARRERA` DECIMAL(10,2),
`CODCURSOS` DECIMAL(10,2),
`ANO` VARCHAR(64),
`CICLO` VARCHAR(64)
) CHARACTER SET latin1;
