INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 659094_Create_Bike_Rental_Database
#
CREATE DATABASE `db_659094_Create_Bike_Rental_Database`;
USE `db_659094_Create_Bike_Rental_Database`;
CREATE TABLE `CUSTOMER` (
`DL_NUMBER` VARCHAR(64),
`FNAME` VARCHAR(64),
`MNAME` VARCHAR(64),
`LNAME` VARCHAR(64),
`PHONE_NUMBER` DECIMAL(10,2),
`EMAIL_ID` VARCHAR(64),
`STREET` VARCHAR(64),
`CITY` VARCHAR(64),
`STATE_NAME` VARCHAR(64),
`ZIPCODE` DECIMAL(10,2),
`MEMBERSHIP_TYPE` VARCHAR(64),
`MEMBERSHIP_ID` VARCHAR(64),
PRIMARY KEY (`DL_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `BIKE_CATEGORY` (
`CATEGORY_NAME` VARCHAR(64),
`COST_PER_DAY` DECIMAL(10,2),
`LATE_FEE_PER_HOUR` DECIMAL(10,2),
PRIMARY KEY (`CATEGORY_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `LOCATION` (
`LOCATION_ID` VARCHAR(64),
`LOCATION_NAME` VARCHAR(64),
`STREET` VARCHAR(64),
`CITY` VARCHAR(64),
`STATE_NAME` VARCHAR(64),
`ZIPCODE` DECIMAL(10,2),
PRIMARY KEY (`LOCATION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BIKE` (
`REGISTRATION_NUMBER` VARCHAR(64),
`MODEL_NAME` VARCHAR(64),
`MAKE` VARCHAR(64),
`MODEL_YEAR` DECIMAL(10,2),
`MILEAGE` INT,
`BIKE_CATEGORY_NAME` VARCHAR(64),
`LOC_ID` VARCHAR(64),
`AVAILABILITY_FLAG` VARCHAR(64),
PRIMARY KEY (`REGISTRATION_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `DISCOUNT` (
`DISCOUNT_CODE` VARCHAR(64),
`DISCOUNT_NAME` VARCHAR(64),
`EXPIRY_DATE` DATETIME,
`DISCOUNT_PERCENTAGE` DECIMAL(10,2),
PRIMARY KEY (`DISCOUNT_CODE`)
) CHARACTER SET latin1;
CREATE TABLE `INSURANCE` (
`INSURANCE_CODE` VARCHAR(64),
`INSURANCE_NAME` VARCHAR(64),
`COVERAGE_TYPE` VARCHAR(64),
`COST_PER_DAY` DECIMAL(10,2),
PRIMARY KEY (`INSURANCE_CODE`)
) CHARACTER SET latin1;
CREATE TABLE `BOOKING` (
`BOOKING_ID` VARCHAR(64),
`FROM_DT_TIME` DATETIME,
`RET_DT_TIME` DATETIME,
`AMOUNT` DECIMAL(10,2),
`BOOKING_STATUS` VARCHAR(64),
`PICKUP_LOC` VARCHAR(64),
`DROP_LOC` VARCHAR(64),
`REG_NUM` VARCHAR(64),
`DL_NUM` VARCHAR(64),
`INS_CODE` VARCHAR(64),
`ACT_RET_DT_TIME` DATETIME,
`DISCOUNT_CODE` VARCHAR(64),
PRIMARY KEY (`BOOKING_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BILLING` (
`BILL_ID` VARCHAR(64),
`BILL_DATE` DATETIME,
`BILL_STATUS` VARCHAR(64),
`DISCOUNT_AMOUNT` DECIMAL(10,2),
`TOTAL_AMOUNT` DECIMAL(10,2),
`TAX_AMOUNT` DECIMAL(10,2),
`BOOKING_ID` VARCHAR(64),
`TOTAL_LATE_FEE` DECIMAL(10,2),
PRIMARY KEY (`BILL_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_659094_Create_Bike_Rental_Database') AS relationships;
relationships
