`task2` INT,
`task3` INT,
`test1` INT,
`test2` INT,
`id_stud` INT,
`id_class` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_pembagian_kelas` (
`id` INT,
`id_class` INT,
`id_student` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_siswa` (
`id` INT,
`nik` VARCHAR(64),
`name` VARCHAR(64),
`date_of_birth` DATETIME,
`gender` VARCHAR(64),
`school` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`image` VARCHAR(64),
`father_name` VARCHAR(64),
`father_occup` VARCHAR(64),
`father_phone` VARCHAR(64),
`mother_name` VARCHAR(64),
`mother_occup` VARCHAR(64),
`mother_phone` VARCHAR(64),
`parent_add` VARCHAR(64),
`date_of_register` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_staff` (
`id` INT,
`nik` INT,
`name` VARCHAR(64),
`code` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
