) CHARACTER SET latin1;
CREATE TABLE `tb_teacher` (
`id` INT,
`nik` INT,
`name` VARCHAR(64),
`code` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`image` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tb_user` (
`code` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`role_id` INT
) CHARACTER SET latin1;
