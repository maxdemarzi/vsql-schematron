CREATE DATABASE `db_676991_db_sirkus`;
USE `db_676991_db_sirkus`;
CREATE TABLE `tb_absen` (
`id` INT,
`id_stud` INT,
`attend` VARCHAR(64),
`date` DATETIME,
`id_class` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_jadwal` (
`id` INT,
`class` VARCHAR(64),
`day` VARCHAR(64),
`time` DATETIME,
`id_teacher` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_nilai` (
`id` INT,
