INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 640901_database
#
CREATE DATABASE `db_640901_database`;
USE `db_640901_database`;
CREATE TABLE `CULTIVO` (
`ID_CULTIVO` INT,
`ESTADO_CULTIVO` VARCHAR(64),
`NOMBRE_CULTIVO` VARCHAR(64),
`DENSIDAD_SIEMBRA_CULTIVO` VARCHAR(64),
PRIMARY KEY (`ID_CULTIVO`)
) CHARACTER SET latin1;
CREATE TABLE `FINCA` (
`ID_FINCA` INT,
`ID_LUGAR` INT,
`CI_PROPIETARIO` VARCHAR(64),
`CEDULA_USUARIO` VARCHAR(64),
`NOMBRE_FINCA` VARCHAR(64),
`COORDENADA_X_FINCA` VARCHAR(64),
`COORDENADA_Y_FINCA` VARCHAR(64),
`COORDENADA_Z_FINCA` VARCHAR(64),
`ESTADO_FINCA` VARCHAR(64),
`FECHA_UPDATE_FINCA` DATETIME,
PRIMARY KEY (`ID_FINCA`)
) CHARACTER SET latin1;
CREATE TABLE `FINCA_CULTIVO` (
`ID_FINCA` INT,
`ID_CULTIVO` INT,
PRIMARY KEY (`ID_FINCA`, `ID_CULTIVO`)
) CHARACTER SET latin1;
CREATE TABLE `LUGAR` (
`ID_LUGAR` INT,
`NOMBRE_LUGAR` VARCHAR(64),
PRIMARY KEY (`ID_LUGAR`)
) CHARACTER SET latin1;
CREATE TABLE `MONITOREO` (
`ID_MONITOREO` INT,
`ID_CULTIVO` INT,
`ARBOL` INT,
`FRUTO` INT,
`INCIDENCIA` INT,
`SEVERIDAD` INT,
`FECHA_MONITOREO` DATETIME,
PRIMARY KEY (`ID_MONITOREO`)
) CHARACTER SET latin1;
CREATE TABLE `PROPIETARIO` (
`CI_PROPIETARIO` VARCHAR(64),
`CELULAR_PROPIETARIO` VARCHAR(64),
`FECHA_UPDATE_PROPIETARIO` DATETIME,
`ESTADO_PROPIETARIO` VARCHAR(64),
PRIMARY KEY (`CI_PROPIETARIO`)
) CHARACTER SET latin1;
CREATE TABLE `ROL` (
`ID_ROL` INT,
`NOMBRE_ROL` VARCHAR(64),
`DESCRIPCION_ROL` VARCHAR(64),
PRIMARY KEY (`ID_ROL`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO` (
`CEDULA_USUARIO` VARCHAR(64),
`ID_ROL` INT,
`NOMBRE_USUARIO` VARCHAR(64),
`CORREO_USUARIO` VARCHAR(64),
`CONTRASENA_USUARIO` VARCHAR(64),
`CARGO_USUARIO` VARCHAR(64),
`TELEFONO_USUARIO` VARCHAR(64),
`ESTADO_USUARIO` VARCHAR(64),
PRIMARY KEY (`CEDULA_USUARIO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_640901_database') AS relationships;
