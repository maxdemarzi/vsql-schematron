INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 606625_database
#
CREATE DATABASE `db_606625_database`;
USE `db_606625_database`;
CREATE TABLE `characters` (
`user_id` INT,
`name` VARCHAR(64),
`class_name` VARCHAR(64),
`spec` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`name` VARCHAR(64),
`date` DATETIME,
`channel_id` INT,
`message_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signups` (
`event_id` INT,
`character_name` VARCHAR(64),
`signup_status` INT,
`confirm_status` INT,
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_606625_database') AS relationships;
relationships
Database: db_606625_database

