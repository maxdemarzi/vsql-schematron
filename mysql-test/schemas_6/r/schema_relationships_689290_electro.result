INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 689290_electro
#
CREATE DATABASE `db_689290_electro`;
USE `db_689290_electro`;
CREATE TABLE `customer` (
`Cust_id` INT,
`First_name` VARCHAR(255),
`Last_name` VARCHAR(255),
`Email` VARCHAR(255),
`Password` VARCHAR(255),
`Role` VARCHAR(255),
PRIMARY KEY (`Cust_id`)
) CHARACTER SET latin1;
CREATE TABLE `ebill_monthly_plan` (
`Bill_id` VARCHAR(255),
`Total_cost_tou` DECIMAL(10,2),
`Cost_day_time` DECIMAL(10,2),
`Cost_off_peak_time` DECIMAL(10,2),
`Cost_peak_time` DECIMAL(10,2),
`Total_cost_fixed` DECIMAL(10,2),
`Total_units_tou` INT,
`Units_day_time` INT,
`Units_off_peak_time` INT,
`Units_peak_time` INT,
`Total_units_fixed` INT,
`Best_model` INT,
`Cust_id` INT
) CHARACTER SET latin1;
CREATE TABLE `ebill_specialevent` (
`Bill_id` VARCHAR(255),
`No_of_days` INT,
`Total_cost_tou` DECIMAL(10,2),
`Cost_day_time` DECIMAL(10,2),
`Cost_off_peak_time` DECIMAL(10,2),
`Cost_peak_time` DECIMAL(10,2),
`Total_units_tou` INT,
`Units_day_time` INT,
`Units_off_peak_time` INT,
`Units_peak_time` INT,
`Total_units_fixed` INT,
`Cust_id` INT
) CHARACTER SET latin1;
CREATE TABLE `electric_device_mplan` (
`Device_id` VARCHAR(255),
`Bill_id` VARCHAR(255),
`Device_name` VARCHAR(255),
`Quantity` INT,
`Priority` VARCHAR(255),
`Using_hours_peak_time` DECIMAL(10,2),
`Using_hours_off_peak_time` DECIMAL(10,2),
`Using_hours_day_time` DECIMAL(10,2),
`Power(W)` DECIMAL(10,2),
`Total_units_fixed` INT,
`Units_peak_time` INT,
`Units_off_peak_time` INT,
`Units_day_time` INT,
`Total_cost_fixed` DECIMAL(10,2),
`Cost_peak_time` DECIMAL(10,2),
`Cost_off_peak_time` DECIMAL(10,2),
`Cost_day_time` DECIMAL(10,2),
`Cust_id` INT
) CHARACTER SET latin1;
CREATE TABLE `electric_device_special_event` (
`Device_id` VARCHAR(255),
`Bill_id` VARCHAR(255),
`Device_name` VARCHAR(255),
`Quantity` INT,
`Priority` VARCHAR(255),
`Using_hours_peak_time` DECIMAL(10,2),
`Using_hours_off_peak_time` DECIMAL(10,2),
`Using_hours_day_time` DECIMAL(10,2),
`Power(W)` DECIMAL(10,2),
`Total_units_fixed` INT,
`Units_off_peak_time` INT,
`Units_peak_time` INT,
`Units_day_time` INT,
`Cost_day_time` DECIMAL(10,2),
`Cost_peak_time` DECIMAL(10,2),
`Cost_off_peak_time` DECIMAL(10,2),
`Cust_id` INT
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`Emp_id` INT,
`First_name` VARCHAR(255),
`Last_name` VARCHAR(255),
`Email` VARCHAR(255),
`Conatact_no` VARCHAR(255),
`Password` VARCHAR(255),
`NIC` VARCHAR(255),
`Address` VARCHAR(255),
`Enrollment_date` DATETIME,
`Role` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `fixed_ucharge` (
`Unit_category` VARCHAR(255),
`Unit_charge` DECIMAL(10,2),
`Fixed_charge` DECIMAL(10,2),
PRIMARY KEY (`Unit_category`)
) CHARACTER SET latin1;
CREATE TABLE `suggestions_tou` (
`Suggest_id` VARCHAR(255),
`Device_id` VARCHAR(255),
`Bill_id` VARCHAR(255),
`Device_name` VARCHAR(255),
`Priority` VARCHAR(255),
`Quantity` INT,
`Sugesstions` VARCHAR(255),
`Cust_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tou_ucharge` (
`Time_category` VARCHAR(255),
`Fixed_charge` DECIMAL(10,2),
`Unit_charge` DECIMAL(10,2),
PRIMARY KEY (`Time_category`)
) CHARACTER SET latin1;
