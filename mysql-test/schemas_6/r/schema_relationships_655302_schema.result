INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 655302_schema
#
CREATE DATABASE `db_655302_schema`;
USE `db_655302_schema`;
CREATE TABLE `employees` (
`emp_no` INT,
`emp_title_id` VARCHAR(255),
`birth_date` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`sex` VARCHAR(255),
`hire_date` VARCHAR(255),
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`dept_no` VARCHAR(255),
`dept_name` VARCHAR(255),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(255),
`emp_no` INT
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` INT
) CHARACTER SET latin1;
CREATE TABLE `title_id` (
`title_id` VARCHAR(255),
`title` VARCHAR(255),
PRIMARY KEY (`title_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_655302_schema') AS relationships;
relationships
Database: db_655302_schema

Table Connections:
