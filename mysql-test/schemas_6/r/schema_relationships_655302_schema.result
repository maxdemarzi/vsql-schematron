[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  employees.emp_title_id -> title_id.title_id
[Implied]  salaries.emp_no -> employees.emp_no

DROP DATABASE `db_655302_schema`;
UNINSTALL EXTENSION vsql_schematron;
