CREATE DATABASE `db_613991_bdprojeto`;
USE `db_613991_bdprojeto`;
CREATE TABLE `mydb.usuario` (
`login` VARCHAR(64),
`senha` VARCHAR(64),
`nivel_permissao` INT,
PRIMARY KEY (`login`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.clientes` (
`id` INT,
`nome` VARCHAR(64),
`data_nasc` DATETIME,
`email` VARCHAR(64),
`imagem` VARCHAR(64),
`usuario_login` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.administradores` (
`id` INT,
`nome` VARCHAR(64),
`imagem` VARCHAR(64),
`usuario_login` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.autores` (
`id` INT,
`nome` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.editoras` (
`id` INT,
`nome` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.livros` (
`id` INT,
`titulo` VARCHAR(64),
`descricao` VARCHAR(64),
`quantidade` INT,
`imagem` VARCHAR(64),
`editoras_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.emprestimos` (
`id` INT,
`data_devolucao` DATETIME,
`data_emprestimo` DATETIME,
`data_real_devolucao` DATETIME,
`status` INT,
`livros_id` INT,
`clientes_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.livros_has_autores` (
`livros_id` INT,
`autores_id` INT,
PRIMARY KEY (`livros_id`, `autores_id`)
) CHARACTER SET latin1;
