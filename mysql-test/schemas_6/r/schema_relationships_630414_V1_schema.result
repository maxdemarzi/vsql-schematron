CREATE DATABASE `db_630414_V1_schema`;
USE `db_630414_V1_schema`;
CREATE TABLE `COMMUNITY` (
`ID` INT,
`UUID` VARCHAR(64),
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACCOUNT` (
`ID` INT,
`LOGIN` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MEMBER` (
`ACCOUNTID` INT,
`COMMUNITYID` INT,
`ROLE` VARCHAR(64),
PRIMARY KEY (`ACCOUNTID`, `COMMUNITYID`)
) CHARACTER SET latin1;
CREATE TABLE `CONTRIBUTION` (
`ID` INT,
`TIMESTAMP` DATETIME,
`ACCOUNTID` INT,
`COMMUNITYID` INT,
`UUID` VARCHAR(64),
`URL` VARCHAR(64),
`STATUS` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `FEEDBACK` (
`ID` INT,
`TIMESTAMP` DATETIME,
`ACCOUNTID` INT,
`CONTRIBUTIONID` INT,
`UUID` VARCHAR(64),
`URL` VARCHAR(64),
`STATUS` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_630414_V1_schema') AS relationships;
relationships
