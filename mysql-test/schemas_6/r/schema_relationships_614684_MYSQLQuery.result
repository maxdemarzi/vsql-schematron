CREATE DATABASE `db_614684_MYSQLQuery`;
USE `db_614684_MYSQLQuery`;
CREATE TABLE `Projects` (
`Id` INT NOT NULL,
`GroupId` INT,
`Title` VARCHAR(50),
`Description` VARCHAR(50),
`DateCreated` DATETIME,
`DateModified` DATETIME,
`FileLocation` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`Id` INT NOT NULL,
`Username` VARCHAR(50),
`GroupId` INT,
`Email` VARCHAR(50),
`Password` VARCHAR(50),
`IsTeacher` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
`Id` INT NOT NULL,
`ProjectId` INT,
`UserId` INT,
`Text` VARCHAR(50),
`Timestamp` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
