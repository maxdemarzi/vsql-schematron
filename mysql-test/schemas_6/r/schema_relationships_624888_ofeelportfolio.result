CREATE DATABASE `db_624888_ofeelportfolio`;
USE `db_624888_ofeelportfolio`;
CREATE TABLE `ofeelportfolio.works` (
`id` INT,
`title` VARCHAR(64),
`resume` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.categories` (
`id` INT,
`name` VARCHAR(64),
`icone` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.commentsOfWork` (
`id` INT,
`pseudo` VARCHAR(64),
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`work_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.articles` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`resume` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`categorie_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.tags` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.commentsOfArticle` (
`id` INT,
`pseudo` VARCHAR(64),
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`article_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.works_has_categories` (
`work_id` INT,
`categorie_id` INT,
PRIMARY KEY (`work_id`, `categorie_id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.works_has_tags` (
`work_id` INT,
`tag_id` INT,
PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeelportfolio.articles_has_tags` (
`article_id` INT,
`tag_id` INT,
PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;
