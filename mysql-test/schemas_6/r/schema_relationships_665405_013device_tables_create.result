INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 665405_013device-tables-create
#
CREATE DATABASE `db_665405_013device_tables_create`;
USE `db_665405_013device_tables_create`;
CREATE TABLE `raw_devices` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_virtualizations` (
`tool_run_id` VARCHAR(64),
`host_device_id` VARCHAR(64),
`guest_device_id` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `host_device_id`, `guest_device_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_hardware_information` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`device_type` VARCHAR(64),
`vendor` VARCHAR(64),
`model` VARCHAR(64),
`hardware_revision` VARCHAR(64),
`serial_number` VARCHAR(64),
`description` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `device_colors` (
`device_id` VARCHAR(64),
`color` VARCHAR(64),
PRIMARY KEY (`device_id`)
) CHARACTER SET latin1;
CREATE TABLE `device_extra_weights` (
`device_id` VARCHAR(64),
`extra_weight` DECIMAL(10,2),
PRIMARY KEY (`device_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`media_type` VARCHAR(64),
`is_up` BOOL,
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_mac_addrs` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`mac_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`, `mac_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ip_addrs` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`ip_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`, `ip_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ip_routes` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`dst_ip_net` VARCHAR(64),
`rtr_ip_addr` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ip_servers` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`service_name` VARCHAR(64),
`server_ip_addr` VARCHAR(64),
`port` DECIMAL(10,2),
`local_service` BOOL,
`description` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`, `service_name`, `server_ip_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_phys_connections` (
`tool_run_id` VARCHAR(64),
`self_device_id` VARCHAR(64),
`self_interface_name` VARCHAR(64),
`peer_device_id` VARCHAR(64),
`peer_interface_name` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `self_device_id`, `self_interface_name`, `peer_device_id`, `peer_interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_link_connections` (
`tool_run_id` VARCHAR(64),
`self_device_id` VARCHAR(64),
`self_interface_name` VARCHAR(64),
`peer_mac_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `self_device_id`, `self_interface_name`, `peer_mac_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_devices_aaa` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`aaa_command` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `aaa_command`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_mode` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`interface_mode` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_bpdu` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`is_bpduguard_enabled` BOOL,
`is_bpdufilter_enabled` BOOL,
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_cdp` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`is_cdp_enabled` BOOL,
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_portfast` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`is_portfast_enabled` BOOL,
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_port_security` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`is_port_security_enabled` BOOL,
`is_mac_addr_sticky` BOOL,
`max_mac_addrs` INT,
`violation_action` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_port_security_mac_addrs` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`mac_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`, `mac_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ac_nets` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`net_set_id` VARCHAR(64),
`net_set` VARCHAR(64),
`net_set_data` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ac_services` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`service_set` VARCHAR(64),
`service_set_data` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_ac_rules` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`enabled` BOOL,
`ac_id` INT,
`src_net_set_id` VARCHAR(64),
`src_net_set` VARCHAR(64),
`src_iface` VARCHAR(64),
`dst_net_set_id` VARCHAR(64),
`dst_net_set` VARCHAR(64),
`dst_iface` VARCHAR(64),
`service_set` VARCHAR(64),
`action` VARCHAR(64),
`description` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_vlans` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`vlan` DECIMAL(10,2),
`description` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `vlan`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_vlans_ip_nets` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`vlan` DECIMAL(10,2),
`ip_net` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `device_id`, `vlan`, `ip_net`)
) CHARACTER SET latin1;
CREATE TABLE `raw_device_interfaces_vlans` (
`tool_run_id` VARCHAR(64),
`device_id` VARCHAR(64),
`interface_name` VARCHAR(64),
`vlan` DECIMAL(10,2),
PRIMARY KEY (`tool_run_id`, `device_id`, `interface_name`, `vlan`)
) CHARACTER SET latin1;
