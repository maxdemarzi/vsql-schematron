CREATE DATABASE `db_693858_marcel_museum`;
USE `db_693858_marcel_museum`;
CREATE TABLE `banners` (
`id` INT,
`product_id` INT,
`image` VARCHAR(50),
`head` VARCHAR(50),
`content` VARCHAR(50),
`text_color` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`date` DATE,
`edition` VARCHAR(50),
`image` VARCHAR(50),
`description` TEXT,
`address` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_693858_marcel_museum') AS relationships;
