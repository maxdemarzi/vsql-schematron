[Implied]  comments.solutionid -> solutions.solutionid
[Implied]  requirement.materialid -> material.materialid
[Implied]  requirement.solutionid -> solutions.solutionid
[Implied]  solutiontags.TagName -> tags.TagName
[Implied]  solutiontags.solutionid -> solutions.solutionid

DROP DATABASE `db_624778_sevenhills`;
UNINSTALL EXTENSION vsql_schematron;
