INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 624778_sevenhills
#
CREATE DATABASE `db_624778_sevenhills`;
USE `db_624778_sevenhills`;
CREATE TABLE `comments` (
`solutionid` INT,
`commenttext` VARCHAR(64),
`name` VARCHAR(64),
`commentid` INT,
PRIMARY KEY (`commentid`)
) CHARACTER SET latin1;
CREATE TABLE `material` (
`materialid` INT,
`MaterialName` VARCHAR(64),
`Vendor` VARCHAR(64),
PRIMARY KEY (`materialid`)
) CHARACTER SET latin1;
CREATE TABLE `requirement` (
`solutionid` INT,
`materialid` INT,
`amount` INT,
PRIMARY KEY (`solutionid`, `materialid`)
) CHARACTER SET latin1;
CREATE TABLE `solutions` (
`solutionid` INT,
`SolutionName` VARCHAR(64),
`Description` VARCHAR(64),
`Difficulty` INT,
`Instruction` VARCHAR(64),
`EstimatedTotalCost` INT,
`Time` INT,
PRIMARY KEY (`solutionid`)
) CHARACTER SET latin1;
CREATE TABLE `solutiontags` (
`solutionid` INT,
`TagName` VARCHAR(64),
PRIMARY KEY (`solutionid`, `TagName`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`TagName` VARCHAR(64),
PRIMARY KEY (`TagName`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_624778_sevenhills') AS relationships;
relationships
Database: db_624778_sevenhills

Table Connections:
