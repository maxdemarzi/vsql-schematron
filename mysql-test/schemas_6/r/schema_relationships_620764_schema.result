INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 620764_schema
#
CREATE DATABASE `db_620764_schema`;
USE `db_620764_schema`;
CREATE TABLE `tenants` (
`id` INT NOT NULL,
`handle` VARCHAR(50),
`name` VARCHAR(50),
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`login` VARCHAR(50),
`active` BOOLEAN,
`phone` VARCHAR(50),
`password` VARCHAR(50),
`tenant_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hash` (
`id` INT NOT NULL,
`k` VARCHAR(50),
`value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_620764_schema') AS relationships;
