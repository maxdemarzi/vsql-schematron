INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 638456_main
#
CREATE DATABASE `db_638456_main`;
USE `db_638456_main`;
CREATE TABLE `albums` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`pap` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artists` (
`id` VARCHAR(50) NOT NULL,
`band` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`duration` TIME,
`album_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs_artists` (
`id` VARCHAR(50) NOT NULL,
`song_id` VARCHAR(50),
`artist_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`pfp` VARCHAR(50),
`admin` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlists` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`plp` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlists_songs` (
`id` VARCHAR(50) NOT NULL,
`song_id` VARCHAR(50),
`playlist_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_638456_main') AS relationships;
relationships
Database: db_638456_main

Table Connections:
------------------
[Implied]  playlists.user_id -> users.id
[Implied]  playlists_songs.playlist_id -> playlists.id
[Implied]  playlists_songs.song_id -> songs.id
[Implied]  songs.album_id -> albums.id
[Implied]  songs_artists.artist_id -> artists.id
[Implied]  songs_artists.song_id -> songs.id

DROP DATABASE `db_638456_main`;
UNINSTALL EXTENSION vsql_schematron;
