CREATE DATABASE `db_689225_schema`;
USE `db_689225_schema`;
CREATE TABLE `students` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`phoneNumber` VARCHAR(64),
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercises` (
`id` INT,
`name` VARCHAR(64),
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trainings` (
`id` INT,
`name` VARCHAR(64),
`status` VARCHAR(64),
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trainingExercises` (
`id` INT,
`trainingId` INT,
`exerciseId` INT,
`numberOfSessions` INT,
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `studentTrainings` (
`id` INT,
`studentId` INT,
`trainingId` INT,
`status` VARCHAR(64),
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `studentTrainingExercises` (
`id` INT,
`studentTrainingId` INT,
`trainingExerciseId` INT,
`status` VARCHAR(64),
`createdAt` DATETIME,
`modifiedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
