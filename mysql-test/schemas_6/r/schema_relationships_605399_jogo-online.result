INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 605399_jogo-online
#
CREATE DATABASE `db_605399_jogo_online`;
USE `db_605399_jogo_online`;
CREATE TABLE `tb_classe` (
`id` INT NOT NULL,
`nomeclass` VARCHAR(50),
`armaInicial` VARCHAR(50),
`armaduraInicial` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_personagem` (
`id` INT NOT NULL,
`nomechar` VARCHAR(50),
`nivel` INT,
`arma` VARCHAR(50),
`armadura` VARCHAR(50),
`forca` INT,
`agilidade` INT,
`energia` INT,
`vida` INT,
`mana` INT,
`danoAtaque` INT,
`danoHabilidade` INT,
`guild` VARCHAR(50),
`world` VARCHAR(50),
`ranking` VARCHAR(50),
`classeId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605399_jogo_online') AS relationships;
