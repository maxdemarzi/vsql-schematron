[Implied]  ROLE_PRIVILEGE.PRIVILEGE_ID -> PRIVILEGE.ID
[Implied]  ROLE_PRIVILEGE.ROLE_ID -> ROLE.ID
[Implied]  USER_ROLE.ROLE_ID -> ROLE.ID
[Implied]  USER_ROLE.USER_ID -> USER.ID

DROP DATABASE `db_616306_schema`;
UNINSTALL EXTENSION vsql_schematron;
