INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 664975_tunes_ddl
#
CREATE DATABASE `db_664975_tunes_ddl`;
USE `db_664975_tunes_ddl`;
CREATE TABLE `author` (
`id` INT,
`name` VARCHAR(255),
`born_date` DATETIME,
`gender` VARCHAR(255),
`label` VARCHAR(255),
`notes` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
`id` INT,
`name` VARCHAR(255),
`type` VARCHAR(255),
`publication_date` DATETIME,
`producer` VARCHAR(255),
`genre` VARCHAR(255),
`duration` VARCHAR(255),
`track_number` INT,
`notes` VARCHAR(255),
`author_key` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
`id` INT,
`name` VARCHAR(255),
`duration` VARCHAR(255),
`label` VARCHAR(255),
`producer` VARCHAR(255),
`genre` VARCHAR(255),
`notes` VARCHAR(255),
`album_key` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_664975_tunes_ddl') AS relationships;
relationships
Database: db_664975_tunes_ddl

Table Connections:
