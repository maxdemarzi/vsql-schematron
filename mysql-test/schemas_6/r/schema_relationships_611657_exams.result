INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 611657_exams
#
CREATE DATABASE `db_611657_exams`;
USE `db_611657_exams`;
CREATE TABLE `exams` (
`id` INT NOT NULL,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
`id` INT NOT NULL,
`desc` TEXT,
`correct` INT,
`exam_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
`id` INT NOT NULL,
`name` TEXT,
`question_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_611657_exams') AS relationships;
relationships
