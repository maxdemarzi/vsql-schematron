INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 668815_cursos-carrera
#
CREATE DATABASE `db_668815_cursos_carrera`;
USE `db_668815_cursos_carrera`;
CREATE TABLE `carrera` (
`cod_car` VARCHAR(50) NOT NULL,
`nom_car` VARCHAR(50),
PRIMARY KEY (`cod_car`)
) CHARACTER SET latin1;
CREATE TABLE `ciclo` (
`cod_ciclo` VARCHAR(50) NOT NULL,
PRIMARY KEY (`cod_ciclo`)
) CHARACTER SET latin1;
CREATE TABLE `curso` (
`cod_car` CHAR(50),
`cod_cur` VARCHAR(50) NOT NULL,
`cod_ciclo` CHAR(50),
`nom_cur` VARCHAR(50),
`horas_cur` INT,
PRIMARY KEY (`cod_cur`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_668815_cursos_carrera') AS relationships;
relationships
