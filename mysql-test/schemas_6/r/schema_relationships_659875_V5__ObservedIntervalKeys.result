CREATE DATABASE `db_659875_V5__ObservedIntervalKeys`;
USE `db_659875_V5__ObservedIntervalKeys`;
CREATE TABLE `ObservedKeys` (
`id` INT NOT NULL,
`prefix` VARCHAR(50),
`methodName` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ObservedInterval` (
`id` INT NOT NULL,
`observedKeysId` BIGINT,
`startTime` DATETIME,
`duration` BIGINT,
`vrCount` BIGINT,
`vrMax` BIGINT,
`vrMin` BIGINT,
`vrMean` DECIMAL(10,2),
`vrMedian` DECIMAL(10,2),
`stdDev` DECIMAL(10,2),
`p95` DECIMAL(10,2),
`p98` DECIMAL(10,2),
`p99` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
