`PRIMARY_NAME` VARCHAR(64),
`SIPE_NAME` VARCHAR(64),
`PROTEIN_NAMES` VARCHAR(64),
`SEQ_LENGTH` INT,
`GENENAME` VARCHAR(64),
`SEQUENCE` VARCHAR(64),
`FUNCTION_` VARCHAR(64),
PRIMARY KEY (`PROTEIN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROTEIN_TO_DISEASE` (
`ID` INT,
