INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 652946_schema
#
CREATE DATABASE `db_652946_schema`;
USE `db_652946_schema`;
CREATE TABLE `servers` (
`server_id` INT NOT NULL,
`server_name` TEXT,
PRIMARY KEY (`server_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`user_name` TEXT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_servers` (
`user_id` INT,
`server_id` INT
) CHARACTER SET latin1;
CREATE TABLE `violations` (
`violation_id` INT NOT NULL,
`violation_desc` TEXT,
PRIMARY KEY (`violation_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_violations` (
`user_id` INT,
`violation_id` INT,
`server_id` INT,
`reason` TEXT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_652946_schema') AS relationships;
relationships
