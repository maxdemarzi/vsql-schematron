INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 664370_Project3-WikiStats-DB
#
CREATE DATABASE `db_664370_Project3_WikiStats_DB`;
USE `db_664370_Project3_WikiStats_DB`;
CREATE TABLE `language` (
`id` INT NOT NULL,
`languagecode` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `page` (
`id` INT NOT NULL,
`page` TEXT,
`languageid` INT,
`pagemd5` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pageviews` (
`id` INT NOT NULL,
`hourstamp` TIMESTAMP NULL,
`pageid` INT,
`pageviews` INT,
`contentsize` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_664370_Project3_WikiStats_DB') AS relationships;
relationships
