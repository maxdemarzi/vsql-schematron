INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 636189_init
#
CREATE DATABASE `db_636189_init`;
USE `db_636189_init`;
CREATE TABLE `symptom` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `illness` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `anagraph` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `medicine` (
`id` INT,
`name` VARCHAR(255),
`property` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `symptom_illness` (
`illness_id` INT,
`symptom_id` INT
) CHARACTER SET latin1;
CREATE TABLE `illness_anagraph` (
`illness_id` INT,
`anagraph_id` INT
) CHARACTER SET latin1;
CREATE TABLE `anagraph_medicine` (
`anagraph_id` INT,
`medicine_id` INT,
`grams` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_636189_init') AS relationships;
