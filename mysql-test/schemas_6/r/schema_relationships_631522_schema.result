`id` INT,
`description` VARCHAR(255),
`role_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `app_user` (
`id` INT,
`name` VARCHAR(255),
`non_pii_id` VARCHAR(255),
`login` VARCHAR(255),
`password` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_631522_schema') AS relationships;
