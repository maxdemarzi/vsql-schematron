CREATE DATABASE `db_640674_schema`;
USE `db_640674_schema`;
CREATE TABLE `MY_USER` (
`MY_USER_ID` INT,
`USERNAME` VARCHAR(64),
`ENC_PASSWORD` VARCHAR(64),
`IS_LOCKED` INT,
`IS_DISABLED` INT,
`FAILED_ATTEMPTS` INT,
`LAST_PASSWORD_DATE` DATETIME,
`IS_PW_EXPIRED` INT,
PRIMARY KEY (`MY_USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MY_LOGIN_ATTEMPT` (
`MY_LOGIN_ATTEMPT_ID` INT,
`USERNAME` VARCHAR(64),
`RECORD_DATE` DATETIME,
`IP_ADDRESS` VARCHAR(64),
PRIMARY KEY (`MY_LOGIN_ATTEMPT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MY_PASSWORD_HIST` (
`MY_PASSWORD_HIST_ID` INT,
`MY_USER_ID` VARCHAR(64),
`ENC_PASSWORD` VARCHAR(64),
`RECORD_DATE` DATETIME,
PRIMARY KEY (`MY_PASSWORD_HIST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DUMMY` (
`DUMMY_INT` INT,
`DUMMY_VARCHAR` VARCHAR(64),
`DUMMY_DATE` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `SPRING_SESSION` (
`PRIMARY_ID` VARCHAR(64),
`SESSION_ID` VARCHAR(64),
`CREATION_TIME` INT,
`LAST_ACCESS_TIME` INT,
`MAX_INACTIVE_INTERVAL` INT,
`EXPIRY_TIME` INT,
`PRINCIPAL_NAME` VARCHAR(64),
PRIMARY KEY (`PRIMARY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SPRING_SESSION_ATTRIBUTES` (
`SESSION_PRIMARY_ID` VARCHAR(64),
`ATTRIBUTE_NAME` VARCHAR(64),
`ATTRIBUTE_BYTES` VARCHAR(64),
PRIMARY KEY (`SESSION_PRIMARY_ID`, `ATTRIBUTE_NAME`)
) CHARACTER SET latin1;
