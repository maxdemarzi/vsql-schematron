CREATE DATABASE `db_635967_V5__add_orders`;
USE `db_635967_V5__add_orders`;
CREATE TABLE `orders` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`user_api_key_id` VARCHAR(50),
`exchange_name` TEXT,
`exchange_order_id` TEXT,
`exchange_market_name` TEXT,
`market_name` TEXT,
`side` TEXT,
`type` TEXT,
`price` DECIMAL(10,2),
`quantity` DECIMAL(10,2),
`quantity_remaining` DECIMAL(10,2),
`status` TEXT,
`conditions` VARCHAR(50),
`created_on` TIMESTAMP NULL,
`updated_on` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_fills` (
`id` VARCHAR(50) NOT NULL,
`order_id` VARCHAR(50),
`condition` VARCHAR(50),
`price` DECIMAL(10,2),
`quantity` DECIMAL(10,2),
`created_on` TIMESTAMP NULL,
`updated_on` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
