CREATE DATABASE `db_632036_Create_table`;
USE `db_632036_Create_table`;
CREATE TABLE `User` (
`UserId` INT,
`Email` VARCHAR(64),
`Address` VARCHAR(64),
`Phone_Number` INT,
`Password` VARCHAR(64),
`Username` VARCHAR(64),
`Value` INT,
PRIMARY KEY (`UserId`)
) CHARACTER SET latin1;
CREATE TABLE `EmployerMembership` (
`Genre` VARCHAR(64),
`MonthlyFee` DECIMAL(10,2),
`MaxJobPost` INT,
PRIMARY KEY (`Genre`)
) CHARACTER SET latin1;
CREATE TABLE `Employer` (
`Employer_ID` INT,
`Description` VARCHAR(64),
`Name` VARCHAR(64),
`Emoloyer_Balance` DECIMAL(10,2),
`EmMembershipStartTime` DATETIME,
`UserId` INT,
`GenreEm` VARCHAR(64),
`EmployerStatus` VARCHAR(64),
`FrozenTime` DATETIME,
PRIMARY KEY (`Employer_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CandidateMembership` (
`Genre` VARCHAR(64),
`MonthlyFee` DECIMAL(10,2),
`MaxJobApply` INT,
PRIMARY KEY (`Genre`)
) CHARACTER SET latin1;
CREATE TABLE `Candidate` (
`Candidate_ID` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`Candidate_Balance` DECIMAL(10,2),
`CanMembershipStartTime` DATETIME,
`UserId` INT,
`GenreCan` VARCHAR(64),
`CandidateStatus` VARCHAR(64),
`FrozenTime` DATETIME,
PRIMARY KEY (`Candidate_ID`)
) CHARACTER SET latin1;
CREATE TABLE `JobCategory` (
`Genre` VARCHAR(64),
`Name` VARCHAR(64),
PRIMARY KEY (`Genre`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
`Admin_ID` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`UserID` INT,
PRIMARY KEY (`Admin_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Job` (
`Job_ID` INT,
