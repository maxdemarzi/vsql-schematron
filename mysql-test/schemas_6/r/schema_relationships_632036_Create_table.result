`JobStatus` BOOL,
`Title` VARCHAR(64),
`Description` VARCHAR(64),
`Post_Date` DATETIME,
`Location` VARCHAR(64),
`PostEmployer_ID` INT,
`GenreJob` VARCHAR(64),
PRIMARY KEY (`Job_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Payment` (
`Payment_ID` INT,
`Amount` DECIMAL(10,2),
`PaymentCreateDate` DATETIME,
`UserId` INT,
PRIMARY KEY (`Payment_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PayMenthod` (
`Paymthod_ID` INT,
`Card_Number` VARCHAR(64),
`CVV_Number` VARCHAR(64),
`ExpireDate` DATETIME,
`DefaultCard` BOOL,
