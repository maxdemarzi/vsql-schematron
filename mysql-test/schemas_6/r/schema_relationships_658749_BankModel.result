INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 658749_BankModel
#
CREATE DATABASE `db_658749_BankModel`;
USE `db_658749_BankModel`;
CREATE TABLE `Branch` (
`branch_id` INT NOT NULL,
`branch_name` VARCHAR(50),
`branch_address` VARCHAR(50),
PRIMARY KEY (`branch_id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`account_number` INT NOT NULL,
`account_type` VARCHAR(50),
`account_status` VARCHAR(50),
`account_balance` INT,
PRIMARY KEY (`account_number`)
) CHARACTER SET latin1;
CREATE TABLE `Customer` (
`customer_id` INT NOT NULL,
`customer_name` VARCHAR(50),
`customer_address` VARCHAR(50),
`customer_dob` DATE,
`branch_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `Transaction` (
`transaction_id` INT NOT NULL,
`transaction_type` VARCHAR(50),
`transaction_date_time` DATE,
`transaction_amount` INT,
`from_account_number` INT,
`to_account_number` INT,
PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
CREATE TABLE `CustomerAccount` (
`customer_id` INT,
`account_number` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_658749_BankModel') AS relationships;
relationships
Database: db_658749_BankModel

Table Connections:
------------------
[Implied]  Customer.branch_id -> Branch.branch_id
[Implied]  CustomerAccount.account_number -> Account.account_number
[Implied]  CustomerAccount.customer_id -> Customer.customer_id
[Implied]  Transaction.from_account_number -> Account.account_number
[Implied]  Transaction.to_account_number -> Account.account_number

DROP DATABASE `db_658749_BankModel`;
UNINSTALL EXTENSION vsql_schematron;
