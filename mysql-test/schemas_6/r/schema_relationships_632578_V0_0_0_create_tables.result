CREATE DATABASE `db_632578_V0_0_0_create_tables`;
USE `db_632578_V0_0_0_create_tables`;
CREATE TABLE `m_user` (
`id` INT,
`user_handle` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`email_address` VARCHAR(255),
`password` VARCHAR(255),
`locked` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m_group` (
`id` INT,
`group_name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m_authority` (
`id` INT,
`authority` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m_authenticator` (
`id` INT,
`name` VARCHAR(255),
`user_id` INT,
`counter` INT,
`aaguid` VARCHAR(255),
`credential_id` VARCHAR(255),
`cose_key` VARCHAR(255),
`attestation_statement` VARCHAR(255),
`client_extensions` VARCHAR(255),
`authenticator_extensions` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `m_transport` (
`authenticator_id` INT,
`transport` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `r_user_group` (
`user_id` INT,
`group_id` INT
) CHARACTER SET latin1;
CREATE TABLE `r_user_authority` (
`user_id` INT,
`authority_id` INT
) CHARACTER SET latin1;
CREATE TABLE `r_group_authority` (
`group_id` INT,
`authority_id` INT
) CHARACTER SET latin1;
