INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 620334_schema
#
CREATE DATABASE `db_620334_schema`;
USE `db_620334_schema`;
CREATE TABLE `account` (
`id` INT NOT NULL,
`name` TEXT,
`aws_id` TEXT,
`key_id` TEXT,
`access_key` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `network` (
`id` INT NOT NULL,
`region` TEXT,
`private_key` TEXT,
`cidr_block` TEXT,
`vpn_gateway_ip` TEXT,
`vpn_routes` VARCHAR(50),
`name_servers` VARCHAR(50),
`intern_domain` TEXT,
`ami_nat_image` TEXT,
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subnet` (
`type` TEXT,
`availability_zone` TEXT,
`cidr_block` TEXT,
`network_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_620334_schema') AS relationships;
