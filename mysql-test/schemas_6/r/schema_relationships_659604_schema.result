INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 659604_schema
#
CREATE DATABASE `db_659604_schema`;
USE `db_659604_schema`;
CREATE TABLE `reimbursement_status` (
`reimb_status_id` INT,
`reimb_status` VARCHAR(64),
PRIMARY KEY (`reimb_status_id`)
) CHARACTER SET latin1;
CREATE TABLE `reimbursement_type` (
`reimb_type_id` INT,
`reimb_type` VARCHAR(64),
PRIMARY KEY (`reimb_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`ers_user_role_id` INT,
`user_role` VARCHAR(64),
PRIMARY KEY (`ers_user_role_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`ers_users_id` INT,
`ers_username` VARCHAR(64),
`ers_password` VARCHAR(64),
`user_first_name` VARCHAR(64),
`user_last_name` VARCHAR(64),
`user_email` VARCHAR(64),
`user_role_id` INT,
PRIMARY KEY (`ers_users_id`)
) CHARACTER SET latin1;
CREATE TABLE `reimbursement` (
`reimb_id` INT,
`reimb_amount` INT,
`reimb_submitted` DATETIME,
`reimb_resolved` DATETIME,
`reimb_description` VARCHAR(64),
`reimb_receipt` VARCHAR(64),
`reimb_author` INT,
`reimb_resolver` INT,
`reimb_status_id` INT,
`reimb_type_id` INT,
PRIMARY KEY (`reimb_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_659604_schema') AS relationships;
relationships
