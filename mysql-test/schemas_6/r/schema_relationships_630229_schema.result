INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 630229_schema
#
CREATE DATABASE `db_630229_schema`;
USE `db_630229_schema`;
CREATE TABLE `smtp` (
`id` INT NOT NULL,
`host` TEXT,
`username` TEXT,
`password` TEXT,
`paused` BOOLEAN,
`active` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inbox` (
`smtp_id` INT,
`seq` INT,
`message_id` TEXT,
`from_address` TEXT,
`subject` TEXT,
`attachments` TEXT,
`share` TEXT,
`date` DATETIME,
`timestamp` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `folders` (
`folder` VARCHAR(50) NOT NULL,
`share_url` TEXT,
PRIMARY KEY (`folder`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_630229_schema') AS relationships;
relationships
