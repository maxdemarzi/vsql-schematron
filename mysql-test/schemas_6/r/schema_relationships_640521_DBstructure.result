CREATE DATABASE `db_640521_DBstructure`;
USE `db_640521_DBstructure`;
CREATE TABLE `tb_user` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`username` VARCHAR(50),
`pass` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_post` (
`id` INT NOT NULL,
`id_user` INT,
`date` DATETIME,
`title` VARCHAR(50),
`text` TEXT,
`category` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_comment` (
`id` INT NOT NULL,
`id_user` INT,
`id_post` INT,
`date` DATETIME,
`text` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_640521_DBstructure') AS relationships;
