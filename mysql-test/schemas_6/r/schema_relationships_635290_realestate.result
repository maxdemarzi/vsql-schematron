INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 635290_realestate
#
CREATE DATABASE `db_635290_realestate`;
USE `db_635290_realestate`;
CREATE TABLE `agents` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`location` VARCHAR(64),
`contact` VARCHAR(64),
`commission` INT,
`salary` INT,
`hireDate` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
`id` INT,
`email` VARCHAR(64),
`prodId` INT
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`prodId` INT,
`email` VARCHAR(64),
`comment` VARCHAR(64),
`time` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`type` VARCHAR(64),
`description` VARCHAR(64),
`location` VARCHAR(64),
`images` VARCHAR(64),
`buy` INT,
`rent` INT,
`down` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_635290_realestate') AS relationships;
relationships
