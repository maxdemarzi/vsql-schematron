INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 684794_analysis_db
#
CREATE DATABASE `db_684794_analysis_db`;
USE `db_684794_analysis_db`;
CREATE TABLE `match` (
`team1` VARCHAR(64),
`team2` VARCHAR(64),
`date` DATETIME,
`venue` VARCHAR(64),
`id` INT,
`playedOn` DATETIME,
`source` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match_events` (
`id` INT,
`event` VARCHAR(64),
`half` INT,
`kpi` VARCHAR(64),
`location` VARCHAR(64),
`player` VARCHAR(64),
`rawtime` VARCHAR(64),
`sector` INT,
`team` VARCHAR(64),
`time` INT,
`match_id` INT,
`lColumn` INT,
`lRow` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match_plays` (
`id` INT,
`endtime` INT,
`events` VARCHAR(64),
`next` INT,
`origin` VARCHAR(64),
`origin_attacks` INT,
`origin_team` VARCHAR(64),
`outcome` VARCHAR(64),
`outcome_attacks` INT,
`outcome_team` VARCHAR(64),
`previous` INT,
`starttime` VARCHAR(64),
`match_id` INT,
`reduced_outcome` VARCHAR(64),
`playid` INT,
`reduced_origin` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_684794_analysis_db') AS relationships;
relationships
Database: db_684794_analysis_db

Table Connections:
------------------
[Implied]  match_events.match_id -> match.id
[Implied]  match_plays.match_id -> match.id
[Implied]  match_plays.next -> match_plays.id
[Implied]  match_plays.previous -> match_plays.id

DROP DATABASE `db_684794_analysis_db`;
UNINSTALL EXTENSION vsql_schematron;
