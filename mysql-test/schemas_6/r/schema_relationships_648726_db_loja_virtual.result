CREATE DATABASE `db_648726_db_loja_virtual`;
USE `db_648726_db_loja_virtual`;
CREATE TABLE `tb_clientes` (
`id_cliente` INT NOT NULL,
`nome` VARCHAR(50),
`idade` INT,
PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `tb_descricoes_tecnicas` (
`id_descricao_tecnica` INT,
`fk_id_produto` INT,
`descricao_tecnica` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tb_imagens` (
`id_imagem` INT,
`fk_id_produto` INT,
`url_imagem` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos` (
`id_pedido` INT,
`fk_id_cliente` INT,
`data_hora` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos_produtos` (
`fk_id_pedido` INT,
`fk_id_produto` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_648726_db_loja_virtual') AS relationships;
