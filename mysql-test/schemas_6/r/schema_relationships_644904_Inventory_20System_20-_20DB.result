CREATE TABLE `dummy` (
`firstname` VARCHAR(50),
`lastname` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`homephone` VARCHAR(50),
`cellphone` VARCHAR(50),
`workphone` VARCHAR(50),
`street` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`zip` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `purchase_orders` (
`poNumber` INT NOT NULL,
`orderDate` DATE,
`shipDate` DATE,
`customerId` INT,
PRIMARY KEY (`poNumber`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`noOfItems` INT,
`poNumber` INT,
`itemNumber` INT
) CHARACTER SET latin1;
