CREATE TABLE `City` (
`CityId` DECIMAL(10,2),
`CityName` VARCHAR(64),
PRIMARY KEY (`CityId`)
) CHARACTER SET latin1;
CREATE TABLE `State` (
`StateId` DECIMAL(10,2),
`StateName` VARCHAR(64),
PRIMARY KEY (`StateId`)
) CHARACTER SET latin1;
CREATE TABLE `ZipCode` (
`ZipCodeId` DECIMAL(10,2),
`ZipCode` VARCHAR(64),
`StateId` DECIMAL(10,2),
`CityId` DECIMAL(10,2),
PRIMARY KEY (`ZipCodeId`)
) CHARACTER SET latin1;
CREATE TABLE `Membership` (
`MembershipId` DECIMAL(10,2),
`MembershipType` VARCHAR(64),
`MembershipLimitPerMonth` DECIMAL(10,2),
`MembershipMonthlyPrice` DECIMAL(10,2),
`MembershipMonthlyTax` DECIMAL(10,2),
`MembershipDVDLostPrice` DECIMAL(10,2),
PRIMARY KEY (`MembershipId`)
) CHARACTER SET latin1;
CREATE TABLE `Payment` (
`PaymentId` DECIMAL(10,2),
`MemberId` DECIMAL(10,2),
`AmountPaid` DECIMAL(10,2),
`AmountPaidDate` DATETIME,
`AmountPaidUntilDate` DATETIME,
PRIMARY KEY (`PaymentId`)
) CHARACTER SET latin1;
CREATE TABLE `Genre` (
`GenreId` DECIMAL(10,2),
`GenreName` VARCHAR(64),
PRIMARY KEY (`GenreId`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
`RatingId` DECIMAL(10,2),
`RatingName` VARCHAR(64),
`RatingDescription` VARCHAR(64),
PRIMARY KEY (`RatingId`)
) CHARACTER SET latin1;
CREATE TABLE `Role` (
`RoleId` DECIMAL(10,2),
`RoleName` VARCHAR(64),
PRIMARY KEY (`RoleId`)
) CHARACTER SET latin1;
CREATE TABLE `MoviePerson` (
`PersonId` DECIMAL(10,2),
`PersonFirstName` VARCHAR(64),
`PersonLastName` VARCHAR(64),
`PersonInitial` VARCHAR(64),
`PersonDateOfBirth` DATETIME,
PRIMARY KEY (`PersonId`)
) CHARACTER SET latin1;
CREATE TABLE `DVD` (
`DVDId` DECIMAL(10,2),
`DVDTitle` VARCHAR(64),
`GenreId` DECIMAL(10,2),
`RatingId` DECIMAL(10,2),
`DVDReleaseDate` DATETIME,
`TheaterReleaseDate` DATETIME,
`DVDQuantityOnHand` DECIMAL(10,2),
`DVDQuantityOnRent` DECIMAL(10,2),
`DVDLostQuantity` DECIMAL(10,2),
PRIMARY KEY (`DVDId`)
) CHARACTER SET latin1;
CREATE TABLE `RentalQueue` (
`MemberId` DECIMAL(10,2),
`DVDId` DECIMAL(10,2),
`DateAddedInQueue` DATETIME,
PRIMARY KEY (`MemberId`, `DVDId`)
) CHARACTER SET latin1;
CREATE TABLE `MoviePersonRole` (
`PersonId` DECIMAL(10,2),
`RoleId` DECIMAL(10,2),
`DVDId` DECIMAL(10,2),
PRIMARY KEY (`PersonId`, `DVDId`, `RoleId`)
) CHARACTER SET latin1;
CREATE TABLE `Rental` (
`RentalId` DECIMAL(10,2),
`MemberId` DECIMAL(10,2),
`DVDId` DECIMAL(10,2),
`RentalRequestDate` DATETIME,
`RentalShippedDate` DATETIME,
`RentalReturnedDate` DATETIME,
PRIMARY KEY (`RentalId`)
) CHARACTER SET latin1;
