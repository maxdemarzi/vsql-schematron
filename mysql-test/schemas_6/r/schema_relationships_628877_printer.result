INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 628877_printer
#
CREATE DATABASE `db_628877_printer`;
USE `db_628877_printer`;
CREATE TABLE `manufacturer` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `model` (
`id` VARCHAR(50) NOT NULL,
`manufacturer_id` VARCHAR(50),
`name` VARCHAR(50),
`driver` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `printer` (
`id` VARCHAR(50) NOT NULL,
`model_id` VARCHAR(50),
`location_id` VARCHAR(50),
`hostname` VARCHAR(50),
`driver_extra` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_628877_printer') AS relationships;
relationships
Database: db_628877_printer

Table Connections:
