CREATE DATABASE `db_683632_query_documentation`;
USE `db_683632_query_documentation`;
CREATE TABLE `LIBRARIAN` (
`Librarian_Username` VARCHAR(64),
`Librarian_Name` VARCHAR(64),
`Librarian_Password` VARCHAR(64),
PRIMARY KEY (`Librarian_Username`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`Book_ID` VARCHAR(64),
`Book_ISBN` VARCHAR(64),
`Book_Title` VARCHAR(64),
`Book_Author` VARCHAR(64),
`Book_Condition` VARCHAR(64),
`Book_Status` VARCHAR(64),
PRIMARY KEY (`Book_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
`Student_ID` VARCHAR(64),
`Student_LastName` VARCHAR(64),
`Student_FirstName` VARCHAR(64),
`Student_Section` VARCHAR(64),
`Student_YearLevel` VARCHAR(64),
PRIMARY KEY (`Student_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PAYMENT` (
`Payment_ID` VARCHAR(64),
`Payment_Amount` DECIMAL(10,2),
`Payment_Status` VARCHAR(64),
PRIMARY KEY (`Payment_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BORROW` (
`Borrow_ID` VARCHAR(64),
`Borrow_Date` DATETIME,
`Borrow_Return_Date` DATETIME,
`Borrow_Status` VARCHAR(64),
`Borrow_Overdue_Status` INT,
`Borrow_Issuer` VARCHAR(64),
`Student_ID` VARCHAR(64),
`Payment_ID` VARCHAR(64),
`Book_ID` VARCHAR(64),
PRIMARY KEY (`Borrow_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_683632_query_documentation') AS relationships;
