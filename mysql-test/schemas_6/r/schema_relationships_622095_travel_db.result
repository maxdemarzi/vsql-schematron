[Implied]  table2tags.tag_id -> tags.tag_id
[Implied]  trail_park_rel.park_id -> park.park_id
[Implied]  trail_park_rel.trail_id -> trail.trail_id

DROP DATABASE `db_622095_travel_db`;
UNINSTALL EXTENSION vsql_schematron;
