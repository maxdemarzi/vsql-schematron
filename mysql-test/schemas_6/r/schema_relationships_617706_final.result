`Day_3` INT,
`Day_4` INT,
`Day_5` INT,
`Day_6` INT,
`Day_7` INT,
`WeekID` INT,
`START_DATE` DATETIME,
`END_DATE` DATETIME,
`ACTIVE_FLAG` VARCHAR(64)
) CHARACTER SET latin1;
