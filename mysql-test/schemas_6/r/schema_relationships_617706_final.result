) CHARACTER SET latin1;
CREATE TABLE `employee` (
`EmployeeID` INT,
`Employee_FName` VARCHAR(64),
`Employee_LName` VARCHAR(64),
`dob` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `timesheet_TGT` (
`TimeSheetID` INT,
`EmployeeID` INT,
`Day_1` INT,
