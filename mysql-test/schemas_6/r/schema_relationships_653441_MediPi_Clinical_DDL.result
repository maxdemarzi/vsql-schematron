INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 653441_MediPi_Clinical_DDL
#
CREATE DATABASE `db_653441_MediPi_Clinical_DDL`;
USE `db_653441_MediPi_Clinical_DDL`;
CREATE TABLE `alert` (
`alert_id` INT,
`patient_uuid` VARCHAR(64),
`alert_time` DATETIME,
`alert_text` VARCHAR(64),
`data_id` INT,
`transmit_success_date` DATETIME,
`retry_attempts` INT,
PRIMARY KEY (`alert_id`)
) CHARACTER SET latin1;
CREATE TABLE `attribute_threshold` (
`attribute_threshold_id` INT,
`attribute_id` INT,
`patient_uuid` VARCHAR(64),
`threshold_type` VARCHAR(64),
`threshold_low_value` VARCHAR(64),
`threshold_high_value` VARCHAR(64),
`effective_date` DATETIME,
PRIMARY KEY (`attribute_threshold_id`)
) CHARACTER SET latin1;
CREATE TABLE `patient` (
`patient_uuid` VARCHAR(64),
`patient_group_uuid` VARCHAR(64),
PRIMARY KEY (`patient_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `patient_details` (
`patient_uuid` VARCHAR(64),
`nhs_number` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`dob` DATETIME,
PRIMARY KEY (`patient_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `patient_group` (
`patient_group_uuid` VARCHAR(64),
`patient_group_name` VARCHAR(64),
PRIMARY KEY (`patient_group_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `recording_device_attribute` (
`attribute_id` INT,
`attribute_name` VARCHAR(64),
`type_id` INT,
`attribute_units` VARCHAR(64),
`attribute_type` VARCHAR(64),
PRIMARY KEY (`attribute_id`)
) CHARACTER SET latin1;
CREATE TABLE `recording_device_data` (
`data_id` INT,
`attribute_id` INT,
`data_value` VARCHAR(64),
`patient_uuid` VARCHAR(64),
`data_value_time` DATETIME,
`downloaded_time` DATETIME,
`schedule_effective_time` DATETIME,
`schedule_expiry_time` DATETIME,
`alert_status` VARCHAR(64),
PRIMARY KEY (`data_id`)
) CHARACTER SET latin1;
CREATE TABLE `recording_device_type` (
`type_id` INT,
`type` VARCHAR(64),
`make` VARCHAR(64),
`model` VARCHAR(64),
`display_name` VARCHAR(64),
PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `clinician_details` (
`clinician_uuid` VARCHAR(64),
`clinician_username` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`patient_group_uuid` VARCHAR(64),
PRIMARY KEY (`clinician_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `clinician_role` (
`clinician_role_id` INT,
`clinician_uuid` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`clinician_role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_653441_MediPi_Clinical_DDL') AS relationships;
relationships
