CREATE DATABASE `db_626039_BOOK_SYSTEM`;
USE `db_626039_BOOK_SYSTEM`;
CREATE TABLE `T_USER` (
`ID` INT,
`USER_NAME` VARCHAR(64),
`USER_PASSWORD` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_BOOK_TYPE` (
`ID` INT,
`TYPE_NAME` VARCHAR(64),
`TYPE_INTRO` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_PUBLISHER` (
`ID` INT,
