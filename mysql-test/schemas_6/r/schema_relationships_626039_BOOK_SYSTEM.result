PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_IN_RECORD` (
`ID` INT,
`RECORD_DATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_BOOK_IN_RECORD` (
`ID` INT,
`BOOK_ID_FK` INT,
`T_IN_RECORD_ID_FK` INT,
`IN_SUM` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
