`PUB_LINK_MAN` VARCHAR(64),
`PUB_INTRO` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_BOOK` (
`ID` INT,
`BOOK_NAME` VARCHAR(64),
`BOOK_INTRO` VARCHAR(64),
`BOOK_PRICE` DECIMAL(10,2),
`TYPE_ID_FK` INT,
`PUB_ID_FK` INT,
`IMAGE_URL` VARCHAR(64),
`AUTHOR` VARCHAR(64),
`REPERTORY_SIZE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_SALE_RECORD` (
`ID` INT,
`RECORD_DATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `T_BOOK_SALE_RECORD` (
`ID` INT,
`BOOK_ID_FK` INT,
`T_SALE_RECORD_ID_FK` INT,
