INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 647925_initial_script
#
CREATE DATABASE `db_647925_initial_script`;
USE `db_647925_initial_script`;
CREATE TABLE `t_user_profile` (
`id` INT,
`name` VARCHAR(64),
`active` BOOL,
`entry_ts` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_user` (
`id` INT,
`user_id` INT,
`login_name` VARCHAR(64),
`login_password` VARCHAR(64),
`entry_ts` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_prescription` (
`user_id` INT,
`name` VARCHAR(64),
`note` VARCHAR(64),
`entry_ts` DATETIME,
`id` INT,
`active` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_med_time` (
`id` INT,
`user_id` INT,
`medication_id` INT,
`time` DATETIME,
PRIMARY KEY (`id`, `user_id`, `medication_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_647925_initial_script') AS relationships;
relationships
Database: db_647925_initial_script

Table Connections:
