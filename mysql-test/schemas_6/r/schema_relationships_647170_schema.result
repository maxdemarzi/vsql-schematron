INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 647170_schema
#
CREATE DATABASE `db_647170_schema`;
USE `db_647170_schema`;
CREATE TABLE `product` (
`product_id` INT,
`name` VARCHAR(64),
`slogan` VARCHAR(64),
`description` VARCHAR(64),
`category` VARCHAR(64),
`default_price` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`review_id` INT,
`product_id` INT,
`rating` INT,
`date` INT,
`summary` VARCHAR(64),
`body` VARCHAR(64),
`recommend` VARCHAR(64),
`reported` VARCHAR(64),
`reviewer_name` VARCHAR(64),
`reviewer_email` VARCHAR(64),
`response` VARCHAR(64),
`helpfulness` INT,
PRIMARY KEY (`review_id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT,
`review_id` INT,
`url` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characteristics` (
`id` INT,
`product_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characteristic_reviews` (
`id` INT,
`characteristic_id` INT,
`review_id` INT,
`value` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_647170_schema') AS relationships;
relationships
Database: db_647170_schema

Table Connections:
------------------
[Implied]  characteristic_reviews.characteristic_id -> characteristics.id
[Implied]  characteristic_reviews.review_id -> reviews.review_id
[Implied]  characteristics.product_id -> product.product_id
[Implied]  photos.review_id -> reviews.review_id
[Implied]  reviews.product_id -> product.product_id

DROP DATABASE `db_647170_schema`;
UNINSTALL EXTENSION vsql_schematron;
