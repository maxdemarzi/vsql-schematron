CREATE TABLE `admins` (
`id` INT,
`email` VARCHAR(64),
`encrypted_password` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`username` VARCHAR(64),
`encrypted_password` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`title` VARCHAR(64),
`body` VARCHAR(64),
`owner_id` INT,
`created_at` DATETIME,
`published_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `relationships` (
`follower_id` INT,
`followed_id` INT,
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `responses` (
`id` INT,
`body` VARCHAR(64),
`post_id` INT,
`owner_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
