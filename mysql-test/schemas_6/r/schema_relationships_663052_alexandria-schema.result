INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 663052_alexandria-schema
#
CREATE DATABASE `db_663052_alexandria_schema`;
USE `db_663052_alexandria_schema`;
CREATE TABLE `writers` (
`id` BIGINT NOT NULL,
`full_name` VARCHAR(50),
`nick_name` VARCHAR(50),
`nationality` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` BIGINT NOT NULL,
`title` VARCHAR(50),
`synopsis` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `writers_books` (
`writer_id` BIGINT,
`book_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `editions` (
`id` BIGINT NOT NULL,
`book_id` BIGINT,
`publishing_company` VARCHAR(50),
`edition` SMALLINT,
`year` SMALLINT,
`language` VARCHAR(50),
`pages` SMALLINT,
`height` DOUBLE,
`width` DOUBLE,
`weight` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`id` BIGINT NOT NULL,
`edition_id` BIGINT,
`content_type` VARCHAR(50),
`temporary` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookcase` (
`id` BIGINT NOT NULL,
`edition_id` BIGINT,
`comments` VARCHAR(50),
`read` BOOLEAN,
`gender` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_663052_alexandria_schema') AS relationships;
relationships
Database: db_663052_alexandria_schema

Table Connections:
------------------
[Implied]  bookcase.edition_id -> editions.id
[Implied]  editions.book_id -> books.id
[Implied]  images.edition_id -> editions.id
[Implied]  writers_books.book_id -> books.id
[Implied]  writers_books.writer_id -> writers.id

DROP DATABASE `db_663052_alexandria_schema`;
UNINSTALL EXTENSION vsql_schematron;
