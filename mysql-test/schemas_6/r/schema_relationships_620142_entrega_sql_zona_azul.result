CREATE DATABASE `db_620142_entrega_sql_zona_azul`;
USE `db_620142_entrega_sql_zona_azul`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`id_card` VARCHAR(50),
`email` VARCHAR(50),
`telefone_number` VARCHAR(50),
`account_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicles` (
`id` VARCHAR(50) NOT NULL,
`plate_number` VARCHAR(50),
`model` VARCHAR(50),
`mark` VARCHAR(50),
`type` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parks` (
`id` VARCHAR(50) NOT NULL,
`initial_time` DATETIME,
`finish_time` DATETIME,
`vehicle_id` VARCHAR(50),
`zone_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zones` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`initial_time` DATETIME,
`finish_time` DATETIME,
`limit_time` VARCHAR(50),
`prize_minute` VARCHAR(50),
`comments` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fines` (
`id` VARCHAR(50) NOT NULL,
`ammount` VARCHAR(50),
`status` BOOLEAN,
`park_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `claims` (
`id` VARCHAR(50) NOT NULL,
`date` DATE,
`comments` VARCHAR(50),
`reason` VARCHAR(50),
`status` BOOLEAN,
`fine_id` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_620142_entrega_sql_zona_azul') AS relationships;
