[Implied]  sets.user_id -> users.id
[Implied]  sets_and_tags.set_id -> sets.id
[Implied]  sets_and_tags.tag_id -> tags.id

DROP DATABASE `db_616958_schema`;
UNINSTALL EXTENSION vsql_schematron;
