CREATE DATABASE `db_624070_base`;
USE `db_624070_base`;
CREATE TABLE `cursos` (
`id` INT NOT NULL,
`titulo` VARCHAR(50),
`profesor` VARCHAR(50),
`dia` VARCHAR(50),
`turno` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alumnos` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellido` VARCHAR(50),
`edad` INT,
`idCurso` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_624070_base') AS relationships;
