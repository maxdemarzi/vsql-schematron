CREATE DATABASE `db_612447_db`;
USE `db_612447_db`;
CREATE TABLE `admin` (
`id` INT,
`username` VARCHAR(64),
`nama_lengkap` VARCHAR(64),
`instansi` VARCHAR(64),
`password` VARCHAR(64),
`status` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `laporan` (
`id` INT,
`tgl_buat` DATETIME,
`judul_laporan` VARCHAR(64),
`jenis` VARCHAR(64),
`tgl_awal` DATETIME,
`tgl_akhir` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `surat` (
`id` INT,
`judul_surat` VARCHAR(64),
`no_surat` VARCHAR(64),
`username` VARCHAR(64),
`nama_pengirim` VARCHAR(64),
`nama_penerima` VARCHAR(64),
`file` VARCHAR(64),
`note` VARCHAR(64),
`verifikasi` DATETIME,
`diverifikasi` DATETIME,
`keterangan` VARCHAR(64)
) CHARACTER SET latin1;
