INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 680396_serverside
#
CREATE DATABASE `db_680396_serverside`;
USE `db_680396_serverside`;
CREATE TABLE `blogpost` (
`id` INT,
`category_id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`timestamp` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`category_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT,
`comment` VARCHAR(64),
`name` VARCHAR(64),
`captcha` VARCHAR(64),
`date_create` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `forumpost` (
`id` INT,
`category_id` INT,
`comment_id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`timestamp` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `images` (
`id` INT,
`name` VARCHAR(64),
`image` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
`id` INT,
`author` VARCHAR(64),
`content` VARCHAR(64),
`timestamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`admin` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_680396_serverside') AS relationships;
relationships
Database: db_680396_serverside

Table Connections:
------------------
[Implied]  blogpost.category_id -> categories.id
[Implied]  forumpost.category_id -> categories.id
[Implied]  forumpost.comment_id -> comment.id

DROP DATABASE `db_680396_serverside`;
