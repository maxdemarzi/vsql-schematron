INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 636191_demo
#
CREATE DATABASE `db_636191_demo`;
USE `db_636191_demo`;
CREATE TABLE `collect` (
`username` VARCHAR(64),
`file_id` INT
) CHARACTER SET latin1;
CREATE TABLE `favourite` (
`username` VARCHAR(64),
`file_id` INT,
`y_n` INT
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` INT,
`filename` VARCHAR(64),
`path` VARCHAR(64),
`username` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file_description` (
`username` VARCHAR(64),
`file_id` INT,
`description` VARCHAR(64),
`id` INT,
`ip_address` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sample_data` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`age` VARCHAR(64),
`gender` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`r_date` DATETIME,
`is_confirm` INT,
`phone_num` INT,
`path` VARCHAR(64),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `user_avatar` (
`username` VARCHAR(64),
`is_set` INT,
`path` VARCHAR(64),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `videos` (
`title` VARCHAR(64),
`username` VARCHAR(64),
`tag` VARCHAR(64),
`videoid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_636191_demo') AS relationships;
relationships
Database: db_636191_demo

Table Connections:
------------------
[Implied]  collect.file_id -> files.id
[Implied]  collect.username -> users.username
[Implied]  favourite.file_id -> files.id
[Implied]  favourite.username -> users.username
[Implied]  file_description.file_id -> files.id
[Implied]  file_description.username -> users.username
[Implied]  files.username -> users.username
[Implied]  user_avatar.username -> users.username
[Implied]  videos.username -> users.username

DROP DATABASE `db_636191_demo`;
UNINSTALL EXTENSION vsql_schematron;
