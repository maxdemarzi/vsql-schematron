CREATE TABLE `servers` (
`sid` INT,
`description` VARCHAR(64),
`game` VARCHAR(64),
`moniker` VARCHAR(64),
`startfile` VARCHAR(64),
`stopcommand` VARCHAR(64),
`warncommand` VARCHAR(64),
`port` INT,
`autostart` INT,
PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `eventType` (
`etid` INT,
`label` VARCHAR(64),
PRIMARY KEY (`etid`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`eid` INT,
`sid` INT,
`time` DATETIME,
`etype` INT,
`args` VARCHAR(64),
PRIMARY KEY (`eid`)
) CHARACTER SET latin1;
