INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 662852_demo
#
CREATE DATABASE `db_662852_demo`;
USE `db_662852_demo`;
CREATE TABLE `Countries` (
`country_ID` INT NOT NULL,
`name` VARCHAR(50),
`population` INT,
PRIMARY KEY (`country_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Persons` (
`person_ID` INT NOT NULL,
`last_name` VARCHAR(50),
`first_name` VARCHAR(50),
`address` VARCHAR(50),
`city_ID` INT,
`country_ID` INT,
PRIMARY KEY (`person_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Cities` (
`city_ID` INT NOT NULL,
`city_name` VARCHAR(50),
`country_ID` INT,
`population` INT,
PRIMARY KEY (`city_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_662852_demo') AS relationships;
relationships
Database: db_662852_demo

Table Connections:
------------------
[Implied]  Cities.country_ID -> Countries.country_ID
[Implied]  Persons.city_ID -> Cities.city_ID
[Implied]  Persons.country_ID -> Countries.country_ID

DROP DATABASE `db_662852_demo`;
UNINSTALL EXTENSION vsql_schematron;
