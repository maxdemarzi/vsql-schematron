INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 688876_schema
#
CREATE DATABASE `db_688876_schema`;
USE `db_688876_schema`;
CREATE TABLE `proprietarios` (
`id` INT,
`nome` VARCHAR(64),
`cpf` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `modelos` (
`id` INT,
`nome` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cores` (
`id` INT,
`nome` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `carros` (
`id` INT,
`modelo` VARCHAR(64),
`marca` VARCHAR(64),
`placa` VARCHAR(64),
`clientes_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `telefones` (
`id` INT,
`tipo` VARCHAR(64),
`numero` VARCHAR(64),
`proprietarios_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `carros_cores` (
`carros_id` INT,
`cores_id` INT,
PRIMARY KEY (`carros_id`, `cores_id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`id` INT,
`nome` VARCHAR(64),
`sexo` VARCHAR(64),
`cpf` VARCHAR(64),
`cidade` VARCHAR(64),
`estado` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_688876_schema') AS relationships;
relationships
Database: db_688876_schema

