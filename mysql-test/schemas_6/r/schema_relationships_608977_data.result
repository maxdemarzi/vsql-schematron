CREATE DATABASE `db_608977_data`;
USE `db_608977_data`;
CREATE TABLE `employee` (
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`department` VARCHAR(50),
`email` VARCHAR(50),
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile_image` (
`id` INT NOT NULL,
`profile_photo` VARCHAR(50),
`employee_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_file` (
`id` INT NOT NULL,
`file_name` TEXT,
`employee_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_608977_data') AS relationships;
