CREATE DATABASE `db_632145_V11_init_tables_tips_comments_pictures`;
USE `db_632145_V11_init_tables_tips_comments_pictures`;
CREATE TABLE `tips` (
`id` INT,
`body` VARCHAR(64),
`pic_id` INT,
`url` VARCHAR(64),
`when_created` DATETIME,
`usuniety` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tip_pictures` (
`id` INT,
`picture` VARCHAR(64),
`when_created` DATETIME,
`usuniety` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tip_comments` (
`id` INT,
`author` INT,
`body` VARCHAR(64),
`tip_id` INT,
`when_created` DATETIME,
`usuniety` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
