`Nome` VARCHAR(64),
`Provincia_App` VARCHAR(64),
`Istituzione` INT,
`Superficie` INT,
`Tipo_Territorio` VARCHAR(64),
`Mare` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `CONTRATTO` (
`Contratto_id` VARCHAR(64),
`Nome` VARCHAR(64),
`Cognome` VARCHAR(64),
`Password` VARCHAR(64),
PRIMARY KEY (`Contratto_id`)
) CHARACTER SET latin1;
CREATE TABLE `DECESSI` (
`Provincia` VARCHAR(64),
`Anno` VARCHAR(64),
`Incidenti` INT,
`Malattie_tumorali` INT,
`Malattie_cardiovascolari` INT,
`Influenza_dec` INT,
`Polmonite_dec` INT,
`Meningite_dec` INT,
`Epatiti_dec` INT,
`Morbillo_dec` INT,
`Tubercolosi_dec` INT,
`Gastroenteriti_dec` INT
) CHARACTER SET latin1;
CREATE TABLE `ENGISS` (
`Eng_id` VARCHAR(64),
`Nome` VARCHAR(64),
`Cognome` VARCHAR(64),
`Password` VARCHAR(64),
PRIMARY KEY (`Eng_id`)
) CHARACTER SET latin1;
CREATE TABLE `EPIDEMIOLOGICI` (
`Comune` INT,
`Data` DATETIME,
`InCura` VARCHAR(64),
`Influenza` INT,
`Polmonite` INT,
`Meningite` INT,
`Epatite` INT,
`Morbillo` INT,
`Tubercolosi` INT,
