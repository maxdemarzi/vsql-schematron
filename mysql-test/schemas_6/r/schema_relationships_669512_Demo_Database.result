CREATE DATABASE `db_669512_Demo_Database`;
USE `db_669512_Demo_Database`;
CREATE TABLE `ANALISTA` (
`Analista_id` VARCHAR(64),
`Password` VARCHAR(64),
PRIMARY KEY (`Analista_id`)
) CHARACTER SET latin1;
CREATE TABLE `COMUNE` (
`ISTAT` INT,
