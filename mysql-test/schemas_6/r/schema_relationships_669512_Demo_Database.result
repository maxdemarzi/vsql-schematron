) CHARACTER SET latin1;
CREATE TABLE `PROVINCIA` (
`Nome_Provincia` VARCHAR(64),
`Regione_App` VARCHAR(64),
`Superficie` INT
) CHARACTER SET latin1;
CREATE TABLE `REGIONE` (
`Nome_Regione` VARCHAR(64),
`Capoluogo` VARCHAR(64),
`Superficie` INT,
PRIMARY KEY (`Nome_Regione`)
) CHARACTER SET latin1;
