INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 605095_data
#
CREATE DATABASE `db_605095_data`;
USE `db_605095_data`;
CREATE TABLE `category` (
`idCategory` INT,
`designationCategory` VARCHAR(64),
PRIMARY KEY (`idCategory`)
) CHARACTER SET latin1;
CREATE TABLE `Produit` (
`idProduit` INT,
`idCategory` INT,
`designation` VARCHAR(64),
`prixUnitaire` DECIMAL(10,2),
`quantite` INT,
PRIMARY KEY (`idProduit`)
) CHARACTER SET latin1;
CREATE TABLE `admin` (
`idAdmin` INT,
`nomAdmin` VARCHAR(64),
`motDePasse` VARCHAR(64),
PRIMARY KEY (`idAdmin`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`idCustomer` INT,
`nameCustomer` VARCHAR(64),
`sexe` VARCHAR(64),
`region` VARCHAR(64),
`age` INT,
`montant` DECIMAL(10,2),
PRIMARY KEY (`idCustomer`)
) CHARACTER SET latin1;
CREATE TABLE `Caisse` (
`idCaisse` INT,
PRIMARY KEY (`idCaisse`)
) CHARACTER SET latin1;
CREATE TABLE `Achat` (
`idAchat` INT,
`idCaisse` INT,
`idProduit` VARCHAR(64),
`quantite` INT,
PRIMARY KEY (`idAchat`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_605095_data') AS relationships;
