INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 671554_SQL_20Queries
#
CREATE DATABASE `db_671554_SQL_20Queries`;
USE `db_671554_SQL_20Queries`;
CREATE TABLE `College` (
`name` VARCHAR(64),
`main_office` VARCHAR(64),
`phone` VARCHAR(64),
`dean` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `Department` (
`name` VARCHAR(64),
`code_number` INT,
`main_office` VARCHAR(64),
`phone` VARCHAR(64),
`chairman` VARCHAR(64),
`chairman_start_date` DATETIME,
PRIMARY KEY (`code_number`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
`name` VARCHAR(64),
`code_number` INT,
`level` INT,
`credit_hours` INT,
`description` VARCHAR(64),
PRIMARY KEY (`code_number`)
) CHARACTER SET latin1;
CREATE TABLE `Instructor` (
`id` INT,
`name` VARCHAR(64),
`office` VARCHAR(64),
`phone` VARCHAR(64),
`inst_rank` VARCHAR(64),
`department_code` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Student` (
`id` INT,
`name` VARCHAR(64),
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`major_code` VARCHAR(64),
`birth_date` DATETIME,
`department_code` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Classroom` (
`id` INT,
`building_code` INT,
`room_number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Section` (
`id` INT,
`course_code` INT,
`instructor_id` INT,
`number` INT,
`semester` VARCHAR(64),
`year` INT,
`classroom_id` INT,
`days_times` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `College_Department` (
`college_name` VARCHAR(64),
`department_code` INT
) CHARACTER SET latin1;
CREATE TABLE `Level` (
`id` INT,
`level_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Student_Section` (
`section_id` INT,
`student_id` INT,
`student_grade` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_671554_SQL_20Queries') AS relationships;
relationships
Database: db_671554_SQL_20Queries

