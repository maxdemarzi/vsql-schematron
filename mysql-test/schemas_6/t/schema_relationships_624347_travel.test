INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624347_travel
--echo #
CREATE DATABASE `db_624347_travel`;
USE `db_624347_travel`;

CREATE TABLE `category` (
  `id` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `name` VARCHAR(64),
  `comment` VARCHAR(64),
  `news_id` INT
) CHARACTER SET latin1;

CREATE TABLE `news` (
  `id` INT,
  `title` VARCHAR(64),
  `short_intro` VARCHAR(64),
  `content` VARCHAR(64),
  `created_date` DATETIME,
  `pic` VARCHAR(64),
  `author` VARCHAR(64),
  `cat_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tagnews` (
  `id` INT,
  `tag_id` INT,
  `news_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624347_travel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624347_travel') AS relationships;
DROP DATABASE `db_624347_travel`;
UNINSTALL EXTENSION vsql_schematron;
