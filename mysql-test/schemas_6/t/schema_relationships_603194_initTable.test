INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 603194_initTable
--echo #
CREATE DATABASE `db_603194_initTable`;
USE `db_603194_initTable`;

CREATE TABLE `ROOM_MANAGE` (
  `R_RNUM` VARCHAR(64),
  `R_RPERSON` DECIMAL(10,2),
  `R_STU_A` VARCHAR(64),
  `R_STU_B` VARCHAR(64),
  `R_ISA` VARCHAR(64),
  `R_ISB` VARCHAR(64),
  PRIMARY KEY (`R_RNUM`)
) CHARACTER SET latin1;

CREATE TABLE `DORM_STUDENTS_MANAGE` (
  `D_SNAME` VARCHAR(64),
  `D_SNUM` DECIMAL(10,2),
  `D_MAJOR` VARCHAR(64),
  `D_BADPOINT` DECIMAL(10,2),
  `D_GOODPOINT` DECIMAL(10,2),
  `D_RNUM` VARCHAR(64),
  `D_RPOSITION` VARCHAR(64),
  `D_OUTDATE` DECIMAL(10,2),
  `D_SEX` VARCHAR(64),
  `D_PHONENUM` VARCHAR(64),
  PRIMARY KEY (`D_SNUM`)
) CHARACTER SET latin1;

CREATE TABLE `CAFETERIA_MANAGE` (
  `C_BREAKFAST` VARCHAR(64),
  `C_LUNCH` VARCHAR(64),
  `C_DINNER` VARCHAR(64),
  `C_DATE` DATETIME,
  `C_PRICE` DECIMAL(10,2),
  PRIMARY KEY (`C_DATE`)
) CHARACTER SET latin1;

CREATE TABLE `STAYOUT_MANAGE` (
  `S_SNAME` VARCHAR(64),
  `S_SNUM` DECIMAL(10,2),
  `S_RNUM` VARCHAR(64),
  `S_APPLY` VARCHAR(64),
  `S_DATE` DATETIME,
  PRIMARY KEY (`S_SNUM`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_603194_initTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_603194_initTable') AS relationships;
DROP DATABASE `db_603194_initTable`;
UNINSTALL EXTENSION vsql_schematron;
