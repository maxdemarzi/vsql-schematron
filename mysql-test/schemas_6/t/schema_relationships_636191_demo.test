INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636191_demo
--echo #
CREATE DATABASE `db_636191_demo`;
USE `db_636191_demo`;

CREATE TABLE `collect` (
  `username` VARCHAR(255),
  `file_id` INT
) CHARACTER SET latin1;

CREATE TABLE `favourite` (
  `username` VARCHAR(255),
  `file_id` INT,
  `y_n` INT
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` INT,
  `filename` VARCHAR(255),
  `path` VARCHAR(255),
  `username` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `file_description` (
  `username` VARCHAR(255),
  `file_id` INT,
  `description` VARCHAR(255),
  `id` INT,
  `ip_address` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sample_data` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `age` VARCHAR(255),
  `gender` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `email` VARCHAR(255),
  `r_date` DATETIME,
  `is_confirm` INT,
  `phone_num` INT,
  `path` VARCHAR(255),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_avatar` (
  `username` VARCHAR(255),
  `is_set` INT,
  `path` VARCHAR(255),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `videos` (
  `title` VARCHAR(255),
  `username` VARCHAR(255),
  `tag` VARCHAR(255),
  `videoid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636191_demo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636191_demo') AS relationships;
DROP DATABASE `db_636191_demo`;
UNINSTALL EXTENSION vsql_schematron;
