INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611094_initial-db
--echo #
CREATE DATABASE `db_611094_initial_db`;
USE `db_611094_initial_db`;

CREATE TABLE `employee` (
  `id` INT,
  `name` VARCHAR(64),
  `tel` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `project_id` VARCHAR(64),
  `project_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `team` (
  `id` INT,
  `project_id` VARCHAR(64),
  `team_id` VARCHAR(64),
  `team_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `member` (
  `id` INT,
  `project_id` VARCHAR(64),
  `team_id` VARCHAR(64),
  `member_id` VARCHAR(64),
  `member_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611094_initial_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611094_initial_db') AS relationships;
DROP DATABASE `db_611094_initial_db`;
UNINSTALL EXTENSION vsql_schematron;
