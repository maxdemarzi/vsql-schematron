INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608054_25
--echo #
CREATE DATABASE `db_608054_25`;
USE `db_608054_25`;
CREATE TABLE `NEWS_ITEM` (
  `ID` VARCHAR(50) NOT NULL,
  `TITLE` VARCHAR(50),
  `TEXT` VARCHAR(50),
  `CREATED_AT` TIMESTAMP NULL,
  `PUBLISH_DATE` TIMESTAMP NULL,
  `LINK_TEXT` VARCHAR(50),
  `LINK_HREF` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `NEWS_RECIPIENT` (
  `NEWS_ITEM_ID` VARCHAR(50),
  `USERCODE` VARCHAR(50),
  `PUBLISH_DATE` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608054_25') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608054_25') AS relationships;
DROP DATABASE `db_608054_25`;
UNINSTALL EXTENSION vsql_schematron;
