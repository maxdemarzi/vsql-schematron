INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 613991_bdprojeto
--echo #
CREATE DATABASE `db_613991_bdprojeto`;
USE `db_613991_bdprojeto`;

CREATE TABLE `mydb.usuario` (
  `login` VARCHAR(64),
  `senha` VARCHAR(64),
  `nivel_permissao` INT,
  PRIMARY KEY (`login`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.clientes` (
  `id` INT,
  `nome` VARCHAR(64),
  `data_nasc` DATETIME,
  `email` VARCHAR(64),
  `imagem` VARCHAR(64),
  `usuario_login` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.administradores` (
  `id` INT,
  `nome` VARCHAR(64),
  `imagem` VARCHAR(64),
  `usuario_login` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.autores` (
  `id` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.editoras` (
  `id` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.livros` (
  `id` INT,
  `titulo` VARCHAR(64),
  `descricao` VARCHAR(64),
  `quantidade` INT,
  `imagem` VARCHAR(64),
  `editoras_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.emprestimos` (
  `id` INT,
  `data_devolucao` DATETIME,
  `data_emprestimo` DATETIME,
  `data_real_devolucao` DATETIME,
  `status` INT,
  `livros_id` INT,
  `clientes_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.livros_has_autores` (
  `livros_id` INT,
  `autores_id` INT,
  PRIMARY KEY (`livros_id`, `autores_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_613991_bdprojeto') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_613991_bdprojeto') AS relationships;
DROP DATABASE `db_613991_bdprojeto`;
UNINSTALL EXTENSION vsql_schematron;
