INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 685525_create_db
--echo #
CREATE DATABASE `db_685525_create_db`;
USE `db_685525_create_db`;

CREATE TABLE `Role` (
  `id` INT,
  `name` VARCHAR(64),
  `omnis_permissions` INT,
  `roles_permissions` INT,
  `users_permissions` INT,
  `pending_machines_permissions` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_685525_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_685525_create_db') AS relationships;
DROP DATABASE `db_685525_create_db`;
UNINSTALL EXTENSION vsql_schematron;
