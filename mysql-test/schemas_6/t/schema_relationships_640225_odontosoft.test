INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 640225_odontosoft
--echo #
CREATE DATABASE `db_640225_odontosoft`;
USE `db_640225_odontosoft`;
CREATE TABLE `Paciente` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `dataNascimento` DATE,
  `cpf` VARCHAR(50),
  `telefone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Funcionario` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `telefone` VARCHAR(50),
  `dataNascimento` DATE,
  `rg` VARCHAR(50),
  `salario` DOUBLE,
  `isGerente` BOOLEAN,
  `isDentista` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Procedimento` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  `preco` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario` (
  `id` VARCHAR(50) NOT NULL,
  `senha` VARCHAR(50),
  `idFuncionario` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Consulta` (
  `id` INT NOT NULL,
  `idPaciente` INT,
  `idFuncionario` INT,
  `dataConsulta` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Consulta_has_Procedimento` (
  `idConsulta` INT NOT NULL,
  `idProcedimento` INT NOT NULL,
  `quantidade` INT,
  PRIMARY KEY (`idConsulta`, `idProcedimento`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_640225_odontosoft') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_640225_odontosoft') AS relationships;
DROP DATABASE `db_640225_odontosoft`;
UNINSTALL EXTENSION vsql_schematron;
