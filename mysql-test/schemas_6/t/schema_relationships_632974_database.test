INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 632974_database
--echo #
CREATE DATABASE `db_632974_database`;
USE `db_632974_database`;
CREATE TABLE `barang` (
  `KODE` VARCHAR(50),
  `NAMA` VARCHAR(50),
  `KATEGORI` VARCHAR(50),
  `HARGA` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `item_penjualan` (
  `NOTA` VARCHAR(50),
  `KODE_BARANG` VARCHAR(50),
  `Qty` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `migration` VARCHAR(50),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pelanggan` (
  `ID_PELANGGAN` VARCHAR(50),
  `NAMA` VARCHAR(50),
  `DOMISILI` VARCHAR(50),
  `JENIS_KELAMIN` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `penjualan` (
  `ID_NOTA` VARCHAR(50),
  `TGL` DATE,
  `KODE_PELANGGAN` VARCHAR(50),
  `TOTAL` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_632974_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_632974_database') AS relationships;
DROP DATABASE `db_632974_database`;
UNINSTALL EXTENSION vsql_schematron;
