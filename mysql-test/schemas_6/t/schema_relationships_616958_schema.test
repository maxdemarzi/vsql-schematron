INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 616958_schema
--echo #
CREATE DATABASE `db_616958_schema`;
USE `db_616958_schema`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `folders` (
  `id` INT,
  `name` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sets` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `flash_cards` (
  `id` INT,
  `term` VARCHAR(255),
  `definition` VARCHAR(255),
  `q_type` INT,
  `set_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sets_and_tags` (
  `set_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`set_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `folders_and_sets` (
  `folder_id` INT,
  `set_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_616958_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_616958_schema') AS relationships;
DROP DATABASE `db_616958_schema`;
UNINSTALL EXTENSION vsql_schematron;
