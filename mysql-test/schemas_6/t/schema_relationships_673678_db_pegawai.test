INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 673678_db_pegawai
--echo #
CREATE DATABASE `db_673678_db_pegawai`;
USE `db_673678_db_pegawai`;

CREATE TABLE `tb_cuti` (
  `id_cuti` INT,
  `nip` VARCHAR(64),
  `jenis_cuti` VARCHAR(64),
  `tanggal_mulai` DATETIME,
  `tanggal_akhir` DATETIME,
  `file` VARCHAR(64),
  `status` VARCHAR(64),
  `email` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tb_pegawai` (
  `pgw_nip` VARCHAR(64),
  `pgw_nama` VARCHAR(64),
  `pgw_tempatlahir` VARCHAR(64),
  `pgw_tgllahir` DATETIME,
  `pgw_jk` VARCHAR(64),
  `pgw_jabatan` VARCHAR(64),
  `pgw_golongan` VARCHAR(64),
  `email` VARCHAR(64),
  `pgw_MasaKerja` INT,
  `pgw_PendidikanTerakhir` VARCHAR(64),
  `pgw_TahunLulus` VARCHAR(64),
  `pgw_Usia` VARCHAR(64),
  PRIMARY KEY (`pgw_nip`)
) CHARACTER SET latin1;

CREATE TABLE `tb_user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_673678_db_pegawai') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_673678_db_pegawai') AS relationships;
DROP DATABASE `db_673678_db_pegawai`;
UNINSTALL EXTENSION vsql_schematron;
