INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 676991_db_sirkus
--echo #
CREATE DATABASE `db_676991_db_sirkus`;
USE `db_676991_db_sirkus`;

CREATE TABLE `tb_absen` (
  `id` INT,
  `id_stud` INT,
  `attend` VARCHAR(64),
  `date` DATETIME,
  `id_class` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_jadwal` (
  `id` INT,
  `class` VARCHAR(64),
  `day` VARCHAR(64),
  `time` DATETIME,
  `id_teacher` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_nilai` (
  `id` INT,
  `task1` INT,
  `task2` INT,
  `task3` INT,
  `test1` INT,
  `test2` INT,
  `id_stud` INT,
  `id_class` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_pembagian_kelas` (
  `id` INT,
  `id_class` INT,
  `id_student` INT
) CHARACTER SET latin1;

CREATE TABLE `tb_siswa` (
  `id` INT,
  `nik` VARCHAR(64),
  `name` VARCHAR(64),
  `date_of_birth` DATETIME,
  `gender` VARCHAR(64),
  `school` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `image` VARCHAR(64),
  `father_name` VARCHAR(64),
  `father_occup` VARCHAR(64),
  `father_phone` VARCHAR(64),
  `mother_name` VARCHAR(64),
  `mother_occup` VARCHAR(64),
  `mother_phone` VARCHAR(64),
  `parent_add` VARCHAR(64),
  `date_of_register` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_staff` (
  `id` INT,
  `nik` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `image` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tb_teacher` (
  `id` INT,
  `nik` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `image` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tb_user` (
  `code` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_676991_db_sirkus') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_676991_db_sirkus') AS relationships;
DROP DATABASE `db_676991_db_sirkus`;
UNINSTALL EXTENSION vsql_schematron;
