INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 639335_DDL
--echo #
CREATE DATABASE `db_639335_DDL`;
USE `db_639335_DDL`;

CREATE TABLE `faction` (
  `faction_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`faction_id`)
) CHARACTER SET latin1;

CREATE TABLE `ship` (
  `ship_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ship_id`)
) CHARACTER SET latin1;

CREATE TABLE `pilot` (
  `pilot_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`pilot_id`)
) CHARACTER SET latin1;

CREATE TABLE `faction_ship_pilot` (
  `faction_ship_pilot_id` INT,
  `faction_id` INT,
  `ship_id` INT,
  `pilot_id` INT,
  `pilot_skill` INT,
  PRIMARY KEY (`faction_ship_pilot_id`)
) CHARACTER SET latin1;

CREATE TABLE `game_event` (
  `game_event_id` INT,
  `name` VARCHAR(64),
  `game_order` INT,
  PRIMARY KEY (`game_event_id`)
) CHARACTER SET latin1;

CREATE TABLE `upgrade_type` (
  `upgrade_type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`upgrade_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `upgrade` (
  `upgrade_id` INT,
  `upgrade_type_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`upgrade_id`)
) CHARACTER SET latin1;

CREATE TABLE `upgrade_game_event` (
  `upgrade_game_event_id` INT,
  `upgrade_id` INT,
  `game_event_id` INT,
  PRIMARY KEY (`upgrade_game_event_id`)
) CHARACTER SET latin1;

CREATE TABLE `ship_list` (
  `ship_list_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ship_list_id`)
) CHARACTER SET latin1;

CREATE TABLE `ship_list_item` (
  `ship_list_item_id` INT,
  `ship_list_id` INT,
  `faction_ship_pilot_id` INT,
  `upgrade_id` INT,
  PRIMARY KEY (`ship_list_item_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_639335_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_639335_DDL') AS relationships;
DROP DATABASE `db_639335_DDL`;
UNINSTALL EXTENSION vsql_schematron;
