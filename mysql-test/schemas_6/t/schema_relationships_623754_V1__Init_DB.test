INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 623754_V1__Init_DB
--echo #
CREATE DATABASE `db_623754_V1__Init_DB`;
USE `db_623754_V1__Init_DB`;
CREATE TABLE `usr` (
  `id` BIGINT NOT NULL,
  `active_code` VARCHAR(50),
  `active` BOOLEAN,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` BIGINT NOT NULL,
  `post_date` DATETIME,
  `tag` VARCHAR(50),
  `text` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` BIGINT NOT NULL,
  `text` VARCHAR(50),
  `user_id` BIGINT,
  `message_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` BIGINT,
  `roles` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_623754_V1__Init_DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_623754_V1__Init_DB') AS relationships;
DROP DATABASE `db_623754_V1__Init_DB`;
UNINSTALL EXTENSION vsql_schematron;
