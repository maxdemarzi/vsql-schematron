INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 653394_create_tables
--echo #
CREATE DATABASE `db_653394_create_tables`;
USE `db_653394_create_tables`;

CREATE TABLE `UserBlockstackIDs` (
  `id` INT,
  `BlockstackID` VARCHAR(64),
  `cid` INT,
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserContacts` (
  `cid` INT,
  `Name` VARCHAR(64),
  `Gender` VARCHAR(64),
  `Birthday` DATETIME,
  `Hometown` VARCHAR(64),
  `Title` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;

CREATE TABLE `UserEmails` (
  `id` INT,
  `cid` INT,
  `Email` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserFollowers` (
  `id` INT,
  `cid` INT,
  `ProfileID` INT,
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserImages` (
  `id` INT,
  `cid` INT,
  `pid` INT,
  `ResourceURI` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserLoginTimes` (
  `id` INT,
  `cid` INT,
  `Login` DATETIME,
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserPosts` (
  `id` INT,
  `cid` INT,
  `Content` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_653394_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_653394_create_tables') AS relationships;
DROP DATABASE `db_653394_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
