INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608158_migration
--echo #
CREATE DATABASE `db_608158_migration`;
USE `db_608158_migration`;
CREATE TABLE `shopping_carts` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `new_books` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `publishYear` INT,
  `isbn` INT,
  `description` TEXT,
  `price` DOUBLE,
  `coverUrl` TEXT,
  `coverDataUri` TEXT,
  `sold` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `transactionId` TEXT,
  `shoppingCartId` TEXT,
  `publisherId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608158_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608158_migration') AS relationships;
DROP DATABASE `db_608158_migration`;
UNINSTALL EXTENSION vsql_schematron;
