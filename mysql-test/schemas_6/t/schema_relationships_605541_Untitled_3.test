INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605541_Untitled_3
--echo #
CREATE DATABASE `db_605541_Untitled_3`;
USE `db_605541_Untitled_3`;

CREATE TABLE `housingComplex` (
  `complex_id` INT,
  `boretslag_name` VARCHAR(255),
  `adress` VARCHAR(255),
  `anno` INT,
  PRIMARY KEY (`complex_id`)
) CHARACTER SET latin1;

CREATE TABLE `houses` (
  `house_id` INT,
  `complex_id` INT,
  `numApartments` INT,
  `numFloors` INT,
  PRIMARY KEY (`house_id`)
) CHARACTER SET latin1;

CREATE TABLE `apartments` (
  `apt_id` INT,
  `apt_nr` INT,
  `house_id` INT,
  `member_id` INT,
  `numRooms` INT,
  `squareFeet` INT,
  PRIMARY KEY (`apt_id`)
) CHARACTER SET latin1;

CREATE TABLE `members` (
  `member_id` INT,
  `firstname` VARCHAR(255),
  `lastname` VARCHAR(255),
  `share` INT,
  PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605541_Untitled_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605541_Untitled_3') AS relationships;
DROP DATABASE `db_605541_Untitled_3`;
UNINSTALL EXTENSION vsql_schematron;
