INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659512_create%20database
--echo #
CREATE DATABASE `db_659512_create_20database`;
USE `db_659512_create_20database`;

CREATE TABLE `player` (
  `player_id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `admin` BOOL,
  PRIMARY KEY (`player_id`)
) CHARACTER SET latin1;

CREATE TABLE `characteristic` (
  `characteristic_id` INT,
  `name` VARCHAR(64),
  `rollable` BOOL,
  PRIMARY KEY (`characteristic_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_characteristic` (
  `player_characteristic_id` INT,
  `player_id` INT,
  `characteristic_id` INT,
  `value` INT,
  PRIMARY KEY (`player_characteristic_id`)
) CHARACTER SET latin1;

CREATE TABLE `specialization` (
  `specialization_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`specialization_id`)
) CHARACTER SET latin1;

CREATE TABLE `skill` (
  `skill_id` INT,
  `specialization_id` INT,
  `name` VARCHAR(64),
  `mandatory` BOOL,
  `start_value` INT,
  PRIMARY KEY (`skill_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_skill` (
  `player_skill_id` INT,
  `player_id` INT,
  `skill_id` INT,
  `value` INT,
  `checked` BOOL,
  PRIMARY KEY (`player_skill_id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute` (
  `attribute_id` INT,
  `name` VARCHAR(64),
  `rollable` BOOL,
  `bg_color` VARCHAR(64),
  `fill_color` VARCHAR(64),
  PRIMARY KEY (`attribute_id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute_status` (
  `attribute_status_id` INT,
  `attribute_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`attribute_status_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_attribute` (
  `player_attribute_id` INT,
  `player_id` INT,
  `attribute_id` INT,
  `value` INT,
  `max_value` INT,
  PRIMARY KEY (`player_attribute_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_attribute_status` (
  `player_attribute_status_id` INT,
  `player_id` INT,
  `attribute_status_id` INT,
  `value` BOOL,
  PRIMARY KEY (`player_attribute_status_id`)
) CHARACTER SET latin1;

CREATE TABLE `equipment` (
  `equipment_id` INT,
  `name` VARCHAR(64),
  `skill_id` INT,
  `damage` VARCHAR(64),
  `range` VARCHAR(64),
  `attacks` VARCHAR(64),
  `ammo` VARCHAR(64),
  `malfunc` VARCHAR(64),
  PRIMARY KEY (`equipment_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_equipment` (
  `player_equipment_id` INT,
  `player_id` INT,
  `equipment_id` INT,
  `current_ammo` VARCHAR(64),
  `using` BOOL,
  PRIMARY KEY (`player_equipment_id`)
) CHARACTER SET latin1;

CREATE TABLE `spec` (
  `spec_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`spec_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_spec` (
  `player_spec_id` INT,
  `player_id` INT,
  `spec_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`player_spec_id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `item_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_item` (
  `player_item_id` INT,
  `player_id` INT,
  `item_id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`player_item_id`)
) CHARACTER SET latin1;

CREATE TABLE `info` (
  `info_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`info_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_info` (
  `player_info_id` INT,
  `player_id` INT,
  `info_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`player_info_id`)
) CHARACTER SET latin1;

CREATE TABLE `extra_info` (
  `extra_info_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`extra_info_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_extra_info` (
  `player_extra_info_id` INT,
  `player_id` INT,
  `extra_info_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`player_extra_info_id`)
) CHARACTER SET latin1;

CREATE TABLE `finance` (
  `finance_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`finance_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_finance` (
  `player_finance_id` INT,
  `player_id` INT,
  `finance_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`player_finance_id`)
) CHARACTER SET latin1;

CREATE TABLE `avatar` (
  `avatar_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`avatar_id`)
) CHARACTER SET latin1;

CREATE TABLE `player_avatar` (
  `player_avatar_id` INT,
  `player_id` INT,
  `avatar_id` INT,
  `link` VARCHAR(64),
  PRIMARY KEY (`player_avatar_id`)
) CHARACTER SET latin1;

CREATE TABLE `admin_key` (
  `key` INT,
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;

CREATE TABLE `admin_note` (
  `admin_note_id` INT,
  `admin_id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`admin_note_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659512_create_20database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659512_create_20database') AS relationships;
DROP DATABASE `db_659512_create_20database`;
UNINSTALL EXTENSION vsql_schematron;
