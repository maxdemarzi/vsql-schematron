INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 667882_migration
--echo #
CREATE DATABASE `db_667882_migration`;
USE `db_667882_migration`;

CREATE TABLE `actor` (
  `actor_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;

CREATE TABLE `address` (
  `address_id` INT,
  `address` VARCHAR(64),
  `address2` VARCHAR(64),
  `district` VARCHAR(64),
  `city_id` INT,
  `postal_code` VARCHAR(64),
  `phone` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `category_id` INT,
  `name` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `city` (
  `city_id` INT,
  `city` VARCHAR(64),
  `country_id` INT,
  `last_update` DATETIME,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;

CREATE TABLE `country` (
  `country_id` INT,
  `country` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `customer_id` INT,
  `store_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `address_id` INT,
  `activebool` BOOL,
  `create_date` DATETIME,
  `last_update` DATETIME,
  `active` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `film` (
  `film_id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `release_year` INT,
  `language_id` INT,
  `original_language_id` INT,
  `rental_duration` INT,
  `rental_rate` DECIMAL(10,2),
  `length` INT,
  `replacement_cost` DECIMAL(10,2),
  `rating` VARCHAR(64),
  `last_update` DATETIME,
  `special_features` VARCHAR(64),
  `fulltext` VARCHAR(64),
  PRIMARY KEY (`film_id`)
) CHARACTER SET latin1;

CREATE TABLE `film_actor` (
  `actor_id` INT,
  `film_id` INT,
  `last_update` DATETIME,
  PRIMARY KEY (`actor_id`, `film_id`)
) CHARACTER SET latin1;

CREATE TABLE `film_category` (
  `film_id` INT,
  `category_id` INT,
  `last_update` DATETIME,
  PRIMARY KEY (`film_id`, `category_id`)
) CHARACTER SET latin1;

CREATE TABLE `inventory` (
  `inventory_id` INT,
  `film_id` INT,
  `store_id` INT,
  `last_update` DATETIME,
  PRIMARY KEY (`inventory_id`)
) CHARACTER SET latin1;

CREATE TABLE `language` (
  `language_id` INT,
  `name` VARCHAR(64),
  `last_update` DATETIME,
  PRIMARY KEY (`language_id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `payment_id` INT,
  `customer_id` INT,
  `staff_id` INT,
  `rental_id` INT,
  `amount` DECIMAL(10,2),
  `payment_date` DATETIME,
  PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;

