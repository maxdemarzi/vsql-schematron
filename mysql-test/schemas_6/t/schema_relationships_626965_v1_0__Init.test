INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626965_v1_0__Init
--echo #
CREATE DATABASE `db_626965_v1_0__Init`;
USE `db_626965_v1_0__Init`;
CREATE TABLE `product` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_cart_line` (
  `id` INT NOT NULL,
  `shopping_cart_id` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  `amount` INT,
  PRIMARY KEY (`shopping_cart_id`, `id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626965_v1_0__Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626965_v1_0__Init') AS relationships;
DROP DATABASE `db_626965_v1_0__Init`;
UNINSTALL EXTENSION vsql_schematron;
