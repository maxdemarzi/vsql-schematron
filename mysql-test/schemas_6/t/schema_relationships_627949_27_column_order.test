INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 627949_27-column-order
--echo #
CREATE DATABASE `db_627949_27_column_order`;
USE `db_627949_27_column_order`;

CREATE TABLE `aaa` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bbb` (
  `id` INT,
  `a` INT,
  `b` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_627949_27_column_order') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_627949_27_column_order') AS relationships;
DROP DATABASE `db_627949_27_column_order`;
UNINSTALL EXTENSION vsql_schematron;
