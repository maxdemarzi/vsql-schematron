INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 616079_init_corpus
--echo #
CREATE DATABASE `db_616079_init_corpus`;
USE `db_616079_init_corpus`;

CREATE TABLE `corpus` (
  `ID` INT,
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `document` (
  `ID` INT,
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  `lang` VARCHAR(64),
  `corpusID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `sentence` (
  `ID` INT,
  `ident` VARCHAR(64),
  `text` VARCHAR(64),
  `docID` INT,
  `flag` INT,
  `comment` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `token` (
  `ID` INT,
  `sid` INT,
  `widx` INT,
  `cfrom` INT,
  `cto` INT,
  `text` VARCHAR(64),
  `lemma` VARCHAR(64),
  `pos` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `concept` (
  `ID` INT,
  `sid` INT,
  `cidx` INT,
  `clemma` VARCHAR(64),
  `tag` VARCHAR(64),
  `flag` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `ID` INT,
  `sid` INT,
  `wid` INT,
  `cfrom` INT,
  `cto` INT,
  `value` VARCHAR(64),
  `source` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `cwl` (
  `sid` INT,
  `cid` INT,
  `wid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_616079_init_corpus') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_616079_init_corpus') AS relationships;
DROP DATABASE `db_616079_init_corpus`;
UNINSTALL EXTENSION vsql_schematron;
