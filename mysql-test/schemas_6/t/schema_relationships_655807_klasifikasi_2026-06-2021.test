INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655807_klasifikasi%2026-06-2021
--echo #
CREATE DATABASE `db_655807_klasifikasi_2026_06_2021`;
USE `db_655807_klasifikasi_2026_06_2021`;
CREATE TABLE `data_testing` (
  `id_testing` VARCHAR(50) NOT NULL,
  `Kelas_Apel` VARCHAR(50),
  `Mean_H` DOUBLE,
  `Mean_S` DOUBLE,
  `Mean_I` DOUBLE,
  `Skewness_H` DOUBLE,
  `Skewness_S` DOUBLE,
  `Skewness_I` DOUBLE,
  `Kurtosis_H` DOUBLE,
  `Kurtosis_S` DOUBLE,
  `Kurtosis_I` DOUBLE,
  PRIMARY KEY (`id_testing`)
) CHARACTER SET latin1;
CREATE TABLE `data_training` (
  `id_training` VARCHAR(50),
  `Kelas_Asli` VARCHAR(50),
  `Kelas_Klasifikasi` VARCHAR(50),
  `Mean_H` DOUBLE,
  `Mean_S` DOUBLE,
  `Mean_I` DOUBLE,
  `Skewness_H` DOUBLE,
  `Skewness_S` DOUBLE,
  `Skewness_I` DOUBLE,
  `Kurtosis_H` DOUBLE,
  `Kurtosis_S` DOUBLE,
  `Kurtosis_I` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `pengujian` (
  `id_uji` VARCHAR(50),
  `id_user` VARCHAR(50),
  `Mean_H` DOUBLE,
  `Mean_S` DOUBLE,
  `Mean_I` DOUBLE,
  `Skewness_H` DOUBLE,
  `Skewness_S` DOUBLE,
  `Skewness_I` DOUBLE,
  `Kurtosis_H` DOUBLE,
  `Kurtosis_S` DOUBLE,
  `Kurtosis_I` DOUBLE,
  `hasil_klasifikasi` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id_role` VARCHAR(50) NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`id_role`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` VARCHAR(50),
  `id_role` VARCHAR(50),
  `foto_user` VARCHAR(50),
  `nama_user` VARCHAR(50),
  `deskripsi` TEXT,
  `password` VARCHAR(50),
  `tanggal` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655807_klasifikasi_2026_06_2021') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655807_klasifikasi_2026_06_2021') AS relationships;
DROP DATABASE `db_655807_klasifikasi_2026_06_2021`;
UNINSTALL EXTENSION vsql_schematron;
