INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 669861_database
--echo #
CREATE DATABASE `db_669861_database`;
USE `db_669861_database`;

CREATE TABLE `account` (
  `id` INT,
  `client_id` INT,
  `account_number` VARCHAR(64),
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `utility` VARCHAR(64),
  `account_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `arcadia` (
  `id` INT,
  `text` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bill` (
  `id` INT,
  `account_id` INT,
  `start_date` DATETIME,
  `end_date` DATETIME,
  `usage` INT,
  `charges` DECIMAL(10,2),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `is_active` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_669861_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_669861_database') AS relationships;
DROP DATABASE `db_669861_database`;
UNINSTALL EXTENSION vsql_schematron;
