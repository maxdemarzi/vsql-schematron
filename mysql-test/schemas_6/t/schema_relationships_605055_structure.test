INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605055_structure
--echo #
CREATE DATABASE `db_605055_structure`;
USE `db_605055_structure`;

CREATE TABLE `category` (
  `title` VARCHAR(64),
  `product_number` INT,
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `stores` VARCHAR(64),
  `site_url` VARCHAR(64),
  `score` INT,
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;

CREATE TABLE `category_per_product` (
  `category_title` VARCHAR(64),
  `product_title` VARCHAR(64),
  PRIMARY KEY (`category_title`, `product_title`)
) CHARACTER SET latin1;

CREATE TABLE `substitute` (
  `product_title` VARCHAR(64),
  PRIMARY KEY (`product_title`)
) CHARACTER SET latin1;

CREATE TABLE `product_per_substitute` (
  `substitute_title` VARCHAR(64),
  `product_title` VARCHAR(64),
  PRIMARY KEY (`substitute_title`, `product_title`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605055_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605055_structure') AS relationships;
DROP DATABASE `db_605055_structure`;
UNINSTALL EXTENSION vsql_schematron;
