INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 614295_zadatak2
--echo #
CREATE DATABASE `db_614295_zadatak2`;
USE `db_614295_zadatak2`;

CREATE TABLE `fakture` (
  `sifra_fakture` INT,
  `sifra_firme` INT,
  `datum` DATETIME,
  `ulaz_izlaz` VARCHAR(64),
  PRIMARY KEY (`sifra_fakture`)
) CHARACTER SET latin1;

CREATE TABLE `detalji_fakture` (
  `id` INT,
  `faktura` INT,
  `red_br` INT,
  `proizvod` INT,
  `kolicina` DECIMAL(10,2),
  `dan_cena` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_614295_zadatak2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_614295_zadatak2') AS relationships;
DROP DATABASE `db_614295_zadatak2`;
UNINSTALL EXTENSION vsql_schematron;
