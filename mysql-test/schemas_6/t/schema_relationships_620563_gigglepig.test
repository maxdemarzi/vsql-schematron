INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620563_gigglepig
--echo #
CREATE DATABASE `db_620563_gigglepig`;
USE `db_620563_gigglepig`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `email` VARCHAR(50),
  `full_name` VARCHAR(50),
  `profile_pic` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_auth_keys` (
  `user_id` INT NOT NULL,
  `auth_key` VARCHAR(50),
  `valid_till` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620563_gigglepig') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620563_gigglepig') AS relationships;
DROP DATABASE `db_620563_gigglepig`;
UNINSTALL EXTENSION vsql_schematron;
