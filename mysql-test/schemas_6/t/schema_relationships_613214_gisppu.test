INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 613214_gisppu
--echo #
CREATE DATABASE `db_613214_gisppu`;
USE `db_613214_gisppu`;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `migration` VARCHAR(50),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `outlets` (
  `nib` VARCHAR(50),
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `nama_pendaftar` VARCHAR(50),
  `telepon_pendaftar` VARCHAR(50),
  `email_pendaftar` VARCHAR(50),
  `nik` VARCHAR(50),
  `propinsi` VARCHAR(50),
  `kab_kota` VARCHAR(50),
  `kecamatan` VARCHAR(50),
  `kelurahan` VARCHAR(50),
  `jumlah_tki_l` SMALLINT,
  `jumlah_tki_p` SMALLINT,
  `kbli` VARCHAR(50),
  `bangunan` INT,
  `mesin_peralatan` INT,
  `peralatan_impor` INT,
  `pembelian_dan_pematangan_tanah` INT,
  `investasi_lain_lain` INT,
  `pembelian_pematangan_lain_lain` INT,
  `modal_kerja_3_bulanan` INT,
  `jumlah_investasisin_p` INT,
  `tanggal_pengajuan_pemohonan_berusaha` DATE,
  `tanggal_terbit_oss` DATE,
  `jenis_perseroan` VARCHAR(50),
  `status_penanaman_modal` VARCHAR(50),
  `nama_pemegang_saham` VARCHAR(50),
  `total_modal` INT,
  `jabatan` VARCHAR(50),
  `negara_asal` VARCHAR(50),
  `penanggung_jawab` VARCHAR(50),
  `latitude` VARCHAR(50),
  `longitude` VARCHAR(50),
  `creator_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
  `email` VARCHAR(50),
  `token` VARCHAR(50),
  `created_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `email_verified_at` TIMESTAMP NULL,
  `password` VARCHAR(50),
  `remember_token` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_613214_gisppu') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_613214_gisppu') AS relationships;
DROP DATABASE `db_613214_gisppu`;
UNINSTALL EXTENSION vsql_schematron;
