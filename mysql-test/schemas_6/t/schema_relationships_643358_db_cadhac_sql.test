INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 643358_db_cadhac_sql
--echo #
CREATE DATABASE `db_643358_db_cadhac_sql`;
USE `db_643358_db_cadhac_sql`;
CREATE TABLE `accion` (
  `id` INT NOT NULL,
  `titulo` TEXT,
  `fecha` DATE,
  `texto` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
  `id` INT,
  `evento_id` INT,
  `imagen` TEXT
) CHARACTER SET latin1;
CREATE TABLE `comunicado` (
  `id` INT NOT NULL,
  `titulo` TEXT,
  `fecha` DATE,
  `texto` TEXT,
  `imagen` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `desaparecido` (
  `id` INT NOT NULL,
  `nombre` TEXT,
  `imagen` TEXT,
  `fecha` DATE,
  `lugar` TEXT,
  `descripcion` TEXT,
  `estado_civil` TEXT,
  `ocupacion` TEXT,
  `edad` INT,
  `talla` DECIMAL(10,2),
  `tez` TEXT,
  `ojos` TEXT,
  `otras_senias` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `evento` (
  `id` INT NOT NULL,
  `nombre` TEXT,
  `descripcion` TEXT,
  `fecha` DATE,
  `titulo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `imagen` (
  `id` INT,
  `imagen` TEXT,
  `comunicado_id` INT
) CHARACTER SET latin1;
CREATE TABLE `publicacion` (
  `id` INT NOT NULL,
  `titulo` TEXT,
  `descripcion` TEXT,
  `espanol` TEXT,
  `ingles` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_643358_db_cadhac_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_643358_db_cadhac_sql') AS relationships;
DROP DATABASE `db_643358_db_cadhac_sql`;
UNINSTALL EXTENSION vsql_schematron;
