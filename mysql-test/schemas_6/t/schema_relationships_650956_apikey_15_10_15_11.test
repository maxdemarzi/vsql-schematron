INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 650956_apikey-15.10-15.11
--echo #
CREATE DATABASE `db_650956_apikey_15_10_15_11`;
USE `db_650956_apikey_15_10_15_11`;

CREATE TABLE `apikey.apikeys` (
  `apikey` VARCHAR(64),
  `note` VARCHAR(64),
  `isSuperKey` BOOL,
  `owner` VARCHAR(64),
  `starts` DATETIME,
  `expires` DATETIME,
  PRIMARY KEY (`apikey`)
) CHARACTER SET latin1;

CREATE TABLE `apikey.key_revocations` (
  `apikey` VARCHAR(64),
  `revokedOn` DATETIME,
  `revokedBy` VARCHAR(64),
  `reason` VARCHAR(64),
  PRIMARY KEY (`apikey`)
) CHARACTER SET latin1;

CREATE TABLE `apikey.allowed_services` (
  `apikey` VARCHAR(64),
  `moduleName` VARCHAR(64),
  `serviceName` VARCHAR(64),
  PRIMARY KEY (`apikey`, `moduleName`, `serviceName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_650956_apikey_15_10_15_11') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_650956_apikey_15_10_15_11') AS relationships;
DROP DATABASE `db_650956_apikey_15_10_15_11`;
UNINSTALL EXTENSION vsql_schematron;
