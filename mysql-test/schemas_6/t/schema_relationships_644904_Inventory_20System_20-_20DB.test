INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644904_Inventory%20System%20-%20DB
--echo #
CREATE DATABASE `db_644904_Inventory_20System_20__20DB`;
USE `db_644904_Inventory_20System_20__20DB`;
CREATE TABLE `dummy` (
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `homephone` VARCHAR(50),
  `cellphone` VARCHAR(50),
  `workphone` VARCHAR(50),
  `street` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `purchase_orders` (
  `poNumber` INT NOT NULL,
  `orderDate` DATE,
  `shipDate` DATE,
  `customerId` INT,
  PRIMARY KEY (`poNumber`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
  `noOfItems` INT,
  `poNumber` INT,
  `itemNumber` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644904_Inventory_20System_20__20DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644904_Inventory_20System_20__20DB') AS relationships;
DROP DATABASE `db_644904_Inventory_20System_20__20DB`;
UNINSTALL EXTENSION vsql_schematron;
