INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 675698_BarBeerDrinkerSample
--echo #
CREATE DATABASE `db_675698_BarBeerDrinkerSample`;
USE `db_675698_BarBeerDrinkerSample`;

CREATE TABLE `bars` (
  `name` VARCHAR(64),
  `license` VARCHAR(64),
  `city` VARCHAR(64),
  `phone` VARCHAR(64),
  `addr` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `beers` (
  `name` VARCHAR(64),
  `manf` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `drinkers` (
  `name` VARCHAR(64),
  `city` VARCHAR(64),
  `phone` VARCHAR(64),
  `addr` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `frequents` (
  `drinker` VARCHAR(64),
  `bar` VARCHAR(64),
  PRIMARY KEY (`drinker`, `bar`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `drinker` VARCHAR(64),
  `beer` VARCHAR(64),
  PRIMARY KEY (`drinker`, `beer`)
) CHARACTER SET latin1;

CREATE TABLE `sells` (
  `bar` VARCHAR(64),
  `beer` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`bar`, `beer`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_675698_BarBeerDrinkerSample') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_675698_BarBeerDrinkerSample') AS relationships;
DROP DATABASE `db_675698_BarBeerDrinkerSample`;
UNINSTALL EXTENSION vsql_schematron;
