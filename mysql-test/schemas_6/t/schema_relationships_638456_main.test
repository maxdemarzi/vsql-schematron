INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638456_main
--echo #
CREATE DATABASE `db_638456_main`;
USE `db_638456_main`;
CREATE TABLE `albums` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `pap` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artists` (
  `id` VARCHAR(50) NOT NULL,
  `band` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `duration` TIME,
  `album_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs_artists` (
  `id` VARCHAR(50) NOT NULL,
  `song_id` VARCHAR(50),
  `artist_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `pfp` VARCHAR(50),
  `admin` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlists` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `plp` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlists_songs` (
  `id` VARCHAR(50) NOT NULL,
  `song_id` VARCHAR(50),
  `playlist_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638456_main') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638456_main') AS relationships;
DROP DATABASE `db_638456_main`;
UNINSTALL EXTENSION vsql_schematron;
