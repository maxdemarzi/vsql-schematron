) CHARACTER SET latin1;

CREATE TABLE `CAMA_Legals` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Legal_Desc` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_Owners` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Owner_Mail_Name` VARCHAR(64),
  `Owner_Mail_Addr1` VARCHAR(64),
  `Owner_Mail_Addr2` VARCHAR(64),
  `Owner_Mail_Addr3` VARCHAR(64),
  `Owner_Mail_City` VARCHAR(64),
  `Owner_Mail_State` VARCHAR(64),
  `Owner_Mail_Zip` VARCHAR(64),
  `Owner_Mail_Country` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_Permits` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Permit_Num` VARCHAR(64),
  `Permit_Type` VARCHAR(64),
  `Permit_Desc` VARCHAR(64),
  `Permit_Issue_Date` DATETIME,
  `Permit_Completion_Date` DATETIME,
  `Permit_Inspection_Date` DATETIME,
  `Permit_Amount` DECIMAL(10,2),
  `Permit_Comment` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_Property` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Section` VARCHAR(64),
  `Township` VARCHAR(64),
  `Range` VARCHAR(64),
  `City_Code` VARCHAR(64),
  `City_Desc` VARCHAR(64),
  `Prop_Use_Code` VARCHAR(64),
  `Prop_Use_Desc` VARCHAR(64),
  `NBHD_Code` VARCHAR(64),
  `NBHD_Desc` VARCHAR(64),
  `SBDV_Code` VARCHAR(64),
  `SBDV_Desc` VARCHAR(64),
  `Cycle` DECIMAL(10,2),
  `Hmstd` VARCHAR(64),
  `TotSqFt` VARCHAR(64),
  `HtdSqFt` DECIMAL(10,2),
  `Acres` DECIMAL(10,2),
  PRIMARY KEY (`prop_id`)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_Sales` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Sale_Line_Num` INT,
  `Sale_Date` DATETIME,
  `Sale_Price` DECIMAL(10,2),
  `Sale_Vac_Imp` VARCHAR(64),
  `Sale_Qualified` VARCHAR(64),
  `Sale_Book` VARCHAR(64),
  `Sale_Page` VARCHAR(64),
  `Sale_Deed_Type` VARCHAR(64),
  `DOR_Qual_Code` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CourtCase` (
  `id` INT,
  `caseNumber` VARCHAR(64),
  `status` VARCHAR(64),
  `url` VARCHAR(64),
  `summary` VARCHAR(64),
  `action` VARCHAR(64),
  `fileDate` DATETIME,
  `incomplete` BOOL,
  `firstRetrieved` DATETIME,
  `lastUpdate` DATETIME,
  `lastVerified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CourtCaseCost` (
  `courtCaseId` INT,
  `owed` INT,
  `paid` INT,
  `dismissed` INT,
  `due` INT,
  `firstRetrieved` DATETIME,
  `lastUpdate` DATETIME,
  `lastVerified` DATETIME,
  PRIMARY KEY (`courtCaseId`)
) CHARACTER SET latin1;

CREATE TABLE `CourtCaseDocket` (
  `id` INT,
  `courtCaseId` INT,
  `date` DATETIME,
  `text` VARCHAR(64),
  `amount` INT,
  `due` INT,
  `link` VARCHAR(64),
  `firstRetrieved` DATETIME,
  `lastUpdate` DATETIME,
  `lastVerified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CourtCaseParty` (
  `id` INT,
  `courtCaseId` INT,
  `name` VARCHAR(64),
  `affl` VARCHAR(64),
  `type` VARCHAR(64),
  `link` VARCHAR(64),
  `residenceAddress` VARCHAR(64),
  `residenceCityStateZip` VARCHAR(64),
  `mailAddress` VARCHAR(64),
  `mailCityStateZip` VARCHAR(64),
  `firstRetrieved` DATETIME,
  `lastUpdate` DATETIME,
  `lastVerified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ElectricConsumption` (
  `id` INT,
  `serviceAddressId` INT,
  `date` DATETIME,
  `month` VARCHAR(64),
  `year` DECIMAL(10,2),
  `kwhConsumption` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `GRU_Import` (
  `Service Address` VARCHAR(64),
  `Service City` VARCHAR(64),
  `Month` VARCHAR(64),
  `Year` INT,
  `Date` DATETIME,
  `KWH Consumption` DECIMAL(10,2),
  `Latitude` DECIMAL(10,2),
  `Longitude` DECIMAL(10,2),
  `Location` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ServiceAddress` (
  `id` INT,
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_670359_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_670359_Schema') AS relationships;
DROP DATABASE `db_670359_Schema`;
UNINSTALL EXTENSION vsql_schematron;
