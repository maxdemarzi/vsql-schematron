INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 670359_Schema
--echo #
CREATE DATABASE `db_670359_Schema`;
USE `db_670359_Schema`;

CREATE TABLE `AddressPoints` (
  `X` DECIMAL(10,2),
  `Y` DECIMAL(10,2),
  `OBJECTID` INT,
  `FULLADDR` VARCHAR(64),
  `ADD_NUMBER` VARCHAR(64),
  `LST_PREDIR` VARCHAR(64),
  `LST_NAME` VARCHAR(64),
  `LST_TYPE` VARCHAR(64),
  `UNIT` VARCHAR(64),
  `STATUS` VARCHAR(64),
  `ADDRTYPE` VARCHAR(64),
  `PARCEL` VARCHAR(64),
  `INC_MUNI` VARCHAR(64),
  `MSAGCOMM` VARCHAR(64),
  `POST_CODE` VARCHAR(64),
  `ESN` VARCHAR(64),
  `NBRHD_COMM` VARCHAR(64),
  `LANDMKNAME` VARCHAR(64),
  `ADDTL_LOC` VARCHAR(64),
  `TRACK_NUM` VARCHAR(64),
  `COUNTRY` VARCHAR(64),
  `STATE` VARCHAR(64),
  `COUNTY` VARCHAR(64),
  `ST_PREDIR` VARCHAR(64),
  `ST_PRETYP` VARCHAR(64),
  `ST_NAME` VARCHAR(64),
  `ST_POSTYP` VARCHAR(64),
  `DATEUPDATE` DATETIME,
  `created_date` DATETIME,
  `last_edited_date` DATETIME,
  `DISCRPAGID` VARCHAR(64),
  `SITE_NGUID` VARCHAR(64),
  `GlobalID` VARCHAR(64),
  PRIMARY KEY (`OBJECTID`)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_CommonCodes` (
  `Code_Type` VARCHAR(64),
  `Code` VARCHAR(64),
  `Code_Description` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_ExemptionsRE_History` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Hist_Tax_Year` DECIMAL(10,2),
  `Hist_Ex_Code` VARCHAR(64),
  `Hist_Ex_Desc` VARCHAR(64),
  `Hist_Ex_Amount` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_HistoryRE` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Hist_Tax_Year` DECIMAL(10,2),
  `City_Code` VARCHAR(64),
  `City_Name` VARCHAR(64),
  `Prop_Use_Code` VARCHAR(64),
  `Prop_Use_Desc` VARCHAR(64),
  `Value_By` VARCHAR(64),
  `Just_Value` DECIMAL(10,2),
  `Deferred_Value` DECIMAL(10,2),
  `County_Assessed_Value` DECIMAL(10,2),
  `County_Exempt_Amount` DECIMAL(10,2),
  `County_Taxable_Value` DECIMAL(10,2),
  `School_Assessed_Value` DECIMAL(10,2),
  `School_Exempt_Amount` DECIMAL(10,2),
  `School_Taxable_Value` DECIMAL(10,2),
  `Land_Value` DECIMAL(10,2),
  `Classified_Land_Value` DECIMAL(10,2),
  `Improvement_Value` DECIMAL(10,2),
  `Heated_SquareFeet` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_Improvements` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `TaxYear` DECIMAL(10,2),
  `Imprv_ID` INT,
  `Imprv_Type` VARCHAR(64),
  `Imprv_Desc` VARCHAR(64),
  `Effective_YrBlt` DECIMAL(10,2),
  `Actual_YrBlt` DECIMAL(10,2),
  `Bldg_Num` VARCHAR(64),
  `Heated_SquareFeet` DECIMAL(10,2),
  `Stories` DECIMAL(10,2),
  PRIMARY KEY (`Imprv_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_ImprvAttributes` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `Imprv_ID` INT,
  `Imprv_Attribute` VARCHAR(64),
  `Imprv_Attr_Desc` VARCHAR(64),
  `Imprv_Attr_Units` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `CAMA_ImprvDetails` (
  `Parcel` VARCHAR(64),
  `prop_id` INT,
  `TaxYear` DECIMAL(10,2),
  `Imprv_ID` INT,
  `Imprv_Detail_ID` INT,
  `Imprv_Detail_Type` VARCHAR(64),
  `Imprv_Desc` VARCHAR(64),
  `Imprv_SqFt` DECIMAL(10,2),
  `Quality_Code` VARCHAR(64),
  `Quality_Desc` VARCHAR(64),
  `Bldg_Use_Code` VARCHAR(64),
  `Bldg_Use_Desc` VARCHAR(64),
