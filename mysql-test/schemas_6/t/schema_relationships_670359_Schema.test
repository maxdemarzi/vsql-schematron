  `Land_Line_Num` INT,
  `Land_Use_Code` VARCHAR(64),
  `Land_Use_Desc` VARCHAR(64),
  `Land_Zoning_Code` VARCHAR(64),
  `Land_Zoning_Desc` VARCHAR(64),
  `Land_Acres` DECIMAL(10,2),
  `Land_SqFt` DECIMAL(10,2),
  `Land_Lots` DECIMAL(10,2),
