INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 684832_V1__Base_version
--echo #
CREATE DATABASE `db_684832_V1__Base_version`;
USE `db_684832_V1__Base_version`;
CREATE TABLE `Backers` (
  `id` BIGINT NOT NULL,
  `playerId` BIGINT,
  `supportPlayerId` BIGINT,
  `tournamentId` BIGINT,
  `share` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Players` (
  `id` BIGINT NOT NULL,
  `playerName` TEXT,
  `points` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Status` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TournamentPlayers` (
  `id` BIGINT NOT NULL,
  `playerId` BIGINT,
  `tournamentId` BIGINT,
  `share` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tournaments` (
  `id` BIGINT NOT NULL,
  `tournamentNumber` BIGINT,
  `deposit` DECIMAL(10,2),
  `statusId` BIGINT,
  `winnerId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_684832_V1__Base_version') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_684832_V1__Base_version') AS relationships;
DROP DATABASE `db_684832_V1__Base_version`;
UNINSTALL EXTENSION vsql_schematron;
