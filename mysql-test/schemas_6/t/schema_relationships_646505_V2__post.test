INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646505_V2__post
--echo #
CREATE DATABASE `db_646505_V2__post`;
USE `db_646505_V2__post`;
CREATE TABLE `post` (
  `id` VARCHAR(50) NOT NULL,
  `author_id` VARCHAR(50),
  `message` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
  `post_id` VARCHAR(50),
  `tag` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646505_V2__post') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646505_V2__post') AS relationships;
DROP DATABASE `db_646505_V2__post`;
UNINSTALL EXTENSION vsql_schematron;
