INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605043_infaq_ci4
--echo #
CREATE DATABASE `db_605043_infaq_ci4`;
USE `db_605043_infaq_ci4`;
CREATE TABLE `infaqq` (
  `id_infaq` INT,
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  `no_telp` INT,
  `jumlah` VARCHAR(50),
  `id_pembayaran` INT
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `class` VARCHAR(50),
  `group` VARCHAR(50),
  `namespace` VARCHAR(50),
  `time` INT,
  `batch` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pembayaran` (
  `id_pembayaran` INT NOT NULL,
  `metode` VARCHAR(50),
  `norek` VARCHAR(50),
  `logo` VARCHAR(50),
  PRIMARY KEY (`id_pembayaran`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605043_infaq_ci4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605043_infaq_ci4') AS relationships;
DROP DATABASE `db_605043_infaq_ci4`;
UNINSTALL EXTENSION vsql_schematron;
