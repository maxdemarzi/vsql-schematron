INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606255_create_tables
--echo #
CREATE DATABASE `db_606255_create_tables`;
USE `db_606255_create_tables`;

CREATE TABLE `users` (
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `roll_no` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `d_id` VARCHAR(64),
  `d_name` VARCHAR(64),
  PRIMARY KEY (`d_id`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `p_id` INT,
  `url` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `thumb` VARCHAR(64),
  `counter` INT,
  PRIMARY KEY (`p_id`)
) CHARACTER SET latin1;

CREATE TABLE `bookmark` (
  `read_status` BOOL,
  `time_added` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606255_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606255_create_tables') AS relationships;
DROP DATABASE `db_606255_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
