INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 621397_0001
--echo #
CREATE DATABASE `db_621397_0001`;
USE `db_621397_0001`;

CREATE TABLE `project` (
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `modified_at` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `cover_image_id` VARCHAR(255),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `id` VARCHAR(255),
  `modified_at` DATETIME,
  `project_id` VARCHAR(255),
  `title` VARCHAR(255),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article_block` (
  `article_id` VARCHAR(255),
  `created_at` DATETIME,
  `data` VARCHAR(255),
  `deleted_at` DATETIME,
  `id` VARCHAR(255),
  `modified_at` DATETIME,
  `sort_rank` VARCHAR(255),
  `type` VARCHAR(255),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `modified_at` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article_tag` (
  `article_id` VARCHAR(255),
  `created_at` DATETIME,
  `id` VARCHAR(255),
  `modified_at` DATETIME,
  `sort_rank` VARCHAR(255),
  `tag_id` VARCHAR(255),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `type` VARCHAR(255),
  `height` INT,
  `id` VARCHAR(255),
  `modified_at` DATETIME,
  `version` INT,
  `width` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_621397_0001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_621397_0001') AS relationships;
DROP DATABASE `db_621397_0001`;
UNINSTALL EXTENSION vsql_schematron;
