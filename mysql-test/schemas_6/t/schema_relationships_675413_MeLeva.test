INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 675413_MeLeva
--echo #
CREATE DATABASE `db_675413_MeLeva`;
USE `db_675413_MeLeva`;
CREATE TABLE `Condutor` (
  `CPF_condutor` VARCHAR(50) NOT NULL,
  `Nome` VARCHAR(50),
  `Telefone` VARCHAR(50),
  `Data_cadastro` TIMESTAMP NULL,
  PRIMARY KEY (`CPF_condutor`)
) CHARACTER SET latin1;
CREATE TABLE `ModeloVeiculo` (
  `id_modelo_Veiculo` INT NOT NULL,
  `modelo` VARCHAR(50),
  `marca` VARCHAR(50),
  `ano` VARCHAR(50),
  PRIMARY KEY (`id_modelo_Veiculo`)
) CHARACTER SET latin1;
CREATE TABLE `Veiculo` (
  `renavan` VARCHAR(50) NOT NULL,
  `placa` VARCHAR(50),
  `id_modelo_veiculo` INT,
  PRIMARY KEY (`renavan`)
) CHARACTER SET latin1;
CREATE TABLE `Motorista` (
  `id_motorista` INT NOT NULL,
  `CPF_condutor` VARCHAR(50),
  `renavan` VARCHAR(50),
  `data_inicio` TIMESTAMP NULL,
  `data_fim` TIMESTAMP NULL,
  PRIMARY KEY (`id_motorista`)
) CHARACTER SET latin1;
CREATE TABLE `Passageiro` (
  `CPF_passageiro` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  `telefone` VARCHAR(50),
  `data_cadastro` TIMESTAMP NULL,
  PRIMARY KEY (`CPF_passageiro`)
) CHARACTER SET latin1;
CREATE TABLE `Corrida` (
  `id_corrida` INT NOT NULL,
  `id_motorista` INT NOT NULL,
  `CPF_passageiro` VARCHAR(50) NOT NULL,
  `avaliacao_condutor` INT,
  `avaliacao_veiculo` INT,
  `data_inicio` TIMESTAMP NULL,
  `data_fim` TIMESTAMP NULL,
  `origem` VARCHAR(50),
  `destino` VARCHAR(50),
  `tarifa` DOUBLE,
  `distancia` DOUBLE,
  PRIMARY KEY (`id_motorista`, `CPF_passageiro`, `id_corrida`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_675413_MeLeva') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_675413_MeLeva') AS relationships;
DROP DATABASE `db_675413_MeLeva`;
UNINSTALL EXTENSION vsql_schematron;
