INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 680911_jamberoo
--echo #
CREATE DATABASE `db_680911_jamberoo`;
USE `db_680911_jamberoo`;

CREATE TABLE `StructureTypes` (
  `type` VARCHAR(64),
  PRIMARY KEY (`type`)
) CHARACTER SET latin1;

CREATE TABLE `GeneralPropertiesTypes` (
  `propertyName` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`propertyName`)
) CHARACTER SET latin1;

CREATE TABLE `PropertyTypes` (
  `propertyName` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`propertyName`)
) CHARACTER SET latin1;

CREATE TABLE `Methods` (
  `methodName` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`methodName`)
) CHARACTER SET latin1;

CREATE TABLE `Aliases` (
  `id` INT,
  `aliasName` VARCHAR(64),
  `description` VARCHAR(64),
  `idCompound` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ElementContents` (
  `int` INT,
  `idCompound` INT,
  `element` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Conformers` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `idCompoundFK` INT,
  `typeFK` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `GeneralProperties` (
  `propertyNameFK` VARCHAR(64),
  `idCompound` INT
) CHARACTER SET latin1;

CREATE TABLE `Properties` (
  `id` INT,
  `property` VARCHAR(64),
  `propertyNameFK` VARCHAR(64),
  `methodNameFK` VARCHAR(64),
  `idMethodFK` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_680911_jamberoo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_680911_jamberoo') AS relationships;
DROP DATABASE `db_680911_jamberoo`;
UNINSTALL EXTENSION vsql_schematron;
