INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 602274_cursor
--echo #
CREATE DATABASE `db_602274_cursor`;
USE `db_602274_cursor`;
CREATE TABLE `class_room` (
  `id` VARCHAR(50) NOT NULL,
  `capacity` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `prodi` (
  `kode` VARCHAR(50) NOT NULL,
  `prodi_name` VARCHAR(50),
  PRIMARY KEY (`kode`)
) CHARACTER SET latin1;
CREATE TABLE `mahasiswa` (
  `kode_mhs` VARCHAR(50) NOT NULL,
  `namamhs` VARCHAR(50),
  `email` VARCHAR(50),
  `alamat` VARCHAR(50),
  `prodi_kode` VARCHAR(50),
  PRIMARY KEY (`kode_mhs`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_602274_cursor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_602274_cursor') AS relationships;
DROP DATABASE `db_602274_cursor`;
UNINSTALL EXTENSION vsql_schematron;
