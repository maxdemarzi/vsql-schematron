INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609411_schema-mysql
--echo #
CREATE DATABASE `db_609411_schema_mysql`;
USE `db_609411_schema_mysql`;
CREATE TABLE `author` (
  `id` BIGINT NOT NULL,
  `age` INT,
  `genre` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` BIGINT NOT NULL,
  `isbn` VARCHAR(50),
  `title` VARCHAR(50),
  `author_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609411_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609411_schema_mysql') AS relationships;
DROP DATABASE `db_609411_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
