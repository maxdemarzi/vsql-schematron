INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 607998_books-tr
--echo #
CREATE DATABASE `db_607998_books_tr`;
USE `db_607998_books_tr`;

CREATE TABLE `book_dt` (
  `bid` INT,
  `btitle` VARCHAR(64),
  `copies` INT,
  PRIMARY KEY (`bid`)
) CHARACTER SET latin1;

CREATE TABLE `book_issue` (
  `bid` INT,
  `sid` INT,
  `btitle` VARCHAR(64),
  PRIMARY KEY (`bid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_607998_books_tr') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_607998_books_tr') AS relationships;
DROP DATABASE `db_607998_books_tr`;
UNINSTALL EXTENSION vsql_schematron;
