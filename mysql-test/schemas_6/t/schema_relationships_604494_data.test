INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 604494_data
--echo #
CREATE DATABASE `db_604494_data`;
USE `db_604494_data`;

CREATE TABLE `users` (
  `username` VARCHAR(255),
  `firstname` VARCHAR(255),
  `lastname` VARCHAR(255),
  `email` VARCHAR(255),
  `email_confirmed` INT,
  `password` VARCHAR(255),
  `uploads_id` INT,
  `location` VARCHAR(255),
  `study` VARCHAR(255),
  `bio` VARCHAR(255),
  `relationship_status` VARCHAR(255),
  `phone_number` VARCHAR(255),
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `uploads` (
  `id` INT,
  `filename` VARCHAR(255),
  `location` VARCHAR(255),
  `filesize` INT,
  `type` VARCHAR(255),
  `sha256` VARCHAR(255),
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `body` VARCHAR(255),
  `title` VARCHAR(255),
  `username` VARCHAR(255),
  `uploads_id` INT,
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `post_id` INT,
  `username` VARCHAR(255),
  `comment` VARCHAR(255),
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `friends` (
  `id` INT,
  `username` VARCHAR(255),
  `friend` VARCHAR(255),
  `accepted` INT,
  `sender` INT,
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hobbies` (
  `id` INT,
  `username` VARCHAR(255),
  `title` VARCHAR(255),
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `skills` (
  `id` INT,
  `username` VARCHAR(255),
  `title` VARCHAR(255),
  `skill_level` INT,
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `languages` (
  `id` INT,
  `username` VARCHAR(255),
  `title` VARCHAR(255),
  `skill_level` INT,
  `creation_date` DATETIME,
  `last_edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_604494_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_604494_data') AS relationships;
DROP DATABASE `db_604494_data`;
UNINSTALL EXTENSION vsql_schematron;
