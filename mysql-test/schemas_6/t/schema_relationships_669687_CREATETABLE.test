INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 669687_CREATETABLE
--echo #
CREATE DATABASE `db_669687_CREATETABLE`;
USE `db_669687_CREATETABLE`;
CREATE TABLE `Position` (
  `positionID` INT NOT NULL,
  `positionName` VARCHAR(50),
  PRIMARY KEY (`positionID`)
) CHARACTER SET latin1;
CREATE TABLE `Person` (
  `personID` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `positionID` INT,
  `gender` VARCHAR(50),
  `address` VARCHAR(50),
  `dateOfBirth` DATE,
  `workPhone` BIGINT,
  `mobilePhone` BIGINT,
  `startDate` DATE,
  `endDate` DATE,
  `radioNumber` VARCHAR(50),
  `stationNumber` BIGINT,
  `email` VARCHAR(50),
  `isActive` BOOLEAN,
  PRIMARY KEY (`personID`)
) CHARACTER SET latin1;
CREATE TABLE `Certification` (
  `certificationID` INT NOT NULL,
  `certificationAgency` VARCHAR(50),
  `certificationName` VARCHAR(50),
  `defaultExpiration` INT,
  PRIMARY KEY (`certificationID`)
) CHARACTER SET latin1;
CREATE TABLE `Test` (
  `testID` INT NOT NULL,
  `personID` INT,
  `certificationID` INT,
  `testDate` DATE,
  PRIMARY KEY (`testID`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `email` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_669687_CREATETABLE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_669687_CREATETABLE') AS relationships;
DROP DATABASE `db_669687_CREATETABLE`;
UNINSTALL EXTENSION vsql_schematron;
