INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 681646_leadsafe
--echo #
CREATE DATABASE `db_681646_leadsafe`;
USE `db_681646_leadsafe`;
CREATE TABLE `admin` (
  `id` BIGINT NOT NULL,
  `fullName` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  `userType` TINYINT,
  `profileImage` VARCHAR(50),
  `contactNumber` VARCHAR(50),
  `status` TINYINT,
  `authToken` TEXT,
  `passToken` TEXT,
  `crd` TIMESTAMP NULL,
  `upd` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `taskId` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `status` TINYINT,
  `crd` TIMESTAMP NULL,
  `upd` TIMESTAMP NULL,
  PRIMARY KEY (`taskId`)
) CHARACTER SET latin1;
CREATE TABLE `task_meta` (
  `taskmetaId` BIGINT,
  `taskId` BIGINT,
  `fileType` VARCHAR(50),
  `file` TEXT,
  `description` TEXT,
  `sorting_order` BIGINT,
  `crd` TIMESTAMP NULL,
  `upd` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `fullName` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  `profileImage` TEXT,
  `contactNumber` VARCHAR(50),
  `userType` TINYINT,
  `status` TINYINT,
  `authToken` TEXT,
  `passToken` TEXT,
  `deviceType` TINYINT,
  `deviceToken` TEXT,
  `verifyEmail` TINYINT,
  `crd` TIMESTAMP NULL,
  `upd` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_681646_leadsafe') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_681646_leadsafe') AS relationships;
DROP DATABASE `db_681646_leadsafe`;
UNINSTALL EXTENSION vsql_schematron;
