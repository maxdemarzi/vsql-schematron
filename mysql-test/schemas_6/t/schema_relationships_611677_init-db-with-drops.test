INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611677_init-db-with-drops
--echo #
CREATE DATABASE `db_611677_init_db_with_drops`;
USE `db_611677_init_db_with_drops`;
CREATE TABLE `abiyan.Tag` (
  `name` VARCHAR(50) NOT NULL,
  `latitude` VARCHAR(50),
  `longitude` VARCHAR(50),
  `creationDate` VARCHAR(50),
  `lastUpdate` VARCHAR(50),
  `phone` VARCHAR(50),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `abiyan.Vote` (
  `plus` INT,
  `minus` INT,
  `tag` VARCHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `abiyan.Item` (
  `category` VARCHAR(50),
  `type` VARCHAR(50),
  `price` VARCHAR(50),
  `creationDate` VARCHAR(50),
  `lastUpdate` VARCHAR(50),
  `numberInStock` VARCHAR(50),
  `tag` VARCHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611677_init_db_with_drops') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611677_init_db_with_drops') AS relationships;
DROP DATABASE `db_611677_init_db_with_drops`;
UNINSTALL EXTENSION vsql_schematron;
