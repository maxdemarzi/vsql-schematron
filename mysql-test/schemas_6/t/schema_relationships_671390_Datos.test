INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 671390_Datos
--echo #
CREATE DATABASE `db_671390_Datos`;
USE `db_671390_Datos`;

CREATE TABLE `CARRERAS` (
  `CODIGO` DECIMAL(10,2),
  `NOMBRE` VARCHAR(64),
  `TITULO` VARCHAR(64),
  PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;

CREATE TABLE `CURSOS` (
  `CODIGO` DECIMAL(10,2),
  `NOMBRE` VARCHAR(64),
  `CREDITOS` DECIMAL(10,2),
  `HORAS` DECIMAL(10,2),
  PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;

CREATE TABLE `CARRERACURSOS` (
  `CODCARRERA` DECIMAL(10,2),
  `CODCURSOS` DECIMAL(10,2),
  `ANO` VARCHAR(64),
  `CICLO` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_671390_Datos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_671390_Datos') AS relationships;
DROP DATABASE `db_671390_Datos`;
UNINSTALL EXTENSION vsql_schematron;
