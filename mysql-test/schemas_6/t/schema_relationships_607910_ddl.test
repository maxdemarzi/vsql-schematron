INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 607910_ddl
--echo #
CREATE DATABASE `db_607910_ddl`;
USE `db_607910_ddl`;

CREATE TABLE `task_item` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `task_status` (
  `id` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `task_history` (
  `id` INT,
  `task_id` INT,
  `task_status_id` INT,
  `status_dttm` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_607910_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_607910_ddl') AS relationships;
DROP DATABASE `db_607910_ddl`;
UNINSTALL EXTENSION vsql_schematron;
