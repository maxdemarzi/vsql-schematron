INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 657124_go_schema
--echo #
CREATE DATABASE `db_657124_go_schema`;
USE `db_657124_go_schema`;

CREATE TABLE `TERM` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `TERM_TYPE` VARCHAR(64),
  `ACC` VARCHAR(64),
  `IS_OBSOLETE` DECIMAL(10,2),
  `IS_ROOT` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TERM2TERM` (
  `ID` DECIMAL(10,2),
  `RELATIONSHIP_TYPE_ID` DECIMAL(10,2),
  `TERM1_ID` DECIMAL(10,2),
  `TERM2_ID` DECIMAL(10,2),
  `COMPLETE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `GRAPH_PATH` (
  `ID` DECIMAL(10,2),
  `TERM1_ID` DECIMAL(10,2),
  `TERM2_ID` DECIMAL(10,2),
  `DISTANCE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_657124_go_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_657124_go_schema') AS relationships;
DROP DATABASE `db_657124_go_schema`;
UNINSTALL EXTENSION vsql_schematron;
