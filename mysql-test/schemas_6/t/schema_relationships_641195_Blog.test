INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641195_Blog
--echo #
CREATE DATABASE `db_641195_Blog`;
USE `db_641195_Blog`;
CREATE TABLE `Author` (
  `AuthorId` BIGINT NOT NULL,
  `AuthorName` VARCHAR(50),
  PRIMARY KEY (`AuthorId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `PostId` BIGINT NOT NULL,
  `AuthorId` BIGINT,
  `TopicId` BIGINT,
  PRIMARY KEY (`PostId`)
) CHARACTER SET latin1;
CREATE TABLE `Topic` (
  `TopicId` BIGINT NOT NULL,
  `TopicName` VARCHAR(50),
  `ParentTopicId` BIGINT,
  PRIMARY KEY (`TopicId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641195_Blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641195_Blog') AS relationships;
DROP DATABASE `db_641195_Blog`;
UNINSTALL EXTENSION vsql_schematron;
