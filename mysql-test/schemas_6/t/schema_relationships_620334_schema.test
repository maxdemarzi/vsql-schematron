INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620334_schema
--echo #
CREATE DATABASE `db_620334_schema`;
USE `db_620334_schema`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `name` TEXT,
  `aws_id` TEXT,
  `key_id` TEXT,
  `access_key` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `network` (
  `id` INT NOT NULL,
  `region` TEXT,
  `private_key` TEXT,
  `cidr_block` TEXT,
  `vpn_gateway_ip` TEXT,
  `vpn_routes` VARCHAR(50),
  `name_servers` VARCHAR(50),
  `intern_domain` TEXT,
  `ami_nat_image` TEXT,
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subnet` (
  `type` TEXT,
  `availability_zone` TEXT,
  `cidr_block` TEXT,
  `network_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620334_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620334_schema') AS relationships;
DROP DATABASE `db_620334_schema`;
UNINSTALL EXTENSION vsql_schematron;
