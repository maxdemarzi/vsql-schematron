INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 630682_dicebot
--echo #
CREATE DATABASE `db_630682_dicebot`;
USE `db_630682_dicebot`;
CREATE TABLE `guilds` (
  `guildID` VARCHAR(50) NOT NULL,
  `prefix` CHAR(50),
  `rig` TINYINT,
  PRIMARY KEY (`guildID`)
) CHARACTER SET latin1;
CREATE TABLE `aliases` (
  `guildID` VARCHAR(50) NOT NULL,
  `userID` VARCHAR(50),
  `aliasName` VARCHAR(50) NOT NULL,
  `dice` VARCHAR(50),
  PRIMARY KEY (`guildID`, `aliasName`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_630682_dicebot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_630682_dicebot') AS relationships;
DROP DATABASE `db_630682_dicebot`;
UNINSTALL EXTENSION vsql_schematron;
