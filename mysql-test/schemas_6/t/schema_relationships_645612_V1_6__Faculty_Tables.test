INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 645612_V1.6__Faculty_Tables
--echo #
CREATE DATABASE `db_645612_V1_6__Faculty_Tables`;
USE `db_645612_V1_6__Faculty_Tables`;
CREATE TABLE `faculty` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `alias` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `speciality` (
  `id` INT NOT NULL,
  `faculty_id` INT,
  `name` VARCHAR(50),
  `iis_id` INT,
  `alias` VARCHAR(50),
  `education_form` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_645612_V1_6__Faculty_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_645612_V1_6__Faculty_Tables') AS relationships;
DROP DATABASE `db_645612_V1_6__Faculty_Tables`;
UNINSTALL EXTENSION vsql_schematron;
