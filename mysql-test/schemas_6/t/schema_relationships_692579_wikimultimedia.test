INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 692579_wikimultimedia
--echo #
CREATE DATABASE `db_692579_wikimultimedia`;
USE `db_692579_wikimultimedia`;

CREATE TABLE `articulos` (
  `id_articulo` INT,
  `autor_articulo` VARCHAR(64),
  `fecha_articulo` DATETIME,
  `titulo_articulo` VARCHAR(64),
  `resumen_articulo` VARCHAR(64),
  `subtitulo_articulo` VARCHAR(64),
  `contenido_articulo` VARCHAR(64),
  `multimedia_articulo` VARCHAR(64),
  `categoria_articulo` VARCHAR(64),
  `referencias_articulo` VARCHAR(64),
  `usuario_id` INT
) CHARACTER SET latin1;

CREATE TABLE `registros` (
  `id_usuario` INT,
  `correo_usuario` VARCHAR(64),
  `contrasenia_usuario` VARCHAR(64),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_692579_wikimultimedia') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_692579_wikimultimedia') AS relationships;
DROP DATABASE `db_692579_wikimultimedia`;
UNINSTALL EXTENSION vsql_schematron;
