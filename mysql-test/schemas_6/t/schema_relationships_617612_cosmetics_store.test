INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617612_cosmetics-store
--echo #
CREATE DATABASE `db_617612_cosmetics_store`;
USE `db_617612_cosmetics_store`;

CREATE TABLE `brand` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `cart` (
  `id` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `cart_product` (
  `id` INT,
  `cart_id` INT,
  `product_id` INT,
  `quantity` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `parent_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `product_id` INT,
  `user_id` INT,
  `parent_id` INT,
  `content` VARCHAR(64),
  `rating` INT,
  `published` INT,
  `published_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_access_tokens` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `name` VARCHAR(64),
  `scopes` VARCHAR(64),
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_auth_codes` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `scopes` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_clients` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `secret` VARCHAR(64),
  `provider` VARCHAR(64),
  `redirect` VARCHAR(64),
  `personal_access_client` INT,
  `password_client` INT,
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_personal_access_clients` (
  `id` INT,
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_refresh_tokens` (
  `id` VARCHAR(64),
  `access_token_id` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `user_id` INT,
  `status` INT,
  `shipping` DECIMAL(10,2),
  `promo` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `address` VARCHAR(64),
  `district` VARCHAR(64),
  `ward` VARCHAR(64),
  `city` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `order_product` (
  `id` INT,
  `product_id` INT,
  `order_id` INT,
  `price` DECIMAL(10,2),
  `quantity` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `category_id` INT,
  `brand_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `excerpt` VARCHAR(64),
  `content` VARCHAR(64),
  `price` DECIMAL(10,2),
  `discount` DECIMAL(10,2),
  `quantity` INT,
  `published` INT,
  `published_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `product_image` (
  `id` INT,
  `product_id` INT,
  `title` VARCHAR(64),
  `image_url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `product_tag` (
  `product_id` INT,
  `tag_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `slide` (
  `id` INT,
  `title` VARCHAR(64),
  `image_url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `facebook_id` VARCHAR(64),
  `google_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `auth_token` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `address` VARCHAR(64),
  `district` VARCHAR(64),
  `ward` VARCHAR(64),
  `city` VARCHAR(64),
  `gender` VARCHAR(64),
  `avatar` VARCHAR(64),
  `intro` VARCHAR(64),
  `profile` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617612_cosmetics_store') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617612_cosmetics_store') AS relationships;
DROP DATABASE `db_617612_cosmetics_store`;
UNINSTALL EXTENSION vsql_schematron;
