INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 665807_fantasylcs.ddl
--echo #
CREATE DATABASE `db_665807_fantasylcs_ddl`;
USE `db_665807_fantasylcs_ddl`;

CREATE TABLE `discordInfo` (
  `discordName` VARCHAR(64),
  `summoner` VARCHAR(64),
  `serverID` INT,
  PRIMARY KEY (`discordName`, `serverID`)
) CHARACTER SET latin1;

CREATE TABLE `lastOnline` (
  `username` VARCHAR(64),
  `login` DATETIME,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `season` INT,
  `T1` VARCHAR(64),
  `T2` VARCHAR(64),
  `T3` VARCHAR(64),
  `T4` VARCHAR(64),
  `T5` VARCHAR(64),
  `T6` VARCHAR(64),
  `T7` VARCHAR(64),
  `T8` VARCHAR(64),
  `T9` VARCHAR(64),
  `T10` VARCHAR(64),
  PRIMARY KEY (`season`)
) CHARACTER SET latin1;

CREATE TABLE `lastCommand` (
  `username` VARCHAR(64),
  `command` VARCHAR(64),
  `day` DATETIME,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_665807_fantasylcs_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_665807_fantasylcs_ddl') AS relationships;
DROP DATABASE `db_665807_fantasylcs_ddl`;
UNINSTALL EXTENSION vsql_schematron;
