INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605406_V1__initial_schema
--echo #
CREATE DATABASE `db_605406_V1__initial_schema`;
USE `db_605406_V1__initial_schema`;
CREATE TABLE `user` (
  `id` BIGINT,
  `name` VARCHAR(50),
  `age` INT
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `id_user` BIGINT,
  `street` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `phones` (
  `id` BIGINT,
  `id_user` BIGINT,
  `_number` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605406_V1__initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605406_V1__initial_schema') AS relationships;
DROP DATABASE `db_605406_V1__initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
