INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663871_logging-advanced
--echo #
CREATE DATABASE `db_663871_logging_advanced`;
USE `db_663871_logging_advanced`;
CREATE TABLE `Log` (
  `Id` INT NOT NULL,
  `Time` INT,
  `Author` INT,
  `Message` TEXT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663871_logging_advanced') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663871_logging_advanced') AS relationships;
DROP DATABASE `db_663871_logging_advanced`;
UNINSTALL EXTENSION vsql_schematron;
