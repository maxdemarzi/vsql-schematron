INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 683789_vshop
--echo #
CREATE DATABASE `db_683789_vshop`;
USE `db_683789_vshop`;
CREATE TABLE `cliente` (
  `cliente_id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `apellido_paterno` VARCHAR(50),
  `apellido_materno` VARCHAR(50),
  `nombre` VARCHAR(50),
  `estado` CHAR(50),
  `trash` CHAR(50),
  PRIMARY KEY (`cliente_id`)
) CHARACTER SET latin1;
CREATE TABLE `detalle_venta` (
  `detalle_venta_id` VARCHAR(50) NOT NULL,
  `venta_id` VARCHAR(50),
  `producto_id` VARCHAR(50),
  `cantidad` INT,
  PRIMARY KEY (`detalle_venta_id`)
) CHARACTER SET latin1;
CREATE TABLE `venta` (
  `venta_id` VARCHAR(50) NOT NULL,
  `codigo` VARCHAR(50),
  `cliente_id` INT,
  `fecha_hora` TIMESTAMP NULL,
  `estado` CHAR(50),
  `trash` CHAR(50),
  PRIMARY KEY (`venta_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_683789_vshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_683789_vshop') AS relationships;
DROP DATABASE `db_683789_vshop`;
UNINSTALL EXTENSION vsql_schematron;
