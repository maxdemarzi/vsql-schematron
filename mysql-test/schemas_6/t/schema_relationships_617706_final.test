INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617706_final
--echo #
CREATE DATABASE `db_617706_final`;
USE `db_617706_final`;

CREATE TABLE `login` (
  `EmployeeID` INT,
  `email_id` VARCHAR(64),
  `user_password` VARCHAR(64),
  PRIMARY KEY (`EmployeeID`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `EmployeeID` INT,
  `Employee_FName` VARCHAR(64),
  `Employee_LName` VARCHAR(64),
  `dob` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `timesheet_TGT` (
  `TimeSheetID` INT,
  `EmployeeID` INT,
  `Day_1` INT,
  `Day_2` INT,
  `Day_3` INT,
  `Day_4` INT,
  `Day_5` INT,
  `Day_6` INT,
  `Day_7` INT,
  `WeekID` INT,
  `START_DATE` DATETIME,
  `END_DATE` DATETIME,
  `ACTIVE_FLAG` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617706_final') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617706_final') AS relationships;
DROP DATABASE `db_617706_final`;
UNINSTALL EXTENSION vsql_schematron;
