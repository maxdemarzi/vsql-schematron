INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624722_app
--echo #
CREATE DATABASE `db_624722_app`;
USE `db_624722_app`;
CREATE TABLE `state` (
  `id` BIGINT NOT NULL,
  `country_id` BIGINT,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
  `id` BIGINT NOT NULL,
  `state_id` BIGINT,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id` BIGINT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624722_app') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624722_app') AS relationships;
DROP DATABASE `db_624722_app`;
UNINSTALL EXTENSION vsql_schematron;
