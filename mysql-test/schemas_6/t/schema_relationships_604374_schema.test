INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 604374_schema
--echo #
CREATE DATABASE `db_604374_schema`;
USE `db_604374_schema`;

CREATE TABLE `languages` (
  `id` INT,
  `language` VARCHAR(64),
  `region` VARCHAR(64),
  `variant` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` BOOL,
  `language_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authorities` (
  `id` INT,
  `username` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_604374_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_604374_schema') AS relationships;
DROP DATABASE `db_604374_schema`;
UNINSTALL EXTENSION vsql_schematron;
