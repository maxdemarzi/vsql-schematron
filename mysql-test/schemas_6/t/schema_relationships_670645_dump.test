INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 670645_dump
--echo #
CREATE DATABASE `db_670645_dump`;
USE `db_670645_dump`;

CREATE TABLE `branch` (
  `department` VARCHAR(64),
  `course` VARCHAR(64),
  `year` INT,
  `strength` INT,
  PRIMARY KEY (`department`, `course`, `year`)
) CHARACTER SET latin1;

CREATE TABLE `hostel` (
  `name` VARCHAR(64),
  `capacity` INT,
  `head_warden` VARCHAR(64),
  `head_warden_email` VARCHAR(64),
  `head_warden_passwd` VARCHAR(64),
  `gender` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `resides_in` (
  `hostel_name` VARCHAR(64),
  `department` VARCHAR(64),
  `course` VARCHAR(64),
  `year` INT,
  `strength` INT,
  `range_start` INT,
  `range_end` INT,
  `seater` INT,
  PRIMARY KEY (`hostel_name`, `department`, `course`, `year`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_670645_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_670645_dump') AS relationships;
DROP DATABASE `db_670645_dump`;
UNINSTALL EXTENSION vsql_schematron;
