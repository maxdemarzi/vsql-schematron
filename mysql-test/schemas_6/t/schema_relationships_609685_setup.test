INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609685_setup
--echo #
CREATE DATABASE `db_609685_setup`;
USE `db_609685_setup`;

CREATE TABLE `users` (
  `name` VARCHAR(64),
  `passwordHash` VARCHAR(64),
  `secret` VARCHAR(64),
  `crypter` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passwords` (
  `id` INT,
  `title` VARCHAR(64),
  `name` VARCHAR(64),
  `mail` VARCHAR(64),
  `passwordValue` VARCHAR(64),
  `url` VARCHAR(64),
  `backupCode` VARCHAR(64),
  `notes` VARCHAR(64),
  `category` INT,
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609685_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609685_setup') AS relationships;
DROP DATABASE `db_609685_setup`;
UNINSTALL EXTENSION vsql_schematron;
