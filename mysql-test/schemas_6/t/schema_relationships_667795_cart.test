INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 667795_cart
--echo #
CREATE DATABASE `db_667795_cart`;
USE `db_667795_cart`;

CREATE TABLE `addresses` (
  `address_id` INT,
  `address_streetname` VARCHAR(64),
  `address_housenumber` VARCHAR(64),
  `address_country` VARCHAR(64),
  `address_postcode` VARCHAR(64),
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `category_id` INT,
  `category_name` VARCHAR(64),
  `category_description` VARCHAR(64),
  `category_image` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `customer_id` INT,
  `customer_firstname` VARCHAR(64),
  `customer_lastname` VARCHAR(64),
  `customer_email` VARCHAR(64),
  `customer_registered` VARCHAR(64),
  `customer_phone` VARCHAR(64),
  `address_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `logins` (
  `login_id` INT,
  `customer_id` INT,
  `login_username` VARCHAR(64),
  `login_password` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `customer_id` INT,
  `address_id` INT,
  `order_payment_type` VARCHAR(64),
  `order_date` DATETIME,
  `order_status` VARCHAR(64),
  `order_total` DECIMAL(10,2),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_items` (
  `order_items_id` INT,
  `order_id` INT,
  `product_id` INT,
  `order_item_quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `product_id` INT,
  `category_id` INT,
  `product_name` VARCHAR(64),
  `product_description` VARCHAR(64),
  `product_image` VARCHAR(64),
  `product_price` DECIMAL(10,2),
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_667795_cart') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_667795_cart') AS relationships;
DROP DATABASE `db_667795_cart`;
UNINSTALL EXTENSION vsql_schematron;
