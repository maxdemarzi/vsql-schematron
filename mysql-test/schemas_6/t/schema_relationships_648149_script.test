INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648149_script
--echo #
CREATE DATABASE `db_648149_script`;
USE `db_648149_script`;

CREATE TABLE `email` (
  `email` VARCHAR(64),
  `email_id` INT,
  `user_id` INT,
  `is_principal` VARCHAR(64),
  `is_valid` VARCHAR(64),
  `is_active` VARCHAR(64),
  PRIMARY KEY (`email_id`)
) CHARACTER SET latin1;

CREATE TABLE `phone` (
  `phone_id` INT,
  `user_id` INT,
  `phone` VARCHAR(64),
  `is_principal` VARCHAR(64),
  `is_valid` VARCHAR(64),
  `is_active` VARCHAR(64),
  PRIMARY KEY (`phone_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `creation_date` DATETIME,
  `name` VARCHAR(64),
  `user_id` INT,
  `surname` VARCHAR(64),
  `user_type` VARCHAR(64),
  `is_active` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute_kind` (
  `attribute_kind_id` INT,
  `sql_syntax` VARCHAR(64),
  `name` VARCHAR(64),
  `max_value` INT,
  `min_value` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`attribute_kind_id`)
) CHARACTER SET latin1;

CREATE TABLE `_database` (
  `url` VARCHAR(64),
  `name` VARCHAR(64),
  `user_id` INT,
  `_database_id` INT,
  PRIMARY KEY (`_database_id`)
) CHARACTER SET latin1;

CREATE TABLE `_table` (
  `_table_id` INT,
  `name` VARCHAR(64),
  `_database_id` INT,
  PRIMARY KEY (`_table_id`)
) CHARACTER SET latin1;

CREATE TABLE `query` (
  `query_type` VARCHAR(64),
  `creation_date` DATETIME,
  `name` VARCHAR(64),
  `query_id` INT,
  `_database_id` INT,
  PRIMARY KEY (`query_id`)
) CHARACTER SET latin1;

CREATE TABLE `attribute` (
  `attribute_kind_id` INT,
  `attribute_id` INT,
  `name` VARCHAR(64),
  `table_id` INT,
  PRIMARY KEY (`attribute_id`)
) CHARACTER SET latin1;

CREATE TABLE `level` (
  `level_id` INT,
  `name` VARCHAR(64),
  `number` INT,
  `is_principal` VARCHAR(64),
  `is_active` VARCHAR(64),
  PRIMARY KEY (`level_id`)
) CHARACTER SET latin1;

CREATE TABLE `session` (
  `session_id` INT,
  `user_id` INT,
  `token` VARCHAR(64),
  `date` DATETIME,
  `ip` VARCHAR(64),
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648149_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648149_script') AS relationships;
DROP DATABASE `db_648149_script`;
UNINSTALL EXTENSION vsql_schematron;
