CREATE DATABASE `db_602227_20200205205811_create_table_up`;
USE `db_602227_20200205205811_create_table_up`;

CREATE TABLE `users` (
  `id` INT,
  `roleId` INT,
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `password` VARCHAR(64),
  `token` VARCHAR(64),
  `tokenExpiredAt` DATETIME,
  `createdAt` DATETIME,
  `createdBy` VARCHAR(64),
  `updatedAt` DATETIME,
  `updatedBy` VARCHAR(64),
  `deletedAt` DATETIME,
  `deletedBy` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `createdAt` DATETIME,
  `createdBy` VARCHAR(64),
  `updatedAt` DATETIME,
  `updatedBy` VARCHAR(64),
  `deletedAt` DATETIME,
  `deletedBy` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `characters` (
  `id` INT,
  `characterTypeID` INT,
  `name` VARCHAR(64),
  `power` INT,
  `createdAt` DATETIME,
  `createdBy` VARCHAR(64),
  `updatedAt` DATETIME,
  `updatedBy` VARCHAR(64),
  `deletedAt` DATETIME,
  `deletedBy` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `charactersType` (
  `id` INT,
  `name` VARCHAR(64),
  `code` INT,
  `createdAt` DATETIME,
  `createdBy` VARCHAR(64),
  `updatedAt` DATETIME,
  `updatedBy` VARCHAR(64),
  `deletedAt` DATETIME,
  `deletedBy` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

