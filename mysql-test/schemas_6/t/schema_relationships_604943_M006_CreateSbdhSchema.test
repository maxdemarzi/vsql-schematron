INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 604943_M006_CreateSbdhSchema
--echo #
CREATE DATABASE `db_604943_M006_CreateSbdhSchema`;
USE `db_604943_M006_CreateSbdhSchema`;

CREATE TABLE `sbdh.standardheader` (
  `id` INT,
  `version` VARCHAR(64),
  `standard` VARCHAR(64),
  `type_version` VARCHAR(64),
  `identifier` VARCHAR(64),
  `type` VARCHAR(64),
  `creation_datetime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sbdh.contactinformation` (
  `id` INT,
  `header_id` INT,
  `type` INT,
  `identifier` VARCHAR(64),
  `contact` VARCHAR(64),
  `email` VARCHAR(64),
  `fax_number` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `type_identifier` VARCHAR(64),
  PRIMARY KEY (`header_id`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `sbdh.custom_field` (
  `header_id` INT,
  `field_id` INT,
  `parent_id` INT,
  `namespace` VARCHAR(64),
  `name` VARCHAR(64),
  `type` INT,
  `text_value` VARCHAR(64),
  `numeric_value` DECIMAL(10,2),
  `date_value` DATETIME,
  PRIMARY KEY (`header_id`, `field_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_604943_M006_CreateSbdhSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_604943_M006_CreateSbdhSchema') AS relationships;
DROP DATABASE `db_604943_M006_CreateSbdhSchema`;
UNINSTALL EXTENSION vsql_schematron;
