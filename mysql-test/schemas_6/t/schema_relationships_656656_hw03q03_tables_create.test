INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 656656_hw03q03-tables-create
--echo #
CREATE DATABASE `db_656656_hw03q03_tables_create`;
USE `db_656656_hw03q03_tables_create`;

CREATE TABLE `Employee` (
  `eid` DECIMAL(10,2),
  `ename` VARCHAR(64),
  `age` DECIMAL(10,2),
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`eid`)
) CHARACTER SET latin1;

CREATE TABLE `Department` (
  `did` DECIMAL(10,2),
  `dname` VARCHAR(64),
  `budget` DECIMAL(10,2),
  `managerid` DECIMAL(10,2),
  PRIMARY KEY (`did`)
) CHARACTER SET latin1;

CREATE TABLE `ACTORS` (
  `actor_id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `nationality` VARCHAR(64),
  PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;

CREATE TABLE `MOVIES` (
  `movie_id` DECIMAL(10,2),
  `title` VARCHAR(64),
  `year` DECIMAL(10,2),
  `studio` VARCHAR(64),
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `STARSIN` (
  `actor_id` DECIMAL(10,2),
  `movie_id` DECIMAL(10,2),
  `character` VARCHAR(64),
  PRIMARY KEY (`actor_id`, `movie_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_656656_hw03q03_tables_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_656656_hw03q03_tables_create') AS relationships;
DROP DATABASE `db_656656_hw03q03_tables_create`;
UNINSTALL EXTENSION vsql_schematron;
