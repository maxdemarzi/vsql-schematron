INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 651242_V201909011449__users
--echo #
CREATE DATABASE `db_651242_V201909011449__users`;
USE `db_651242_V201909011449__users`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `email` TEXT,
  `first_name` TEXT,
  `last_name` TEXT,
  `password_hash` TEXT,
  `created_date` TIMESTAMP NULL,
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `type` TEXT,
  `created_date` TIMESTAMP NULL,
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `memberships` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `account_id` BIGINT,
  `role` TEXT,
  `created_date` TIMESTAMP NULL,
  `updated_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `invalidated_tokens` (
  `id` BIGINT NOT NULL,
  `value` TEXT,
  `user_id` BIGINT,
  `created_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_651242_V201909011449__users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_651242_V201909011449__users') AS relationships;
DROP DATABASE `db_651242_V201909011449__users`;
UNINSTALL EXTENSION vsql_schematron;
