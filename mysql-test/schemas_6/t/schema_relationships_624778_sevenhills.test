INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624778_sevenhills
--echo #
CREATE DATABASE `db_624778_sevenhills`;
USE `db_624778_sevenhills`;

CREATE TABLE `comments` (
  `solutionid` INT,
  `commenttext` VARCHAR(64),
  `name` VARCHAR(64),
  `commentid` INT,
  PRIMARY KEY (`commentid`)
) CHARACTER SET latin1;

CREATE TABLE `material` (
  `materialid` INT,
  `MaterialName` VARCHAR(64),
  `Vendor` VARCHAR(64),
  PRIMARY KEY (`materialid`)
) CHARACTER SET latin1;

CREATE TABLE `requirement` (
  `solutionid` INT,
  `materialid` INT,
  `amount` INT,
  PRIMARY KEY (`solutionid`, `materialid`)
) CHARACTER SET latin1;

CREATE TABLE `solutions` (
  `solutionid` INT,
  `SolutionName` VARCHAR(64),
  `Description` VARCHAR(64),
  `Difficulty` INT,
  `Instruction` VARCHAR(64),
  `EstimatedTotalCost` INT,
  `Time` INT,
  PRIMARY KEY (`solutionid`)
) CHARACTER SET latin1;

CREATE TABLE `solutiontags` (
  `solutionid` INT,
  `TagName` VARCHAR(64),
  PRIMARY KEY (`solutionid`, `TagName`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `TagName` VARCHAR(64),
  PRIMARY KEY (`TagName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624778_sevenhills') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624778_sevenhills') AS relationships;
DROP DATABASE `db_624778_sevenhills`;
UNINSTALL EXTENSION vsql_schematron;
