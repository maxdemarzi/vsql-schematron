INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646724_migration
--echo #
CREATE DATABASE `db_646724_migration`;
USE `db_646724_migration`;

CREATE TABLE `ActionVerb` (
  `id` INT,
  `name` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Action` (
  `id` INT,
  `verbName` VARCHAR(64),
  `activityId` INT,
  `timestamp` DATETIME,
  `result` DECIMAL(10,2),
  `projectId` INT,
  `userId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ActionActivity` (
  `id` INT,
  `contentId` INT,
  `topicId` INT,
  `stepID` VARCHAR(64),
  `hintID` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `detail` VARCHAR(64),
  `extra` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Content` (
  `id` INT,
  `projectId` INT,
  `domainId` INT,
  `topicId` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646724_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646724_migration') AS relationships;
DROP DATABASE `db_646724_migration`;
UNINSTALL EXTENSION vsql_schematron;
