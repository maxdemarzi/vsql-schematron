INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609477_000001_init_schema.up
--echo #
CREATE DATABASE `db_609477_000001_init_schema_up`;
USE `db_609477_000001_init_schema_up`;
CREATE TABLE `battletag` (
  `id` INT NOT NULL,
  `userId` VARCHAR(50),
  `name` VARCHAR(50),
  `urlName` VARCHAR(50),
  `blizzId` INT,
  `level` INT,
  `playerLevel` INT,
  `platform` VARCHAR(50),
  `isPublic` BOOLEAN,
  `portrait` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `id` INT NOT NULL,
  `userId` VARCHAR(50),
  `battletagId` INT,
  `starting_sr_tank` INT,
  `sr_tank` INT,
  `starting_sr_damage` INT,
  `sr_damage` INT,
  `starting_sr_support` INT,
  `sr_support` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609477_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609477_000001_init_schema_up') AS relationships;
DROP DATABASE `db_609477_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
