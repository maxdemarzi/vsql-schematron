INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644396_schema-mysql
--echo #
CREATE DATABASE `db_644396_schema_mysql`;
USE `db_644396_schema_mysql`;
CREATE TABLE `vets` (
  `id` VARCHAR(50) NOT NULL,
  `vet_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `resume` VARCHAR(50),
  `workday` VARCHAR(50),
  `is_active` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialties` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vet_specialties` (
  `vet_id` VARCHAR(50),
  `specialty_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644396_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644396_schema_mysql') AS relationships;
DROP DATABASE `db_644396_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
