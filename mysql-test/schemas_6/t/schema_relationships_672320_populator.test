INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 672320_populator
--echo #
CREATE DATABASE `db_672320_populator`;
USE `db_672320_populator`;
CREATE TABLE `db.roles` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.moderators` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `role_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.subjects` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.tags` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_by` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `db.comments` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `email` VARCHAR(50),
  `content` VARCHAR(50),
  `post_id` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_672320_populator') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_672320_populator') AS relationships;
DROP DATABASE `db_672320_populator`;
UNINSTALL EXTENSION vsql_schematron;
