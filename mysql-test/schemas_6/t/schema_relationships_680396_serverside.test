INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 680396_serverside
--echo #
CREATE DATABASE `db_680396_serverside`;
USE `db_680396_serverside`;

CREATE TABLE `blogpost` (
  `id` INT,
  `category_id` INT,
  `title` VARCHAR(255),
  `content` VARCHAR(255),
  `timestamp` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `category_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `comment` VARCHAR(255),
  `name` VARCHAR(255),
  `captcha` VARCHAR(255),
  `date_create` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forumpost` (
  `id` INT,
  `category_id` INT,
  `comment_id` INT,
  `title` VARCHAR(255),
  `content` VARCHAR(255),
  `timestamp` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `name` VARCHAR(255),
  `image` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `quotes` (
  `id` INT,
  `author` VARCHAR(255),
  `content` VARCHAR(255),
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `admin` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_680396_serverside') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_680396_serverside') AS relationships;
DROP DATABASE `db_680396_serverside`;
UNINSTALL EXTENSION vsql_schematron;
