INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 668038_calcomp
--echo #
CREATE DATABASE `db_668038_calcomp`;
USE `db_668038_calcomp`;

CREATE TABLE `dqc84` (
  `id` INT,
  `model` INT,
  `fat_part_no` VARCHAR(64),
  `total_location` INT,
  `update_dt` DATETIME,
  `create_dt` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `dqc841` (
  `id` INT,
  `fat_part_no` INT,
  `parts_no` VARCHAR(64),
  `unt_usg` VARCHAR(64),
  `description` VARCHAR(64),
  `ref_designator` VARCHAR(64),
  `update_dt` DATETIME,
  `create_dt` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `dqcmodel` (
  `id` INT,
  `model` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_668038_calcomp') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_668038_calcomp') AS relationships;
DROP DATABASE `db_668038_calcomp`;
UNINSTALL EXTENSION vsql_schematron;
