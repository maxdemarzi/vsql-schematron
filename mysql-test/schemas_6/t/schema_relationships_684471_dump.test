INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 684471_dump
--echo #
CREATE DATABASE `db_684471_dump`;
USE `db_684471_dump`;

CREATE TABLE `car` (
  `id` INT,
  `make` VARCHAR(255),
  `model` VARCHAR(255),
  `year` INT,
  `consumption` INT,
  `km` INT,
  `lastTechInspection` DATETIME,
  `priceTechInspection` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `costs` (
  `id` INT,
  `fuelCosts` INT,
  `techInspectionCosts` INT,
  `status` VARCHAR(255),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `payment_id` INT,
  `employee_id` INT
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `id` INT,
  `firstName` VARCHAR(255),
  `lastName` VARCHAR(255),
  `phoneNumber` INT,
  `email` VARCHAR(255),
  `kmLimit` INT,
  `car_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payment` (
  `id` INT,
  `sum` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_684471_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_684471_dump') AS relationships;
DROP DATABASE `db_684471_dump`;
UNINSTALL EXTENSION vsql_schematron;
