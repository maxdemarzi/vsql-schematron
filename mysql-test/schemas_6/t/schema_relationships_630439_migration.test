INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 630439_migration
--echo #
CREATE DATABASE `db_630439_migration`;
USE `db_630439_migration`;

CREATE TABLE `Group` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `parentId` VARCHAR(64),
  `color` VARCHAR(64),
  `description` VARCHAR(64),
  `icon` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_GroupToUser` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_GroupToUserDocument` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_630439_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_630439_migration') AS relationships;
DROP DATABASE `db_630439_migration`;
UNINSTALL EXTENSION vsql_schematron;
