INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 687301_aero_mysql_script
--echo #
CREATE DATABASE `db_687301_aero_mysql_script`;
USE `db_687301_aero_mysql_script`;

CREATE TABLE `Company` (
  `ID_comp` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ID_comp`)
) CHARACTER SET latin1;

CREATE TABLE `Pass_in_trip` (
  `trip_no` INT,
  `date` DATETIME,
  `ID_psg` INT,
  `place` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Passenger` (
  `ID_psg` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Trip` (
  `trip_no` INT,
  `ID_comp` INT,
  `plane` VARCHAR(64),
  `town_from` VARCHAR(64),
  `town_to` VARCHAR(64),
  `time_out` DATETIME,
  `time_in` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_687301_aero_mysql_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_687301_aero_mysql_script') AS relationships;
DROP DATABASE `db_687301_aero_mysql_script`;
UNINSTALL EXTENSION vsql_schematron;
