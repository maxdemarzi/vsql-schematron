INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 669212_pacific
--echo #
CREATE DATABASE `db_669212_pacific`;
USE `db_669212_pacific`;

CREATE TABLE `activities` (
  `ActivityId` INT,
  `ActivityName` VARCHAR(255),
  `ActivityDescription` VARCHAR(255),
  PRIMARY KEY (`ActivityId`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `ClientId` INT,
  `FName` VARCHAR(255),
  `LName` VARCHAR(255),
  `Address` VARCHAR(255),
  `Phone` VARCHAR(255),
  `Email` VARCHAR(255),
  `ResId` INT,
  `ActivityId` INT,
  PRIMARY KEY (`ClientId`)
) CHARACTER SET latin1;

CREATE TABLE `package` (
  `PackageId` INT,
  `PackageName` VARCHAR(255),
  `PackageDescription` VARCHAR(255),
  `NumberOfNights` INT,
  `Cost` INT,
  PRIMARY KEY (`PackageId`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `ProductId` INT,
  `Name` VARCHAR(255),
  `Description` VARCHAR(255),
  `Product_Image_URL` VARCHAR(255),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`ProductId`)
) CHARACTER SET latin1;

CREATE TABLE `reservationyurt` (
  `ResId` INT,
  `ArrivalDate` DATETIME,
  `NumberOfNights` INT,
  `PackageId` INT,
  `Comments` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `whenclientactivity` (
  `Id` INT,
  `Date` DATETIME,
  `ActivityId` INT,
  `ClientId` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_669212_pacific') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_669212_pacific') AS relationships;
DROP DATABASE `db_669212_pacific`;
UNINSTALL EXTENSION vsql_schematron;
