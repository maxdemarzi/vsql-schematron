INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 630450_Tlek-DDL-queries
--echo #
CREATE DATABASE `db_630450_Tlek_DDL_queries`;
USE `db_630450_Tlek_DDL_queries`;
CREATE TABLE `interactions` (
  `user_id` INT,
  `item_id` INT,
  `progress` INT,
  `rating` DOUBLE,
  `isFavorite` BOOLEAN,
  `start_date` DATE
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `genres` VARCHAR(50),
  `authors` VARCHAR(50),
  `year` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `age` VARCHAR(50),
  `sex` DOUBLE,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlist` (
  `user_id` INT,
  `item_id` INT
) CHARACTER SET latin1;
CREATE TABLE `rating` (
  `user_id` INT,
  `item_id` INT,
  `user_rating` INT
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `user_id` INT,
  `item_id` INT,
  `context` VARCHAR(50),
  `created_date` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_630450_Tlek_DDL_queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_630450_Tlek_DDL_queries') AS relationships;
DROP DATABASE `db_630450_Tlek_DDL_queries`;
UNINSTALL EXTENSION vsql_schematron;
