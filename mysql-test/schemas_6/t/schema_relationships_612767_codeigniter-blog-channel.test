INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 612767_codeigniter-blog-channel
--echo #
CREATE DATABASE `db_612767_codeigniter_blog_channel`;
USE `db_612767_codeigniter_blog_channel`;
CREATE TABLE `migrations` (
  `id` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `class` VARCHAR(50),
  `group` VARCHAR(50),
  `namespace` VARCHAR(50),
  `time` INT,
  `batch` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` VARCHAR(50),
  `title` VARCHAR(50),
  `description` TEXT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` VARCHAR(50),
  `post_image` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `is_admin` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_612767_codeigniter_blog_channel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_612767_codeigniter_blog_channel') AS relationships;
DROP DATABASE `db_612767_codeigniter_blog_channel`;
UNINSTALL EXTENSION vsql_schematron;
