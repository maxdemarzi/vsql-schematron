CREATE TABLE `af.test_data_set_checking_result` (
  `id` BIGINT NOT NULL,
  `test_data_set_id` BIGINT,
  `initiator` CHAR(50),
  `created_at` TIMESTAMP NULL,
  `template` TEXT,
  `party_id` CHAR(50),
  `shop_id` CHAR(50),
  `checking_timestamp` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `af.test_payment_checking_result` (
  `id` BIGINT NOT NULL,
  `test_data_set_checking_result_id` BIGINT,
  `test_payment_id` BIGINT,
  `checked_template` CHAR(50),
  `result_status` CHAR(50),
  `rule_checked` CHAR(50),
  `notifications_rule` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
