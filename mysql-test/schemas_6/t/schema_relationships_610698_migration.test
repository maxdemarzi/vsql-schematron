INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 610698_migration
--echo #
CREATE DATABASE `db_610698_migration`;
USE `db_610698_migration`;

CREATE TABLE `Assets` (
  `uuid` VARCHAR(64),
  `binary` VARCHAR(64),
  `digest` VARCHAR(64),
  `compressed` BOOL,
  `filename` VARCHAR(64),
  `status` VARCHAR(64),
  `draftRequestId` VARCHAR(64),
  `draftExpectedParts` INT,
  `invalidReason` VARCHAR(64),
  `invalidTimestamp` DATETIME,
  `created` DATETIME,
  `createdByUuid` VARCHAR(64),
  `modified` DATETIME,
  `modifiedByUuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Biomes` (
  `uuid` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `link` VARCHAR(64),
  `created` DATETIME,
  `createdByUuid` VARCHAR(64),
  `modified` DATETIME,
  `modifiedByUuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Fragments` (
  `uuid` VARCHAR(64),
  `assetsByUuid` VARCHAR(64),
  `part` INT,
  `binary` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Species` (
  `uuid` VARCHAR(64),
  `tag` VARCHAR(64),
  `generation` INT,
  `description` VARCHAR(64),
  `link` VARCHAR(64),
  `created` DATETIME,
  `createdByUuid` VARCHAR(64),
  `modified` DATETIME,
  `modifiedByUuid` VARCHAR(64),
  `assetByUuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `uuid` VARCHAR(64),
  `email` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `token` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Habitats` (
  `uuid` VARCHAR(64),
  `speciesByUuid` VARCHAR(64),
  `biomesByUuid` VARCHAR(64),
  `created` DATETIME,
  `createdByUuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Characteristics` (
  `uuid` VARCHAR(64),
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  `speciesByUuid` VARCHAR(64),
  `created` DATETIME,
  `createdByUuid` VARCHAR(64),
  `modified` DATETIME,
  `modifiedByUuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_610698_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_610698_migration') AS relationships;
DROP DATABASE `db_610698_migration`;
UNINSTALL EXTENSION vsql_schematron;
