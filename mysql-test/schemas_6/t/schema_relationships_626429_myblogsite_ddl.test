INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626429_myblogsite.ddl
--echo #
CREATE DATABASE `db_626429_myblogsite_ddl`;
USE `db_626429_myblogsite_ddl`;
CREATE TABLE `User` (
  `userId` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `phoneNum` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `postalCode` VARCHAR(50),
  `country` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `isAdmin` VARCHAR(50),
  `enabled` VARCHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `postId` INT NOT NULL,
  `postTitle` VARCHAR(50),
  `content` VARCHAR(50),
  `postDate` DATE,
  `likeCount` INT,
  `postImage` VARCHAR(50),
  `userId` INT,
  PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
  `tagId` INT NOT NULL,
  `tagName` VARCHAR(50),
  PRIMARY KEY (`tagId`)
) CHARACTER SET latin1;
CREATE TABLE `Related` (
  `tagId` INT,
  `postId` INT
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `commentId` INT NOT NULL,
  `content` VARCHAR(50),
  `commentDate` DATE,
  `postId` INT,
  `userId` INT,
  PRIMARY KEY (`commentId`)
) CHARACTER SET latin1;
CREATE TABLE `ContactUs` (
  `contactId` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `message` VARCHAR(50),
  PRIMARY KEY (`contactId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626429_myblogsite_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626429_myblogsite_ddl') AS relationships;
DROP DATABASE `db_626429_myblogsite_ddl`;
UNINSTALL EXTENSION vsql_schematron;
