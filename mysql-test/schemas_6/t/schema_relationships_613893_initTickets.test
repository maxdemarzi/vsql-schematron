INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 613893_initTickets
--echo #
CREATE DATABASE `db_613893_initTickets`;
USE `db_613893_initTickets`;

CREATE TABLE `clients` (
  `id` VARCHAR(64),
  `secret` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_codes` (
  `auth_code` VARCHAR(64),
  `expires_at` INT,
  `client_id` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`client_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `is_admin` VARCHAR(64),
  `expires_at` INT,
  `client_id` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`client_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_613893_initTickets') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_613893_initTickets') AS relationships;
DROP DATABASE `db_613893_initTickets`;
UNINSTALL EXTENSION vsql_schematron;
