INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 627232_schema
--echo #
CREATE DATABASE `db_627232_schema`;
USE `db_627232_schema`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `tags` VARCHAR(50),
  `path` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_file` (
  `user_id` INT NOT NULL,
  `file_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `file_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_627232_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_627232_schema') AS relationships;
DROP DATABASE `db_627232_schema`;
UNINSTALL EXTENSION vsql_schematron;
