INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 601403_initial-schema
--echo #
CREATE DATABASE `db_601403_initial_schema`;
USE `db_601403_initial_schema`;
CREATE TABLE `CUSTOMER` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ADDRESS` (
  `id` DECIMAL(10,2),
  `customer_id` DECIMAL(10,2),
  `street` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_601403_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_601403_initial_schema') AS relationships;
DROP DATABASE `db_601403_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
