INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 637026_118
--echo #
CREATE DATABASE `db_637026_118`;
USE `db_637026_118`;
CREATE TABLE `organization` (
  `org_id` INT NOT NULL,
  `org_name` TEXT,
  `org_description` TEXT,
  PRIMARY KEY (`org_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_org` (
  `user_org_id` INT NOT NULL,
  `user_id` TEXT,
  `org_id` INT,
  PRIMARY KEY (`user_org_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_637026_118') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_637026_118') AS relationships;
DROP DATABASE `db_637026_118`;
UNINSTALL EXTENSION vsql_schematron;
