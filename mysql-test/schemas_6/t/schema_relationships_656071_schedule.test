INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 656071_schedule
--echo #
CREATE DATABASE `db_656071_schedule`;
USE `db_656071_schedule`;

CREATE TABLE `classroom` (
  `classroom_id` INT,
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`classroom_id`)
) CHARACTER SET latin1;

CREATE TABLE `day` (
  `day_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`day_id`)
) CHARACTER SET latin1;

CREATE TABLE `gender` (
  `gender_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`gender_id`)
) CHARACTER SET latin1;

CREATE TABLE `gruppa` (
  `gruppa_id` INT,
  `name` VARCHAR(64),
  `special_id` INT,
  `date_begin` DATETIME,
  `date_end` DATETIME,
  PRIMARY KEY (`gruppa_id`)
) CHARACTER SET latin1;

CREATE TABLE `lesson_num` (
  `lesson_num_id` INT,
  `name` VARCHAR(64),
  `time_lesson` DATETIME,
  PRIMARY KEY (`lesson_num_id`)
) CHARACTER SET latin1;

CREATE TABLE `lesson_plan` (
  `lesson_plan_id` INT,
  `gruppa_id` INT,
  `subject_id` INT,
  `user_id` INT,
  PRIMARY KEY (`lesson_plan_id`)
) CHARACTER SET latin1;

CREATE TABLE `otdel` (
  `otdel_id` INT,
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`otdel_id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `role_id` INT,
  `sys_name` VARCHAR(64),
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `schedule` (
  `schedule_id` INT,
  `lesson_plan_id` INT,
  `day_id` INT,
  `lesson_num_id` INT,
  `classroom_id` INT
) CHARACTER SET latin1;

CREATE TABLE `special` (
  `special_id` INT,
  `name` VARCHAR(64),
  `otdel_id` INT,
  `active` INT
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `user_id` INT,
  `gruppa_id` INT,
  `num_zach` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `subject` (
  `subject_id` INT,
  `name` VARCHAR(64),
  `otdel_id` INT,
  `hours` INT,
  `active` INT,
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;

CREATE TABLE `teacher` (
  `user_id` INT,
  `otdel_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `lastname` VARCHAR(64),
  `firstname` VARCHAR(64),
  `patronymic` VARCHAR(64),
  `login` VARCHAR(64),
  `pass` VARCHAR(64),
  `gender_id` INT,
  `birthday` DATETIME,
  `role_id` INT,
  `active` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_656071_schedule') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_656071_schedule') AS relationships;
DROP DATABASE `db_656071_schedule`;
UNINSTALL EXTENSION vsql_schematron;
