INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 600363_db_seinfo_2021_2
--echo #
CREATE DATABASE `db_600363_db_seinfo_2021_2`;
USE `db_600363_db_seinfo_2021_2`;

CREATE TABLE `agendamentoAtividade` (
  `idAtividade` INT,
  `idAgenda` INT,
  PRIMARY KEY (`idAtividade`, `idAgenda`)
) CHARACTER SET latin1;

CREATE TABLE `despesa` (
  `idDespesa` INT,
  `descricao` VARCHAR(64),
  `valor` DECIMAL(10,2),
  `dataDespesa` DATETIME,
  `idEvento` INT,
  PRIMARY KEY (`idDespesa`)
) CHARACTER SET latin1;

CREATE TABLE `eventoImagem` (
  `idEvento` INT,
  `idImagem` INT,
  PRIMARY KEY (`idEvento`, `idImagem`)
) CHARACTER SET latin1;

CREATE TABLE `inscricaoAtividade` (
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `idAtividade` INT,
  `dataInscricao` DATETIME,
  PRIMARY KEY (`CPF`, `idEvento`, `idAtividade`)
) CHARACTER SET latin1;

CREATE TABLE `inscricaoEvento` (
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `dataInscricao` DATETIME,
  `idLote` INT,
  PRIMARY KEY (`CPF`, `idEvento`)
) CHARACTER SET latin1;

CREATE TABLE `organizacao` (
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `horasParticipacao` DATETIME,
  PRIMARY KEY (`CPF`, `idEvento`)
) CHARACTER SET latin1;

CREATE TABLE `presenca` (
  `idAgenda` INT,
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `idAtividade` INT,
  `presenca` INT,
  PRIMARY KEY (`idAgenda`, `CPF`, `idEvento`, `idAtividade`)
) CHARACTER SET latin1;

CREATE TABLE `protagonista` (
  `CPF` VARCHAR(64),
  `idAtividade` INT,
  `atuacao` INT,
  PRIMARY KEY (`CPF`, `idAtividade`)
) CHARACTER SET latin1;

CREATE TABLE `receita` (
  `idReceita` INT,
  `descricao` VARCHAR(64),
  `valor` DECIMAL(10,2),
  `dataReceita` DATETIME,
  `idEvento` INT,
  PRIMARY KEY (`idReceita`)
) CHARACTER SET latin1;

CREATE TABLE `receitaInscricaoAtividade` (
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `idAtividade` INT,
  `dataPagamento` DATETIME,
  PRIMARY KEY (`CPF`, `idEvento`, `idAtividade`)
) CHARACTER SET latin1;

CREATE TABLE `receitaInscricaoEvento` (
  `CPF` VARCHAR(64),
  `idEvento` INT,
  `dataPagamento` DATETIME,
  PRIMARY KEY (`CPF`, `idEvento`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_600363_db_seinfo_2021_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_600363_db_seinfo_2021_2') AS relationships;
DROP DATABASE `db_600363_db_seinfo_2021_2`;
UNINSTALL EXTENSION vsql_schematron;
