INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 613195_DDL
--echo #
CREATE DATABASE `db_613195_DDL`;
USE `db_613195_DDL`;
CREATE TABLE `UserData` (
  `account_ID` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `preference` VARCHAR(50),
  PRIMARY KEY (`account_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Stuff` (
  `stuff_ID` INT NOT NULL,
  `account_ID` CHAR(50),
  `record_date_date` DATE,
  `record_date_time` TIME,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`stuff_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
  `event_ID` INT NOT NULL,
  `account_ID` CHAR(50),
  `time_start_date` DATE,
  `time_start_time` TIME,
  `time_end_date` DATE,
  `time_end_time` TIME,
  `buf_time` TIME,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`event_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
  `project_ID` INT NOT NULL,
  `account_ID` CHAR(50),
  `deadline_date` DATE,
  `deadline_time` TIME,
  `importance` DECIMAL(10,2),
  `title` VARCHAR(50),
  `tag` VARCHAR(50),
  `intro` VARCHAR(50),
  `highlight` INT,
  `status` VARCHAR(50),
  PRIMARY KEY (`project_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
  `task_ID` INT NOT NULL,
  `project_ID` INT,
  `destination` VARCHAR(50),
  `time_req_date` DATE,
  `time_req_time` TIME,
  `status` VARCHAR(50),
  PRIMARY KEY (`task_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_613195_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_613195_DDL') AS relationships;
DROP DATABASE `db_613195_DDL`;
UNINSTALL EXTENSION vsql_schematron;
