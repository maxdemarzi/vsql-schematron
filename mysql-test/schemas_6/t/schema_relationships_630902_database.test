INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 630902_database
--echo #
CREATE DATABASE `db_630902_database`;
USE `db_630902_database`;

CREATE TABLE `department` (
  `depid` VARCHAR(64),
  `name` VARCHAR(64),
  `py` VARCHAR(64),
  PRIMARY KEY (`depid`)
) CHARACTER SET latin1;

CREATE TABLE `doctor` (
  `docid` VARCHAR(64),
  `depid` VARCHAR(64),
  `name` VARCHAR(64),
  `py` VARCHAR(64),
  `password` VARCHAR(64),
  `speciallist` INT,
  `last_login_datetime` DATETIME,
  PRIMARY KEY (`docid`)
) CHARACTER SET latin1;

CREATE TABLE `patient` (
  `pid` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `balance` DECIMAL(10,2),
  `last_login_datetime` DATETIME,
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;

CREATE TABLE `register` (
  `reg_id` VARCHAR(64),
  `catid` VARCHAR(64),
  `docid` VARCHAR(64),
  `pid` VARCHAR(64),
  `current_reg_count` INT,
  `unreg` INT,
  `reg_fee` DECIMAL(10,2),
  `reg_datetime` DATETIME,
  PRIMARY KEY (`reg_id`)
) CHARACTER SET latin1;

CREATE TABLE `register_category` (
  `catid` VARCHAR(64),
  `name` VARCHAR(64),
  `py` VARCHAR(64),
  `depid` VARCHAR(64),
  `speciallist` INT,
  `max_reg_number` INT,
  `reg_fee` DECIMAL(10,2),
  PRIMARY KEY (`catid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_630902_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_630902_database') AS relationships;
DROP DATABASE `db_630902_database`;
UNINSTALL EXTENSION vsql_schematron;
