INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655595_model_mysql
--echo #
CREATE DATABASE `db_655595_model_mysql`;
USE `db_655595_model_mysql`;

CREATE TABLE `schemaname.person` (
  `person_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `dob` DATETIME,
  PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;

CREATE TABLE `schemaname.studio` (
  `studio_id` INT,
  `name` VARCHAR(255),
  `website` VARCHAR(255),
  PRIMARY KEY (`studio_id`)
) CHARACTER SET latin1;

CREATE TABLE `schemaname.movie` (
  `movie_id` INT,
  `title` VARCHAR(255),
  `year` INT,
  `description` VARCHAR(255),
  `studio_id` INT,
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `schemaname.actors` (
  `person_id` INT,
  `movie_id` INT,
  PRIMARY KEY (`person_id`, `movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `schemaname.showing` (
  `theater` VARCHAR(255),
  `day` VARCHAR(255),
  `movie_id` INT,
  PRIMARY KEY (`theater`, `day`, `movie_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655595_model_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655595_model_mysql') AS relationships;
DROP DATABASE `db_655595_model_mysql`;
UNINSTALL EXTENSION vsql_schematron;
