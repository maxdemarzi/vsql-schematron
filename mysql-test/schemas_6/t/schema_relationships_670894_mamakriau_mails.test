INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 670894_mamakriau_mails
--echo #
CREATE DATABASE `db_670894_mamakriau_mails`;
USE `db_670894_mamakriau_mails`;

CREATE TABLE `mama_eav_attributes_bigint` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` INT
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_bool` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` INT
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_datetime` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_double` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_int` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` INT
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_mediumblob` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_string` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_attributes_text` (
  `id` INT,
  `id_entity` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `mama_eav_entities` (
  `id` INT,
  `uuid` VARCHAR(64),
  `parent_uuid` VARCHAR(64),
  `entity_type` VARCHAR(64),
  `module_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `mama_min_hashes` (
  `hash_id` VARCHAR(64),
  `user_id` INT,
  `hash` VARCHAR(64),
  `data` VARCHAR(64),
  `expire_date` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_670894_mamakriau_mails') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_670894_mamakriau_mails') AS relationships;
DROP DATABASE `db_670894_mamakriau_mails`;
UNINSTALL EXTENSION vsql_schematron;
