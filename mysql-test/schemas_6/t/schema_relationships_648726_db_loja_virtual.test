INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648726_db_loja_virtual
--echo #
CREATE DATABASE `db_648726_db_loja_virtual`;
USE `db_648726_db_loja_virtual`;
CREATE TABLE `tb_clientes` (
  `id_cliente` INT NOT NULL,
  `nome` VARCHAR(50),
  `idade` INT,
  PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `tb_descricoes_tecnicas` (
  `id_descricao_tecnica` INT,
  `fk_id_produto` INT,
  `descricao_tecnica` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tb_imagens` (
  `id_imagem` INT,
  `fk_id_produto` INT,
  `url_imagem` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos` (
  `id_pedido` INT,
  `fk_id_cliente` INT,
  `data_hora` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos_produtos` (
  `fk_id_pedido` INT,
  `fk_id_produto` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648726_db_loja_virtual') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648726_db_loja_virtual') AS relationships;
DROP DATABASE `db_648726_db_loja_virtual`;
UNINSTALL EXTENSION vsql_schematron;
