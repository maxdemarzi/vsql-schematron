INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638800_SQL-script
--echo #
CREATE DATABASE `db_638800_SQL_script`;
USE `db_638800_SQL_script`;
CREATE TABLE `Kunden` (
  `Kunden_ID` INT NOT NULL,
  `Vorname` VARCHAR(50),
  `Nachname` VARCHAR(50),
  `Adresse` VARCHAR(50),
  `Aktiv` BOOLEAN,
  `Beginndatum` DATE,
  `Enddatum` DATE,
  PRIMARY KEY (`Kunden_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Bikes` (
  `Bike_ID` INT NOT NULL,
  `Kunden_ID` INT,
  `Fahrradtyp` VARCHAR(50),
  `Kaufdatum` DATE,
  `GPS` VARCHAR(50),
  `Standort` VARCHAR(50),
  `Status` VARCHAR(50),
  PRIMARY KEY (`Bike_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BikesService` (
  `BikesService_ID` INT NOT NULL,
  `Serviceart` VARCHAR(50),
  `Bike_ID` INT,
  `Erstellungsdatum` DATE,
  `Bearbeitungsdatum` DATE,
  PRIMARY KEY (`BikesService_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638800_SQL_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638800_SQL_script') AS relationships;
DROP DATABASE `db_638800_SQL_script`;
UNINSTALL EXTENSION vsql_schematron;
