INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 623630_zend_curd
--echo #
CREATE DATABASE `db_623630_zend_curd`;
USE `db_623630_zend_curd`;

CREATE TABLE `actors` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `directors` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `director_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies_actors` (
  `id` INT,
  `movies_id` INT,
  `actors_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_623630_zend_curd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_623630_zend_curd') AS relationships;
DROP DATABASE `db_623630_zend_curd`;
UNINSTALL EXTENSION vsql_schematron;
