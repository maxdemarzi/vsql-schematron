INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 615689_create
--echo #
CREATE DATABASE `db_615689_create`;
USE `db_615689_create`;

CREATE TABLE `publishers` (
  `publisher_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`publisher_id`)
) CHARACTER SET latin1;

CREATE TABLE `authors` (
  `author_id` INT,
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `book_id` INT,
  `title` VARCHAR(64),
  `total_pages` INT,
  `rating` DECIMAL(10,2),
  `isbn` VARCHAR(64),
  `published_date` DATETIME,
  `publisher_id` INT,
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `book_authors` (
  `book_id` INT,
  `author_id` INT,
  PRIMARY KEY (`book_id`, `author_id`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `genre_id` INT,
  `genre` VARCHAR(64),
  `parent_id` INT,
  PRIMARY KEY (`genre_id`)
) CHARACTER SET latin1;

CREATE TABLE `book_genres` (
  `book_id` INT,
  `genre_id` INT,
  PRIMARY KEY (`book_id`, `genre_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_615689_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_615689_create') AS relationships;
DROP DATABASE `db_615689_create`;
UNINSTALL EXTENSION vsql_schematron;
