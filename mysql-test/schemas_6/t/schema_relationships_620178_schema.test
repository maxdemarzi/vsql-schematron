INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620178_schema
--echo #
CREATE DATABASE `db_620178_schema`;
USE `db_620178_schema`;
CREATE TABLE `companies` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `tin` VARCHAR(50),
  `address` VARCHAR(50),
  `phone_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `birth_date` DATE,
  `email` VARCHAR(50),
  `company_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620178_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620178_schema') AS relationships;
DROP DATABASE `db_620178_schema`;
UNINSTALL EXTENSION vsql_schematron;
