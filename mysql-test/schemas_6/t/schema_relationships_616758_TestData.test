INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 616758_TestData
--echo #
CREATE DATABASE `db_616758_TestData`;
USE `db_616758_TestData`;

CREATE TABLE `Publisher` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Author` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Sex` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Reader` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `Id` INT,
  `ReaderId` INT,
  `BookId` INT,
  `Content` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `WriteBook` (
  `AuthorId` INT,
  `BookId` INT,
  PRIMARY KEY (`AuthorId`, `BookId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_616758_TestData') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_616758_TestData') AS relationships;
DROP DATABASE `db_616758_TestData`;
UNINSTALL EXTENSION vsql_schematron;
