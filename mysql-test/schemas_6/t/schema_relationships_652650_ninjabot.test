INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652650_ninjabot
--echo #
CREATE DATABASE `db_652650_ninjabot`;
USE `db_652650_ninjabot`;
CREATE TABLE `cuentas` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `telefono` VARCHAR(50),
  `deleted` TINYINT,
  `deleted_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `token` (
  `id` VARCHAR(50),
  `auth` VARCHAR(50),
  `cuenta_id` VARCHAR(50),
  `deleted` TINYINT,
  `deleted_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652650_ninjabot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652650_ninjabot') AS relationships;
DROP DATABASE `db_652650_ninjabot`;
UNINSTALL EXTENSION vsql_schematron;
