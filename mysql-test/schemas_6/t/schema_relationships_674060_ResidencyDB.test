  `DT_ENT` DATETIME,
  `USER_SEQ_CHG_BY` DECIMAL(10,2),
  `DT_CHG` DATETIME,
  PRIMARY KEY (`NON_CITIZEN_SEQ`)
) CHARACTER SET latin1;

CREATE TABLE `NON_RESIDENT` (
  `NON_RESIDENT_SEQ` INT,
