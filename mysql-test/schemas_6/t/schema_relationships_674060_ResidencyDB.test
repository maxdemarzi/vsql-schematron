  `DT_ENT` DATETIME,
  `USER_SEQ_CHG_BY` DECIMAL(10,2),
  `DT_CHG` DATETIME,
  PRIMARY KEY (`USER_SEQ`)
) CHARACTER SET latin1;

CREATE TABLE `USER_ROLE` (
  `USER_ROLE_SEQ` INT,
  `USER_ROLE_CODE` VARCHAR(64),
  `USER_ROLE_DESCRIPTION` VARCHAR(64),
  `USER_SEQ_ENT_BY` DECIMAL(10,2),
  `DT_ENT` DATETIME,
  `USER_SEQ_CHG_BY` DECIMAL(10,2),
  `DT_CHG` DATETIME,
  PRIMARY KEY (`USER_ROLE_SEQ`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_674060_ResidencyDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_674060_ResidencyDB') AS relationships;
DROP DATABASE `db_674060_ResidencyDB`;
UNINSTALL EXTENSION vsql_schematron;
