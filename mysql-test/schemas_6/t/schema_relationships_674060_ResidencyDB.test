CREATE TABLE `USER` (
  `USER_SEQ` INT,
  `USER_ROLE_SEQ` INT,
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `Z_NUMBER` DECIMAL(10,2),
  `EMAIL_ADDRESS` VARCHAR(64),
