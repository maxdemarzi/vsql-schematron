INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 674060_ResidencyDB
--echo #
CREATE DATABASE `db_674060_ResidencyDB`;
USE `db_674060_ResidencyDB`;

CREATE TABLE `CLAIMING_RESIDENCY` (
  `CLAIMING_RESIDENCY_SEQ` INT,
  `SUPPORTING_DOCUMENTS_SEQ` INT,
  `DEMONSTRATE_RESIDENCY_SEQ` INT,
  `PERSON_NAME` VARCHAR(64),
  `CLAIMANT_RELATIONSHIP` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `PHONE_NUMBER` VARCHAR(64),
  `RESIDENCY_DATE` DATETIME,
  `USER_SEQ_ENT_BY` DECIMAL(10,2),
  `DT_ENT` DATETIME,
  `USER_SEQ_CHG_BY` DECIMAL(10,2),
  `DT_CHG` DATETIME,
  PRIMARY KEY (`CLAIMING_RESIDENCY_SEQ`)
) CHARACTER SET latin1;

CREATE TABLE `DEMONSTRATE_RESIDENCY` (
  `DEMONSTRATE_RESIDENCY_SEQ` INT,
  `CODE` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `USER_SEQ_ENT_BY` DECIMAL(10,2),
  `DT_ENT` DATETIME,
  `USER_SEQ_CHG_BY` DECIMAL(10,2),
  `DT_CHG` DATETIME,
