INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 653679_hadesAndQuartz186Tables
--echo #
CREATE DATABASE `db_653679_hadesAndQuartz186Tables`;
USE `db_653679_hadesAndQuartz186Tables`;

CREATE TABLE `HADES_RESULTS` (
  `DS` VARCHAR(64),
  `SQL_STMT` VARCHAR(64),
  `CONN_TIMEOUT` INT,
  `EXEC_TIMEOUT` INT,
  `TIME_NANOS` INT,
  `HOST` VARCHAR(64),
  `REPO` VARCHAR(64),
  `MAIN_DS` VARCHAR(64),
  `FAILOVER_DS` VARCHAR(64),
  `TS` DATETIME,
  PRIMARY KEY (`DS`, `SQL_STMT`, `CONN_TIMEOUT`, `EXEC_TIMEOUT`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_STATES` (
  `MODIFIED_MILLIS` INT,
  `HOST` VARCHAR(64),
  `QUARTZ_INSTANCE` VARCHAR(64),
  `QUARTZ_CLUSTER` VARCHAR(64),
  `MAIN_DS` VARCHAR(64),
  `FAILOVER_DS` VARCHAR(64),
  `FAILOVER_ACTIVE` VARCHAR(64),
  `DURATION_MILLIS` INT,
  `MAIN_NANOS` INT,
  `FAILOVER_NANOS` INT,
  PRIMARY KEY (`QUARTZ_CLUSTER`, `MAIN_DS`, `FAILOVER_DS`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_JOB_DETAILS` (
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `JOB_CLASS_NAME` VARCHAR(64),
  `IS_DURABLE` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `IS_STATEFUL` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_JOB_LISTENERS` (
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `JOB_LISTENER` VARCHAR(64),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`, `JOB_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `NEXT_FIRE_TIME` DECIMAL(10,2),
  `PREV_FIRE_TIME` DECIMAL(10,2),
  `PRIORITY` DECIMAL(10,2),
  `TRIGGER_STATE` VARCHAR(64),
  `TRIGGER_TYPE` VARCHAR(64),
  `START_TIME` DECIMAL(10,2),
  `END_TIME` DECIMAL(10,2),
  `CALENDAR_NAME` VARCHAR(64),
  `MISFIRE_INSTR` DECIMAL(10,2),
  `JOB_DATA` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_SIMPLE_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `REPEAT_COUNT` DECIMAL(10,2),
  `REPEAT_INTERVAL` DECIMAL(10,2),
  `TIMES_TRIGGERED` DECIMAL(10,2),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_CRON_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `CRON_EXPRESSION` VARCHAR(64),
  `TIME_ZONE_ID` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_BLOB_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `BLOB_DATA` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_TRIGGER_LISTENERS` (
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `TRIGGER_LISTENER` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`, `TRIGGER_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_CALENDARS` (
  `CALENDAR_NAME` VARCHAR(64),
  `CALENDAR` VARCHAR(64),
  PRIMARY KEY (`CALENDAR_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_PAUSED_TRIGGER_GRPS` (
  `TRIGGER_GROUP` VARCHAR(64),
  PRIMARY KEY (`TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_FIRED_TRIGGERS` (
  `ENTRY_ID` VARCHAR(64),
  `TRIGGER_NAME` VARCHAR(64),
  `TRIGGER_GROUP` VARCHAR(64),
  `IS_VOLATILE` VARCHAR(64),
  `INSTANCE_NAME` VARCHAR(64),
  `FIRED_TIME` DECIMAL(10,2),
  `PRIORITY` DECIMAL(10,2),
  `STATE` VARCHAR(64),
  `JOB_NAME` VARCHAR(64),
  `JOB_GROUP` VARCHAR(64),
  `IS_STATEFUL` VARCHAR(64),
  `REQUESTS_RECOVERY` VARCHAR(64),
  PRIMARY KEY (`ENTRY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_SCHEDULER_STATE` (
  `INSTANCE_NAME` VARCHAR(64),
  `LAST_CHECKIN_TIME` DECIMAL(10,2),
  `CHECKIN_INTERVAL` DECIMAL(10,2),
  PRIMARY KEY (`INSTANCE_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `HADES_LOCKS` (
  `LOCK_NAME` VARCHAR(64),
  PRIMARY KEY (`LOCK_NAME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_653679_hadesAndQuartz186Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_653679_hadesAndQuartz186Tables') AS relationships;
DROP DATABASE `db_653679_hadesAndQuartz186Tables`;
UNINSTALL EXTENSION vsql_schematron;
