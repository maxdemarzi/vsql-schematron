  `_id` INT,
  `mitzvahName` VARCHAR(64),
  `mitzvahNameEn` VARCHAR(64),
  `asehOrLoSaseh` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

