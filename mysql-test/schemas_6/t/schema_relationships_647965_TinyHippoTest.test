INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 647965_TinyHippoTest
--echo #
CREATE DATABASE `db_647965_TinyHippoTest`;
USE `db_647965_TinyHippoTest`;

CREATE TABLE `TINYHIPPOTEST.Recommendation` (
  `recommendationID` INT,
  `title` VARCHAR(64),
  `tag` VARCHAR(64),
  `imageURL` VARCHAR(64),
  `editedTime` DATETIME,
  `restaurantID` INT,
  PRIMARY KEY (`recommendationID`, `restaurantID`)
) CHARACTER SET latin1;

CREATE TABLE `TINYHIPPOTEST.RecommendationDetails` (
  `recommendationID` INT,
  `dishID` INT,
  `description` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_647965_TinyHippoTest') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_647965_TinyHippoTest') AS relationships;
DROP DATABASE `db_647965_TinyHippoTest`;
UNINSTALL EXTENSION vsql_schematron;
