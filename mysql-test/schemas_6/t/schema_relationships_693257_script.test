INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 693257_script
--echo #
CREATE DATABASE `db_693257_script`;
USE `db_693257_script`;
CREATE TABLE `eventosessao` (
  `id` INT NOT NULL,
  `idcurso` INT,
  `idevento` INT,
  `ideventolocal` INT,
  `idformato` INT,
  `idtiposessao` INT,
  `idvertical` INT,
  `nome` VARCHAR(50),
  `nome_curto` VARCHAR(50),
  `data` DATETIME,
  `inicio` SMALLINT,
  `termino` SMALLINT,
  `url_remota` VARCHAR(50),
  `url_privada` TINYINT,
  `descricao` VARCHAR(50),
  `oculta` TINYINT,
  `sugestao` TINYINT,
  `publico_alvo` VARCHAR(50),
  `tags` VARCHAR(50),
  `permiteinscricao` TINYINT,
  `permitesimultanea` TINYINT,
  `acomminutos` INT,
  `senhacontrole` VARCHAR(50),
  `senhapresenca` VARCHAR(50),
  `mensagemesgotada` VARCHAR(50),
  `tipomultidata` TINYINT,
  `presencaminima` TINYINT,
  `encontrostotais` TINYINT,
  `id_integra` BIGINT,
  `status_integra` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `eventosessaomultidata` (
  `id` BIGINT NOT NULL,
  `ideventosessao` INT,
  `data` DATETIME,
  `inicio` SMALLINT,
  `termino` SMALLINT,
  `permitesimultanea` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_693257_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_693257_script') AS relationships;
DROP DATABASE `db_693257_script`;
UNINSTALL EXTENSION vsql_schematron;
