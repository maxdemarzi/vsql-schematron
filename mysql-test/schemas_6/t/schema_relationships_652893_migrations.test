INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652893_migrations
--echo #
CREATE DATABASE `db_652893_migrations`;
USE `db_652893_migrations`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64),
  PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652893_migrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652893_migrations') AS relationships;
DROP DATABASE `db_652893_migrations`;
UNINSTALL EXTENSION vsql_schematron;
