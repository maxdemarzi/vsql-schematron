INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 674009_postgres
--echo #
CREATE DATABASE `db_674009_postgres`;
USE `db_674009_postgres`;

CREATE TABLE `labels` (
  `language_id` INT,
  `value` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`language_id`, `key`)
) CHARACTER SET latin1;

CREATE TABLE `languages` (
  `id` INT,
  `active` VARCHAR(64),
  `created` DATETIME,
  `deleted` VARCHAR(64),
  `modified` DATETIME,
  `iso_language` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `parameters` (
  `id` INT,
  `active` VARCHAR(64),
  `description` VARCHAR(64),
  `label` VARCHAR(64),
  `type` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `databasechangelog` (
  `id` VARCHAR(64),
  `author` VARCHAR(64),
  `filename` VARCHAR(64),
  `dateexecuted` DATETIME,
  `orderexecuted` INT,
  `exectype` VARCHAR(64),
  `md5sum` VARCHAR(64),
  `description` VARCHAR(64),
  `comments` VARCHAR(64),
  `tag` VARCHAR(64),
  `liquibase` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `databasechangeloglock` (
  `id` INT,
  `locked` VARCHAR(64),
  `lockgranted` DATETIME,
  `lockedby` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `consumer_api` (
  `id` INT,
  `document_number` VARCHAR(64),
  `name` VARCHAR(64),
  `contact_name` VARCHAR(64),
  `consumer_id` VARCHAR(64),
  `secret` VARCHAR(64),
  `access_level` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `keychain` (
  `id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `security_profile` (
  `id` INT,
  `key` VARCHAR(64),
  `name` VARCHAR(64),
  `max_number_of_connections_per_user` INT,
  `max_number_of_connections` INT,
  `refresh_token_timeout_seconds` INT,
  `access_token_timeout_seconds` INT,
  `revocable` VARCHAR(64),
  `max_access_token_requests` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `security_profile_id` INT,
  `remote_ip` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `issued_at` DATETIME,
  `expiration` DATETIME,
  `token_type` VARCHAR(64),
  `token` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_674009_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_674009_postgres') AS relationships;
DROP DATABASE `db_674009_postgres`;
UNINSTALL EXTENSION vsql_schematron;
