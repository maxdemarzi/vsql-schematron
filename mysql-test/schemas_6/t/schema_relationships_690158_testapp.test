INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 690158_testapp
--echo #
CREATE DATABASE `db_690158_testapp`;
USE `db_690158_testapp`;

CREATE TABLE `afisha` (
  `id` INT,
  `name` VARCHAR(64),
  `short_content` VARCHAR(64),
  `content` VARCHAR(64),
  `image` VARCHAR(64),
  `seo_url` VARCHAR(64),
  `seo_title` VARCHAR(64),
  `seo_description` VARCHAR(64),
  `seo_keywords` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `film` (
  `id` INT,
  `name` VARCHAR(64),
  `content` VARCHAR(64),
  `main_image` VARCHAR(64),
  `image1` VARCHAR(64),
  `image2` VARCHAR(64),
  `image3` VARCHAR(64),
  `image4` VARCHAR(64),
  `image5` VARCHAR(64),
  `link_trayler` VARCHAR(64),
  `type_3d` INT,
  `type_2d` INT,
  `type_imax` INT,
  `seo_url` VARCHAR(64),
  `seo_title` VARCHAR(64),
  `seo_description` VARCHAR(64),
  `seo_keywords` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `id` INT,
  `name` VARCHAR(64),
  `parent` INT,
  `route` VARCHAR(64),
  `order` INT,
  `data` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `auth_key` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `password_reset_token` VARCHAR(64),
  `email` VARCHAR(64),
  `status` INT,
  `created_at` INT,
  `updated_at` INT,
  `verification_token` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_690158_testapp') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_690158_testapp') AS relationships;
DROP DATABASE `db_690158_testapp`;
UNINSTALL EXTENSION vsql_schematron;
