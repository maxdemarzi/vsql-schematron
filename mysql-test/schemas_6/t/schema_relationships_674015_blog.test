INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 674015_blog
--echo #
CREATE DATABASE `db_674015_blog`;
USE `db_674015_blog`;

CREATE TABLE `comments` (
  `comment_id` INT,
  `post_id` INT,
  `user_id` INT,
  `comments` VARCHAR(64),
  `is_delete` INT,
  `commented_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `post_id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `is_delete` INT,
  `posted_at` DATETIME,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `userschat` (
  `chat_id` INT,
  `user_id` INT,
  `with_user_id` INT,
  `chat` VARCHAR(64),
  `chat_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_674015_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_674015_blog') AS relationships;
DROP DATABASE `db_674015_blog`;
UNINSTALL EXTENSION vsql_schematron;
