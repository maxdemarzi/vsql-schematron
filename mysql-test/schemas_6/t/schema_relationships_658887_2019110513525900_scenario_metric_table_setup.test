INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 658887_2019110513525900_scenario_metric_table_setup
--echo #
CREATE DATABASE `db_658887_2019110513525900_scenario_metric_table_setup`;
USE `db_658887_2019110513525900_scenario_metric_table_setup`;
CREATE TABLE `scenarios` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `assumptions` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `metric_data` (
  `id` INT NOT NULL,
  `scenario_id` INT,
  `metric_id` INT,
  `year` INT,
  `value` DOUBLE,
  `spatial_table_column` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `metrics` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `low_outcome` DOUBLE,
  `high_outcome` DOUBLE,
  `low_outcome_text` VARCHAR(50),
  `high_outcome_text` VARCHAR(50),
  `unit` VARCHAR(50),
  `bins` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_658887_2019110513525900_scenario_metric_table_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_658887_2019110513525900_scenario_metric_table_setup') AS relationships;
DROP DATABASE `db_658887_2019110513525900_scenario_metric_table_setup`;
UNINSTALL EXTENSION vsql_schematron;
