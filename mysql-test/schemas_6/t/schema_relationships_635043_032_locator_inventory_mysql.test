INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635043_032_locator_inventory.mysql
--echo #
CREATE DATABASE `db_635043_032_locator_inventory_mysql`;
USE `db_635043_032_locator_inventory_mysql`;
CREATE TABLE `inv_locations` (
  `location_id` INT NOT NULL,
  `entity_id` VARCHAR(50),
  `location_barcode` VARCHAR(50),
  `zone` VARCHAR(50),
  `aisle` VARCHAR(50),
  `bay` VARCHAR(50),
  `level` VARCHAR(50),
  `position` VARCHAR(50),
  `visible` INT,
  `location_description` VARCHAR(50),
  `location_capacity` DECIMAL(10,2),
  `capacity_uom` CHAR(50),
  `last_count_date` DATETIME,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `inv_location_master` (
  `inventory_location_id` INT NOT NULL,
  `inventory_id` INT,
  `location_id` INT,
  `total_on_hand` DECIMAL(10,2),
  `total_in_wip` DECIMAL(10,2),
  `total_on_order` DECIMAL(10,2),
  `total_reserved` DECIMAL(10,2),
  `total_unshipped_sold` DECIMAL(10,2),
  `total_shipped_sold` DECIMAL(10,2),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`inventory_location_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635043_032_locator_inventory_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635043_032_locator_inventory_mysql') AS relationships;
DROP DATABASE `db_635043_032_locator_inventory_mysql`;
UNINSTALL EXTENSION vsql_schematron;
