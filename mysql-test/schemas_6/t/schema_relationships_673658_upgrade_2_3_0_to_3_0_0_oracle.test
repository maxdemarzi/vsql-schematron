INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 673658_upgrade_2_3_0_to_3_0_0_oracle
--echo #
CREATE DATABASE `db_673658_upgrade_2_3_0_to_3_0_0_oracle`;
USE `db_673658_upgrade_2_3_0_to_3_0_0_oracle`;

CREATE TABLE `METASTORE_DB_PROPERTIES` (
  `PROPERTY_KEY` VARCHAR(64),
  `PROPERTY_VALUE` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  PRIMARY KEY (`PROPERTY_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `WM_RESOURCEPLAN` (
  `RP_ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `QUERY_PARALLELISM` DECIMAL(10,2),
  `STATUS` VARCHAR(64),
  `DEFAULT_POOL_ID` DECIMAL(10,2),
  PRIMARY KEY (`RP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_POOL` (
  `POOL_ID` DECIMAL(10,2),
  `RP_ID` DECIMAL(10,2),
  `PATH` VARCHAR(64),
  `ALLOC_FRACTION` DECIMAL(10,2),
  `QUERY_PARALLELISM` DECIMAL(10,2),
  `SCHEDULING_POLICY` VARCHAR(64),
  PRIMARY KEY (`POOL_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_TRIGGER` (
  `TRIGGER_ID` DECIMAL(10,2),
  `RP_ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `TRIGGER_EXPRESSION` VARCHAR(64),
  `ACTION_EXPRESSION` VARCHAR(64),
  `IS_IN_UNMANAGED` DECIMAL(10,2),
  PRIMARY KEY (`TRIGGER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_POOL_TO_TRIGGER` (
  `POOL_ID` DECIMAL(10,2),
  `TRIGGER_ID` DECIMAL(10,2),
  PRIMARY KEY (`POOL_ID`, `TRIGGER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_MAPPING` (
  `MAPPING_ID` DECIMAL(10,2),
  `RP_ID` DECIMAL(10,2),
  `ENTITY_TYPE` VARCHAR(64),
  `ENTITY_NAME` VARCHAR(64),
  `POOL_ID` DECIMAL(10,2),
  `ORDERING` DECIMAL(10,2),
  PRIMARY KEY (`MAPPING_ID`)
) CHARACTER SET latin1;

CREATE TABLE `I_SCHEMA` (
  `SCHEMA_ID` DECIMAL(10,2),
  `SCHEMA_TYPE` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `DB_ID` DECIMAL(10,2),
  `COMPATIBILITY` DECIMAL(10,2),
  `VALIDATION_LEVEL` DECIMAL(10,2),
  `CAN_EVOLVE` DECIMAL(10,2),
  `SCHEMA_GROUP` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  PRIMARY KEY (`SCHEMA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SCHEMA_VERSION` (
  `SCHEMA_VERSION_ID` DECIMAL(10,2),
  `SCHEMA_ID` DECIMAL(10,2),
  `VERSION` DECIMAL(10,2),
  `CREATED_AT` DECIMAL(10,2),
  `CD_ID` DECIMAL(10,2),
  `STATE` DECIMAL(10,2),
  `DESCRIPTION` VARCHAR(64),
  `SCHEMA_TEXT` VARCHAR(64),
  `FINGERPRINT` VARCHAR(64),
  `SCHEMA_VERSION_NAME` VARCHAR(64),
  `SERDE_ID` DECIMAL(10,2),
  PRIMARY KEY (`SCHEMA_VERSION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `MV_CREATION_METADATA` (
  `MV_CREATION_METADATA_ID` DECIMAL(10,2),
  `CAT_NAME` VARCHAR(64),
  `DB_NAME` VARCHAR(64),
  `TBL_NAME` VARCHAR(64),
  `TXN_LIST` VARCHAR(64),
  PRIMARY KEY (`MV_CREATION_METADATA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `MV_TABLES_USED` (
  `MV_CREATION_METADATA_ID` DECIMAL(10,2),
  `TBL_ID` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `TXN_TO_WRITE_ID` (
  `T2W_TXNID` DECIMAL(10,2),
  `T2W_DATABASE` VARCHAR(64),
  `T2W_TABLE` VARCHAR(64),
  `T2W_WRITEID` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `NEXT_WRITE_ID` (
  `NWI_DATABASE` VARCHAR(64),
  `NWI_TABLE` VARCHAR(64),
  `NWI_NEXT` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `CTLGS` (
  `CTLG_ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `DESC` VARCHAR(64),
  `LOCATION_URI` VARCHAR(64),
  PRIMARY KEY (`CTLG_ID`)
) CHARACTER SET latin1;

CREATE TABLE `REPL_TXN_MAP` (
  `RTM_REPL_POLICY` VARCHAR(64),
  `RTM_SRC_TXN_ID` DECIMAL(10,2),
  `RTM_TARGET_TXN_ID` DECIMAL(10,2),
  PRIMARY KEY (`RTM_REPL_POLICY`, `RTM_SRC_TXN_ID`)
) CHARACTER SET latin1;

CREATE TABLE `MIN_HISTORY_LEVEL` (
  `MHL_TXNID` DECIMAL(10,2),
  `MHL_MIN_OPEN_TXNID` DECIMAL(10,2),
  PRIMARY KEY (`MHL_TXNID`)
) CHARACTER SET latin1;

CREATE TABLE `RUNTIME_STATS` (
  `RS_ID` DECIMAL(10,2),
  `CREATE_TIME` DECIMAL(10,2),
  `WEIGHT` DECIMAL(10,2),
  `PAYLOAD` VARCHAR(64),
  PRIMARY KEY (`RS_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_673658_upgrade_2_3_0_to_3_0_0_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_673658_upgrade_2_3_0_to_3_0_0_oracle') AS relationships;
DROP DATABASE `db_673658_upgrade_2_3_0_to_3_0_0_oracle`;
UNINSTALL EXTENSION vsql_schematron;
