INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 665887_23
--echo #
CREATE DATABASE `db_665887_23`;
USE `db_665887_23`;

CREATE TABLE `commit_explicit_watching` (
  `id` INT,
  `project_id` INT,
  `commit_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `commit_explicit_watcher` (
  `commit_explicit_watching_id` INT,
  `n4user_id` INT,
  PRIMARY KEY (`commit_explicit_watching_id`, `n4user_id`)
) CHARACTER SET latin1;

CREATE TABLE `commit_explicit_unwatcher` (
  `commit_explicit_watching_id` INT,
  `n4user_id` INT,
  PRIMARY KEY (`commit_explicit_watching_id`, `n4user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_665887_23') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_665887_23') AS relationships;
DROP DATABASE `db_665887_23`;
UNINSTALL EXTENSION vsql_schematron;
