INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644192_db_pos
--echo #
CREATE DATABASE `db_644192_db_pos`;
USE `db_644192_db_pos`;
CREATE TABLE `karyawans` (
  `id` VARCHAR(50) NOT NULL,
  `nip` VARCHAR(50),
  `password` VARCHAR(50),
  `nama` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pakets` (
  `id` VARCHAR(50) NOT NULL,
  `tanggal_datang` DATE,
  `penghunis_id` VARCHAR(50),
  `karyawans_id` VARCHAR(50),
  `isi_paket` TEXT,
  `tanggal_ambil` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penghunis` (
  `id` VARCHAR(50) NOT NULL,
  `nama` VARCHAR(50),
  `foto` VARCHAR(50),
  `unit` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644192_db_pos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644192_db_pos') AS relationships;
DROP DATABASE `db_644192_db_pos`;
UNINSTALL EXTENSION vsql_schematron;
