INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 664975_tunes_ddl
--echo #
CREATE DATABASE `db_664975_tunes_ddl`;
USE `db_664975_tunes_ddl`;

CREATE TABLE `author` (
  `id` INT,
  `name` VARCHAR(255),
  `born_date` DATETIME,
  `gender` VARCHAR(255),
  `label` VARCHAR(255),
  `notes` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `album` (
  `id` INT,
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `publication_date` DATETIME,
  `producer` VARCHAR(255),
  `genre` VARCHAR(255),
  `duration` VARCHAR(255),
  `track_number` INT,
  `notes` VARCHAR(255),
  `author_key` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `track` (
  `id` INT,
  `name` VARCHAR(255),
  `duration` VARCHAR(255),
  `label` VARCHAR(255),
  `producer` VARCHAR(255),
  `genre` VARCHAR(255),
  `notes` VARCHAR(255),
  `album_key` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_664975_tunes_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_664975_tunes_ddl') AS relationships;
DROP DATABASE `db_664975_tunes_ddl`;
UNINSTALL EXTENSION vsql_schematron;
