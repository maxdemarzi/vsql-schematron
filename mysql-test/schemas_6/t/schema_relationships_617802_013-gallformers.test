INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617802_013-gallformers
--echo #
CREATE DATABASE `db_617802_013_gallformers`;
USE `db_617802_013_gallformers`;
CREATE TABLE `season` (
  `id` INT NOT NULL,
  `season` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gallseason` (
  `id` INT NOT NULL,
  `gall_id` INT,
  `season_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617802_013_gallformers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617802_013_gallformers') AS relationships;
DROP DATABASE `db_617802_013_gallformers`;
UNINSTALL EXTENSION vsql_schematron;
