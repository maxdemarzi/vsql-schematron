INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648346_schema
--echo #
CREATE DATABASE `db_648346_schema`;
USE `db_648346_schema`;

CREATE TABLE `BusLine` (
  `line` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`line`)
) CHARACTER SET latin1;

CREATE TABLE `BusStop` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `BusLineStop` (
  `stopId` VARCHAR(64),
  `lineId` VARCHAR(64),
  `sequenceNumber` INT,
  PRIMARY KEY (`stopId`, `lineId`, `sequenceNumber`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648346_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648346_schema') AS relationships;
DROP DATABASE `db_648346_schema`;
UNINSTALL EXTENSION vsql_schematron;
