INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 681857_shop_api
--echo #
CREATE DATABASE `db_681857_shop_api`;
USE `db_681857_shop_api`;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `payment_id` VARCHAR(255),
  `payment_status` VARCHAR(255),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_images` (
  `id` INT,
  `product_id` INT,
  `name` VARCHAR(255),
  `url` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `product_sizes` (
  `product_id` INT,
  `size_id` INT
) CHARACTER SET latin1;

CREATE TABLE `sizes` (
  `id` INT,
  `size` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `role` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_681857_shop_api') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_681857_shop_api') AS relationships;
DROP DATABASE `db_681857_shop_api`;
UNINSTALL EXTENSION vsql_schematron;
