INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641099_03%20CREATE%20TABLE%20DOCUMENTO
--echo #
CREATE DATABASE `db_641099_03_20CREATE_20TABLE_20DOCUMENTO`;
USE `db_641099_03_20CREATE_20TABLE_20DOCUMENTO`;

CREATE TABLE `DocumentoIdentidad` (
  `id` DECIMAL(10,2),
  `numeroIdentidad` DECIMAL(10,2),
  `idPersona` DECIMAL(10,2),
  `idRangoEdad` DECIMAL(10,2),
  `idTipo` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `RangoEdad` (
  `id` DECIMAL(10,2),
  `valorMin` DECIMAL(10,2),
  `valorMax` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `TipoDocumentoIdentidad` (
  `id` DECIMAL(10,2),
  `descripcion` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641099_03_20CREATE_20TABLE_20DOCUMENTO') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641099_03_20CREATE_20TABLE_20DOCUMENTO') AS relationships;
DROP DATABASE `db_641099_03_20CREATE_20TABLE_20DOCUMENTO`;
UNINSTALL EXTENSION vsql_schematron;
