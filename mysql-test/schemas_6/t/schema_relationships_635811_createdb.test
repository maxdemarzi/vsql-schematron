INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635811_createdb
--echo #
CREATE DATABASE `db_635811_createdb`;
USE `db_635811_createdb`;

CREATE TABLE `servers` (
  `sid` INT,
  `description` VARCHAR(64),
  `game` VARCHAR(64),
  `moniker` VARCHAR(64),
  `startfile` VARCHAR(64),
  `stopcommand` VARCHAR(64),
  `warncommand` VARCHAR(64),
  `port` INT,
  `autostart` INT,
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;

CREATE TABLE `eventType` (
  `etid` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`etid`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `eid` INT,
  `sid` INT,
  `time` DATETIME,
  `etype` INT,
  `args` VARCHAR(64),
  PRIMARY KEY (`eid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635811_createdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635811_createdb') AS relationships;
DROP DATABASE `db_635811_createdb`;
UNINSTALL EXTENSION vsql_schematron;
