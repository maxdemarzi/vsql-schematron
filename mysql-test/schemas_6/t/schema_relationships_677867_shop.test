INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 677867_shop
--echo #
CREATE DATABASE `db_677867_shop`;
USE `db_677867_shop`;

CREATE TABLE `categories` (
  `cat_id` INT,
  `cat_name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `user_name` VARCHAR(255),
  `salt` VARCHAR(255),
  `digest` VARCHAR(255),
  `totalPrice` DECIMAL(10,2),
  `transactionId` VARCHAR(255),
  `p_id` VARCHAR(255),
  `quantity` VARCHAR(255),
  `payment_status` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `payment_id` INT,
  `txn_id` VARCHAR(255),
  `digest` VARCHAR(255),
  `p_id` VARCHAR(255),
  `quantity` VARCHAR(255),
  `payment_amount` DECIMAL(10,2),
  `payment_status` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `p_id` INT,
  `p_name` VARCHAR(255),
  `cat_id` INT,
  `p_price` DECIMAL(10,2),
  `p_description` VARCHAR(255),
  `p_image` VARCHAR(255),
  `p_keyword` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` INT,
  `user_email` VARCHAR(255),
  `user_name` VARCHAR(255),
  `user_password` VARCHAR(255),
  `salt` VARCHAR(255),
  `adminFlag` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_677867_shop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_677867_shop') AS relationships;
DROP DATABASE `db_677867_shop`;
UNINSTALL EXTENSION vsql_schematron;
