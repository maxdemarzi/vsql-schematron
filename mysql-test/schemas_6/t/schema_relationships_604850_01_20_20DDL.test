INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 604850_01%20-%20DDL
--echo #
CREATE DATABASE `db_604850_01_20_20DDL`;
USE `db_604850_01_20_20DDL`;

CREATE TABLE `Users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Repositories` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Repositories_Contributors` (
  `repository_id` INT,
  `contributor_id` INT
) CHARACTER SET latin1;

CREATE TABLE `Issues` (
  `id` INT,
  `title` VARCHAR(64),
  `issue_status` VARCHAR(64),
  `repository_id` INT,
  `assignee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Commits` (
  `id` INT,
  `message` VARCHAR(64),
  `issue_id` INT,
  `repository_id` INT,
  `contributor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_604850_01_20_20DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_604850_01_20_20DDL') AS relationships;
DROP DATABASE `db_604850_01_20_20DDL`;
UNINSTALL EXTENSION vsql_schematron;
