INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 619994_ersSchema
--echo #
CREATE DATABASE `db_619994_ersSchema`;
USE `db_619994_ersSchema`;

CREATE TABLE `ReimbursementRequest` (
  `id` INT,
  `employeeId` INT,
  `image` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `description` VARCHAR(64),
  `resolver` INT,
  `hasImage` BOOL,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `accountType` INT,
  `managerId` INT,
  `isManager` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_619994_ersSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_619994_ersSchema') AS relationships;
DROP DATABASE `db_619994_ersSchema`;
UNINSTALL EXTENSION vsql_schematron;
