CREATE DATABASE `db_661854_V4_46__create_email_message_tables`;
USE `db_661854_V4_46__create_email_message_tables`;
CREATE TABLE `ptcore.email_message_type` (
  `id` BIGINT NOT NULL,
  `created` TIMESTAMP NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptcore.email_message_template` (
  `id` BIGINT NOT NULL,
  `email_message_type_id` BIGINT,
  `created` TIMESTAMP NULL,
  `d_email_subject` VARCHAR(50),
  `d_email_text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
