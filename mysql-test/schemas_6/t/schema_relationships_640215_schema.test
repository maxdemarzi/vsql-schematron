INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 640215_schema
--echo #
CREATE DATABASE `db_640215_schema`;
USE `db_640215_schema`;
CREATE TABLE `menu` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `category` VARCHAR(50),
  `short_description` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dish` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `prep_time` VARCHAR(50),
  `total_time` VARCHAR(50),
  `servings` INT,
  `yield` INT,
  `menu_fk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredient` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `quantity` INT,
  `measurment_unit` VARCHAR(50),
  `measurment_descriptor` VARCHAR(50),
  `dish_fk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `directions` (
  `id` INT NOT NULL,
  `order_number` INT,
  `description` VARCHAR(50),
  `dish_fk_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_640215_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_640215_schema') AS relationships;
DROP DATABASE `db_640215_schema`;
UNINSTALL EXTENSION vsql_schematron;
