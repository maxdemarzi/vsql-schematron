INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 686188_016-gallformers
--echo #
CREATE DATABASE `db_686188_016_gallformers`;
USE `db_686188_016_gallformers`;

CREATE TABLE `galltexture__` (
  `gall_id` INT,
  `texture_id` INT,
  PRIMARY KEY (`gall_id`, `texture_id`)
) CHARACTER SET latin1;

CREATE TABLE `galllocation__` (
  `gall_id` INT,
  `location_id` INT,
  PRIMARY KEY (`gall_id`, `location_id`)
) CHARACTER SET latin1;

CREATE TABLE `form` (
  `id` INT,
  `form` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gallform` (
  `gall_id` INT,
  `form_id` INT,
  PRIMARY KEY (`gall_id`, `form_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_686188_016_gallformers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_686188_016_gallformers') AS relationships;
DROP DATABASE `db_686188_016_gallformers`;
UNINSTALL EXTENSION vsql_schematron;
