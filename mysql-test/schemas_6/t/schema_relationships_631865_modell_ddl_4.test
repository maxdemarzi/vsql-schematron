INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 631865_modell_ddl_4
--echo #
CREATE DATABASE `db_631865_modell_ddl_4`;
USE `db_631865_modell_ddl_4`;

CREATE TABLE `Doctors` (
  `DoctorID` INT,
  `First_Name` VARCHAR(64),
  `Last_Name` VARCHAR(64),
  `CenterID` INT,
  `Employed_Since` DATETIME,
  PRIMARY KEY (`DoctorID`)
) CHARACTER SET latin1;

CREATE TABLE `Patients` (
  `PatientID` INT,
  `First_Name` VARCHAR(64),
  `Last_Name` VARCHAR(64),
  `Member_Since` DATETIME,
  PRIMARY KEY (`PatientID`)
) CHARACTER SET latin1;

CREATE TABLE `Visits` (
  `VisitID` INT,
  `Doctor` INT,
  `Patient` INT,
  `Diagnosis` INT,
  `Date` DATETIME,
  PRIMARY KEY (`VisitID`)
) CHARACTER SET latin1;

CREATE TABLE `Diseases` (
  `DiseaseID` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`DiseaseID`)
) CHARACTER SET latin1;

CREATE TABLE `Diagnoses` (
  `DiagnosisID` INT,
  `Instructions` VARCHAR(64),
  `Disease` INT,
  `Visit` INT,
  PRIMARY KEY (`DiagnosisID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_631865_modell_ddl_4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_631865_modell_ddl_4') AS relationships;
DROP DATABASE `db_631865_modell_ddl_4`;
UNINSTALL EXTENSION vsql_schematron;
