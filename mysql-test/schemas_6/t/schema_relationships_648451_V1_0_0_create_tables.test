INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648451_V1_0_0_create_tables
--echo #
CREATE DATABASE `db_648451_V1_0_0_create_tables`;
USE `db_648451_V1_0_0_create_tables`;

CREATE TABLE `movie` (
  `id` INT,
  `title` VARCHAR(255),
  `imdb_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `role` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `id` INT,
  `type` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_room` (
  `movie_id` INT,
  `room_id` INT,
  `price` DECIMAL(10,2),
  `time` VARCHAR(255),
  PRIMARY KEY (`movie_id`, `room_id`)
) CHARACTER SET latin1;

CREATE TABLE `review` (
  `id` INT,
  `rate` DECIMAL(10,2),
  `comment` VARCHAR(255),
  `movie_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reservation` (
  `id` INT,
  `ticket_number` INT,
  `user_id` INT,
  `movie_id` INT,
  `room_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648451_V1_0_0_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648451_V1_0_0_create_tables') AS relationships;
DROP DATABASE `db_648451_V1_0_0_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
