INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 695757_1_exchange_bot_schema
--echo #
CREATE DATABASE `db_695757_1_exchange_bot_schema`;
USE `db_695757_1_exchange_bot_schema`;
CREATE TABLE `exchange_bot.sources` (
  `id` INT NOT NULL,
  `issuer_id` INT,
  `url` VARCHAR(50),
  `spider_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exchange_bot.content_sent` (
  `user_id` INT,
  `content_id` INT
) CHARACTER SET latin1;
CREATE TABLE `exchange_bot.currencies` (
  `id` INT NOT NULL,
  `short_name` VARCHAR(50),
  `full_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exchange_bot.deals` (
  `id` INT NOT NULL,
  `user_id` INT,
  `datetime_open` DATETIME,
  `broker_id` INT,
  `issuer_id` INT,
  `direction_long` TINYINT,
  `price_open` DECIMAL(10,2),
  `price_close` DECIMAL(10,2),
  `risk_value` DECIMAL(10,2),
  `comment_open` VARCHAR(50),
  `comment_close` VARCHAR(50),
  `currency_id` INT,
  `datetime_close` DATETIME,
  `quantity` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_695757_1_exchange_bot_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_695757_1_exchange_bot_schema') AS relationships;
DROP DATABASE `db_695757_1_exchange_bot_schema`;
UNINSTALL EXTENSION vsql_schematron;
