INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635330_script
--echo #
CREATE DATABASE `db_635330_script`;
USE `db_635330_script`;

CREATE TABLE `aula` (
  `id_aula` INT,
  `nome_aula` VARCHAR(64),
  `desc_aula` VARCHAR(64),
  `inicio_aula` DATETIME,
  `termino_aula` DATETIME,
  `carga_horaria` INT,
  PRIMARY KEY (`id_aula`)
) CHARACTER SET latin1;

CREATE TABLE `aula_ocorrencia` (
  `id_ocorrencia` INT,
  `id_aula` INT,
  `inicio_ocorrencia` DATETIME,
  PRIMARY KEY (`id_ocorrencia`)
) CHARACTER SET latin1;

CREATE TABLE `sala` (
  `id_sala` INT,
  `desc_sala` VARCHAR(64),
  `andar_sala` INT,
  PRIMARY KEY (`id_sala`)
) CHARACTER SET latin1;

CREATE TABLE `aula_sala` (
  `id_aula` INT,
  `id_sala` INT,
  PRIMARY KEY (`id_aula`, `id_sala`)
) CHARACTER SET latin1;

CREATE TABLE `professor` (
  `id_prof` INT,
  `nome_prof` VARCHAR(64),
  PRIMARY KEY (`id_prof`)
) CHARACTER SET latin1;

CREATE TABLE `aula_prof` (
  `id_prof` INT,
  `id_aula` INT,
  PRIMARY KEY (`id_prof`, `id_aula`)
) CHARACTER SET latin1;

CREATE TABLE `turma` (
  `id_turma` INT,
  `desc_turma` VARCHAR(64),
  PRIMARY KEY (`id_turma`)
) CHARACTER SET latin1;

CREATE TABLE `aula_turma` (
  `id_aula` INT,
  `id_turma` INT,
  PRIMARY KEY (`id_aula`, `id_turma`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635330_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635330_script') AS relationships;
DROP DATABASE `db_635330_script`;
UNINSTALL EXTENSION vsql_schematron;
