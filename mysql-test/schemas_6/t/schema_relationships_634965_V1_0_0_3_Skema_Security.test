INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 634965_V1.0.0.3__Skema_Security
--echo #
CREATE DATABASE `db_634965_V1_0_0_3_Skema_Security`;
USE `db_634965_V1_0_0_3_Skema_Security`;

CREATE TABLE `s_user` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `enabled` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `s_group` (
  `id` VARCHAR(64),
  `nama` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `s_permission` (
  `id` VARCHAR(64),
  `nama` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `s_user_group` (
  `id_user` VARCHAR(64),
  `id_group` VARCHAR(64),
  PRIMARY KEY (`id_user`, `id_group`)
) CHARACTER SET latin1;

CREATE TABLE `s_group_permission` (
  `id_group` VARCHAR(64),
  `id_permission` VARCHAR(64),
  PRIMARY KEY (`id_group`, `id_permission`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_634965_V1_0_0_3_Skema_Security') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_634965_V1_0_0_3_Skema_Security') AS relationships;
DROP DATABASE `db_634965_V1_0_0_3_Skema_Security`;
UNINSTALL EXTENSION vsql_schematron;
