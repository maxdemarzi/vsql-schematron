INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 664363_schema
--echo #
CREATE DATABASE `db_664363_schema`;
USE `db_664363_schema`;
CREATE TABLE `projects` (
  `id` VARCHAR(50) NOT NULL,
  `github_id` INT,
  `name` VARCHAR(50),
  `full_name` VARCHAR(50),
  `description` TEXT,
  `language` VARCHAR(50),
  `git_url` VARCHAR(50),
  `watcher_count` INT,
  `stars_count` INT,
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` VARCHAR(50) NOT NULL,
  `github_id` INT,
  `project_id` VARCHAR(50),
  `number` INT,
  `title` VARCHAR(50),
  `body` VARCHAR(50),
  `user` VARCHAR(50),
  `state` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` VARCHAR(50) NOT NULL,
  `github_id` INT,
  `issue_id` VARCHAR(50),
  `body` TEXT,
  `user` VARCHAR(50),
  `created_at` VARCHAR(50),
  `updated_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_664363_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_664363_schema') AS relationships;
DROP DATABASE `db_664363_schema`;
UNINSTALL EXTENSION vsql_schematron;
