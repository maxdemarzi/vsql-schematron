INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608319_swamda-sg
--echo #
CREATE DATABASE `db_608319_swamda_sg`;
USE `db_608319_swamda_sg`;

CREATE TABLE `calendar_data` (
  `id` INT,
  `title` VARCHAR(64),
  `start` DATETIME,
  `end` DATETIME,
  `start_time` DATETIME,
  `end_time` DATETIME,
  `url` VARCHAR(64),
  `auth` INT,
  `auth_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `rol` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `realname` VARCHAR(64),
  `realsurname` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `auth_date` DATETIME,
  `rol` INT,
  `color` VARCHAR(64),
  `flag_activo` INT
) CHARACTER SET latin1;

CREATE TABLE `userlogin` (
  `id` INT,
  `id_user` INT,
  `date_login` DATETIME,
  `time_login` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608319_swamda_sg') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608319_swamda_sg') AS relationships;
DROP DATABASE `db_608319_swamda_sg`;
UNINSTALL EXTENSION vsql_schematron;
