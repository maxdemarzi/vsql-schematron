  `title` VARCHAR(64),
  `excerpt` VARCHAR(64),
  `body` VARCHAR(64),
  `image` VARCHAR(64),
  `slug` VARCHAR(64),
  `meta_description` VARCHAR(64),
  `meta_keywords` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
