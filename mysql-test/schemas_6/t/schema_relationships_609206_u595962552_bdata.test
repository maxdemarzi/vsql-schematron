  `excerpt` VARCHAR(64),
  `body` VARCHAR(64),
  `image` VARCHAR(64),
  `slug` VARCHAR(64),
  `meta_description` VARCHAR(64),
  `meta_keywords` VARCHAR(64),
  `status` VARCHAR(64),
  `featured` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `rows` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
