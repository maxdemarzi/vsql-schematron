CREATE DATABASE `db_609206_u595962552_bdata`;
USE `db_609206_u595962552_bdata`;

CREATE TABLE `categories` (
  `id` INT,
  `parent_id` INT,
  `order` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `columns` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `column_details` (
  `id` INT,
  `name` VARCHAR(64),
  `column_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `data` (
  `id` INT,
  `template_id` INT,
  `row_id` INT,
  `row_detail_id` INT,
  `column_id` INT,
  `column_detail_id` INT,
  `value` DECIMAL(10,2),
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `data_rows` (
  `id` INT,
  `data_type_id` INT,
  `field` VARCHAR(64),
  `type` VARCHAR(64),
  `display_name` VARCHAR(64),
  `required` INT,
  `browse` INT,
  `read` INT,
  `edit` INT,
