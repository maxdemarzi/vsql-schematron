  `slug` VARCHAR(64),
  `display_name_singular` VARCHAR(64),
  `display_name_plural` VARCHAR(64),
  `icon` VARCHAR(64),
  `model_name` VARCHAR(64),
  `policy_name` VARCHAR(64),
  `controller` VARCHAR(64),
  `description` VARCHAR(64),
  `generate_permissions` INT,
  `server_side` INT,
  `details` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `menu_items` (
  `id` INT,
