INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635290_realestate
--echo #
CREATE DATABASE `db_635290_realestate`;
USE `db_635290_realestate`;

CREATE TABLE `agents` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `location` VARCHAR(64),
  `contact` VARCHAR(64),
  `commission` INT,
  `salary` INT,
  `hireDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart` (
  `id` INT,
  `email` VARCHAR(64),
  `prodId` INT
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `prodId` INT,
  `email` VARCHAR(64),
  `comment` VARCHAR(64),
  `time` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `type` VARCHAR(64),
  `description` VARCHAR(64),
  `location` VARCHAR(64),
  `images` VARCHAR(64),
  `buy` INT,
  `rent` INT,
  `down` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635290_realestate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635290_realestate') AS relationships;
DROP DATABASE `db_635290_realestate`;
UNINSTALL EXTENSION vsql_schematron;
