INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655884_script
--echo #
CREATE DATABASE `db_655884_script`;
USE `db_655884_script`;
CREATE TABLE `autor` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `editora` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `livro` (
  `id` INT NOT NULL,
  `isbn` VARCHAR(50),
  `titulo` VARCHAR(50),
  `genero` VARCHAR(50),
  `sinopse` VARCHAR(50),
  `idAutor` INT,
  `idEditora` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655884_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655884_script') AS relationships;
DROP DATABASE `db_655884_script`;
UNINSTALL EXTENSION vsql_schematron;
