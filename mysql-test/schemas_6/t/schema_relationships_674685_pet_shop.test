INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 674685_pet_shop
--echo #
CREATE DATABASE `db_674685_pet_shop`;
USE `db_674685_pet_shop`;
CREATE TABLE `category_tab_p` (
  `category_id_p` INT NOT NULL,
  `category_name_p` VARCHAR(50),
  PRIMARY KEY (`category_id_p`)
) CHARACTER SET latin1;
CREATE TABLE `contact` (
  `nom` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `company` VARCHAR(50),
  `message` TEXT
) CHARACTER SET latin1;
CREATE TABLE `pet_tab` (
  `id_p` INT NOT NULL,
  `description_p` VARCHAR(50),
  `category_id_p` INT,
  `imgs_p` VARCHAR(50),
  `status_p` VARCHAR(50),
  `price` DOUBLE,
  `name_p` VARCHAR(50),
  PRIMARY KEY (`id_p`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_674685_pet_shop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_674685_pet_shop') AS relationships;
DROP DATABASE `db_674685_pet_shop`;
UNINSTALL EXTENSION vsql_schematron;
