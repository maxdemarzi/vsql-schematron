INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 685490_accsys_data_db
--echo #
CREATE DATABASE `db_685490_accsys_data_db`;
USE `db_685490_accsys_data_db`;

CREATE TABLE `employee` (
  `employee_id` INT,
  `user_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email` VARCHAR(255),
  `phone_No` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `manager` (
  `manager_id` INT,
  `user_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email` VARCHAR(255),
  `phone_No` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `printer` (
  `printer_id` INT,
  `printer_model` VARCHAR(255),
  `printer_brand` VARCHAR(255),
  `quantity` INT,
  PRIMARY KEY (`printer_id`)
) CHARACTER SET latin1;

CREATE TABLE `rma` (
  `rma_id` INT,
  `printer_id` INT,
  `toner_id` INT,
  `date` VARCHAR(255),
  `rma_reason` VARCHAR(255),
  `rma_quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `stock_history` (
  `stock_history_id` INT,
  `user_id` INT,
  `printer_id` INT,
  `toner_id` INT,
  `worker_name` VARCHAR(255),
  `date` VARCHAR(255),
  `type_of_change` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `toner` (
  `toner_id` INT,
  `toner_model` VARCHAR(255),
  `toner_brand` VARCHAR(255),
  `quantity` INT,
  PRIMARY KEY (`toner_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `username` VARCHAR(255),
  `password_hash` VARCHAR(255),
  `user_role` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_685490_accsys_data_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_685490_accsys_data_db') AS relationships;
DROP DATABASE `db_685490_accsys_data_db`;
UNINSTALL EXTENSION vsql_schematron;
