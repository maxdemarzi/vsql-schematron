INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 600880_schema
--echo #
CREATE DATABASE `db_600880_schema`;
USE `db_600880_schema`;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `roomname` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`roomname`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `username` CHAR(50),
  `message` TEXT,
  `roomname` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_600880_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_600880_schema') AS relationships;
DROP DATABASE `db_600880_schema`;
UNINSTALL EXTENSION vsql_schematron;
