INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636948_schema
--echo #
CREATE DATABASE `db_636948_schema`;
USE `db_636948_schema`;
CREATE TABLE `Units` (
  `uid` INT,
  `Name` TEXT,
  `Position` INT
) CHARACTER SET latin1;
CREATE TABLE `Aisles` (
  `uid` INT,
  `Name` TEXT,
  `Color` TEXT,
  `Icon` TEXT,
  `Position` INT
) CHARACTER SET latin1;
CREATE TABLE `Products` (
  `uid` INT,
  `Name` TEXT,
  `Note` TEXT,
  `LastUsed` TIMESTAMP NULL,
  `AisleID` INT,
  `UnitID` INT
) CHARACTER SET latin1;
CREATE TABLE `Lists` (
  `uid` INT,
  `Name` TEXT,
  `Position` INT
) CHARACTER SET latin1;
CREATE TABLE `ProductsLists` (
  `Position` INT,
  `ListID` INT,
  `ProductID` INT,
  `Purchased` INT
) CHARACTER SET latin1;
CREATE TABLE `InternalInformation` (
  `Version` TIMESTAMP NULL,
  `CreatedDate` TIMESTAMP NULL
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636948_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636948_schema') AS relationships;
DROP DATABASE `db_636948_schema`;
UNINSTALL EXTENSION vsql_schematron;
