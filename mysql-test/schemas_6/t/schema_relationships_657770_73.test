INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 657770_73
--echo #
CREATE DATABASE `db_657770_73`;
USE `db_657770_73`;
CREATE TABLE `organization` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `descr` VARCHAR(50),
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organization_user` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `organization_id` BIGINT,
  `role_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_657770_73') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_657770_73') AS relationships;
DROP DATABASE `db_657770_73`;
UNINSTALL EXTENSION vsql_schematron;
