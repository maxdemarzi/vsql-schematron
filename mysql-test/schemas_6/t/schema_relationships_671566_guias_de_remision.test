INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 671566_guias_de_remision
--echo #
CREATE DATABASE `db_671566_guias_de_remision`;
USE `db_671566_guias_de_remision`;
CREATE TABLE `departamentos` (
  `Cod_Departamento` VARCHAR(50) NOT NULL,
  `Nombre_Depto` VARCHAR(50),
  `Sucursal` VARCHAR(50),
  `Fecha_Ingreso` TIMESTAMP NULL,
  `Fecha_Actualizacion` TIMESTAMP NULL,
  PRIMARY KEY (`Cod_Departamento`)
) CHARACTER SET latin1;
CREATE TABLE `productos` (
  `Cod_Producto` VARCHAR(50) NOT NULL,
  `Nombre_Producto` VARCHAR(50),
  `Descripcion` VARCHAR(50),
  `Fecha_Ingreso` TIMESTAMP NULL,
  `Fecha_Actualizacion` TIMESTAMP NULL,
  PRIMARY KEY (`Cod_Producto`)
) CHARACTER SET latin1;
CREATE TABLE `sucursales` (
  `Cod_Sucursal` VARCHAR(50) NOT NULL,
  `Nombre_Sucursal` VARCHAR(50),
  `RTN` VARCHAR(50),
  `Direccion` VARCHAR(50),
  `Telefono` VARCHAR(50),
  `Correo` VARCHAR(50),
  `Fecha_Ingreso` TIMESTAMP NULL,
  `Fecha_Actualizacion` TIMESTAMP NULL,
  PRIMARY KEY (`Cod_Sucursal`)
) CHARACTER SET latin1;
CREATE TABLE `unidades_de_transporte` (
  `Cod_Unidad` VARCHAR(50) NOT NULL,
  `Marca_Vehiculo` VARCHAR(50),
  `Placa_Vehiculo` VARCHAR(50),
  `Modelo_Vehiculo` VARCHAR(50),
  `Estado` VARCHAR(50),
  `Fecha_Ingreso` TIMESTAMP NULL,
  `Fecha_Actualizacion` TIMESTAMP NULL,
  PRIMARY KEY (`Cod_Unidad`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_671566_guias_de_remision') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_671566_guias_de_remision') AS relationships;
DROP DATABASE `db_671566_guias_de_remision`;
UNINSTALL EXTENSION vsql_schematron;
