INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 676158_CinemaTickets
--echo #
CREATE DATABASE `db_676158_CinemaTickets`;
USE `db_676158_CinemaTickets`;

CREATE TABLE `ALLOCATABLE_CINEMA_SECTION` (
  `CINEMA_ID` INT,
  `SECTION_NAME` VARCHAR(64),
  PRIMARY KEY (`CINEMA_ID`, `SECTION_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `PLACES_PAID` (
  `BOOKING_NR` INT,
  `PAYMENT_METHOD_CODE` VARCHAR(64),
  `NUMBER` INT,
  PRIMARY KEY (`BOOKING_NR`, `PAYMENT_METHOD_CODE`)
) CHARACTER SET latin1;

CREATE TABLE `SEAT` (
  `ROW_CINEMA_ID` INT,
  `ROW_NR` VARCHAR(64),
  `SEAT_NUMBER` INT,
  `SECTION_NAME` VARCHAR(64),
  PRIMARY KEY (`ROW_CINEMA_ID`, `ROW_NR`, `SEAT_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `SEAT_ALLOCATION` (
  `BOOKING_NR` INT,
  `ALLOCATED_SEAT_ROW_CINEMA_ID` INT,
  `ALLOCATED_SEAT_ROW_NR` VARCHAR(64),
  `ALLOCATED_SEAT_NUMBER` INT,
  PRIMARY KEY (`BOOKING_NR`, `ALLOCATED_SEAT_ROW_CINEMA_ID`, `ALLOCATED_SEAT_ROW_NR`, `ALLOCATED_SEAT_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `SESSION` (
  `CINEMA_ID` INT,
  `SESSION_TIME_YEAR_NR` INT,
  `SESSION_TIME_MONTH_NR` INT,
  `SESSION_TIME_DAY` INT,
  `SESSION_TIME_HOUR` INT,
  `SESSION_TIME_MINUTE` INT,
  `IS_HIGH_DEMAND` VARCHAR(64),
  `USES_ALLOCATED_SEATING` VARCHAR(64),
  `FILM_ID` INT,
  PRIMARY KEY (`CINEMA_ID`, `SESSION_TIME_YEAR_NR`, `SESSION_TIME_MONTH_NR`, `SESSION_TIME_DAY`, `SESSION_TIME_HOUR`, `SESSION_TIME_MINUTE`)
) CHARACTER SET latin1;

CREATE TABLE `TICKET_PRICING` (
  `SESSION_TIME_YEAR_NR` INT,
  `SESSION_TIME_MONTH_NR` INT,
  `SESSION_TIME_DAY` INT,
  `SESSION_TIME_HOUR` INT,
  `SESSION_TIME_MINUTE` INT,
  `CINEMA_ID` INT,
  `SECTION_NAME` VARCHAR(64),
  `HIGH_DEMAND` VARCHAR(64),
  `PRICE` VARCHAR(64),
  PRIMARY KEY (`SESSION_TIME_YEAR_NR`, `SESSION_TIME_MONTH_NR`, `SESSION_TIME_DAY`, `SESSION_TIME_HOUR`, `SESSION_TIME_MINUTE`, `CINEMA_ID`, `SECTION_NAME`, `HIGH_DEMAND`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_676158_CinemaTickets') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_676158_CinemaTickets') AS relationships;
DROP DATABASE `db_676158_CinemaTickets`;
UNINSTALL EXTENSION vsql_schematron;
