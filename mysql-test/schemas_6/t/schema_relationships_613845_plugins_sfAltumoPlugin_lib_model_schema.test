INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 613845_plugins.sfAltumoPlugin.lib.model.schema
--echo #
CREATE DATABASE `db_613845_plugins_sfAltumoPlugin_lib_model_schema`;
USE `db_613845_plugins_sfAltumoPlugin_lib_model_schema`;
CREATE TABLE `system_event_subscription` (
  `id` INT NOT NULL,
  `system_event_id` INT,
  `remote_url` VARCHAR(50),
  `enabled` TINYINT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `system_event_instance` (
  `id` INT NOT NULL,
  `system_event_id` INT,
  `message` TEXT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `system_event_instance_message` (
  `id` INT NOT NULL,
  `system_event_instance_id` INT,
  `system_event_subscription_id` INT,
  `received` TINYINT,
  `received_at` DATETIME,
  `status_message` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_613845_plugins_sfAltumoPlugin_lib_model_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_613845_plugins_sfAltumoPlugin_lib_model_schema') AS relationships;
DROP DATABASE `db_613845_plugins_sfAltumoPlugin_lib_model_schema`;
UNINSTALL EXTENSION vsql_schematron;
