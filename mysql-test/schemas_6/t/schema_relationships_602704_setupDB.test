INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 602704_setupDB
--echo #
CREATE DATABASE `db_602704_setupDB`;
USE `db_602704_setupDB`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `user_password` VARCHAR(50),
  `user_admin` BOOLEAN,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `card_templates` (
  `card_template_id` INT NOT NULL,
  `user_id` INT,
  `card_template_description` VARCHAR(50),
  `card_front_template` TEXT,
  `card_back_template` TEXT,
  PRIMARY KEY (`card_template_id`)
) CHARACTER SET latin1;
CREATE TABLE `cards` (
  `card_id` INT NOT NULL,
  `card_template_id` INT,
  `card_data` TEXT,
  PRIMARY KEY (`card_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_602704_setupDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_602704_setupDB') AS relationships;
DROP DATABASE `db_602704_setupDB`;
UNINSTALL EXTENSION vsql_schematron;
