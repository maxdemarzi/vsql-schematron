INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 678182_panjar_biaya
--echo #
CREATE DATABASE `db_678182_panjar_biaya`;
USE `db_678182_panjar_biaya`;
CREATE TABLE `kecamatan` (
  `id` INT NOT NULL,
  `kecamatan` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `perkara` (
  `id` INT NOT NULL,
  `perkara` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `radius` (
  `id` INT,
  `kecamatan` INT,
  `kelurahan` VARCHAR(50),
  `biaya` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_678182_panjar_biaya') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_678182_panjar_biaya') AS relationships;
DROP DATABASE `db_678182_panjar_biaya`;
UNINSTALL EXTENSION vsql_schematron;
