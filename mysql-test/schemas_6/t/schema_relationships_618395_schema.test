INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 618395_schema
--echo #
CREATE DATABASE `db_618395_schema`;
USE `db_618395_schema`;
CREATE TABLE `application_user` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `email_address` (
  `id` BIGINT NOT NULL,
  `address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_email` (
  `user_id` BIGINT NOT NULL,
  `email_id` BIGINT NOT NULL,
  `created_at` DATETIME,
  PRIMARY KEY (`user_id`, `email_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_618395_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_618395_schema') AS relationships;
DROP DATABASE `db_618395_schema`;
UNINSTALL EXTENSION vsql_schematron;
