INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644536_001-initial-schema
--echo #
CREATE DATABASE `db_644536_001_initial_schema`;
USE `db_644536_001_initial_schema`;
CREATE TABLE `Sensor` (
  `name` VARCHAR(50) NOT NULL,
  `firstonline` TEXT,
  `lastonline` TEXT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `Reading` (
  `id` INT NOT NULL,
  `sensorname` TEXT,
  `temperature` DECIMAL(10,2),
  `pressure` DECIMAL(10,2),
  `humidity` DECIMAL(10,2),
  `timestamp` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644536_001_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644536_001_initial_schema') AS relationships;
DROP DATABASE `db_644536_001_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
