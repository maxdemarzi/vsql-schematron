INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 632504_db_setup
--echo #
CREATE DATABASE `db_632504_db_setup`;
USE `db_632504_db_setup`;
CREATE TABLE `users` (
  `user_email` VARCHAR(50) NOT NULL,
  `user_key` VARCHAR(50),
  `name` VARCHAR(50),
  `salt` VARCHAR(50),
  `admin` VARCHAR(50),
  PRIMARY KEY (`user_email`)
) CHARACTER SET latin1;
CREATE TABLE `eval` (
  `eval_id` INT NOT NULL,
  `eval_name` VARCHAR(50),
  `date_of_eval` DATE,
  `description` VARCHAR(50),
  `max_marks` INT,
  PRIMARY KEY (`eval_id`)
) CHARACTER SET latin1;
CREATE TABLE `marks` (
  `record_number` INT NOT NULL,
  `user_email` VARCHAR(50),
  `eval_id` INT,
  `score` INT,
  `verified` VARCHAR(50),
  PRIMARY KEY (`record_number`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_632504_db_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_632504_db_setup') AS relationships;
DROP DATABASE `db_632504_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
