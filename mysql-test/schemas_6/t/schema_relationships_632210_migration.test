INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 632210_migration
--echo #
CREATE DATABASE `db_632210_migration`;
USE `db_632210_migration`;

CREATE TABLE `User` (
  `id` INT,
  `email` VARCHAR(64),
  `hashedPassword` VARCHAR(64),
  `salt` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Vault` (
  `id` INT,
  `vaultname` VARCHAR(64),
  `vaultusername` VARCHAR(64),
  `vaultpassword` VARCHAR(64),
  `userEmailId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_632210_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_632210_migration') AS relationships;
DROP DATABASE `db_632210_migration`;
UNINSTALL EXTENSION vsql_schematron;
