INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 676710_database-export
--echo #
CREATE DATABASE `db_676710_database_export`;
USE `db_676710_database_export`;
CREATE TABLE `computer` (
  `systemid` INT NOT NULL,
  `devicename` VARCHAR(50),
  `manufacture` VARCHAR(50),
  `model` VARCHAR(50),
  `processor` VARCHAR(50),
  `ram` VARCHAR(50),
  `drive` VARCHAR(50),
  `location` VARCHAR(50),
  `description` VARCHAR(50),
  `gst` VARCHAR(50),
  `price` VARCHAR(50),
  `warranty` VARCHAR(50),
  PRIMARY KEY (`systemid`)
) CHARACTER SET latin1;
CREATE TABLE `keyboard` (
  `id` INT NOT NULL,
  `manufacture` VARCHAR(50),
  `model` VARCHAR(50),
  `type` VARCHAR(50),
  `location` VARCHAR(50),
  `description` VARCHAR(50),
  `gst` VARCHAR(50),
  `price` VARCHAR(50),
  `warranty` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `monitor` (
  `id` INT NOT NULL,
  `manufacture` VARCHAR(50),
  `model` VARCHAR(50),
  `type` VARCHAR(50),
  `location` VARCHAR(50),
  `description` VARCHAR(50),
  `gst` VARCHAR(50),
  `price` VARCHAR(50),
  `warranty` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mouse` (
  `id` INT NOT NULL,
  `manufacture` VARCHAR(50),
  `model` VARCHAR(50),
  `type` VARCHAR(50),
  `location` VARCHAR(50),
  `description` VARCHAR(50),
  `gst` VARCHAR(50),
  `price` VARCHAR(50),
  `warranty` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `printer` (
  `id` INT NOT NULL,
  `manufacture` VARCHAR(50),
  `model` VARCHAR(50),
  `type` VARCHAR(50),
  `location` VARCHAR(50),
  `description` VARCHAR(50),
  `gst` VARCHAR(50),
  `price` VARCHAR(50),
  `warranty` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `report` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `itemid` INT,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `software` (
  `id` INT,
  `name` VARCHAR(50),
  `version` VARCHAR(50),
  `systemid` INT,
  `installdate` DATE,
  `type` VARCHAR(50),
  `description` VARCHAR(50),
  `price` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `type` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_676710_database_export') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_676710_database_export') AS relationships;
DROP DATABASE `db_676710_database_export`;
UNINSTALL EXTENSION vsql_schematron;
