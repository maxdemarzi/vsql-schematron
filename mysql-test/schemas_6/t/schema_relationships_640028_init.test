INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 640028_init
--echo #
CREATE DATABASE `db_640028_init`;
USE `db_640028_init`;
CREATE TABLE `wedding.app_users` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `enabled` BOOLEAN,
  `user_password` VARCHAR(50),
  `security_key` VARCHAR(50),
  `is_super_user` BOOLEAN,
  `last_login_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wedding.configuration` (
  `fiance_name` VARCHAR(50),
  `fiancee_name` VARCHAR(50),
  `event_timezone` VARCHAR(50),
  `wedding_ceremony_date` TIMESTAMP NULL,
  `wedding_reception_date` TIMESTAMP NULL,
  `enabled` BOOLEAN
) CHARACTER SET latin1;
CREATE TABLE `wedding.extra_information` (
  `id` INT NOT NULL,
  `key` VARCHAR(50),
  `value` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wedding.guests` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `cell_phone` VARCHAR(50),
  `parent_id` INT,
  `identifier` VARCHAR(50),
  `relation` INT,
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_640028_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_640028_init') AS relationships;
DROP DATABASE `db_640028_init`;
UNINSTALL EXTENSION vsql_schematron;
