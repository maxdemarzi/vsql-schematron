INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626893_database
--echo #
CREATE DATABASE `db_626893_database`;
USE `db_626893_database`;

CREATE TABLE `roles` (
  `id` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `modules` (
  `id` INT,
  `module` VARCHAR(64),
  `url` VARCHAR(64),
  `base_url` BOOL,
  `parent` INT,
  `is_parent` BOOL,
  `other` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `module_role` (
  `id` INT,
  `module_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626893_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626893_database') AS relationships;
DROP DATABASE `db_626893_database`;
UNINSTALL EXTENSION vsql_schematron;
