INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 673727_ecommerceDB
--echo #
CREATE DATABASE `db_673727_ecommerceDB`;
USE `db_673727_ecommerceDB`;

CREATE TABLE `customers` (
  `cus_id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `contact_num` INT,
  `cus_street` VARCHAR(64),
  `cus_city` VARCHAR(64),
  `cus_province` VARCHAR(64),
  `cus_postal` VARCHAR(64),
  `cus_email` VARCHAR(64),
  `date_created` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `delivery` (
  `delivery_id` INT,
  `delivery_date` DATETIME,
  `delivery_status` VARCHAR(64),
  `order_id` INT
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `cus_id` INT,
  `orderDate` DATETIME,
  `shippedDate` DATETIME,
  `isDeliver` VARCHAR(64),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_details` (
  `order_id` INT,
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `product_id` INT,
  `product_name` VARCHAR(64),
  `purchase_price` DECIMAL(10,2),
  `sell_price` DECIMAL(10,2),
  `product_image` VARCHAR(64),
  `short_desc` VARCHAR(64),
  `description` VARCHAR(64),
  `category_id` INT,
  `date_added` DATETIME,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

CREATE TABLE `product_category` (
  `category_id` INT,
  `category_name` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `stock` (
  `stock_id` INT,
  `product_id` INT,
  `supplier_id` INT,
  `quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `supplier` (
  `supplier_id` INT,
  `supplier_name` VARCHAR(64),
  `contact_number` VARCHAR(64),
  `supplier_address` VARCHAR(64),
  `supplier_phone` VARCHAR(64),
  `supplier_email` VARCHAR(64),
  PRIMARY KEY (`supplier_id`)
) CHARACTER SET latin1;

CREATE TABLE `supplier_transaction` (
  `sup_transactionID` INT,
  `supplier_id` INT,
  `product_id` INT
) CHARACTER SET latin1;

CREATE TABLE `useraccounts` (
  `userid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `status` INT,
  `accesslevel` INT,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_673727_ecommerceDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_673727_ecommerceDB') AS relationships;
DROP DATABASE `db_673727_ecommerceDB`;
UNINSTALL EXTENSION vsql_schematron;
