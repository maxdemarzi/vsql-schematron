INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659875_V5__ObservedIntervalKeys
--echo #
CREATE DATABASE `db_659875_V5__ObservedIntervalKeys`;
USE `db_659875_V5__ObservedIntervalKeys`;
CREATE TABLE `ObservedKeys` (
  `id` INT NOT NULL,
  `prefix` VARCHAR(50),
  `methodName` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ObservedInterval` (
  `id` INT NOT NULL,
  `observedKeysId` BIGINT,
  `startTime` DATETIME,
  `duration` BIGINT,
  `vrCount` BIGINT,
  `vrMax` BIGINT,
  `vrMin` BIGINT,
  `vrMean` DECIMAL(10,2),
  `vrMedian` DECIMAL(10,2),
  `stdDev` DECIMAL(10,2),
  `p95` DECIMAL(10,2),
  `p98` DECIMAL(10,2),
  `p99` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659875_V5__ObservedIntervalKeys') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659875_V5__ObservedIntervalKeys') AS relationships;
DROP DATABASE `db_659875_V5__ObservedIntervalKeys`;
UNINSTALL EXTENSION vsql_schematron;
