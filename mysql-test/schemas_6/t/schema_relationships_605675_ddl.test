INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605675_ddl
--echo #
CREATE DATABASE `db_605675_ddl`;
USE `db_605675_ddl`;

CREATE TABLE `book` (
  `id` INT,
  `ISBN` VARCHAR(64),
  `Name` VARCHAR(64),
  `Author` VARCHAR(64),
  `Price` VARCHAR(64),
  `Description` VARCHAR(64),
  `Link` VARCHAR(64),
  `PicturePath` VARCHAR(64),
  `IsRentedOut` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `Name` VARCHAR(64),
  `Birthday` DATETIME,
  `Gender` VARCHAR(64),
  `Email` VARCHAR(64),
  `Telno` VARCHAR(64),
  `PicturePath` VARCHAR(64),
  `CanRent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bookrental` (
  `ID` INT,
  `UserId` INT,
  `BookId` INT,
  `RentalDate` DATETIME,
  `ReturnDate` DATETIME,
  `isRentOut` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `leaveduser` (
  `id` INT,
  `Name` VARCHAR(64),
  `Birthday` DATETIME,
  `Gender` VARCHAR(64),
  `Email` VARCHAR(64),
  `Telno` VARCHAR(64),
  `PicturePath` VARCHAR(64),
  `LeaveDate` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605675_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605675_ddl') AS relationships;
DROP DATABASE `db_605675_ddl`;
UNINSTALL EXTENSION vsql_schematron;
