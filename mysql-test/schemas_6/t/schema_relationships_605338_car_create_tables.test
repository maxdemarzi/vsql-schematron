INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605338_car_create_tables
--echo #
CREATE DATABASE `db_605338_car_create_tables`;
USE `db_605338_car_create_tables`;
CREATE TABLE `car_body` (
  `body_id` INT NOT NULL,
  `body_model` VARCHAR(50),
  PRIMARY KEY (`body_id`)
) CHARACTER SET latin1;
CREATE TABLE `engine` (
  `engine_id` INT NOT NULL,
  `engine_model` VARCHAR(50),
  PRIMARY KEY (`engine_id`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
  `transm_id` INT NOT NULL,
  `transm_model` VARCHAR(50),
  PRIMARY KEY (`transm_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
  `car_id` INT NOT NULL,
  `car_model` VARCHAR(50),
  `body_id` INT,
  `engine_id` INT,
  `transm_id` INT,
  PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605338_car_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605338_car_create_tables') AS relationships;
DROP DATABASE `db_605338_car_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
