INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606096_aulasql
--echo #
CREATE DATABASE `db_606096_aulasql`;
USE `db_606096_aulasql`;
CREATE TABLE `CLIENTE` (
  `IDCLIENTE` INT NOT NULL,
  `NOME` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `CPF` VARCHAR(50),
  `SEXO` VARCHAR(50),
  PRIMARY KEY (`IDCLIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `TELEFONE` (
  `IDTELEFONE` INT NOT NULL,
  `TIPO` VARCHAR(50),
  `NUMERO` VARCHAR(50),
  `ID_CLIENTE` INT,
  PRIMARY KEY (`IDTELEFONE`)
) CHARACTER SET latin1;
CREATE TABLE `ENDERECO` (
  `IDENDERECO` INT NOT NULL,
  `RUA` VARCHAR(50),
  `BAIRRO` VARCHAR(50),
  `CIDADE` VARCHAR(50),
  `ESTADO` CHAR(50),
  `ID_CLIENTE` INT,
  PRIMARY KEY (`IDENDERECO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606096_aulasql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606096_aulasql') AS relationships;
DROP DATABASE `db_606096_aulasql`;
UNINSTALL EXTENSION vsql_schematron;
