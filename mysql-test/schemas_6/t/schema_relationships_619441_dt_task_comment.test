INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 619441_dt_task_comment
--echo #
CREATE DATABASE `db_619441_dt_task_comment`;
USE `db_619441_dt_task_comment`;
CREATE TABLE `dt_task_comment` (
  `created_dt` TIMESTAMP NULL,
  `updated_dt` TIMESTAMP NULL,
  `id` INT NOT NULL,
  `parent_id` INT,
  `task_id` INT,
  `edition` INT,
  `owner_id` INT,
  `created_by` INT,
  `updated_by` INT,
  `markup_type_id` INT,
  `comment_markup` TEXT,
  `comment_html` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_619441_dt_task_comment') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_619441_dt_task_comment') AS relationships;
DROP DATABASE `db_619441_dt_task_comment`;
UNINSTALL EXTENSION vsql_schematron;
