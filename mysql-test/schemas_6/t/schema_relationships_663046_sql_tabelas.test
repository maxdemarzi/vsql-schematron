INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663046_sql_tabelas
--echo #
CREATE DATABASE `db_663046_sql_tabelas`;
USE `db_663046_sql_tabelas`;

CREATE TABLE `authors` (
  `id` INT,
  `name` VARCHAR(64),
  `birth_date` DATETIME,
  `thumbnail_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `title` VARCHAR(64),
  `sinopsis` VARCHAR(64),
  `release_date` DATETIME,
  `thumbnail_url` VARCHAR(64),
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `user_name` VARCHAR(64),
  `fullname` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books_genres` (
  `book_id` INT,
  `genre_id` INT
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `message` VARCHAR(64),
  `created_at` DATETIME,
  `book_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663046_sql_tabelas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663046_sql_tabelas') AS relationships;
DROP DATABASE `db_663046_sql_tabelas`;
UNINSTALL EXTENSION vsql_schematron;
