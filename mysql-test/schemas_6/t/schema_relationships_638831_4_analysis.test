INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 638831_4_analysis
--echo #
CREATE DATABASE `db_638831_4_analysis`;
USE `db_638831_4_analysis`;
CREATE TABLE `analysis_tool` (
  `id` VARCHAR(50) NOT NULL,
  `analysis_id` VARCHAR(50),
  `tool_id` VARCHAR(50),
  `duration` TIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` VARCHAR(50) NOT NULL,
  `analysis_tool_id` VARCHAR(50),
  `path` VARCHAR(50),
  `line` VARCHAR(50),
  `hunk_pos` VARCHAR(50),
  `issue` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_638831_4_analysis') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_638831_4_analysis') AS relationships;
DROP DATABASE `db_638831_4_analysis`;
UNINSTALL EXTENSION vsql_schematron;
