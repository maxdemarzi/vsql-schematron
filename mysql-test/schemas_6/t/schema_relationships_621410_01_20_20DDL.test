INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 621410_01%20-%20DDL
--echo #
CREATE DATABASE `db_621410_01_20_20DDL`;
USE `db_621410_01_20_20DDL`;

CREATE TABLE `WEATHER_FORECAST_H` (
  `FORECAST_PK` VARCHAR(64),
  `FORECAST_BK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`FORECAST_PK`)
) CHARACTER SET latin1;

CREATE TABLE `SUPPLIER_INVENTORY_H` (
  `INVENTORY_PK` VARCHAR(64),
  `INVENTORY_BK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`INVENTORY_PK`)
) CHARACTER SET latin1;

CREATE TABLE `SUPPLIER_H` (
  `SUPPLIER_PK` VARCHAR(64),
  `SUPPLIER_BK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`SUPPLIER_PK`)
) CHARACTER SET latin1;

CREATE TABLE `PART_H` (
  `PART_PK` VARCHAR(64),
  `PART_BK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`PART_PK`)
) CHARACTER SET latin1;

CREATE TABLE `WEATHER_FORECAST_S` (
  `FORECAST_H_FK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `FORECAST_MADE_DTS` DATETIME,
  `FORECAST_ATTRIBUTES` VARCHAR(64),
  `HASH_DIFF` VARCHAR(64),
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`FORECAST_H_FK`, `LOAD_DTS`)
) CHARACTER SET latin1;

CREATE TABLE `SUPPLIER_S` (
  `SUPPLIER_H_FK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `NAME` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `PHONE` VARCHAR(64),
  `ACCTBAL` VARCHAR(64),
  `NATIONCODE` VARCHAR(64),
  `HASH_DIFF` VARCHAR(64),
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`SUPPLIER_H_FK`, `LOAD_DTS`)
) CHARACTER SET latin1;

CREATE TABLE `SUPPLIER_INVENTORY_S` (
  `INVENTORY_H_PK` VARCHAR(64),
  `LOAD_DTS` DATETIME,
  `SUPPLY_COST` DECIMAL(10,2),
  `AVAILABLE_QTY` DECIMAL(10,2),
  `PART_BK` VARCHAR(64),
  `SUPPLIER_BK` VARCHAR(64),
  `HASH_DIFF` VARCHAR(64),
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`INVENTORY_H_PK`, `LOAD_DTS`)
) CHARACTER SET latin1;

CREATE TABLE `SUPPLIER_INVENTORY_L` (
  `SUPPLIER_INVENTORY_L_PK` VARCHAR(64),
  `PART_PK` VARCHAR(64),
  `SUPPLIER_PK` VARCHAR(64),
  `INVENTORY_PK` VARCHAR(64),
  `LOAD_DTS` VARCHAR(64),
  `REC_SRC` VARCHAR(64),
  PRIMARY KEY (`SUPPLIER_INVENTORY_L_PK`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_621410_01_20_20DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_621410_01_20_20DDL') AS relationships;
DROP DATABASE `db_621410_01_20_20DDL`;
UNINSTALL EXTENSION vsql_schematron;
