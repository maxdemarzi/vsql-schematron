INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609031_V0_0_1_0__Basic_Models
--echo #
CREATE DATABASE `db_609031_V0_0_1_0_Basic_Models`;
USE `db_609031_V0_0_1_0_Basic_Models`;

CREATE TABLE `exams` (
  `id` INT,
  `description` VARCHAR(64),
  `starting_at` DATETIME,
  `duration` INT,
  `state` VARCHAR(64),
  `actual_starting_moment` DATETIME,
  `actual_duration` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exercises` (
  `id` INT,
  `question` VARCHAR(64),
  `belongs_to` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `test_cases` (
  `id` INT,
  `visibility` VARCHAR(64),
  `belongs_to` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `test_case_inputs` (
  `test_case_id` INT,
  `input` VARCHAR(64),
  `input_order` INT
) CHARACTER SET latin1;

CREATE TABLE `test_case_expected_outputs` (
  `test_case_id` INT,
  `expected_output` VARCHAR(64),
  `expected_output_order` INT
) CHARACTER SET latin1;

CREATE TABLE `exercise_solutions` (
  `id` INT,
  `answer` VARCHAR(64),
  `belongs_to` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exercise_solution_results` (
  `id` INT,
  `solution_id` INT,
  `test_case_id` INT,
  `result` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609031_V0_0_1_0_Basic_Models') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609031_V0_0_1_0_Basic_Models') AS relationships;
DROP DATABASE `db_609031_V0_0_1_0_Basic_Models`;
UNINSTALL EXTENSION vsql_schematron;
