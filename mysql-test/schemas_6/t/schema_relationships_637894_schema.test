INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 637894_schema
--echo #
CREATE DATABASE `db_637894_schema`;
USE `db_637894_schema`;

CREATE TABLE `animals` (
  `id` INT,
  `name` VARCHAR(64),
  `date_of_birth` DATETIME,
  `escape_attempts` INT,
  `neutered` VARCHAR(64),
  `weight_kg` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vets` (
  `id` INT,
  `name` VARCHAR(64),
  `age` INT,
  `date_of_graduation` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `specializations` (
  `species_id` INT,
  `vets_id` INT,
  PRIMARY KEY (`species_id`, `vets_id`)
) CHARACTER SET latin1;

CREATE TABLE `visits` (
  `animals_id` INT,
  `vets_id` INT,
  `date_of_visit` DATETIME,
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_637894_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_637894_schema') AS relationships;
DROP DATABASE `db_637894_schema`;
UNINSTALL EXTENSION vsql_schematron;
