INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648587_CREATE_DATABASE
--echo #
CREATE DATABASE `db_648587_CREATE_DATABASE`;
USE `db_648587_CREATE_DATABASE`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `user_url_photo` VARCHAR(50),
  `email` VARCHAR(50),
  `user_password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_checks` (
  `id_daily_check` INT NOT NULL,
  `weight` INT,
  `waist_lenght` INT,
  `date_check` DATE,
  `water_glasses` INT,
  `calories_count` INT,
  `user_id` INT,
  PRIMARY KEY (`id_daily_check`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
  `recipe_id` INT NOT NULL,
  `calories` INT,
  `url_photo` VARCHAR(50),
  PRIMARY KEY (`recipe_id`)
) CHARACTER SET latin1;
CREATE TABLE `daily_checks_recipes` (
  `dcr_id` INT NOT NULL,
  `id_daily_check` INT,
  `recipe_id` INT,
  PRIMARY KEY (`dcr_id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `steps_id` INT NOT NULL,
  `order_no` INT,
  `description_step` TEXT,
  `recipe_id` INT,
  PRIMARY KEY (`steps_id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `ingredient_id` INT NOT NULL,
  `ingredient_name` VARCHAR(50),
  `total_calories` INT,
  `measure` VARCHAR(50),
  `grams_per_measure` VARCHAR(50),
  PRIMARY KEY (`ingredient_id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_ingredients` (
  `ri_id` INT NOT NULL,
  `recipe_id` INT,
  `ingredient_id` INT,
  PRIMARY KEY (`ri_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648587_CREATE_DATABASE') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648587_CREATE_DATABASE') AS relationships;
DROP DATABASE `db_648587_CREATE_DATABASE`;
UNINSTALL EXTENSION vsql_schematron;
