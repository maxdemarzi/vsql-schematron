INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 612409_migration
--echo #
CREATE DATABASE `db_612409_migration`;
USE `db_612409_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `auth0Id` TEXT,
  `isAdmin` BOOLEAN,
  `firstName` TEXT,
  `lastName` TEXT,
  `website` TEXT,
  `instagram` TEXT,
  `applySwapCredit` BOOLEAN,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Postcards` (
  `id` INT NOT NULL,
  `userId` INT,
  `s3Url` TEXT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_612409_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_612409_migration') AS relationships;
DROP DATABASE `db_612409_migration`;
UNINSTALL EXTENSION vsql_schematron;
