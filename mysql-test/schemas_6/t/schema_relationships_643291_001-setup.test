INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 643291_001-setup
--echo #
CREATE DATABASE `db_643291_001_setup`;
USE `db_643291_001_setup`;
CREATE TABLE `users` (
  `id` CHAR(50),
  `time` VARCHAR(50),
  `name` VARCHAR(50),
  `secret` CHAR(50),
  `blob` TEXT
) CHARACTER SET latin1;
CREATE TABLE `threads` (
  `id` CHAR(50),
  `container_id` CHAR(50),
  `blob` TEXT
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` CHAR(50),
  `time` VARCHAR(50),
  `text` TEXT,
  `user_id` CHAR(50),
  `thread_id` CHAR(50),
  `blob` TEXT
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` CHAR(50),
  `time` VARCHAR(50),
  `text` TEXT,
  `user_id` CHAR(50),
  `thread_id` VARCHAR(50),
  `blob` TEXT
) CHARACTER SET latin1;
CREATE TABLE `reactions` (
  `id` CHAR(50),
  `time` VARCHAR(50),
  `emoji` VARCHAR(50),
  `user_id` CHAR(50),
  `comment_id` CHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `id` INT NOT NULL,
  `file` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_643291_001_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_643291_001_setup') AS relationships;
DROP DATABASE `db_643291_001_setup`;
UNINSTALL EXTENSION vsql_schematron;
