INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 606625_database
--echo #
CREATE DATABASE `db_606625_database`;
USE `db_606625_database`;

CREATE TABLE `characters` (
  `user_id` INT,
  `name` VARCHAR(64),
  `class_name` VARCHAR(64),
  `spec` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` INT,
  `name` VARCHAR(64),
  `date` DATETIME,
  `channel_id` INT,
  `message_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `signups` (
  `event_id` INT,
  `character_name` VARCHAR(64),
  `signup_status` INT,
  `confirm_status` INT,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_606625_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_606625_database') AS relationships;
DROP DATABASE `db_606625_database`;
UNINSTALL EXTENSION vsql_schematron;
