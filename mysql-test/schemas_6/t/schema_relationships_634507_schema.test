INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 634507_schema
--echo #
CREATE DATABASE `db_634507_schema`;
USE `db_634507_schema`;

CREATE TABLE `builds` (
  `name` VARCHAR(64),
  `short_name` VARCHAR(64),
  PRIMARY KEY (`name`, `short_name`)
) CHARACTER SET latin1;

CREATE TABLE `floors` (
  `number` INT,
  `build_name` VARCHAR(64),
  `build_short_name` VARCHAR(64),
  PRIMARY KEY (`build_short_name`, `number`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_634507_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_634507_schema') AS relationships;
DROP DATABASE `db_634507_schema`;
UNINSTALL EXTENSION vsql_schematron;
