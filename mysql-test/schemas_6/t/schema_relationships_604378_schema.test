INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 604378_schema
--echo #
CREATE DATABASE `db_604378_schema`;
USE `db_604378_schema`;

CREATE TABLE `users` (
  `userID` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `followers` INT,
  `mentionCount` INT,
  `profileURL` VARCHAR(64),
  `bio` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `postID` VARCHAR(64),
  `userID` VARCHAR(64),
  `postURL` VARCHAR(64),
  `title` VARCHAR(64),
  `username` VARCHAR(64),
  `profileURL` VARCHAR(64),
  `loveCount` INT,
  `commentCount` INT,
  PRIMARY KEY (`postID`)
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `love` VARCHAR(64),
  `postID` VARCHAR(64),
  `userID` VARCHAR(64),
  PRIMARY KEY (`postID`, `userID`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `commentID` VARCHAR(64),
  `userID` VARCHAR(64),
  `parentCommentID` VARCHAR(64),
  `postID` VARCHAR(64),
  `body` VARCHAR(64),
  `createdAt` DATETIME,
  `mentions` VARCHAR(64),
  PRIMARY KEY (`commentID`)
) CHARACTER SET latin1;

CREATE TABLE `follows` (
  `userID` VARCHAR(64),
  `followID` VARCHAR(64),
  PRIMARY KEY (`followID`, `userID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_604378_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_604378_schema') AS relationships;
DROP DATABASE `db_604378_schema`;
UNINSTALL EXTENSION vsql_schematron;
