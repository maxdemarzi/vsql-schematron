INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 625399_testdb
--echo #
CREATE DATABASE `db_625399_testdb`;
USE `db_625399_testdb`;

CREATE TABLE `brands` (
  `id` INT,
  `title` VARCHAR(255),
  `alias` VARCHAR(255),
  `dateadd` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `id` INT,
  `model_id` INT,
  `engine_id` INT,
  `drive_id` INT
) CHARACTER SET latin1;

CREATE TABLE `drives` (
  `id` INT,
  `title` VARCHAR(255),
  `alias` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `engines` (
  `id` INT,
  `title` VARCHAR(255),
  `alias` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `models` (
  `id` INT,
  `brand_id` INT,
  `title` VARCHAR(255),
  `alias` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_625399_testdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_625399_testdb') AS relationships;
DROP DATABASE `db_625399_testdb`;
UNINSTALL EXTENSION vsql_schematron;
