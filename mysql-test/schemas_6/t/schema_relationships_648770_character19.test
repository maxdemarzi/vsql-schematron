INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 648770_character19
--echo #
CREATE DATABASE `db_648770_character19`;
USE `db_648770_character19`;

CREATE TABLE `Cityorders` (
  `onum` INT,
  `amt` DECIMAL(10,2),
  `cnum` INT,
  `snum` INT,
  `city` VARCHAR(64),
  PRIMARY KEY (`onum`)
) CHARACTER SET latin1;

CREATE TABLE `Orders` (
  `onum` INT,
  `amt` DECIMAL(10,2),
  `odate` DATETIME,
  `cnum` INT,
  `snum` INT,
  `prev` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_648770_character19') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_648770_character19') AS relationships;
DROP DATABASE `db_648770_character19`;
UNINSTALL EXTENSION vsql_schematron;
