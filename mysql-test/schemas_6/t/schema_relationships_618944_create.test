INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 618944_create
--echo #
CREATE DATABASE `db_618944_create`;
USE `db_618944_create`;

CREATE TABLE `BUSINESS_DATE` (
  `SEGMENT_ID` VARCHAR(64),
  `BIZ_DATE` VARCHAR(64),
  PRIMARY KEY (`SEGMENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CODE_NAME` (
  `CODE_ID` VARCHAR(64),
  `CODE_VALUE` VARCHAR(64),
  `LANG` VARCHAR(64),
  `SORT_ORDER` INT,
  `CODE_NAME` VARCHAR(64),
  `SHORT_NAME` VARCHAR(64),
  `OPTION01` VARCHAR(64),
  `OPTION02` VARCHAR(64),
  `OPTION03` VARCHAR(64),
  `OPTION04` VARCHAR(64),
  `OPTION05` VARCHAR(64),
  `OPTION06` VARCHAR(64),
  `OPTION07` VARCHAR(64),
  `OPTION08` VARCHAR(64),
  `OPTION09` VARCHAR(64),
  `OPTION10` VARCHAR(64),
  PRIMARY KEY (`CODE_ID`, `CODE_VALUE`, `LANG`)
) CHARACTER SET latin1;

CREATE TABLE `CODE_PATTERN` (
  `CODE_ID` VARCHAR(64),
  `CODE_VALUE` VARCHAR(64),
  `PATTERN01` VARCHAR(64),
  `PATTERN02` VARCHAR(64),
  `PATTERN03` VARCHAR(64),
  `PATTERN04` VARCHAR(64),
  `PATTERN05` VARCHAR(64),
  `PATTERN06` VARCHAR(64),
  `PATTERN07` VARCHAR(64),
  `PATTERN08` VARCHAR(64),
  `PATTERN09` VARCHAR(64),
  `PATTERN10` VARCHAR(64),
  `PATTERN11` VARCHAR(64),
  `PATTERN12` VARCHAR(64),
  `PATTERN13` VARCHAR(64),
  `PATTERN14` VARCHAR(64),
  `PATTERN15` VARCHAR(64),
  `PATTERN16` VARCHAR(64),
  `PATTERN17` VARCHAR(64),
  `PATTERN18` VARCHAR(64),
  `PATTERN19` VARCHAR(64),
  `PATTERN20` VARCHAR(64),
  PRIMARY KEY (`CODE_ID`, `CODE_VALUE`)
) CHARACTER SET latin1;

CREATE TABLE `SAMPLE_USER` (
  `USER_ID` VARCHAR(64),
  `FAMILY_NAME` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAMPLE_USER_ERROR` (
  `LINE_NUMBER` INT,
  `USER_ID` VARCHAR(64),
  `FAMILY_NAME` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  PRIMARY KEY (`LINE_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `SAMPLE_USER_WORK` (
  `LINE_NUMBER` INT,
  `USER_ID` VARCHAR(64),
  `FAMILY_NAME` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  PRIMARY KEY (`LINE_NUMBER`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_618944_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_618944_create') AS relationships;
DROP DATABASE `db_618944_create`;
UNINSTALL EXTENSION vsql_schematron;
