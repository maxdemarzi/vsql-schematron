INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646608_schema
--echo #
CREATE DATABASE `db_646608_schema`;
USE `db_646608_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `client_user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `videos` (
  `id` INT NOT NULL,
  `media_content_key` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progress_relations` (
  `id` INT NOT NULL,
  `video_id` INT,
  `user_id` INT,
  `progress_block_info` TEXT,
  `progress_values` DOUBLE,
  `start_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `progress_datas` (
  `id` INT NOT NULL,
  `progress_relation_id` INT,
  `start_at` INT,
  `progress_block_info` TEXT,
  `playtime` INT,
  `player_id` TEXT,
  `device_name` VARCHAR(50),
  `updated_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646608_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646608_schema') AS relationships;
DROP DATABASE `db_646608_schema`;
UNINSTALL EXTENSION vsql_schematron;
