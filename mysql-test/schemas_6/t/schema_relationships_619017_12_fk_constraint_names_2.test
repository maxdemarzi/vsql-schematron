INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 619017_12-fk-constraint-names-2
--echo #
CREATE DATABASE `db_619017_12_fk_constraint_names_2`;
USE `db_619017_12_fk_constraint_names_2`;

CREATE TABLE `aaa` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bbb` (
  `id` INT,
  `a` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_619017_12_fk_constraint_names_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_619017_12_fk_constraint_names_2') AS relationships;
DROP DATABASE `db_619017_12_fk_constraint_names_2`;
UNINSTALL EXTENSION vsql_schematron;
