INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611225_script
--echo #
CREATE DATABASE `db_611225_script`;
USE `db_611225_script`;

CREATE TABLE `post` (
  `id` INT,
  `titulo` VARCHAR(64),
  `conteudo` VARCHAR(64),
  `data_pub` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `arquivo` (
  `id` INT,
  `post_id` INT,
  `nome` VARCHAR(64),
  `descr` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post_tag` (
  `post_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`post_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611225_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611225_script') AS relationships;
DROP DATABASE `db_611225_script`;
UNINSTALL EXTENSION vsql_schematron;
