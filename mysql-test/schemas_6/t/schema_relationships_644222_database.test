INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644222_database
--echo #
CREATE DATABASE `db_644222_database`;
USE `db_644222_database`;

CREATE TABLE `courses` (
  `id` INT,
  `title` VARCHAR(64),
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `account` VARCHAR(64),
  `password_salt` VARCHAR(64),
  `password_pepper` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `password_loop` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lessons` (
  `id` INT,
  `course_id` INT,
  `user_id` INT,
  `teacher_id` INT,
  `day` INT,
  `hour` INT,
  `completed` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_tokens` (
  `token` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644222_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644222_database') AS relationships;
DROP DATABASE `db_644222_database`;
UNINSTALL EXTENSION vsql_schematron;
