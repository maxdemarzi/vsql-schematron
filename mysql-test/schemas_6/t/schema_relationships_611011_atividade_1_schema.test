INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611011_atividade_1_schema
--echo #
CREATE DATABASE `db_611011_atividade_1_schema`;
USE `db_611011_atividade_1_schema`;

CREATE TABLE `Departament` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Employee` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Salary` DECIMAL(10,2),
  `DepartmentId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611011_atividade_1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611011_atividade_1_schema') AS relationships;
DROP DATABASE `db_611011_atividade_1_schema`;
UNINSTALL EXTENSION vsql_schematron;
