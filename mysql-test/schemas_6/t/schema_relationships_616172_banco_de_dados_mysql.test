INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 616172_banco_de_dados_mysql
--echo #
CREATE DATABASE `db_616172_banco_de_dados_mysql`;
USE `db_616172_banco_de_dados_mysql`;
CREATE TABLE `produto` (
  `id` INT NOT NULL,
  `descricao` VARCHAR(50),
  `estoque` INT,
  `preco_custo` INT,
  `preco_venda` INT,
  `codigo_de_barras` INT,
  `data_cadastro` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cadastro_do_conteudo` (
  `id` INT NOT NULL,
  `titulo` VARCHAR(50),
  `conteudo` VARCHAR(50),
  `data_do_cadastro` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `carrinho_de_compra` (
  `id` INT NOT NULL,
  `id_cliente` INT,
  `id_produto` INT,
  `quantidade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `local_de_entrega` (
  `id` INT NOT NULL,
  `id_cliente` INT,
  `country` VARCHAR(50),
  `street` VARCHAR(50),
  `street_number` INT,
  `state` VARCHAR(50),
  `city` VARCHAR(50),
  `neighborhood` VARCHAR(50),
  `zipcode` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_616172_banco_de_dados_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_616172_banco_de_dados_mysql') AS relationships;
DROP DATABASE `db_616172_banco_de_dados_mysql`;
UNINSTALL EXTENSION vsql_schematron;
