INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 641561_schema
--echo #
CREATE DATABASE `db_641561_schema`;
USE `db_641561_schema`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `image_url` VARCHAR(64),
  `created_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exam` (
  `id` INT,
  `course_id` INT,
  `number` VARCHAR(64),
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exam_answer` (
  `id` INT,
  `exam_id` INT,
  `label` VARCHAR(64),
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exam_progress` (
  `id` INT,
  `exam_id` INT,
  `exam_answer_id` INT,
  `answer_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `exam_solution` (
  `id` INT,
  `exam_id` INT,
  `exam_answer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_641561_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_641561_schema') AS relationships;
DROP DATABASE `db_641561_schema`;
UNINSTALL EXTENSION vsql_schematron;
