INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 643928_database
--echo #
CREATE DATABASE `db_643928_database`;
USE `db_643928_database`;
CREATE TABLE `Address` (
  `id` INT NOT NULL,
  `city` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Person` (
  `id` INT NOT NULL,
  `family_name` TEXT,
  `given_name` TEXT,
  `birth_date` TIMESTAMP NULL,
  `perm_address_id` INT,
  `temp_address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
  `id` INT NOT NULL,
  `product_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_643928_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_643928_database') AS relationships;
DROP DATABASE `db_643928_database`;
UNINSTALL EXTENSION vsql_schematron;
