INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646822_db
--echo #
CREATE DATABASE `db_646822_db`;
USE `db_646822_db`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `followers` (
  `user_id` INT,
  `follower_id` INT,
  PRIMARY KEY (`user_id`, `follower_id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `author_id` INT,
  `likes` INT,
  `created_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646822_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646822_db') AS relationships;
DROP DATABASE `db_646822_db`;
UNINSTALL EXTENSION vsql_schematron;
