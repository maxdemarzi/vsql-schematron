INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663835_20210214154022_init_schema.up
--echo #
CREATE DATABASE `db_663835_20210214154022_init_schema_up`;
USE `db_663835_20210214154022_init_schema_up`;

CREATE TABLE `admins` (
  `id` INT,
  `email` VARCHAR(64),
  `encrypted_password` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `encrypted_password` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `owner_id` INT,
  `created_at` DATETIME,
  `published_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `relationships` (
  `follower_id` INT,
  `followed_id` INT,
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `responses` (
  `id` INT,
  `body` VARCHAR(64),
  `post_id` INT,
  `owner_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663835_20210214154022_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663835_20210214154022_init_schema_up') AS relationships;
DROP DATABASE `db_663835_20210214154022_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
