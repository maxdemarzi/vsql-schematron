INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 633498_dump
--echo #
CREATE DATABASE `db_633498_dump`;
USE `db_633498_dump`;

CREATE TABLE `post` (
  `postId` VARCHAR(255),
  `postTruckId` VARCHAR(255),
  `postUserId` VARCHAR(255),
  `postContent` VARCHAR(255),
  `postDatetime` DATETIME,
  PRIMARY KEY (`postId`)
) CHARACTER SET latin1;

CREATE TABLE `truck` (
  `truckId` VARCHAR(255),
  `truckUserId` VARCHAR(255),
  `truckAvatarUrl` VARCHAR(255),
  `truckEmail` VARCHAR(255),
  `truckFoodType` VARCHAR(255),
  `truckMenuUrl` VARCHAR(255),
  `truckName` VARCHAR(255),
  `truckPhoneNumber` VARCHAR(255),
  `truckVerifyImage` VARCHAR(255),
  PRIMARY KEY (`truckId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_633498_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_633498_dump') AS relationships;
DROP DATABASE `db_633498_dump`;
UNINSTALL EXTENSION vsql_schematron;
