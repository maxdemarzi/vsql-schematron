INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 603437_schema
--echo #
CREATE DATABASE `db_603437_schema`;
USE `db_603437_schema`;

CREATE TABLE `user` (
  `id` INT,
  `user_name` VARCHAR(64),
  `about` VARCHAR(64),
  `picture` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tweets` (
  `id` INT,
  `user_id` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `faves` (
  `id` INT,
  `favoriter_user_id` INT,
  `author_user_id` INT,
  `tweet_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `retweets` (
  `id` INT,
  `retweeter_id` INT,
  `author_user_id` INT,
  `tweet_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `follows` (
  `follower_user_id` INT,
  `followed_user_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_603437_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_603437_schema') AS relationships;
DROP DATABASE `db_603437_schema`;
UNINSTALL EXTENSION vsql_schematron;
