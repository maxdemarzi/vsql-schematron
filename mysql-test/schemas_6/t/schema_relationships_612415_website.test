INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 612415_website
--echo #
CREATE DATABASE `db_612415_website`;
USE `db_612415_website`;

CREATE TABLE `article` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `content` VARCHAR(64),
  `date` DATETIME,
  `viewed` INT,
  `user_id` INT,
  `status` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article_tag` (
  `id` INT,
  `article_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `text` VARCHAR(64),
  `user_id` INT,
  `article_id` INT,
  `status` INT,
  `date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `id` INT,
  `filePath` VARCHAR(64),
  `itemId` INT,
  `isMain` INT,
  `modelName` VARCHAR(64),
  `urlAlias` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `auth_key` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_612415_website') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_612415_website') AS relationships;
DROP DATABASE `db_612415_website`;
UNINSTALL EXTENSION vsql_schematron;
