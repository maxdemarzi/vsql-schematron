INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 647170_schema
--echo #
CREATE DATABASE `db_647170_schema`;
USE `db_647170_schema`;

CREATE TABLE `product` (
  `product_id` INT,
  `name` VARCHAR(255),
  `slogan` VARCHAR(255),
  `description` VARCHAR(255),
  `category` VARCHAR(255),
  `default_price` INT,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `review_id` INT,
  `product_id` INT,
  `rating` INT,
  `date` INT,
  `summary` VARCHAR(255),
  `body` VARCHAR(255),
  `recommend` VARCHAR(255),
  `reported` VARCHAR(255),
  `reviewer_name` VARCHAR(255),
  `reviewer_email` VARCHAR(255),
  `response` VARCHAR(255),
  `helpfulness` INT,
  PRIMARY KEY (`review_id`)
) CHARACTER SET latin1;

CREATE TABLE `photos` (
  `id` INT,
  `review_id` INT,
  `url` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `characteristics` (
  `id` INT,
  `product_id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `characteristic_reviews` (
  `id` INT,
  `characteristic_id` INT,
  `review_id` INT,
  `value` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_647170_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_647170_schema') AS relationships;
DROP DATABASE `db_647170_schema`;
UNINSTALL EXTENSION vsql_schematron;
