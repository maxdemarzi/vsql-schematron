INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 629674_dbSchema
--echo #
CREATE DATABASE `db_629674_dbSchema`;
USE `db_629674_dbSchema`;
CREATE TABLE `Users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Files` (
  `file_id` INT NOT NULL,
  `user_id` INT,
  `file` VARCHAR(50),
  `file_name` VARCHAR(50),
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_629674_dbSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_629674_dbSchema') AS relationships;
DROP DATABASE `db_629674_dbSchema`;
UNINSTALL EXTENSION vsql_schematron;
