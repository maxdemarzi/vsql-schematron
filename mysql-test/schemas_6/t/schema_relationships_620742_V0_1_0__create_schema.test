INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620742_V0.1.0__create_schema
--echo #
CREATE DATABASE `db_620742_V0_1_0__create_schema`;
USE `db_620742_V0_1_0__create_schema`;
CREATE TABLE `vets` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `specialties` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vet_specialties` (
  `vet_id` INT,
  `specialty_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `types` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owners` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `telephone` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `birth_date` DATE,
  `type_id` INT,
  `owner_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `visits` (
  `id` INT NOT NULL,
  `pet_id` INT,
  `visit_date` DATE,
  `description` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620742_V0_1_0__create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620742_V0_1_0__create_schema') AS relationships;
DROP DATABASE `db_620742_V0_1_0__create_schema`;
UNINSTALL EXTENSION vsql_schematron;
