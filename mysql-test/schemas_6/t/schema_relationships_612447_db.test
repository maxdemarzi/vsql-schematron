INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 612447_db
--echo #
CREATE DATABASE `db_612447_db`;
USE `db_612447_db`;

CREATE TABLE `admin` (
  `id` INT,
  `username` VARCHAR(64),
  `nama_lengkap` VARCHAR(64),
  `instansi` VARCHAR(64),
  `password` VARCHAR(64),
  `status` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `laporan` (
  `id` INT,
  `tgl_buat` DATETIME,
  `judul_laporan` VARCHAR(64),
  `jenis` VARCHAR(64),
  `tgl_awal` DATETIME,
  `tgl_akhir` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `surat` (
  `id` INT,
  `judul_surat` VARCHAR(64),
  `no_surat` VARCHAR(64),
  `username` VARCHAR(64),
  `nama_pengirim` VARCHAR(64),
  `nama_penerima` VARCHAR(64),
  `file` VARCHAR(64),
  `note` VARCHAR(64),
  `verifikasi` DATETIME,
  `diverifikasi` DATETIME,
  `keterangan` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_612447_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_612447_db') AS relationships;
DROP DATABASE `db_612447_db`;
UNINSTALL EXTENSION vsql_schematron;
