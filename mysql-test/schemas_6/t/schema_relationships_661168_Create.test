INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 661168_Create
--echo #
CREATE DATABASE `db_661168_Create`;
USE `db_661168_Create`;

CREATE TABLE `GameStatus` (
  `ID` INT,
  `Value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Level` (
  `ID` INT,
  `Value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `SeasonType` (
  `ID` INT,
  `Value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Season` (
  `ID` INT,
  `GUID` VARCHAR(64),
  `Year` INT,
  `NumWeeksInRegularSeason` INT
) CHARACTER SET latin1;

CREATE TABLE `Conference` (
  `ID` INT,
  `GUID` VARCHAR(64),
  `Name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Division` (
  `ID` INT,
  `GUID` VARCHAR(64),
  `ConferenceGUID` VARCHAR(64),
  `Name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Team` (
  `ID` INT,
  `GUID` VARCHAR(64),
  `Name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Game` (
  `ID` INT,
  `GUID` VARCHAR(64),
  `SeasonGUID` VARCHAR(64),
  `Week` INT,
  `Level` VARCHAR(64),
  `SeasonType` VARCHAR(64),
  `Status` VARCHAR(64),
  `Date` DATETIME,
  `HomeTeamGUID` VARCHAR(64),
  `HomeTeamScore` INT,
  `AwayTeamGUID` VARCHAR(64),
  `AwayTeamScore` INT,
  `TV` VARCHAR(64),
  `Notes` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `TeamBySeason` (
  `ID` INT,
  `Level` VARCHAR(64),
  `SeasonGUID` VARCHAR(64),
  `ConferenceGUID` VARCHAR(64),
  `DivisionGUID` VARCHAR(64),
  `TeamGUID` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_661168_Create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_661168_Create') AS relationships;
DROP DATABASE `db_661168_Create`;
UNINSTALL EXTENSION vsql_schematron;
