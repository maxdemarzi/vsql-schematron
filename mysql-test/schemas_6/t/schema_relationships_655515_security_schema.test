INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655515_security-schema
--echo #
CREATE DATABASE `db_655515_security_schema`;
USE `db_655515_security_schema`;

CREATE TABLE `user_roles` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `functionalities` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles_users` (
  `role_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `roles_functionalities` (
  `role_id` INT,
  `functionality_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655515_security_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655515_security_schema') AS relationships;
DROP DATABASE `db_655515_security_schema`;
UNINSTALL EXTENSION vsql_schematron;
