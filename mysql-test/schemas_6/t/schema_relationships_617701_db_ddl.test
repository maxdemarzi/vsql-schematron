INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 617701_db.ddl
--echo #
CREATE DATABASE `db_617701_db_ddl`;
USE `db_617701_db_ddl`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `username` VARCHAR(50),
  `createdAt` DATE,
  `updatedAt` DATE,
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `userId` INT,
  `createdAt` DATE,
  `updatedAt` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_617701_db_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_617701_db_ddl') AS relationships;
DROP DATABASE `db_617701_db_ddl`;
UNINSTALL EXTENSION vsql_schematron;
