INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 631603_filehosting
--echo #
CREATE DATABASE `db_631603_filehosting`;
USE `db_631603_filehosting`;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `uploader` CHAR(50),
  `upload_date` TIMESTAMP NULL,
  `size` INT,
  `downloads` INT,
  `auth_token` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `parent_id` INT,
  `file_id` INT,
  `author` CHAR(50),
  `date_posted` TIMESTAMP NULL,
  `comment_text` TEXT,
  `matpath` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_631603_filehosting') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_631603_filehosting') AS relationships;
DROP DATABASE `db_631603_filehosting`;
UNINSTALL EXTENSION vsql_schematron;
