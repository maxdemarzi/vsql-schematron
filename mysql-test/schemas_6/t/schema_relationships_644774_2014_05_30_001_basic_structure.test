INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644774_2014-05-30-001-basic-structure
--echo #
CREATE DATABASE `db_644774_2014_05_30_001_basic_structure`;
USE `db_644774_2014_05_30_001_basic_structure`;

CREATE TABLE `comments` (
  `id` INT,
  `post_id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_x_tags` (
  `post_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`post_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644774_2014_05_30_001_basic_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644774_2014_05_30_001_basic_structure') AS relationships;
DROP DATABASE `db_644774_2014_05_30_001_basic_structure`;
UNINSTALL EXTENSION vsql_schematron;
