INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 688876_schema
--echo #
CREATE DATABASE `db_688876_schema`;
USE `db_688876_schema`;

CREATE TABLE `proprietarios` (
  `id` INT,
  `nome` VARCHAR(255),
  `cpf` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `modelos` (
  `id` INT,
  `nome` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cores` (
  `id` INT,
  `nome` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `carros` (
  `id` INT,
  `modelo` VARCHAR(255),
  `marca` VARCHAR(255),
  `placa` VARCHAR(255),
  `clientes_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `telefones` (
  `id` INT,
  `tipo` VARCHAR(255),
  `numero` VARCHAR(255),
  `proprietarios_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `carros_cores` (
  `carros_id` INT,
  `cores_id` INT,
  PRIMARY KEY (`carros_id`, `cores_id`)
) CHARACTER SET latin1;

CREATE TABLE `clientes` (
  `id` INT,
  `nome` VARCHAR(255),
  `sexo` VARCHAR(255),
  `cpf` VARCHAR(255),
  `cidade` VARCHAR(255),
  `estado` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_688876_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_688876_schema') AS relationships;
DROP DATABASE `db_688876_schema`;
UNINSTALL EXTENSION vsql_schematron;
