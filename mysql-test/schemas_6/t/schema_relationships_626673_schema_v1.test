INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626673_schema_v1
--echo #
CREATE DATABASE `db_626673_schema_v1`;
USE `db_626673_schema_v1`;
CREATE TABLE `COURSE_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `COURSE_ATTR_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ATTR_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ENROLLMENT_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `COMMENT_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `VOTE_SEQUENCE` (
  `NEXT_VAL` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `COURSE` (
  `ID` INT NOT NULL,
  `CODE` VARCHAR(50),
  `LEVEL` INT,
  `TERM` VARCHAR(50),
  `ACADEMIC_YEAR` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE_ATTR` (
  `ID` INT NOT NULL,
  `COURSE_ID` INT,
  `ATTR_NAME` VARCHAR(50),
  `ATTR_VALUE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT` (
  `ID` INT NOT NULL,
  `COURSE_ID` INT,
  `NAME` VARCHAR(50),
  `DUE_DATE` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ATTR` (
  `ID` INT NOT NULL,
  `ASSIGNMENT_ID` INT,
  `ATTR_NAME` VARCHAR(50),
  `ATTR_VALUE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ASSIGNMENT_ENROLLMENT` (
  `ID` INT NOT NULL,
  `ASSIGNMENT_ID` INT,
  `USER_ID` VARCHAR(50),
  `PINNED` BOOLEAN,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COMMENT` (
  `ID` INT NOT NULL,
  `CREATED` DATETIME,
  `SOURCE_TYPE` VARCHAR(50),
  `SOURCE_ITEM_ID` INT,
  `AUTHOR_ID` VARCHAR(50),
  `CONTENT` VARCHAR(50),
  `LAST_EDITED` DATETIME,
  `UPVOTE_COUNT` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VOTE` (
  `ID` INT NOT NULL,
  `SOURCE_TYPE` VARCHAR(50),
  `SOURCE_ITEM_ID` INT,
  `AUTHOR_ID` VARCHAR(50),
  `ACTION` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626673_schema_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626673_schema_v1') AS relationships;
DROP DATABASE `db_626673_schema_v1`;
UNINSTALL EXTENSION vsql_schematron;
