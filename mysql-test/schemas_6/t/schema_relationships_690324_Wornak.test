INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 690324_Wornak
--echo #
CREATE DATABASE `db_690324_Wornak`;
USE `db_690324_Wornak`;

CREATE TABLE `admin` (
  `id` INT,
  `full_name` VARCHAR(64),
  `mail` VARCHAR(64),
  `tel` VARCHAR(64),
  `password` VARCHAR(64),
  `address` VARCHAR(64),
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `company` (
  `id` INT,
  `roles` VARCHAR(64),
  `employees_number` VARCHAR(64),
  `company_name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `doctrine_migration_versions` (
  `version` VARCHAR(64),
  `executed_at` DATETIME,
  `execution_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `job_post` (
  `id` INT,
  `company` VARCHAR(64),
  `job_title` VARCHAR(64),
  `description` VARCHAR(64),
  `reference` VARCHAR(64),
  `exp_date` DATETIME,
  `job_zone` VARCHAR(64),
  `training` VARCHAR(64),
  `contract_type` VARCHAR(64),
  `published_at` DATETIME,
  `salary` INT,
  `sector` VARCHAR(64),
  `study_level_required` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `job_seeker` (
  `id` INT,
  `roles` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `gender` VARCHAR(64),
  `birthday_date` DATETIME,
  `address` VARCHAR(64),
  `mobility` VARCHAR(64),
  `handicap` INT,
  `diploma` VARCHAR(64),
  `skills` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `search_bar` (
  `id` INT,
  `search_content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `activation_token` VARCHAR(64),
  `tel` INT,
  `companies_id` INT,
  `jobseeker_id` INT,
  `uuid` VARCHAR(64),
  `roles` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_690324_Wornak') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_690324_Wornak') AS relationships;
DROP DATABASE `db_690324_Wornak`;
UNINSTALL EXTENSION vsql_schematron;
