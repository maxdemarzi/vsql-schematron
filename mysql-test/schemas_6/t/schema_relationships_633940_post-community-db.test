INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 633940_post-community-db
--echo #
CREATE DATABASE `db_633940_post_community_db`;
USE `db_633940_post_community_db`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `avatar` VARCHAR(50),
  `description` VARCHAR(50),
  `created_date` DATE,
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `wechat_openid` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `topic` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `create_datetime` DATETIME,
  `last_edit_datetime` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_category` (
  `id` INT NOT NULL,
  `post_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_topic` (
  `id` INT NOT NULL,
  `post_id` INT,
  `topic_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `content` TEXT,
  `user_id` INT,
  `post_id` INT,
  `parent_comment_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_633940_post_community_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_633940_post_community_db') AS relationships;
DROP DATABASE `db_633940_post_community_db`;
UNINSTALL EXTENSION vsql_schematron;
