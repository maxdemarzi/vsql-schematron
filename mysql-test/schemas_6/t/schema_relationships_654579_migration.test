INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 654579_migration
--echo #
CREATE DATABASE `db_654579_migration`;
USE `db_654579_migration`;

CREATE TABLE `accounts` (
  `id` INT,
  `provider_type` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `provider_account_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified` DATETIME,
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `queues` (
  `id` INT,
  `key` VARCHAR(64),
  `description` VARCHAR(64),
  `creatorId` INT,
  `ownerId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_654579_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_654579_migration') AS relationships;
DROP DATABASE `db_654579_migration`;
UNINSTALL EXTENSION vsql_schematron;
