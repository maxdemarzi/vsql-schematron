INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655897_M2%20-%20Student-Department%20Queries
--echo #
CREATE DATABASE `db_655897_M2_20_20Student_Department_20Queries`;
USE `db_655897_M2_20_20Student_Department_20Queries`;

CREATE TABLE `Department` (
  `DeptId` INT,
  `DeptCode` VARCHAR(64),
  `DepartmentName` VARCHAR(64),
  PRIMARY KEY (`DeptId`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `RollNo` INT,
  `StudentName` VARCHAR(64),
  `Address` VARCHAR(64),
  `Gender` VARCHAR(64),
  `Age` INT,
  `DeptartmentId` INT,
  PRIMARY KEY (`RollNo`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655897_M2_20_20Student_Department_20Queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655897_M2_20_20Student_Department_20Queries') AS relationships;
DROP DATABASE `db_655897_M2_20_20Student_Department_20Queries`;
UNINSTALL EXTENSION vsql_schematron;
