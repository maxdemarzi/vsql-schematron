INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652946_schema
--echo #
CREATE DATABASE `db_652946_schema`;
USE `db_652946_schema`;
CREATE TABLE `servers` (
  `server_id` INT NOT NULL,
  `server_name` TEXT,
  PRIMARY KEY (`server_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_servers` (
  `user_id` INT,
  `server_id` INT
) CHARACTER SET latin1;
CREATE TABLE `violations` (
  `violation_id` INT NOT NULL,
  `violation_desc` TEXT,
  PRIMARY KEY (`violation_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_violations` (
  `user_id` INT,
  `violation_id` INT,
  `server_id` INT,
  `reason` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652946_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652946_schema') AS relationships;
DROP DATABASE `db_652946_schema`;
UNINSTALL EXTENSION vsql_schematron;
