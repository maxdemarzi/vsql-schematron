INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 640296_assignment4
--echo #
CREATE DATABASE `db_640296_assignment4`;
USE `db_640296_assignment4`;
CREATE TABLE `shop` (
  `shop_no` VARCHAR(50) NOT NULL,
  `shop_name` VARCHAR(50),
  `owner_name` VARCHAR(50),
  PRIMARY KEY (`shop_no`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `cust_no` VARCHAR(50) NOT NULL,
  `cust_name` VARCHAR(50),
  `cust_addr` VARCHAR(50),
  PRIMARY KEY (`cust_no`)
) CHARACTER SET latin1;
CREATE TABLE `sale` (
  `cust_no` VARCHAR(50),
  `shop_no` VARCHAR(50),
  `item` VARCHAR(50),
  `price` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_640296_assignment4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_640296_assignment4') AS relationships;
DROP DATABASE `db_640296_assignment4`;
UNINSTALL EXTENSION vsql_schematron;
