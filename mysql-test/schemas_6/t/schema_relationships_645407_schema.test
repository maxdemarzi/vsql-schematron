INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 645407_schema
--echo #
CREATE DATABASE `db_645407_schema`;
USE `db_645407_schema`;

CREATE TABLE `groups_scanlation` (
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `release_delay` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `groups_scanlation_urls` (
  `group_name` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`group_name`, `url`)
) CHARACTER SET latin1;

CREATE TABLE `languages` (
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `series` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `cover_image` VARCHAR(64),
  `type_name` VARCHAR(64),
  `type_demonym` VARCHAR(64),
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `series_aliases` (
  `series_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`series_id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `series_chapters` (
  `id` INT,
  `series_id` INT,
  `title` VARCHAR(64),
  `chapter_number_absolute` VARCHAR(64),
  `chapter_number_volume` DECIMAL(10,2),
  `volume_number` DECIMAL(10,2),
  `chapter_language` VARCHAR(64),
  `contributor_id` INT,
  `time_uploaded` DATETIME,
  `hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `series_chapters_files` (
  `chapter_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`chapter_id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `series_chapters_groups` (
  `chapter_id` INT,
  `group_name` VARCHAR(64),
  PRIMARY KEY (`chapter_id`, `group_name`)
) CHARACTER SET latin1;

CREATE TABLE `series_ratings` (
  `series_id` INT,
  `user_id` INT,
  `rating` INT,
  PRIMARY KEY (`series_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `series_tags` (
  `series_id` INT,
  `tag_name` VARCHAR(64),
  `tag_namespace` VARCHAR(64),
  PRIMARY KEY (`series_id`, `tag_name`, `tag_namespace`)
) CHARACTER SET latin1;

CREATE TABLE `statuses` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `name` VARCHAR(64),
  `namespace` VARCHAR(64),
  PRIMARY KEY (`name`, `namespace`)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `name` VARCHAR(64),
  `origin_demonym` VARCHAR(64),
  PRIMARY KEY (`name`, `origin_demonym`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password_hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_following_series` (
  `user_id` INT,
  `series_id` INT,
  PRIMARY KEY (`user_id`, `series_id`)
) CHARACTER SET latin1;

CREATE TABLE `users_groups` (
  `user_id` INT,
  `group_name` VARCHAR(64),
  PRIMARY KEY (`user_id`, `group_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_645407_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_645407_schema') AS relationships;
DROP DATABASE `db_645407_schema`;
UNINSTALL EXTENSION vsql_schematron;
