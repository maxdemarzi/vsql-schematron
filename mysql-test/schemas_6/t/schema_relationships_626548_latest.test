INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 626548_latest
--echo #
CREATE DATABASE `db_626548_latest`;
USE `db_626548_latest`;

CREATE TABLE `talk` (
  `id` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `filmed_at` DATETIME,
  `published_at` DATETIME,
  `description` VARCHAR(64),
  `image` VARCHAR(64),
  `languages` VARCHAR(64),
  `media_slug` VARCHAR(64),
  `media_pad` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transcript` (
  `id` INT,
  `en_tsvector` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_626548_latest') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_626548_latest') AS relationships;
DROP DATABASE `db_626548_latest`;
UNINSTALL EXTENSION vsql_schematron;
