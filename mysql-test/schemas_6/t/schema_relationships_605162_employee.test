INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605162_employee
--echo #
CREATE DATABASE `db_605162_employee`;
USE `db_605162_employee`;
CREATE TABLE `employees` (
  `emp_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `role_id` INT,
  `manager_id` INT,
  PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605162_employee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605162_employee') AS relationships;
DROP DATABASE `db_605162_employee`;
UNINSTALL EXTENSION vsql_schematron;
