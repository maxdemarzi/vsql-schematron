INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 623274_postgres
--echo #
CREATE DATABASE `db_623274_postgres`;
USE `db_623274_postgres`;
CREATE TABLE `adventurers` (
  `id` BIGINT NOT NULL,
  `username` CHAR(50),
  `password_hash` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dungeons` (
  `id` BIGINT NOT NULL,
  `name` CHAR(50),
  `level_data` TEXT,
  `adventurer_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `result` (
  `id` BIGINT NOT NULL,
  `dungeon_id` BIGINT,
  `is_win` BOOLEAN,
  `turns` INT,
  `rating` INT,
  `adventurer_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
  `id` BIGINT NOT NULL,
  `adventurer_id` BIGINT,
  `pointintime` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_623274_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_623274_postgres') AS relationships;
DROP DATABASE `db_623274_postgres`;
UNINSTALL EXTENSION vsql_schematron;
