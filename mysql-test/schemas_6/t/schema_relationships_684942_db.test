INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 684942_db
--echo #
CREATE DATABASE `db_684942_db`;
USE `db_684942_db`;

CREATE TABLE `problem_category` (
  `category_id` INT,
  `parent_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `problem` (
  `problem_id` INT,
  `category_id` INT,
  `member_id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `time_limit` INT,
  `reference` VARCHAR(64),
  `hint` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`problem_id`)
) CHARACTER SET latin1;

CREATE TABLE `solve` (
  `solve_id` INT,
  `problem_id` INT,
  `member_id` INT,
  `content` VARCHAR(64),
  `duration` INT,
  `created` DATETIME,
  PRIMARY KEY (`solve_id`)
) CHARACTER SET latin1;

CREATE TABLE `answer` (
  `answer_id` INT,
  `problem_id` INT,
  `member_id` INT,
  `content` VARCHAR(64),
  `reference` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`answer_id`)
) CHARACTER SET latin1;

CREATE TABLE `document_category` (
  `category_id` INT,
  `parent_id` INT,
  `board_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `document` (
  `document_id` INT,
  `board_id` INT,
  `category_id` INT,
  `member_id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `reference` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`document_id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `comment_id` INT,
  `parent_id` INT,
  `member_id` INT,
  `problem_id` INT,
  `answer_id` INT,
  `document_id` INT,
  `content` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_684942_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_684942_db') AS relationships;
DROP DATABASE `db_684942_db`;
UNINSTALL EXTENSION vsql_schematron;
