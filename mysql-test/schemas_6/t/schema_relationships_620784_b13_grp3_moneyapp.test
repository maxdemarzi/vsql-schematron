INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 620784_b13_grp3_moneyapp
--echo #
CREATE DATABASE `db_620784_b13_grp3_moneyapp`;
USE `db_620784_b13_grp3_moneyapp`;
CREATE TABLE `Users` (
  `user_id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `mobile` VARCHAR(50),
  `ic_number` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Transactions` (
  `transaction_id` VARCHAR(50) NOT NULL,
  `transaction_type` VARCHAR(50),
  `user_id` VARCHAR(50),
  `transaction_title` VARCHAR(50),
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_620784_b13_grp3_moneyapp') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_620784_b13_grp3_moneyapp') AS relationships;
DROP DATABASE `db_620784_b13_grp3_moneyapp`;
UNINSTALL EXTENSION vsql_schematron;
