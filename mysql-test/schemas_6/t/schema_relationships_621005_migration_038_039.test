INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 621005_migration_038_039
--echo #
CREATE DATABASE `db_621005_migration_038_039`;
USE `db_621005_migration_038_039`;

CREATE TABLE `AUTHORIZATION_GROUPS` (
  `ID` VARCHAR(255),
  `DBIN_ID` VARCHAR(255),
  `CODE` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `REGISTRATION_TIMESTAMP` DATETIME,
  `PERS_ID_REGISTERER` VARCHAR(255),
  `MODIFICATION_TIMESTAMP` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `AUTHORIZATION_GROUP_PERSONS` (
  `AG_ID` VARCHAR(255),
  `PERS_ID` VARCHAR(255),
  PRIMARY KEY (`PERS_ID`, `AG_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_621005_migration_038_039') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_621005_migration_038_039') AS relationships;
DROP DATABASE `db_621005_migration_038_039`;
UNINSTALL EXTENSION vsql_schematron;
