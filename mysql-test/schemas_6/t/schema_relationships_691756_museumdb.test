INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 691756_museumdb
--echo #
CREATE DATABASE `db_691756_museumdb`;
USE `db_691756_museumdb`;

CREATE TABLE `users` (
  `user_id` INT,
  `name` VARCHAR(255),
  `surname` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `birthday` DATETIME,
  `username` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_rooms` (
  `user_rooms_id` INT,
  `name` VARCHAR(255),
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `visitors` (
  `visitors_id` INT,
  `path` VARCHAR(255),
  `number_visitors` INT,
  `room_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_691756_museumdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_691756_museumdb') AS relationships;
DROP DATABASE `db_691756_museumdb`;
UNINSTALL EXTENSION vsql_schematron;
