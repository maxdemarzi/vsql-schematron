INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 677167_ci4
--echo #
CREATE DATABASE `db_677167_ci4`;
USE `db_677167_ci4`;

CREATE TABLE `contents` (
  `id` INT,
  `judul` VARCHAR(64),
  `deskripsi` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `personal_access_tokens` (
  `id` INT,
  `tokenable_type` VARCHAR(64),
  `tokenable_id` INT,
  `name` VARCHAR(64),
  `token` VARCHAR(64),
  `abilities` VARCHAR(64),
  `last_used_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` VARCHAR(64),
  `user_id` INT,
  `ip_address` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `payload` VARCHAR(64),
  `last_activity` INT
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `personal_team` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `team_invitations` (
  `id` INT,
  `team_id` INT,
  `email` VARCHAR(64),
  `role` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `team_user` (
  `id` INT,
  `team_id` INT,
  `user_id` INT,
  `role` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `turnamen` (
  `id` INT,
  `team` VARCHAR(64),
  `slug` VARCHAR(64),
  `menang` VARCHAR(64),
  `kalah` VARCHAR(64),
  `poin` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `two_factor_secret` VARCHAR(64),
  `two_factor_recovery_codes` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `current_team_id` INT,
  `profile_photo_path` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_677167_ci4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_677167_ci4') AS relationships;
DROP DATABASE `db_677167_ci4`;
UNINSTALL EXTENSION vsql_schematron;
