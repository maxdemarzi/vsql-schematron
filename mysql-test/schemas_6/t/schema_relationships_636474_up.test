INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636474_up
--echo #
CREATE DATABASE `db_636474_up`;
USE `db_636474_up`;
CREATE TABLE `accounts` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `tos_agreed_at` TIMESTAMP NULL,
  `status` VARCHAR(50),
  `public_key` VARCHAR(50),
  `eab_id` VARCHAR(50),
  `eab_protected_header` VARCHAR(50),
  `eab_payload` VARCHAR(50),
  `eab_sig` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_contacts` (
  `id` VARCHAR(50) NOT NULL,
  `account` VARCHAR(50),
  `contact_type` VARCHAR(50),
  `contact_value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636474_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636474_up') AS relationships;
DROP DATABASE `db_636474_up`;
UNINSTALL EXTENSION vsql_schematron;
