INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 636189_init
--echo #
CREATE DATABASE `db_636189_init`;
USE `db_636189_init`;

CREATE TABLE `symptom` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `illness` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `anagraph` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `medicine` (
  `id` INT,
  `name` VARCHAR(255),
  `property` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `symptom_illness` (
  `illness_id` INT,
  `symptom_id` INT
) CHARACTER SET latin1;

CREATE TABLE `illness_anagraph` (
  `illness_id` INT,
  `anagraph_id` INT
) CHARACTER SET latin1;

CREATE TABLE `anagraph_medicine` (
  `anagraph_id` INT,
  `medicine_id` INT,
  `grams` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_636189_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_636189_init') AS relationships;
DROP DATABASE `db_636189_init`;
UNINSTALL EXTENSION vsql_schematron;
