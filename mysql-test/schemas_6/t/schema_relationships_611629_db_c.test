INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611629_db-c
--echo #
CREATE DATABASE `db_611629_db_c`;
USE `db_611629_db_c`;

CREATE TABLE `custom_types` (
  `id` VARCHAR(64),
  `xtype_long_classic` VARCHAR(64),
  `xtype_long_modern` VARCHAR(64),
  `extendsxtype_classic` VARCHAR(64),
  `extendsxtype_modern` VARCHAR(64),
  `name` VARCHAR(64),
  `vendor` VARCHAR(64),
  `description` VARCHAR(64),
  `create_datetime` DATETIME,
  `login` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `custom_types_attributes_integer` (
  `id` VARCHAR(64),
  `property` VARCHAR(64),
  `description` VARCHAR(64),
  `val` INT,
  PRIMARY KEY (`id`, `property`)
) CHARACTER SET latin1;

CREATE TABLE `custom_types_attributes_string` (
  `id` VARCHAR(64),
  `property` VARCHAR(64),
  `description` VARCHAR(64),
  `val` VARCHAR(64),
  PRIMARY KEY (`id`, `property`)
) CHARACTER SET latin1;

CREATE TABLE `custom_types_attributes_boolean` (
  `id` VARCHAR(64),
  `property` VARCHAR(64),
  `description` VARCHAR(64),
  `val` INT,
  PRIMARY KEY (`id`, `property`)
) CHARACTER SET latin1;

CREATE TABLE `extjs_base_types` (
  `id` VARCHAR(64),
  `classname` VARCHAR(64),
  `baseclass` VARCHAR(64),
  `xtype_long_classic` VARCHAR(64),
  `xtype_long_modern` VARCHAR(64),
  `name` VARCHAR(64),
  `vendor` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611629_db_c') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611629_db_c') AS relationships;
DROP DATABASE `db_611629_db_c`;
UNINSTALL EXTENSION vsql_schematron;
