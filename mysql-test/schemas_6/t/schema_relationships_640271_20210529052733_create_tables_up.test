INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 640271_20210529052733-create-tables-up
--echo #
CREATE DATABASE `db_640271_20210529052733_create_tables_up`;
USE `db_640271_20210529052733_create_tables_up`;

CREATE TABLE `public.users` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `created_on` DATETIME,
  `modified_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.meals` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `calories` DECIMAL(10,2),
  `created_by` VARCHAR(64),
  `schedule_time` DATETIME,
  `created_on` DATETIME,
  `modified_by` VARCHAR(64),
  `modified_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_640271_20210529052733_create_tables_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_640271_20210529052733_create_tables_up') AS relationships;
DROP DATABASE `db_640271_20210529052733_create_tables_up`;
UNINSTALL EXTENSION vsql_schematron;
