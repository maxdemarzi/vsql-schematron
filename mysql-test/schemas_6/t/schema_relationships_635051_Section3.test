INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 635051_Section3
--echo #
CREATE DATABASE `db_635051_Section3`;
USE `db_635051_Section3`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
  `id` INT NOT NULL,
  `url` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `photo_id` INT,
  `user_id` INT,
  `contents` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_635051_Section3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_635051_Section3') AS relationships;
DROP DATABASE `db_635051_Section3`;
UNINSTALL EXTENSION vsql_schematron;
