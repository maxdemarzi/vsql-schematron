INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 687402_V1_init
--echo #
CREATE DATABASE `db_687402_V1_init`;
USE `db_687402_V1_init`;

CREATE TABLE `fr.identity` (
  `id` INT,
  `event_id` INT,
  `event_created_at` DATETIME,
  `identity_id` VARCHAR(64),
  `sequence_id` INT,
  `event_occured_at` DATETIME,
  `event_type` VARCHAR(64),
  `party_id` VARCHAR(64),
  `identity_provider_id` VARCHAR(64),
  `identity_class_id` VARCHAR(64),
  `party_contract_id` VARCHAR(64),
  `identity_level_id` VARCHAR(64),
  `identity_challenge_id` VARCHAR(64),
  `identity_effective_chalenge_id` VARCHAR(64),
  `wtime` DATETIME,
  `current` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fr.challenge` (
  `id` INT,
  `event_id` INT,
  `event_created_at` DATETIME,
  `identity_id` VARCHAR(64),
  `sequence_id` INT,
  `event_occured_at` DATETIME,
  `event_type` VARCHAR(64),
  `challenge_id` VARCHAR(64),
  `challenge_class_id` VARCHAR(64),
  `challenge_status` VARCHAR(64),
  `challenge_resolution` VARCHAR(64),
  `challenge_valid_until` DATETIME,
  `wtime` DATETIME,
  `current` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fr.wallet` (
  `id` INT,
  `event_id` INT,
  `event_created_at` DATETIME,
  `wallet_id` VARCHAR(64),
  `sequence_id` INT,
  `event_occured_at` DATETIME,
  `event_type` VARCHAR(64),
