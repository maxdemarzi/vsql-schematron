) CHARACTER SET latin1;

CREATE TABLE `fr.fistful_cash_flow` (
  `id` INT,
  `event_id` INT,
  `event_created_at` DATETIME,
  `source_id` VARCHAR(64),
  `sequence_id` INT,
  `event_occured_at` DATETIME,
  `event_type` VARCHAR(64),
  `obj_id` INT,
  `source_account_type` VARCHAR(64),
  `source_account_type_value` VARCHAR(64),
  `source_account_id` VARCHAR(64),
  `destination_account_type` VARCHAR(64),
  `destination_account_type_value` VARCHAR(64),
  `destination_account_id` VARCHAR(64),
  `amount` INT,
  `currency_code` VARCHAR(64),
  `details` VARCHAR(64),
  `obj_type` VARCHAR(64),
  `wtime` DATETIME,
  `current` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fr.report` (
  `id` INT,
  `party_id` VARCHAR(64),
  `contract_id` VARCHAR(64),
