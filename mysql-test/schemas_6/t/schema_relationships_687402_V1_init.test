CREATE TABLE `fr.file_info` (
  `id` INT,
  `report_id` INT,
  `file_data_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_687402_V1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_687402_V1_init') AS relationships;
DROP DATABASE `db_687402_V1_init`;
UNINSTALL EXTENSION vsql_schematron;
