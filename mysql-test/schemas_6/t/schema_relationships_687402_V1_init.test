  `event_created_at` DATETIME,
  `deposit_id` VARCHAR(64),
  `sequence_id` INT,
  `event_occured_at` DATETIME,
  `event_type` VARCHAR(64),
  `wallet_id` VARCHAR(64),
  `source_id` VARCHAR(64),
  `amount` INT,
  `currency_code` VARCHAR(64),
  `deposit_status` VARCHAR(64),
  `deposit_transfer_status` VARCHAR(64),
