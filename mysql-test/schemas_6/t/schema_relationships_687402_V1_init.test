  `account_id` VARCHAR(64),
  `accounter_account_id` INT,
  `currency_code` VARCHAR(64),
  `party_id` VARCHAR(64),
  `party_contract_id` VARCHAR(64),
  `identity_id` VARCHAR(64),
  `wtime` DATETIME,
  `current` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fr.source` (
  `id` INT,
