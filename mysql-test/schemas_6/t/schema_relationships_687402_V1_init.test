  `resource_bank_card_payment_system` VARCHAR(64),
  `resource_bank_card_bin` VARCHAR(64),
  `resource_bank_card_masked_pan` VARCHAR(64),
  `account_id` VARCHAR(64),
  `accounter_account_id` INT,
  `currency_code` VARCHAR(64),
  `party_id` VARCHAR(64),
  `party_contract_id` VARCHAR(64),
  `identity_id` VARCHAR(64),
  `destination_status` VARCHAR(64),
  `wtime` DATETIME,
  `current` VARCHAR(64),
