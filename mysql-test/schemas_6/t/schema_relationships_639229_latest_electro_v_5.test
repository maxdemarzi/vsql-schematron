CREATE DATABASE `db_639229_latest_electro_v_5`;
USE `db_639229_latest_electro_v_5`;

CREATE TABLE `customer` (
  `Cust_id` INT,
  `First_name` VARCHAR(64),
  `Last_name` VARCHAR(64),
  `Email` VARCHAR(64),
  `Password` VARCHAR(64),
  `Role` VARCHAR(64),
  PRIMARY KEY (`Cust_id`)
) CHARACTER SET latin1;

CREATE TABLE `ebill_monthly_plan` (
  `bill_id` INT,
  `Total_cost_tou` DECIMAL(10,2),
  `Cost_day_time` DECIMAL(10,2),
  `Cost_off_peak_time` DECIMAL(10,2),
  `Cost_peak_time` DECIMAL(10,2),
  `Total_cost_fixed` DECIMAL(10,2),
  `Units_day_time` INT,
  `Units_off_peak_time` INT,
  `Units_peak_time` INT,
  `Total_units` INT,
  `Best_model` VARCHAR(64),
  `Cust_id` INT
) CHARACTER SET latin1;

CREATE TABLE `ebill_special_event_fixed` (
  `bill_id` INT,
  `bill_plan_name` VARCHAR(64),
  `Total_cost_fixed` DECIMAL(10,2),
  `Total_units` DECIMAL(10,2),
  `Cust_id` INT
) CHARACTER SET latin1;

CREATE TABLE `ebill_special_event_tou` (
  `bill_id` INT,
  `bill_plan_name` VARCHAR(64),
