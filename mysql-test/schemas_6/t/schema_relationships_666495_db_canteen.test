INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 666495_db_canteen
--echo #
CREATE DATABASE `db_666495_db_canteen`;
USE `db_666495_db_canteen`;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tbl_admin` (
  `id` INT,
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `photo` VARCHAR(64),
  `password` VARCHAR(64),
  `status` INT,
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_credits` (
  `id` INT,
  `uid` INT,
  `creditamount` DECIMAL(10,2),
  `mac` VARCHAR(64),
  `ip` VARCHAR(64),
  `createdby` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tbl_menucategorys` (
  `id` INT,
  `category` VARCHAR(64),
  `image` VARCHAR(64),
  `ip` VARCHAR(64),
  `mac` VARCHAR(64),
  `admin` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_restmenus` (
  `id` INT,
  `itemid` VARCHAR(64),
  `name` VARCHAR(64),
  `photo` VARCHAR(64),
  `description` VARCHAR(64),
  `price` DECIMAL(10,2),
  `type` INT,
  `status` INT,
  `cid` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tbl_tests` (
  `id` INT,
  `category` VARCHAR(64),
  `ip` VARCHAR(64),
  `mac` VARCHAR(64),
  `admin` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_user` (
  `id` INT,
  `empno` INT,
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `photo` VARCHAR(64),
  `password` VARCHAR(64),
  `otp` INT,
  `otptime` DATETIME,
  `nootp` INT,
  `status` INT,
  `timestamp` DATETIME,
  `insert_at` DATETIME,
  `update_at` DATETIME,
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_666495_db_canteen') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_666495_db_canteen') AS relationships;
DROP DATABASE `db_666495_db_canteen`;
UNINSTALL EXTENSION vsql_schematron;
