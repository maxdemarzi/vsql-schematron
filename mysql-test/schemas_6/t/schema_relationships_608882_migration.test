INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608882_migration
--echo #
CREATE DATABASE `db_608882_migration`;
USE `db_608882_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `name` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `published` BOOLEAN,
  `authorId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Like` (
  `id` VARCHAR(50) NOT NULL,
  `userId` TEXT,
  `postId` TEXT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Token` (
  `id` VARCHAR(50) NOT NULL,
  `userId` TEXT,
  `token` TEXT,
  `type` VARCHAR(50),
  `ExpiresAt` INT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608882_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608882_migration') AS relationships;
DROP DATABASE `db_608882_migration`;
UNINSTALL EXTENSION vsql_schematron;
