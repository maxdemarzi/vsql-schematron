INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 601611_V1__Init_schema_config
--echo #
CREATE DATABASE `db_601611_V1_Init_schema_config`;
USE `db_601611_V1_Init_schema_config`;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `paypal_id` VARCHAR(64),
  `creation_date` DATETIME,
  `card_number` VARCHAR(64),
  `card_type` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `status` VARCHAR(64),
  `link` VARCHAR(64),
  `message` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_products` (
  `order_id` INT,
  `product_id` INT,
  PRIMARY KEY (`order_id`, `product_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_601611_V1_Init_schema_config') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_601611_V1_Init_schema_config') AS relationships;
DROP DATABASE `db_601611_V1_Init_schema_config`;
UNINSTALL EXTENSION vsql_schematron;
