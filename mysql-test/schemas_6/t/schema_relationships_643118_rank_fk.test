INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 643118_rank_fk
--echo #
CREATE DATABASE `db_643118_rank_fk`;
USE `db_643118_rank_fk`;

CREATE TABLE `rank_pk` (
  `col1` DATETIME,
  `col2` DATETIME,
  `col3` DATETIME,
  `col4` DATETIME,
  PRIMARY KEY (`col3`)
) CHARACTER SET latin1;

CREATE TABLE `rank_fk` (
  `col1` INT,
  `col2` VARCHAR(64),
  `col3` DATETIME,
  PRIMARY KEY (`col3`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_643118_rank_fk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_643118_rank_fk') AS relationships;
DROP DATABASE `db_643118_rank_fk`;
UNINSTALL EXTENSION vsql_schematron;
