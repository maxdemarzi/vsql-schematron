INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 634785_bd_biblioteca
--echo #
CREATE DATABASE `db_634785_bd_biblioteca`;
USE `db_634785_bd_biblioteca`;
CREATE TABLE `usuarios` (
  `idUsuario` INT NOT NULL,
  `nombreUsuario` VARCHAR(50),
  `nombre` VARCHAR(50),
  `apellidoPaterno` VARCHAR(50),
  `apellidoMaterno` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`idUsuario`)
) CHARACTER SET latin1;
CREATE TABLE `alumnos` (
  `idAlumno` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellidoPaterno` VARCHAR(50),
  `apellidoMaterno` VARCHAR(50),
  `matricula` VARCHAR(50),
  `deudor` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`idAlumno`)
) CHARACTER SET latin1;
CREATE TABLE `autores` (
  `idAutor` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellidoPaterno` VARCHAR(50),
  `apellidoMaterno` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`idAutor`)
) CHARACTER SET latin1;
CREATE TABLE `categorias` (
  `idCategoria` INT NOT NULL,
  `categoria` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`idCategoria`)
) CHARACTER SET latin1;
CREATE TABLE `editoriales` (
  `idEditorial` INT NOT NULL,
  `editorial` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`idEditorial`)
) CHARACTER SET latin1;
CREATE TABLE `libros` (
  `idLibro` INT NOT NULL,
  `titulo` VARCHAR(50),
  `paginas` INT,
  `descripcion` VARCHAR(50),
  `pais` VARCHAR(50),
  `fechaPublicacion` DATE,
  `idioma` VARCHAR(50),
  `isbn` VARCHAR(50),
  `existencia` INT,
  `idCategoria` INT,
  `idEditorial` INT,
  `status` VARCHAR(50),
  PRIMARY KEY (`idLibro`)
) CHARACTER SET latin1;
CREATE TABLE `prestamos` (
  `idPrestamo` INT NOT NULL,
  `idLibro` INT,
  `idUsuario` INT,
  `idAlumno` INT,
  `fechaPrestamo` DATE,
  `fechaDevolucion` DATE,
  `status` VARCHAR(50),
  PRIMARY KEY (`idPrestamo`)
) CHARACTER SET latin1;
CREATE TABLE `relacion_autoria` (
  `idAutoria` INT NOT NULL,
  `idAutor` INT,
  `idLibro` INT,
  PRIMARY KEY (`idAutoria`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_634785_bd_biblioteca') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_634785_bd_biblioteca') AS relationships;
DROP DATABASE `db_634785_bd_biblioteca`;
UNINSTALL EXTENSION vsql_schematron;
