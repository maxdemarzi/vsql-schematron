INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 602769_s1471412
--echo #
CREATE DATABASE `db_602769_s1471412`;
USE `db_602769_s1471412`;

CREATE TABLE `departments` (
  `departmentID` INT,
  `departmentName` VARCHAR(64),
  `workers` INT,
  PRIMARY KEY (`departmentID`)
) CHARACTER SET latin1;

CREATE TABLE `inventory` (
  `productName` VARCHAR(64),
  `stockQty` INT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`productName`)
) CHARACTER SET latin1;

CREATE TABLE `jobtitles` (
  `jobTitle` VARCHAR(64),
  `departmentID_fk` INT,
  PRIMARY KEY (`jobTitle`)
) CHARACTER SET latin1;

CREATE TABLE `test` (
  `id` INT,
  `name` VARCHAR(64),
  `color` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_602769_s1471412') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_602769_s1471412') AS relationships;
DROP DATABASE `db_602769_s1471412`;
UNINSTALL EXTENSION vsql_schematron;
