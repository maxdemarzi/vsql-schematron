INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605394_create_database
--echo #
CREATE DATABASE `db_605394_create_database`;
USE `db_605394_create_database`;
CREATE TABLE `USERS` (
  `LOGIN_ID` VARCHAR(50) NOT NULL,
  `PASSWORD` VARCHAR(50),
  `ENABLED` BOOLEAN,
  PRIMARY KEY (`LOGIN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHORITIES` (
  `LOGIN_ID` VARCHAR(50),
  `ROLE` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605394_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605394_create_database') AS relationships;
DROP DATABASE `db_605394_create_database`;
UNINSTALL EXTENSION vsql_schematron;
