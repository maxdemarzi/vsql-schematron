INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 691806_uas_pemweb_lab
--echo #
CREATE DATABASE `db_691806_uas_pemweb_lab`;
USE `db_691806_uas_pemweb_lab`;

CREATE TABLE `facilities` (
  `facility_id` VARCHAR(255),
  `facility_name` VARCHAR(255),
  PRIMARY KEY (`facility_id`)
) CHARACTER SET latin1;

CREATE TABLE `hotel_bookings` (
  `id` INT,
  `user_id` VARCHAR(255),
  `booking_id` VARCHAR(255),
  `hotel_id` INT,
  `full_name` VARCHAR(255),
  `phone_number` VARCHAR(255),
  `email` VARCHAR(255),
  `number_of_rooms` INT,
  `duration` INT,
  `check_in` DATETIME,
  `check_out` DATETIME,
  `price_per_day` INT,
  `total_price` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `hotel_facilities` (
  `id` INT,
  `hotel_id` INT,
  `facility_id` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `hotel_list` (
  `id` INT,
  `name` VARCHAR(255),
  `star_rating` INT,
  `number_of_rooms` INT,
  `price_per_day` INT,
  `address` VARCHAR(255),
  `city` VARCHAR(255),
  `province` VARCHAR(255),
  `postal_code` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_accounts` (
  `id` INT,
  `uid` VARCHAR(255),
  `role_id` VARCHAR(255),
  `full_name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `birth_date` DATETIME,
  `phone_number` VARCHAR(255),
  `gender` VARCHAR(255),
  `avatar` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `role_id` VARCHAR(255),
  `role_name` VARCHAR(255),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_691806_uas_pemweb_lab') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_691806_uas_pemweb_lab') AS relationships;
DROP DATABASE `db_691806_uas_pemweb_lab`;
UNINSTALL EXTENSION vsql_schematron;
