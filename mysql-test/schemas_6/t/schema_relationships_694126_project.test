INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 694126_project
--echo #
CREATE DATABASE `db_694126_project`;
USE `db_694126_project`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `films` (
  `id` INT NOT NULL,
  `preview` TEXT,
  `name` VARCHAR(50),
  `description` TEXT,
  `season` INT,
  `seria` INT,
  `place` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(50),
  `description` TEXT,
  `text` TEXT,
  `photo` TEXT,
  `idCategory` INT,
  `timestamp` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `admin` INT,
  `sub` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_694126_project') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_694126_project') AS relationships;
DROP DATABASE `db_694126_project`;
UNINSTALL EXTENSION vsql_schematron;
