INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 649634_project_iomt
--echo #
CREATE DATABASE `db_649634_project_iomt`;
USE `db_649634_project_iomt`;

CREATE TABLE `blood` (
  `blood_id` INT,
  `blood_name` VARCHAR(64),
  PRIMARY KEY (`blood_id`)
) CHARACTER SET latin1;

CREATE TABLE `data` (
  `hid` INT,
  `temp_body` DECIMAL(10,2),
  `spo2` DECIMAL(10,2),
  `heart_rate` DECIMAL(10,2),
  `timeStamp` DATETIME,
  PRIMARY KEY (`hid`, `timeStamp`)
) CHARACTER SET latin1;

CREATE TABLE `patient` (
  `hid` INT,
  `p_Fname` VARCHAR(64),
  `p_Lname` INT,
  `dob` DATETIME,
  `blood` INT
) CHARACTER SET latin1;

CREATE TABLE `patient_mass` (
  `hid` INT,
  `weight` DECIMAL(10,2),
  `height` DECIMAL(10,2),
  `timeStamp` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_649634_project_iomt') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_649634_project_iomt') AS relationships;
DROP DATABASE `db_649634_project_iomt`;
UNINSTALL EXTENSION vsql_schematron;
