INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 655740_employees
--echo #
CREATE DATABASE `db_655740_employees`;
USE `db_655740_employees`;

CREATE TABLE `employees` (
  `id` INT,
  `name` VARCHAR(64),
  `manager_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `managers` (
  `id` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `company_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `companies` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_655740_employees') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_655740_employees') AS relationships;
DROP DATABASE `db_655740_employees`;
UNINSTALL EXTENSION vsql_schematron;
