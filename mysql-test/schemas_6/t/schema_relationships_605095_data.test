INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605095_data
--echo #
CREATE DATABASE `db_605095_data`;
USE `db_605095_data`;

CREATE TABLE `category` (
  `idCategory` INT,
  `designationCategory` VARCHAR(64),
  PRIMARY KEY (`idCategory`)
) CHARACTER SET latin1;

CREATE TABLE `Produit` (
  `idProduit` INT,
  `idCategory` INT,
  `designation` VARCHAR(64),
  `prixUnitaire` DECIMAL(10,2),
  `quantite` INT,
  PRIMARY KEY (`idProduit`)
) CHARACTER SET latin1;

CREATE TABLE `admin` (
  `idAdmin` INT,
  `nomAdmin` VARCHAR(64),
  `motDePasse` VARCHAR(64),
  PRIMARY KEY (`idAdmin`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `idCustomer` INT,
  `nameCustomer` VARCHAR(64),
  `sexe` VARCHAR(64),
  `region` VARCHAR(64),
  `age` INT,
  `montant` DECIMAL(10,2),
  PRIMARY KEY (`idCustomer`)
) CHARACTER SET latin1;

CREATE TABLE `Caisse` (
  `idCaisse` INT,
  PRIMARY KEY (`idCaisse`)
) CHARACTER SET latin1;

CREATE TABLE `Achat` (
  `idAchat` INT,
  `idCaisse` INT,
  `idProduit` VARCHAR(64),
  `quantite` INT,
  PRIMARY KEY (`idAchat`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605095_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605095_data') AS relationships;
DROP DATABASE `db_605095_data`;
UNINSTALL EXTENSION vsql_schematron;
