INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 632553_sentences
--echo #
CREATE DATABASE `db_632553_sentences`;
USE `db_632553_sentences`;
CREATE TABLE `categories` (
  `category_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `product_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `unit` VARCHAR(50),
  `content` VARCHAR(50),
  `category_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `costumers` (
  `costumer_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `surnames` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  `phone` VARCHAR(50),
  `address` VARCHAR(50),
  `birthdate` DATE,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`costumer_id`)
) CHARACTER SET latin1;
CREATE TABLE `product_by_purchase` (
  `purchase_id` VARCHAR(50),
  `product_id` VARCHAR(50),
  `amount` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_632553_sentences') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_632553_sentences') AS relationships;
DROP DATABASE `db_632553_sentences`;
UNINSTALL EXTENSION vsql_schematron;
