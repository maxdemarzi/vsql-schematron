INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 652829_migration
--echo #
CREATE DATABASE `db_652829_migration`;
USE `db_652829_migration`;
CREATE TABLE `Archive` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `name` TEXT,
  `year` TEXT,
  `madeAt` TEXT,
  `builtWith` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Link` (
  `id` VARCHAR(50) NOT NULL,
  `archiveID` TEXT,
  `type` VARCHAR(50),
  `link` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_652829_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_652829_migration') AS relationships;
DROP DATABASE `db_652829_migration`;
UNINSTALL EXTENSION vsql_schematron;
