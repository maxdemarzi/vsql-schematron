INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 624348_schema-002
--echo #
CREATE DATABASE `db_624348_schema_002`;
USE `db_624348_schema_002`;

CREATE TABLE `EXPERIMENTS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAMPLES` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `EXPE_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATA_SETS` (
  `ID` INT,
  `PERM_ID` VARCHAR(64),
  `EXPE_ID` VARCHAR(64),
  `SAMP_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EIC_MS_RUNS` (
  `ID` INT,
  `EXPE_ID` VARCHAR(64),
  `SAMP_ID` VARCHAR(64),
  `DS_ID` VARCHAR(64),
  `RAW_DATA_FILE_NAME` VARCHAR(64),
  `RAW_DATA_FILE_PATH` VARCHAR(64),
  `ACQUISITION_DATE` DATETIME,
  `INSTRUMENT_TYPE` VARCHAR(64),
  `INSTRUMENT_MANUFACTURER` VARCHAR(64),
  `INSTRUMENT_MODEL` VARCHAR(64),
  `METHOD_IONISATION` VARCHAR(64),
  `METHOD_SEPARATION` VARCHAR(64),
  `OPERATOR` VARCHAR(64),
  `MS_RUN_ID` INT,
  `SET_ID` VARCHAR(64),
  `START_TIME` DECIMAL(10,2),
  `END_TIME` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EIC_CHROMATOGRAMS` (
  `ID` INT,
  `EIC_MS_RUN_ID` VARCHAR(64),
  `Q1_MZ` DECIMAL(10,2),
  `Q3_LOW_MZ` DECIMAL(10,2),
  `Q3_HIGH_MZ` DECIMAL(10,2),
  `LABEL` VARCHAR(64),
  `POLARITY` VARCHAR(64),
  `RUN_TIMES` VARCHAR(64),
  `INTENSITIES` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FIA_MS_RUNS` (
  `ID` INT,
  `EXPE_ID` VARCHAR(64),
  `SAMP_ID` VARCHAR(64),
  `DS_ID` VARCHAR(64),
  `RAW_DATA_FILE_NAME` VARCHAR(64),
  `RAW_DATA_FILE_PATH` VARCHAR(64),
  `ACQUISITION_DATE` DATETIME,
  `INSTRUMENT_TYPE` VARCHAR(64),
  `INSTRUMENT_MANUFACTURER` VARCHAR(64),
  `INSTRUMENT_MODEL` VARCHAR(64),
  `METHOD_IONISATION` VARCHAR(64),
  `METHOD_SEPARATION` VARCHAR(64),
  `POLARITY` VARCHAR(64),
  `LOW_MZ` DECIMAL(10,2),
  `HIGH_MZ` DECIMAL(10,2),
  `INTERNAL_STANDARD` DECIMAL(10,2),
  `OD` DECIMAL(10,2),
  `OPERATOR` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FIA_PROFILES` (
  `ID` INT,
  `FIA_MS_RUN_ID` VARCHAR(64),
  `LOW_MZ` DECIMAL(10,2),
  `HIGH_MZ` DECIMAL(10,2),
  `MZ` VARCHAR(64),
  `INTENSITIES` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FIA_CENTROIDS` (
  `ID` INT,
  `FIA_MS_RUN_ID` VARCHAR(64),
  `MZ` DECIMAL(10,2),
  `INTENSITY` DECIMAL(10,2),
  `CORRELATION` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EVENTS` (
  `LAST_SEEN_DELETION_EVENT_ID` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_624348_schema_002') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_624348_schema_002') AS relationships;
DROP DATABASE `db_624348_schema_002`;
UNINSTALL EXTENSION vsql_schematron;
