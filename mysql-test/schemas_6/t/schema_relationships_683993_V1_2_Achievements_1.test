INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 683993_V1_2__Achievements_1
--echo #
CREATE DATABASE `db_683993_V1_2_Achievements_1`;
USE `db_683993_V1_2_Achievements_1`;

CREATE TABLE `achievement_details` (
  `identifier` VARCHAR(64),
  `achievement_type` VARCHAR(64),
  `rarity` VARCHAR(64),
  `image_url` VARCHAR(64),
  `value_number` INT,
  `value_string` VARCHAR(64),
  PRIMARY KEY (`identifier`)
) CHARACTER SET latin1;

CREATE TABLE `achievements` (
  `achievement_id` INT,
  `identifier` VARCHAR(64),
  `profile_id` INT,
  `award_date` DATETIME,
  PRIMARY KEY (`achievement_id`)
) CHARACTER SET latin1;

CREATE TABLE `localized_texts` (
  `text_id` INT,
  `lang` VARCHAR(64),
  `text` VARCHAR(64),
  `achievement_name` VARCHAR(64),
  `achievement_description` VARCHAR(64),
  PRIMARY KEY (`text_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_683993_V1_2_Achievements_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_683993_V1_2_Achievements_1') AS relationships;
DROP DATABASE `db_683993_V1_2_Achievements_1`;
UNINSTALL EXTENSION vsql_schematron;
