INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 614860_file
--echo #
CREATE DATABASE `db_614860_file`;
USE `db_614860_file`;
CREATE TABLE `Product` (
  `pid` INT NOT NULL,
  `bid` VARCHAR(50),
  `pname` VARCHAR(50),
  `unit_price` DOUBLE,
  `sid` INT,
  `cid` INT,
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `Store` (
  `sid` INT NOT NULL,
  `store_name` VARCHAR(50),
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
  `cid` INT NOT NULL,
  `cname` VARCHAR(50),
  `subc_name` VARCHAR(50),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `Supplier` (
  `supplier_id` INT NOT NULL,
  `supplier_name` VARCHAR(50),
  `sid` INT,
  `pid` INT,
  PRIMARY KEY (`supplier_id`)
) CHARACTER SET latin1;
CREATE TABLE `Sale` (
  `sales_id` INT NOT NULL,
  `date` DATE,
  `quantity` INT,
  `sid` INT,
  `pid` INT,
  PRIMARY KEY (`sales_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_614860_file') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_614860_file') AS relationships;
DROP DATABASE `db_614860_file`;
UNINSTALL EXTENSION vsql_schematron;
