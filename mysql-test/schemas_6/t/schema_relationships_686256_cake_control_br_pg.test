INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 686256_cake_control_br_pg
--echo #
CREATE DATABASE `db_686256_cake_control_br_pg`;
USE `db_686256_cake_control_br_pg`;

CREATE TABLE `groups` (
  `id` INT,
  `name` VARCHAR(255),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `group_id` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `group_id` INT,
  `controller` VARCHAR(255),
  `action` VARCHAR(255),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `name` VARCHAR(255),
  `birthday` DATETIME,
  `phone` VARCHAR(255),
  `user_id` INT,
  `observation` VARCHAR(255),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_686256_cake_control_br_pg') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_686256_cake_control_br_pg') AS relationships;
DROP DATABASE `db_686256_cake_control_br_pg`;
UNINSTALL EXTENSION vsql_schematron;
