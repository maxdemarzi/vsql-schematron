INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 605027_V1.0__init
--echo #
CREATE DATABASE `db_605027_V1_0__init`;
USE `db_605027_V1_0__init`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `dob` DATE,
  `create_date` DATETIME,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trails` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `start_time` TIME,
  `end_time` TIME,
  `lower_age` INT,
  `upper_age` INT,
  `price` DOUBLE,
  `create_date` DATETIME,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings` (
  `id` BIGINT NOT NULL,
  `trail_id` BIGINT,
  `user_id` BIGINT,
  `start_time` TIME,
  `end_time` TIME,
  `booking_date` DATE,
  `booking_status` VARCHAR(50),
  `create_date` DATETIME,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookings_users_mapping` (
  `booking_id` BIGINT,
  `user_id` BIGINT,
  `create_date` DATETIME,
  `update_date` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_605027_V1_0__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_605027_V1_0__init') AS relationships;
DROP DATABASE `db_605027_V1_0__init`;
UNINSTALL EXTENSION vsql_schematron;
