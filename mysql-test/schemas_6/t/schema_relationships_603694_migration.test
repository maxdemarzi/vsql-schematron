INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 603694_migration
--echo #
CREATE DATABASE `db_603694_migration`;
USE `db_603694_migration`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `avatar` TEXT,
  `full_name` TEXT,
  `email` TEXT,
  `passcode` TEXT,
  `tell` TEXT,
  `address` TEXT,
  `phone` TEXT,
  `status` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_category` (
  `id` INT NOT NULL,
  `account_id` INT,
  `code` TEXT,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_post` (
  `id` INT NOT NULL,
  `code` TEXT,
  `name` TEXT,
  `title` TEXT,
  `category_id` INT,
  `status` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_603694_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_603694_migration') AS relationships;
DROP DATABASE `db_603694_migration`;
UNINSTALL EXTENSION vsql_schematron;
