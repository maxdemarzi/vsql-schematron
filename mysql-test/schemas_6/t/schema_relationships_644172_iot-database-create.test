INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 644172_iot-database-create
--echo #
CREATE DATABASE `db_644172_iot_database_create`;
USE `db_644172_iot_database_create`;
CREATE TABLE `mydb.IotDevice` (
  `deviceId` INT NOT NULL,
  `name` VARCHAR(50),
  `serialNumber` VARCHAR(50),
  `type` VARCHAR(50),
  `model` VARCHAR(50),
  `manufacturer` VARCHAR(50),
  PRIMARY KEY (`deviceId`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.DeviceInfo` (
  `id` INT NOT NULL,
  `version` INT,
  `posX` INT,
  `posY` INT,
  `deviceId` INT,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_644172_iot_database_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_644172_iot_database_create') AS relationships;
DROP DATABASE `db_644172_iot_database_create`;
UNINSTALL EXTENSION vsql_schematron;
