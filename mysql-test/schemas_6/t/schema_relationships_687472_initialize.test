INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 687472_initialize
--echo #
CREATE DATABASE `db_687472_initialize`;
USE `db_687472_initialize`;

CREATE TABLE `location` (
  `uuid` VARCHAR(255),
  `order_id` VARCHAR(255),
  `x` DECIMAL(10,2),
  `y` DECIMAL(10,2),
  `time` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `order_include` (
  `dish_id` VARCHAR(255),
  `order_id` VARCHAR(255),
  `amount` INT,
  `attribute` VARCHAR(255),
  PRIMARY KEY (`dish_id`, `order_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` VARCHAR(255),
  `username` VARCHAR(255),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `score` (
  `use_username` VARCHAR(255),
  `username` VARCHAR(255),
  `score` DECIMAL(10,2),
  `comment` VARCHAR(255),
  `img` VARCHAR(255),
  `type` INT,
  PRIMARY KEY (`use_username`, `username`)
) CHARACTER SET latin1;

CREATE TABLE `score_dish` (
  `username` VARCHAR(255),
  `dish_id` VARCHAR(255),
  `grade` DECIMAL(10,2),
  `comment` VARCHAR(255),
  `img` VARCHAR(255),
  PRIMARY KEY (`username`, `dish_id`)
) CHARACTER SET latin1;

CREATE TABLE `store` (
  `store_id` VARCHAR(255),
  `username` VARCHAR(255),
  `address` VARCHAR(255),
  `s_phone` VARCHAR(255),
  PRIMARY KEY (`store_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `username` VARCHAR(255),
  `role` VARCHAR(255),
  `phone` VARCHAR(255),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_attributes` (
  `username` VARCHAR(255),
  `balance` DECIMAL(10,2),
  `look_count` DECIMAL(10,2),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_orders` (
  `username` VARCHAR(255),
  `order_id` VARCHAR(255),
  `state` VARCHAR(255),
  `reciever` VARCHAR(255),
  `recieve_address` VARCHAR(255),
  `r_phone` VARCHAR(255),
  PRIMARY KEY (`username`, `order_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_687472_initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_687472_initialize') AS relationships;
DROP DATABASE `db_687472_initialize`;
UNINSTALL EXTENSION vsql_schematron;
