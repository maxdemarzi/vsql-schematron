INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 621270_db
--echo #
CREATE DATABASE `db_621270_db`;
USE `db_621270_db`;
CREATE TABLE `wp_elberos_forms` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `api_name` VARCHAR(50),
  `settings` TEXT,
  `email_to` VARCHAR(50),
  `is_deleted` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wp_elberos_forms_data` (
  `id` BIGINT NOT NULL,
  `form_id` BIGINT,
  `form_title` VARCHAR(50),
  `data` TEXT,
  `utm` TEXT,
  `send_email_uuid` VARCHAR(50),
  `send_email_code` TINYINT,
  `send_email_error` VARCHAR(50),
  `gmtime_add` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_621270_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_621270_db') AS relationships;
DROP DATABASE `db_621270_db`;
UNINSTALL EXTENSION vsql_schematron;
