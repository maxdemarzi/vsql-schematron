INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 676509_rukun_warga
--echo #
CREATE DATABASE `db_676509_rukun_warga`;
USE `db_676509_rukun_warga`;

CREATE TABLE `tb_berita` (
  `Berita_Id` INT,
  `Berita_Judul` VARCHAR(64),
  `Berita_Konten` VARCHAR(64),
  `Berita_Img` VARCHAR(64),
  `Berita_UpdateId` INT,
  `Berita_UpdateTime` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tb_keuangan` (
  `Transaksi_ID` INT,
  `Transaksi_Penerima` VARCHAR(64),
  `Transaksi_Flag` VARCHAR(64),
  `Transaksi_Value` INT,
  `Transaksi_Keterangan` VARCHAR(64),
  `Transaksi_Tanggal` DATETIME,
  `Transaksi_UpdateId` INT,
  `Transaksi_UpdateTime` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tb_kk_detail` (
  `KKD_ID` INT,
  `KKD_IdHeader` INT,
  `KKD_Nama` VARCHAR(64),
  `KKD_NIK` VARCHAR(64),
  `KKD_Jk` VARCHAR(64),
  `KKD_TmpLahir` VARCHAR(64),
  `KKD_TglLahir` DATETIME,
  `KKD_Agama` VARCHAR(64),
  `KKD_Pendidikan` VARCHAR(64),
  `KKD_Pekerjaan` VARCHAR(64),
  `KKD_UpdateID` INT,
  `KKD_UpdateTime` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tb_kk_header` (
  `KKH_ID` INT,
  `KKH_NoKK` VARCHAR(64),
  `KKH_KepalaKK` VARCHAR(64),
  `KKH_Tlp` VARCHAR(64),
  `KKH_Alamat` VARCHAR(64),
  `KKH_DomisiliYN` VARCHAR(64),
  `KKH_Status` VARCHAR(64),
  `KKH_UpdateID` INT,
  `KKH_UpdateTime` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tb_surat` (
  `Surat_ID` INT,
  `Surat_Numb` VARCHAR(64),
  `Surat_IdKKD` INT,
  `Surat_Keperluan` VARCHAR(64),
  `Surat_Pengajuan` INT,
  `Surat_TglPengajuan` DATETIME,
  `Surat_PrintYN` VARCHAR(64),
  `Surat_UpdateID` INT,
  `Surat_UpdateTime` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tb_users` (
  `User_Id` INT,
  `User_Email` VARCHAR(64),
  `User_Username` VARCHAR(64),
  `User_Password` VARCHAR(64),
  `User_Akses` VARCHAR(64),
  PRIMARY KEY (`User_Id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_visimisi` (
  `Visimisi_ID` INT,
  `Visimisi_Visi` VARCHAR(64),
  `Visimisi_Misi` VARCHAR(64),
  `Visimisi_UpdateId` INT,
  `Visimisi_UpdateTime` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_676509_rukun_warga') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_676509_rukun_warga') AS relationships;
DROP DATABASE `db_676509_rukun_warga`;
UNINSTALL EXTENSION vsql_schematron;
