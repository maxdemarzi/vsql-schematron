INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 611657_exams
--echo #
CREATE DATABASE `db_611657_exams`;
USE `db_611657_exams`;
CREATE TABLE `exams` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` INT NOT NULL,
  `desc` TEXT,
  `correct` INT,
  `exam_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
  `id` INT NOT NULL,
  `name` TEXT,
  `question_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_611657_exams') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_611657_exams') AS relationships;
DROP DATABASE `db_611657_exams`;
UNINSTALL EXTENSION vsql_schematron;
