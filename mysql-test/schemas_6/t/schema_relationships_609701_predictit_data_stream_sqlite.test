INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 609701_predictit_data_stream_sqlite
--echo #
CREATE DATABASE `db_609701_predictit_data_stream_sqlite`;
USE `db_609701_predictit_data_stream_sqlite`;

CREATE TABLE `market` (
  `marketId` INT,
  `name` VARCHAR(255),
  `sortName` VARCHAR(255),
  `url` VARCHAR(255),
  `imageUrl` VARCHAR(255),
  `dateEnd` DATETIME,
  PRIMARY KEY (`marketId`)
) CHARACTER SET latin1;

CREATE TABLE `contract` (
  `imageUrl` VARCHAR(255),
  `contractId` INT,
  `marketId` INT,
  `contractName` VARCHAR(255),
  `contractShortName` VARCHAR(255),
  `dateEnd` DATETIME,
  PRIMARY KEY (`contractId`)
) CHARACTER SET latin1;

CREATE TABLE `querySource` (
  `querySourceId` INT,
  `name` VARCHAR(255),
  `shortName` VARCHAR(255),
  PRIMARY KEY (`querySourceId`)
) CHARACTER SET latin1;

CREATE TABLE `marketNotExist` (
  `marketId` INT,
  `querySourceId` INT,
  PRIMARY KEY (`marketId`, `querySourceId`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `imageUrl` VARCHAR(255),
  `image` VARCHAR(255),
  `type` VARCHAR(255),
  PRIMARY KEY (`imageUrl`)
) CHARACTER SET latin1;

CREATE TABLE `marketObservation` (
  `dateTimeStamp` DATETIME,
  `contractId` INT,
  `contractStatus` VARCHAR(255),
  `marketId` INT,
  `marketStatus` VARCHAR(255),
  `lastTradePrice` DECIMAL(10,2),
  `bestBuyYesCost` DECIMAL(10,2),
  `bestBuyNoCost` DECIMAL(10,2),
  `bestSellYesCost` DECIMAL(10,2),
  `bestSellNoCost` DECIMAL(10,2),
  `lastClosePrice` DECIMAL(10,2),
  `displayOrder` INT,
  `querySourceId` INT,
  PRIMARY KEY (`dateTimeStamp`, `contractId`, `querySourceId`)
) CHARACTER SET latin1;

CREATE TABLE `marketChartData` (
  `marketId` INT,
  `contractId` INT,
  `dateTimeStamp` DATETIME,
  `querySourceId` INT,
  `openSharePrice` DECIMAL(10,2),
  `highSharePrice` DECIMAL(10,2),
  `lowSharePrice` DECIMAL(10,2),
  `closeSharePrice` DECIMAL(10,2),
  `tradeVolume` DECIMAL(10,2),
  PRIMARY KEY (`contractId`, `dateTimeStamp`, `querySourceId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_609701_predictit_data_stream_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_609701_predictit_data_stream_sqlite') AS relationships;
DROP DATABASE `db_609701_predictit_data_stream_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
