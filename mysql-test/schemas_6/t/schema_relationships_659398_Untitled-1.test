INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 659398_Untitled-1
--echo #
CREATE DATABASE `db_659398_Untitled_1`;
USE `db_659398_Untitled_1`;
CREATE TABLE `cliente` (
  `codcliente` INT NOT NULL,
  `nome` VARCHAR(50),
  `endereco` VARCHAR(50),
  `cidade` VARCHAR(50),
  `estado` VARCHAR(50),
  `telefone` INT,
  `cpf` INT,
  `rg` INT,
  PRIMARY KEY (`codcliente`)
) CHARACTER SET latin1;
CREATE TABLE `conta` (
  `codconta` INT NOT NULL,
  `tipo` VARCHAR(50),
  `saldo` INT,
  `codagencia` INT,
  `codcliente` INT,
  PRIMARY KEY (`codconta`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_659398_Untitled_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_659398_Untitled_1') AS relationships;
DROP DATABASE `db_659398_Untitled_1`;
UNINSTALL EXTENSION vsql_schematron;
