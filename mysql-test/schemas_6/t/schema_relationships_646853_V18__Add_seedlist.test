INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 646853_V18__Add_seedlist
--echo #
CREATE DATABASE `db_646853_V18__Add_seedlist`;
USE `db_646853_V18__Add_seedlist`;
CREATE TABLE `seedlist` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `total_seeds` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `seed` (
  `id` BIGINT NOT NULL,
  `url` VARCHAR(50),
  `surt` VARCHAR(50),
  `seedlist_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_646853_V18__Add_seedlist') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_646853_V18__Add_seedlist') AS relationships;
DROP DATABASE `db_646853_V18__Add_seedlist`;
UNINSTALL EXTENSION vsql_schematron;
