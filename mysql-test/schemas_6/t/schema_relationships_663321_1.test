INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 663321_1
--echo #
CREATE DATABASE `db_663321_1`;
USE `db_663321_1`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `friendcode` VARCHAR(64),
  `enabled` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_friends` (
  `id` INT,
  `user_1` INT,
  `user_2` INT,
  `bestfriend` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `applied` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_663321_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_663321_1') AS relationships;
DROP DATABASE `db_663321_1`;
UNINSTALL EXTENSION vsql_schematron;
