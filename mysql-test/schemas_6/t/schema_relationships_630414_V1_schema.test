INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 630414_V1__schema
--echo #
CREATE DATABASE `db_630414_V1_schema`;
USE `db_630414_V1_schema`;

CREATE TABLE `COMMUNITY` (
  `ID` INT,
  `UUID` VARCHAR(64),
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ACCOUNT` (
  `ID` INT,
  `LOGIN` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MEMBER` (
  `ACCOUNTID` INT,
  `COMMUNITYID` INT,
  `ROLE` VARCHAR(64),
  PRIMARY KEY (`ACCOUNTID`, `COMMUNITYID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTRIBUTION` (
  `ID` INT,
  `TIMESTAMP` DATETIME,
  `ACCOUNTID` INT,
  `COMMUNITYID` INT,
  `UUID` VARCHAR(64),
  `URL` VARCHAR(64),
  `STATUS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FEEDBACK` (
  `ID` INT,
  `TIMESTAMP` DATETIME,
  `ACCOUNTID` INT,
  `CONTRIBUTIONID` INT,
  `UUID` VARCHAR(64),
  `URL` VARCHAR(64),
  `STATUS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_630414_V1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_630414_V1_schema') AS relationships;
DROP DATABASE `db_630414_V1_schema`;
UNINSTALL EXTENSION vsql_schematron;
