INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 601085_DDL_DML_Productos
--echo #
CREATE DATABASE `db_601085_DDL_DML_Productos`;
USE `db_601085_DDL_DML_Productos`;
CREATE TABLE `Empresa` (
  `ID_Empresa` INT NOT NULL,
  `Nombre` VARCHAR(50),
  `NIT` VARCHAR(50),
  `Fecha_Fundacion` DATETIME,
  `Antiguedad` INT,
  PRIMARY KEY (`ID_Empresa`)
) CHARACTER SET latin1;
CREATE TABLE `Producto` (
  `ID_Producto` INT NOT NULL,
  `Nombre` VARCHAR(50),
  `ID_Empresa` INT,
  PRIMARY KEY (`ID_Producto`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_601085_DDL_DML_Productos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_601085_DDL_DML_Productos') AS relationships;
DROP DATABASE `db_601085_DDL_DML_Productos`;
UNINSTALL EXTENSION vsql_schematron;
