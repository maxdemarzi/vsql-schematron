INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 622542_tables
--echo #
CREATE DATABASE `db_622542_tables`;
USE `db_622542_tables`;
CREATE TABLE `mesa_resultado` (
  `id_mesaResultado` INT NOT NULL,
  `num_mesa` INT,
  `cnt_oficial` INT,
  `cnt_a` INT,
  `cnt_b` INT,
  `cnt_blanco` INT,
  `cnt_nulo` INT,
  PRIMARY KEY (`id_mesaResultado`)
) CHARACTER SET latin1;
CREATE TABLE `mesa` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `dni` INT,
  `votoRealizado` TINYINT,
  `pertenecePartido` TINYINT,
  `mesa` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `nick` VARCHAR(50),
  `clave` VARCHAR(50),
  `habilitado` TINYINT,
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `cliente` (
  `id_cliente` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  `id_usuario` INT,
  `email` VARCHAR(50),
  PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_622542_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_622542_tables') AS relationships;
DROP DATABASE `db_622542_tables`;
UNINSTALL EXTENSION vsql_schematron;
