INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 633905_MemberSQL
--echo #
CREATE DATABASE `db_633905_MemberSQL`;
USE `db_633905_MemberSQL`;

CREATE TABLE `MemberStatus` (
  `memberStatusID` INT,
  `memberStatusType` VARCHAR(64),
  PRIMARY KEY (`memberStatusID`)
) CHARACTER SET latin1;

CREATE TABLE `Member` (
  `memberID` INT,
  `lastName` VARCHAR(64),
  `fisrtName` VARCHAR(64),
  `middleName` VARCHAR(64),
  `preferredName` VARCHAR(64),
  `callSign` VARCHAR(64),
  `dob` DATETIME,
  `sarEmail` VARCHAR(64),
  `personalEmail` VARCHAR(64),
  `dlNuber` VARCHAR(64),
  `dlState` VARCHAR(64),
  `ssnLastFour` INT,
  `createdDate` DATETIME,
  `lastUpdate` DATETIME,
  `memberStatusID` INT,
  PRIMARY KEY (`memberID`)
) CHARACTER SET latin1;

CREATE TABLE `MemberTenure` (
  `memberTenureID` INT,
  `startDate` DATETIME,
  `endDate` DATETIME,
  `createdDate` DATETIME,
  `lastUpdate` DATETIME,
  `memberID` INT,
  `createdBy` INT,
  `lastUpdateBy` INT,
  PRIMARY KEY (`memberTenureID`)
) CHARACTER SET latin1;

CREATE TABLE `MemberAddress` (
  `memberAddressID` INT,
  `street1` VARCHAR(64),
  `street2` VARCHAR(64),
  `street3` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `createdDate` DATETIME,
  `lastUpdate` DATETIME,
  `memberID` INT,
  `createdBy` INT,
  `lastUpdateBy` INT,
  PRIMARY KEY (`memberAddressID`)
) CHARACTER SET latin1;

CREATE TABLE `MemberEmergencyContact` (
  `memberEmergencyContactID` INT,
  `contactFullName` VARCHAR(64),
  `contactCellPhone` VARCHAR(64),
  `contactHomePhone` VARCHAR(64),
  `createdDate` DATETIME,
  `lastUpdate` DATETIME,
  `memberID` INT,
  `createdBy` INT,
  `lastUpdateBy` INT,
  PRIMARY KEY (`memberEmergencyContactID`)
) CHARACTER SET latin1;

CREATE TABLE `MemberPhone` (
  `memberPhoneID` INT,
  `phoneType` VARCHAR(64),
  `phoneNumber` VARCHAR(64),
  `isPrimary` BOOL,
  `createdDate` DATETIME,
  `lastUpdate` DATETIME,
  `memberID` INT,
  `createdBy` INT,
  `lastUpdateBy` INT,
  PRIMARY KEY (`memberPhoneID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_633905_MemberSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_633905_MemberSQL') AS relationships;
DROP DATABASE `db_633905_MemberSQL`;
UNINSTALL EXTENSION vsql_schematron;
