INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 612138_211%20Disabled%20Overrides
--echo #
CREATE DATABASE `db_612138_211_20Disabled_20Overrides`;
USE `db_612138_211_20Disabled_20Overrides`;
CREATE TABLE `override_type` (
  `uniqueid` DECIMAL(10,2) NOT NULL,
  `reference` VARCHAR(50),
  `label` VARCHAR(50),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;
CREATE TABLE `disabled_override` (
  `course_id` DECIMAL(10,2) NOT NULL,
  `type_id` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`course_id`, `type_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_612138_211_20Disabled_20Overrides') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_612138_211_20Disabled_20Overrides') AS relationships;
DROP DATABASE `db_612138_211_20Disabled_20Overrides`;
UNINSTALL EXTENSION vsql_schematron;
