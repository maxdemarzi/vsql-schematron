INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 602620_migration
--echo #
CREATE DATABASE `db_602620_migration`;
USE `db_602620_migration`;
CREATE TABLE `Webhook` (
  `id` INT NOT NULL,
  `key` TEXT,
  `url` TEXT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
  `id` INT NOT NULL,
  `webhookId` INT,
  `platform` TEXT,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_602620_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_602620_migration') AS relationships;
DROP DATABASE `db_602620_migration`;
UNINSTALL EXTENSION vsql_schematron;
