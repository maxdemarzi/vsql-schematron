INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 608264_sql_dump
--echo #
CREATE DATABASE `db_608264_sql_dump`;
USE `db_608264_sql_dump`;

CREATE TABLE `Users` (
  `id` INT,
  `display_name` VARCHAR(64),
  `slack_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Stories` (
  `id` INT,
  `max_lines` INT,
  `locked` BOOL,
  `locked_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `StoryLines` (
  `id` INT,
  `author` INT,
  `story` INT,
  `line_idx` INT,
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_608264_sql_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_608264_sql_dump') AS relationships;
DROP DATABASE `db_608264_sql_dump`;
UNINSTALL EXTENSION vsql_schematron;
