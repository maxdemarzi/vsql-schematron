INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 614330_property
--echo #
CREATE DATABASE `db_614330_property`;
USE `db_614330_property`;

CREATE TABLE `admin` (
  `id_admin` INT,
  `username_admin` VARCHAR(64),
  `password_admin` VARCHAR(64),
  `token_admin` VARCHAR(64),
  `token_expired_admin` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_admin`)
) CHARACTER SET latin1;

CREATE TABLE `tipe_property` (
  `id_tipe` INT,
  `tipe` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_tipe`)
) CHARACTER SET latin1;

CREATE TABLE `property` (
  `id_property` INT,
  `nama_property` VARCHAR(64),
  `harga_property` INT,
  `stock_property` INT,
  `detail_property` VARCHAR(64),
  `lokasi_property` VARCHAR(64),
  `gambar_property` VARCHAR(64),
  `tipe_property` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_property`)
) CHARACTER SET latin1;

CREATE TABLE `bayar_transaksi` (
  `id_bayar_transaksi` INT,
  `tgl_bayar` DATETIME,
  `jumlah_bayar` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_bayar_transaksi`)
) CHARACTER SET latin1;

CREATE TABLE `transaksi_pesan` (
  `id_transaksipesan` INT,
  `no_transaksipesan` VARCHAR(64),
  `tgl_pesan_transaksipesan` DATETIME,
  `nomor` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_transaksipesan`)
) CHARACTER SET latin1;

CREATE TABLE `item_transaksi` (
  `id_item_transaksi` INT,
  `customer_id` INT,
  `property_id` INT,
  `transaksipesan_id` INT,
  `total_item_transaksi` INT,
  `harga_item_transaksi` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id_item_transaksi`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_614330_property') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_614330_property') AS relationships;
DROP DATABASE `db_614330_property`;
UNINSTALL EXTENSION vsql_schematron;
