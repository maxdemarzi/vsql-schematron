INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 643484_patch70
--echo #
CREATE DATABASE `db_643484_patch70`;
USE `db_643484_patch70`;

CREATE TABLE `talk_link_types` (
  `ID` INT,
  `display_name` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `talk_links` (
  `ID` INT,
  `talk_id` INT,
  `talk_type` INT,
  `url` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_643484_patch70') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_643484_patch70') AS relationships;
DROP DATABASE `db_643484_patch70`;
UNINSTALL EXTENSION vsql_schematron;
