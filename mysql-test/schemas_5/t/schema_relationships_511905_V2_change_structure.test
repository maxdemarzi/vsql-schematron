INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 511905_V2__change_structure
--echo #
CREATE DATABASE `db_511905_V2_change_structure`;
USE `db_511905_V2_change_structure`;

CREATE TABLE `todo_list` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `todo` (
  `id` INT,
  `description` VARCHAR(64),
  `ordering` INT,
  `done` BOOL,
  `list_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_511905_V2_change_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_511905_V2_change_structure') AS relationships;
DROP DATABASE `db_511905_V2_change_structure`;
UNINSTALL EXTENSION vsql_schematron;
