INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 560662_testdata
--echo #
CREATE DATABASE `db_560662_testdata`;
USE `db_560662_testdata`;

CREATE TABLE `example` (
  `id` INT,
  `name` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shop` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `shopId` INT,
  `customerId` INT,
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_order` (
  `itemId` INT,
  `orderId` INT
) CHARACTER SET latin1;

CREATE TABLE `remark` (
  `id` INT,
  `orderId` INT,
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_560662_testdata') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_560662_testdata') AS relationships;
DROP DATABASE `db_560662_testdata`;
UNINSTALL EXTENSION vsql_schematron;
