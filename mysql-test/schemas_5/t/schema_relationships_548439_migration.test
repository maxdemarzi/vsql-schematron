INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 548439_migration
--echo #
CREATE DATABASE `db_548439_migration`;
USE `db_548439_migration`;

CREATE TABLE `Project` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `icon` VARCHAR(64),
  `userId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Page` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `icon` VARCHAR(64),
  `blocksArray` VARCHAR(64),
  `projectId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Block` (
  `id` VARCHAR(64),
  `noteId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Note` (
  `id` VARCHAR(64),
  `text` VARCHAR(64),
  `tag` VARCHAR(64),
  `type` VARCHAR(64),
  `creatorId` VARCHAR(64),
  `assignedId` VARCHAR(64),
  `complete` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Profile` (
  `id` VARCHAR(64),
  `bio` VARCHAR(64),
  `userId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ProjectTeam` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_548439_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_548439_migration') AS relationships;
DROP DATABASE `db_548439_migration`;
UNINSTALL EXTENSION vsql_schematron;
