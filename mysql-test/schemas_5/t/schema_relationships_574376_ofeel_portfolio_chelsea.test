INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574376_ofeel_portfolio_chelsea
--echo #
CREATE DATABASE `db_574376_ofeel_portfolio_chelsea`;
USE `db_574376_ofeel_portfolio_chelsea`;

CREATE TABLE `ofeel_portfolio_chelsea.categories` (
  `id` INT,
  `name` VARCHAR(255),
  `icone` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.works` (
  `id` INT,
  `title` VARCHAR(255),
  `resume` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `categorie_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.workcomments` (
  `id` INT,
  `pseudo` VARCHAR(255),
  `content` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `work_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.articles` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `resume` VARCHAR(255),
  `created_at` VARCHAR(255),
  `updated_at` VARCHAR(255),
  `categorie_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.tags` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.artcomments` (
  `id` INT,
  `pseudo` VARCHAR(255),
  `content` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `article_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.works_has_tags` (
  `work_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio_chelsea.articles_has_tags` (
  `article_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574376_ofeel_portfolio_chelsea') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574376_ofeel_portfolio_chelsea') AS relationships;
DROP DATABASE `db_574376_ofeel_portfolio_chelsea`;
UNINSTALL EXTENSION vsql_schematron;
