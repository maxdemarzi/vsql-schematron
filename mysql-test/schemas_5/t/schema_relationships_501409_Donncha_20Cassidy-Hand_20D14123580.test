INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501409_Donncha%20Cassidy-Hand%20D14123580
--echo #
CREATE DATABASE `db_501409_Donncha_20Cassidy_Hand_20D14123580`;
USE `db_501409_Donncha_20Cassidy_Hand_20D14123580`;
CREATE TABLE `Customer` (
  `customerID` DECIMAL(10,2) NOT NULL,
  `customerName` VARCHAR(50),
  `customerPhone` VARCHAR(50),
  `customerAddress` VARCHAR(50),
  PRIMARY KEY (`customerID`)
) CHARACTER SET latin1;
CREATE TABLE `Specification` (
  `specificationID` DECIMAL(10,2) NOT NULL,
  `customerID` DECIMAL(10,2),
  `specDate` DATE,
  `returnDate` DATE,
  `specDesc` VARCHAR(50),
  `designerName` VARCHAR(50),
  PRIMARY KEY (`specificationID`)
) CHARACTER SET latin1;
CREATE TABLE `LightStock` (
  `itemID` DECIMAL(10,2) NOT NULL,
  `ItemDesc` VARCHAR(50),
  `ItemPrice` DECIMAL(10,2),
  PRIMARY KEY (`itemID`)
) CHARACTER SET latin1;
CREATE TABLE `LightDesignItems` (
  `specificationID` DECIMAL(10,2) NOT NULL,
  `itemID` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`specificationID`, `itemID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501409_Donncha_20Cassidy_Hand_20D14123580') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501409_Donncha_20Cassidy_Hand_20D14123580') AS relationships;
DROP DATABASE `db_501409_Donncha_20Cassidy_Hand_20D14123580`;
UNINSTALL EXTENSION vsql_schematron;
