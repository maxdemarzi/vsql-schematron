INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 571794_create_schema
--echo #
CREATE DATABASE `db_571794_create_schema`;
USE `db_571794_create_schema`;

CREATE TABLE `organization` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `organization_id` INT,
  `id` INT,
  `role_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `asset_type` (
  `organization_id` INT,
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `manufacturer` (
  `organization_id` INT,
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `asset` (
  `organization_id` INT,
  `id` INT,
  `asset_type_id` INT,
  `asset_id` INT,
  `name` VARCHAR(64),
  `manufacturer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `assignee` (
  `organization_id` INT,
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `assignee_asset` (
  `assignee_id` INT,
  `asset_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_571794_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_571794_create_schema') AS relationships;
DROP DATABASE `db_571794_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
