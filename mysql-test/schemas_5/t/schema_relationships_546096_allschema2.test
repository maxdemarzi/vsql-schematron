INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546096_allschema2
--echo #
CREATE DATABASE `db_546096_allschema2`;
USE `db_546096_allschema2`;
CREATE TABLE `author` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genre` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quote` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `genre_id` VARCHAR(50),
  `author_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546096_allschema2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546096_allschema2') AS relationships;
DROP DATABASE `db_546096_allschema2`;
UNINSTALL EXTENSION vsql_schematron;
