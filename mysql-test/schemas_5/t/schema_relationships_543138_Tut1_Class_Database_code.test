INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543138_Tut1_Class_Database_code
--echo #
CREATE DATABASE `db_543138_Tut1_Class_Database_code`;
USE `db_543138_Tut1_Class_Database_code`;

CREATE TABLE `student_data` (
  `id` INT,
  `student_no` INT,
  `first_name` VARCHAR(64),
  `surname` VARCHAR(64),
  `programme` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student_contact_details` (
  `id` INT,
  `student_email` VARCHAR(64),
  `contact_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nas_programmes` (
  `id` INT,
  `Bachelor_of_science_in_data_science` VARCHAR(64),
  `Bachelor_of_science_in_mathematical_and_computer_science` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543138_Tut1_Class_Database_code') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543138_Tut1_Class_Database_code') AS relationships;
DROP DATABASE `db_543138_Tut1_Class_Database_code`;
UNINSTALL EXTENSION vsql_schematron;
