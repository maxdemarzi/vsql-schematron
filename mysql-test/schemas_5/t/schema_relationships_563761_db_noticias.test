INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 563761_db_noticias
--echo #
CREATE DATABASE `db_563761_db_noticias`;
USE `db_563761_db_noticias`;
CREATE TABLE `tbl_categoria` (
  `idcategoria` INT,
  `nomecategoria` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tbl_noticia` (
  `idnoticia` INT,
  `titulonoticia` VARCHAR(50),
  `conteudonoticia` VARCHAR(50),
  `fk_categoria` INT,
  `imgnoticias` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_563761_db_noticias') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_563761_db_noticias') AS relationships;
DROP DATABASE `db_563761_db_noticias`;
UNINSTALL EXTENSION vsql_schematron;
