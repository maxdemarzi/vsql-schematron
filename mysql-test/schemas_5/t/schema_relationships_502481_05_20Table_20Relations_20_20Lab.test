INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 502481_05.%20Table%20Relations%20-%20Lab
--echo #
CREATE DATABASE `db_502481_05_20Table_20Relations_20_20Lab`;
USE `db_502481_05_20Table_20Relations_20_20Lab`;

CREATE TABLE `mountains` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `peaks` (
  `id` INT,
  `name` VARCHAR(64),
  `mountain_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authors` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `name` VARCHAR(64),
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clients` (
  `id` INT,
  `client_name` VARCHAR(64),
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` INT,
  `client_id` INT,
  `project_lead_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_502481_05_20Table_20Relations_20_20Lab') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_502481_05_20Table_20Relations_20_20Lab') AS relationships;
DROP DATABASE `db_502481_05_20Table_20Relations_20_20Lab`;
UNINSTALL EXTENSION vsql_schematron;
