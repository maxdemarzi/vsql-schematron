INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508300_24092019
--echo #
CREATE DATABASE `db_508300_24092019`;
USE `db_508300_24092019`;

CREATE TABLE `tbl_user_type` (
  `id` INT,
  `utype` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `entryby` INT,
  `updatedby` INT,
  `isactive` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_user` (
  `id` INT,
  `name` VARCHAR(64),
  `emailid` VARCHAR(64),
  `contact` VARCHAR(64),
  `usertype` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `entryby` INT,
  `updatedby` INT,
  `isactive` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_auth` (
  `id` INT,
  `password` VARCHAR(64),
  `userid` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `entryby` INT,
  `updatedby` INT,
  `isactive` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508300_24092019') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508300_24092019') AS relationships;
DROP DATABASE `db_508300_24092019`;
UNINSTALL EXTENSION vsql_schematron;
