INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524982_create_database
--echo #
CREATE DATABASE `db_524982_create_database`;
USE `db_524982_create_database`;
CREATE TABLE `poll` (
  `id` VARCHAR(50) NOT NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
  `id` VARCHAR(50) NOT NULL,
  `poll_id` VARCHAR(50),
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vote` (
  `id` INT NOT NULL,
  `answer_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524982_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524982_create_database') AS relationships;
DROP DATABASE `db_524982_create_database`;
UNINSTALL EXTENSION vsql_schematron;
