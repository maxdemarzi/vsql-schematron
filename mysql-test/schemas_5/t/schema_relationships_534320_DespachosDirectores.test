INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534320_DespachosDirectores
--echo #
CREATE DATABASE `db_534320_DespachosDirectores`;
USE `db_534320_DespachosDirectores`;

CREATE TABLE `DIRECTORES` (
  `DNI` VARCHAR(64),
  `NomApels` VARCHAR(64),
  `DNIJefe` VARCHAR(64),
  `Despacho` INT,
  PRIMARY KEY (`DNI`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534320_DespachosDirectores') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534320_DespachosDirectores') AS relationships;
DROP DATABASE `db_534320_DespachosDirectores`;
UNINSTALL EXTENSION vsql_schematron;
