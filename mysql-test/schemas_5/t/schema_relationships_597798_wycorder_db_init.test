INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 597798_wycorder_db_init
--echo #
CREATE DATABASE `db_597798_wycorder_db_init`;
USE `db_597798_wycorder_db_init`;
CREATE TABLE `system_user` (
  `system_user_id` INT NOT NULL,
  `email` VARCHAR(50),
  `sis_id` VARCHAR(50),
  `token` VARCHAR(50),
  `password` VARCHAR(50),
  `active` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`system_user_id`)
) CHARACTER SET latin1;
CREATE TABLE `reading` (
  `reading_id` INT NOT NULL,
  `system_user_id` INT,
  `time_taken` TIMESTAMP NULL,
  `status` VARCHAR(50),
  `fever_chills` SMALLINT,
  `cough` SMALLINT,
  `sore_throat` SMALLINT,
  `short_breath` SMALLINT,
  `fatigue` SMALLINT,
  `aches` SMALLINT,
  `taste_loss` SMALLINT,
  `congestion` SMALLINT,
  `nausea_vomit_diarrhea` SMALLINT,
  `infectious_contact` SMALLINT,
  `temperature` SMALLINT,
  PRIMARY KEY (`reading_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_597798_wycorder_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_597798_wycorder_db_init') AS relationships;
DROP DATABASE `db_597798_wycorder_db_init`;
UNINSTALL EXTENSION vsql_schematron;
