CREATE TABLE `ptcore.program_test` (
  `id` INT,
  `created` DATETIME,
  `name` VARCHAR(64),
  `data_url` VARCHAR(64),
  `updated` DATETIME,
  `active` VARCHAR(64),
  `file_name` VARCHAR(64),
  `file_size` INT,
  `file_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ptcore.parse_workout_test` (
  `id` INT,
  `program_test_id` INT,
  `created` DATETIME,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ptcore.parse_warmup_workout_item_test` (
  `id` INT,
  `parse_workout_test_id` INT,
  `created` DATETIME,
  `name` VARCHAR(64),
  `speed` INT,
  `incline` INT,
  `time_in_min` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ptcore.parse_workout_item_test` (
  `id` INT,
  `parse_workout_test_id` INT,
  `created` DATETIME,
  `name` VARCHAR(64),
  `sets` INT,
  `repetitions` INT,
  `weight` INT,
  `bodyweight` VARCHAR(64),
  `time_in_min` INT,
  `speed` INT,
  `resistance` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

