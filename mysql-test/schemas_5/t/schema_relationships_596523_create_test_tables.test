INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 596523_create-test-tables
--echo #
CREATE DATABASE `db_596523_create_test_tables`;
USE `db_596523_create_test_tables`;

CREATE TABLE `resource` (
  `id` INT,
  `urn` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rating` (
  `authorid` INT,
  `subjectid` INT,
  `comment` VARCHAR(64),
  `qualityrating` INT,
  `resourceisfake` BOOL,
  `feeling` VARCHAR(64),
  PRIMARY KEY (`authorid`, `subjectid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_596523_create_test_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_596523_create_test_tables') AS relationships;
DROP DATABASE `db_596523_create_test_tables`;
UNINSTALL EXTENSION vsql_schematron;
