INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 503045_jds-databse
--echo #
CREATE DATABASE `db_503045_jds_databse`;
USE `db_503045_jds_databse`;
CREATE TABLE `SERVER_HOST` (
  `SERVER_ID` BIGINT NOT NULL,
  `SERVER_NAME` VARCHAR(50),
  PRIMARY KEY (`SERVER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `IP_ADDRESS` (
  `IP_ADDRESS` VARCHAR(50) NOT NULL,
  `STATE` VARCHAR(50),
  `SERVER_ID` BIGINT,
  PRIMARY KEY (`IP_ADDRESS`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
  `USER_ID` BIGINT NOT NULL,
  `USERNAME` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `USER_TYPE` VARCHAR(50),
  `SERVER_ID` BIGINT,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `APPLICATION` (
  `APPLICATION_ID` BIGINT NOT NULL,
  `APPLICATION_NAME` VARCHAR(50),
  `APPLICATION_TYPE` VARCHAR(50),
  `APPLICATION_USER` BIGINT,
  PRIMARY KEY (`APPLICATION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `BINDING` (
  `BINDING_ID` BIGINT NOT NULL,
  `APPLICATION_ID` BIGINT,
  `SERVER_ID` BIGINT,
  `IP_ADDRESS` VARCHAR(50),
  PRIMARY KEY (`BINDING_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_503045_jds_databse') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_503045_jds_databse') AS relationships;
DROP DATABASE `db_503045_jds_databse`;
UNINSTALL EXTENSION vsql_schematron;
