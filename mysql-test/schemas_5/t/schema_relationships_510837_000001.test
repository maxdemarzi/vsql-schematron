INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510837_000001
--echo #
CREATE DATABASE `db_510837_000001`;
USE `db_510837_000001`;
CREATE TABLE `genvasc_collaborators_practice` (
  `id` INT NOT NULL,
  `practiceCode` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genvasc_collaborators_delegate` (
  `id` INT NOT NULL,
  `practiceId` INT,
  `fullname` VARCHAR(50),
  `email` VARCHAR(50),
  `role` VARCHAR(50),
  `dietary` VARCHAR(50),
  `meeting` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510837_000001') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510837_000001') AS relationships;
DROP DATABASE `db_510837_000001`;
UNINSTALL EXTENSION vsql_schematron;
