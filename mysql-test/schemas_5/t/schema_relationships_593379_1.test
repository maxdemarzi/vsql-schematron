INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 593379_1
--echo #
CREATE DATABASE `db_593379_1`;
USE `db_593379_1`;

CREATE TABLE `users` (
  `id` INT,
  `security_user_id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `bio` VARCHAR(64),
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articles` (
  `id` INT,
  `slug` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `author_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articles_tags` (
  `id` INT,
  `article_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `body` VARCHAR(64),
  `article_id` INT,
  `author_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `follow_associations` (
  `id` INT,
  `follower_id` INT,
  `followed_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `favorite_associations` (
  `id` INT,
  `user_id` INT,
  `favorited_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_593379_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_593379_1') AS relationships;
DROP DATABASE `db_593379_1`;
UNINSTALL EXTENSION vsql_schematron;
