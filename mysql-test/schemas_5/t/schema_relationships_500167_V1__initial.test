INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 500167_V1__initial
--echo #
CREATE DATABASE `db_500167_V1__initial`;
USE `db_500167_V1__initial`;
CREATE TABLE `application` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `contact` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `interface` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `type` VARCHAR(50),
  `application_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `version` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `version` VARCHAR(50),
  `description` VARCHAR(50),
  `content` TEXT,
  `interface_id` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_500167_V1__initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_500167_V1__initial') AS relationships;
DROP DATABASE `db_500167_V1__initial`;
UNINSTALL EXTENSION vsql_schematron;
