INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 544618_ErnaeringStrategi
--echo #
CREATE DATABASE `db_544618_ErnaeringStrategi`;
USE `db_544618_ErnaeringStrategi`;

CREATE TABLE `ErnaeringStrategi` (
  `_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `TaxonErnaeringStrategi` (
  `ernaeringsstrategi_id` INT,
  `taxon_id` INT,
  PRIMARY KEY (`ernaeringsstrategi_id`, `taxon_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_544618_ErnaeringStrategi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_544618_ErnaeringStrategi') AS relationships;
DROP DATABASE `db_544618_ErnaeringStrategi`;
UNINSTALL EXTENSION vsql_schematron;
