INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 538450_schema
--echo #
CREATE DATABASE `db_538450_schema`;
USE `db_538450_schema`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bookmark_list` (
  `id` INT,
  `name` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bookmark` (
  `id` INT,
  `name` VARCHAR(64),
  `url` VARCHAR(64),
  `list_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_538450_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_538450_schema') AS relationships;
DROP DATABASE `db_538450_schema`;
UNINSTALL EXTENSION vsql_schematron;
