INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 502309_atividade3
--echo #
CREATE DATABASE `db_502309_atividade3`;
USE `db_502309_atividade3`;
CREATE TABLE `tb_turmas` (
  `id` BIGINT NOT NULL,
  `turno` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_alunos` (
  `id` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  `idade` INT,
  `turma_id` BIGINT,
  `nota` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_502309_atividade3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_502309_atividade3') AS relationships;
DROP DATABASE `db_502309_atividade3`;
UNINSTALL EXTENSION vsql_schematron;
