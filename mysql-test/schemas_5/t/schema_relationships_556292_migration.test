INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 556292_migration
--echo #
CREATE DATABASE `db_556292_migration`;
USE `db_556292_migration`;

CREATE TABLE `official_absences` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` VARCHAR(64),
  `class` VARCHAR(64),
  `date_time` DATETIME,
  `reason` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` VARCHAR(64),
  `title` VARCHAR(64),
  `introduction` VARCHAR(64),
  `image_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book_tags` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Schedule` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `schedule` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_book_tags` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_556292_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_556292_migration') AS relationships;
DROP DATABASE `db_556292_migration`;
UNINSTALL EXTENSION vsql_schematron;
