INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 564878_employees
--echo #
CREATE DATABASE `db_564878_employees`;
USE `db_564878_employees`;
CREATE TABLE `departments` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `id` VARCHAR(50) NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `RoleId` VARCHAR(50),
  `managerId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_564878_employees') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_564878_employees') AS relationships;
DROP DATABASE `db_564878_employees`;
UNINSTALL EXTENSION vsql_schematron;
