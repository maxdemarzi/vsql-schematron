INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 540373_exemple_database
--echo #
CREATE DATABASE `db_540373_exemple_database`;
USE `db_540373_exemple_database`;
CREATE TABLE `personne` (
  `id` VARCHAR(50) NOT NULL,
  `nom` VARCHAR(50),
  `email` VARCHAR(50),
  `mdp` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `eleve` (
  `id` VARCHAR(50) NOT NULL,
  `idPersonne` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classe` (
  `id` INT NOT NULL,
  `intitule` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_540373_exemple_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_540373_exemple_database') AS relationships;
DROP DATABASE `db_540373_exemple_database`;
UNINSTALL EXTENSION vsql_schematron;
