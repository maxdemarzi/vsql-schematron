INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592947_db-create
--echo #
CREATE DATABASE `db_592947_db_create`;
USE `db_592947_db_create`;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `role_id` INT,
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dish` (
  `id` INT,
  `name` VARCHAR(64),
  `category_id` INT,
  `price` INT,
  `weight` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `status` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `receipt` (
  `id` INT,
  `user_id` INT,
  `status_id` INT,
  `total` INT,
  `manager_id` INT,
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart_has_dish` (
  `user_id` INT,
  `dish_id` INT,
  `count` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592947_db_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592947_db_create') AS relationships;
DROP DATABASE `db_592947_db_create`;
UNINSTALL EXTENSION vsql_schematron;
