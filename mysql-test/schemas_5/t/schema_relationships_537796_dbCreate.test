INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 537796_dbCreate
--echo #
CREATE DATABASE `db_537796_dbCreate`;
USE `db_537796_dbCreate`;

CREATE TABLE `site` (
  `id` INT,
  `name` VARCHAR(64),
  `longitude` VARCHAR(64),
  `latitude` VARCHAR(64),
  `manager` VARCHAR(64),
  `phone` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `dino` (
  `id` INT,
  `site_id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `x` INT,
  `y` INT,
  `z` VARCHAR(64),
  `picture` VARCHAR(64),
  `conservation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `list` (
  `site_id` INT,
  `dino_id` INT
) CHARACTER SET latin1;

CREATE TABLE `remarks` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_537796_dbCreate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_537796_dbCreate') AS relationships;
DROP DATABASE `db_537796_dbCreate`;
UNINSTALL EXTENSION vsql_schematron;
