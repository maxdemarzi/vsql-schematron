INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 514330_ddl
--echo #
CREATE DATABASE `db_514330_ddl`;
USE `db_514330_ddl`;
CREATE TABLE `Income` (
  `id` INT NOT NULL,
  `amount` DOUBLE,
  `date` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
  `id` INT NOT NULL,
  `percent` DOUBLE,
  `info` TEXT,
  `payout` DOUBLE,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Expense` (
  `id` INT NOT NULL,
  `amount` INT,
  `title` TEXT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_514330_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_514330_ddl') AS relationships;
DROP DATABASE `db_514330_ddl`;
UNINSTALL EXTENSION vsql_schematron;
