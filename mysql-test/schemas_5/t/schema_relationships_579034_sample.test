INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 579034_sample
--echo #
CREATE DATABASE `db_579034_sample`;
USE `db_579034_sample`;

CREATE TABLE `Countries` (
  `country_ID` INT,
  `name` VARCHAR(64),
  `population` INT,
  PRIMARY KEY (`country_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Persons` (
  `person_ID` INT,
  `last_name` VARCHAR(64),
  `first_name` VARCHAR(64),
  `address` VARCHAR(64),
  `city_ID` INT,
  `country_ID` INT,
  PRIMARY KEY (`person_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Cities` (
  `city_ID` INT,
  `city_name` VARCHAR(64),
  `country_ID` INT,
  `population` INT,
  PRIMARY KEY (`city_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_579034_sample') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_579034_sample') AS relationships;
DROP DATABASE `db_579034_sample`;
UNINSTALL EXTENSION vsql_schematron;
