INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 591035_bootstrap
--echo #
CREATE DATABASE `db_591035_bootstrap`;
USE `db_591035_bootstrap`;

CREATE TABLE `pipelines` (
  `remote` VARCHAR(64),
  `ref` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`remote`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `runs` (
  `count` INT,
  `start_time` DATETIME,
  `end_time` DATETIME,
  `success` VARCHAR(64),
  `pipeline_remote` VARCHAR(64),
  `pipeline_name` VARCHAR(64),
  PRIMARY KEY (`pipeline_remote`, `pipeline_name`, `count`)
) CHARACTER SET latin1;

CREATE TABLE `steps` (
  `id` INT,
  `name` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  `success` VARCHAR(64),
  `pipeline_remote` VARCHAR(64),
  `pipeline_name` VARCHAR(64),
  `run_count` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `name` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  `success` VARCHAR(64),
  `step_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_591035_bootstrap') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_591035_bootstrap') AS relationships;
DROP DATABASE `db_591035_bootstrap`;
UNINSTALL EXTENSION vsql_schematron;
