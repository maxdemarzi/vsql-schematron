INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553839_Insurance
--echo #
CREATE DATABASE `db_553839_Insurance`;
USE `db_553839_Insurance`;

CREATE TABLE `PERSON` (
  `driver_id` VARCHAR(255),
  `name` VARCHAR(255),
  `address` VARCHAR(255),
  PRIMARY KEY (`driver_id`)
) CHARACTER SET latin1;

CREATE TABLE `CAR` (
  `reg_num` VARCHAR(255),
  `model` VARCHAR(255),
  `year` INT,
  PRIMARY KEY (`reg_num`)
) CHARACTER SET latin1;

CREATE TABLE `ACCIDENT` (
  `report_num` INT,
  `accident_date` DATETIME,
  `location` VARCHAR(255),
  PRIMARY KEY (`report_num`)
) CHARACTER SET latin1;

CREATE TABLE `OWNS` (
  `driver_id` VARCHAR(255),
  `reg_num` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `PARTICIPATED` (
  `driver_id` VARCHAR(255),
  `reg_num` VARCHAR(255),
  `report_num` INT,
  `damage_amount` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553839_Insurance') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553839_Insurance') AS relationships;
DROP DATABASE `db_553839_Insurance`;
UNINSTALL EXTENSION vsql_schematron;
