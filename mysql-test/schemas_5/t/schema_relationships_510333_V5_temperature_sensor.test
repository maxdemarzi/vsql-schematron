INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510333_V5__temperature_sensor
--echo #
CREATE DATABASE `db_510333_V5_temperature_sensor`;
USE `db_510333_V5_temperature_sensor`;

CREATE TABLE `temperature_sensors` (
  `id` INT,
  `zone_id` INT,
  `name` VARCHAR(64),
  `min` DECIMAL(10,2),
  `max` DECIMAL(10,2),
  `active` BOOL,
  `channel_id` INT,
  `api_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `temperatures` (
  `id` INT,
  `sensor_id` INT,
  `time` DATETIME,
  `temperature` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510333_V5_temperature_sensor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510333_V5_temperature_sensor') AS relationships;
DROP DATABASE `db_510333_V5_temperature_sensor`;
UNINSTALL EXTENSION vsql_schematron;
