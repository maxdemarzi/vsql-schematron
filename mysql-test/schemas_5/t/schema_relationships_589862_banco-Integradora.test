INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 589862_banco-Integradora
--echo #
CREATE DATABASE `db_589862_banco_Integradora`;
USE `db_589862_banco_Integradora`;
CREATE TABLE `cliente` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `dataNascimento` DATE,
  `email` VARCHAR(50),
  `telefone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `cpf` VARCHAR(50),
  `cargo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quarto` (
  `id` INT NOT NULL,
  `tipo` VARCHAR(50),
  `valor` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reserva` (
  `id` INT NOT NULL,
  `id_funcionario` INT,
  `id_cliente` INT,
  `id_quarto` INT,
  `valor` DECIMAL(10,2),
  `data` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_589862_banco_Integradora') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_589862_banco_Integradora') AS relationships;
DROP DATABASE `db_589862_banco_Integradora`;
UNINSTALL EXTENSION vsql_schematron;
