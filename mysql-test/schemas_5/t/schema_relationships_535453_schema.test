INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535453_schema
--echo #
CREATE DATABASE `db_535453_schema`;
USE `db_535453_schema`;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `roles` VARCHAR(50),
  `password_hash` TEXT,
  `date_created` TIMESTAMP NULL,
  `date_updated` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `product_id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `cost` INT,
  `quantity` INT,
  `user_id` VARCHAR(50),
  `date_created` TIMESTAMP NULL,
  `date_updated` TIMESTAMP NULL,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `sales` (
  `sale_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `product_id` VARCHAR(50),
  `quantity` INT,
  `paid` INT,
  `date_created` TIMESTAMP NULL,
  PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535453_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535453_schema') AS relationships;
DROP DATABASE `db_535453_schema`;
UNINSTALL EXTENSION vsql_schematron;
