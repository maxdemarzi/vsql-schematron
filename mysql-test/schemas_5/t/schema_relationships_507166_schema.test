INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 507166_schema
--echo #
CREATE DATABASE `db_507166_schema`;
USE `db_507166_schema`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `id` INT,
  `name` VARCHAR(64),
  `room` VARCHAR(64),
  `teacher_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `periods` (
  `id` INT,
  `display` VARCHAR(64),
  `start_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `enrollments` (
  `id` INT,
  `student_id` INT,
  `course_id` INT,
  `period_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `assignments` (
  `id` INT,
  `name` VARCHAR(64),
  `total_points` INT,
  `due_date` DATETIME,
  `course_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `grades` (
  `id` INT,
  `student_id` INT,
  `assignment_id` INT,
  `points` INT,
  `graded_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_507166_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_507166_schema') AS relationships;
DROP DATABASE `db_507166_schema`;
UNINSTALL EXTENSION vsql_schematron;
