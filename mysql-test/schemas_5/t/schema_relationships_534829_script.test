INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534829_script
--echo #
CREATE DATABASE `db_534829_script`;
USE `db_534829_script`;
CREATE TABLE `order.tb_product` (
  `id_product` INT NOT NULL,
  `ds_product` VARCHAR(50),
  `vl_product` DECIMAL(10,2),
  `qt_product` INT,
  PRIMARY KEY (`id_product`)
) CHARACTER SET latin1;
CREATE TABLE `order.tb_order` (
  `id_order` INT NOT NULL,
  `ds_address` VARCHAR(50),
  `st_order` CHAR(50),
  `id_person` INT,
  PRIMARY KEY (`id_order`)
) CHARACTER SET latin1;
CREATE TABLE `order.rl_order_product` (
  `id_order_product` INT NOT NULL,
  `id_product` INT,
  `id_order` INT,
  PRIMARY KEY (`id_order_product`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534829_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534829_script') AS relationships;
DROP DATABASE `db_534829_script`;
UNINSTALL EXTENSION vsql_schematron;
