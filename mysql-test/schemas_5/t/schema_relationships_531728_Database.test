INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531728_Database
--echo #
CREATE DATABASE `db_531728_Database`;
USE `db_531728_Database`;

CREATE TABLE `galleries` (
  `id` INT,
  `title` VARCHAR(255),
  `slug` VARCHAR(255),
  `summary` VARCHAR(255),
  `showHome` INT,
  `image` VARCHAR(255),
  `content` VARCHAR(255),
  `design` VARCHAR(255),
  `order` INT,
  `metaTitle` VARCHAR(255),
  `metaDescription` VARCHAR(255),
  `metaKeywords` VARCHAR(255),
  `status` VARCHAR(255),
  `visited` INT,
  `language` VARCHAR(255),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gallery_images` (
  `id` INT,
  `galleryId` INT,
  `title` VARCHAR(255),
  `image` VARCHAR(255),
  `content` VARCHAR(255),
  `order` INT,
  `status` VARCHAR(255),
  `language` VARCHAR(255),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531728_Database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531728_Database') AS relationships;
DROP DATABASE `db_531728_Database`;
UNINSTALL EXTENSION vsql_schematron;
