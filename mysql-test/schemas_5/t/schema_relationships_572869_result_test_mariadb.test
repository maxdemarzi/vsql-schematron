INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 572869_result_test_mariadb
--echo #
CREATE DATABASE `db_572869_result_test_mariadb`;
USE `db_572869_result_test_mariadb`;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `role_name` VARCHAR(50),
  `role_description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_data_binary` (
  `c1` BLOB
) CHARACTER SET latin1;
CREATE TABLE `test_data_number` (
  `c1` DOUBLE,
  `c2` DECIMAL(10,2),
  `c3` VARCHAR(50),
  `c4` DOUBLE,
  `c5` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `test_table` (
  `updated_time` TIMESTAMP NULL,
  `s_time` TIME,
  `s_date` DATE
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `user_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_572869_result_test_mariadb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_572869_result_test_mariadb') AS relationships;
DROP DATABASE `db_572869_result_test_mariadb`;
UNINSTALL EXTENSION vsql_schematron;
