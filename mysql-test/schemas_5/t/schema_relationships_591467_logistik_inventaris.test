INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 591467_logistik_inventaris
--echo #
CREATE DATABASE `db_591467_logistik_inventaris`;
USE `db_591467_logistik_inventaris`;

CREATE TABLE `barang` (
  `id` INT,
  `kode` VARCHAR(255),
  `nm_barang` VARCHAR(255),
  `jml` INT,
  `jenis_id` INT,
  `ruangan_id` INT,
  `ket` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `hilang` (
  `id` INT,
  `nm_barang` VARCHAR(255),
  `barang_id` VARCHAR(255),
  `tgl` DATETIME,
  `desc` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `jenis` (
  `id` INT,
  `nm_jenis` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `keluar` (
  `id` INT,
  `logistik_id` INT,
  `jml` INT,
  `tgl` DATETIME,
  `ket` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `logistik` (
  `id` INT,
  `kode` VARCHAR(255),
  `nm_logistik` VARCHAR(255),
  `jml` INT,
  `jenis_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `masuk` (
  `id` INT,
  `logistik_id` INT,
  `jml` INT,
  `tgl` DATETIME,
  `ket` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ruangan` (
  `id` INT,
  `nm_ruangan` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rusak` (
  `id` INT,
  `logistik_id` INT,
  `jml` INT,
  `tgl` DATETIME,
  `ket` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `role` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `image` VARCHAR(255),
  `level` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_591467_logistik_inventaris') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_591467_logistik_inventaris') AS relationships;
DROP DATABASE `db_591467_logistik_inventaris`;
UNINSTALL EXTENSION vsql_schematron;
