INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 564945_healthcare
--echo #
CREATE DATABASE `db_564945_healthcare`;
USE `db_564945_healthcare`;

CREATE TABLE `beacon` (
  `uuid` VARCHAR(64),
  `major` INT,
  `minor` INT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `cleaning_task` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `maintainance_task` (
  `repeat_task_in_day` INT,
  `id` INT,
  `picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `picture_of_object` (
  `id` INT,
  `picture` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sub_task_checkbox` (
  `value` VARCHAR(64),
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sub_task_image` (
  `picture` VARCHAR(64),
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sub_task_slider` (
  `value` INT,
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transport_task` (
  `id` INT,
  `target_location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_564945_healthcare') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_564945_healthcare') AS relationships;
DROP DATABASE `db_564945_healthcare`;
UNINSTALL EXTENSION vsql_schematron;
