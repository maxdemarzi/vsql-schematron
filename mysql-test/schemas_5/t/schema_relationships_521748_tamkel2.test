INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521748_tamkel2
--echo #
CREATE DATABASE `db_521748_tamkel2`;
USE `db_521748_tamkel2`;

CREATE TABLE `auth_activation_attempts` (
  `id` INT,
  `ip_address` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups_permissions` (
  `group_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_groups_users` (
  `group_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_logins` (
  `id` INT,
  `ip_address` VARCHAR(64),
  `email` VARCHAR(64),
  `user_id` INT,
  `date` DATETIME,
  `success` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_reset_attempts` (
  `id` INT,
  `email` VARCHAR(64),
  `ip_address` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_tokens` (
  `id` INT,
  `selector` VARCHAR(64),
  `hashedValidator` VARCHAR(64),
  `user_id` INT,
  `expires` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_users_permissions` (
  `user_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

CREATE TABLE `bagian` (
  `id` INT,
  `deskripsi` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `karyawan` (
  `id` INT,
  `nama_lengkap` VARCHAR(64),
  `jk` VARCHAR(64),
  `tgl_lahir` DATETIME,
  `alamat` VARCHAR(64),
  `umur` INT,
  `email` VARCHAR(64),
  `nohp` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `version` VARCHAR(64),
  `class` VARCHAR(64),
  `group` VARCHAR(64),
  `namespace` VARCHAR(64),
  `time` INT,
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shift` (
  `id` INT,
  `deskripsi` VARCHAR(64),
  `awal` DATETIME,
  `selesai` DATETIME,
  `karyawan_id` INT,
  `bagian_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `reset_hash` VARCHAR(64),
  `reset_at` DATETIME,
  `reset_expires` DATETIME,
  `activate_hash` VARCHAR(64),
  `status` VARCHAR(64),
  `status_message` VARCHAR(64),
  `active` INT,
  `force_pass_reset` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521748_tamkel2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521748_tamkel2') AS relationships;
DROP DATABASE `db_521748_tamkel2`;
UNINSTALL EXTENSION vsql_schematron;
