INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 554712_mep_0004
--echo #
CREATE DATABASE `db_554712_mep_0004`;
USE `db_554712_mep_0004`;

CREATE TABLE `accounts_account` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_accountaddress` (
  `id` INT,
  `notes` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `account_id` INT,
  `address_id` INT,
  `care_of_person_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_address` (
  `id` INT,
  `notes` VARCHAR(64),
  `address_line_1` VARCHAR(64),
  `address_line_2` VARCHAR(64),
  `city_town` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `country_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_borrow` (
  `event_ptr_id` INT,
  `purchase_id_id` INT,
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_event` (
  `id` INT,
  `notes` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_purchase` (
  `event_ptr_id` INT,
  `price` DECIMAL(10,2),
  `currency` VARCHAR(64),
  `item_id` INT,
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_reimbursement` (
  `event_ptr_id` INT,
  `price` DECIMAL(10,2),
  `currency` VARCHAR(64),
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_subscribe` (
  `event_ptr_id` INT,
  `duration` INT,
  `volumes` INT,
  `sub_type` VARCHAR(64),
  `price_paid` DECIMAL(10,2),
  `deposit` DECIMAL(10,2),
  `currency` VARCHAR(64),
  `modification` VARCHAR(64),
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `books_item` (
  `id` INT,
  `notes` VARCHAR(64),
  `mep_id` VARCHAR(64),
  `title` VARCHAR(64),
  `volume` INT,
  `number` INT,
  `year` INT,
  `season` VARCHAR(64),
  `edition` VARCHAR(64),
  `viaf_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_admin_log` (
  `id` INT,
  `action_time` DATETIME,
  `object_id` VARCHAR(64),
  `object_repr` VARCHAR(64),
  `action_flag` INT,
  `change_message` VARCHAR(64),
  `content_type_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_cas_ng_sessionticket` (
  `id` INT,
  `session_key` VARCHAR(64),
  `ticket` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_session` (
  `session_key` VARCHAR(64),
  `session_data` VARCHAR(64),
  `expire_date` DATETIME,
  PRIMARY KEY (`session_key`)
) CHARACTER SET latin1;

CREATE TABLE `footnotes_bibliography` (
  `id` INT,
  `notes` VARCHAR(64),
  `bibliographic_note` VARCHAR(64),
  `source_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `footnotes_footnote` (
  `id` INT,
  `notes` VARCHAR(64),
  `location` VARCHAR(64),
  `snippet_text` VARCHAR(64),
  `object_id` INT,
  `is_agree` INT,
  `bibliography_id` INT,
  `content_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `people_infourl` (
  `id` INT,
  `notes` VARCHAR(64),
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `people_person` (
  `id` INT,
  `notes` VARCHAR(64),
  `start_year` INT,
  `end_year` INT,
  `mep_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `viaf_id` VARCHAR(64),
  `sex` VARCHAR(64),
  `title` VARCHAR(64),
  `profession_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `people_relationship` (
  `id` INT,
  `from_person_id` INT,
  `relationship_type_id` INT,
  `to_person_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_554712_mep_0004') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_554712_mep_0004') AS relationships;
DROP DATABASE `db_554712_mep_0004`;
UNINSTALL EXTENSION vsql_schematron;
