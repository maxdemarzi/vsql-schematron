INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 581433_schema
--echo #
CREATE DATABASE `db_581433_schema`;
USE `db_581433_schema`;
CREATE TABLE `chat_log` (
  `id` INT NOT NULL,
  `timestamp` INT,
  `user` TEXT,
  `message` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tracks` (
  `id` INT NOT NULL,
  `title` TEXT,
  `path` TEXT,
  `artist` TEXT,
  `album` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vetoes` (
  `id` INT NOT NULL,
  `timestamp` INT,
  `user` TEXT,
  `track_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `requests` (
  `id` INT NOT NULL,
  `timestamp` INT,
  `user` TEXT,
  `track_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_581433_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_581433_schema') AS relationships;
DROP DATABASE `db_581433_schema`;
UNINSTALL EXTENSION vsql_schematron;
