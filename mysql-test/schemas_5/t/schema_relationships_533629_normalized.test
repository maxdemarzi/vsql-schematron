INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 533629_normalized
--echo #
CREATE DATABASE `db_533629_normalized`;
USE `db_533629_normalized`;

CREATE TABLE `employee` (
  `employee_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `hire_date` DATETIME,
  `salary` DECIMAL(10,2),
  `manager` INT,
  `dept_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `employee_location` (
  `employee_id` INT,
  `office` VARCHAR(64),
  PRIMARY KEY (`employee_id`, `office`)
) CHARACTER SET latin1;

CREATE TABLE `location_phone_number` (
  `office` VARCHAR(64),
  `phone_number` VARCHAR(64),
  PRIMARY KEY (`office`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `dept_id` INT,
  `dept_name` VARCHAR(64),
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_533629_normalized') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_533629_normalized') AS relationships;
DROP DATABASE `db_533629_normalized`;
UNINSTALL EXTENSION vsql_schematron;
