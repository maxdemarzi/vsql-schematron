INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 572502_schema
--echo #
CREATE DATABASE `db_572502_schema`;
USE `db_572502_schema`;
CREATE TABLE `todos` (
  `id` INT NOT NULL,
  `groupId` INT,
  `task` VARCHAR(50),
  `done` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `groupId` INT NOT NULL,
  `groupName` VARCHAR(50),
  PRIMARY KEY (`groupId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_572502_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_572502_schema') AS relationships;
DROP DATABASE `db_572502_schema`;
UNINSTALL EXTENSION vsql_schematron;
