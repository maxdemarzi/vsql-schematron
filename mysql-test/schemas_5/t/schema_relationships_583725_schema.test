INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583725_schema
--echo #
CREATE DATABASE `db_583725_schema`;
USE `db_583725_schema`;

CREATE TABLE `books` (
  `book_id` INT,
  `title` VARCHAR(64),
  `year_first_published` INT,
  `current_price_dollar` DECIMAL(10,2),
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `authors_books` (
  `author_id` VARCHAR(64),
  `book_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583725_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583725_schema') AS relationships;
DROP DATABASE `db_583725_schema`;
UNINSTALL EXTENSION vsql_schematron;
