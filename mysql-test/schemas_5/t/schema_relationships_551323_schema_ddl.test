INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 551323_schema.ddl
--echo #
CREATE DATABASE `db_551323_schema_ddl`;
USE `db_551323_schema_ddl`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `email` VARCHAR(64),
  `user_name` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  `pic_url` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `queries` (
  `query_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created` DATETIME,
  `img_url` VARCHAR(64),
  `result` VARCHAR(64),
  PRIMARY KEY (`query_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `session_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `session_count` INT,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_551323_schema_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_551323_schema_ddl') AS relationships;
DROP DATABASE `db_551323_schema_ddl`;
UNINSTALL EXTENSION vsql_schematron;
