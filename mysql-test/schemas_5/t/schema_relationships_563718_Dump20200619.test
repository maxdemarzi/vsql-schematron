INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 563718_Dump20200619
--echo #
CREATE DATABASE `db_563718_Dump20200619`;
USE `db_563718_Dump20200619`;

CREATE TABLE `bank_business` (
  `idbank_business_id` INT,
  `business_id` INT,
  `score` INT,
  PRIMARY KEY (`idbank_business_id`)
) CHARACTER SET latin1;

CREATE TABLE `business` (
  `business_id` INT,
  `name` VARCHAR(64),
  `surplus` INT,
  PRIMARY KEY (`business_id`)
) CHARACTER SET latin1;

CREATE TABLE `deal` (
  `user_id` INT,
  `goods_id` INT,
  `deal_time` DATETIME,
  `deal_num` INT,
  `way_of_deal` INT,
  `deal_id` INT,
  PRIMARY KEY (`user_id`, `deal_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_information` (
  `user_id` INT,
  `user_name` VARCHAR(64),
  `user_account` VARCHAR(64),
  `user_secret` VARCHAR(64),
  `surplus` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_user_score` (
  `send_id` INT,
  `get_id` INT,
  `score` INT,
  `time` DATETIME,
  PRIMARY KEY (`send_id`, `get_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_563718_Dump20200619') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_563718_Dump20200619') AS relationships;
DROP DATABASE `db_563718_Dump20200619`;
UNINSTALL EXTENSION vsql_schematron;
