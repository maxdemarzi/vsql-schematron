INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 599673_airlines
--echo #
CREATE DATABASE `db_599673_airlines`;
USE `db_599673_airlines`;
CREATE TABLE `FLIGHTS` (
  `flight_no` INT NOT NULL,
  `fromPlace` VARCHAR(50),
  `toPlace` VARCHAR(50),
  `distance` INT,
  `departs` DATE,
  `arrives` DATE,
  `price` DOUBLE,
  PRIMARY KEY (`flight_no`)
) CHARACTER SET latin1;
CREATE TABLE `AIRCRAFT` (
  `a_id` INT NOT NULL,
  `a_name` VARCHAR(50),
  `cruisingrange` INT,
  PRIMARY KEY (`a_id`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEES` (
  `e_id` INT NOT NULL,
  `e_name` VARCHAR(50),
  `salary` INT,
  PRIMARY KEY (`e_id`)
) CHARACTER SET latin1;
CREATE TABLE `CERTIFIED` (
  `e_id` INT,
  `a_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_599673_airlines') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_599673_airlines') AS relationships;
DROP DATABASE `db_599673_airlines`;
UNINSTALL EXTENSION vsql_schematron;
