INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 527363_20190119184757_create_user_permissions
--echo #
CREATE DATABASE `db_527363_20190119184757_create_user_permissions`;
USE `db_527363_20190119184757_create_user_permissions`;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_permissions` (
  `id` INT,
  `role_id` INT,
  `permission_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `id` INT,
  `user_id` INT,
  `role_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `admins` (
  `id` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_527363_20190119184757_create_user_permissions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_527363_20190119184757_create_user_permissions') AS relationships;
DROP DATABASE `db_527363_20190119184757_create_user_permissions`;
UNINSTALL EXTENSION vsql_schematron;
