INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 584111_comercioyusuarios
--echo #
CREATE DATABASE `db_584111_comercioyusuarios`;
USE `db_584111_comercioyusuarios`;

CREATE TABLE `administradordeventas` (
  `IDVenta` VARCHAR(64),
  `ValorVenta` INT,
  `DescripcionVenta` INT,
  `FechaVenta` DATETIME,
  `FechaPago` DATETIME,
  `IDVendedor` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `gestionusuarios` (
  `IDUsuario` VARCHAR(64),
  `Nombre` VARCHAR(64),
  `Rol` VARCHAR(64),
  PRIMARY KEY (`IDUsuario`)
) CHARACTER SET latin1;

CREATE TABLE `gestionvendedores` (
  `IDVendedor` VARCHAR(64),
  `Nombre` VARCHAR(64),
  `Especialidad` VARCHAR(64),
  `Telefono` VARCHAR(64),
  `FechaIngreso` DATETIME,
  PRIMARY KEY (`IDVendedor`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_584111_comercioyusuarios') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_584111_comercioyusuarios') AS relationships;
DROP DATABASE `db_584111_comercioyusuarios`;
UNINSTALL EXTENSION vsql_schematron;
