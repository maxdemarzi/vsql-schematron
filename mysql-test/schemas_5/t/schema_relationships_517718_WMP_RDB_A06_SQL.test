INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 517718_WMP_RDB_A06_SQL
--echo #
CREATE DATABASE `db_517718_WMP_RDB_A06_SQL`;
USE `db_517718_WMP_RDB_A06_SQL`;

CREATE TABLE `gameTable` (
  `gameID` INT,
  `userName` VARCHAR(64),
  `isRunning` VARCHAR(64),
  PRIMARY KEY (`gameID`)
) CHARACTER SET latin1;

CREATE TABLE `questionTable` (
  `questionID` INT,
  `question` VARCHAR(64),
  PRIMARY KEY (`questionID`)
) CHARACTER SET latin1;

CREATE TABLE `scoreTable` (
  `gameID` INT,
  `questionID` INT,
  `timeTaken` INT,
  PRIMARY KEY (`gameID`, `questionID`)
) CHARACTER SET latin1;

CREATE TABLE `answersTable` (
  `answerID` INT,
  `answer1` VARCHAR(64),
  `answer2` VARCHAR(64),
  `answer3` VARCHAR(64),
  `answer4` VARCHAR(64),
  `correctAnswer` INT,
  PRIMARY KEY (`answerID`)
) CHARACTER SET latin1;

CREATE TABLE `leaderBoardTable` (
  `gameID` INT,
  `totalScore` INT,
  PRIMARY KEY (`gameID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_517718_WMP_RDB_A06_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_517718_WMP_RDB_A06_SQL') AS relationships;
DROP DATABASE `db_517718_WMP_RDB_A06_SQL`;
UNINSTALL EXTENSION vsql_schematron;
