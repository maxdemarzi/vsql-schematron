INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 585367_Emp_database
--echo #
CREATE DATABASE `db_585367_Emp_database`;
USE `db_585367_Emp_database`;

CREATE TABLE `salaries` (
  `emp_no` INT,
  `salary` INT
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `emp_no` INT,
  `emp_title_id` VARCHAR(255),
  `birth_date` DATETIME,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `sex` VARCHAR(255),
  `hire_date` DATETIME,
  PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;

CREATE TABLE `dept_manager` (
  `dept_no` VARCHAR(255),
  `emp_no` INT
) CHARACTER SET latin1;

CREATE TABLE `dept_emp` (
  `emp_no` INT,
  `dept_no` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_585367_Emp_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_585367_Emp_database') AS relationships;
DROP DATABASE `db_585367_Emp_database`;
UNINSTALL EXTENSION vsql_schematron;
