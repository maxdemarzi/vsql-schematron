INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543431_47-on-delete
--echo #
CREATE DATABASE `db_543431_47_on_delete`;
USE `db_543431_47_on_delete`;

CREATE TABLE `aaa` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bbb` (
  `id` INT,
  `a` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ccc` (
  `id` INT,
  `a` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ddd` (
  `id` INT,
  `a` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543431_47_on_delete') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543431_47_on_delete') AS relationships;
DROP DATABASE `db_543431_47_on_delete`;
UNINSTALL EXTENSION vsql_schematron;
