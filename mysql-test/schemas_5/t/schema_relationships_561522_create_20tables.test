INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 561522_create%20tables
--echo #
CREATE DATABASE `db_561522_create_20tables`;
USE `db_561522_create_20tables`;

CREATE TABLE `Emp` (
  `eid` INT,
  `ename` VARCHAR(64),
  `age` INT,
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`eid`)
) CHARACTER SET latin1;

CREATE TABLE `Works` (
  `eid` INT,
  `did` INT,
  `pct_time` INT,
  PRIMARY KEY (`eid`, `did`)
) CHARACTER SET latin1;

CREATE TABLE `Dept` (
  `did` INT,
  `dname` VARCHAR(64),
  `budget` DECIMAL(10,2),
  `managerid` INT,
  PRIMARY KEY (`did`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_561522_create_20tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_561522_create_20tables') AS relationships;
DROP DATABASE `db_561522_create_20tables`;
UNINSTALL EXTENSION vsql_schematron;
