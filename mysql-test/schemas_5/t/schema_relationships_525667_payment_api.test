INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 525667_payment_api
--echo #
CREATE DATABASE `db_525667_payment_api`;
USE `db_525667_payment_api`;

CREATE TABLE `merchant` (
  `id` INT,
  `name` VARCHAR(64),
  `code` INT
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `invoice_id` INT,
  `item_name` VARCHAR(64),
  `amount` INT,
  `payment_type` VARCHAR(64),
  `customer_name` VARCHAR(64),
  `merchant_id` INT,
  `references_id` VARCHAR(64),
  `number_va` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_525667_payment_api') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_525667_payment_api') AS relationships;
DROP DATABASE `db_525667_payment_api`;
UNINSTALL EXTENSION vsql_schematron;
