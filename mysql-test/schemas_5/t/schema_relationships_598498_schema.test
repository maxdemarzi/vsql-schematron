INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 598498_schema
--echo #
CREATE DATABASE `db_598498_schema`;
USE `db_598498_schema`;

CREATE TABLE `connector` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `icon` VARCHAR(64),
  `tags` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `connector_property` (
  `id` INT,
  `connector_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `secret` BOOL,
  `type` VARCHAR(64),
  `default_value` VARCHAR(64),
  `required` BOOL,
  `property_index` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `action` (
  `id` INT,
  `connector_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `tags` VARCHAR(64),
  `camel_connector_gav` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `action_property` (
  `id` INT,
  `action_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `secret` BOOL,
  `type` VARCHAR(64),
  `default_value` VARCHAR(64),
  `property_index` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `configured_connector` (
  `id` INT,
  `connector_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `properties` VARCHAR(64),
  `tags` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `action_instance` (
  `id` INT,
  `action_id` INT,
  `configured_connector_id` INT,
  `properties` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `integration` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `tags` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `integration_step` (
  `id` INT,
  `integration_id` INT,
  `action_instance_id` INT,
  `step_index` INT,
  `step_type` VARCHAR(64),
  `properties` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_598498_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_598498_schema') AS relationships;
DROP DATABASE `db_598498_schema`;
UNINSTALL EXTENSION vsql_schematron;
