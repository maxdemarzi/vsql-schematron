INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 519666_create_schema_n_tables
--echo #
CREATE DATABASE `db_519666_create_schema_n_tables`;
USE `db_519666_create_schema_n_tables`;

CREATE TABLE `cities` (
  `CityName` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `forecast` (
  `CityName` VARCHAR(255),
  `Description` VARCHAR(255),
  `WindSpeed` DECIMAL(10,2),
  `Humidity` VARCHAR(255),
  `Pressure` VARCHAR(255),
  `TempMin` DECIMAL(10,2),
  `TempMax` DECIMAL(10,2),
  `FeelsLike` DECIMAL(10,2),
  `Temp` DECIMAL(10,2),
  `LocalTime` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_519666_create_schema_n_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_519666_create_schema_n_tables') AS relationships;
DROP DATABASE `db_519666_create_schema_n_tables`;
UNINSTALL EXTENSION vsql_schematron;
