INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 542884_contactee
--echo #
CREATE DATABASE `db_542884_contactee`;
USE `db_542884_contactee`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` INT,
  `created_at` INT,
  PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  `group_code` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64),
  PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item_group` (
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `country` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `programs` (
  `id` INT,
  `speciality` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student_registration` (
  `id` INT,
  `id_user` INT,
  `fullname` VARCHAR(64),
  `gender` VARCHAR(64),
  `birthday` DATETIME,
  `id_country` INT,
  `email` VARCHAR(64),
  `photo_passport` VARCHAR(64),
  `pdf_attestat` VARCHAR(64),
  `pdf_motivation` VARCHAR(64),
  `id_uni_1` INT,
  `id_program_1` INT,
  `datetime_reg_1` DATETIME,
  `id_uni_2` INT,
  `id_program_2` INT,
  `datetime_reg_2` DATETIME,
  `id_uni_3` INT,
  `id_program_3` INT,
  `datetime_reg_3` DATETIME,
  `id_uni_4` INT,
  `id_program_4` INT,
  `datetime_reg_4` DATETIME,
  `id_uni_5` INT,
  `id_program_5` INT,
  `datetime_reg_5` DATETIME,
  `id_uni_accepted_1` INT,
  `id_uni_accepted_2` INT,
  `id_uni_accepted_3` INT,
  `id_uni_accepted_4` INT,
  `id_uni_accepted_5` INT,
  `visa` VARCHAR(64),
  `datetime_visa` DATETIME,
  `status_visa` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `university` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_542884_contactee') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_542884_contactee') AS relationships;
DROP DATABASE `db_542884_contactee`;
UNINSTALL EXTENSION vsql_schematron;
