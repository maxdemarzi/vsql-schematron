INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508628_migration
--echo #
CREATE DATABASE `db_508628_migration`;
USE `db_508628_migration`;

CREATE TABLE `accounts` (
  `id` INT,
  `compound_id` VARCHAR(255),
  `user_id` INT,
  `provider_type` VARCHAR(255),
  `provider_id` VARCHAR(255),
  `provider_account_id` VARCHAR(255),
  `refresh_token` VARCHAR(255),
  `access_token` VARCHAR(255),
  `access_token_expires` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` INT,
  `user_id` INT,
  `expires` DATETIME,
  `session_token` VARCHAR(255),
  `access_token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `username` VARCHAR(255),
  `email_verified` DATETIME,
  `image` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `verification_requests` (
  `id` INT,
  `identifier` VARCHAR(255),
  `token` VARCHAR(255),
  `expires` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `folders` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `user_id` INT,
  `order_index` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clips` (
  `id` VARCHAR(255),
  `name` VARCHAR(255),
  `url` VARCHAR(255),
  `folder_id` VARCHAR(255),
  `order_index` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508628_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508628_migration') AS relationships;
DROP DATABASE `db_508628_migration`;
UNINSTALL EXTENSION vsql_schematron;
