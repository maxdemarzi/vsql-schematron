INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580105_Basics
--echo #
CREATE DATABASE `db_580105_Basics`;
USE `db_580105_Basics`;

CREATE TABLE `clothes_line` (
  `collection` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `rlist` (
  `num` INT,
  `rname` VARCHAR(64),
  `address` VARCHAR(64),
  `income` INT,
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `num` INT,
  `meal` VARCHAR(64),
  `mealtype` VARCHAR(64),
  `price` INT,
  `rnum` INT,
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;

CREATE TABLE `planes` (
  `num` INT,
  `country_start` VARCHAR(64),
  `country_arrival` VARCHAR(64),
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;

CREATE TABLE `ftype` (
  `num` INT,
  `flight_type` VARCHAR(64),
  `food` VARCHAR(64),
  `plane_num` INT,
  PRIMARY KEY (`num`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580105_Basics') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580105_Basics') AS relationships;
DROP DATABASE `db_580105_Basics`;
UNINSTALL EXTENSION vsql_schematron;
