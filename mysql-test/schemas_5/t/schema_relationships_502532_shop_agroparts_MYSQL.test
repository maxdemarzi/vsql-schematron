INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 502532_shop-agroparts.MYSQL
--echo #
CREATE DATABASE `db_502532_shop_agroparts_MYSQL`;
USE `db_502532_shop_agroparts_MYSQL`;

CREATE TABLE `TRANSPORT` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `group` VARCHAR(64),
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `PARTS` (
  `id` INT,
  `name` VARCHAR(64),
  `code` VARCHAR(64),
  `price` DECIMAL(10,2),
  `image` VARCHAR(64),
  `is_del` BOOL,
  `status` INT,
  `create_date` DATETIME,
  `change_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TRANSPORT_PARTS` (
  `id` INT,
  `transpotr_id` INT,
  `parts_id` INT,
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `WAREHOUSE` (
  `id` INT,
  `parts_id` INT,
  `quantity` INT,
  `status` INT,
  `create_date` DATETIME,
  `change_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `MERCHANT` (
  `id` INT,
  `name` VARCHAR(64),
  `location_id` INT,
  `description` VARCHAR(64),
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CUSTOMER` (
  `id` INT,
  `name` VARCHAR(64),
  `location_id` INT,
  `description` VARCHAR(64),
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `LOCATION` (
  `id` INT,
  `postal_code` INT,
  `city` VARCHAR(64),
  `region` VARCHAR(64),
  `country` VARCHAR(64),
  `create_date` DATETIME,
  `change_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ORDERS` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `client_id` INT,
  `type` VARCHAR(64),
  `status` INT,
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ORDER_ITEMS` (
  `id` INT,
  `order_id` INT,
  `warehouse_id` INT,
  `status` INT,
  `is_del` BOOL,
  `create_date` DATETIME,
  `change_date` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_502532_shop_agroparts_MYSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_502532_shop_agroparts_MYSQL') AS relationships;
DROP DATABASE `db_502532_shop_agroparts_MYSQL`;
UNINSTALL EXTENSION vsql_schematron;
