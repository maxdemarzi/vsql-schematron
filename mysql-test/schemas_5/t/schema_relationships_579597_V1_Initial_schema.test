INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 579597_V1_Initial_schema
--echo #
CREATE DATABASE `db_579597_V1_Initial_schema`;
USE `db_579597_V1_Initial_schema`;

CREATE TABLE `course_lectures` (
  `course_id` VARCHAR(255),
  `lecture_id` VARCHAR(255),
  `lecture_ordinal` INT,
  PRIMARY KEY (`course_id`, `lecture_id`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `course_id` VARCHAR(255),
  `course_title` VARCHAR(255),
  `course_description` VARCHAR(255),
  `author_id` VARCHAR(255),
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;

CREATE TABLE `lecture_units` (
  `lecture_id` VARCHAR(255),
  `unit_id` VARCHAR(255),
  `unit_ordinal` INT,
  PRIMARY KEY (`lecture_id`, `unit_id`)
) CHARACTER SET latin1;

CREATE TABLE `lectures` (
  `lecture_id` VARCHAR(255),
  `lecture_title` VARCHAR(255),
  `lecture_description` VARCHAR(255),
  `author_id` VARCHAR(255),
  PRIMARY KEY (`lecture_id`)
) CHARACTER SET latin1;

CREATE TABLE `units` (
  `unit_id` VARCHAR(255),
  `unit_type` VARCHAR(255),
  `unit_title` VARCHAR(255),
  `author_id` VARCHAR(255),
  PRIMARY KEY (`unit_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_id` VARCHAR(255),
  `user_email` VARCHAR(255),
  `user_password` VARCHAR(255),
  `user_name` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_579597_V1_Initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_579597_V1_Initial_schema') AS relationships;
DROP DATABASE `db_579597_V1_Initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
