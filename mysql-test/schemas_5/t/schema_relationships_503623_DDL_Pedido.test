INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 503623_DDL_Pedido
--echo #
CREATE DATABASE `db_503623_DDL_Pedido`;
USE `db_503623_DDL_Pedido`;
CREATE TABLE `ITEM` (
  `IDITEM` INT NOT NULL,
  `DESCITEM` VARCHAR(50),
  PRIMARY KEY (`IDITEM`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOCAB` (
  `IDPEDIDOCAB` INT NOT NULL,
  `DTEMISSAO` DATE,
  `NUMERO` INT,
  `CLIENTE` VARCHAR(50),
  PRIMARY KEY (`IDPEDIDOCAB`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOITEM` (
  `IDPEDIDOITEM` INT NOT NULL,
  `IDPEDIDOCAB` INT,
  `IDITEM` INT,
  `QUANTIDADE` DOUBLE,
  `VALORUNIT` DOUBLE,
  `VALORTOTAL` DOUBLE,
  PRIMARY KEY (`IDPEDIDOITEM`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_503623_DDL_Pedido') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_503623_DDL_Pedido') AS relationships;
DROP DATABASE `db_503623_DDL_Pedido`;
UNINSTALL EXTENSION vsql_schematron;
