INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583044_data
--echo #
CREATE DATABASE `db_583044_data`;
USE `db_583044_data`;
CREATE TABLE `personajes_peliculas` (
  `id_pelicula` INT,
  `id_personaje` INT
) CHARACTER SET latin1;
CREATE TABLE `peliculas` (
  `id` INT,
  `imagen` VARCHAR(50),
  `titulo` VARCHAR(50),
  `fecha_creacion` TIMESTAMP NULL,
  `id_genero` INT,
  `id_calificacion` INT
) CHARACTER SET latin1;
CREATE TABLE `calificaciones` (
  `id` INT,
  `calificacion` INT
) CHARACTER SET latin1;
CREATE TABLE `generos` (
  `id` INT,
  `nombre` VARCHAR(50),
  `imagen` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `personajes` (
  `id` INT,
  `nombre` VARCHAR(50),
  `imagen` VARCHAR(50),
  `edad` INT,
  `peso` INT,
  `historia` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id` INT,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `passwordd` VARCHAR(50),
  `rol` VARCHAR(50),
  `lockedd` BOOLEAN,
  `enablee` BOOLEAN
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583044_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583044_data') AS relationships;
DROP DATABASE `db_583044_data`;
UNINSTALL EXTENSION vsql_schematron;
