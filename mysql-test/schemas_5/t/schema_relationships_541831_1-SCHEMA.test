INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 541831_1-SCHEMA
--echo #
CREATE DATABASE `db_541831_1_SCHEMA`;
USE `db_541831_1_SCHEMA`;
CREATE TABLE `company` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `computer` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `introduced` TIMESTAMP NULL,
  `discontinued` TIMESTAMP NULL,
  `company_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `role` VARCHAR(50),
  `active` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_541831_1_SCHEMA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_541831_1_SCHEMA') AS relationships;
DROP DATABASE `db_541831_1_SCHEMA`;
UNINSTALL EXTENSION vsql_schematron;
