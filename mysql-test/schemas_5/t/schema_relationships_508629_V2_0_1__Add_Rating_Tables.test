INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508629_V2_0_1__Add_Rating_Tables
--echo #
CREATE DATABASE `db_508629_V2_0_1__Add_Rating_Tables`;
USE `db_508629_V2_0_1__Add_Rating_Tables`;
CREATE TABLE `imdb_users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_rating` (
  `id` INT NOT NULL,
  `movie_id` INT,
  `user_id` INT,
  `rating` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508629_V2_0_1__Add_Rating_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508629_V2_0_1__Add_Rating_Tables') AS relationships;
DROP DATABASE `db_508629_V2_0_1__Add_Rating_Tables`;
UNINSTALL EXTENSION vsql_schematron;
