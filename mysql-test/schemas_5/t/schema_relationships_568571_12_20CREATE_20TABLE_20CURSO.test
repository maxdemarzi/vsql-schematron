INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568571_12%20CREATE%20TABLE%20CURSO
--echo #
CREATE DATABASE `db_568571_12_20CREATE_20TABLE_20CURSO`;
USE `db_568571_12_20CREATE_20TABLE_20CURSO`;
CREATE TABLE `PERIODO` (
  `id` DECIMAL(10,2),
  `idFechaInicial` DATE,
  `idFechaFinal` DATE
) CHARACTER SET latin1;
CREATE TABLE `Curso` (
  `id` DECIMAL(10,2),
  `nombre` VARCHAR(50),
  `costo` DECIMAL(10,2),
  `idHorarioSemanal` DECIMAL(10,2),
  `idHoraInicio` DECIMAL(10,2),
  `idHoraFinal` DECIMAL(10,2),
  `idMercadoMeta` DECIMAL(10,2),
  `isActivo` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `ProfesoresXCurso` (
  `idProfesor` DECIMAL(10,2),
  `idCurso` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568571_12_20CREATE_20TABLE_20CURSO') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568571_12_20CREATE_20TABLE_20CURSO') AS relationships;
DROP DATABASE `db_568571_12_20CREATE_20TABLE_20CURSO`;
UNINSTALL EXTENSION vsql_schematron;
