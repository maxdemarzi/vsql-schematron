INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582540_25_RSS_Feeds
--echo #
CREATE DATABASE `db_582540_25_RSS_Feeds`;
USE `db_582540_25_RSS_Feeds`;
CREATE TABLE `channels` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  `link` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `description` TEXT,
  `content` TEXT,
  `link` VARCHAR(50),
  `is_read` BOOLEAN,
  `timestamp` TIMESTAMP NULL,
  `channel` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582540_25_RSS_Feeds') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582540_25_RSS_Feeds') AS relationships;
DROP DATABASE `db_582540_25_RSS_Feeds`;
UNINSTALL EXTENSION vsql_schematron;
