INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 584631_migration
--echo #
CREATE DATABASE `db_584631_migration`;
USE `db_584631_migration`;
CREATE TABLE `Team` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Member` (
  `id` VARCHAR(50) NOT NULL,
  `role` TEXT,
  `teamId` TEXT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Pet` (
  `id` INT NOT NULL,
  `name` TEXT,
  `species` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_584631_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_584631_migration') AS relationships;
DROP DATABASE `db_584631_migration`;
UNINSTALL EXTENSION vsql_schematron;
