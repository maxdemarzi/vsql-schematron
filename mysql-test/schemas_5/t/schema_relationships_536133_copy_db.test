INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 536133_copy_db
--echo #
CREATE DATABASE `db_536133_copy_db`;
USE `db_536133_copy_db`;

CREATE TABLE `User` (
  `UserId` INT,
  `FullName` VARCHAR(255),
  PRIMARY KEY (`UserId`)
) CHARACTER SET latin1;

CREATE TABLE `Event` (
  `EventId` INT,
  `EventName` VARCHAR(255),
  `DueDate` DATETIME,
  `Description` VARCHAR(255),
  PRIMARY KEY (`EventId`)
) CHARACTER SET latin1;

CREATE TABLE `CreateEvent` (
  `EventId` INT,
  `UserId` INT
) CHARACTER SET latin1;

CREATE TABLE `Account` (
  `LatestLoginTime` DATETIME,
  `Username` VARCHAR(255),
  `HashedPassword` VARCHAR(255),
  `CreatedTime` DATETIME,
  `UserId` INT
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `CourseId` INT,
  `CourseName` VARCHAR(255),
  `Professor` VARCHAR(255),
  `MeetingTime` DATETIME,
  PRIMARY KEY (`CourseId`)
) CHARACTER SET latin1;

CREATE TABLE `CourseLink` (
  `CourseId` INT,
  `Link` VARCHAR(255),
  `Tag` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `Enrollment` (
  `CourseId` INT,
  `UserId` INT
) CHARACTER SET latin1;

CREATE TABLE `Assign` (
  `AssignId` INT,
  `EventId` INT,
  `CourseId` INT,
  PRIMARY KEY (`AssignId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_536133_copy_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_536133_copy_db') AS relationships;
DROP DATABASE `db_536133_copy_db`;
UNINSTALL EXTENSION vsql_schematron;
