INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583750_script
--echo #
CREATE DATABASE `db_583750_script`;
USE `db_583750_script`;
CREATE TABLE `clients` (
  `id` INT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `email` VARCHAR(50),
  `phoneNumber` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `zip` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `account_type` VARCHAR(50),
  `balance` DECIMAL(10,2),
  `client_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583750_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583750_script') AS relationships;
DROP DATABASE `db_583750_script`;
UNINSTALL EXTENSION vsql_schematron;
