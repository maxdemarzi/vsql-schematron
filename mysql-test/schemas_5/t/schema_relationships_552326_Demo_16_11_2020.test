INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552326_Demo-16-11-2020
--echo #
CREATE DATABASE `db_552326_Demo_16_11_2020`;
USE `db_552326_Demo_16_11_2020`;

CREATE TABLE `Countries` (
  `Id` INT,
  `Name` VARCHAR(64),
  `Population` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Towns` (
  `Id` INT,
  `Name` VARCHAR(64),
  `CoutryId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552326_Demo_16_11_2020') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552326_Demo_16_11_2020') AS relationships;
DROP DATABASE `db_552326_Demo_16_11_2020`;
UNINSTALL EXTENSION vsql_schematron;
