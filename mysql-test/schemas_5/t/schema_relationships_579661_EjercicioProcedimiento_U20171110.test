INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 579661_EjercicioProcedimiento_U20171110
--echo #
CREATE DATABASE `db_579661_EjercicioProcedimiento_U20171110`;
USE `db_579661_EjercicioProcedimiento_U20171110`;
CREATE TABLE `alumno` (
  `alumno_carnet` VARCHAR(50) NOT NULL,
  `alumno_nombreCompleto` VARCHAR(50),
  PRIMARY KEY (`alumno_carnet`)
) CHARACTER SET latin1;
CREATE TABLE `materia` (
  `materia_codigo` VARCHAR(50) NOT NULL,
  `materia_nombre` VARCHAR(50),
  `materia_uv` INT,
  PRIMARY KEY (`materia_codigo`)
) CHARACTER SET latin1;
CREATE TABLE `inscripcion` (
  `alumno_carnet` VARCHAR(50) NOT NULL,
  `materia_codigo` VARCHAR(50) NOT NULL,
  `inscripcion_ciclo` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`alumno_carnet`, `materia_codigo`, `inscripcion_ciclo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_579661_EjercicioProcedimiento_U20171110') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_579661_EjercicioProcedimiento_U20171110') AS relationships;
DROP DATABASE `db_579661_EjercicioProcedimiento_U20171110`;
UNINSTALL EXTENSION vsql_schematron;
