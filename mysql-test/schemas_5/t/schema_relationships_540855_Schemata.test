INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 540855_Schemata
--echo #
CREATE DATABASE `db_540855_Schemata`;
USE `db_540855_Schemata`;

CREATE TABLE `Department` (
  `dept_no` VARCHAR(255),
  `dept_name` VARCHAR(255),
  PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;

CREATE TABLE `Employee` (
  `emp_no` INT,
  `birth_date` DATETIME,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `gender` VARCHAR(255),
  `hire_date` DATETIME,
  PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;

CREATE TABLE `Dept_Emp` (
  `emp_no` INT,
  `dept_no` VARCHAR(255),
  `from_date` DATETIME,
  `to_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `Dept_Managers` (
  `dept_no` VARCHAR(255),
  `emp_no` INT,
  `from_date` DATETIME,
  `to_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `Salaries` (
  `emp_no` INT,
  `salary` INT,
  `from_date` DATETIME,
  `to_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `Titles` (
  `emp_no` INT,
  `title` VARCHAR(255),
  `from_date` DATETIME,
  `to_date` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_540855_Schemata') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_540855_Schemata') AS relationships;
DROP DATABASE `db_540855_Schemata`;
UNINSTALL EXTENSION vsql_schematron;
