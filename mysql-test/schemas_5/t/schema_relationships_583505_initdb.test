INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583505_initdb
--echo #
CREATE DATABASE `db_583505_initdb`;
USE `db_583505_initdb`;

CREATE TABLE `coffees` (
  `id` INT,
  `coffee_name` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `salespeople` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `commission_rate` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `id` INT,
  `company_name` VARCHAR(64),
  `street_address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `customer_id` INT,
  `salesperson_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_items` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `product_quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583505_initdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583505_initdb') AS relationships;
DROP DATABASE `db_583505_initdb`;
UNINSTALL EXTENSION vsql_schematron;
