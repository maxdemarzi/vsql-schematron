INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 549649_project_v2
--echo #
CREATE DATABASE `db_549649_project_v2`;
USE `db_549649_project_v2`;

CREATE TABLE `locations` (
  `location_id` INT,
  `city` VARCHAR(255),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;

CREATE TABLE `customers` (
  `customer_id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `phone_number` VARCHAR(255),
  `location_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `hotels` (
  `hotel_id` INT,
  `location_id` INT,
  `hotel_name` VARCHAR(255),
  PRIMARY KEY (`hotel_id`)
) CHARACTER SET latin1;

CREATE TABLE `sections` (
  `hotel_id` INT,
  `section_id` INT,
  `room_type` VARCHAR(255),
  PRIMARY KEY (`hotel_id`, `section_id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `sale_id` INT,
  `apply_month` INT,
  `sale_percent` INT,
  PRIMARY KEY (`sale_id`)
) CHARACTER SET latin1;

CREATE TABLE `rooms` (
  `room_id` INT,
  `hotel_id` INT,
  `section_id` INT,
  `sale_id` INT,
  `floor` INT,
  PRIMARY KEY (`hotel_id`, `section_id`, `room_id`)
) CHARACTER SET latin1;

CREATE TABLE `reservations` (
  `reservation_id` INT,
  `customer_id` INT,
  `hotel_id` INT,
  `section_id` INT,
  `room_id` INT,
  `day_start` DATETIME,
  `day_end` DATETIME,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`reservation_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_549649_project_v2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_549649_project_v2') AS relationships;
DROP DATABASE `db_549649_project_v2`;
UNINSTALL EXTENSION vsql_schematron;
