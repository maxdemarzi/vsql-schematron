INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534418_createRelations
--echo #
CREATE DATABASE `db_534418_createRelations`;
USE `db_534418_createRelations`;

CREATE TABLE `EMPLOYEE` (
  `EMPLOYEEID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `PHONE` VARCHAR(64),
  `POSITION` VARCHAR(64),
  `LEADERID` VARCHAR(64),
  PRIMARY KEY (`EMPLOYEEID`)
) CHARACTER SET latin1;

CREATE TABLE `FACTORY` (
  `FACTORYID` VARCHAR(64),
  `FACTORYNAME` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  `PHONE` VARCHAR(64),
  PRIMARY KEY (`FACTORYID`)
) CHARACTER SET latin1;

CREATE TABLE `BUYRECORD` (
  `BUYRECORDID` VARCHAR(64),
  `DATE` DATETIME,
  `TIME` DATETIME,
  `FACTORYID` VARCHAR(64),
  `BUYERID` VARCHAR(64),
  PRIMARY KEY (`BUYRECORDID`)
) CHARACTER SET latin1;

CREATE TABLE `CLIENT` (
  `CLIENTID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `PHONE` VARCHAR(64),
  PRIMARY KEY (`CLIENTID`)
) CHARACTER SET latin1;

CREATE TABLE `SALERECORD` (
  `SALERECORDID` VARCHAR(64),
  `DATE` DATETIME,
  `TIME` DATETIME,
  `CLIENTID` VARCHAR(64),
  `SALERID` VARCHAR(64),
  PRIMARY KEY (`SALERECORDID`)
) CHARACTER SET latin1;

CREATE TABLE `TYPE` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `FATHERID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `MEDICINE` (
  `MEDICINEID` VARCHAR(64),
  `MEDICINENAME` VARCHAR(64),
  `TYPEID` VARCHAR(64),
  `BUYPRICE` DECIMAL(10,2),
  `SALEPRICE` DECIMAL(10,2),
  `PRODUCERID` VARCHAR(64),
  PRIMARY KEY (`MEDICINEID`)
) CHARACTER SET latin1;

CREATE TABLE `BUYRECORDEXP` (
  `BUYRECORDID` VARCHAR(64),
  `MEDICINEID` VARCHAR(64),
  `QUANTITY` INT,
  `BUYPRICE` DECIMAL(10,2),
  `PRODUCEDATE` DATETIME,
  PRIMARY KEY (`BUYRECORDID`, `MEDICINEID`)
) CHARACTER SET latin1;

CREATE TABLE `SALERECORDEXP` (
  `SALERECORDID` VARCHAR(64),
  `MEDICINEID` VARCHAR(64),
  `QUANTITY` INT,
  `SALEPRICE` DECIMAL(10,2),
  `PRODUCEDATE` DATETIME,
  PRIMARY KEY (`SALERECORDID`, `MEDICINEID`, `PRODUCEDATE`)
) CHARACTER SET latin1;

CREATE TABLE `STOCK` (
  `MEDICINEID` VARCHAR(64),
  `PRODUCEDATE` DATETIME,
  `EFFICIENTDATE` DATETIME,
  `STOCK` INT,
  PRIMARY KEY (`MEDICINEID`, `PRODUCEDATE`)
) CHARACTER SET latin1;

CREATE TABLE `RETURNFACTORY` (
  `MEDICINEID` VARCHAR(64),
  `PRODUCEDATE` DATETIME,
  `EFFICIENTDATE` DATETIME,
  `STOCK` INT,
  PRIMARY KEY (`MEDICINEID`, `PRODUCEDATE`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534418_createRelations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534418_createRelations') AS relationships;
DROP DATABASE `db_534418_createRelations`;
UNINSTALL EXTENSION vsql_schematron;
