INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 575496_Create_Products
--echo #
CREATE DATABASE `db_575496_Create_Products`;
USE `db_575496_Create_Products`;

CREATE TABLE `product_type` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `type_id` DECIMAL(10,2),
  `expired_date` DATETIME,
  `price` DECIMAL(10,2),
  `quantity` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_575496_Create_Products') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_575496_Create_Products') AS relationships;
DROP DATABASE `db_575496_Create_Products`;
UNINSTALL EXTENSION vsql_schematron;
