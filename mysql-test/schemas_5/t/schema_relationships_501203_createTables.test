INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501203_createTables
--echo #
CREATE DATABASE `db_501203_createTables`;
USE `db_501203_createTables`;
CREATE TABLE `post` (
  `post_id` INT NOT NULL,
  `title` VARCHAR(50),
  `text` VARCHAR(50),
  `picture` VARCHAR(50),
  `picture_text` VARCHAR(50),
  `date_created` VARCHAR(50),
  `category` VARCHAR(50),
  `importance` INT,
  `active` INT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `comment_id` INT NOT NULL,
  `commenter` VARCHAR(50),
  `text` VARCHAR(50),
  `comment_date` BIGINT,
  `active` INT,
  `post_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501203_createTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501203_createTables') AS relationships;
DROP DATABASE `db_501203_createTables`;
UNINSTALL EXTENSION vsql_schematron;
