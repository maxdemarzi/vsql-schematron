INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 560257_V1__init
--echo #
CREATE DATABASE `db_560257_V1__init`;
USE `db_560257_V1__init`;
CREATE TABLE `privilege` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `label` VARCHAR(50),
  `active` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `label` VARCHAR(50),
  `active` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_privilege` (
  `id` BIGINT NOT NULL,
  `role_id` BIGINT,
  `privilege_id` BIGINT,
  `active` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `active` VARCHAR(50),
  `country_phone_code` VARCHAR(50),
  `email_id` VARCHAR(50),
  `federation_id` VARCHAR(50),
  `federation_type` VARCHAR(50),
  `mobile_number` VARCHAR(50),
  `password` VARCHAR(50),
  `salt` VARCHAR(50),
  `user_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `role_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_560257_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_560257_V1__init') AS relationships;
DROP DATABASE `db_560257_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
