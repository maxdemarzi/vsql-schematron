INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 593661_init
--echo #
CREATE DATABASE `db_593661_init`;
USE `db_593661_init`;

CREATE TABLE `results` (
  `run` VARCHAR(255),
  `lang` VARCHAR(255),
  `backend` VARCHAR(255),
  `benchmark` VARCHAR(255),
  `trial` INT,
  `t_compile` DECIMAL(10,2),
  `t_run` DECIMAL(10,2),
  `ans` VARCHAR(255),
  `err` VARCHAR(255),
  PRIMARY KEY (`run`, `lang`, `backend`, `benchmark`, `trial`)
) CHARACTER SET latin1;

CREATE TABLE `runs` (
  `run` VARCHAR(255),
  `run_timestamp` INT,
  `hostname` VARCHAR(255),
  PRIMARY KEY (`run`)
) CHARACTER SET latin1;

CREATE TABLE `commits` (
  `commit_hash` VARCHAR(255),
  `commit_timestamp` INT,
  PRIMARY KEY (`commit_hash`)
) CHARACTER SET latin1;

CREATE TABLE `ci_runs` (
  `commit_hash` VARCHAR(255),
  PRIMARY KEY (`commit_hash`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_593661_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_593661_init') AS relationships;
DROP DATABASE `db_593661_init`;
UNINSTALL EXTENSION vsql_schematron;
