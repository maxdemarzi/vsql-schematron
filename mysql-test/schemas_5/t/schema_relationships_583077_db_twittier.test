INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583077_db_twittier
--echo #
CREATE DATABASE `db_583077_db_twittier`;
USE `db_583077_db_twittier`;

CREATE TABLE `comments` (
  `original_post` INT,
  `comment_id` INT
) CHARACTER SET latin1;

CREATE TABLE `post_hashtag` (
  `post_id` INT,
  `hashtag_id` INT
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `post_text` VARCHAR(64),
  `attachment` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583077_db_twittier') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583077_db_twittier') AS relationships;
DROP DATABASE `db_583077_db_twittier`;
UNINSTALL EXTENSION vsql_schematron;
