INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 514702_baseschema
--echo #
CREATE DATABASE `db_514702_baseschema`;
USE `db_514702_baseschema`;

CREATE TABLE `db_patch` (
  `id` INT,
  `apply_datetime` INT,
  `patch_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `uuid` VARCHAR(255),
  `create_datetime` INT,
  `last_datetime` INT,
  `user_agent` VARCHAR(255),
  `user_os_name` VARCHAR(255),
  `user_agent_type` VARCHAR(255),
  `user_agent_family` VARCHAR(255),
  `user_agent_name` VARCHAR(255),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `game` (
  `uuid` VARCHAR(255),
  `host_uuid` VARCHAR(255),
  `invite_code` VARCHAR(255),
  `state` VARCHAR(255),
  `maxPlayers` INT,
  `mapId` INT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `game_player` (
  `id` INT,
  `game_uuid` VARCHAR(255),
  `client_uuid` VARCHAR(255),
  `player_idx` INT,
  `name` VARCHAR(255),
  `colour_r` INT,
  `colour_g` INT,
  `colour_b` INT,
  `population` INT,
  `wood` INT,
  `coin` INT,
  `food` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_514702_baseschema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_514702_baseschema') AS relationships;
DROP DATABASE `db_514702_baseschema`;
UNINSTALL EXTENSION vsql_schematron;
