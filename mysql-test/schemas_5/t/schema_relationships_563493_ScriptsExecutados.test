INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 563493_ScriptsExecutados
--echo #
CREATE DATABASE `db_563493_ScriptsExecutados`;
USE `db_563493_ScriptsExecutados`;

CREATE TABLE `clientes` (
  `codigo` INT,
  `nome` VARCHAR(64),
  `cidade` VARCHAR(64),
  `uf` VARCHAR(64),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `produtos` (
  `codigo` INT,
  `descricao` VARCHAR(64),
  `precovenda` DECIMAL(10,2),
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;

CREATE TABLE `pedidos_dados_gerais` (
  `numero` INT,
  `codigo_cli` INT,
  `emissao` DATETIME,
  `valortotal` DECIMAL(10,2),
  PRIMARY KEY (`numero`)
) CHARACTER SET latin1;

CREATE TABLE `pedidos_produtos` (
  `id` INT,
  `numeropedido` INT,
  `codigoproduto` INT,
  `quantidade` DECIMAL(10,2),
  `valorunitario` DECIMAL(10,2),
  `valortotal` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_563493_ScriptsExecutados') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_563493_ScriptsExecutados') AS relationships;
DROP DATABASE `db_563493_ScriptsExecutados`;
UNINSTALL EXTENSION vsql_schematron;
