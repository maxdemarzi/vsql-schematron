INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 533378_geekboard
--echo #
CREATE DATABASE `db_533378_geekboard`;
USE `db_533378_geekboard`;

CREATE TABLE `auth_users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `full_name` VARCHAR(64),
  `date_joined` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `job_applications` (
  `id` INT,
  `job_id` INT,
  `applied_on` DATETIME,
  `full_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `cover_letter` VARCHAR(64),
  `coding_task_solution` VARCHAR(64),
  `status` VARCHAR(64),
  `message` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `job_details` (
  `id` INT,
  `title` VARCHAR(64),
  `details` VARCHAR(64),
  `coding_task` VARCHAR(64),
  `posted_on` DATETIME,
  `company` VARCHAR(64),
  `location` VARCHAR(64),
  `posted_by` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_533378_geekboard') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_533378_geekboard') AS relationships;
DROP DATABASE `db_533378_geekboard`;
UNINSTALL EXTENSION vsql_schematron;
