INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532196_V024__Add_Privileges
--echo #
CREATE DATABASE `db_532196_V024__Add_Privileges`;
USE `db_532196_V024__Add_Privileges`;
CREATE TABLE `privileges` (
  `privilege_id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `module` VARCHAR(50),
  `category` VARCHAR(50),
  PRIMARY KEY (`privilege_id`)
) CHARACTER SET latin1;
CREATE TABLE `role_privilege` (
  `role_id` BIGINT NOT NULL,
  `privilege_id` BIGINT NOT NULL,
  PRIMARY KEY (`role_id`, `privilege_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532196_V024__Add_Privileges') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532196_V024__Add_Privileges') AS relationships;
DROP DATABASE `db_532196_V024__Add_Privileges`;
UNINSTALL EXTENSION vsql_schematron;
