INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577470_db
--echo #
CREATE DATABASE `db_577470_db`;
USE `db_577470_db`;

CREATE TABLE `payment` (
  `id` INT,
  `account_id` INT,
  `order_id` INT,
  `amount` DECIMAL(10,2),
  `currency` VARCHAR(64),
  `method` INT,
  `status` INT,
  `auth_code` VARCHAR(64),
  `created_at` DATETIME,
  `last_modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payment_request` (
  `pmt_gateway_id` VARCHAR(64),
  `pmt_id` INT,
  `amount` DECIMAL(10,2),
  `currency` VARCHAR(64),
  `name` VARCHAR(64),
  `number` VARCHAR(64),
  `cvv` INT,
  `exp_date` DATETIME,
  `method` INT,
  `status` INT,
  `auth_code` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`pmt_gateway_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577470_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577470_db') AS relationships;
DROP DATABASE `db_577470_db`;
UNINSTALL EXTENSION vsql_schematron;
