INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 575841_ProcessEngine.mysql
--echo #
CREATE DATABASE `db_575841_ProcessEngine_mysql`;
USE `db_575841_ProcessEngine_mysql`;

CREATE TABLE `#__deployment` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `deployed_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `#__execution` (
  `id` VARCHAR(64),
  `pid` VARCHAR(64),
  `process_id` VARCHAR(64),
  `definition_id` VARCHAR(64),
  `state` INT,
  `active` DECIMAL(10,2),
  `node` VARCHAR(64),
  `transition` VARCHAR(64),
  `depth` INT,
  `business_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `#__execution_variables` (
  `execution_id` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `value_blob` VARCHAR(64),
  PRIMARY KEY (`execution_id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `#__event_subscription` (
  `id` VARCHAR(64),
  `execution_id` VARCHAR(64),
  `activity_id` VARCHAR(64),
  `node` VARCHAR(64),
  `process_instance_id` VARCHAR(64),
  `flags` INT,
  `name` VARCHAR(64),
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_575841_ProcessEngine_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_575841_ProcessEngine_mysql') AS relationships;
DROP DATABASE `db_575841_ProcessEngine_mysql`;
UNINSTALL EXTENSION vsql_schematron;
