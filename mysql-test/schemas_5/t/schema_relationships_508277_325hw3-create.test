INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508277_325hw3-create
--echo #
CREATE DATABASE `db_508277_325hw3_create`;
USE `db_508277_325hw3_create`;
CREATE TABLE `Client` (
  `Cli_id` VARCHAR(50) NOT NULL,
  `Cli_lname` VARCHAR(50),
  `Cli_fname` VARCHAR(50),
  `Cli_phone` VARCHAR(50),
  PRIMARY KEY (`Cli_id`)
) CHARACTER SET latin1;
CREATE TABLE `Video` (
  `Vid_id` VARCHAR(50) NOT NULL,
  `Vid_format` VARCHAR(50),
  `Vid_purchase_date` DATE,
  `Vid_rental_price` DECIMAL(10,2),
  `Vid_length` INT,
  PRIMARY KEY (`Vid_id`)
) CHARACTER SET latin1;
CREATE TABLE `Rental` (
  `Cli_id` VARCHAR(50) NOT NULL,
  `Vid_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Cli_id`, `Vid_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508277_325hw3_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508277_325hw3_create') AS relationships;
DROP DATABASE `db_508277_325hw3_create`;
UNINSTALL EXTENSION vsql_schematron;
