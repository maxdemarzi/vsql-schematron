INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508822_cocok
--echo #
CREATE DATABASE `db_508822_cocok`;
USE `db_508822_cocok`;

CREATE TABLE `attribute` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `human` (
  `id` INT,
  `name` VARCHAR(64),
  `jenis_kelamin` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `score` (
  `id` INT,
  `human_id` INT,
  `sub_attribute_id` INT,
  `value` INT
) CHARACTER SET latin1;

CREATE TABLE `sub_attribute` (
  `id` INT,
  `attribute_id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508822_cocok') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508822_cocok') AS relationships;
DROP DATABASE `db_508822_cocok`;
UNINSTALL EXTENSION vsql_schematron;
