INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588200_pgsql_ddl
--echo #
CREATE DATABASE `db_588200_pgsql_ddl`;
USE `db_588200_pgsql_ddl`;
CREATE TABLE `organization` (
  `id` INT NOT NULL,
  `display_name` VARCHAR(50),
  `ogrn` BIGINT,
  `oktmo` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `organization_id` INT,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `middlename` VARCHAR(50),
  `birthday` DATE,
  `inn` BIGINT,
  `snils` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588200_pgsql_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588200_pgsql_ddl') AS relationships;
DROP DATABASE `db_588200_pgsql_ddl`;
UNINSTALL EXTENSION vsql_schematron;
