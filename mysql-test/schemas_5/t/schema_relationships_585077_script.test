INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 585077_script
--echo #
CREATE DATABASE `db_585077_script`;
USE `db_585077_script`;

CREATE TABLE `CLIENTE` (
  `CLI_nCOD` INT,
  `CLI_cNOME` VARCHAR(64),
  `CLI_cRG` VARCHAR(64),
  `CLI_cCPF` VARCHAR(64),
  `CLI_dDTNASC` DATETIME,
  `CLI_cGENERO` VARCHAR(64),
  `CLI_nTRESIDENCIAL` VARCHAR(64),
  `CLI_nTCELULAR` VARCHAR(64),
  `CLI_nTCOMERCIAL` VARCHAR(64),
  `CLI_cEMAIL` VARCHAR(64),
  `CLI_cSENHA` VARCHAR(64),
  `CLI_dDTULTIMO_ACESSO` DATETIME,
  `CLI_cSTATUS` VARCHAR(64),
  `CLI_tPREFERENCIA` VARCHAR(64),
  PRIMARY KEY (`CLI_nCOD`)
) CHARACTER SET latin1;

CREATE TABLE `ENDERECO` (
  `END_nID` INT,
  `END_nCEP` VARCHAR(64),
  `END_cLOGRADOURO` VARCHAR(64),
  `END_cCIDADE` VARCHAR(64),
  `END_cBAIRRO` VARCHAR(64),
  `END_nNUMERO` VARCHAR(64),
  `END_cCOMPLEMENTO` VARCHAR(64),
  `END_cTIPO` VARCHAR(64),
  `END_cUF` VARCHAR(64),
  `CLI_nCOD` INT,
  PRIMARY KEY (`END_nID`)
) CHARACTER SET latin1;

CREATE TABLE `PRODUTO` (
  `PRODUTO_nID` INT,
  `PRODUTO_cDESC` VARCHAR(64),
  `PRODUTO_cDESCCOMPLETA` VARCHAR(64),
  `PRODUTO_cSTATUS` VARCHAR(64),
  `PRODUTO_tsCRIACAO` DATETIME,
  `PRODUTO_tMATERIAL` VARCHAR(64),
  PRIMARY KEY (`PRODUTO_nID`)
) CHARACTER SET latin1;

CREATE TABLE `COR` (
  `COR_nID` INT,
  `COR_cDESC` VARCHAR(64),
  `COR_cHEX` VARCHAR(64),
  PRIMARY KEY (`COR_nID`)
) CHARACTER SET latin1;

CREATE TABLE `TAMANHO` (
  `TAMANHO_nID` INT,
  `TAMANHO_cTAMANHO` VARCHAR(64),
  `TAMANHO_cDESC` VARCHAR(64),
  PRIMARY KEY (`TAMANHO_nID`)
) CHARACTER SET latin1;

CREATE TABLE `USUARIO` (
  `USR_nCOD` INT,
  `USR_cSTATUS` VARCHAR(64),
  `USR_cLOGIN` VARCHAR(64),
  `USR_cSENHA` VARCHAR(64),
  `USR_cNOME` VARCHAR(64),
  `USR_nPERMISSAO` INT,
  `USR_EMAIL` VARCHAR(64),
  PRIMARY KEY (`USR_nCOD`)
) CHARACTER SET latin1;

CREATE TABLE `CATEGORIA` (
  `CATEGORIA_nID` INT,
  `CATEGORIA_cDESC` VARCHAR(64),
  `CATEGORIA_cSTATUS` VARCHAR(64),
  `CATEGORIA_nCODPAI` INT,
  PRIMARY KEY (`CATEGORIA_nID`)
) CHARACTER SET latin1;

CREATE TABLE `PRODUTO_CATEGORIA` (
  `PRODUTO_CATEGORIA_nID` INT,
  `CATEGORIA_nID` INT,
  `PRODUTO_nID` INT,
  PRIMARY KEY (`PRODUTO_CATEGORIA_nID`)
) CHARACTER SET latin1;

CREATE TABLE `MAILMARKETING` (
  `ID` INT,
  `EMAIL` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_585077_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_585077_script') AS relationships;
DROP DATABASE `db_585077_script`;
UNINSTALL EXTENSION vsql_schematron;
