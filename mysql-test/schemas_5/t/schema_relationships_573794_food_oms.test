INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 573794_food_oms
--echo #
CREATE DATABASE `db_573794_food_oms`;
USE `db_573794_food_oms`;
CREATE TABLE `order_details` (
  `id` INT NOT NULL,
  `order_id` INT,
  `item_id` INT,
  `quantity` INT,
  `each_price` INT,
  `total_price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `customer_id` INT,
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_573794_food_oms') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_573794_food_oms') AS relationships;
DROP DATABASE `db_573794_food_oms`;
UNINSTALL EXTENSION vsql_schematron;
