INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501873_V202010042030__baseline
--echo #
CREATE DATABASE `db_501873_V202010042030_baseline`;
USE `db_501873_V202010042030_baseline`;

CREATE TABLE `ATTRIBUTE` (
  `ID` INT,
  `TYPE` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `MAXIMUM` INT,
  `MINIMUM` INT,
  `NAME` VARCHAR(64),
  `PATTERN` VARCHAR(64),
  `NULLABLE` BOOL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DOMAIN` (
  `ID` INT,
  `DESCRIPTION` VARCHAR(64),
  `NAME` VARCHAR(64),
  `SELECTED` BOOL,
  `PROJECT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DOMAIN_ATTRIBUTES` (
  `DOMAIN_ENTITY_ID` INT,
  `ATTRIBUTES_ID` INT,
  PRIMARY KEY (`DOMAIN_ENTITY_ID`, `ATTRIBUTES_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PROJECT` (
  `ID` INT,
  `DESCRIPTION` VARCHAR(64),
  `PACKAGEPREFIX` VARCHAR(64),
  `TARGETPATH` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `TEMPLATE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PROJECTTEMPLATE` (
  `ID` INT,
  `BRANCH` VARCHAR(64),
  `CREDENTIALS_REQUIRED` BOOL,
  `DESCRIPTION` VARCHAR(64),
  `LOCATION` VARCHAR(64),
  `PREFIX` VARCHAR(64),
  `TITLE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CATEGORY` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CODETEMPLATE` (
  `ID` INT,
  `CREATE_DOMAIN_DIR` BOOL,
  `FILE_NAME_SUFFIX` VARCHAR(64),
  `LOWER_CASE` BOOL,
  `TARGET_PATH` VARCHAR(64),
  `TEMPLATE_PATH` VARCHAR(64),
  `TEMPLATE_TYPE` VARCHAR(64),
  `FIRST_UPPER` BOOL,
  `CATEGORY_ID` INT,
  `PROJECTTEMPLATE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CODETEMPLATE_PROJECT` (
  `CODETEMPLATE_ID` INT,
  `PROJECT_ID` INT,
  PRIMARY KEY (`CODETEMPLATE_ID`, `PROJECT_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501873_V202010042030_baseline') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501873_V202010042030_baseline') AS relationships;
DROP DATABASE `db_501873_V202010042030_baseline`;
UNINSTALL EXTENSION vsql_schematron;
