INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580752_schema
--echo #
CREATE DATABASE `db_580752_schema`;
USE `db_580752_schema`;

CREATE TABLE `persons` (
  `id` INT,
  `username` VARCHAR(64),
  `fullname` VARCHAR(64),
  `bio` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `profile_image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usersongs` (
  `id` INT,
  `username_songs` VARCHAR(64),
  `artistname` VARCHAR(64),
  `songtitle` VARCHAR(64),
  `image_url` VARCHAR(64),
  `cover_preview` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `userevents` (
  `id` INT,
  `username_event` VARCHAR(64),
  `event_image` VARCHAR(64),
  `artist_name` VARCHAR(64),
  `event_title` VARCHAR(64),
  `event_time` VARCHAR(64),
  `location` VARCHAR(64),
  `offer` VARCHAR(64),
  `description` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580752_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580752_schema') AS relationships;
DROP DATABASE `db_580752_schema`;
UNINSTALL EXTENSION vsql_schematron;
