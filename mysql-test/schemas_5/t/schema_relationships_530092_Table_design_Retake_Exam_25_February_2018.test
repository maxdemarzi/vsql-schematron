INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530092_Table_design_Retake_Exam_25_February_2018
--echo #
CREATE DATABASE `db_530092_Table_design_Retake_Exam_25_February_2018`;
USE `db_530092_Table_design_Retake_Exam_25_February_2018`;
CREATE TABLE `planets` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spaceports` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `planet_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spaceships` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `manufacturer` VARCHAR(50),
  `light_speed_rate` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `colonists` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `ucn` VARCHAR(50),
  `birth_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `journeys` (
  `id` INT NOT NULL,
  `journey_start` DATETIME,
  `journey_end` DATETIME,
  `purpose` VARCHAR(50),
  `destination_spaceport_id` INT,
  `spaceship_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `travel_cards` (
  `id` INT NOT NULL,
  `card_number` VARCHAR(50),
  `job_during_journey` VARCHAR(50),
  `colonist_id` INT,
  `journey_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530092_Table_design_Retake_Exam_25_February_2018') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530092_Table_design_Retake_Exam_25_February_2018') AS relationships;
DROP DATABASE `db_530092_Table_design_Retake_Exam_25_February_2018`;
UNINSTALL EXTENSION vsql_schematron;
