INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 567951_create
--echo #
CREATE DATABASE `db_567951_create`;
USE `db_567951_create`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` TEXT,
  `email` TEXT,
  `weekly_work_time` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `session_id` INT NOT NULL,
  `user_id` INT,
  `start_timestamp` INT,
  `end_timestamp` INT,
  `is_distance` INT,
  `length` INT,
  PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_567951_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_567951_create') AS relationships;
DROP DATABASE `db_567951_create`;
UNINSTALL EXTENSION vsql_schematron;
