INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565803_babelfish
--echo #
CREATE DATABASE `db_565803_babelfish`;
USE `db_565803_babelfish`;
CREATE TABLE `languages` (
  `locale` VARCHAR(50) NOT NULL,
  `language` VARCHAR(50),
  PRIMARY KEY (`locale`)
) CHARACTER SET latin1;
CREATE TABLE `translations` (
  `id` VARCHAR(50) NOT NULL,
  `locale` VARCHAR(50) NOT NULL,
  `content` TEXT,
  PRIMARY KEY (`id`, `locale`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565803_babelfish') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565803_babelfish') AS relationships;
DROP DATABASE `db_565803_babelfish`;
UNINSTALL EXTENSION vsql_schematron;
