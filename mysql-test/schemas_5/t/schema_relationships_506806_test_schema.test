INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 506806_test_schema
--echo #
CREATE DATABASE `db_506806_test_schema`;
USE `db_506806_test_schema`;
CREATE TABLE `items` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `sender` INT,
  `message` VARCHAR(50),
  `timestamp` DATETIME,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items_owned` (
  `id` INT NOT NULL,
  `user_id` INT,
  `item_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages_found` (
  `id` INT NOT NULL,
  `user_id` INT,
  `message_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_506806_test_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_506806_test_schema') AS relationships;
DROP DATABASE `db_506806_test_schema`;
UNINSTALL EXTENSION vsql_schematron;
