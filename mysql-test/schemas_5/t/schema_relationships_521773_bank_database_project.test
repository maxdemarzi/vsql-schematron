INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521773_bank_database_project
--echo #
CREATE DATABASE `db_521773_bank_database_project`;
USE `db_521773_bank_database_project`;

CREATE TABLE `account` (
  `account_id` INT,
  `branch_id` INT,
  `customer_id` INT,
  `account_type` VARCHAR(64),
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `customer_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `birth_date` DATETIME,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `employee_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `birth_date` DATETIME,
  `title` VARCHAR(64),
  `branch_id` INT,
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521773_bank_database_project') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521773_bank_database_project') AS relationships;
DROP DATABASE `db_521773_bank_database_project`;
UNINSTALL EXTENSION vsql_schematron;
