INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 551498_V1_create_database
--echo #
CREATE DATABASE `db_551498_V1_create_database`;
USE `db_551498_V1_create_database`;

CREATE TABLE `books` (
  `isbn` VARCHAR(255),
  `title` VARCHAR(255),
  `authors` VARCHAR(255),
  `description` VARCHAR(255),
  `thumbnail_uri` VARCHAR(255),
  `added` DATETIME,
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;

CREATE TABLE `collections` (
  `name` VARCHAR(255),
  `preferred_sort` VARCHAR(255),
  `sort_ascending` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `collection_books` (
  `collection_name` VARCHAR(255),
  `isbn` VARCHAR(255),
  PRIMARY KEY (`collection_name`, `isbn`)
) CHARACTER SET latin1;

CREATE TABLE `currently_reading_books` (
  `isbn` VARCHAR(255),
  `started` DATETIME,
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;

CREATE TABLE `read_books` (
  `isbn` VARCHAR(255),
  `started` DATETIME,
  `finished` DATETIME,
  PRIMARY KEY (`isbn`, `started`)
) CHARACTER SET latin1;

CREATE TABLE `rated_books` (
  `isbn` VARCHAR(255),
  `rating` INT,
  PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_551498_V1_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_551498_V1_create_database') AS relationships;
DROP DATABASE `db_551498_V1_create_database`;
UNINSTALL EXTENSION vsql_schematron;
