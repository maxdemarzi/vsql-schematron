INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524412_pg-create-all
--echo #
CREATE DATABASE `db_524412_pg_create_all`;
USE `db_524412_pg_create_all`;

CREATE TABLE `o_address` (
  `id` INT,
  `line1` VARCHAR(64),
  `line2` VARCHAR(64),
  `city` VARCHAR(64),
  `country_code` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `be_contact` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `customer_id` INT,
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contact_note` (
  `id` INT,
  `contact_id` INT,
  `title` VARCHAR(64),
  `note` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `o_country` (
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `be_customer` (
  `id` INT,
  `inactive` BOOL,
  `name` VARCHAR(64),
  `registered` DATETIME,
  `comments` VARCHAR(64),
  `billing_address_id` INT,
  `shipping_address_id` INT,
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `o_order` (
  `id` INT,
  `status` VARCHAR(64),
  `order_date` DATETIME,
  `ship_date` DATETIME,
  `customer_id` INT,
  `shipping_address_id` INT,
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `o_order_detail` (
  `id` INT,
  `order_id` INT,
  `order_qty` INT,
  `ship_qty` INT,
  `unit_price` DECIMAL(10,2),
  `product_id` INT,
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `o_product` (
  `id` INT,
  `sku` VARCHAR(64),
  `name` VARCHAR(64),
  `version` INT,
  `when_created` DATETIME,
  `when_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524412_pg_create_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524412_pg_create_all') AS relationships;
DROP DATABASE `db_524412_pg_create_all`;
UNINSTALL EXTENSION vsql_schematron;
