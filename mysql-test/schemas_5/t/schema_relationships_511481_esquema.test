INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 511481_esquema
--echo #
CREATE DATABASE `db_511481_esquema`;
USE `db_511481_esquema`;
CREATE TABLE `recetas` (
  `id` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `porciones` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredientes_recetas` (
  `id_receta` VARCHAR(50),
  `nombre` VARCHAR(50),
  `cantidad` INT,
  `unidad_medida` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `pasos_recetas` (
  `id_receta` VARCHAR(50),
  `paso` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `fotos_recetas` (
  `id_receta` VARCHAR(50),
  `foto` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_511481_esquema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_511481_esquema') AS relationships;
DROP DATABASE `db_511481_esquema`;
UNINSTALL EXTENSION vsql_schematron;
