INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577141_V1_baseline
--echo #
CREATE DATABASE `db_577141_V1_baseline`;
USE `db_577141_V1_baseline`;

CREATE TABLE `itemStorage.item` (
  `item_uid` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `market` VARCHAR(64),
  `stock` INT,
  `price_tag` DECIMAL(10,2),
  `state` VARCHAR(64),
  `created_by` VARCHAR(64),
  `modified_at` DATETIME,
  `created_at` DATETIME,
  `last_modified_by` VARCHAR(64),
  PRIMARY KEY (`item_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.user` (
  `user_uid` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_by` VARCHAR(64),
  `modified_at` DATETIME,
  `created_at` DATETIME,
  `last_modified_by` VARCHAR(64),
  PRIMARY KEY (`user_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.cart` (
  `cart_uid` INT,
  `fk_user_uid` INT,
  `created_by` VARCHAR(64),
  `modified_at` DATETIME,
  `created_at` DATETIME,
  `last_modified_by` VARCHAR(64),
  PRIMARY KEY (`cart_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.cart_item` (
  `cart_item_uid` INT,
  `fk_cart_uid` INT,
  `fk_item_uid` INT,
  `quantity` INT,
  `created_by` VARCHAR(64),
  `modified_at` DATETIME,
  `created_at` DATETIME,
  `last_modified_by` VARCHAR(64),
  PRIMARY KEY (`cart_item_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.role` (
  `role_uid` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`role_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.user_roles` (
  `role_uid` INT,
  `user_uid` INT,
  PRIMARY KEY (`role_uid`, `user_uid`)
) CHARACTER SET latin1;

CREATE TABLE `itemStorage.session` (
  `session_uid` INT,
  `token` VARCHAR(64),
  PRIMARY KEY (`session_uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577141_V1_baseline') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577141_V1_baseline') AS relationships;
DROP DATABASE `db_577141_V1_baseline`;
UNINSTALL EXTENSION vsql_schematron;
