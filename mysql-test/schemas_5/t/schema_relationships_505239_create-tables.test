INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505239_create-tables
--echo #
CREATE DATABASE `db_505239_create_tables`;
USE `db_505239_create_tables`;
CREATE TABLE `project` (
  `id` VARCHAR(50) NOT NULL,
  `project_name` VARCHAR(50),
  `description` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `services` (
  `id` VARCHAR(50) NOT NULL,
  `service_def_id` VARCHAR(50),
  `namespace_id` VARCHAR(50),
  `project_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505239_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505239_create_tables') AS relationships;
DROP DATABASE `db_505239_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
