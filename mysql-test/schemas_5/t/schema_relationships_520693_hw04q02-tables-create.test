INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520693_hw04q02-tables-create
--echo #
CREATE DATABASE `db_520693_hw04q02_tables_create`;
USE `db_520693_hw04q02_tables_create`;
CREATE TABLE `Students` (
  `sid` DECIMAL(10,2) NOT NULL,
  `sname` VARCHAR(50),
  PRIMARY KEY (`sid`)
) CHARACTER SET latin1;
CREATE TABLE `Courses` (
  `cid` DECIMAL(10,2) NOT NULL,
  `cname` VARCHAR(50),
  `credits` DECIMAL(10,2),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;
CREATE TABLE `Enrolled` (
  `sid` DECIMAL(10,2) NOT NULL,
  `cid` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`sid`, `cid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520693_hw04q02_tables_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520693_hw04q02_tables_create') AS relationships;
DROP DATABASE `db_520693_hw04q02_tables_create`;
UNINSTALL EXTENSION vsql_schematron;
