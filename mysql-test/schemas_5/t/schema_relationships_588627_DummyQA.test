INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588627_DummyQA
--echo #
CREATE DATABASE `db_588627_DummyQA`;
USE `db_588627_DummyQA`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `context` VARCHAR(50),
  `question_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `question_id` INT,
  `comment` VARCHAR(50),
  `comment_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588627_DummyQA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588627_DummyQA') AS relationships;
DROP DATABASE `db_588627_DummyQA`;
UNINSTALL EXTENSION vsql_schematron;
