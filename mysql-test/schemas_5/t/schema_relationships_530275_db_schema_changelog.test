INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530275_db_schema_changelog
--echo #
CREATE DATABASE `db_530275_db_schema_changelog`;
USE `db_530275_db_schema_changelog`;

CREATE TABLE `projects` (
  `folderName` VARCHAR(64),
  `projectID` INT,
  `projectName` VARCHAR(64),
  `projectDescription` VARCHAR(64),
  `exampleResources` VARCHAR(64),
  `usedResources` VARCHAR(64),
  `githubLink` VARCHAR(64),
  `presentationDate` DATETIME,
  `presentationTime` DATETIME,
  `presentationLink` VARCHAR(64),
  PRIMARY KEY (`folderName`, `projectID`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `folderName` VARCHAR(64),
  `projectID` INT,
  `facultyNumber` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `courseName` VARCHAR(64),
  `courseYear` INT,
  `projectTasks` VARCHAR(64),
  `manHours` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530275_db_schema_changelog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530275_db_schema_changelog') AS relationships;
DROP DATABASE `db_530275_db_schema_changelog`;
UNINSTALL EXTENSION vsql_schematron;
