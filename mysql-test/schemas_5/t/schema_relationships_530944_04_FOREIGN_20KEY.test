INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530944_04.FOREIGN%20KEY
--echo #
CREATE DATABASE `db_530944_04_FOREIGN_20KEY`;
USE `db_530944_04_FOREIGN_20KEY`;
CREATE TABLE `Persons` (
  `ID` INT NOT NULL,
  `LastName` VARCHAR(50),
  `FirstName` VARCHAR(50),
  `Age` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `OrderID` INT NOT NULL,
  `OrderNumber` INT,
  `PersonID` INT,
  PRIMARY KEY (`OrderID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530944_04_FOREIGN_20KEY') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530944_04_FOREIGN_20KEY') AS relationships;
DROP DATABASE `db_530944_04_FOREIGN_20KEY`;
UNINSTALL EXTENSION vsql_schematron;
