INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 562982_1
--echo #
CREATE DATABASE `db_562982_1`;
USE `db_562982_1`;

CREATE TABLE `User` (
  `id` INT,
  `user_id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `avatar_url` VARCHAR(64),
  `activated` BOOL,
  `failed_login_attempts` INT,
  `invited_by` INT,
  `roles` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_562982_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_562982_1') AS relationships;
DROP DATABASE `db_562982_1`;
UNINSTALL EXTENSION vsql_schematron;
