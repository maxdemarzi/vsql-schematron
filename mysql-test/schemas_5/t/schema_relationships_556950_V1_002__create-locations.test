INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 556950_V1_002__create-locations
--echo #
CREATE DATABASE `db_556950_V1_002__create_locations`;
USE `db_556950_V1_002__create_locations`;
CREATE TABLE `public.country` (
  `country_id` INT NOT NULL,
  `country` TEXT,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `public.city` (
  `city_id` INT NOT NULL,
  `city` TEXT,
  `country_id` INT,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `public.address` (
  `address_id` INT NOT NULL,
  `address` TEXT,
  `address2` TEXT,
  `district` TEXT,
  `city_id` INT,
  `postal_code` TEXT,
  `phone` TEXT,
  `last_update` TIMESTAMP NULL,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_556950_V1_002__create_locations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_556950_V1_002__create_locations') AS relationships;
DROP DATABASE `db_556950_V1_002__create_locations`;
UNINSTALL EXTENSION vsql_schematron;
