INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 525983_table_definitions
--echo #
CREATE DATABASE `db_525983_table_definitions`;
USE `db_525983_table_definitions`;

CREATE TABLE `public.book` (
  `isbn13` VARCHAR(64),
  `title` VARCHAR(64),
  `thumbnail` VARCHAR(64),
  PRIMARY KEY (`isbn13`)
) CHARACTER SET latin1;

CREATE TABLE `public.media` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `public.user` (
  `user_name` VARCHAR(64),
  PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;

CREATE TABLE `public.own` (
  `own_id` INT,
  `isbn13` VARCHAR(64),
  `media_name` VARCHAR(64),
  `own_user` VARCHAR(64),
  PRIMARY KEY (`own_id`)
) CHARACTER SET latin1;

CREATE TABLE `public.read_book` (
  `read_book_id` INT,
  `user_name` VARCHAR(64),
  `own_id` INT,
  `is_read` VARCHAR(64),
  PRIMARY KEY (`read_book_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_525983_table_definitions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_525983_table_definitions') AS relationships;
DROP DATABASE `db_525983_table_definitions`;
UNINSTALL EXTENSION vsql_schematron;
