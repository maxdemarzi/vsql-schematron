INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530547_initDB
--echo #
CREATE DATABASE `db_530547_initDB`;
USE `db_530547_initDB`;
CREATE TABLE `Schedules` (
  `scheduleID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`scheduleID`)
) CHARACTER SET latin1;
CREATE TABLE `Transitions` (
  `transitionID` MEDIUMINT NOT NULL,
  `scheduleID` MEDIUMINT,
  `offset` INT,
  `state` VARCHAR(50),
  PRIMARY KEY (`transitionID`)
) CHARACTER SET latin1;
CREATE TABLE `Sensors` (
  `sensorID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `value` INT,
  `readtime` TIMESTAMP NULL,
  PRIMARY KEY (`sensorID`)
) CHARACTER SET latin1;
CREATE TABLE `Channels` (
  `channelID` MEDIUMINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `scheduleID` MEDIUMINT,
  `sensorID` MEDIUMINT,
  `enabled` VARCHAR(50),
  `state` VARCHAR(50),
  PRIMARY KEY (`channelID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530547_initDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530547_initDB') AS relationships;
DROP DATABASE `db_530547_initDB`;
UNINSTALL EXTENSION vsql_schematron;
