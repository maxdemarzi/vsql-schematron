INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543914_08%20CREATE%20TABLE%20ACTIVIDAD
--echo #
CREATE DATABASE `db_543914_08_20CREATE_20TABLE_20ACTIVIDAD`;
USE `db_543914_08_20CREATE_20TABLE_20ACTIVIDAD`;

CREATE TABLE `Actividad` (
  `id` DECIMAL(10,2),
  `descripcion` VARCHAR(64),
  `isActiva` DECIMAL(10,2),
  `idTipo` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `TipoActividad` (
  `id` DECIMAL(10,2),
  `descripcion` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543914_08_20CREATE_20TABLE_20ACTIVIDAD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543914_08_20CREATE_20TABLE_20ACTIVIDAD') AS relationships;
DROP DATABASE `db_543914_08_20CREATE_20TABLE_20ACTIVIDAD`;
UNINSTALL EXTENSION vsql_schematron;
