INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 525348_blog_management
--echo #
CREATE DATABASE `db_525348_blog_management`;
USE `db_525348_blog_management`;
CREATE TABLE `tbl_blogs` (
  `id` VARCHAR(50),
  `user_id` VARCHAR(50),
  `blog_title` VARCHAR(50),
  `blog_description` TEXT,
  `image` VARCHAR(50),
  `added_on` DATETIME,
  `updated_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tbl_blog_tags` (
  `id` VARCHAR(50),
  `blog_id` VARCHAR(50),
  `tag` VARCHAR(50),
  `added_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tbl_users` (
  `id` VARCHAR(50) NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` TEXT,
  `added_on` DATETIME,
  `updated_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_525348_blog_management') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_525348_blog_management') AS relationships;
DROP DATABASE `db_525348_blog_management`;
UNINSTALL EXTENSION vsql_schematron;
