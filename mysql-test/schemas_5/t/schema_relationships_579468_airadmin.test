INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 579468_airadmin
--echo #
CREATE DATABASE `db_579468_airadmin`;
USE `db_579468_airadmin`;
CREATE TABLE `ts_flight` (
  `ticket_id` INT NOT NULL,
  `flight_no` VARCHAR(50),
  `starttime` DATETIME,
  `start` VARCHAR(50),
  `end` VARCHAR(50),
  `price` DOUBLE,
  `peo_num` TINYINT,
  `endtime` DATETIME,
  `discount` DOUBLE,
  `start_city` VARCHAR(50),
  `end_city` VARCHAR(50),
  `aircraft_type` VARCHAR(50),
  `air_company` VARCHAR(50),
  PRIMARY KEY (`ticket_id`)
) CHARACTER SET latin1;
CREATE TABLE `us_role` (
  `role_id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `us_user_role` (
  `user_role_id` INT NOT NULL,
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_579468_airadmin') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_579468_airadmin') AS relationships;
DROP DATABASE `db_579468_airadmin`;
UNINSTALL EXTENSION vsql_schematron;
