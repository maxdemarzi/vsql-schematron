INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 500208_V1__init
--echo #
CREATE DATABASE `db_500208_V1__init`;
USE `db_500208_V1__init`;
CREATE TABLE `car` (
  `id` INT NOT NULL,
  `mark` VARCHAR(50),
  `model` VARCHAR(50),
  `odometerstatus` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `expense` (
  `id` INT NOT NULL,
  `car_id` INT,
  `created_at` TIMESTAMP NULL,
  `value` DECIMAL(10,2),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_500208_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_500208_V1__init') AS relationships;
DROP DATABASE `db_500208_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
