INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 561196_schema
--echo #
CREATE DATABASE `db_561196_schema`;
USE `db_561196_schema`;

CREATE TABLE `usr_usuario` (
  `usr_email` VARCHAR(64),
  `usr_nome_completo` VARCHAR(64),
  `usr_senha` VARCHAR(64),
  `usr_foto` VARCHAR(64),
  PRIMARY KEY (`usr_email`)
) CHARACTER SET latin1;

CREATE TABLE `amz_amizade` (
  `amz_usrfk_email1` VARCHAR(64),
  `amz_usrfk_email2` VARCHAR(64),
  PRIMARY KEY (`amz_usrfk_email1`, `amz_usrfk_email2`)
) CHARACTER SET latin1;

CREATE TABLE `fle_filme` (
  `fle_nome` VARCHAR(64),
  `fle_ano_lancamento` DECIMAL(10,2),
  `fle_sinopse` VARCHAR(64),
  `fle_fkfle_nome` VARCHAR(64),
  `fle_fkfle_lancamento` DECIMAL(10,2),
  PRIMARY KEY (`fle_nome`, `fle_ano_lancamento`)
) CHARACTER SET latin1;

CREATE TABLE `ast_assiste` (
  `ast_nota` DECIMAL(10,2),
  `ast_usrfk_email` VARCHAR(64),
  `ast_flefk_nome` VARCHAR(64),
  `ast_flefk_ano_lancamento` DECIMAL(10,2),
  PRIMARY KEY (`ast_usrfk_email`, `ast_flefk_nome`, `ast_flefk_ano_lancamento`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_561196_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_561196_schema') AS relationships;
DROP DATABASE `db_561196_schema`;
UNINSTALL EXTENSION vsql_schematron;
