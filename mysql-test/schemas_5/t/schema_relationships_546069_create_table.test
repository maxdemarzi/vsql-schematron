INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546069_create_table
--echo #
CREATE DATABASE `db_546069_create_table`;
USE `db_546069_create_table`;
CREATE TABLE `PAYMENT_TYPE` (
  `ID` INT NOT NULL,
  `PAYMENT_MODE` VARCHAR(50),
  `PAYMENT_MODE_DETAIL` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EXPENSE_CATEGORY` (
  `ID` INT NOT NULL,
  `EXPENSE_TYPE` VARCHAR(50),
  `EXPENSE_TYPE_DETAIL` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON` (
  `ID` INT NOT NULL,
  `PERSON_FIRST_NAME` VARCHAR(50),
  `PERSON_LAST_NAME` VARCHAR(50),
  `PERSON_SHORT_NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `STORE` (
  `ID` INT NOT NULL,
  `STORE_NAME` VARCHAR(50),
  `STORE_DETAIL` VARCHAR(50),
  `HOME_DELIVERY` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EXPENSE` (
  `ID` INT NOT NULL,
  `EXPENSE_DETAIL` VARCHAR(50),
  `EXPENSE_CATEGORY_ID` INT,
  `EXPENSE_DATE` DATE,
  `EXPENSE_AMOUNT` DECIMAL(10,2),
  `PAYMENT_TYPE_ID` INT,
  `PERSON_ID` INT,
  `STORE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOGIN` (
  `LOGIN_ID` VARCHAR(50),
  `PASSWORD_HASH` VARCHAR(50),
  `ACTIVE` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546069_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546069_create_table') AS relationships;
DROP DATABASE `db_546069_create_table`;
UNINSTALL EXTENSION vsql_schematron;
