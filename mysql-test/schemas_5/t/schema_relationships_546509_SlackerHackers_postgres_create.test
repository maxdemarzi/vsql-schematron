INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546509_SlackerHackers_postgres_create
--echo #
CREATE DATABASE `db_546509_SlackerHackers_postgres_create`;
USE `db_546509_SlackerHackers_postgres_create`;

CREATE TABLE `mentors` (
  `id` INT,
  `slackUserId` VARCHAR(64),
  `defaultLocationId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `trainees` (
  `id` INT,
  `slackUserId` VARCHAR(64),
  `classId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `classes` (
  `id` INT,
  `locationId` INT,
  `name` VARCHAR(64),
  `startDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `thresholds` (
  `id` INT,
  `mentorId` INT,
  `classId` INT,
  `postsWeight` INT,
  `callsCountWeight` INT,
  `callsTimeWeight` INT,
  `threshold` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `slackUserId` VARCHAR(64),
  `slackChannelId` VARCHAR(64),
  `timestamp` DATETIME,
  `isReply` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546509_SlackerHackers_postgres_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546509_SlackerHackers_postgres_create') AS relationships;
DROP DATABASE `db_546509_SlackerHackers_postgres_create`;
UNINSTALL EXTENSION vsql_schematron;
