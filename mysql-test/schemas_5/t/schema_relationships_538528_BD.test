INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 538528_BD
--echo #
CREATE DATABASE `db_538528_BD`;
USE `db_538528_BD`;
CREATE TABLE `clientes` (
  `cpf` VARCHAR(50) NOT NULL,
  `nome_completo` VARCHAR(50),
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `contato_cliente` (
  `id_contato` INT NOT NULL,
  `telefone` CHAR(50),
  `email` VARCHAR(50),
  `cpf_cliente` CHAR(50),
  PRIMARY KEY (`id_contato`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_538528_BD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_538528_BD') AS relationships;
DROP DATABASE `db_538528_BD`;
UNINSTALL EXTENSION vsql_schematron;
