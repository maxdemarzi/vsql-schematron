INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 532993_Lab_5
--echo #
CREATE DATABASE `db_532993_Lab_5`;
USE `db_532993_Lab_5`;

CREATE TABLE `MsStaff` (
  `StaffId` VARCHAR(64),
  `StaffName` VARCHAR(64),
  `StaffGender` VARCHAR(64),
  `StaffPhone` VARCHAR(64),
  `StaffAddress` VARCHAR(64),
  `StaffSalary` DECIMAL(10,2),
  `StaffPosition` VARCHAR(64),
  PRIMARY KEY (`StaffId`)
) CHARACTER SET latin1;

CREATE TABLE `MsTreatmentType` (
  `TreatmentTypeId` VARCHAR(64),
  `TreatmentTypeName` VARCHAR(64),
  PRIMARY KEY (`TreatmentTypeId`)
) CHARACTER SET latin1;

CREATE TABLE `MsTreatment` (
  `TreatmentId` VARCHAR(64),
  `TreatmentTypeId` VARCHAR(64),
  `TreatmentName` VARCHAR(64),
  `Price` DECIMAL(10,2),
  PRIMARY KEY (`TreatmentId`)
) CHARACTER SET latin1;

CREATE TABLE `HeaderSalonServices` (
  `TransactionId` VARCHAR(64),
  `CustomerId` VARCHAR(64),
  `StaffId` VARCHAR(64),
  `TransactionDate` DATETIME,
  `PaymentType` VARCHAR(64),
  PRIMARY KEY (`TransactionId`)
) CHARACTER SET latin1;

CREATE TABLE `DetailSalonServices` (
  `TransactionId` VARCHAR(64),
  `TreatmentId` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_532993_Lab_5') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_532993_Lab_5') AS relationships;
DROP DATABASE `db_532993_Lab_5`;
UNINSTALL EXTENSION vsql_schematron;
