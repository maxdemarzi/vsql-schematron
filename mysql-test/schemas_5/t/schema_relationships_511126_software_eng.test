INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 511126_software_eng
--echo #
CREATE DATABASE `db_511126_software_eng`;
USE `db_511126_software_eng`;

CREATE TABLE `admin` (
  `aid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`aid`)
) CHARACTER SET latin1;

CREATE TABLE `attend` (
  `sid` INT,
  `clid` INT,
  `gid` INT
) CHARACTER SET latin1;

CREATE TABLE `cou_attend` (
  `coid` INT,
  `clid` INT,
  `sid` INT,
  `type` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `hw_ma` (
  `hid` INT,
  `sid` INT,
  `clid` INT
) CHARACTER SET latin1;

CREATE TABLE `student_info` (
  `sid` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `college` VARCHAR(64),
  `major` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ta_assist` (
  `taid` INT,
  `clid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`taid`)
) CHARACTER SET latin1;

CREATE TABLE `ta_info` (
  `taid` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `id` VARCHAR(64),
  `college` VARCHAR(64),
  `major` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ta_permission` (
  `clid` INT,
  `p_ma_upload` VARCHAR(64),
  `p_ma_modify` VARCHAR(64),
  `p_ma_delete` VARCHAR(64),
  `p_hw_deliver` VARCHAR(64),
  `p_hw_modify` VARCHAR(64),
  `p_hw_review` VARCHAR(64),
  `p_BBS_reply` VARCHAR(64),
  `p_nt_deliver` VARCHAR(64),
  `p_nt_modify` VARCHAR(64),
  `p_nt_delete` VARCHAR(64),
  `p_ta_info` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `teacher_info` (
  `tid` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `college` VARCHAR(64),
  `department` VARCHAR(64),
  `position` VARCHAR(64),
  `education` VARCHAR(64),
  `direction` VARCHAR(64),
  `past_evaluation` VARCHAR(64),
  `desc_achive` VARCHAR(64),
  `desc_teach_type` VARCHAR(64),
  `desc_publish` VARCHAR(64),
  `desc_honor` VARCHAR(64),
  `desc_more` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_511126_software_eng') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_511126_software_eng') AS relationships;
DROP DATABASE `db_511126_software_eng`;
UNINSTALL EXTENSION vsql_schematron;
