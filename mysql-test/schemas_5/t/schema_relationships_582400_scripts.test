INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582400_scripts
--echo #
CREATE DATABASE `db_582400_scripts`;
USE `db_582400_scripts`;
CREATE TABLE `accrue_user` (
  `userid` BIGINT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `TOKENS` (
  `id` BIGINT NOT NULL,
  `access_token` VARCHAR(50),
  `userid` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
  `account_id` BIGINT NOT NULL,
  `payout_freq` BIGINT,
  `contract_name` VARCHAR(50),
  `payout_amt` BIGINT,
  `userid` INT,
  `total_balance` BIGINT,
  `contract_balance` BIGINT,
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `tr_id` BIGINT NOT NULL,
  `transaction_date` TIMESTAMP NULL,
  `withdraw_amount` DECIMAL(10,2),
  `deposit_amount` DECIMAL(10,2),
  `balance` DECIMAL(10,2),
  `account_id` BIGINT,
  PRIMARY KEY (`tr_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582400_scripts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582400_scripts') AS relationships;
DROP DATABASE `db_582400_scripts`;
UNINSTALL EXTENSION vsql_schematron;
