INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 563964_migration
--echo #
CREATE DATABASE `db_563964_migration`;
USE `db_563964_migration`;
CREATE TABLE `Account` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `balance` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Credit` (
  `id` VARCHAR(50) NOT NULL,
  `amount` DOUBLE,
  `notes` TEXT,
  `date` TIMESTAMP NULL,
  `accountId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Debit` (
  `id` VARCHAR(50) NOT NULL,
  `amount` DOUBLE,
  `notes` TEXT,
  `date` TIMESTAMP NULL,
  `accountId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_563964_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_563964_migration') AS relationships;
DROP DATABASE `db_563964_migration`;
UNINSTALL EXTENSION vsql_schematron;
