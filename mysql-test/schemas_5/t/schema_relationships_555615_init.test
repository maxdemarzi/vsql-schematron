INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555615_init
--echo #
CREATE DATABASE `db_555615_init`;
USE `db_555615_init`;

CREATE TABLE `menu` (
  `id` INT,
  `name` VARCHAR(64),
  `mtype` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dishes` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `rating` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `man_date` DATETIME,
  `available_until` DATETIME,
  `man_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `PD` (
  `pid` INT,
  `did` INT,
  PRIMARY KEY (`pid`, `did`)
) CHARACTER SET latin1;

CREATE TABLE `MD` (
  `mid` INT,
  `did` INT,
  PRIMARY KEY (`did`, `mid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555615_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555615_init') AS relationships;
DROP DATABASE `db_555615_init`;
UNINSTALL EXTENSION vsql_schematron;
