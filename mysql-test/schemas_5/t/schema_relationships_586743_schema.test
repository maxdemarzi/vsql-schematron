INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586743_schema
--echo #
CREATE DATABASE `db_586743_schema`;
USE `db_586743_schema`;

CREATE TABLE `users` (
  `userId` INT,
  `forename` VARCHAR(64),
  `surname` VARCHAR(64),
  `kentId` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  `stripeCustomerId` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `trips` (
  `tripId` INT,
  `tripName` VARCHAR(64),
  `tripDesc` VARCHAR(64),
  `stripeProductId` VARCHAR(64),
  PRIMARY KEY (`tripId`)
) CHARACTER SET latin1;

CREATE TABLE `tripApplicants` (
  `tripId` INT,
  `userId` INT,
  `status` VARCHAR(64),
  `paid` DECIMAL(10,2),
  PRIMARY KEY (`tripId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `resetTokens` (
  `tokenId` VARCHAR(64),
  `email` VARCHAR(64),
  `expirationDate` DATETIME,
  `state` VARCHAR(64),
  PRIMARY KEY (`tokenId`, `email`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586743_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586743_schema') AS relationships;
DROP DATABASE `db_586743_schema`;
UNINSTALL EXTENSION vsql_schematron;
