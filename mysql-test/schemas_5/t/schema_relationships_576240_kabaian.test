INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576240_kabaian
--echo #
CREATE DATABASE `db_576240_kabaian`;
USE `db_576240_kabaian`;
CREATE TABLE `diklat` (
  `diklat_id` INT NOT NULL,
  `user_id` INT,
  `jenis_diklat` VARCHAR(50),
  `sejak` DATE,
  `hingga` DATE,
  `lembaga_pendidikan` VARCHAR(50),
  `judul_diklat` VARCHAR(50),
  `no_sertifikat` VARCHAR(50),
  `tanggal_sertifikat` DATE,
  PRIMARY KEY (`diklat_id`)
) CHARACTER SET latin1;
CREATE TABLE `laporan_hcr` (
  `laporan_hcr_id` INT NOT NULL,
  `user_id` INT,
  `daftar_aktivitas_pengembangan` VARCHAR(50),
  `level_profisiensi` VARCHAR(50),
  `tanggal_selesai_pelaksanaan` DATE,
  `output_laporan_hcr` VARCHAR(50),
  PRIMARY KEY (`laporan_hcr_id`)
) CHARACTER SET latin1;
CREATE TABLE `penilaian` (
  `penilaian_id` INT NOT NULL,
  `user_id` INT,
  `penilaian_nama` VARCHAR(50),
  `nilai` INT,
  PRIMARY KEY (`penilaian_id`)
) CHARACTER SET latin1;
CREATE TABLE `penugasan_hcr` (
  `penugasan_hcr_id` INT NOT NULL,
  `user_id` INT,
  `kode_sjf` VARCHAR(50),
  `competency_profile` VARCHAR(50),
  `aktivitas` VARCHAR(50),
  `tanggal_awal_penugasan` DATE,
  `tanggal_akhir_penugasan` DATE,
  `aktivitas_penugasan` VARCHAR(50),
  `keterangan` VARCHAR(50),
  PRIMARY KEY (`penugasan_hcr_id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `role_id` INT NOT NULL,
  `role_nama` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `sertifikasi_hcr` (
  `sertifikasi_hcr_id` INT NOT NULL,
  `user_id` INT,
  `kode_sjf` VARCHAR(50),
  `competency_profile` VARCHAR(50),
  `judul_sertifikasi` VARCHAR(50),
  `lembaga_sertifikasi` VARCHAR(50),
  `no_sertfikat_sertifikasi` VARCHAR(50),
  `tanggal_awal_sertifikat` DATE,
  `tanggal_akhir_sertifikat` DATE,
  `status` VARCHAR(50),
  `keterangan` VARCHAR(50),
  PRIMARY KEY (`sertifikasi_hcr_id`)
) CHARACTER SET latin1;
CREATE TABLE `unit` (
  `unit_id` INT NOT NULL,
  `unit_nama` VARCHAR(50),
  `personnel_area` VARCHAR(50),
  `personnel_sub_area` VARCHAR(50),
  PRIMARY KEY (`unit_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `unit_id` INT,
  `role_id` INT,
  `nip` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `personal_number` VARCHAR(50),
  `nama_lengkap` VARCHAR(50),
  `grade` VARCHAR(50),
  `jenjang_jabatan` VARCHAR(50),
  `jabatan` VARCHAR(50),
  `marital_status` INT,
  `gender` INT,
  `telepon` VARCHAR(50),
  `email` VARCHAR(50),
  `bank_account` VARCHAR(50),
  `no_rekening` VARCHAR(50),
  `jenjang_pendidikan` VARCHAR(50),
  `golongan_darah` VARCHAR(50),
  `tanggal_grade_terakhir` DATE,
  `tanggal_masuk` DATE,
  `tanggal_capeg` DATE,
  `tanggal_pegawai_tetap` DATE,
  `birth_date` DATE,
  `masa_kerja` INT,
  `kelompok_masa_kerja` INT,
  `usia` INT,
  `kelompok_usia` INT,
  `ulang_tahun` DATE,
  `tahun_pensiun` DATE,
  `tanggal_jabat` DATE,
  `masa_jabat` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576240_kabaian') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576240_kabaian') AS relationships;
DROP DATABASE `db_576240_kabaian`;
UNINSTALL EXTENSION vsql_schematron;
