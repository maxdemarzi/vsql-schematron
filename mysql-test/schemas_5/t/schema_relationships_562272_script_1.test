INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 562272_script_1
--echo #
CREATE DATABASE `db_562272_script_1`;
USE `db_562272_script_1`;

CREATE TABLE `event` (
  `id` INT,
  `canceled` BOOL,
  `created_date_time` DATETIME,
  `date_time_string` VARCHAR(64),
  `location` VARCHAR(64),
  `start_date_time` DATETIME,
  `event_type` INT,
  `name` VARCHAR(64),
  `applies_to_group` INT,
  `created_by_user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_log` (
  `id` INT,
  `created_date_time` DATETIME,
  `event_log_type` INT,
  `message` VARCHAR(64),
  `event_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_profile` (
  `id` INT,
  `created_date_time` DATETIME,
  `name` VARCHAR(64),
  `group_token_code` VARCHAR(64),
  `token_code_expiry` DATETIME,
  `created_by_user` INT,
  `parent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_user_membership` (
  `group_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission` (
  `id` INT,
  `permission_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_permissions` (
  `role_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`permission_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_profile` (
  `id` INT,
  `created_date_time` DATETIME,
  `display_name` VARCHAR(64),
  `enabled` BOOL,
  `first_name` VARCHAR(64),
  `language_code` VARCHAR(64),
  `last_name` VARCHAR(64),
  `password` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `user_name` VARCHAR(64),
  `version` INT,
  `web` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `verification_token_code` (
  `id` INT,
  `code` VARCHAR(64),
  `creation_date` DATETIME,
  `expiry_date` DATETIME,
  `token_access_attempts` INT,
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_562272_script_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_562272_script_1') AS relationships;
DROP DATABASE `db_562272_script_1`;
UNINSTALL EXTENSION vsql_schematron;
