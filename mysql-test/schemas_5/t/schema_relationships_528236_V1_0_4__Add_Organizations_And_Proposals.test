INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 528236_V1_0_4__Add_Organizations_And_Proposals
--echo #
CREATE DATABASE `db_528236_V1_0_4__Add_Organizations_And_Proposals`;
USE `db_528236_V1_0_4__Add_Organizations_And_Proposals`;
CREATE TABLE `organizations` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organization_members` (
  `id` INT NOT NULL,
  `credential_id` INT,
  `organization_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `id` INT NOT NULL,
  `province` VARCHAR(50),
  `town` VARCHAR(50),
  `address` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `proposals` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `organization_id` INT,
  `location_id` INT,
  `required_days` VARCHAR(50),
  `min_age` INT,
  `max_age` INT,
  `expiration_date` TIMESTAMP NULL,
  `published` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `volunteers_proposals` (
  `proposal_id` INT NOT NULL,
  `volunteer_id` INT NOT NULL,
  PRIMARY KEY (`proposal_id`, `volunteer_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_528236_V1_0_4__Add_Organizations_And_Proposals') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_528236_V1_0_4__Add_Organizations_And_Proposals') AS relationships;
DROP DATABASE `db_528236_V1_0_4__Add_Organizations_And_Proposals`;
UNINSTALL EXTENSION vsql_schematron;
