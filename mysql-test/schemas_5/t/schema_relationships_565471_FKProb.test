INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565471_FKProb
--echo #
CREATE DATABASE `db_565471_FKProb`;
USE `db_565471_FKProb`;

CREATE TABLE `ot` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `vtp` (
  `vt_name` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`vt_name`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `vtp_restriction` (
  `vt_name` VARCHAR(64),
  `vtp_vt_name` VARCHAR(64),
  `vtp_name` VARCHAR(64),
  PRIMARY KEY (`vt_name`, `vtp_vt_name`, `vtp_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565471_FKProb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565471_FKProb') AS relationships;
DROP DATABASE `db_565471_FKProb`;
UNINSTALL EXTENSION vsql_schematron;
