INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592948_AllTables
--echo #
CREATE DATABASE `db_592948_AllTables`;
USE `db_592948_AllTables`;

CREATE TABLE `Accounts` (
  `userId` VARCHAR(64),
  `email` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `AccountCredentials` (
  `userId` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `Contests` (
  `contestId` INT,
  `createdBy` VARCHAR(64),
  `startTime` DATETIME,
  `name` VARCHAR(64),
  `currentState` INT,
  PRIMARY KEY (`contestId`)
) CHARACTER SET latin1;

CREATE TABLE `ContestParticipants` (
  `contestParticipantsId` INT,
  `contestId` INT,
  `userId` VARCHAR(64),
  `points` INT,
  PRIMARY KEY (`contestParticipantsId`)
) CHARACTER SET latin1;

CREATE TABLE `Events` (
  `eventId` INT,
  `name` VARCHAR(64),
  `startTime` DATETIME,
  `currentState` INT,
  `link` VARCHAR(64),
  PRIMARY KEY (`eventId`)
) CHARACTER SET latin1;

CREATE TABLE `ContestEvents` (
  `contestEventsId` INT,
  `contestId` INT,
  `eventId` INT,
  PRIMARY KEY (`contestEventsId`)
) CHARACTER SET latin1;

CREATE TABLE `Players` (
  `playerId` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `displayName` VARCHAR(64),
  `image` VARCHAR(64),
  `salary` INT,
  PRIMARY KEY (`playerId`)
) CHARACTER SET latin1;

CREATE TABLE `ContestPlayers` (
  `contestPlayersId` INT,
  `contestId` INT,
  `playerId` INT,
  PRIMARY KEY (`contestPlayersId`)
) CHARACTER SET latin1;

CREATE TABLE `EventPoints` (
  `eventPointsId` INT,
  `eventId` INT,
  `playerId` INT,
  `points` INT,
  PRIMARY KEY (`eventPointsId`)
) CHARACTER SET latin1;

CREATE TABLE `LeagueStats` (
  `eventPointsId` INT,
  `deaths` INT,
  `assists` INT,
  `kills` INT,
  `creepScore` INT,
  PRIMARY KEY (`eventPointsId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592948_AllTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592948_AllTables') AS relationships;
DROP DATABASE `db_592948_AllTables`;
UNINSTALL EXTENSION vsql_schematron;
