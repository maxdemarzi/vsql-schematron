INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 567125_03.%20Many-To-Many%20Relationship
--echo #
CREATE DATABASE `db_567125_03__20Many_To_Many_20Relationship`;
USE `db_567125_03__20Many_To_Many_20Relationship`;
CREATE TABLE `students` (
  `student_id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `exams` (
  `exam_id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`exam_id`)
) CHARACTER SET latin1;
CREATE TABLE `students_exams` (
  `student_id` INT NOT NULL,
  `exam_id` INT NOT NULL,
  PRIMARY KEY (`student_id`, `exam_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_567125_03__20Many_To_Many_20Relationship') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_567125_03__20Many_To_Many_20Relationship') AS relationships;
DROP DATABASE `db_567125_03__20Many_To_Many_20Relationship`;
UNINSTALL EXTENSION vsql_schematron;
