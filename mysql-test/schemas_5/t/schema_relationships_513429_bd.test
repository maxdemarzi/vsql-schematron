INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 513429_bd
--echo #
CREATE DATABASE `db_513429_bd`;
USE `db_513429_bd`;

CREATE TABLE `compradores` (
  `Nome` VARCHAR(64),
  `id` INT,
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `livros` (
  `id` INT,
  `autor` VARCHAR(64),
  `titulo` VARCHAR(64),
  `editora` VARCHAR(64),
  `preco` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pedidos` (
  `idcliente` INT,
  `idlivro` INT,
  `preco` DECIMAL(10,2),
  `nome` VARCHAR(64),
  PRIMARY KEY (`idcliente`, `idlivro`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513429_bd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513429_bd') AS relationships;
DROP DATABASE `db_513429_bd`;
UNINSTALL EXTENSION vsql_schematron;
