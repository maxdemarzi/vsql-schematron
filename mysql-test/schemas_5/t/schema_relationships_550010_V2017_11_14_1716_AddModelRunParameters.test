INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 550010_V2017.11.14.1716__AddModelRunParameters
--echo #
CREATE DATABASE `db_550010_V2017_11_14_1716_AddModelRunParameters`;
USE `db_550010_V2017_11_14_1716_AddModelRunParameters`;

CREATE TABLE `upload_info` (
  `id` INT,
  `uploaded_by` VARCHAR(64),
  `uploaded_on` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_run_parameter_set` (
  `id` INT,
  `responsibility_set` INT,
  `description` VARCHAR(64),
  `upload_info` INT,
  `model_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_run` (
  `internal_id` INT,
  `run_id` VARCHAR(64),
  `model_run_parameter_set` INT,
  PRIMARY KEY (`internal_id`)
) CHARACTER SET latin1;

CREATE TABLE `model_run_parameter` (
  `id` INT,
  `key` VARCHAR(64),
  `model_run_parameter_set` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_run_parameter_value` (
  `id` INT,
  `model_run` INT,
  `model_run_parameter` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_550010_V2017_11_14_1716_AddModelRunParameters') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_550010_V2017_11_14_1716_AddModelRunParameters') AS relationships;
DROP DATABASE `db_550010_V2017_11_14_1716_AddModelRunParameters`;
UNINSTALL EXTENSION vsql_schematron;
