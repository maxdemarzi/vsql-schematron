INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515844_schema
--echo #
CREATE DATABASE `db_515844_schema`;
USE `db_515844_schema`;

CREATE TABLE `DEPT` (
  `DEPTNO` INT,
  `DNAME` VARCHAR(64),
  `LOC` VARCHAR(64),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;

CREATE TABLE `EMP` (
  `EMPNO` INT,
  `ENAME` VARCHAR(64),
  `JOB` VARCHAR(64),
  `MGR` INT,
  `HIREDATE` DATETIME,
  `SAL` DECIMAL(10,2),
  `COMM` DECIMAL(10,2),
  `DEPTNO` INT,
  PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515844_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515844_schema') AS relationships;
DROP DATABASE `db_515844_schema`;
UNINSTALL EXTENSION vsql_schematron;
