INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547494_scriptBDbikego
--echo #
CREATE DATABASE `db_547494_scriptBDbikego`;
USE `db_547494_scriptBDbikego`;
CREATE TABLE `tabCliente` (
  `codCli` INT NOT NULL,
  `nomeCli` VARCHAR(50),
  `cpfCli` VARCHAR(50),
  `rgCli` VARCHAR(50),
  `celCli` VARCHAR(50),
  PRIMARY KEY (`codCli`)
) CHARACTER SET latin1;
CREATE TABLE `tabBicicleta` (
  `codBici` INT NOT NULL,
  `modelo` VARCHAR(50),
  PRIMARY KEY (`codBici`)
) CHARACTER SET latin1;
CREATE TABLE `tabAluguel` (
  `codAluguel` INT NOT NULL,
  `codCli` INT,
  `codBici` INT,
  `dataAluguel` VARCHAR(50),
  `horaInicio` VARCHAR(50),
  `horaFim` VARCHAR(50),
  `statusAluguel` VARCHAR(50),
  PRIMARY KEY (`codAluguel`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547494_scriptBDbikego') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547494_scriptBDbikego') AS relationships;
DROP DATABASE `db_547494_scriptBDbikego`;
UNINSTALL EXTENSION vsql_schematron;
