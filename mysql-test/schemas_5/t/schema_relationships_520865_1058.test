INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520865_1058
--echo #
CREATE DATABASE `db_520865_1058`;
USE `db_520865_1058`;
CREATE TABLE `p7` (
  `a` INT NOT NULL,
  `b` INT,
  PRIMARY KEY (`a`)
) CHARACTER SET latin1;
CREATE TABLE `p1` (
  `b` INT,
  `a` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520865_1058') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520865_1058') AS relationships;
DROP DATABASE `db_520865_1058`;
UNINSTALL EXTENSION vsql_schematron;
