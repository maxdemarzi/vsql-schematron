INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 564208_20210219114044_init
--echo #
CREATE DATABASE `db_564208_20210219114044_init`;
USE `db_564208_20210219114044_init`;
CREATE TABLE `user` (
  `username` VARCHAR(50) NOT NULL,
  `pw_hash` TEXT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `redirect` (
  `path` VARCHAR(50) NOT NULL,
  `user` TEXT,
  `created` TIMESTAMP NULL,
  `url` TEXT,
  PRIMARY KEY (`path`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_564208_20210219114044_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_564208_20210219114044_init') AS relationships;
DROP DATABASE `db_564208_20210219114044_init`;
UNINSTALL EXTENSION vsql_schematron;
