INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 528801_schema
--echo #
CREATE DATABASE `db_528801_schema`;
USE `db_528801_schema`;

CREATE TABLE `Sala` (
  `Sala_ID` INT,
  `Nombre` VARCHAR(64),
  PRIMARY KEY (`Sala_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Administrador` (
  `RUT_Adm` VARCHAR(64),
  PRIMARY KEY (`RUT_Adm`)
) CHARACTER SET latin1;

CREATE TABLE `Alumno` (
  `RUT_Alu` VARCHAR(64),
  `Sala_Alu` INT,
  PRIMARY KEY (`RUT_Alu`)
) CHARACTER SET latin1;

CREATE TABLE `Apoderado` (
  `RUT_Apo` VARCHAR(64),
  `RUT_Pup` VARCHAR(64),
  PRIMARY KEY (`RUT_Apo`)
) CHARACTER SET latin1;

CREATE TABLE `Profesor` (
  `RUT_Pro` VARCHAR(64),
  `Sala_Pro` INT,
  PRIMARY KEY (`RUT_Pro`)
) CHARACTER SET latin1;

CREATE TABLE `Colegio` (
  `ID_Colegio` INT,
  `Estado_Colegio` INT,
  `Nombre_Colegio` VARCHAR(64),
  PRIMARY KEY (`ID_Colegio`)
) CHARACTER SET latin1;

CREATE TABLE `Contagio` (
  `Contagio_ID` INT,
  `RUT_Con` VARCHAR(64),
  `Fecha` DATETIME,
  PRIMARY KEY (`Contagio_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_528801_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_528801_schema') AS relationships;
DROP DATABASE `db_528801_schema`;
UNINSTALL EXTENSION vsql_schematron;
