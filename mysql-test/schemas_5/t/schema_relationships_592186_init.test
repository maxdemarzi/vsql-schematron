INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592186_init
--echo #
CREATE DATABASE `db_592186_init`;
USE `db_592186_init`;

CREATE TABLE `partner` (
  `id` INT,
  `partner_name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `product_name` VARCHAR(255),
  `base_url` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `client_name` VARCHAR(255),
  `partner_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_product` (
  `client_id` INT,
  `product_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`client_id`, `product_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592186_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592186_init') AS relationships;
DROP DATABASE `db_592186_init`;
UNINSTALL EXTENSION vsql_schematron;
