INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588291_Database_structure
--echo #
CREATE DATABASE `db_588291_Database_structure`;
USE `db_588291_Database_structure`;

CREATE TABLE `bewegung` (
  `ID` INT,
  `eventIDFS` INT,
  `ortIDFS` INT,
  `moveIndex` INT
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `ID` INT,
  `monatIDFS` INT,
  `content` VARCHAR(64),
  `title` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `jahre` (
  `ID` INT,
  `jahr` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `monat` (
  `ID` INT,
  `jahrIDFS` INT,
  `monat` INT
) CHARACTER SET latin1;

CREATE TABLE `ort` (
  `ID` INT,
  `name` VARCHAR(64),
  `x` DECIMAL(10,2),
  `y` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588291_Database_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588291_Database_structure') AS relationships;
DROP DATABASE `db_588291_Database_structure`;
UNINSTALL EXTENSION vsql_schematron;
