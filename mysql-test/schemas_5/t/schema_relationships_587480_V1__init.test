INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 587480_V1__init
--echo #
CREATE DATABASE `db_587480_V1__init`;
USE `db_587480_V1__init`;
CREATE TABLE `my_portfolio.usuario` (
  `id_usuario` BIGINT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  `cpf` VARCHAR(50),
  `perfil` VARCHAR(50),
  `data_atualizacao` TIMESTAMP NULL,
  `data_criacao` TIMESTAMP NULL,
  `data_desativacao` TIMESTAMP NULL,
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `my_portfolio.portfolio` (
  `id_portfolio` BIGINT NOT NULL,
  `id_usuario` INT,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `data_atualizacao` TIMESTAMP NULL,
  `data_criacao` TIMESTAMP NULL,
  `data_desativacao` TIMESTAMP NULL,
  PRIMARY KEY (`id_portfolio`)
) CHARACTER SET latin1;
CREATE TABLE `my_portfolio.carteira` (
  `id_carteira` BIGINT NOT NULL,
  `id_portfolio` INT,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `data_atualizacao` TIMESTAMP NULL,
  `percentual` DOUBLE,
  `data_criacao` TIMESTAMP NULL,
  `data_desativacao` TIMESTAMP NULL,
  PRIMARY KEY (`id_carteira`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_587480_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_587480_V1__init') AS relationships;
DROP DATABASE `db_587480_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
