INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543214_user
--echo #
CREATE DATABASE `db_543214_user`;
USE `db_543214_user`;

CREATE TABLE `user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phonenumber` VARCHAR(64),
  `nationalID` VARCHAR(64),
  `wallet` INT,
  `point` INT,
  `reference` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543214_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543214_user') AS relationships;
DROP DATABASE `db_543214_user`;
UNINSTALL EXTENSION vsql_schematron;
