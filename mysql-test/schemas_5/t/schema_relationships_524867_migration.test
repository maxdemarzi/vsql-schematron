INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524867_migration
--echo #
CREATE DATABASE `db_524867_migration`;
USE `db_524867_migration`;

CREATE TABLE `Match` (
  `id` INT,
  `matchResult` INT,
  `screenshotPath` VARCHAR(64),
  `teamId1` INT,
  `teamId2` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `PlayerH` (
  `id` INT,
  `playerId` INT,
  `skillLevel` DECIMAL(10,2),
  `userTag` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Players` (
  `id` INT,
  `userId` VARCHAR(64),
  `skillLevel` DECIMAL(10,2),
  `userTag` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Team` (
  `id` INT,
  `teamName` VARCHAR(64),
  `playerId1` INT,
  `playerId2` INT,
  `playerId3` INT,
  `playerId4` INT,
  `playerId5` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524867_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524867_migration') AS relationships;
DROP DATABASE `db_524867_migration`;
UNINSTALL EXTENSION vsql_schematron;
