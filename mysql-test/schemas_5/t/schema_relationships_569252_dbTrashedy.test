INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 569252_dbTrashedy
--echo #
CREATE DATABASE `db_569252_dbTrashedy`;
USE `db_569252_dbTrashedy`;
CREATE TABLE `departement` (
  `num_departement` VARCHAR(50),
  `nom_departement` VARCHAR(50) NOT NULL,
  `nom_region` VARCHAR(50),
  PRIMARY KEY (`nom_departement`)
) CHARACTER SET latin1;
CREATE TABLE `fleuve` (
  `nom_fleuve` VARCHAR(50) NOT NULL,
  `longueur` INT,
  PRIMARY KEY (`nom_fleuve`)
) CHARACTER SET latin1;
CREATE TABLE `region` (
  `nom_region` VARCHAR(50) NOT NULL,
  `nb_habitants` INT,
  PRIMARY KEY (`nom_region`)
) CHARACTER SET latin1;
CREATE TABLE `usine` (
  `ID_usine` INT NOT NULL,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `nom_usine` VARCHAR(50),
  `secteur` VARCHAR(50),
  `nom_region` VARCHAR(50),
  `nom_utilisateur` VARCHAR(50),
  PRIMARY KEY (`ID_usine`)
) CHARACTER SET latin1;
CREATE TABLE `utilisateur` (
  `nom_utilisateur` VARCHAR(50) NOT NULL,
  `passwd` VARCHAR(50),
  PRIMARY KEY (`nom_utilisateur`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_569252_dbTrashedy') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_569252_dbTrashedy') AS relationships;
DROP DATABASE `db_569252_dbTrashedy`;
UNINSTALL EXTENSION vsql_schematron;
