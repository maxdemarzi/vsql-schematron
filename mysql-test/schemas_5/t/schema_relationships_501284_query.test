INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501284_query
--echo #
CREATE DATABASE `db_501284_query`;
USE `db_501284_query`;
CREATE TABLE `authority` (
  `id` BIGINT NOT NULL,
  `authority_type` VARCHAR(50),
  `user_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `enabled` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `last_password_reset_date` DATETIME,
  `password` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501284_query') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501284_query') AS relationships;
DROP DATABASE `db_501284_query`;
UNINSTALL EXTENSION vsql_schematron;
