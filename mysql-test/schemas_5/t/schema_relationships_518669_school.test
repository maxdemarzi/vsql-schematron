INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518669_school
--echo #
CREATE DATABASE `db_518669_school`;
USE `db_518669_school`;
CREATE TABLE `class` (
  `id` INT NOT NULL,
  `class` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `birth_date` DATE,
  `class_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518669_school') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518669_school') AS relationships;
DROP DATABASE `db_518669_school`;
UNINSTALL EXTENSION vsql_schematron;
