INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501766_011_groups_and_users.mysql
--echo #
CREATE DATABASE `db_501766_011_groups_and_users_mysql`;
USE `db_501766_011_groups_and_users_mysql`;
CREATE TABLE `sec_groups` (
  `group_id` INT NOT NULL,
  `group_name` VARCHAR(50),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `sec_users` (
  `user_id` VARCHAR(50) NOT NULL,
  `human_id` VARCHAR(50),
  `group_id` INT,
  `salt1` VARCHAR(50),
  `salt2` VARCHAR(50),
  `auth` VARCHAR(50),
  `must_change_auth` CHAR(50),
  `token` VARCHAR(50),
  `user_status` CHAR(50),
  `last_access` DATETIME,
  `access_revoked_date` DATETIME,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501766_011_groups_and_users_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501766_011_groups_and_users_mysql') AS relationships;
DROP DATABASE `db_501766_011_groups_and_users_mysql`;
UNINSTALL EXTENSION vsql_schematron;
