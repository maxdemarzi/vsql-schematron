INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515991_create
--echo #
CREATE DATABASE `db_515991_create`;
USE `db_515991_create`;

CREATE TABLE `USER` (
  `username` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `email` VARCHAR(64),
  `createtime` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `book` (
  `bid` VARCHAR(64),
  `bookname` VARCHAR(64),
  `author` VARCHAR(64),
  `price` DECIMAL(10,2),
  `buytime` VARCHAR(64),
  `uid` VARCHAR(64),
  PRIMARY KEY (`bid`, `uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515991_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515991_create') AS relationships;
DROP DATABASE `db_515991_create`;
UNINSTALL EXTENSION vsql_schematron;
