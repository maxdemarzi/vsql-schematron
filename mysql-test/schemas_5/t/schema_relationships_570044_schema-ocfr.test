INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 570044_schema-ocfr
--echo #
CREATE DATABASE `db_570044_schema_ocfr`;
USE `db_570044_schema_ocfr`;
CREATE TABLE `CurrentMembers` (
  `member_id` INT NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `station_number` INT,
  `radio_number` INT,
  `address_street` VARCHAR(50),
  `address_city` VARCHAR(50),
  `address_state` VARCHAR(50),
  `address_zip` INT,
  `email` VARCHAR(50),
  `date_of_birth` DATE,
  `gender` VARCHAR(50),
  `mobile_phone` INT,
  `work_phone` INT,
  `position` VARCHAR(50),
  `isActive` BOOLEAN,
  PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `Certifications` (
  `certification_id` INT NOT NULL,
  `certifying_agency` VARCHAR(50),
  `certification_name` VARCHAR(50),
  `expiration_period` INT,
  PRIMARY KEY (`certification_id`)
) CHARACTER SET latin1;
CREATE TABLE `Certified` (
  `certified_id` INT NOT NULL,
  `certification_id` INT,
  `member_id` INT,
  `issued_date` DATE,
  PRIMARY KEY (`certified_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_570044_schema_ocfr') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_570044_schema_ocfr') AS relationships;
DROP DATABASE `db_570044_schema_ocfr`;
UNINSTALL EXTENSION vsql_schematron;
