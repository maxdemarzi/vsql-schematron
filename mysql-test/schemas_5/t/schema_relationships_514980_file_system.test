INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 514980_file_system
--echo #
CREATE DATABASE `db_514980_file_system`;
USE `db_514980_file_system`;

CREATE TABLE `child_nodes` (
  `child_node_id` INT,
  `child_node` VARCHAR(64),
  `child_node_path` VARCHAR(64),
  `parent_node_id` INT
) CHARACTER SET latin1;

CREATE TABLE `parent_nodes` (
  `parent_node_id` INT,
  `parent_node` VARCHAR(64),
  PRIMARY KEY (`parent_node_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_514980_file_system') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_514980_file_system') AS relationships;
DROP DATABASE `db_514980_file_system`;
UNINSTALL EXTENSION vsql_schematron;
