INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 566754_01.Mountains_and_Peaks
--echo #
CREATE DATABASE `db_566754_01_Mountains_and_Peaks`;
USE `db_566754_01_Mountains_and_Peaks`;
CREATE TABLE `mountains` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peaks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `mountain_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_566754_01_Mountains_and_Peaks') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_566754_01_Mountains_and_Peaks') AS relationships;
DROP DATABASE `db_566754_01_Mountains_and_Peaks`;
UNINSTALL EXTENSION vsql_schematron;
