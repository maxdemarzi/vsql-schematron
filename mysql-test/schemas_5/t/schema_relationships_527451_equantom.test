INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 527451_equantom
--echo #
CREATE DATABASE `db_527451_equantom`;
USE `db_527451_equantom`;
CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(50),
  `rating` DECIMAL(10,2),
  `price` DECIMAL(10,2),
  `img_url` VARCHAR(50),
  `category` INT
) CHARACTER SET latin1;
CREATE TABLE `product_categories` (
  `idcategory` INT NOT NULL,
  `categoryname` VARCHAR(50),
  PRIMARY KEY (`idcategory`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_527451_equantom') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_527451_equantom') AS relationships;
DROP DATABASE `db_527451_equantom`;
UNINSTALL EXTENSION vsql_schematron;
