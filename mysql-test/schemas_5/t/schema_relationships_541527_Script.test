INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 541527_Script
--echo #
CREATE DATABASE `db_541527_Script`;
USE `db_541527_Script`;

CREATE TABLE `client` (
  `client_id` INT,
  `client` VARCHAR(64),
  `token` VARCHAR(64),
  `token_start` VARCHAR(64),
  `location_id` INT,
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;

CREATE TABLE `vote` (
  `vote_id` INT,
  `client_id` INT,
  `created` DATETIME,
  `upvote` BOOL,
  PRIMARY KEY (`vote_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `username` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_541527_Script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_541527_Script') AS relationships;
DROP DATABASE `db_541527_Script`;
UNINSTALL EXTENSION vsql_schematron;
