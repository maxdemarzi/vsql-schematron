INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 509882_sql-schema
--echo #
CREATE DATABASE `db_509882_sql_schema`;
USE `db_509882_sql_schema`;
CREATE TABLE `customers` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `surname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_items` (
  `id` INT NOT NULL,
  `orders_id` INT,
  `items_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `cost` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_509882_sql_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_509882_sql_schema') AS relationships;
DROP DATABASE `db_509882_sql_schema`;
UNINSTALL EXTENSION vsql_schematron;
