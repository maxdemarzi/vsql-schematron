INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 559021_query
--echo #
CREATE DATABASE `db_559021_query`;
USE `db_559021_query`;
CREATE TABLE `type` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `type_id` INT,
  `expired_date` TIMESTAMP NULL,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_559021_query') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_559021_query') AS relationships;
DROP DATABASE `db_559021_query`;
UNINSTALL EXTENSION vsql_schematron;
