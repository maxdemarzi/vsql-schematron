INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539236_notes
--echo #
CREATE DATABASE `db_539236_notes`;
USE `db_539236_notes`;
CREATE TABLE `tbl_note` (
  `note_id` INT,
  `title` VARCHAR(50),
  `body` TEXT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `tbl_user` (
  `user_id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539236_notes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539236_notes') AS relationships;
DROP DATABASE `db_539236_notes`;
UNINSTALL EXTENSION vsql_schematron;
