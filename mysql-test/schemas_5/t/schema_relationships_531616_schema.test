INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531616_schema
--echo #
CREATE DATABASE `db_531616_schema`;
USE `db_531616_schema`;

CREATE TABLE `Domains` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ARecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `IpAddress` VARCHAR(64),
  `DynamicFQDN` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`, `IpAddress`, `DynamicFQDN`)
) CHARACTER SET latin1;

CREATE TABLE `CNameRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `CanonicalName` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `DKIMRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `DMARCRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `MxRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  `Priority` INT,
  PRIMARY KEY (`DomainId`, `Name`, `Value`)
) CHARACTER SET latin1;

CREATE TABLE `NsRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  `SortOrder` INT,
  PRIMARY KEY (`DomainId`, `Name`, `Value`)
) CHARACTER SET latin1;

CREATE TABLE `SPFRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `SRVRecords` (
  `DomainId` INT,
  `Service` VARCHAR(64),
  `Protocol` VARCHAR(64),
  `Priority` INT,
  `Weight` INT,
  `Port` INT,
  `Target` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Service`, `Protocol`, `Port`, `Target`)
) CHARACTER SET latin1;

CREATE TABLE `TXTRecords` (
  `DomainId` INT,
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`DomainId`, `Name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531616_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531616_schema') AS relationships;
DROP DATABASE `db_531616_schema`;
UNINSTALL EXTENSION vsql_schematron;
