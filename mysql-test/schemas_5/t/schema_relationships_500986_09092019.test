INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 500986_09092019
--echo #
CREATE DATABASE `db_500986_09092019`;
USE `db_500986_09092019`;

CREATE TABLE `tbl_communication_type` (
  `id` INT,
  `type` VARCHAR(64),
  `entryby` INT,
  `createdat` DATETIME,
  `updatedby` INT,
  `updatedat` DATETIME,
  `isactive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_experiance_type` (
  `id` INT,
  `type` VARCHAR(64),
  `entryby` INT,
  `createdat` DATETIME,
  `updatedby` INT,
  `updatedat` DATETIME,
  `isactive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_communication_details` (
  `id` INT,
  `apid` INT,
  `at` VARCHAR(64),
  `po` VARCHAR(64),
  `ps` VARCHAR(64),
  `landmark` VARCHAR(64),
  `dist` INT,
  `state` INT,
  `pincode` INT,
  `commtid` INT,
  `entryby` INT,
  `createdat` DATETIME,
  `updatedby` INT,
  `updatedat` DATETIME,
  `isactive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_500986_09092019') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_500986_09092019') AS relationships;
DROP DATABASE `db_500986_09092019`;
UNINSTALL EXTENSION vsql_schematron;
