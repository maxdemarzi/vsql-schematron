INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 593544_init
--echo #
CREATE DATABASE `db_593544_init`;
USE `db_593544_init`;
CREATE TABLE `Generos` (
  `id` INT NOT NULL,
  `genero` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Peliculas` (
  `id` INT NOT NULL,
  `titulo` VARCHAR(50),
  `director` VARCHAR(50),
  `fecha` VARCHAR(50),
  `genero` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_593544_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_593544_init') AS relationships;
DROP DATABASE `db_593544_init`;
UNINSTALL EXTENSION vsql_schematron;
