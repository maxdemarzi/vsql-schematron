INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565486_jpd
--echo #
CREATE DATABASE `db_565486_jpd`;
USE `db_565486_jpd`;
CREATE TABLE `periodicidade_apoio` (
  `id_periodicidade_apoio` INT NOT NULL,
  `periodicidade` VARCHAR(50),
  PRIMARY KEY (`id_periodicidade_apoio`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_doacao` (
  `id_tipo_doacao` INT NOT NULL,
  `tipo` VARCHAR(50),
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id_tipo_doacao`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_acao` (
  `id_tipo_acao` INT NOT NULL,
  `tipo` VARCHAR(50),
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id_tipo_acao`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_voluntarios` (
  `id_tipo_voluntarios` INT NOT NULL,
  `tipo` VARCHAR(50),
  `descricao` VARCHAR(50),
  PRIMARY KEY (`id_tipo_voluntarios`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_apoio` (
  `id_tipo_apoio` INT NOT NULL,
  `tipo` VARCHAR(50),
  `valor` INT,
  `descricao` VARCHAR(50),
  `fk_periodicidade_apoio` INT,
  PRIMARY KEY (`id_tipo_apoio`)
) CHARACTER SET latin1;
CREATE TABLE `voluntario_org` (
  `id_voluntario_org` INT NOT NULL,
  `fk_tipo_voluntarios` INT,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  PRIMARY KEY (`id_voluntario_org`)
) CHARACTER SET latin1;
CREATE TABLE `patrocinador` (
  `idpatrocinador` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `comprovante` VARCHAR(50),
  PRIMARY KEY (`idpatrocinador`)
) CHARACTER SET latin1;
CREATE TABLE `dados_gerais` (
  `id_dados_gerais` INT NOT NULL,
  `fk_voluntario_org` INT,
  `num_acoes` INT,
  PRIMARY KEY (`id_dados_gerais`)
) CHARACTER SET latin1;
CREATE TABLE `acoes` (
  `id_acoes` INT NOT NULL,
  `fk_voluntario_org` INT,
  `nome_inst` VARCHAR(50),
  `localizacao` VARCHAR(50),
  `num_voluntarios` INT,
  `num_beneficiados` INT,
  `regional` VARCHAR(50),
  PRIMARY KEY (`id_acoes`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565486_jpd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565486_jpd') AS relationships;
DROP DATABASE `db_565486_jpd`;
UNINSTALL EXTENSION vsql_schematron;
