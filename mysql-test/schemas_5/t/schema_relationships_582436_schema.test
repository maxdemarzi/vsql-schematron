INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582436_schema
--echo #
CREATE DATABASE `db_582436_schema`;
USE `db_582436_schema`;

CREATE TABLE `votes` (
  `observation_id` VARCHAR(64),
  `upvotes` INT,
  `downvotes` INT,
  PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_observations` (
  `observation_id` VARCHAR(64),
  `user_id` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `_id` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `puntuation` (
  `observation_id` VARCHAR(64),
  `positive` INT,
  `negative` INT,
  PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;

CREATE TABLE `position` (
  `observation_id` VARCHAR(64),
  `x_position` INT,
  `y_position` INT,
  PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;

CREATE TABLE `policy` (
  `_id` VARCHAR(64),
  `_Policy__formula` VARCHAR(64),
  `max_level` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `observation` (
  `_id` VARCHAR(64),
  `state` VARCHAR(64),
  `image_id` VARCHAR(64),
  `brightness` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `_id` VARCHAR(64),
  `x_size` INT,
  `y_size` INT,
  `probability` INT,
  `fwhm` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582436_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582436_schema') AS relationships;
DROP DATABASE `db_582436_schema`;
UNINSTALL EXTENSION vsql_schematron;
