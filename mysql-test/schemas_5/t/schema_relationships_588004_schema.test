INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588004_schema
--echo #
CREATE DATABASE `db_588004_schema`;
USE `db_588004_schema`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `status` VARCHAR(64),
  `date_added` DATETIME,
  `profile_pic` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `urls` (
  `suffix` VARCHAR(64),
  `short_url` VARCHAR(64),
  `long_url` VARCHAR(64),
  `user_id` VARCHAR(64),
  `description` VARCHAR(64),
  `date_added` DATETIME,
  `date_expire` DATETIME,
  PRIMARY KEY (`suffix`)
) CHARACTER SET latin1;

CREATE TABLE `click_log` (
  `date_added` DATETIME,
  `click_source` VARCHAR(64),
  `suffix_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588004_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588004_schema') AS relationships;
DROP DATABASE `db_588004_schema`;
UNINSTALL EXTENSION vsql_schematron;
