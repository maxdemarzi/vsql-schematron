INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 530556_creates
--echo #
CREATE DATABASE `db_530556_creates`;
USE `db_530556_creates`;

CREATE TABLE `tb_user` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_canary` (
  `id` INT,
  `name` VARCHAR(64),
  `lat` DECIMAL(10,2),
  `lng` DECIMAL(10,2),
  `security_token` INT,
  `nh3` DECIMAL(10,2),
  `co2` DECIMAL(10,2),
  `co` DECIMAL(10,2),
  `temperature` DECIMAL(10,2),
  `humidity` DECIMAL(10,2),
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_user_canary` (
  `user_id` INT,
  `canary_id` INT,
  PRIMARY KEY (`user_id`, `canary_id`)
) CHARACTER SET latin1;

CREATE TABLE `tb_daily_reading` (
  `id` INT,
  `nh3` DECIMAL(10,2),
  `co2` DECIMAL(10,2),
  `co` DECIMAL(10,2),
  `temperature` DECIMAL(10,2),
  `humity` DECIMAL(10,2),
  `created_at` DATETIME,
  `canary_id` INT,
  `readings` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_530556_creates') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_530556_creates') AS relationships;
DROP DATABASE `db_530556_creates`;
UNINSTALL EXTENSION vsql_schematron;
