INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501599_id16930867_certdbase
--echo #
CREATE DATABASE `db_501599_id16930867_certdbase`;
USE `db_501599_id16930867_certdbase`;
CREATE TABLE `certificates` (
  `certid` INT,
  `eventname` VARCHAR(50),
  `eventdate` VARCHAR(50),
  `orgid` INT,
  `venue` VARCHAR(50),
  `organizer1` VARCHAR(50),
  `organizer2` VARCHAR(50),
  `organizer3` VARCHAR(50),
  `signatory1` VARCHAR(50),
  `signatory2` VARCHAR(50),
  `signatory3` VARCHAR(50),
  `department` VARCHAR(50),
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `recognition` VARCHAR(50),
  `presentationline` VARCHAR(50),
  `logo1` VARCHAR(50),
  `logo2` VARCHAR(50),
  `logo3` VARCHAR(50),
  `expdate` DATE
) CHARACTER SET latin1;
CREATE TABLE `organizers` (
  `id` INT NOT NULL,
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `participants` (
  `pid` INT NOT NULL,
  `eventid` INT,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501599_id16930867_certdbase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501599_id16930867_certdbase') AS relationships;
DROP DATABASE `db_501599_id16930867_certdbase`;
UNINSTALL EXTENSION vsql_schematron;
