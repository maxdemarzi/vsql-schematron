INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583547_20201122_material
--echo #
CREATE DATABASE `db_583547_20201122_material`;
USE `db_583547_20201122_material`;

CREATE TABLE `material_list` (
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `cost` INT,
  `rarity` INT
) CHARACTER SET latin1;

CREATE TABLE `material_ingredient` (
  `target` VARCHAR(64),
  `ingredient` VARCHAR(64),
  `number` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583547_20201122_material') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583547_20201122_material') AS relationships;
DROP DATABASE `db_583547_20201122_material`;
UNINSTALL EXTENSION vsql_schematron;
