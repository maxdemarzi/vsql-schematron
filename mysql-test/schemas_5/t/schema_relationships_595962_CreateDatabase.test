INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 595962_CreateDatabase
--echo #
CREATE DATABASE `db_595962_CreateDatabase`;
USE `db_595962_CreateDatabase`;
CREATE TABLE `Subscription` (
  `Id` INT NOT NULL,
  `Type` VARCHAR(50),
  `AccessKey` VARCHAR(50),
  `SecretKey` VARCHAR(50),
  `State` VARCHAR(50),
  `CreatedDate` DATE,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `SubscriptionItem` (
  `Id` INT NOT NULL,
  `SubscriptionId` INT,
  `ApplicationId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_595962_CreateDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_595962_CreateDatabase') AS relationships;
DROP DATABASE `db_595962_CreateDatabase`;
UNINSTALL EXTENSION vsql_schematron;
