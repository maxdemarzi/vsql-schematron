INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547689_db_schema
--echo #
CREATE DATABASE `db_547689_db_schema`;
USE `db_547689_db_schema`;

CREATE TABLE `chatweb.rooms` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chatweb.messages` (
  `id` INT,
  `message` VARCHAR(64),
  `room_id` INT,
  `sender_id` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chatweb.user_room` (
  `users_id` INT,
  `rooms_id` INT,
  PRIMARY KEY (`users_id`, `rooms_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547689_db_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547689_db_schema') AS relationships;
DROP DATABASE `db_547689_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
