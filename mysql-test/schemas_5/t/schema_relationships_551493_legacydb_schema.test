INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 551493_legacydb-schema
--echo #
CREATE DATABASE `db_551493_legacydb_schema`;
USE `db_551493_legacydb_schema`;

CREATE TABLE `Booking` (
  `id` INT,
  `cancellationCode` VARCHAR(64),
  `contactEmail` VARCHAR(64),
  `createdOn` DATETIME,
  `performance_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Ticket` (
  `id` INT,
  `price` DECIMAL(10,2),
  `number` INT,
  `rowNumber` INT,
  `section_id` INT,
  `ticketCategory_id` INT,
  `tickets_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_551493_legacydb_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_551493_legacydb_schema') AS relationships;
DROP DATABASE `db_551493_legacydb_schema`;
UNINSTALL EXTENSION vsql_schematron;
