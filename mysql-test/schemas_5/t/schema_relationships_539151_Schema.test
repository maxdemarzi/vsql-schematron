INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539151_Schema
--echo #
CREATE DATABASE `db_539151_Schema`;
USE `db_539151_Schema`;

CREATE TABLE `questions` (
  `id` INT,
  `product_id` INT,
  `body` VARCHAR(64),
  `date_written` DATETIME,
  `asker_name` VARCHAR(64),
  `asker_email` VARCHAR(64),
  `reported` INT,
  `helpful` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answers` (
  `id` INT,
  `question_id` INT,
  `body` VARCHAR(64),
  `date_written` DATETIME,
  `answerer_name` VARCHAR(64),
  `answerer_email` VARCHAR(64),
  `reported` INT,
  `helpful` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answerphotos` (
  `id` INT,
  `answer_id` INT,
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539151_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539151_Schema') AS relationships;
DROP DATABASE `db_539151_Schema`;
UNINSTALL EXTENSION vsql_schematron;
