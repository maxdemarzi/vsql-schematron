INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553624_CodingChallenge1
--echo #
CREATE DATABASE `db_553624_CodingChallenge1`;
USE `db_553624_CodingChallenge1`;

CREATE TABLE `CodeChall.Customers` (
  `ID` INT,
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `CardNumber` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CodeChall.Products` (
  `ID` INT,
  `Name` VARCHAR(64),
  `Price` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CodeChall.Orders` (
  `ID` INT,
  `ProductID` INT,
  `CustomerID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553624_CodingChallenge1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553624_CodingChallenge1') AS relationships;
DROP DATABASE `db_553624_CodingChallenge1`;
UNINSTALL EXTENSION vsql_schematron;
