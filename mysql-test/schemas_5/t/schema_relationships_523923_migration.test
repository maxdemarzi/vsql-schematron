INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 523923_migration
--echo #
CREATE DATABASE `db_523923_migration`;
USE `db_523923_migration`;

CREATE TABLE `organizations` (
  `id` INT,
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `creatorId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `published` DATETIME,
  `creatorId` INT,
  `organizationId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `description` VARCHAR(64),
  `creatorId` INT,
  `postId` INT,
  `issueId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reactions` (
  `id` INT,
  `kind` VARCHAR(64),
  `creatorId` INT,
  `postId` INT,
  `issueId` INT,
  `commentId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_orgSubscriptions` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_issueSubscriptions` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_postSubscriptions` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_523923_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_523923_migration') AS relationships;
DROP DATABASE `db_523923_migration`;
UNINSTALL EXTENSION vsql_schematron;
