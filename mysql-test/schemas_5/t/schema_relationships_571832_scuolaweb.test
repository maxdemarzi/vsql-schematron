INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 571832_scuolaweb
--echo #
CREATE DATABASE `db_571832_scuolaweb`;
USE `db_571832_scuolaweb`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `studenti` (
  `id` INT,
  `name` VARCHAR(255),
  `cognome` VARCHAR(255),
  `datadinascita` DATETIME,
  `classe` INT,
  `sezione` VARCHAR(255),
  `userid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `voti` (
  `id` INT,
  `materia` VARCHAR(255),
  `punteggio` DECIMAL(10,2),
  `userid` INT,
  `studenteid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_571832_scuolaweb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_571832_scuolaweb') AS relationships;
DROP DATABASE `db_571832_scuolaweb`;
UNINSTALL EXTENSION vsql_schematron;
