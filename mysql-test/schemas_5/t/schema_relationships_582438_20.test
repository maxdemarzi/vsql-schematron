INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582438_20
--echo #
CREATE DATABASE `db_582438_20`;
USE `db_582438_20`;

CREATE TABLE `companies` (
  `id` VARCHAR(64),
  `siret` VARCHAR(64),
  `creation_date` DATETIME,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `postal_code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `company_accesses` (
  `company_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `level` VARCHAR(64),
  `update_date` DATETIME,
  PRIMARY KEY (`company_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `company_access_tokens` (
  `id` VARCHAR(64),
  `company_id` VARCHAR(64),
  `token` VARCHAR(64),
  `level` VARCHAR(64),
  `valid` VARCHAR(64),
  `expiration_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582438_20') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582438_20') AS relationships;
DROP DATABASE `db_582438_20`;
UNINSTALL EXTENSION vsql_schematron;
