INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552639_dbsetup
--echo #
CREATE DATABASE `db_552639_dbsetup`;
USE `db_552639_dbsetup`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  `nome` VARCHAR(50),
  `isAdmin` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peca` (
  `id` INT NOT NULL,
  `tipo` VARCHAR(50),
  `modelo` VARCHAR(50),
  `marca` VARCHAR(50),
  `fabricante` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorito` (
  `id` INT NOT NULL,
  `idUsuario` INT,
  `idPeca` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `loja` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552639_dbsetup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552639_dbsetup') AS relationships;
DROP DATABASE `db_552639_dbsetup`;
UNINSTALL EXTENSION vsql_schematron;
