INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577118_schema
--echo #
CREATE DATABASE `db_577118_schema`;
USE `db_577118_schema`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password_hash` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bugs` (
  `id` INT,
  `created_on` VARCHAR(255),
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `priority` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `archive` (
  `id` INT,
  `archived_on` VARCHAR(255),
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `resolved` VARCHAR(255),
  `user_id` INT,
  `archived_by` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577118_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577118_schema') AS relationships;
DROP DATABASE `db_577118_schema`;
UNINSTALL EXTENSION vsql_schematron;
