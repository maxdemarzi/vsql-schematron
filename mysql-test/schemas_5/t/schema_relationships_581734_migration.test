INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 581734_migration
--echo #
CREATE DATABASE `db_581734_migration`;
USE `db_581734_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `photoURL` TEXT,
  `password` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
  `id` VARCHAR(50) NOT NULL,
  `billerStreetAddress` TEXT,
  `billerCity` TEXT,
  `billerZipCode` TEXT,
  `billerCountry` TEXT,
  `clientName` TEXT,
  `clientEmail` TEXT,
  `clientStreetAddress` TEXT,
  `clientCity` TEXT,
  `clientZipCode` TEXT,
  `clientCountry` TEXT,
  `invoiceDate` TIMESTAMP NULL,
  `paymentDueDate` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `published` BOOLEAN,
  `authorId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `InvoiceItem` (
  `id` VARCHAR(50) NOT NULL,
  `itemName` TEXT,
  `qty` INT,
  `price` DOUBLE,
  `invoiceId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_581734_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_581734_migration') AS relationships;
DROP DATABASE `db_581734_migration`;
UNINSTALL EXTENSION vsql_schematron;
