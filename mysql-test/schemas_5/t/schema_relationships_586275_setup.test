INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586275_setup
--echo #
CREATE DATABASE `db_586275_setup`;
USE `db_586275_setup`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `phone` VARCHAR(50),
  `password` VARCHAR(50),
  `nike_name` VARCHAR(50),
  `age` INT,
  `created_on` BIGINT,
  `modified_on` BIGINT,
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `goods` (
  `id` BIGINT NOT NULL,
  `fk_user_goods` BIGINT,
  `price` INT,
  `keyword` VARCHAR(50),
  `content` VARCHAR(50),
  `image` VARCHAR(50),
  `location` VARCHAR(50),
  `address` VARCHAR(50),
  `created_on` BIGINT,
  `modified_on` BIGINT,
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586275_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586275_setup') AS relationships;
DROP DATABASE `db_586275_setup`;
UNINSTALL EXTENSION vsql_schematron;
