INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576928_0001_base.up
--echo #
CREATE DATABASE `db_576928_0001_base_up`;
USE `db_576928_0001_base_up`;

CREATE TABLE `topics` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subscriptions` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `message_ttl` INT,
  `topic_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` VARCHAR(64),
  `payload` VARCHAR(64),
  `published_at` DATETIME,
  `topic_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `deliveries` (
  `id` VARCHAR(64),
  `attempt_at` DATETIME,
  `last_attempted_at` DATETIME,
  `attempts` INT,
  `completed_at` DATETIME,
  `expires_at` DATETIME,
  `message_id` VARCHAR(64),
  `subscription_id` VARCHAR(64),
  `not_before_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576928_0001_base_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576928_0001_base_up') AS relationships;
DROP DATABASE `db_576928_0001_base_up`;
UNINSTALL EXTENSION vsql_schematron;
