INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565380_structure
--echo #
CREATE DATABASE `db_565380_structure`;
USE `db_565380_structure`;

CREATE TABLE `actions` (
  `id` INT,
  `name` VARCHAR(64),
  `started_at` DATETIME,
  `finished_at` DATETIME,
  `succeeded` VARCHAR(64),
  `error_id` INT,
  `trigger` VARCHAR(64),
  `params` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ar_internal_metadata` (
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;

CREATE TABLE `authorizations` (
  `id` INT,
  `scope` VARCHAR(64),
  `access_token` VARCHAR(64),
  `refresh_token` VARCHAR(64),
  `secret` VARCHAR(64),
  `expires_in` INT,
  `expires_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` INT,
  `props` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `commits` (
  `id` INT,
  `sha` VARCHAR(64),
  `message` VARCHAR(64),
  `committer` VARCHAR(64),
  `date` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `committer_email` VARCHAR(64),
  `project_id` INT,
  `authored_at` DATETIME,
  `unreachable` VARCHAR(64),
  `parent_sha` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `commits_pull_requests` (
  `commit_id` INT,
  `pull_request_id` INT
) CHARACTER SET latin1;

CREATE TABLE `commits_users` (
  `commit_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `deploys` (
  `id` INT,
  `project_id` INT,
  `sha` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `environment_name` VARCHAR(64),
  `deployer` VARCHAR(64),
  `commit_id` INT,
  `duration` INT,
  `branch` VARCHAR(64),
  `completed_at` DATETIME,
  `output` VARCHAR(64),
  `user_id` INT,
  `successful` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `errors` (
  `id` INT,
  `sha` VARCHAR(64),
  `message` VARCHAR(64),
  `backtrace` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `follows` (
  `id` INT,
  `user_id` INT,
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `measurements` (
  `id` INT,
  `subject_type` VARCHAR(64),
  `subject_id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `taken_at` DATETIME,
  `taken_on` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `persistent_triggers` (
  `id` INT,
  `type` VARCHAR(64),
  `value` VARCHAR(64),
  `params` VARCHAR(64),
  `action` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` INT,
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `color_name` VARCHAR(64),
  `retired_at` DATETIME,
  `category` VARCHAR(64),
  `version_control_name` VARCHAR(64),
  `ticket_tracker_name` VARCHAR(64),
  `ci_server_name` VARCHAR(64),
  `error_tracker_name` VARCHAR(64),
  `last_ticket_tracker_sync_at` DATETIME,
  `ticket_tracker_sync_started_at` DATETIME,
  `selected_features` VARCHAR(64),
  `head_sha` VARCHAR(64),
  `props` VARCHAR(64),
  `team_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pull_requests` (
  `id` INT,
  `project_id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `number` INT,
  `repo` VARCHAR(64),
  `username` VARCHAR(64),
  `url` VARCHAR(64),
  `base_ref` VARCHAR(64),
  `base_sha` VARCHAR(64),
  `head_ref` VARCHAR(64),
  `head_sha` VARCHAR(64),
  `body` VARCHAR(64),
  `props` VARCHAR(64),
  `avatar_url` VARCHAR(64),
  `json_labels` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `closed_at` DATETIME,
  `merged_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `user_id` INT,
  `project_id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schema_migrations` (
  `version` VARCHAR(64),
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(64),
  `props` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teams_users` (
  `id` INT,
  `team_id` INT,
  `user_id` INT,
  `roles` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `encrypted_password` VARCHAR(64),
  `reset_password_token` VARCHAR(64),
  `reset_password_sent_at` DATETIME,
  `remember_created_at` DATETIME,
  `sign_in_count` INT,
  `current_sign_in_at` DATETIME,
  `last_sign_in_at` DATETIME,
  `current_sign_in_ip` VARCHAR(64),
  `last_sign_in_ip` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `invitation_token` VARCHAR(64),
  `invitation_sent_at` DATETIME,
  `invitation_accepted_at` DATETIME,
  `invitation_limit` INT,
  `invited_by_type` VARCHAR(64),
  `invited_by_id` INT,
  `authentication_token` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `retired_at` DATETIME,
  `email_addresses` VARCHAR(64),
  `invitation_created_at` DATETIME,
  `current_project_id` INT,
  `nickname` VARCHAR(64),
  `username` VARCHAR(64),
  `props` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `versions` (
  `id` INT,
  `versioned_type` VARCHAR(64),
  `versioned_id` INT,
  `user_type` VARCHAR(64),
  `user_id` INT,
  `user_name` VARCHAR(64),
  `modifications` VARCHAR(64),
  `number` INT,
  `reverted_from` INT,
  `tag` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565380_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565380_structure') AS relationships;
DROP DATABASE `db_565380_structure`;
UNINSTALL EXTENSION vsql_schematron;
