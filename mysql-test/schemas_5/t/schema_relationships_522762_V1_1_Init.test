INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 522762_V1.1__Init
--echo #
CREATE DATABASE `db_522762_V1_1_Init`;
USE `db_522762_V1_1_Init`;

CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(64),
  `ProductVersion` VARCHAR(64),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;

CREATE TABLE `Roles` (
  `Id` VARCHAR(64),
  `Name` VARCHAR(64),
  `NormalizedName` VARCHAR(64),
  `ConcurrencyStamp` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `Id` VARCHAR(64),
  `UserName` VARCHAR(64),
  `NormalizedUserName` VARCHAR(64),
  `Email` VARCHAR(64),
  `NormalizedEmail` VARCHAR(64),
  `EmailConfirmed` VARCHAR(64),
  `PasswordHash` VARCHAR(64),
  `SecurityStamp` VARCHAR(64),
  `ConcurrencyStamp` VARCHAR(64),
  `PhoneNumber` VARCHAR(64),
  `PhoneNumberConfirmed` VARCHAR(64),
  `TwoFactorEnabled` VARCHAR(64),
  `LockoutEnd` DATETIME,
  `LockoutEnabled` VARCHAR(64),
  `AccessFailedCount` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `RoleClaims` (
  `Id` INT,
  `RoleId` VARCHAR(64),
  `ClaimType` VARCHAR(64),
  `ClaimValue` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `UserClaims` (
  `Id` INT,
  `UserId` VARCHAR(64),
  `ClaimType` VARCHAR(64),
  `ClaimValue` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `UserLogins` (
  `LoginProvider` VARCHAR(64),
  `ProviderKey` VARCHAR(64),
  `ProviderDisplayName` VARCHAR(64),
  `UserId` VARCHAR(64),
  PRIMARY KEY (`LoginProvider`, `ProviderKey`)
) CHARACTER SET latin1;

CREATE TABLE `UserRoles` (
  `UserId` VARCHAR(64),
  `RoleId` VARCHAR(64),
  PRIMARY KEY (`UserId`, `RoleId`)
) CHARACTER SET latin1;

CREATE TABLE `UserTokens` (
  `UserId` VARCHAR(64),
  `LoginProvider` VARCHAR(64),
  `Name` VARCHAR(64),
  `Value` VARCHAR(64),
  PRIMARY KEY (`UserId`, `LoginProvider`, `Name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_522762_V1_1_Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_522762_V1_1_Init') AS relationships;
DROP DATABASE `db_522762_V1_1_Init`;
UNINSTALL EXTENSION vsql_schematron;
