INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588817_schema-mysql
--echo #
CREATE DATABASE `db_588817_schema_mysql`;
USE `db_588817_schema_mysql`;

CREATE TABLE `customers` (
  `customerNumber` INT,
  `customerName` VARCHAR(64),
  `contactLastName` VARCHAR(64),
  `contactFirstName` VARCHAR(64),
  `phone` VARCHAR(64),
  `addressLine1` VARCHAR(64),
  `addressLine2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `country` VARCHAR(64),
  `salesRepEmployeeNumber` INT,
  `creditLimit` DECIMAL(10,2),
  PRIMARY KEY (`customerNumber`)
) CHARACTER SET latin1;

CREATE TABLE `offices` (
  `officeCode` INT,
  `city` VARCHAR(64),
  `phone` VARCHAR(64),
  `addressLine1` VARCHAR(64),
  `addressLine2` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `territory` VARCHAR(64),
  PRIMARY KEY (`officeCode`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `employeeNumber` INT,
  `lastName` VARCHAR(64),
  `firstName` VARCHAR(64),
  `extension` VARCHAR(64),
  `email` VARCHAR(64),
  `officeCode` INT,
  `reportsTo` INT,
  `jobTitle` VARCHAR(64),
  PRIMARY KEY (`employeeNumber`)
) CHARACTER SET latin1;

CREATE TABLE `orderdetails` (
  `orderNumber` INT,
  `productCode` VARCHAR(64),
  `quantityOrdered` INT,
  `priceEach` DECIMAL(10,2),
  `orderLineNumber` INT,
  PRIMARY KEY (`orderNumber`, `productCode`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `orderNumber` INT,
  `orderDate` DATETIME,
  `requiredDate` DATETIME,
  `shippedDate` DATETIME,
  `status` VARCHAR(64),
  `comments` VARCHAR(64),
  `customerNumber` INT,
  PRIMARY KEY (`orderNumber`)
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `customerNumber` INT,
  `checkNumber` VARCHAR(64),
  `paymentDate` DATETIME,
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`customerNumber`, `checkNumber`)
) CHARACTER SET latin1;

CREATE TABLE `productlines` (
  `productLine` VARCHAR(64),
  `textDescription` VARCHAR(64),
  `htmlDescription` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`productLine`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `productCode` VARCHAR(64),
  `productName` VARCHAR(64),
  `productLine` VARCHAR(64),
  `productScale` VARCHAR(64),
  `productVendor` VARCHAR(64),
  `productDescription` VARCHAR(64),
  `quantityInStock` INT,
  `buyPrice` DECIMAL(10,2),
  `MSRP` DECIMAL(10,2),
  PRIMARY KEY (`productCode`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588817_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588817_schema_mysql') AS relationships;
DROP DATABASE `db_588817_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
