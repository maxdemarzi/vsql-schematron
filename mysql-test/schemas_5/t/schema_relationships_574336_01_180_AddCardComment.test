INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574336_01-180-AddCardComment
--echo #
CREATE DATABASE `db_574336_01_180_AddCardComment`;
USE `db_574336_01_180_AddCardComment`;

CREATE TABLE `WF_CARD_COMMENT` (
  `ID` VARCHAR(64),
  `CREATE_TS` DATETIME,
  `CREATED_BY` VARCHAR(64),
  `VERSION` INT,
  `UPDATE_TS` DATETIME,
  `UPDATED_BY` VARCHAR(64),
  `DELETE_TS` DATETIME,
  `DELETED_BY` VARCHAR(64),
  `COMMENT` VARCHAR(64),
  `USER_ID` VARCHAR(64),
  `CARD_ID` VARCHAR(64),
  `PARENT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `WF_CARD_COMMENT_USER` (
  `CARD_COMMENT_ID` VARCHAR(64),
  `USER_ID` VARCHAR(64),
  PRIMARY KEY (`CARD_COMMENT_ID`, `USER_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574336_01_180_AddCardComment') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574336_01_180_AddCardComment') AS relationships;
DROP DATABASE `db_574336_01_180_AddCardComment`;
UNINSTALL EXTENSION vsql_schematron;
