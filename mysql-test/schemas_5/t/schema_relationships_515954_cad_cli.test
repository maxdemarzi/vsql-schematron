INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 515954_cad_cli
--echo #
CREATE DATABASE `db_515954_cad_cli`;
USE `db_515954_cad_cli`;

CREATE TABLE `clientes` (
  `id` INT,
  `cpf` VARCHAR(64),
  `nome` VARCHAR(64),
  `credito_liberado` VARCHAR(64),
  `data_nasc` DATETIME,
  `user_id` INT,
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `produtos` (
  `id` INT,
  `descricao` VARCHAR(64),
  `unidade` VARCHAR(64),
  `user_id` INT,
  `data_cadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pedidos` (
  `id` INT,
  `quantidade` INT,
  `preco_venda` DECIMAL(10,2),
  `data_pedido` DATETIME,
  `data_confirmacao` DATETIME,
  `cliente_id` INT,
  `user_id` INT,
  `produto_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_515954_cad_cli') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_515954_cad_cli') AS relationships;
DROP DATABASE `db_515954_cad_cli`;
UNINSTALL EXTENSION vsql_schematron;
