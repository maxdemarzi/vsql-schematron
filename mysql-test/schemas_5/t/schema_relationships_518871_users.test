INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518871_users
--echo #
CREATE DATABASE `db_518871_users`;
USE `db_518871_users`;
CREATE TABLE `HackOps.f_categories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.f_subcategories` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `categories_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.f_topics` (
  `id` INT NOT NULL,
  `users_id` INT,
  `title` VARCHAR(50),
  `content` TEXT,
  `date_create` DATETIME,
  `resolved` TINYINT,
  `notif_user` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.f_topic-categories` (
  `id` INT NOT NULL,
  `topics_id` INT,
  `categories_id` INT,
  `subcategories_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.f_message` (
  `id` INT NOT NULL,
  `topics_id` INT,
  `users_id` INT,
  `date_post` DATETIME,
  `date_edit` DATETIME,
  `best_res` TINYINT,
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.f_follow` (
  `id` INT NOT NULL,
  `users_id` INT,
  `topics_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HackOps.programming-challenges-status` (
  `id` INT NOT NULL,
  `user` INT,
  `challenge` INT,
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518871_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518871_users') AS relationships;
DROP DATABASE `db_518871_users`;
UNINSTALL EXTENSION vsql_schematron;
