INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543134_travis
--echo #
CREATE DATABASE `db_543134_travis`;
USE `db_543134_travis`;

CREATE TABLE `avviso` (
  `idAvviso` INT,
  `data` DATETIME,
  `ora` DATETIME,
  `emailCoordinatore` VARCHAR(64),
  `avviso` VARCHAR(64),
  `documentoPath` VARCHAR(64),
  PRIMARY KEY (`idAvviso`)
) CHARACTER SET latin1;

CREATE TABLE `coordinatore` (
  `emailCoordinatore` VARCHAR(64),
  `password` VARCHAR(64),
  `nome` VARCHAR(64),
  `cognome` VARCHAR(64),
  `codiceFiscale` VARCHAR(64),
  `via` VARCHAR(64),
  `ruolo` VARCHAR(64),
  `recapito` VARCHAR(64),
  `bio` VARCHAR(64),
  `facolta` VARCHAR(64),
  `imgProfiloPath` VARCHAR(64),
  `passToken` VARCHAR(64),
  PRIMARY KEY (`emailCoordinatore`)
) CHARACTER SET latin1;

CREATE TABLE `documento` (
  `idDocumento` INT,
  `titolo` VARCHAR(64),
  `contenutoPath` VARCHAR(64),
  `idTimeline` INT,
  `dataUpload` DATETIME,
  `emailCoordinatore` VARCHAR(64),
  PRIMARY KEY (`idDocumento`)
) CHARACTER SET latin1;

CREATE TABLE `studente` (
  `emailStudente` VARCHAR(64),
  `password` VARCHAR(64),
  `nome` VARCHAR(64),
  `cognome` VARCHAR(64),
  `codiceFiscale` VARCHAR(64),
  `via` VARCHAR(64),
  `recapito` VARCHAR(64),
  `facolta` VARCHAR(64),
  `matricola` VARCHAR(64),
  `status` VARCHAR(64),
  `bio` VARCHAR(64),
  `imgProfiloPath` VARCHAR(64),
  `passToken` VARCHAR(64),
  `rating` INT,
  PRIMARY KEY (`emailStudente`)
) CHARACTER SET latin1;

CREATE TABLE `votazione` (
  `idTimeline` INT,
  `emailStudente` VARCHAR(64),
  `nomeEsame` VARCHAR(64),
  `votoIta` INT,
  `esameEstero` VARCHAR(64),
  `votoEstero` VARCHAR(64),
  PRIMARY KEY (`idTimeline`, `nomeEsame`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543134_travis') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543134_travis') AS relationships;
DROP DATABASE `db_543134_travis`;
UNINSTALL EXTENSION vsql_schematron;
