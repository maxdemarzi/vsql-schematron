INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 527450_testdb
--echo #
CREATE DATABASE `db_527450_testdb`;
USE `db_527450_testdb`;
CREATE TABLE `messages` (
  `id` INT,
  `user_id` INT,
  `report` TEXT,
  `status` VARCHAR(50),
  `dateadd` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `auth_key` VARCHAR(50),
  `name` CHAR(50),
  `email` CHAR(50),
  `password` CHAR(50),
  `role` VARCHAR(50),
  `dateadd` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_527450_testdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_527450_testdb') AS relationships;
DROP DATABASE `db_527450_testdb`;
UNINSTALL EXTENSION vsql_schematron;
