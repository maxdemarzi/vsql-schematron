INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535292_userAuthDBSchema
--echo #
CREATE DATABASE `db_535292_userAuthDBSchema`;
USE `db_535292_userAuthDBSchema`;

CREATE TABLE `tblUsers` (
  `fldID` INT,
  `fldFirstName` VARCHAR(64),
  `fldLastName` VARCHAR(64),
  `fldEmail` VARCHAR(64),
  `fldPassword` VARCHAR(64),
  `fldCreatedAt` DATETIME,
  `fldUpdatedAt` DATETIME,
  PRIMARY KEY (`fldID`)
) CHARACTER SET latin1;

CREATE TABLE `tblActivationTokens` (
  `fldToken` VARCHAR(64),
  `fldTokenDateIssued` DATETIME,
  `fldTokenDateUsed` DATETIME,
  `fldIsActivated` BOOL,
  `fldFKUserID` INT,
  PRIMARY KEY (`fldToken`, `fldFKUserID`)
) CHARACTER SET latin1;

CREATE TABLE `tblSessions` (
  `fldSessionID` VARCHAR(64),
  `fldCreatedAt` DATETIME,
  `fldLastActive` DATETIME,
  `fldFKUserID` INT,
  PRIMARY KEY (`fldFKUserID`, `fldSessionID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535292_userAuthDBSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535292_userAuthDBSchema') AS relationships;
DROP DATABASE `db_535292_userAuthDBSchema`;
UNINSTALL EXTENSION vsql_schematron;
