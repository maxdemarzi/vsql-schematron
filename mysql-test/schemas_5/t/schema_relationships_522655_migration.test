INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 522655_migration
--echo #
CREATE DATABASE `db_522655_migration`;
USE `db_522655_migration`;

CREATE TABLE `User` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `bio` VARCHAR(64),
  `profilePictureUrl` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Article` (
  `id` INT,
  `slug` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `markdownContent` VARCHAR(64),
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `id` INT,
  `createdAt` DATETIME,
  `content` VARCHAR(64),
  `userId` INT,
  `articleId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ArticleTag` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `_FavoritedArticles` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_FollowedUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_ArticleToArticleTag` (
  `A` INT,
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_522655_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_522655_migration') AS relationships;
DROP DATABASE `db_522655_migration`;
UNINSTALL EXTENSION vsql_schematron;
