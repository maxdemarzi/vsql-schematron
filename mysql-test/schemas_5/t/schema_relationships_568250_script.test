INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568250_script
--echo #
CREATE DATABASE `db_568250_script`;
USE `db_568250_script`;
CREATE TABLE `AUTOR` (
  `AUTID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`AUTID`)
) CHARACTER SET latin1;
CREATE TABLE `WYDAWCA` (
  `WYDID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`WYDID`)
) CHARACTER SET latin1;
CREATE TABLE `POZYCJE` (
  `ISBN` VARCHAR(50) NOT NULL,
  `AUTID` INT,
  `TYTUL` VARCHAR(50),
  `WYDID` INT,
  `ROK` INT,
  `CENA` DOUBLE,
  PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568250_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568250_script') AS relationships;
DROP DATABASE `db_568250_script`;
UNINSTALL EXTENSION vsql_schematron;
