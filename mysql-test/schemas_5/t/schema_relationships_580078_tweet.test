INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580078_tweet
--echo #
CREATE DATABASE `db_580078_tweet`;
USE `db_580078_tweet`;

CREATE TABLE `tweet` (
  `id_tw` INT,
  `rts` INT,
  `likes` INT,
  `texto` VARCHAR(64),
  `fecha` DATETIME,
  `id_ans` INT,
  PRIMARY KEY (`id_tw`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580078_tweet') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580078_tweet') AS relationships;
DROP DATABASE `db_580078_tweet`;
UNINSTALL EXTENSION vsql_schematron;
