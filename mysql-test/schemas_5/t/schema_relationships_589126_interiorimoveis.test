INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 589126_interiorimoveis
--echo #
CREATE DATABASE `db_589126_interiorimoveis`;
USE `db_589126_interiorimoveis`;

CREATE TABLE `anuncios` (
  `id` INT,
  `cidade_anuncio` VARCHAR(64),
  `tipoImovel` VARCHAR(64),
  `tipoAnuncio` VARCHAR(64),
  `preco` DECIMAL(10,2),
  `descricao` VARCHAR(64),
  `caminho` VARCHAR(64),
  `idUsuario` INT,
  `situacao` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `solicitacoes` (
  `id` INT,
  `cidade_solicitacao` VARCHAR(64),
  `descricao` VARCHAR(64),
  `idu` INT
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id` INT,
  `nome` VARCHAR(64),
  `celular` VARCHAR(64),
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  `cidade` VARCHAR(64),
  `cep` VARCHAR(64),
  `caminho_foto` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_589126_interiorimoveis') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_589126_interiorimoveis') AS relationships;
DROP DATABASE `db_589126_interiorimoveis`;
UNINSTALL EXTENSION vsql_schematron;
