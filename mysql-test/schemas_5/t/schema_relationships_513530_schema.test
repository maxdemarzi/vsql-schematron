INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 513530_schema
--echo #
CREATE DATABASE `db_513530_schema`;
USE `db_513530_schema`;

CREATE TABLE `WEBSTORE.ADMIN` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WEBSTORE.ARTICLE` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `price` DECIMAL(10,2),
  `amount_in_stock` INT,
  `image_url` VARCHAR(64),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WEBSTORE.CUSTOMER_ORDER` (
  `id` VARCHAR(64),
  `creation_time` DATETIME,
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `email` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `zipcode` VARCHAR(64),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WEBSTORE.ORDER_ITEM` (
  `id` VARCHAR(64),
  `quantity` INT,
  `article_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WEBSTORE.CUSTOMER_ORDER_ITEMS` (
  `customer_order_id` VARCHAR(64),
  `items_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513530_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513530_schema') AS relationships;
DROP DATABASE `db_513530_schema`;
UNINSTALL EXTENSION vsql_schematron;
