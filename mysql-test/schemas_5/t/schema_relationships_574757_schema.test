INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574757_schema
--echo #
CREATE DATABASE `db_574757_schema`;
USE `db_574757_schema`;
CREATE TABLE `awsfederation.federationUser` (
  `arn` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `ttl` INT,
  PRIMARY KEY (`arn`)
) CHARACTER SET latin1;
CREATE TABLE `awsfederation.accountType` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `class_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `awsfederation.accountStatus` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `awsfederation.account` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `name` VARCHAR(50),
  `accountType_id` INT,
  `accountStatus_id` INT,
  `federationUser_arn` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574757_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574757_schema') AS relationships;
DROP DATABASE `db_574757_schema`;
UNINSTALL EXTENSION vsql_schematron;
