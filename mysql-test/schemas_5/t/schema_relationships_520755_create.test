INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520755_create
--echo #
CREATE DATABASE `db_520755_create`;
USE `db_520755_create`;

CREATE TABLE `game` (
  `gamename` VARCHAR(64),
  `oringinal_price` DECIMAL(10,2),
  `current_price` DECIMAL(10,2),
  `lowest_price` DECIMAL(10,2),
  `link` VARCHAR(64),
  `image_url` VARCHAR(64),
  `desc` VARCHAR(64),
  PRIMARY KEY (`gamename`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `nickname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  PRIMARY KEY (`nickname`)
) CHARACTER SET latin1;

CREATE TABLE `wishlist` (
  `nickname` INT,
  `gamename` INT,
  `email_alert` BOOL,
  PRIMARY KEY (`nickname`, `gamename`)
) CHARACTER SET latin1;

CREATE TABLE `own` (
  `nickname` INT,
  `gamename` INT,
  PRIMARY KEY (`nickname`, `gamename`)
) CHARACTER SET latin1;

CREATE TABLE `history_price` (
  `gamename` VARCHAR(64),
  `price` DECIMAL(10,2),
  `date` DATETIME,
  PRIMARY KEY (`gamename`, `date`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520755_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520755_create') AS relationships;
DROP DATABASE `db_520755_create`;
UNINSTALL EXTENSION vsql_schematron;
