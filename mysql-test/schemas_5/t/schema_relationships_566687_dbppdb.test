INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 566687_dbppdb
--echo #
CREATE DATABASE `db_566687_dbppdb`;
USE `db_566687_dbppdb`;

CREATE TABLE `auth_activation_attempts` (
  `id` INT,
  `ip_address` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups_permissions` (
  `group_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_groups_users` (
  `group_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_logins` (
  `id` INT,
  `ip_address` VARCHAR(64),
  `email` VARCHAR(64),
  `user_id` INT,
  `date` DATETIME,
  `success` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_reset_attempts` (
  `id` INT,
  `email` VARCHAR(64),
  `ip_address` VARCHAR(64),
  `user_agent` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_tokens` (
  `id` INT,
  `selector` VARCHAR(64),
  `hashedValidator` VARCHAR(64),
  `user_id` INT,
  `expires` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_users_permissions` (
  `user_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_566687_dbppdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_566687_dbppdb') AS relationships;
DROP DATABASE `db_566687_dbppdb`;
UNINSTALL EXTENSION vsql_schematron;
