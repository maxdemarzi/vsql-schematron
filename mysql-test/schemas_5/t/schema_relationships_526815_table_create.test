INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 526815_table_create
--echo #
CREATE DATABASE `db_526815_table_create`;
USE `db_526815_table_create`;
CREATE TABLE `physical_unit` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `description` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor_type` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `physical_unit` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
  `id` INT NOT NULL,
  `description` CHAR(50),
  `olc_code` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
  `id` INT NOT NULL,
  `type` INT,
  `location` INT,
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurement` (
  `id` INT NOT NULL,
  `time` VARCHAR(50),
  `sensor_id` INT,
  `raw_value` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_526815_table_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_526815_table_create') AS relationships;
DROP DATABASE `db_526815_table_create`;
UNINSTALL EXTENSION vsql_schematron;
