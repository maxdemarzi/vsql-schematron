INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592144_04.do.oauth
--echo #
CREATE DATABASE `db_592144_04_do_oauth`;
USE `db_592144_04_do_oauth`;

CREATE TABLE `user_token` (
  `token` VARCHAR(64),
  `user_id` INT,
  `created` DATETIME,
  `expires` DATETIME,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT,
  `active` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592144_04_do_oauth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592144_04_do_oauth') AS relationships;
DROP DATABASE `db_592144_04_do_oauth`;
UNINSTALL EXTENSION vsql_schematron;
