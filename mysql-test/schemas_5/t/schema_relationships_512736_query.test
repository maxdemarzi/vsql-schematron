INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512736_query
--echo #
CREATE DATABASE `db_512736_query`;
USE `db_512736_query`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `user_password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
  `project_id` INT NOT NULL,
  `project_name` VARCHAR(50),
  `project_desc` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `task_id` INT NOT NULL,
  `task_name` VARCHAR(50),
  `task_desc` VARCHAR(50),
  `task_created` DATETIME,
  `task_state` INT,
  `project_id` INT,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512736_query') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512736_query') AS relationships;
DROP DATABASE `db_512736_query`;
UNINSTALL EXTENSION vsql_schematron;
