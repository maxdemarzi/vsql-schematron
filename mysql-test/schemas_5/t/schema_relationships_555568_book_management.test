INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555568_book_management
--echo #
CREATE DATABASE `db_555568_book_management`;
USE `db_555568_book_management`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `user_number` VARCHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `adress` VARCHAR(50),
  `postal_code` VARCHAR(50),
  `city` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` VARCHAR(50) NOT NULL,
  `autor` VARCHAR(50),
  `title` VARCHAR(50),
  `release_date` INT,
  `literary_style` VARCHAR(50),
  `status` VARCHAR(50),
  `resume` TEXT,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555568_book_management') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555568_book_management') AS relationships;
DROP DATABASE `db_555568_book_management`;
UNINSTALL EXTENSION vsql_schematron;
