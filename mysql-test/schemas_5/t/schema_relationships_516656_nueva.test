INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 516656_nueva
--echo #
CREATE DATABASE `db_516656_nueva`;
USE `db_516656_nueva`;
CREATE TABLE `area_desempenio` (
  `id_area` INT NOT NULL,
  `nombre_area` VARCHAR(50),
  PRIMARY KEY (`id_area`)
) CHARACTER SET latin1;
CREATE TABLE `grado_academico` (
  `id_grado` INT NOT NULL,
  `nombre_grado` VARCHAR(50),
  PRIMARY KEY (`id_grado`)
) CHARACTER SET latin1;
CREATE TABLE `persona` (
  `id_persona` INT NOT NULL,
  `nombres_persona` VARCHAR(50),
  `apellidos_persona` VARCHAR(50),
  `telefono_persona` VARCHAR(50),
  `direccion_persona` VARCHAR(50),
  `fecha_nacimiento` DATE,
  `usuario_persona` VARCHAR(50),
  `contrasenia_persona` VARCHAR(50),
  PRIMARY KEY (`id_persona`)
) CHARACTER SET latin1;
CREATE TABLE `registro_grado` (
  `id_persona` INT,
  `id_grado` INT,
  `id_area` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_516656_nueva') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_516656_nueva') AS relationships;
DROP DATABASE `db_516656_nueva`;
UNINSTALL EXTENSION vsql_schematron;
