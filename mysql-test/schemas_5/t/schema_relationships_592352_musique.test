INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592352_musique
--echo #
CREATE DATABASE `db_592352_musique`;
USE `db_592352_musique`;
CREATE TABLE `artiste` (
  `id` INT NOT NULL,
  `nom` VARCHAR(50),
  `est_solo` BOOLEAN,
  `nombre_individus` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `maison_disque` (
  `id` INT NOT NULL,
  `nom` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
  `id` INT NOT NULL,
  `titre` VARCHAR(50),
  `annee` INT,
  `artiste_id` INT,
  `maison_disque_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592352_musique') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592352_musique') AS relationships;
DROP DATABASE `db_592352_musique`;
UNINSTALL EXTENSION vsql_schematron;
