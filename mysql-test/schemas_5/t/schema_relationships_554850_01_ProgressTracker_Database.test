INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 554850_01_ProgressTracker_Database
--echo #
CREATE DATABASE `db_554850_01_ProgressTracker_Database`;
USE `db_554850_01_ProgressTracker_Database`;

CREATE TABLE `Semesters` (
  `semesterID` INT,
  `semesterName` VARCHAR(64),
  `semesterStarts` DATETIME,
  `semesterEnds` DATETIME,
  PRIMARY KEY (`semesterID`)
) CHARACTER SET latin1;

CREATE TABLE `Schools` (
  `schoolID` INT,
  `schoolName` VARCHAR(64),
  PRIMARY KEY (`schoolID`)
) CHARACTER SET latin1;

CREATE TABLE `Divisions` (
  `divisionID` INT,
  `divisionName` VARCHAR(64),
  `schoolID` INT,
  PRIMARY KEY (`divisionID`)
) CHARACTER SET latin1;

CREATE TABLE `Tracks` (
  `trackID` INT,
  `trackName` VARCHAR(64),
  `validFrom` DATETIME,
  `divisionID` INT,
  PRIMARY KEY (`trackID`)
) CHARACTER SET latin1;

CREATE TABLE `Courses` (
  `courseNumber` VARCHAR(64),
  `courseName` VARCHAR(64),
  `courseCredits` INT,
  `minCredits` INT,
  `divisionID` INT,
  PRIMARY KEY (`courseNumber`)
) CHARACTER SET latin1;

CREATE TABLE `StudentCourses` (
  `studentCourseID` INT,
  `grade` INT,
  `semesterTaken` INT,
  `studentID` INT,
  `trackCourseID` INT,
  PRIMARY KEY (`studentCourseID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_554850_01_ProgressTracker_Database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_554850_01_ProgressTracker_Database') AS relationships;
DROP DATABASE `db_554850_01_ProgressTracker_Database`;
UNINSTALL EXTENSION vsql_schematron;
