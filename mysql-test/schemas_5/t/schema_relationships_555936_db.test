INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555936_db
--echo #
CREATE DATABASE `db_555936_db`;
USE `db_555936_db`;
CREATE TABLE `users` (
  `idUser` INT NOT NULL,
  `nome` VARCHAR(50),
  `local` VARCHAR(50),
  PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `idPost` INT NOT NULL,
  `texto` VARCHAR(50),
  `imagem` BLOB,
  `idUser` INT,
  PRIMARY KEY (`idPost`)
) CHARACTER SET latin1;
CREATE TABLE `parceirias` (
  `idParceiro` INT NOT NULL,
  `nome` VARCHAR(50),
  `texto` VARCHAR(50),
  `image` BLOB,
  `telefone` VARCHAR(50),
  PRIMARY KEY (`idParceiro`)
) CHARACTER SET latin1;
CREATE TABLE `avisos` (
  `idavisos` INT NOT NULL,
  `titulo` VARCHAR(50),
  `texto` VARCHAR(50),
  `image` BLOB,
  PRIMARY KEY (`idavisos`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555936_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555936_db') AS relationships;
DROP DATABASE `db_555936_db`;
UNINSTALL EXTENSION vsql_schematron;
