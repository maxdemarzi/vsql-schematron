INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 545270_digibook
--echo #
CREATE DATABASE `db_545270_digibook`;
USE `db_545270_digibook`;

CREATE TABLE `categories` (
  `id` INT,
  `label` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `order_date` DATETIME,
  `total_price` INT,
  `status` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_items` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `qty` INT,
  `price` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `price` INT,
  `category_id` INT,
  `user_id` INT,
  `author` VARCHAR(255),
  `translator` VARCHAR(255),
  `page_count` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `role` VARCHAR(255),
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `mobile` VARCHAR(255),
  `address` VARCHAR(255),
  `postal_code` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_545270_digibook') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_545270_digibook') AS relationships;
DROP DATABASE `db_545270_digibook`;
UNINSTALL EXTENSION vsql_schematron;
