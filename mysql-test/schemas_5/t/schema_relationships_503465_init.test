INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 503465_init
--echo #
CREATE DATABASE `db_503465_init`;
USE `db_503465_init`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie` (
  `id` INT,
  `name` VARCHAR(255),
  `brief` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_style` (
  `movie_id` INT,
  `style_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user_movie` (
  `user_id` INT,
  `movie_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_503465_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_503465_init') AS relationships;
DROP DATABASE `db_503465_init`;
UNINSTALL EXTENSION vsql_schematron;
