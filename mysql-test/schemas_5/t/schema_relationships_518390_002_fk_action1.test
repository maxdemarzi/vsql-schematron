INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518390__002_fk_action1
--echo #
CREATE DATABASE `db_518390_002_fk_action1`;
USE `db_518390_002_fk_action1`;

CREATE TABLE `a_tbl` (
  `id` INT,
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `b_tbl` (
  `ID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518390_002_fk_action1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518390_002_fk_action1') AS relationships;
DROP DATABASE `db_518390_002_fk_action1`;
UNINSTALL EXTENSION vsql_schematron;
