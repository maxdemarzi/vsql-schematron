INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 595238_V5__bracket_remodel
--echo #
CREATE DATABASE `db_595238_V5__bracket_remodel`;
USE `db_595238_V5__bracket_remodel`;
CREATE TABLE `games` (
  `game_id` VARCHAR(50) NOT NULL,
  `team_a` VARCHAR(50),
  `team_b` VARCHAR(50),
  `score_a` INT,
  `score_b` INT,
  `round_id` VARCHAR(50),
  `game_index` VARCHAR(50),
  `bracket_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `brackets` (
  `bracket_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `name` VARCHAR(50),
  `master` TINYINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`bracket_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_595238_V5__bracket_remodel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_595238_V5__bracket_remodel') AS relationships;
DROP DATABASE `db_595238_V5__bracket_remodel`;
UNINSTALL EXTENSION vsql_schematron;
