INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534804_unique_tables
--echo #
CREATE DATABASE `db_534804_unique_tables`;
USE `db_534804_unique_tables`;
CREATE TABLE `expired` (
  `id` TEXT,
  `task` INT,
  `ts` INT,
  `stimulus` INT
) CHARACTER SET latin1;
CREATE TABLE `source` (
  `id` INT NOT NULL,
  `ts` INT,
  `data` TEXT,
  `stimulus` INT,
  `sent` INT,
  `expired` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sink` (
  `id` INT NOT NULL,
  `ts` INT,
  `data` TEXT,
  `stimulus` INT,
  `sent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `edge` (
  `source` BIGINT,
  `sink` BIGINT,
  `stimulus` BIGINT,
  `sent` BOOLEAN
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534804_unique_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534804_unique_tables') AS relationships;
DROP DATABASE `db_534804_unique_tables`;
UNINSTALL EXTENSION vsql_schematron;
