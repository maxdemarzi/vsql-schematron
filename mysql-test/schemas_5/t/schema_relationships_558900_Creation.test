INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558900_Creation
--echo #
CREATE DATABASE `db_558900_Creation`;
USE `db_558900_Creation`;

CREATE TABLE `addresses` (
  `id` INT,
  `compony_name` VARCHAR(64),
  `country` VARCHAR(64),
  `street` VARCHAR(64),
  `apartment` VARCHAR(64),
  `city` VARCHAR(64),
  `postcode` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `carts` (
  `id` INT,
  `product_id` INT,
  `user_id` INT,
  `quantity` INT,
  `size_id` INT,
  `color_id` INT
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `cat_name` VARCHAR(64),
  `cat_img` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `colors` (
  `id` INT,
  `pro_color` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `favorites` (
  `id` INT,
  `product_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `offers` (
  `id` INT,
  `product_id` INT,
  `percentage` INT
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `date` DATETIME,
  `payment_method` VARCHAR(64),
  `total_price` INT,
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_products` (
  `id` INT,
  `product_id` INT,
  `quantity` INT,
  `order_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `pro_name` VARCHAR(64),
  `pro_des` VARCHAR(64),
  `price` INT,
  `mainImage` VARCHAR(64),
  `category_id` INT,
  `pro_rate` INT,
  `pro_gender` VARCHAR(64),
  `favHeader` INT,
  `trending` INT,
  `defaultSize_id` INT,
  `defaultColor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_colors` (
  `id` INT,
  `product_id` INT,
  `color_id` INT
) CHARACTER SET latin1;

CREATE TABLE `product_images` (
  `id` INT,
  `pro_img` VARCHAR(64),
  `product_id` INT
) CHARACTER SET latin1;

CREATE TABLE `product_sizes` (
  `id` INT,
  `product_id` INT,
  `size_id` INT
) CHARACTER SET latin1;

CREATE TABLE `resetpasswords` (
  `id` INT,
  `pin` INT,
  PRIMARY KEY (`id`, `pin`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `re_des` VARCHAR(64),
  `re_rate` INT,
  `product_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `sizes` (
  `id` INT,
  `pro_size` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `Fname` VARCHAR(64),
  `Lname` VARCHAR(64),
  `email` VARCHAR(64),
  `verify_code` VARCHAR(64),
  `password` VARCHAR(64),
  `IsAdmin` INT,
  `email_verified_at` DATETIME,
  `remember_token` VARCHAR(64),
  `img` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558900_Creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558900_Creation') AS relationships;
DROP DATABASE `db_558900_Creation`;
UNINSTALL EXTENSION vsql_schematron;
