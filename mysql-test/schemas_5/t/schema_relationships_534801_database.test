INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534801_database
--echo #
CREATE DATABASE `db_534801_database`;
USE `db_534801_database`;
CREATE TABLE `todo` (
  `todo_id` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`todo_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `email` TEXT,
  `password` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534801_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534801_database') AS relationships;
DROP DATABASE `db_534801_database`;
UNINSTALL EXTENSION vsql_schematron;
