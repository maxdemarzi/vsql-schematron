INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582102_schema
--echo #
CREATE DATABASE `db_582102_schema`;
USE `db_582102_schema`;
CREATE TABLE `accident_type` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accident` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `text` VARCHAR(50),
  `address` VARCHAR(50),
  `accident_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accident_rule` (
  `accident_id` INT NOT NULL,
  `rule_id` INT NOT NULL,
  PRIMARY KEY (`accident_id`, `rule_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582102_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582102_schema') AS relationships;
DROP DATABASE `db_582102_schema`;
UNINSTALL EXTENSION vsql_schematron;
