INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 592943_database_create
--echo #
CREATE DATABASE `db_592943_database_create`;
USE `db_592943_database_create`;

CREATE TABLE `mu_process` (
  `process_id` INT,
  `correlation_id` VARCHAR(255),
  `state` INT,
  `accept_failure` VARCHAR(255),
  `result` VARCHAR(255),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`process_id`)
) CHARACTER SET latin1;

CREATE TABLE `mu_process_step` (
  `process_id` INT,
  `step_id` INT,
  `class_name` VARCHAR(255),
  `method_name` VARCHAR(255),
  `activity_params` VARCHAR(255),
  `orchestr_params` VARCHAR(255),
  `previous_state` VARCHAR(255),
  `compensate_if_failure` VARCHAR(255),
  `transaction_successful` VARCHAR(255),
  `retries` INT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`process_id`, `step_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_592943_database_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_592943_database_create') AS relationships;
DROP DATABASE `db_592943_database_create`;
UNINSTALL EXTENSION vsql_schematron;
