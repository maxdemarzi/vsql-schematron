INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577373_application
--echo #
CREATE DATABASE `db_577373_application`;
USE `db_577373_application`;
CREATE TABLE `company` (
  `companyID` INT NOT NULL,
  `companyName` VARCHAR(50),
  `applicationStartDate` TEXT,
  `applicationEndDate` TEXT,
  PRIMARY KEY (`companyID`)
) CHARACTER SET latin1;
CREATE TABLE `application` (
  `applicationID` INT NOT NULL,
  `companyID` INT,
  `applicationName` VARCHAR(50),
  `applicationUsername` VARCHAR(50),
  `applicationEmail` VARCHAR(50),
  `applicationCourse` VARCHAR(50),
  `applicationYear` VARCHAR(50),
  `applicationCV` VARCHAR(50),
  `applicationCover` VARCHAR(50),
  PRIMARY KEY (`applicationID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577373_application') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577373_application') AS relationships;
DROP DATABASE `db_577373_application`;
UNINSTALL EXTENSION vsql_schematron;
