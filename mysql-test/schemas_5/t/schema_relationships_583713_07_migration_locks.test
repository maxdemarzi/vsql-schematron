INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583713_07_migration_locks
--echo #
CREATE DATABASE `db_583713_07_migration_locks`;
USE `db_583713_07_migration_locks`;

CREATE TABLE `OPENBILL_LOCKS` (
  `id` VARCHAR(64),
  `owner_id` VARCHAR(64),
  `username` VARCHAR(64),
  `date` DATETIME,
  `created_at` DATETIME,
  `account_id` VARCHAR(64),
  `amount_cents` DECIMAL(10,2),
  `amount_currency` VARCHAR(64),
  `key` VARCHAR(64),
  `details` VARCHAR(64),
  `meta` VARCHAR(64),
  `lock_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583713_07_migration_locks') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583713_07_migration_locks') AS relationships;
DROP DATABASE `db_583713_07_migration_locks`;
UNINSTALL EXTENSION vsql_schematron;
