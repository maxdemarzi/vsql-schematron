INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552471_base
--echo #
CREATE DATABASE `db_552471_base`;
USE `db_552471_base`;

CREATE TABLE `owners` (
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `realties` (
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `ownerships` (
  `fk_owner_id` INT,
  `fk_realty_id` INT
) CHARACTER SET latin1;

CREATE TABLE `brains` (
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `looking_at_the_moon` (
  `id` INT,
  `fk_brain_id` INT,
  `fk_owner_id` INT
) CHARACTER SET latin1;

CREATE TABLE `states` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `impulses` (
  `id` INT,
  `fk_looking_at_the_moon_id` INT,
  `fk_state_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `properties` (
  `fk_impulse_id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `materials` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `monoliths` (
  `id` INT,
  `fk_material_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `dreams` (
  `id` INT,
  `fk_monolith_id` INT
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `is_real` BOOL,
  `fk_dream_id` INT
) CHARACTER SET latin1;

CREATE TABLE `aliens` (
  `id` INT,
  `fk_realty_id` INT
) CHARACTER SET latin1;

CREATE TABLE `expulsions` (
  `fk_impulse_id` INT,
  `fk_alien_id` INT,
  `is_success` BOOL
) CHARACTER SET latin1;

CREATE TABLE `births` (
  `fk_brain_id` INT,
  `fk_dream_id` INT,
  `probability` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `phenomena` (
  `fk_looking_at_the_moon_id` INT,
  `fk_dream_id` INT,
  `probability` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552471_base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552471_base') AS relationships;
DROP DATABASE `db_552471_base`;
UNINSTALL EXTENSION vsql_schematron;
