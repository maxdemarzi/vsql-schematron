INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534134_CreationServeur2
--echo #
CREATE DATABASE `db_534134_CreationServeur2`;
USE `db_534134_CreationServeur2`;

CREATE TABLE `Emprunt` (
  `numA` DECIMAL(10,2),
  `dateE` DATETIME,
  `dateR` DATETIME,
  PRIMARY KEY (`numA`, `dateE`)
) CHARACTER SET latin1;

CREATE TABLE `Exemplaire` (
  `numInv` DECIMAL(10,2),
  `ISBN` DECIMAL(10,2),
  PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;

CREATE TABLE `ExemplaireEmprunte` (
  `numInv` DECIMAL(10,2),
  `numA` DECIMAL(10,2),
  `dateE` DATETIME,
  PRIMARY KEY (`numInv`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534134_CreationServeur2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534134_CreationServeur2') AS relationships;
DROP DATABASE `db_534134_CreationServeur2`;
UNINSTALL EXTENSION vsql_schematron;
