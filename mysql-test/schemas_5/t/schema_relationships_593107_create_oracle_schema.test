  PRIMARY KEY (`DATASET_ACCESS_TYPE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PARAMETER_SET_HASHES` (
  `PARAMETER_SET_HASH_ID` INT,
  `PSET_HASH` VARCHAR(64),
