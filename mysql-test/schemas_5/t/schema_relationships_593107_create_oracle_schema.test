  `IS_DATASET_VALID` INT,
  `PRIMARY_DS_ID` INT,
  `PROCESSED_DS_ID` INT,
  `DATA_TIER_ID` INT,
  `DATASET_ACCESS_TYPE_ID` INT,
  `ACQUISITION_ERA_ID` INT,
  `PROCESSING_ERA_ID` INT,
  `PHYSICS_GROUP_ID` INT,
  `XTCROSSSECTION` DECIMAL(10,2),
  `PREP_ID` VARCHAR(64),
