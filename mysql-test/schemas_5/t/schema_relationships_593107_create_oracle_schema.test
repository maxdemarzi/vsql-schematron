) CHARACTER SET latin1;

CREATE TABLE `DATA_TIERS` (
  `DATA_TIER_ID` INT,
  `DATA_TIER_NAME` VARCHAR(64),
  `CREATION_DATE` INT,
  `CREATE_BY` VARCHAR(64),
  PRIMARY KEY (`DATA_TIER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PRIMARY_DATASETS` (
  `PRIMARY_DS_ID` INT,
  `PRIMARY_DS_NAME` VARCHAR(64),
  `PRIMARY_DS_TYPE_ID` INT,
  `CREATION_DATE` INT,
  `CREATE_BY` VARCHAR(64),
  PRIMARY KEY (`PRIMARY_DS_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ACQUISITION_ERAS` (
  `ACQUISITION_ERA_ID` INT,
