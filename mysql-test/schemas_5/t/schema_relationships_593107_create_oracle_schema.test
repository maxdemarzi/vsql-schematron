  PRIMARY KEY (`PROCESSED_DS_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BRANCH_HASHES` (
  `BRANCH_HASH_ID` INT,
  `BRANCH_HASH` VARCHAR(64),
  `CONTENT` VARCHAR(64),
  PRIMARY KEY (`BRANCH_HASH_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FILE_DATA_TYPES` (
  `FILE_TYPE_ID` INT,
  `FILE_TYPE` VARCHAR(64),
  PRIMARY KEY (`FILE_TYPE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PHYSICS_GROUPS` (
  `PHYSICS_GROUP_ID` INT,
  `PHYSICS_GROUP_NAME` VARCHAR(64),
  PRIMARY KEY (`PHYSICS_GROUP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PRIMARY_DS_TYPES` (
  `PRIMARY_DS_TYPE_ID` INT,
