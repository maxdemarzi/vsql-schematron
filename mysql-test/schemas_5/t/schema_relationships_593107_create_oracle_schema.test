  `ORIGIN_SITE_NAME` VARCHAR(64),
  `BLOCK_SIZE` INT,
  `FILE_COUNT` INT,
  `CREATION_DATE` INT,
  `CREATE_BY` VARCHAR(64),
  `LAST_MODIFICATION_DATE` INT,
  `LAST_MODIFIED_BY` VARCHAR(64),
  PRIMARY KEY (`BLOCK_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FILES` (
  `FILE_ID` INT,
  `LOGICAL_FILE_NAME` VARCHAR(64),
  `IS_FILE_VALID` INT,
  `DATASET_ID` INT,
  `BLOCK_ID` INT,
  `FILE_TYPE_ID` INT,
  `CHECK_SUM` VARCHAR(64),
  `EVENT_COUNT` INT,
  `FILE_SIZE` INT,
  `BRANCH_HASH_ID` INT,
  `ADLER32` VARCHAR(64),
  `MD5` VARCHAR(64),
  `AUTO_CROSS_SECTION` DECIMAL(10,2),
  `CREATION_DATE` INT,
  `CREATE_BY` VARCHAR(64),
  `LAST_MODIFICATION_DATE` INT,
  `LAST_MODIFIED_BY` VARCHAR(64),
  PRIMARY KEY (`FILE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATASET_OUTPUT_MOD_CONFIGS` (
  `DS_OUTPUT_MOD_CONF_ID` INT,
  `DATASET_ID` INT,
  `OUTPUT_MOD_CONFIG_ID` INT,
  PRIMARY KEY (`DS_OUTPUT_MOD_CONF_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATASET_RUNS` (
  `DATASET_RUN_ID` INT,
  `DATASET_ID` INT,
  `RUN_NUMBER` INT,
  `COMPLETE` INT,
  `LUMI_SECTION_COUNT` INT,
  `CREATION_DATE` INT,
  `CREATE_BY` VARCHAR(64),
  PRIMARY KEY (`DATASET_RUN_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FILE_OUTPUT_MOD_CONFIGS` (
  `FILE_OUTPUT_CONFIG_ID` INT,
  `FILE_ID` INT,
  `OUTPUT_MOD_CONFIG_ID` INT,
  PRIMARY KEY (`FILE_OUTPUT_CONFIG_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ASSOCIATED_FILES` (
  `ASSOCATED_FILE_ID` INT,
  `THIS_FILE_ID` INT,
  `ASSOCATED_FILE` INT,
  PRIMARY KEY (`ASSOCATED_FILE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FILE_LUMIS` (
  `RUN_NUM` INT,
  `LUMI_SECTION_NUM` INT,
  `FILE_ID` INT,
  `EVENT_COUNT` INT,
  PRIMARY KEY (`RUN_NUM`, `LUMI_SECTION_NUM`, `FILE_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_593107_create_oracle_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_593107_create_oracle_schema') AS relationships;
DROP DATABASE `db_593107_create_oracle_schema`;
UNINSTALL EXTENSION vsql_schematron;
