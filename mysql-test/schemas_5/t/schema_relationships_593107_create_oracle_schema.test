  PRIMARY KEY (`PARAMETER_SET_HASH_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DBS_VERSIONS` (
  `DBS_VERSION_ID` INT,
  `SCHEMA_VERSION` VARCHAR(64),
  `DBS_RELEASE_VERSION` VARCHAR(64),
  `INSTANCE_NAME` VARCHAR(64),
  `INSTANCE_TYPE` VARCHAR(64),
  `CREATION_DATE` INT,
  `LAST_MODIFICATION_DATE` INT,
  PRIMARY KEY (`DBS_VERSION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `OUTPUT_MODULE_CONFIGS` (
  `OUTPUT_MOD_CONFIG_ID` INT,
