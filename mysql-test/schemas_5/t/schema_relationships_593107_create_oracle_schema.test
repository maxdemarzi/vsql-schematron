INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 593107_create_oracle_schema
--echo #
CREATE DATABASE `db_593107_create_oracle_schema`;
USE `db_593107_create_oracle_schema`;

CREATE TABLE `APPLICATION_EXECUTABLES` (
  `APP_EXEC_ID` INT,
  `APP_NAME` VARCHAR(64),
  PRIMARY KEY (`APP_EXEC_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RELEASE_VERSIONS` (
  `RELEASE_VERSION_ID` INT,
  `RELEASE_VERSION` VARCHAR(64),
  PRIMARY KEY (`RELEASE_VERSION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PROCESSED_DATASETS` (
  `PROCESSED_DS_ID` INT,
