  PRIMARY KEY (`ACQUISITION_ERA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PROCESSING_ERAS` (
  `PROCESSING_ERA_ID` INT,
  `PROCESSING_VERSION` INT,
