INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 597902_data
--echo #
CREATE DATABASE `db_597902_data`;
USE `db_597902_data`;

CREATE TABLE `Txn` (
  `id` VARCHAR(64),
  `order_id` VARCHAR(64),
  `txn_desc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `id` VARCHAR(64),
  `txn_id` VARCHAR(64),
  `cust_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CustomerOrder` (
  `id` VARCHAR(64),
  `txn_id` VARCHAR(64),
  `cust_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_597902_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_597902_data') AS relationships;
DROP DATABASE `db_597902_data`;
UNINSTALL EXTENSION vsql_schematron;
