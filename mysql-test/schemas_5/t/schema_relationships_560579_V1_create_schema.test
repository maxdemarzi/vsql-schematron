INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 560579_V1__create-schema
--echo #
CREATE DATABASE `db_560579_V1_create_schema`;
USE `db_560579_V1_create_schema`;

CREATE TABLE `application` (
  `application_id` VARCHAR(64),
  `application_name` VARCHAR(64),
  `url` VARCHAR(64),
  `read_sensitive_data` BOOL,
  PRIMARY KEY (`application_id`)
) CHARACTER SET latin1;

CREATE TABLE `access_token` (
  `application_id` VARCHAR(64),
  `token` VARCHAR(64),
  PRIMARY KEY (`application_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_560579_V1_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_560579_V1_create_schema') AS relationships;
DROP DATABASE `db_560579_V1_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
