INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552355_schema
--echo #
CREATE DATABASE `db_552355_schema`;
USE `db_552355_schema`;

CREATE TABLE `students` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `courses` (
  `course_name` VARCHAR(64),
  `course_code` VARCHAR(64),
  PRIMARY KEY (`course_code`)
) CHARACTER SET latin1;

CREATE TABLE `attendance` (
  `date_attended` DATETIME,
  `id` INT,
  `course_code` VARCHAR(64),
  `status` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552355_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552355_schema') AS relationships;
DROP DATABASE `db_552355_schema`;
UNINSTALL EXTENSION vsql_schematron;
