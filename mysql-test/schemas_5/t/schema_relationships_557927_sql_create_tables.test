INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 557927_sql_create_tables
--echo #
CREATE DATABASE `db_557927_sql_create_tables`;
USE `db_557927_sql_create_tables`;
CREATE TABLE `links` (
  `id` INT NOT NULL,
  `link_name` VARCHAR(50),
  `alias` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clicks` (
  `id` INT NOT NULL,
  `link_id` INT,
  `click_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queue` (
  `id` INT NOT NULL,
  `channel` VARCHAR(50),
  `job` BLOB,
  `pushed_at` INT,
  `ttr` INT,
  `delay` INT,
  `priority` VARCHAR(50),
  `reserved_at` INT,
  `attempt` INT,
  `done_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_557927_sql_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_557927_sql_create_tables') AS relationships;
DROP DATABASE `db_557927_sql_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
