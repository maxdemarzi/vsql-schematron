INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586429_ProjetoT2S
--echo #
CREATE DATABASE `db_586429_ProjetoT2S`;
USE `db_586429_ProjetoT2S`;

CREATE TABLE `Crud_Container` (
  `CtId` INT,
  `CtCliente` VARCHAR(64),
  `CtNumero` VARCHAR(64),
  `CtTipo` VARCHAR(64),
  `CtStatus` VARCHAR(64),
  `CtCategoria` VARCHAR(64),
  PRIMARY KEY (`CtId`)
) CHARACTER SET latin1;

CREATE TABLE `Crud_Movimentacao` (
  `MovId` INT,
  `MovNumero` VARCHAR(64),
  `MovTipo` VARCHAR(64),
  `MovDataInicial` DATETIME,
  `MovHoraInicial` DATETIME,
  `MovDataFinal` DATETIME,
  `MovHoraFinal` DATETIME,
  PRIMARY KEY (`MovId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586429_ProjetoT2S') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586429_ProjetoT2S') AS relationships;
DROP DATABASE `db_586429_ProjetoT2S`;
UNINSTALL EXTENSION vsql_schematron;
