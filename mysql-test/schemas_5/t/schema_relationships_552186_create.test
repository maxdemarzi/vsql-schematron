INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552186_create
--echo #
CREATE DATABASE `db_552186_create`;
USE `db_552186_create`;

CREATE TABLE `customers` (
  `cust_id` INT,
  `cust_name` VARCHAR(64),
  `cust_address` VARCHAR(64),
  `cust_city` VARCHAR(64),
  `cust_state` VARCHAR(64),
  `cust_zip` VARCHAR(64),
  `cust_country` VARCHAR(64),
  `cust_contact` VARCHAR(64),
  `cust_email` VARCHAR(64),
  PRIMARY KEY (`cust_id`)
) CHARACTER SET latin1;

CREATE TABLE `orderitems` (
  `order_num` INT,
  `order_item` INT,
  `prod_id` VARCHAR(64),
  `quantity` INT,
  `item_price` DECIMAL(10,2),
  PRIMARY KEY (`order_num`, `order_item`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_num` INT,
  `order_date` DATETIME,
  `cust_id` INT,
  PRIMARY KEY (`order_num`)
) CHARACTER SET latin1;

CREATE TABLE `vendors` (
  `vend_id` INT,
  `vend_name` VARCHAR(64),
  `vend_address` VARCHAR(64),
  `vend_city` VARCHAR(64),
  `vend_state` VARCHAR(64),
  `vend_zip` VARCHAR(64),
  `vend_country` VARCHAR(64),
  PRIMARY KEY (`vend_id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `prod_id` VARCHAR(64),
  `vend_id` INT,
  `prod_name` VARCHAR(64),
  `prod_price` DECIMAL(10,2),
  `prod_desc` VARCHAR(64),
  PRIMARY KEY (`prod_id`)
) CHARACTER SET latin1;

CREATE TABLE `productnotes` (
  `note_id` INT,
  `prod_id` VARCHAR(64),
  `note_date` DATETIME,
  `note_text` VARCHAR(64),
  PRIMARY KEY (`note_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552186_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552186_create') AS relationships;
DROP DATABASE `db_552186_create`;
UNINSTALL EXTENSION vsql_schematron;
