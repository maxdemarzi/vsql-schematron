INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583219_comparisonDDL
--echo #
CREATE DATABASE `db_583219_comparisonDDL`;
USE `db_583219_comparisonDDL`;
CREATE TABLE `gameData` (
  `dataId` DECIMAL(10,2) NOT NULL,
  `category` VARCHAR(50),
  `title` VARCHAR(50),
  `imgsrc` VARCHAR(50),
  `parameter` VARCHAR(50),
  PRIMARY KEY (`dataId`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `userId` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `userName` VARCHAR(50),
  `nickName` VARCHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `score` (
  `scoreId` DECIMAL(10,2) NOT NULL,
  `category` VARCHAR(50),
  `userId` VARCHAR(50),
  `score` VARCHAR(50),
  PRIMARY KEY (`scoreId`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
  `category` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`category`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583219_comparisonDDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583219_comparisonDDL') AS relationships;
DROP DATABASE `db_583219_comparisonDDL`;
UNINSTALL EXTENSION vsql_schematron;
