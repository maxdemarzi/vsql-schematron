INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568191_10119254_Kepegawaian
--echo #
CREATE DATABASE `db_568191_10119254_Kepegawaian`;
USE `db_568191_10119254_Kepegawaian`;
CREATE TABLE `data_gaji` (
  `kd_gaji` VARCHAR(50),
  `nip` VARCHAR(50),
  `tglMasuk` DATE,
  `golongan` VARCHAR(50),
  `tunjangan` INT,
  `gajiPokok` INT
) CHARACTER SET latin1;
CREATE TABLE `data_pegawai` (
  `nip` VARCHAR(50) NOT NULL,
  `nama` VARCHAR(50),
  `jenisKelamin` VARCHAR(50),
  `tglLahir` DATE,
  `alamat` TEXT,
  `status` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`nip`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568191_10119254_Kepegawaian') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568191_10119254_Kepegawaian') AS relationships;
DROP DATABASE `db_568191_10119254_Kepegawaian`;
UNINSTALL EXTENSION vsql_schematron;
