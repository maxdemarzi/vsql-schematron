INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 553649_a
--echo #
CREATE DATABASE `db_553649_a`;
USE `db_553649_a`;

CREATE TABLE `tab_new` (
  `id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tab_new_detail` (
  `id1` DECIMAL(10,2),
  `id2` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_553649_a') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_553649_a') AS relationships;
DROP DATABASE `db_553649_a`;
UNINSTALL EXTENSION vsql_schematron;
