INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552498_schema
--echo #
CREATE DATABASE `db_552498_schema`;
USE `db_552498_schema`;

CREATE TABLE `set` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `card` (
  `id` VARCHAR(64),
  `set_id` VARCHAR(64),
  `number` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `image` VARCHAR(64),
  `rarity` VARCHAR(64),
  `language` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `price` (
  `card_id` VARCHAR(64),
  `timestamp` DATETIME,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`card_id`, `timestamp`)
) CHARACTER SET latin1;

CREATE TABLE `user_card` (
  `user_id` INT,
  `card_id` VARCHAR(64),
  `quality` INT,
  `start_price` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552498_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552498_schema') AS relationships;
DROP DATABASE `db_552498_schema`;
UNINSTALL EXTENSION vsql_schematron;
