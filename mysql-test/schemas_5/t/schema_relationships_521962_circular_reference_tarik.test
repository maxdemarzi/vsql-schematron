INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521962_circular_reference_tarik
--echo #
CREATE DATABASE `db_521962_circular_reference_tarik`;
USE `db_521962_circular_reference_tarik`;

CREATE TABLE `Teams` (
  `team_name` VARCHAR(64),
  `captain` VARCHAR(64),
  PRIMARY KEY (`team_name`)
) CHARACTER SET latin1;

CREATE TABLE `Players` (
  `player_name` VARCHAR(64),
  `team` VARCHAR(64),
  PRIMARY KEY (`player_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521962_circular_reference_tarik') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521962_circular_reference_tarik') AS relationships;
DROP DATABASE `db_521962_circular_reference_tarik`;
UNINSTALL EXTENSION vsql_schematron;
