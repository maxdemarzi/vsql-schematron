INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505426_eu-tenders
--echo #
CREATE DATABASE `db_505426_eu_tenders`;
USE `db_505426_eu_tenders`;

CREATE TABLE `program` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contractor` (
  `id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `isun` VARCHAR(64),
  `project_number` INT,
  `name` VARCHAR(64),
  `beneficiary_id` INT,
  `program_id` INT,
  `date_contract` DATETIME,
  `date_begin` DATETIME,
  `date_end` DATETIME,
  `status` VARCHAR(64),
  `place` VARCHAR(64),
  `activities` VARCHAR(64),
  `budget_approved` INT,
  `budget_total` INT,
  `budget_fin_help` INT,
  `budget_paid` INT,
  `duration` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project_has_contractor` (
  `project_id` INT,
  `contractor_id` INT,
  PRIMARY KEY (`project_id`, `contractor_id`)
) CHARACTER SET latin1;

CREATE TABLE `project_has_partner` (
  `project_id` INT,
  `contractor_id` INT,
  PRIMARY KEY (`project_id`, `contractor_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505426_eu_tenders') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505426_eu_tenders') AS relationships;
DROP DATABASE `db_505426_eu_tenders`;
UNINSTALL EXTENSION vsql_schematron;
