INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 541281_migration
--echo #
CREATE DATABASE `db_541281_migration`;
USE `db_541281_migration`;

CREATE TABLE `Device` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `code` INT,
  `description` VARCHAR(64),
  `model` VARCHAR(64),
  `equipmentNumber` VARCHAR(64),
  `phone` VARCHAR(64),
  `mobileOperator` VARCHAR(64),
  `chipNumber` VARCHAR(64),
  `timezone` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Info` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `odometer` INT,
  `power` DECIMAL(10,2),
  `serial` INT,
  `io` VARCHAR(64),
  `mode` INT,
  `hourMeter` INT,
  `archive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `serverTime` DATETIME,
  `fixTime` DATETIME,
  `satellite` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `speed` INT,
  `course` VARCHAR(64),
  `cellId` VARCHAR(64),
  `mcc` INT,
  `mnc` INT,
  `lac` INT,
  `deviceId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Status` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `blocked` BOOL,
  `valid` BOOL,
  `charge` BOOL,
  `ignition` BOOL,
  `battery` DECIMAL(10,2),
  `rssi` INT,
  `deviceId` VARCHAR(64),
  `infoId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Alert` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `emergency` VARCHAR(64),
  `event` VARCHAR(64),
  `alert` VARCHAR(64),
  `deviceId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `role` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `fullName` VARCHAR(64),
  `cpfOrCnpj` VARCHAR(64),
  `cellPhone` VARCHAR(64),
  `landline` VARCHAR(64),
  `typeOfAddress` VARCHAR(64),
  `cep` VARCHAR(64),
  `street` VARCHAR(64),
  `number` VARCHAR(64),
  `district` VARCHAR(64),
  `complement` VARCHAR(64),
  `state` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Vehicle` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `licensePlate` VARCHAR(64),
  `type` VARCHAR(64),
  `deviceId` VARCHAR(64),
  `customerId` VARCHAR(64),
  `branchId` VARCHAR(64),
  `brand` VARCHAR(64),
  `model` VARCHAR(64),
  `color` VARCHAR(64),
  `year` INT,
  `chassi` VARCHAR(64),
  `renavam` VARCHAR(64),
  `observation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Branch` (
  `id` VARCHAR(64),
  `active` BOOL,
  `deleted` BOOL,
  `createAt` DATETIME,
  `updateAt` DATETIME,
  `customerId` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_541281_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_541281_migration') AS relationships;
DROP DATABASE `db_541281_migration`;
UNINSTALL EXTENSION vsql_schematron;
