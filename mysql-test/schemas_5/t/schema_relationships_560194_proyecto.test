INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 560194_proyecto
--echo #
CREATE DATABASE `db_560194_proyecto`;
USE `db_560194_proyecto`;

CREATE TABLE `tipo_documento` (
  `id_tipo_documento` INT,
  `descripcion` VARCHAR(64),
  PRIMARY KEY (`id_tipo_documento`)
) CHARACTER SET latin1;

CREATE TABLE `factura` (
  `id_factura` INT,
  `id_cliente` INT,
  `monto_final` DECIMAL(10,2),
  `descuento` VARCHAR(64),
  `fecha` DATETIME,
  PRIMARY KEY (`id_factura`)
) CHARACTER SET latin1;

CREATE TABLE `producto` (
  `id_producto` INT,
  `id_proveedor` INT,
  `nombre` VARCHAR(64),
  `precio` DECIMAL(10,2),
  `stock` INT,
  PRIMARY KEY (`id_producto`)
) CHARACTER SET latin1;

CREATE TABLE `detalle` (
  `id_detalle` INT,
  `id_factura` INT,
  `id_producto` INT,
  `monto_total_producto` DECIMAL(10,2),
  `cantidad_venta_producto` VARCHAR(64),
  `precio_unidad_producto` DECIMAL(10,2),
  PRIMARY KEY (`id_detalle`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_560194_proyecto') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_560194_proyecto') AS relationships;
DROP DATABASE `db_560194_proyecto`;
UNINSTALL EXTENSION vsql_schematron;
