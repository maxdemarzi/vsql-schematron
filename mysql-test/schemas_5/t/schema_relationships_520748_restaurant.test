INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520748_restaurant
--echo #
CREATE DATABASE `db_520748_restaurant`;
USE `db_520748_restaurant`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurants` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `image_url` VARCHAR(50),
  `place_id` VARCHAR(50),
  `formatted_address` VARCHAR(50),
  `formatted_phone_number` VARCHAR(50),
  `website` VARCHAR(50),
  `weekday_text` VARCHAR(50),
  `price_level` VARCHAR(50),
  `rating` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorites` (
  `id` INT NOT NULL,
  `user_id` INT,
  `restaurants_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520748_restaurant') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520748_restaurant') AS relationships;
DROP DATABASE `db_520748_restaurant`;
UNINSTALL EXTENSION vsql_schematron;
