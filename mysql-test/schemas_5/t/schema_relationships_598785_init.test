INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 598785_init
--echo #
CREATE DATABASE `db_598785_init`;
USE `db_598785_init`;

CREATE TABLE `poll` (
  `team_id` VARCHAR(64),
  `channel_id` VARCHAR(64),
  `title` VARCHAR(64),
  `user_id` VARCHAR(64),
  PRIMARY KEY (`team_id`, `channel_id`)
) CHARACTER SET latin1;

CREATE TABLE `options` (
  `id` INT,
  `team_id` VARCHAR(64),
  `channel_id` VARCHAR(64),
  `option` VARCHAR(64),
  PRIMARY KEY (`id`, `team_id`, `channel_id`)
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `team_id` VARCHAR(64),
  `channel_id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `option_id` INT,
  PRIMARY KEY (`team_id`, `channel_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_598785_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_598785_init') AS relationships;
DROP DATABASE `db_598785_init`;
UNINSTALL EXTENSION vsql_schematron;
