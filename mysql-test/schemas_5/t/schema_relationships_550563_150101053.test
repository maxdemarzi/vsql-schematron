INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 550563_150101053
--echo #
CREATE DATABASE `db_550563_150101053`;
USE `db_550563_150101053`;

CREATE TABLE `cc` (
  `course_id` VARCHAR(64),
  `number_of_credits` INT,
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;

CREATE TABLE `ett` (
  `line_number` INT,
  `course_id` VARCHAR(64),
  `exam_date` DATETIME,
  `start_time` DATETIME,
  `end_time` DATETIME,
  PRIMARY KEY (`course_id`, `exam_date`)
) CHARACTER SET latin1;

CREATE TABLE `cwsl` (
  `serial_number` INT,
  `roll_number` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `course_id` VARCHAR(64),
  PRIMARY KEY (`roll_number`, `course_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_550563_150101053') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_550563_150101053') AS relationships;
DROP DATABASE `db_550563_150101053`;
UNINSTALL EXTENSION vsql_schematron;
