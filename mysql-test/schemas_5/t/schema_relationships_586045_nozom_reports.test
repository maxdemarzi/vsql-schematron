INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 586045_nozom_reports
--echo #
CREATE DATABASE `db_586045_nozom_reports`;
USE `db_586045_nozom_reports`;

CREATE TABLE `servers` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `db_user` VARCHAR(255),
  `db_password` VARCHAR(255),
  `db_ip` VARCHAR(255),
  `db_name` VARCHAR(255),
  `server_name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `email` VARCHAR(255),
  `server_id` INT,
  `password` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_586045_nozom_reports') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_586045_nozom_reports') AS relationships;
DROP DATABASE `db_586045_nozom_reports`;
UNINSTALL EXTENSION vsql_schematron;
