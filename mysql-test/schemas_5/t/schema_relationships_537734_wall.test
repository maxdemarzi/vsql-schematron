INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 537734_wall
--echo #
CREATE DATABASE `db_537734_wall`;
USE `db_537734_wall`;

CREATE TABLE `admin` (
  `user_id` INT,
  `type` INT
) CHARACTER SET latin1;

CREATE TABLE `c3p0TestTable` (
  `a` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `table_id` INT,
  `user_id` INT,
  `create_time` DATETIME,
  `content` VARCHAR(64),
  `images` VARCHAR(64),
  `status` INT
) CHARACTER SET latin1;

CREATE TABLE `support` (
  `user_id` INT,
  `table_id` INT
) CHARACTER SET latin1;

CREATE TABLE `table` (
  `id` INT,
  `sender` VARCHAR(64),
  `sender_sex` VARCHAR(64),
  `recipient` VARCHAR(64),
  `recipient_sex` VARCHAR(64),
  `create_time` DATETIME,
  `content` VARCHAR(64),
  `images` VARCHAR(64),
  `user_id` INT,
  `anonymous` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `student_id` INT,
  `create_time` DATETIME,
  `last_time` DATETIME,
  `token` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_537734_wall') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_537734_wall') AS relationships;
DROP DATABASE `db_537734_wall`;
UNINSTALL EXTENSION vsql_schematron;
