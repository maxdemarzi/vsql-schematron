INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531697_user
--echo #
CREATE DATABASE `db_531697_user`;
USE `db_531697_user`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `password2` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `userSession` (
  `sessionCode` VARCHAR(64),
  `userId` INT,
  `ip` VARCHAR(64),
  `userAgent` VARCHAR(64),
  `platform` VARCHAR(64),
  `appVersion` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`sessionCode`)
) CHARACTER SET latin1;

CREATE TABLE `chatRoomUser` (
  `userId` INT,
  `chatId` INT,
  `createdAt` DATETIME,
  PRIMARY KEY (`userId`, `chatId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531697_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531697_user') AS relationships;
DROP DATABASE `db_531697_user`;
UNINSTALL EXTENSION vsql_schematron;
