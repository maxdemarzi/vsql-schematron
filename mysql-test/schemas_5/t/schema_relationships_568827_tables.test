INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568827_tables
--echo #
CREATE DATABASE `db_568827_tables`;
USE `db_568827_tables`;
CREATE TABLE `Entreprise` (
  `id_entreprise` VARCHAR(50) NOT NULL,
  `nom_entreprise` VARCHAR(50),
  `url_entreprise` TEXT,
  PRIMARY KEY (`id_entreprise`)
) CHARACTER SET latin1;
CREATE TABLE `Utilisateur` (
  `id_utilisateur` VARCHAR(50) NOT NULL,
  `nom_utilisateur` VARCHAR(50),
  PRIMARY KEY (`id_utilisateur`)
) CHARACTER SET latin1;
CREATE TABLE `Produit` (
  `id_produit` VARCHAR(50) NOT NULL,
  `titre_produit` VARCHAR(50),
  `description_produit` VARCHAR(50),
  PRIMARY KEY (`id_produit`)
) CHARACTER SET latin1;
CREATE TABLE `Vente` (
  `id_utilisateur` VARCHAR(50) NOT NULL,
  `id_produit` VARCHAR(50) NOT NULL,
  `id_entreprise` VARCHAR(50) NOT NULL,
  `dateCreation` DATE NOT NULL,
  `reference` VARCHAR(50),
  `prix` INT,
  `quantite` INT,
  PRIMARY KEY (`id_utilisateur`, `id_produit`, `id_entreprise`, `dateCreation`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568827_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568827_tables') AS relationships;
DROP DATABASE `db_568827_tables`;
UNINSTALL EXTENSION vsql_schematron;
