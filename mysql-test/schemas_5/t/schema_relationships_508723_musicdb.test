INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508723_musicdb
--echo #
CREATE DATABASE `db_508723_musicdb`;
USE `db_508723_musicdb`;

CREATE TABLE `login` (
  `Fname` VARCHAR(255),
  `Lname` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `DOB` DATETIME,
  `country` VARCHAR(255),
  `gender` VARCHAR(255),
  `userType` VARCHAR(255),
  `subscriptionPeriod` INT,
  `subscriptionCost` INT
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `movieName` VARCHAR(255),
  `movieID` INT,
  `director` VARCHAR(255),
  `actor` VARCHAR(255),
  `actress` VARCHAR(255),
  `language` VARCHAR(255),
  PRIMARY KEY (`movieID`)
) CHARACTER SET latin1;

CREATE TABLE `playlist` (
  `playlistName` VARCHAR(255),
  `playlistID` INT,
  `songID` INT
) CHARACTER SET latin1;

CREATE TABLE `singers` (
  `singerName` VARCHAR(255),
  `singerID` INT,
  `country` VARCHAR(255),
  `DOB` DATETIME,
  `Gender` VARCHAR(255),
  PRIMARY KEY (`singerID`)
) CHARACTER SET latin1;

CREATE TABLE `songs` (
  `songID` INT,
  `songName` VARCHAR(255),
  `singerID` INT,
  `movieID` INT,
  `lyricist` VARCHAR(255),
  `musicProducer` VARCHAR(255),
  `musicDistributer` VARCHAR(255),
  `language` VARCHAR(255),
  `genre` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `trending` (
  `slno` INT,
  `songID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508723_musicdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508723_musicdb') AS relationships;
DROP DATABASE `db_508723_musicdb`;
UNINSTALL EXTENSION vsql_schematron;
