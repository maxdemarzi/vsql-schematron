INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 519909_V1_2__ExtendedSchemaStock_Order
--echo #
CREATE DATABASE `db_519909_V1_2_ExtendedSchemaStock_Order`;
USE `db_519909_V1_2_ExtendedSchemaStock_Order`;

CREATE TABLE `Address` (
  `AddressId` INT,
  `Country` VARCHAR(64),
  `City` VARCHAR(64),
  `County` VARCHAR(64),
  `Street` VARCHAR(64),
  PRIMARY KEY (`AddressId`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `LocationId` INT,
  `Name` VARCHAR(64),
  `AddressId` INT,
  PRIMARY KEY (`LocationId`)
) CHARACTER SET latin1;

CREATE TABLE `Stock` (
  `ProductId` INT,
  `LocationId` INT,
  `Quantity` INT,
  PRIMARY KEY (`ProductId`, `LocationId`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `CustomerId` INT,
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `UserName` VARCHAR(64),
  `PasswordHash` VARCHAR(64),
  `EmailAddress` VARCHAR(64),
  PRIMARY KEY (`CustomerId`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `OrderId` INT,
  `LocationId` INT,
  `CustomerId` INT,
  `CreatedAt` DATETIME,
  `AddressId` INT,
  PRIMARY KEY (`OrderId`)
) CHARACTER SET latin1;

CREATE TABLE `OrderDetail` (
  `orderId` INT,
  `productId` INT,
  `quantity` INT,
  PRIMARY KEY (`orderId`, `productId`)
) CHARACTER SET latin1;

CREATE TABLE `Revenue` (
  `RevenueId` INT,
  `LocationId` INT,
  `Date` DATETIME,
  `Sum` DECIMAL(10,2),
  PRIMARY KEY (`RevenueId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_519909_V1_2_ExtendedSchemaStock_Order') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_519909_V1_2_ExtendedSchemaStock_Order') AS relationships;
DROP DATABASE `db_519909_V1_2_ExtendedSchemaStock_Order`;
UNINSTALL EXTENSION vsql_schematron;
