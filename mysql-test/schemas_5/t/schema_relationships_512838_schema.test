INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512838_schema
--echo #
CREATE DATABASE `db_512838_schema`;
USE `db_512838_schema`;

CREATE TABLE `alpha` (
  `id` INT,
  `val` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `beta` (
  `id` INT,
  `alpha_id` INT,
  `val` VARCHAR(64),
  `val2` VARCHAR(64),
  `j` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gamma` (
  `id` INT,
  `alpha_id_one` INT,
  `alpha_id_two` INT,
  `beta_id` INT,
  `val` VARCHAR(64),
  `j` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zeta` (
  `id` INT,
  `val` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `alpha_zeta` (
  `alpha_id` INT,
  `zeta_id` INT
) CHARACTER SET latin1;

CREATE TABLE `sch.delta` (
  `id` INT,
  `beta_id` INT,
  `val` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sch.epsilon` (
  `id` INT,
  `alpha_id` INT,
  `val` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512838_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512838_schema') AS relationships;
DROP DATABASE `db_512838_schema`;
UNINSTALL EXTENSION vsql_schematron;
