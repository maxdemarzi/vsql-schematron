INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 526638_dbfilmoteka
--echo #
CREATE DATABASE `db_526638_dbfilmoteka`;
USE `db_526638_dbfilmoteka`;
CREATE TABLE `film` (
  `id` INT NOT NULL,
  `nazev` VARCHAR(50),
  `filename` VARCHAR(50),
  `popis` TEXT,
  `idrok` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zanr` (
  `id` INT NOT NULL,
  `nazev` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rok` (
  `id` INT NOT NULL,
  `rok` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `film_zanr` (
  `idfilm` INT,
  `idzanr` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_526638_dbfilmoteka') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_526638_dbfilmoteka') AS relationships;
DROP DATABASE `db_526638_dbfilmoteka`;
UNINSTALL EXTENSION vsql_schematron;
