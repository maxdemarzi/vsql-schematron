INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531512_COMPANY
--echo #
CREATE DATABASE `db_531512_COMPANY`;
USE `db_531512_COMPANY`;

CREATE TABLE `EMPLOYEE` (
  `Eno` VARCHAR(64),
  `Ename` VARCHAR(64),
  `Job_type` VARCHAR(64),
  `SupervisorENo` VARCHAR(64),
  `Hire_date` DATETIME,
  `Dno` INT,
  `Commission` VARCHAR(64),
  `Salary` VARCHAR(64),
  PRIMARY KEY (`Eno`)
) CHARACTER SET latin1;

CREATE TABLE `DEPARTMENT` (
  `Dno` INT,
  `Dname` VARCHAR(64),
  `Location` VARCHAR(64),
  PRIMARY KEY (`Dno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531512_COMPANY') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531512_COMPANY') AS relationships;
DROP DATABASE `db_531512_COMPANY`;
UNINSTALL EXTENSION vsql_schematron;
