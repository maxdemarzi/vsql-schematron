INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 527012_DBTables
--echo #
CREATE DATABASE `db_527012_DBTables`;
USE `db_527012_DBTables`;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlist` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `creation_date` DATE,
  `creator` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `song` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `image` VARCHAR(50),
  `singer` VARCHAR(50),
  `release_date` DATE,
  `musical_genre` VARCHAR(50),
  `file` VARCHAR(50),
  `creator` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `association` (
  `songid` INT NOT NULL,
  `playlistid` INT NOT NULL,
  `ordering` INT,
  PRIMARY KEY (`songid`, `playlistid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_527012_DBTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_527012_DBTables') AS relationships;
DROP DATABASE `db_527012_DBTables`;
UNINSTALL EXTENSION vsql_schematron;
