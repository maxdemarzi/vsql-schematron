INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588323_provinces.cities.areas
--echo #
CREATE DATABASE `db_588323_provinces_cities_areas`;
USE `db_588323_provinces_cities_areas`;
CREATE TABLE `provinces` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
  `id` VARCHAR(50) NOT NULL,
  `province_id` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `areas` (
  `id` VARCHAR(50) NOT NULL,
  `city_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`, `city_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588323_provinces_cities_areas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588323_provinces_cities_areas') AS relationships;
DROP DATABASE `db_588323_provinces_cities_areas`;
UNINSTALL EXTENSION vsql_schematron;
