INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 561832_28
--echo #
CREATE DATABASE `db_561832_28`;
USE `db_561832_28`;
CREATE TABLE `PUBLISH_CATEGORY` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `NEWS_ITEM_CATEGORY` (
  `NEWS_ITEM_ID` VARCHAR(50),
  `PUBLISH_CATEGORY_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `NOTIFICATION_CATEGORY` (
  `NOTIFICATION_ID` VARCHAR(50),
  `PUBLISH_CATEGORY_ID` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_561832_28') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_561832_28') AS relationships;
DROP DATABASE `db_561832_28`;
UNINSTALL EXTENSION vsql_schematron;
