INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 520585_db
--echo #
CREATE DATABASE `db_520585_db`;
USE `db_520585_db`;

CREATE TABLE `player` (
  `id` INT,
  `name` VARCHAR(64),
  `points` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournament` (
  `id` INT,
  `name` VARCHAR(64),
  `deposit` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tournament_player` (
  `id` INT,
  `player_id` INT,
  `tournament_id` INT,
  `prize` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `backer` (
  `id` INT,
  `player_id` INT,
  `backer_id` INT,
  `sum` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_520585_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_520585_db') AS relationships;
DROP DATABASE `db_520585_db`;
UNINSTALL EXTENSION vsql_schematron;
