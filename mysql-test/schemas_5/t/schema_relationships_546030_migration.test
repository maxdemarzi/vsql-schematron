INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546030_migration
--echo #
CREATE DATABASE `db_546030_migration`;
USE `db_546030_migration`;

CREATE TABLE `DevelopmentField` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `DevelopmentTool` (
  `id` INT,
  `name` VARCHAR(64),
  `developmentFieldId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SoftwarePlatform` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `repo` VARCHAR(64),
  `logo` VARCHAR(64),
  `intro` VARCHAR(64),
  `language` VARCHAR(64),
  `coverUrl` VARCHAR(64),
  `description` VARCHAR(64),
  `dockerHubUrl` VARCHAR(64),
  `downloadUrl` VARCHAR(64),
  `tags` VARCHAR(64),
  `screenshots` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_DevelopmentToolToProject` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

CREATE TABLE `_ProjectToSoftwarePlatform` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546030_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546030_migration') AS relationships;
DROP DATABASE `db_546030_migration`;
UNINSTALL EXTENSION vsql_schematron;
