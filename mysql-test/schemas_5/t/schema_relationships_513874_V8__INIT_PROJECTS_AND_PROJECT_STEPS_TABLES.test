USE `db_513874_V8__INIT_PROJECTS_AND_PROJECT_STEPS_TABLES`;
CREATE TABLE `projects` (
  `id` BIGINT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_steps` (
  `id` BIGINT NOT NULL,
  `description` VARCHAR(50),
  `days_to_deadline` INT,
  `project_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513874_V8__INIT_PROJECTS_AND_PROJECT_STEPS_TABLES') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513874_V8__INIT_PROJECTS_AND_PROJECT_STEPS_TABLES') AS relationships;
DROP DATABASE `db_513874_V8__INIT_PROJECTS_AND_PROJECT_STEPS_TABLES`;
