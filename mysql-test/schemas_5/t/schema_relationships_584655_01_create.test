INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 584655_01-create
--echo #
CREATE DATABASE `db_584655_01_create`;
USE `db_584655_01_create`;

CREATE TABLE `CATEGORY` (
  `PAR_CAT_IDE` VARCHAR(64),
  `PAR_CAT_DES` VARCHAR(64),
  PRIMARY KEY (`PAR_CAT_IDE`)
) CHARACTER SET latin1;

CREATE TABLE `PARAMETER` (
  `PAR_CAT_IDE` VARCHAR(64),
  `VAL` VARCHAR(64),
  `DESCR` VARCHAR(64),
  PRIMARY KEY (`PAR_CAT_IDE`)
) CHARACTER SET latin1;

CREATE TABLE `AUTHOR` (
  `id` INT,
  `name` VARCHAR(64),
  `birth_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `BAR_CODE` (
  `id` INT,
  `code` VARCHAR(64),
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `READER` (
  `id` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `STORE` (
  `id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `zipCode` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_584655_01_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_584655_01_create') AS relationships;
DROP DATABASE `db_584655_01_create`;
UNINSTALL EXTENSION vsql_schematron;
