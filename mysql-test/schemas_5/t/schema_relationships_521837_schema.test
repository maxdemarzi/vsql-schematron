INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521837_schema
--echo #
CREATE DATABASE `db_521837_schema`;
USE `db_521837_schema`;
CREATE TABLE `user` (
  `user_id` INT NOT NULL,
  `guild_id` CHAR(50),
  `user_name` VARCHAR(50),
  `is_assignable` BOOLEAN,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `ticket` (
  `ticket_id` INT NOT NULL,
  `user_id` INT,
  `assigned_user_id` INT,
  `ticket_title` VARCHAR(50),
  `ticket_description` TEXT,
  `ticket_tag` VARCHAR(50),
  `is_closed` BOOLEAN,
  `ticket_created_on` DATETIME,
  PRIMARY KEY (`ticket_id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `message_id` INT NOT NULL,
  `ticket_id` INT,
  `user_id` INT,
  `message_text` TEXT,
  `message_sent_on` DATETIME,
  PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521837_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521837_schema') AS relationships;
DROP DATABASE `db_521837_schema`;
UNINSTALL EXTENSION vsql_schematron;
