INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 589196_build_db
--echo #
CREATE DATABASE `db_589196_build_db`;
USE `db_589196_build_db`;

CREATE TABLE `grandparents` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `parents` (
  `id` INT,
  `name` VARCHAR(64),
  `grandparent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `children` (
  `id` INT,
  `name` VARCHAR(64),
  `parent_id` INT,
  `type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_589196_build_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_589196_build_db') AS relationships;
DROP DATABASE `db_589196_build_db`;
UNINSTALL EXTENSION vsql_schematron;
