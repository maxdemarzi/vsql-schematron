INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568075_V1__base_tables
--echo #
CREATE DATABASE `db_568075_V1__base_tables`;
USE `db_568075_V1__base_tables`;
CREATE TABLE `terminal` (
  `terminal_id` BIGINT NOT NULL,
  `created` TIMESTAMP NULL,
  `last_updated` TIMESTAMP NULL,
  PRIMARY KEY (`terminal_id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` BIGINT NOT NULL,
  `created` TIMESTAMP NULL,
  `last_updated` TIMESTAMP NULL,
  `message_type` SMALLINT,
  `terminal_id` BIGINT,
  `issuer_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issuer` (
  `id` BIGINT NOT NULL,
  `created` TIMESTAMP NULL,
  `last_updated` TIMESTAMP NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `card_range` (
  `id` BIGINT NOT NULL,
  `created` TIMESTAMP NULL,
  `last_updated` TIMESTAMP NULL,
  `min_card_number` INT,
  `max_card_number` INT,
  `issuer_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568075_V1__base_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568075_V1__base_tables') AS relationships;
DROP DATABASE `db_568075_V1__base_tables`;
UNINSTALL EXTENSION vsql_schematron;
