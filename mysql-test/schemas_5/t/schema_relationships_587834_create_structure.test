INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 587834_create_structure
--echo #
CREATE DATABASE `db_587834_create_structure`;
USE `db_587834_create_structure`;

CREATE TABLE `USERS` (
  `ID` DECIMAL(10,2),
  `USER_NAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ANALYSES` (
  `ID` DECIMAL(10,2),
  `RUN_TIME` DATETIME,
  `NAME` VARCHAR(64),
  `COMMENT` VARCHAR(64),
  `TYPE` VARCHAR(64),
  `USER_RATE` VARCHAR(64),
  `QUALITY_STATUS` VARCHAR(64),
  `MAIN_SUMMARY` VARCHAR(64),
  `ADDITIONAL_SUMMARY` VARCHAR(64),
  `HTML_REPORT` VARCHAR(64),
  `USER_ID` DECIMAL(10,2),
  `PARENT_ANALYSIS_ID` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_587834_create_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_587834_create_structure') AS relationships;
DROP DATABASE `db_587834_create_structure`;
UNINSTALL EXTENSION vsql_schematron;
