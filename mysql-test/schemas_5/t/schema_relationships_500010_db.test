INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 500010_db
--echo #
CREATE DATABASE `db_500010_db`;
USE `db_500010_db`;

CREATE TABLE `usuario` (
  `id` INT,
  `nome_completo` VARCHAR(64),
  `cpf` VARCHAR(64),
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  `tipo` INT,
  `carteira` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `value` INT,
  `payer` INT,
  `payee` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_500010_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_500010_db') AS relationships;
DROP DATABASE `db_500010_db`;
UNINSTALL EXTENSION vsql_schematron;
