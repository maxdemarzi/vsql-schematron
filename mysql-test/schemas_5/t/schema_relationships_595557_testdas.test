INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 595557_testdas
--echo #
CREATE DATABASE `db_595557_testdas`;
USE `db_595557_testdas`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` TEXT,
  `password` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_to_groups` (
  `id` INT NOT NULL,
  `userid` INT,
  `groupid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_595557_testdas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_595557_testdas') AS relationships;
DROP DATABASE `db_595557_testdas`;
UNINSTALL EXTENSION vsql_schematron;
