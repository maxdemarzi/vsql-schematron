INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 522892_livraria%20depressao%202
--echo #
CREATE DATABASE `db_522892_livraria_20depressao_202`;
USE `db_522892_livraria_20depressao_202`;
CREATE TABLE `CLIENTE` (
  `idCliente` INT NOT NULL,
  `nomeCliente` VARCHAR(50),
  `sexo` VARCHAR(50),
  `cpf` VARCHAR(50),
  `email` VARCHAR(50),
  `celular` VARCHAR(50),
  `statusCliente` VARCHAR(50),
  PRIMARY KEY (`idCliente`)
) CHARACTER SET latin1;
CREATE TABLE `FUNCIONARIOS` (
  `idFuncionario` INT NOT NULL,
  `nomeFuncionario` VARCHAR(50),
  `cargo` VARCHAR(50),
  `sexo` VARCHAR(50),
  PRIMARY KEY (`idFuncionario`)
) CHARACTER SET latin1;
CREATE TABLE `LOGIN` (
  `idUsuarioLogin` INT NOT NULL,
  `idFuncionario` INT,
  `nomeUsuario` VARCHAR(50),
  `senha` VARCHAR(50),
  `permissao` VARCHAR(50),
  PRIMARY KEY (`idUsuarioLogin`)
) CHARACTER SET latin1;
CREATE TABLE `AUTORES` (
  `idAutor` INT NOT NULL,
  `nomeAutor` VARCHAR(50),
  PRIMARY KEY (`idAutor`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORIA` (
  `idCategoria` INT NOT NULL,
  `nomeCategoria` VARCHAR(50),
  PRIMARY KEY (`idCategoria`)
) CHARACTER SET latin1;
CREATE TABLE `EDITORA` (
  `idEditora` INT NOT NULL,
  `nomeEditora` VARCHAR(50),
  PRIMARY KEY (`idEditora`)
) CHARACTER SET latin1;
CREATE TABLE `LIVROS` (
  `idLivro` INT NOT NULL,
  `idCategoria` INT,
  `idAutor` INT,
  `idEditora` INT,
  `nomeLivro` VARCHAR(50),
  `isbn` VARCHAR(50),
  `qtd` INT,
  `precoUnidade` DOUBLE,
  PRIMARY KEY (`idLivro`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVA` (
  `idReserva` INT NOT NULL,
  `idCliente` INT,
  `idFuncionario` INT,
  `idLivro` INT,
  `idEmprestimo` INT,
  `dataReserva` DATETIME,
  `dataRetiradaPrevista` DATETIME,
  `dataRetirada` DATETIME,
  `statusReserva` VARCHAR(50),
  PRIMARY KEY (`idReserva`)
) CHARACTER SET latin1;
CREATE TABLE `TIPOS_MULTA` (
  `idTipoMulta` INT NOT NULL,
  `nomeTipo` VARCHAR(50),
  `valor` DOUBLE,
  PRIMARY KEY (`idTipoMulta`)
) CHARACTER SET latin1;
CREATE TABLE `MULTA` (
  `idMulta` INT NOT NULL,
  `idTipoMulta` INT,
  `idEmprestimo` INT,
  `idFuncionario` INT,
  `observacoes` VARCHAR(50),
  `statusMulta` VARCHAR(50),
  `totalMulta` DOUBLE,
  PRIMARY KEY (`idMulta`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_522892_livraria_20depressao_202') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_522892_livraria_20depressao_202') AS relationships;
DROP DATABASE `db_522892_livraria_20depressao_202`;
UNINSTALL EXTENSION vsql_schematron;
