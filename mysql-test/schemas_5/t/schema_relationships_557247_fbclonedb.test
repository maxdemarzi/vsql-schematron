INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 557247_fbclonedb
--echo #
CREATE DATABASE `db_557247_fbclonedb`;
USE `db_557247_fbclonedb`;
CREATE TABLE `fbclonedb.users` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.posts` (
  `id` INT NOT NULL,
  `content` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.comments` (
  `id` INT NOT NULL,
  `content` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.likes` (
  `id` INT NOT NULL,
  `like` TINYINT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `user_id` INT,
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_557247_fbclonedb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_557247_fbclonedb') AS relationships;
DROP DATABASE `db_557247_fbclonedb`;
UNINSTALL EXTENSION vsql_schematron;
