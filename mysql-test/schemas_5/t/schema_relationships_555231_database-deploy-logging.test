INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555231_database-deploy-logging
--echo #
CREATE DATABASE `db_555231_database_deploy_logging`;
USE `db_555231_database_deploy_logging`;
CREATE TABLE `dbdeploy.activitytype` (
  `activitytypeid` SMALLINT NOT NULL,
  `activitytype` VARCHAR(50),
  PRIMARY KEY (`activitytypeid`)
) CHARACTER SET latin1;
CREATE TABLE `dbdeploy.activity` (
  `activityid` INT NOT NULL,
  `activitytimestamp` TIMESTAMP NULL,
  `filename` VARCHAR(50),
  `activitytypeid` SMALLINT,
  PRIMARY KEY (`activityid`)
) CHARACTER SET latin1;
CREATE TABLE `dbdeploy.deployed` (
  `deployedid` INT NOT NULL,
  `filename` VARCHAR(50),
  `deployedtimestamp` TIMESTAMP NULL,
  PRIMARY KEY (`deployedid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555231_database_deploy_logging') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555231_database_deploy_logging') AS relationships;
DROP DATABASE `db_555231_database_deploy_logging`;
UNINSTALL EXTENSION vsql_schematron;
