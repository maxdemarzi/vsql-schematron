INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539700_210513_ch4
--echo #
CREATE DATABASE `db_539700_210513_ch4`;
USE `db_539700_210513_ch4`;

CREATE TABLE `hubo` (
  `kiho` INT,
  `name` VARCHAR(64),
  `gongyak` VARCHAR(64),
  PRIMARY KEY (`kiho`)
) CHARACTER SET latin1;

CREATE TABLE `tupyo` (
  `kiho` INT,
  `age` INT
) CHARACTER SET latin1;

CREATE TABLE `tupyo2` (
  `kiho1` INT,
  `kiho2` INT,
  `kiho3` INT,
  `age` INT
) CHARACTER SET latin1;

CREATE TABLE `examtable4` (
  `name` VARCHAR(64),
  `id` INT,
  `kor` INT,
  `eng` INT,
  `mat` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539700_210513_ch4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539700_210513_ch4') AS relationships;
DROP DATABASE `db_539700_210513_ch4`;
UNINSTALL EXTENSION vsql_schematron;
