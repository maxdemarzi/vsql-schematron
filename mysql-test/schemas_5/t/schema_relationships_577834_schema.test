INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577834_schema
--echo #
CREATE DATABASE `db_577834_schema`;
USE `db_577834_schema`;

CREATE TABLE `uniparc` (
  `uniparc_id` VARCHAR(255),
  `sequence` VARCHAR(255),
  `sequence_length` INT,
  `sequence_checksum` VARCHAR(255),
  PRIMARY KEY (`uniparc_id`)
) CHARACTER SET latin1;

CREATE TABLE `domain` (
  `uniparc_id` VARCHAR(255),
  `database` VARCHAR(255),
  `database_id` VARCHAR(255),
  `interpro_name` VARCHAR(255),
  `interpro_id` VARCHAR(255),
  `domain_start` INT,
  `domain_end` INT
) CHARACTER SET latin1;

CREATE TABLE `xref` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `db_type` VARCHAR(255),
  `db_id` VARCHAR(255),
  `version_i` VARCHAR(255),
  `active` VARCHAR(255),
  `version` VARCHAR(255),
  `created` VARCHAR(255),
  `last` VARCHAR(255),
  PRIMARY KEY (`uniparc_id`, `xref_id`)
) CHARACTER SET latin1;

CREATE TABLE `component` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `gene_name` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ncbi_gi` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ncbi_taxonomy_id` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `pdb_chain` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `protein_name` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `proteome_id` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `uniprot_kb_accession` (
  `uniparc_id` VARCHAR(255),
  `xref_id` INT,
  `property` VARCHAR(255),
  `value` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577834_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577834_schema') AS relationships;
DROP DATABASE `db_577834_schema`;
UNINSTALL EXTENSION vsql_schematron;
