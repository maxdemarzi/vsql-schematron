INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 506252_db
--echo #
CREATE DATABASE `db_506252_db`;
USE `db_506252_db`;

CREATE TABLE `detail_servis` (
  `tglServisTerakhir` DATETIME,
  `tglServisSelanjutnya` DATETIME,
  `noRangka` VARCHAR(64),
  `kilometer` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `mobil` (
  `noRangka` VARCHAR(64),
  `model` VARCHAR(64),
  `noMesin` VARCHAR(64),
  `noPolisi` VARCHAR(64),
  `deliveryDate` DATETIME,
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `pelanggan` (
  `id` INT,
  `nama` VARCHAR(64),
  `alamat` VARCHAR(64),
  `telepon` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `riwayat` (
  `idRiwayatBooking` INT,
  `noRangka` VARCHAR(64),
  `tanggalServis` DATETIME,
  `kilometer` INT,
  `namaBooking` VARCHAR(64),
  `noTeleponBooking` VARCHAR(64),
  `jamBooking` VARCHAR(64),
  `status` INT,
  `done` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_506252_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_506252_db') AS relationships;
DROP DATABASE `db_506252_db`;
UNINSTALL EXTENSION vsql_schematron;
