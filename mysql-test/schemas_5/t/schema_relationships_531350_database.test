INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531350_database
--echo #
CREATE DATABASE `db_531350_database`;
USE `db_531350_database`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `importance` VARCHAR(50),
  `description` TEXT,
  `completed` BOOLEAN,
  `userid` INT,
  `created_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531350_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531350_database') AS relationships;
DROP DATABASE `db_531350_database`;
UNINSTALL EXTENSION vsql_schematron;
