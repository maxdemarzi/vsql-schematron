INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582178_b
--echo #
CREATE DATABASE `db_582178_b`;
USE `db_582178_b`;
CREATE TABLE `tab_new` (
  `id` DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tab_new_detail` (
  `id` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582178_b') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582178_b') AS relationships;
DROP DATABASE `db_582178_b`;
UNINSTALL EXTENSION vsql_schematron;
