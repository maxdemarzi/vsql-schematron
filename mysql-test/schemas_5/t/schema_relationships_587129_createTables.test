INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 587129_createTables
--echo #
CREATE DATABASE `db_587129_createTables`;
USE `db_587129_createTables`;

CREATE TABLE `Artist` (
  `artistID` INT,
  `name` VARCHAR(64),
  `thumbnail` VARCHAR(64),
  PRIMARY KEY (`artistID`)
) CHARACTER SET latin1;

CREATE TABLE `Album` (
  `albumID` INT,
  `name` VARCHAR(64),
  `releaseYear` VARCHAR(64),
  `thumbnail` VARCHAR(64),
  `artistID` INT,
  PRIMARY KEY (`albumID`)
) CHARACTER SET latin1;

CREATE TABLE `Track` (
  `trackID` INT,
  `title` VARCHAR(64),
  `length` VARCHAR(64),
  `youtubeAddr` VARCHAR(64),
  `artistID` INT,
  `albumID` INT,
  PRIMARY KEY (`trackID`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `userID` INT,
  `username` VARCHAR(64),
  `lName` VARCHAR(64),
  `fName` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `Role` (
  `roleID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`roleID`)
) CHARACTER SET latin1;

CREATE TABLE `UserRole` (
  `roleID` INT,
  `userID` INT,
  PRIMARY KEY (`roleID`, `userID`)
) CHARACTER SET latin1;

CREATE TABLE `UserPlaylist` (
  `playlistID` INT,
  `userID` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`playlistID`)
) CHARACTER SET latin1;

CREATE TABLE `Playlist` (
  `ID` INT,
  `playlistID` INT,
  `trackID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_587129_createTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_587129_createTables') AS relationships;
DROP DATABASE `db_587129_createTables`;
UNINSTALL EXTENSION vsql_schematron;
