INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 572343_script_bancoDizimo
--echo #
CREATE DATABASE `db_572343_script_bancoDizimo`;
USE `db_572343_script_bancoDizimo`;
CREATE TABLE `LANCAMENTO` (
  `ID` INT NOT NULL,
  `CDFICHA` INT,
  `NOMEDIZ` VARCHAR(50),
  `VLRDOACAO` DECIMAL(10,2),
  `REFERENCIA` VARCHAR(50),
  `DTLANCAMENTO` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TBL_PLANDADOS` (
  `CDFICHA` INT NOT NULL,
  `NOME` VARCHAR(50),
  `NASCDIZIMISTA` TIMESTAMP NULL,
  `COMUNIDADE` VARCHAR(50),
  `END_RUA` VARCHAR(50),
  `END_NR` INT,
  `END_COMPLEM` VARCHAR(50),
  `END_BAIRRO` VARCHAR(50),
  `END_CEP` VARCHAR(50),
  `END_CIDADE` VARCHAR(50),
  `END_UF` VARCHAR(50),
  `FONE_FIXO` VARCHAR(50),
  `FONE_MOVEL` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `GENERO` VARCHAR(50),
  `ESTADO_CIVIL` VARCHAR(50),
  `NOME_CONJ` VARCHAR(50),
  `NASCONJUGE` TIMESTAMP NULL,
  `DATACASAMENTO` TIMESTAMP NULL,
  `DATACADASTRO` TIMESTAMP NULL,
  `SITUACAO` VARCHAR(50),
  PRIMARY KEY (`CDFICHA`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_572343_script_bancoDizimo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_572343_script_bancoDizimo') AS relationships;
DROP DATABASE `db_572343_script_bancoDizimo`;
UNINSTALL EXTENSION vsql_schematron;
