INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 534244_forum-example
--echo #
CREATE DATABASE `db_534244_forum_example`;
USE `db_534244_forum_example`;

CREATE TABLE `category` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `post_id` INT,
  `user_id` INT,
  `parent_id` INT,
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `published` INT,
  `published_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `uuid` VARCHAR(64),
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `favorite_post` (
  `id` INT,
  `user_id` INT,
  `post_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `favorite_comment` (
  `id` INT,
  `user_id` INT,
  `comment_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `follow_tag` (
  `id` INT,
  `user_id` INT,
  `tag_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `follow_user` (
  `id` INT,
  `user_id` INT,
  `following_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_access_tokens` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `name` VARCHAR(64),
  `scopes` VARCHAR(64),
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_auth_codes` (
  `id` VARCHAR(64),
  `user_id` INT,
  `client_id` INT,
  `scopes` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_clients` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `secret` VARCHAR(64),
  `provider` VARCHAR(64),
  `redirect` VARCHAR(64),
  `personal_access_client` INT,
  `password_client` INT,
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `oauth_personal_access_clients` (
  `id` INT,
  `client_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_refresh_tokens` (
  `id` VARCHAR(64),
  `access_token_id` VARCHAR(64),
  `revoked` INT,
  `expires_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permission` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `id` INT,
  `category_id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `excerpt` VARCHAR(64),
  `image` VARCHAR(64),
  `content` VARCHAR(64),
  `pinned` INT,
  `published` INT,
  `published_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `post_tag` (
  `id` INT,
  `post_id` INT,
  `tag_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `role_permission` (
  `id` INT,
  `role_id` INT,
  `permission_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `role_id` INT,
  `facebook_id` VARCHAR(64),
  `google_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `auth_token` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `address` VARCHAR(64),
  `gender` VARCHAR(64),
  `avatar` VARCHAR(64),
  `biography` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_534244_forum_example') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_534244_forum_example') AS relationships;
DROP DATABASE `db_534244_forum_example`;
UNINSTALL EXTENSION vsql_schematron;
