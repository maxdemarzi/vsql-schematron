INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 578998_inventory_ddl
--echo #
CREATE DATABASE `db_578998_inventory_ddl`;
USE `db_578998_inventory_ddl`;

CREATE TABLE `customers` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `id` INT,
  `customer_id` INT,
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `weight` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_number` INT,
  `order_date` DATETIME,
  `purchaser` INT,
  `quantity` INT,
  `product_id` INT,
  PRIMARY KEY (`order_number`)
) CHARACTER SET latin1;

CREATE TABLE `products_on_hand` (
  `product_id` INT,
  `quantity` INT,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_578998_inventory_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_578998_inventory_ddl') AS relationships;
DROP DATABASE `db_578998_inventory_ddl`;
UNINSTALL EXTENSION vsql_schematron;
