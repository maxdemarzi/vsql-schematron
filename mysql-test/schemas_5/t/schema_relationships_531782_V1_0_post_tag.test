INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 531782_V1_0_post_tag
--echo #
CREATE DATABASE `db_531782_V1_0_post_tag`;
USE `db_531782_V1_0_post_tag`;

CREATE TABLE `post` (
  `id` INT,
  `title` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post_tag` (
  `post_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_531782_V1_0_post_tag') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_531782_V1_0_post_tag') AS relationships;
DROP DATABASE `db_531782_V1_0_post_tag`;
UNINSTALL EXTENSION vsql_schematron;
