INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 596903_init
--echo #
CREATE DATABASE `db_596903_init`;
USE `db_596903_init`;

CREATE TABLE `user` (
  `global_user_no` INT,
  `user_auth_token` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `user_skin_color` VARCHAR(64),
  `user_skin_role` VARCHAR(64),
  `user_skin_cloth` VARCHAR(64),
  `user_join_dt` DATETIME,
  PRIMARY KEY (`global_user_no`)
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `global_room_no` INT,
  `room_name` VARCHAR(64),
  `room_code` VARCHAR(64),
  `room_present` INT,
  `room_max` INT,
  `room_create_dt` DATETIME,
  `room_agora_uid` VARCHAR(64),
  `room_agora_token` VARCHAR(64),
  PRIMARY KEY (`global_room_no`)
) CHARACTER SET latin1;

CREATE TABLE `joining` (
  `joining_user_no` INT,
  `joining_room_no` INT,
  `joining_recent_dt` DATETIME,
  PRIMARY KEY (`joining_room_no`, `joining_user_no`)
) CHARACTER SET latin1;

CREATE TABLE `timer` (
  `global_timer_no` INT,
  `timer_subject` VARCHAR(64),
  `timer_acc_time` INT,
  `timer_user_no` INT,
  `timer_room_no` INT,
  PRIMARY KEY (`global_timer_no`)
) CHARACTER SET latin1;

CREATE TABLE `board` (
  `global_board_no` INT,
  `board_user_no` INT,
  `board_room_no` INT,
  `board_title` VARCHAR(64),
  `board_content` VARCHAR(64),
  `board_write_dt` DATETIME,
  `board_edit_dt` DATETIME,
  `board_deadline` DATETIME,
  `board_notice` BOOL,
  `board_assignment` BOOL,
  `board_visible` BOOL,
  PRIMARY KEY (`global_board_no`)
) CHARACTER SET latin1;

CREATE TABLE `logs` (
  `logs_time` DATETIME,
  `logs_status` VARCHAR(64),
  `logs_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_596903_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_596903_init') AS relationships;
DROP DATABASE `db_596903_init`;
UNINSTALL EXTENSION vsql_schematron;
