INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 544451_V001__init-schema
--echo #
CREATE DATABASE `db_544451_V001_init_schema`;
USE `db_544451_V001_init_schema`;

CREATE TABLE `tbl_sport` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `venue` VARCHAR(64),
  `start_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_team` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `sport_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_player` (
  `id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `dob` DATETIME,
  `home_city` VARCHAR(64),
  `home_country` VARCHAR(64),
  `team_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_sponsor` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `mission_statement` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_prize` (
  `id` VARCHAR(64),
  `rank` INT,
  `title` VARCHAR(64),
  `prize_value` DECIMAL(10,2),
  `value_currency` VARCHAR(64),
  `sponsor_id` VARCHAR(64),
  `sport_id` VARCHAR(64),
  `winner_id` VARCHAR(64),
  `date_awarded` DATETIME,
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_544451_V001_init_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_544451_V001_init_schema') AS relationships;
DROP DATABASE `db_544451_V001_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
