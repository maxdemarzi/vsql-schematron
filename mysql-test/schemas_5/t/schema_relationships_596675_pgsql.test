INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 596675_pgsql
--echo #
CREATE DATABASE `db_596675_pgsql`;
USE `db_596675_pgsql`;

CREATE TABLE `books` (
  `id` INT,
  `book_name` VARCHAR(64),
  `author` VARCHAR(64),
  `seller` VARCHAR(64),
  `available` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `availability_zone` (
  `id` INT,
  `book_name` VARCHAR(64),
  `address` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_596675_pgsql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_596675_pgsql') AS relationships;
DROP DATABASE `db_596675_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
