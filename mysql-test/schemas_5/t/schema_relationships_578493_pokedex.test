INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 578493_pokedex
--echo #
CREATE DATABASE `db_578493_pokedex`;
USE `db_578493_pokedex`;

CREATE TABLE `pokedex` (
  `pokemon_id` INT,
  `id` INT,
  `num` INT,
  `name` VARCHAR(64),
  `img` VARCHAR(64),
  `height` VARCHAR(64),
  `weight` VARCHAR(64),
  `candy` VARCHAR(64),
  `candy_count` INT,
  `egg` VARCHAR(64),
  `spawn_chance` INT,
  `avg_spawns` INT,
  `spawn_time` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pokemon_type` (
  `type_id` INT,
  `id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pokemon_multipliers` (
  `type_id` INT,
  `id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pokemon_weaknesses` (
  `type_id` INT,
  `id` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pokemon_next_evolution` (
  `type_id` INT,
  `id` INT,
  `num` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_578493_pokedex') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_578493_pokedex') AS relationships;
DROP DATABASE `db_578493_pokedex`;
UNINSTALL EXTENSION vsql_schematron;
