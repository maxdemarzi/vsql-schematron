INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539880_schema
--echo #
CREATE DATABASE `db_539880_schema`;
USE `db_539880_schema`;

CREATE TABLE `posts` (
  `id` INT,
  `id_user` INT,
  `content` VARCHAR(255),
  `id_parent` INT,
  `at` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `id` INT,
  `token` VARCHAR(255),
  `id_user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `codes` (
  `code` VARCHAR(255),
  `generated_at` VARCHAR(255),
  `valid` INT,
  `id_user` INT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539880_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539880_schema') AS relationships;
DROP DATABASE `db_539880_schema`;
UNINSTALL EXTENSION vsql_schematron;
