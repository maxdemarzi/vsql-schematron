INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546390_simple_twitter_ruby
--echo #
CREATE DATABASE `db_546390_simple_twitter_ruby`;
USE `db_546390_simple_twitter_ruby`;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `user_id` INT,
  `post_id` INT,
  `text` VARCHAR(50),
  `attachment_path` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments_hashtags` (
  `id` INT NOT NULL,
  `comment_id` INT,
  `hashtag_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hashtags` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `text` VARCHAR(50),
  `attachment_path` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts_hashtags` (
  `id` INT NOT NULL,
  `post_id` INT,
  `hashtag_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546390_simple_twitter_ruby') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546390_simple_twitter_ruby') AS relationships;
DROP DATABASE `db_546390_simple_twitter_ruby`;
UNINSTALL EXTENSION vsql_schematron;
