INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 505241_the_nerd_herd_db
--echo #
CREATE DATABASE `db_505241_the_nerd_herd_db`;
USE `db_505241_the_nerd_herd_db`;

CREATE TABLE `locations` (
  `id` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `credentials` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `nickname` VARCHAR(64),
  `gender` VARCHAR(64),
  `age` INT,
  `location_id` INT,
  `credential_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chats` (
  `id` INT,
  `title` VARCHAR(64),
  `start_date` DATETIME,
  `is_active` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `content` VARCHAR(64),
  `sent_on` DATETIME,
  `chat_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_chats` (
  `user_id` INT,
  `chat_id` INT,
  PRIMARY KEY (`user_id`, `chat_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_505241_the_nerd_herd_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_505241_the_nerd_herd_db') AS relationships;
DROP DATABASE `db_505241_the_nerd_herd_db`;
UNINSTALL EXTENSION vsql_schematron;
