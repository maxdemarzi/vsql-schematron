INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 572419_V1_0_0_INITIAL_MODEL
--echo #
CREATE DATABASE `db_572419_V1_0_0_INITIAL_MODEL`;
USE `db_572419_V1_0_0_INITIAL_MODEL`;

CREATE TABLE `PARENTS` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHILDREN` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  `PARENT_ID` DECIMAL(10,2),
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_572419_V1_0_0_INITIAL_MODEL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_572419_V1_0_0_INITIAL_MODEL') AS relationships;
DROP DATABASE `db_572419_V1_0_0_INITIAL_MODEL`;
UNINSTALL EXTENSION vsql_schematron;
