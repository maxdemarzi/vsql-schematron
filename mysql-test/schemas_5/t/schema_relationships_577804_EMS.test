INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577804_EMS
--echo #
CREATE DATABASE `db_577804_EMS`;
USE `db_577804_EMS`;

CREATE TABLE `customers` (
  `id` INT,
  `full_name` VARCHAR(64),
  `mobile_number` INT,
  `pin_code` INT,
  `address` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_complaints` (
  `id` INT,
  `customer_id` INT,
  `problem` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `role_name` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `role_id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577804_EMS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577804_EMS') AS relationships;
DROP DATABASE `db_577804_EMS`;
UNINSTALL EXTENSION vsql_schematron;
