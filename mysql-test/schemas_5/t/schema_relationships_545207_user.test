INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 545207_user
--echo #
CREATE DATABASE `db_545207_user`;
USE `db_545207_user`;

CREATE TABLE `USERINFO` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `uid` INT,
  `GID` INT,
  `FULL_NAME` VARCHAR(64),
  `HOME_DIR` VARCHAR(64),
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `NETGROUP_WHITELIST` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSONALITY_ROOTUSER` (
  `PERSONALITY_ID` INT,
  `USER_ID` INT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`PERSONALITY_ID`, `USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSONALITY_ROOTNETGROUP` (
  `PERSONALITY_ID` INT,
  `NETGROUP_ID` INT,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`PERSONALITY_ID`, `NETGROUP_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_545207_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_545207_user') AS relationships;
DROP DATABASE `db_545207_user`;
UNINSTALL EXTENSION vsql_schematron;
