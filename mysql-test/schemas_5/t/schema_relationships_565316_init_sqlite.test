INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 565316_init_sqlite
--echo #
CREATE DATABASE `db_565316_init_sqlite`;
USE `db_565316_init_sqlite`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `createdAt` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currencies` (
  `id` INT NOT NULL,
  `userId` INT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `currencyValues` (
  `id` INT NOT NULL,
  `snapshotId` INT,
  `currencyId` INT,
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `assets` (
  `id` INT NOT NULL,
  `snapshotId` INT,
  `name` TEXT,
  `amount` DOUBLE,
  `currencyId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_565316_init_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_565316_init_sqlite') AS relationships;
DROP DATABASE `db_565316_init_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
