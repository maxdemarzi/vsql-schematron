INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576692_property_listing
--echo #
CREATE DATABASE `db_576692_property_listing`;
USE `db_576692_property_listing`;

CREATE TABLE `addresses` (
  `id` INT,
  `line_1` VARCHAR(64),
  `line_2` VARCHAR(64),
  `landmark` VARCHAR(64),
  `pincode` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `admins` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hibernate_sequence` (
  `next_val` INT
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `imageurl` VARCHAR(64),
  `size` INT,
  `property_id` INT
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `id` INT,
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `properties` (
  `id` INT,
  `name` VARCHAR(64),
  `price` DECIMAL(10,2),
  `p_den` VARCHAR(64),
  `description` VARCHAR(64),
  `avg_rating` INT,
  `address_id` INT,
  `location_id` INT,
  `category_id` INT,
  `list_for` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `website_review` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_properties` (
  `id` INT,
  `user_id` INT,
  `property_id` INT,
  `list_in` VARCHAR(64),
  `rating` INT,
  `review` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576692_property_listing') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576692_property_listing') AS relationships;
DROP DATABASE `db_576692_property_listing`;
UNINSTALL EXTENSION vsql_schematron;
