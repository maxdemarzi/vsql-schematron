INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543016_rosliny-create-db
--echo #
CREATE DATABASE `db_543016_rosliny_create_db`;
USE `db_543016_rosliny_create_db`;

CREATE TABLE `kategorie` (
  `Id` INT,
  `Nazwa` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `kraje` (
  `Id` INT,
  `Kraj` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `kraje_roslin` (
  `Id` INT,
  `Id_kraju` INT,
  `Id_rosliny` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543016_rosliny_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543016_rosliny_create_db') AS relationships;
DROP DATABASE `db_543016_rosliny_create_db`;
UNINSTALL EXTENSION vsql_schematron;
