INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 587698_db
--echo #
CREATE DATABASE `db_587698_db`;
USE `db_587698_db`;
CREATE TABLE `Proprietario` (
  `codProprietario` INT NOT NULL,
  `Nome` VARCHAR(50),
  PRIMARY KEY (`codProprietario`)
) CHARACTER SET latin1;
CREATE TABLE `Veiculo` (
  `Placa` VARCHAR(50) NOT NULL,
  `codProprietario` INT,
  `Modelo` VARCHAR(50),
  `Valor` DECIMAL(10,2),
  PRIMARY KEY (`Placa`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_587698_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_587698_db') AS relationships;
DROP DATABASE `db_587698_db`;
UNINSTALL EXTENSION vsql_schematron;
