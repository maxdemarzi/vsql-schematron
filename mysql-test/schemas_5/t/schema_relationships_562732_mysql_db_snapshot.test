INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 562732_mysql_db_snapshot
--echo #
CREATE DATABASE `db_562732_mysql_db_snapshot`;
USE `db_562732_mysql_db_snapshot`;

CREATE TABLE `blobs` (
  `id` INT,
  `blobstore_id` VARCHAR(64),
  `sha1` VARCHAR(64),
  `created_at` DATETIME,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cloud_configs` (
  `id` INT,
  `properties` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cpi_configs` (
  `id` INT,
  `properties` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `deployment_problems` (
  `id` INT,
  `deployment_id` INT,
  `state` VARCHAR(64),
  `resource_id` INT,
  `type` VARCHAR(64),
  `data_json` VARCHAR(64),
  `created_at` DATETIME,
  `last_seen_at` DATETIME,
  `counter` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dns_schema` (
  `filename` VARCHAR(64),
  PRIMARY KEY (`filename`)
) CHARACTER SET latin1;

CREATE TABLE `errand_runs` (
  `id` INT,
  `deployment_id` INT,
  `errand_name` VARCHAR(64),
  `successful_state_hash` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `local_dns_blobs` (
  `id` INT,
  `blob_id` INT,
  `version` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `runtime_configs` (
  `id` INT,
  `properties` VARCHAR(64),
  `created_at` DATETIME,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `schema_migrations` (
  `filename` VARCHAR(64),
  PRIMARY KEY (`filename`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_562732_mysql_db_snapshot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_562732_mysql_db_snapshot') AS relationships;
DROP DATABASE `db_562732_mysql_db_snapshot`;
UNINSTALL EXTENSION vsql_schematron;
