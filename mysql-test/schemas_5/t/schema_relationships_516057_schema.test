INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 516057_schema
--echo #
CREATE DATABASE `db_516057_schema`;
USE `db_516057_schema`;

CREATE TABLE `users` (
  `user_id` INT,
  `login` VARCHAR(255),
  `password` VARCHAR(255),
  `role_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `role_id` INT,
  `role` VARCHAR(255),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `client_accounts` (
  `client_account_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `telephone` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`client_account_id`)
) CHARACTER SET latin1;

CREATE TABLE `manager_accounts` (
  `manager_account_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `telephone` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`manager_account_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `order_id` INT,
  `car_id` INT,
  `client_account_id` INT,
  `description` VARCHAR(255),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `car_id` INT,
  `vin` VARCHAR(255),
  `brand` VARCHAR(255),
  `model` VARCHAR(255),
  `production_year` VARCHAR(255),
  `registration_number` VARCHAR(255),
  `description` VARCHAR(255),
  `client_account_id` INT,
  PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_516057_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_516057_schema') AS relationships;
DROP DATABASE `db_516057_schema`;
UNINSTALL EXTENSION vsql_schematron;
