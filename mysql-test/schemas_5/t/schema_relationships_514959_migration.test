INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 514959_migration
--echo #
CREATE DATABASE `db_514959_migration`;
USE `db_514959_migration`;

CREATE TABLE `Post` (
  `id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Contact` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `message` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `userName` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Ticket` (
  `id` INT,
  `number` VARCHAR(64),
  `title` VARCHAR(64),
  `userId` INT,
  `cmdbId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Cmdb` (
  `id` INT,
  `number` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_514959_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_514959_migration') AS relationships;
DROP DATABASE `db_514959_migration`;
UNINSTALL EXTENSION vsql_schematron;
