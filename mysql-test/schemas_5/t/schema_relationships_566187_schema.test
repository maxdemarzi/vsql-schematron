INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 566187_schema
--echo #
CREATE DATABASE `db_566187_schema`;
USE `db_566187_schema`;

CREATE TABLE `bangumix_user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `bangumix_anime` (
  `anime_name` VARCHAR(64),
  `director_name` VARCHAR(64),
  `synopsis` VARCHAR(64),
  PRIMARY KEY (`anime_name`)
) CHARACTER SET latin1;

CREATE TABLE `bangumix_anime_comment` (
  `comment_id` INT,
  `anime_name` VARCHAR(64),
  `username` VARCHAR(64),
  `comment_content` VARCHAR(64),
  `comment_timestamp` DATETIME,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

CREATE TABLE `bangumix_anime_point` (
  `anime_name` VARCHAR(64),
  `username` VARCHAR(64),
  `point` INT,
  PRIMARY KEY (`anime_name`, `username`)
) CHARACTER SET latin1;

CREATE TABLE `bangumix_anime_tag` (
  `anime_name` VARCHAR(64),
  `username` VARCHAR(64),
  `tag_content` VARCHAR(64),
  PRIMARY KEY (`anime_name`, `username`, `tag_content`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_566187_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_566187_schema') AS relationships;
DROP DATABASE `db_566187_schema`;
UNINSTALL EXTENSION vsql_schematron;
