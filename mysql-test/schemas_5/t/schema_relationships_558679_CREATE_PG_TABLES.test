INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558679_CREATE_PG_TABLES
--echo #
CREATE DATABASE `db_558679_CREATE_PG_TABLES`;
USE `db_558679_CREATE_PG_TABLES`;

CREATE TABLE `test_interview_templates` (
  `id` INT,
  `title` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `test_interview_template_questions` (
  `id` INT,
  `tag_id` INT,
  `questions_count` INT,
  `template_id` INT
) CHARACTER SET latin1;

CREATE TABLE `unanswered_questions` (
  `id` INT,
  `user_identifier` INT,
  `question_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558679_CREATE_PG_TABLES') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558679_CREATE_PG_TABLES') AS relationships;
DROP DATABASE `db_558679_CREATE_PG_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
