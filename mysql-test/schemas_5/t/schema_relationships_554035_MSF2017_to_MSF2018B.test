INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 554035_MSF2017_to_MSF2018B
--echo #
CREATE DATABASE `db_554035_MSF2017_to_MSF2018B`;
USE `db_554035_MSF2017_to_MSF2018B`;

CREATE TABLE `dummy_vlan_ifs_info` (
  `node_id` VARCHAR(64),
  `vlan_if_id` VARCHAR(64),
  `vlan_id` VARCHAR(64),
  `irb_instance_id` VARCHAR(64),
  PRIMARY KEY (`node_id`, `vlan_if_id`)
) CHARACTER SET latin1;

CREATE TABLE `irb_instance_info` (
  `node_id` VARCHAR(64),
  `vlan_id` VARCHAR(64),
  `irb_instance_id` VARCHAR(64),
  `irb_vni` VARCHAR(64),
  `irb_ipv4_address` VARCHAR(64),
  `irb_ipv4_prefix` INT,
  `virtual_gateway_address` VARCHAR(64),
  PRIMARY KEY (`node_id`, `vlan_id`, `irb_instance_id`)
) CHARACTER SET latin1;

CREATE TABLE `acl_info` (
  `node_id` VARCHAR(64),
  `acl_id` VARCHAR(64),
  `physical_if_id` VARCHAR(64),
  `lag_if_id` VARCHAR(64),
  `breakout_if_id` VARCHAR(64),
  `vlan_if_id` VARCHAR(64),
  PRIMARY KEY (`node_id`, `acl_id`)
) CHARACTER SET latin1;

CREATE TABLE `acl_detail_info` (
  `node_id` VARCHAR(64),
  `acl_id` VARCHAR(64),
  `term_name` VARCHAR(64),
  `action` VARCHAR(64),
  `direction` VARCHAR(64),
  `source_mac_address` VARCHAR(64),
  `destination_mac_address` VARCHAR(64),
  `source_ip_address` VARCHAR(64),
  `destination_ip_address` VARCHAR(64),
  `source_port` INT,
  `destination_port` INT,
  `protocol` VARCHAR(64),
  `acl_priority` INT,
  PRIMARY KEY (`node_id`, `acl_id`, `term_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_554035_MSF2017_to_MSF2018B') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_554035_MSF2017_to_MSF2018B') AS relationships;
DROP DATABASE `db_554035_MSF2017_to_MSF2018B`;
UNINSTALL EXTENSION vsql_schematron;
