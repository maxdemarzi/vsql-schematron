INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 533298_schema
--echo #
CREATE DATABASE `db_533298_schema`;
USE `db_533298_schema`;

CREATE TABLE `album_user` (
  `userid` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `avatar` VARCHAR(64),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

CREATE TABLE `album` (
  `albumid` INT,
  `userid` INT,
  `albumname` VARCHAR(64),
  PRIMARY KEY (`albumid`)
) CHARACTER SET latin1;

CREATE TABLE `ele` (
  `eleid` INT,
  `source` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`eleid`)
) CHARACTER SET latin1;

CREATE TABLE `relation` (
  `albumid` INT,
  `eleid` INT
) CHARACTER SET latin1;

CREATE TABLE `user_relation` (
  `userid` INT,
  `friendid` INT
) CHARACTER SET latin1;

CREATE TABLE `like_relation` (
  `userid` INT,
  `eleid` INT
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `commentid` INT,
  `eleid` INT,
  `userid` INT,
  `tarid` INT,
  `comments` VARCHAR(64),
  PRIMARY KEY (`commentid`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `messageid` INT,
  `userid` INT,
  `tarid` INT,
  `flag` BOOL,
  `type` INT,
  `info` INT,
  PRIMARY KEY (`messageid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_533298_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_533298_schema') AS relationships;
DROP DATABASE `db_533298_schema`;
UNINSTALL EXTENSION vsql_schematron;
