CREATE TABLE `curso` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `data_fundacao` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `unidade_curso` (
  `curso_id` INT,
  `unidade_id` INT
) CHARACTER SET latin1;
--disable_query_log
