INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 573247_agent
--echo #
CREATE DATABASE `db_573247_agent`;
USE `db_573247_agent`;

CREATE TABLE `agent_products` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `user_id` INT,
  `product_id` INT,
  `quantity` INT,
  `price_per_item` DECIMAL(10,2),
  `valid_from` DATETIME,
  `is_valid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `campaign_stats` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `campaign_id` INT,
  `post_link` VARCHAR(255),
  `statistics_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `influencer_stats` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `campaign_stat_id` INT,
  `influencer_username` VARCHAR(255),
  `statistics_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `interest_stats` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `campaign_stat_id` INT,
  `interest` VARCHAR(255),
  `statistics_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `product_id` INT,
  `quantity` INT,
  `order_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `timestamp` DATETIME,
  `full_price` DECIMAL(10,2),
  `user_id` INT,
  `agent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `name` VARCHAR(255),
  `picture_path` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_privileges` (
  `role_id` INT,
  `privilege_id` INT,
  PRIMARY KEY (`role_id`, `privilege_id`)
) CHARACTER SET latin1;

CREATE TABLE `statistics` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `num_of_likes` INT,
  `num_of_dislikes` INT,
  `num_of_visits` INT,
  `num_of_comments` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_573247_agent') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_573247_agent') AS relationships;
DROP DATABASE `db_573247_agent`;
UNINSTALL EXTENSION vsql_schematron;
