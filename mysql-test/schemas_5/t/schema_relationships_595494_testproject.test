INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 595494_testproject
--echo #
CREATE DATABASE `db_595494_testproject`;
USE `db_595494_testproject`;
CREATE TABLE `contact` (
  `id` INT,
  `nombre` VARCHAR(50),
  `type_id` INT,
  `phone` INT,
  `dob` DATETIME,
  `description` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `type` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_595494_testproject') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_595494_testproject') AS relationships;
DROP DATABASE `db_595494_testproject`;
UNINSTALL EXTENSION vsql_schematron;
