INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 596110_dump
--echo #
CREATE DATABASE `db_596110_dump`;
USE `db_596110_dump`;

CREATE TABLE `post` (
  `postId` VARCHAR(255),
  `postUserId` VARCHAR(255),
  `body` VARCHAR(255),
  `title` VARCHAR(255),
  PRIMARY KEY (`postId`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `userId` VARCHAR(255),
  `email` VARCHAR(255),
  `name` VARCHAR(255),
  `phone` VARCHAR(255),
  `username` VARCHAR(255),
  `website` VARCHAR(255),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_596110_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_596110_dump') AS relationships;
DROP DATABASE `db_596110_dump`;
UNINSTALL EXTENSION vsql_schematron;
