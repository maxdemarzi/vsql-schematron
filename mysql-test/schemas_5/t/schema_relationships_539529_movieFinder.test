INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 539529_movieFinder
--echo #
CREATE DATABASE `db_539529_movieFinder`;
USE `db_539529_movieFinder`;

CREATE TABLE `movieList` (
  `userID` INT,
  `movieID` INT,
  `choiceID` INT,
  PRIMARY KEY (`userID`, `movieID`)
) CHARACTER SET latin1;

CREATE TABLE `movieLocations` (
  `movieID` INT,
  `serviceID` INT,
  PRIMARY KEY (`movieID`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `movieID` INT,
  `movieName` VARCHAR(64),
  `releaseYear` INT,
  `ranking` INT,
  PRIMARY KEY (`movieID`)
) CHARACTER SET latin1;

CREATE TABLE `streamingServices` (
  `serviceID` INT,
  `serviceName` VARCHAR(64),
  `website` VARCHAR(64),
  PRIMARY KEY (`serviceID`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `userID` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_539529_movieFinder') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_539529_movieFinder') AS relationships;
DROP DATABASE `db_539529_movieFinder`;
UNINSTALL EXTENSION vsql_schematron;
