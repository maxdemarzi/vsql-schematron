INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 581279_toDoList
--echo #
CREATE DATABASE `db_581279_toDoList`;
USE `db_581279_toDoList`;
CREATE TABLE `record_info` (
  `id` INT NOT NULL,
  `author` VARCHAR(50),
  `content` VARCHAR(50),
  `time` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_info` (
  `user_name` VARCHAR(50) NOT NULL,
  `user_pas` VARCHAR(50),
  PRIMARY KEY (`user_name`)
) CHARACTER SET latin1;
CREATE TABLE `blog_like` (
  `id` INT NOT NULL,
  `like_user` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`, `like_user`)
) CHARACTER SET latin1;
CREATE TABLE `blog_comment` (
  `comment_id` INT NOT NULL,
  `blog_id` INT,
  `comment_user` VARCHAR(50),
  `comment_content` VARCHAR(50),
  `time` VARCHAR(50),
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `blog_attention` (
  `give_User` VARCHAR(50) NOT NULL,
  `get_User` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`give_User`, `get_User`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_581279_toDoList') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_581279_toDoList') AS relationships;
DROP DATABASE `db_581279_toDoList`;
UNINSTALL EXTENSION vsql_schematron;
