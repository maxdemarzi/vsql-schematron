INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 504413_schema
--echo #
CREATE DATABASE `db_504413_schema`;
USE `db_504413_schema`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `agency` VARCHAR(50),
  `account_number` VARCHAR(50),
  `balance` DECIMAL(10,2),
  `account_limit` DECIMAL(10,2),
  `account_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `surname` VARCHAR(50),
  `sex` CHAR(50),
  `account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bankstatement` (
  `id` INT NOT NULL,
  `transaction_type` CHAR(50),
  `VALUE` DECIMAL(10,2),
  `balance` DECIMAL(10,2),
  `history` VARCHAR(50),
  `movement_date` DATE,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_504413_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_504413_schema') AS relationships;
DROP DATABASE `db_504413_schema`;
UNINSTALL EXTENSION vsql_schematron;
