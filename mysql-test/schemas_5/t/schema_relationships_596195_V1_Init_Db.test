INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 596195_V1__Init_Db
--echo #
CREATE DATABASE `db_596195_V1_Init_Db`;
USE `db_596195_V1_Init_Db`;

CREATE TABLE `internal_users` (
  `id` INT,
  `telegram_id` INT,
  `full_name` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `external_users` (
  `id` INT,
  `telegram_id` INT,
  `full_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `timetable` (
  `id` INT,
  `user_id` INT,
  `times` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_596195_V1_Init_Db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_596195_V1_Init_Db') AS relationships;
DROP DATABASE `db_596195_V1_Init_Db`;
UNINSTALL EXTENSION vsql_schematron;
