INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 558905_database
--echo #
CREATE DATABASE `db_558905_database`;
USE `db_558905_database`;

CREATE TABLE `CREDIT_TENDER` (
  `ID` VARCHAR(64),
  `PAYMENT_METHOD_STATUS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PAYMENT_CARD` (
  `CREDIT_CARD_EXPIRED` BOOL,
  `CARD_TOKEN` VARCHAR(64),
  `ISSUE_NUMBER` VARCHAR(64),
  `BILL_TO_CITY` VARCHAR(64),
  `ID` VARCHAR(64),
  `MASKED_NUMBER` VARCHAR(64),
  `NAME` VARCHAR(64),
  `COMPANY_NAME` VARCHAR(64),
  `CARD_HOLDER_NAME` VARCHAR(64),
  `NUMBER_LAST_DIGITS` VARCHAR(64),
  `PAYMENT_CARD_TYPE` VARCHAR(64),
  `DERIVED_CARD_TYPE_CODE` VARCHAR(64),
  `BILL_TO_FIRST_NAME` VARCHAR(64),
  `BILL_TO_STREET` VARCHAR(64),
  `EXPIRATION_YEAR` VARCHAR(64),
  `BILL_TO_STREET2` VARCHAR(64),
  `EXPIRATION_MONTH` VARCHAR(64),
  `BILL_TO_LAST_NAME` VARCHAR(64),
  `PAYMENT_METHOD_STATUS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PAYMENT_METHOD_TYPE` (
  `TYPE_DESCRIPTION` VARCHAR(64),
  `MEDIA_TYPE` VARCHAR(64),
  `MAX_PER_PERIOD_AMOUNT` INT,
  `TYPE_REQUIRED_IDENTIFICATION` VARCHAR(64),
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `USE_MINIMUM_AGE_YEAR` INT,
  `MAX_TRANSACTION_AMOUNT` INT,
  `MAX_PER_PERIOD_TRANSACTION_COUNT` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `COUPON` (
  `PRIMARY_SCAN_CODE_LABEL` VARCHAR(64),
  `IS_RETURN_COUPON` BOOL,
  `EXPIRATION_DATE` DATETIME,
  `ID` VARCHAR(64),
  `SECONDARY_SCAN_CODE_LABEL` VARCHAR(64),
  `SCAN_CODE` VARCHAR(64),
  `COUPON_CODE` VARCHAR(64),
  `RETURN_COUPON_REASON` VARCHAR(64),
  `DISCOUNT_AMOUNT` INT,
  `IS_VALID` BOOL,
  `COUPON_STATUS` VARCHAR(64),
  `DISCOUNT_PERCENTAGE` INT,
  `COUPON_COUNT` INT,
  `PAYMENT_METHOD_STATUS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PAYMENT_METHOD` (
  `PAYMENT_METHOD_STATUS` VARCHAR(64),
  `ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CREDIT_TENDER_ACCOUNT_JOIN` (
  `CREDIT_TENDER_ID` VARCHAR(64),
  `ACCOUNT_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CREDIT_TENDER_PAYMENT_METHOD_TYPE_JOIN` (
  `CREDIT_TENDER_ID` VARCHAR(64),
  `PAYMENT_METHOD_TYPE_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `PAYMENT_CARD_PAYMENT_METHOD_TYPE_JOIN` (
  `PAYMENT_CARD_ID` VARCHAR(64),
  `PAYMENT_METHOD_TYPE_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `COUPON_MANUFACTURER_JOIN` (
  `COUPON_ID` VARCHAR(64),
  `PARTY_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `COUPON_PAYMENT_METHOD_TYPE_JOIN` (
  `COUPON_ID` VARCHAR(64),
  `PAYMENT_METHOD_TYPE_ID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `PAYMENT_METHOD_PAYMENT_METHOD_TYPE_JOIN` (
  `PAYMENT_METHOD_ID` VARCHAR(64),
  `PAYMENT_METHOD_TYPE_ID` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_558905_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_558905_database') AS relationships;
DROP DATABASE `db_558905_database`;
UNINSTALL EXTENSION vsql_schematron;
