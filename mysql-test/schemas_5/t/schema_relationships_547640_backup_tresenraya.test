INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 547640_backup.tresenraya
--echo #
CREATE DATABASE `db_547640_backup_tresenraya`;
USE `db_547640_backup_tresenraya`;

CREATE TABLE `activaciones` (
  `aid` INT,
  `uid` INT,
  `clave` VARCHAR(64),
  `fecha_limite` DATETIME,
  `avisado` BOOL,
  PRIMARY KEY (`aid`)
) CHARACTER SET latin1;

CREATE TABLE `partidas` (
  `pid` VARCHAR(64),
  `desafiante` INT,
  `desafiado` INT,
  `aceptado` INT
) CHARACTER SET latin1;

CREATE TABLE `recordarme` (
  `id` VARCHAR(64),
  `token` VARCHAR(64),
  `salt` VARCHAR(64),
  `uid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usuarios` (
  `uid` INT,
  `nombre` VARCHAR(64),
  `contrasena` VARCHAR(64),
  `correo` VARCHAR(64),
  `activado` BOOL,
  `pais` VARCHAR(64),
  `fecha_registro` DATETIME,
  `info_partidas` VARCHAR(64),
  `fecha_conexion` DATETIME,
  `direccion_ip` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `usuarios_conectados` (
  `uid` INT,
  `nombre` VARCHAR(64),
  `pais` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_547640_backup_tresenraya') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_547640_backup_tresenraya') AS relationships;
DROP DATABASE `db_547640_backup_tresenraya`;
UNINSTALL EXTENSION vsql_schematron;
