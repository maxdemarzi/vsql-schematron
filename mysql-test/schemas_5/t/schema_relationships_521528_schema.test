INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521528_schema
--echo #
CREATE DATABASE `db_521528_schema`;
USE `db_521528_schema`;

CREATE TABLE `authassignment` (
  `itemname` VARCHAR(64),
  `userid` VARCHAR(64),
  `bizrule` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`itemname`, `userid`)
) CHARACTER SET latin1;

CREATE TABLE `authitem` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `bizrule` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `authitemchild` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64),
  PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521528_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521528_schema') AS relationships;
DROP DATABASE `db_521528_schema`;
UNINSTALL EXTENSION vsql_schematron;
