INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 509867_kartu
--echo #
CREATE DATABASE `db_509867_kartu`;
USE `db_509867_kartu`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT,
  PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64),
  PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `bahasaasing` (
  `bahasaasing_id` INT,
  `bahasaasing_nama` INT,
  `id_daftar` INT,
  PRIMARY KEY (`bahasaasing_id`)
) CHARACTER SET latin1;

CREATE TABLE `golongan` (
  `golongan_id` INT,
  `golongan_nama` VARCHAR(64),
  `golongan_jenis` VARCHAR(64),
  PRIMARY KEY (`golongan_id`)
) CHARACTER SET latin1;

CREATE TABLE `jurusan` (
  `jurusan_id` INT,
  `jurusan_nama` VARCHAR(64),
  `id_sekolah` INT,
  `jurusan_jurusan1` VARCHAR(64),
  `jurusan_jurusan2` VARCHAR(64),
  PRIMARY KEY (`jurusan_id`)
) CHARACTER SET latin1;

CREATE TABLE `migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `nilai` (
  `id` INT,
  `siswa_id` INT,
  `nilai` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pekerjaan` (
  `pekerjaan_id` INT,
  `pekerjaan_nama` VARCHAR(64),
  `id_jabatan` INT,
  PRIMARY KEY (`pekerjaan_id`)
) CHARACTER SET latin1;

CREATE TABLE `purchase_order` (
  `id` INT,
  `po_no` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `route` (
  `name` VARCHAR(64),
  `alias` VARCHAR(64),
  `type` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_509867_kartu') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_509867_kartu') AS relationships;
DROP DATABASE `db_509867_kartu`;
UNINSTALL EXTENSION vsql_schematron;
