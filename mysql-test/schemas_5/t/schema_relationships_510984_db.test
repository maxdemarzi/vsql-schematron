INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510984_db
--echo #
CREATE DATABASE `db_510984_db`;
USE `db_510984_db`;

CREATE TABLE `debian_package` (
  `id` INT,
  `debian_package_name` VARCHAR(64),
  `version` VARCHAR(64),
  `distribution` VARCHAR(64),
  `project_id` INT,
  `is_vulnerable` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `debian_package_cve` (
  `debian_package_id` INT,
  `cve_id` INT,
  PRIMARY KEY (`debian_package_id`, `cve_id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `project_name` VARCHAR(64),
  `operating_system` VARCHAR(64),
  `users_id` INT,
  `uploaded_file` VARCHAR(64),
  `status_cve_check` VARCHAR(64),
  `check_active` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `profile_image` VARCHAR(64),
  `company` VARCHAR(64),
  `is_admin` VARCHAR(64),
  `verified_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `last_login_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `yocto_package` (
  `id` INT,
  `yocto_package_name` VARCHAR(64),
  `version` VARCHAR(64),
  `project_id` INT,
  `is_vulnerable` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `yocto_package_cve` (
  `yocto_package_id` INT,
  `yocto_cve_id` INT,
  PRIMARY KEY (`yocto_package_id`, `yocto_cve_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510984_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510984_db') AS relationships;
DROP DATABASE `db_510984_db`;
UNINSTALL EXTENSION vsql_schematron;
