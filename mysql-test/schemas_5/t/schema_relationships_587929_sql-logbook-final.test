INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 587929_sql-logbook-final
--echo #
CREATE DATABASE `db_587929_sql_logbook_final`;
USE `db_587929_sql_logbook_final`;
CREATE TABLE `log` (
  `id` INT NOT NULL,
  `project_id` INT,
  `research_group_id` INT,
  `keyword_id` INT,
  `role` VARCHAR(50),
  `ref_rg_id` INT,
  `date_entered` TIMESTAMP NULL,
  `log_text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
  `id` INT NOT NULL,
  `log_id` INT,
  `date_entered` TIMESTAMP NULL,
  `comment` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `keyword` (
  `id` INT NOT NULL,
  `keyword` VARCHAR(50),
  `description` VARCHAR(50),
  `project_id` INT,
  `section` CHAR(50),
  `section_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_587929_sql_logbook_final') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_587929_sql_logbook_final') AS relationships;
DROP DATABASE `db_587929_sql_logbook_final`;
UNINSTALL EXTENSION vsql_schematron;
