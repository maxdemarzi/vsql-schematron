INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 540637_laravel
--echo #
CREATE DATABASE `db_540637_laravel`;
USE `db_540637_laravel`;

CREATE TABLE `lngs` (
  `id` INT,
  `u_id` INT,
  `org_name` VARCHAR(64),
  `short_name` VARCHAR(64),
  `icon` VARCHAR(64),
  `default` INT,
  `ordering` INT
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `l_id` INT,
  `u_id` INT,
  `sub_id` INT,
  `ordering` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `keyword` VARCHAR(64),
  `name` VARCHAR(64),
  `url_tag` VARCHAR(64),
  `picture` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `weight` INT
) CHARACTER SET latin1;

CREATE TABLE `social_accounts` (
  `id` INT,
  `user_id` INT,
  `provider` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `token` VARCHAR(64),
  `avatar` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `active` INT,
  `confirmation_code` VARCHAR(64),
  `confirmed` INT,
  `remember_token` VARCHAR(64),
  `email_verified_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_540637_laravel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_540637_laravel') AS relationships;
DROP DATABASE `db_540637_laravel`;
UNINSTALL EXTENSION vsql_schematron;
