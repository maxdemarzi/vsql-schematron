INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 578982_schema
--echo #
CREATE DATABASE `db_578982_schema`;
USE `db_578982_schema`;

CREATE TABLE `COMMENT` (
  `ID` INT,
  `DESCRIPTION` VARCHAR(64),
  `BOOK_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `GENRE` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `AUTHOR` (
  `ID` INT,
  `FULLNAME` VARCHAR(64),
  `ALIAS` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `AUTHOR_ID` INT,
  `GENRE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER` (
  `ID` INT,
  `LOGIN` VARCHAR(64),
  `NAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `ROLE_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ROLE` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_578982_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_578982_schema') AS relationships;
DROP DATABASE `db_578982_schema`;
UNINSTALL EXTENSION vsql_schematron;
