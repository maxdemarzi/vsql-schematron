INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 577678_dump
--echo #
CREATE DATABASE `db_577678_dump`;
USE `db_577678_dump`;

CREATE TABLE `like` (
  `likePostId` VARCHAR(255),
  `likeProfileId` VARCHAR(255),
  `likeDateTime` DATETIME,
  PRIMARY KEY (`likePostId`, `likeProfileId`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `postId` VARCHAR(255),
  `postProfileId` VARCHAR(255),
  `postContent` VARCHAR(255),
  `postDate` DATETIME,
  `postImageUrl` VARCHAR(255),
  PRIMARY KEY (`postId`)
) CHARACTER SET latin1;

CREATE TABLE `sighting` (
  `sightingId` VARCHAR(255),
  `sightingCity` VARCHAR(255),
  `sightingSummary` VARCHAR(255),
  `sightingLatitude` VARCHAR(255),
  `sightingLongitude` VARCHAR(255),
  `sightingDateTime` DATETIME,
  PRIMARY KEY (`sightingId`)
) CHARACTER SET latin1;

CREATE TABLE `transmission` (
  `transmissionId` VARCHAR(255),
  `transmissionProfileId` VARCHAR(255),
  `transmissionPostId` VARCHAR(255),
  `transmissionContent` VARCHAR(255),
  `transmissionDateTime` DATETIME,
  PRIMARY KEY (`transmissionId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_577678_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_577678_dump') AS relationships;
DROP DATABASE `db_577678_dump`;
UNINSTALL EXTENSION vsql_schematron;
