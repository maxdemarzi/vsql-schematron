INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 548679_20.do.user-preferences
--echo #
CREATE DATABASE `db_548679_20_do_user_preferences`;
USE `db_548679_20_do_user_preferences`;
CREATE TABLE `preference` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `key` VARCHAR(50),
  `description` TEXT,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_preferences` (
  `user_id` BIGINT NOT NULL,
  `preference_id` INT NOT NULL,
  `value` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `updated` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`, `preference_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_548679_20_do_user_preferences') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_548679_20_do_user_preferences') AS relationships;
DROP DATABASE `db_548679_20_do_user_preferences`;
UNINSTALL EXTENSION vsql_schematron;
