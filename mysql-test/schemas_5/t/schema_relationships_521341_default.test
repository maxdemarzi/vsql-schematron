INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 521341_default
--echo #
CREATE DATABASE `db_521341_default`;
USE `db_521341_default`;
CREATE TABLE `rupay_orders` (
  `id` INT,
  `order_number` VARCHAR(50),
  `transaction_id` VARCHAR(50),
  `hash` VARCHAR(50),
  `date` DATETIME,
  `valid_through` DATETIME,
  `buyer` VARCHAR(50),
  `email` VARCHAR(50),
  `phone` VARCHAR(50),
  `address` VARCHAR(50),
  `passport` VARCHAR(50),
  `inn` VARCHAR(50),
  `comment` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME,
  `paid` DATETIME,
  `fiscalized` DATETIME,
  `refunded` DATETIME,
  `refund_fiscalized` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `rupay_orders_items` (
  `id` INT,
  `order_id` INT,
  `product` VARCHAR(50),
  `price` DECIMAL(10,2),
  `quantity` DECIMAL(10,2),
  `units` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `rupay_orders_payments` (
  `id` INT,
  `order_id` INT,
  `gateway` VARCHAR(50),
  `is_outdated` TINYINT,
  `payment_url` VARCHAR(50),
  `gateway_order_id` VARCHAR(50),
  `data` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_521341_default') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_521341_default') AS relationships;
DROP DATABASE `db_521341_default`;
UNINSTALL EXTENSION vsql_schematron;
