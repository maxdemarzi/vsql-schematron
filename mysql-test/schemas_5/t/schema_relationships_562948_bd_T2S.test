INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 562948_bd_T2S
--echo #
CREATE DATABASE `db_562948_bd_T2S`;
USE `db_562948_bd_T2S`;
CREATE TABLE `tb_Conteiner` (
  `cd_Conteiner` INT NOT NULL,
  `nm_Cliente_Conteiner` VARCHAR(50),
  `nm_Numero_Conteiner` VARCHAR(50),
  `nm_Tipo_Conteiner` VARCHAR(50),
  `nm_Status_Conteiner` VARCHAR(50),
  `nm_Categoria_Conteiner` VARCHAR(50),
  PRIMARY KEY (`cd_Conteiner`)
) CHARACTER SET latin1;
CREATE TABLE `tb_Movimentacao` (
  `cd_Movimentacao` INT NOT NULL,
  `nm_Tipo_Movimentacao` VARCHAR(50),
  `nm_DHInicio_Movimentacao` VARCHAR(50),
  `nm_DHFim_Movimentacao` VARCHAR(50),
  `cd_Conteiner` INT,
  PRIMARY KEY (`cd_Movimentacao`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_562948_bd_T2S') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_562948_bd_T2S') AS relationships;
DROP DATABASE `db_562948_bd_T2S`;
UNINSTALL EXTENSION vsql_schematron;
