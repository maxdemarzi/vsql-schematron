INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 555537_database
--echo #
CREATE DATABASE `db_555537_database`;
USE `db_555537_database`;

CREATE TABLE `users` (
  `id` INT,
  `login` VARCHAR(64),
  `passwd` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `groups` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `user_id1` INT,
  `user_id2` INT,
  PRIMARY KEY (`user_id1`, `user_id2`)
) CHARACTER SET latin1;

CREATE TABLE `group_messages` (
  `id` INT,
  `group_id` INT,
  `author_id` INT,
  `text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group_members` (
  `group_id` INT,
  `member_id` INT,
  PRIMARY KEY (`group_id`, `member_id`)
) CHARACTER SET latin1;

CREATE TABLE `group_msg_views` (
  `group_id` INT,
  `msg_id` INT,
  `viewer_id` INT,
  `viewed` BOOL,
  PRIMARY KEY (`group_id`, `msg_id`, `viewer_id`)
) CHARACTER SET latin1;

CREATE TABLE `priv_messages` (
  `id` INT,
  `sender_id` INT,
  `receiver_id` INT,
  `text` VARCHAR(64),
  `viewed` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_555537_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_555537_database') AS relationships;
DROP DATABASE `db_555537_database`;
UNINSTALL EXTENSION vsql_schematron;
