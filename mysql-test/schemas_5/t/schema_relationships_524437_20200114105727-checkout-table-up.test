INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524437_20200114105727-checkout-table-up
--echo #
CREATE DATABASE `db_524437_20200114105727_checkout_table_up`;
USE `db_524437_20200114105727_checkout_table_up`;
CREATE TABLE `checkout` (
  `sessionId` VARCHAR(50) NOT NULL,
  `clientId` VARCHAR(50),
  `timestamp` TIMESTAMP NULL,
  `traceId` VARCHAR(50),
  PRIMARY KEY (`sessionId`)
) CHARACTER SET latin1;
CREATE TABLE `purchase` (
  `id` VARCHAR(50) NOT NULL,
  `sessionId` VARCHAR(50),
  `wertgarantieProductId` INT,
  `deviceClass` VARCHAR(50),
  `devicePrice` INT,
  `success` BOOLEAN,
  `message` TEXT,
  `shopProduct` TEXT,
  `contractNumber` INT,
  `transactionNumber` INT,
  `activationCode` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524437_20200114105727_checkout_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524437_20200114105727_checkout_table_up') AS relationships;
DROP DATABASE `db_524437_20200114105727_checkout_table_up`;
UNINSTALL EXTENSION vsql_schematron;
