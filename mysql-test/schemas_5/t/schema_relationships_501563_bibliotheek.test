INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 501563_bibliotheek
--echo #
CREATE DATABASE `db_501563_bibliotheek`;
USE `db_501563_bibliotheek`;

CREATE TABLE `book` (
  `ISBN` INT,
  `Title` VARCHAR(255),
  `Author` VARCHAR(255),
  `ShortDescription` VARCHAR(255),
  `Edition` VARCHAR(255),
  `ImageURL` VARCHAR(255),
  `UpdatedDate` DATETIME,
  PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;

CREATE TABLE `copy` (
  `CopyID` INT,
  `LendingPeriod` INT,
  `BookISBN` INT,
  `UpdatedDate` DATETIME,
  PRIMARY KEY (`CopyID`)
) CHARACTER SET latin1;

CREATE TABLE `member` (
  `MemberID` INT,
  `FirstName` VARCHAR(255),
  `LastName` VARCHAR(255),
  `Street` VARCHAR(255),
  `HouseNumber` VARCHAR(255),
  `City` VARCHAR(255),
  `PhoneNumber` VARCHAR(255),
  `EmailAddress` VARCHAR(255),
  `Fine` DECIMAL(10,2),
  `UpdatedDate` DATETIME,
  PRIMARY KEY (`MemberID`)
) CHARACTER SET latin1;

CREATE TABLE `reservation` (
  `ReservationID` INT,
  `ReservationDate` DATETIME,
  `MemberID` INT,
  `CopyID` INT,
  `UpdatedDate` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_501563_bibliotheek') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_501563_bibliotheek') AS relationships;
DROP DATABASE `db_501563_bibliotheek`;
UNINSTALL EXTENSION vsql_schematron;
