INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 594789_TabelasDosProjeto
--echo #
CREATE DATABASE `db_594789_TabelasDosProjeto`;
USE `db_594789_TabelasDosProjeto`;
CREATE TABLE `LOJISTA` (
  `COD_LOJ` INT NOT NULL,
  `NOME_LOJISTA` VARCHAR(50),
  PRIMARY KEY (`COD_LOJ`)
) CHARACTER SET latin1;
CREATE TABLE `VAUCHER` (
  `COD_VAU` VARCHAR(50) NOT NULL,
  `PORCENTAGEM_DES` DECIMAL(10,2),
  PRIMARY KEY (`COD_VAU`)
) CHARACTER SET latin1;
CREATE TABLE `VENDAS` (
  `COD_LOJ` INT,
  `COD_CLI` INT,
  `COD_PRO` INT,
  `TOTAL_COMPRA` DECIMAL(10,2),
  `COD_VAU` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_594789_TabelasDosProjeto') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_594789_TabelasDosProjeto') AS relationships;
DROP DATABASE `db_594789_TabelasDosProjeto`;
UNINSTALL EXTENSION vsql_schematron;
