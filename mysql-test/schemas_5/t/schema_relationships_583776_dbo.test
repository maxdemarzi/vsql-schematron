INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583776_dbo
--echo #
CREATE DATABASE `db_583776_dbo`;
USE `db_583776_dbo`;

CREATE TABLE `empresa` (
  `id` INT,
  `nome` VARCHAR(64),
  `cnpj` VARCHAR(64),
  `dataCadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usuario` (
  `id` INT,
  `nome` VARCHAR(64),
  `cpf` VARCHAR(64),
  `nomeComunidade` VARCHAR(64),
  `dataCadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comunidade` (
  `id` INT,
  `nome` VARCHAR(64),
  `cep` VARCHAR(64),
  `idRepresentante` INT,
  `dataCadastro` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_583776_dbo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_583776_dbo') AS relationships;
DROP DATABASE `db_583776_dbo`;
UNINSTALL EXTENSION vsql_schematron;
