INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 548221_seed
--echo #
CREATE DATABASE `db_548221_seed`;
USE `db_548221_seed`;
CREATE TABLE `public.DemoTable` (
  `id` INT NOT NULL,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.another_table` (
  `id` INT NOT NULL,
  `is_array` VARCHAR(50),
  `demo_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_548221_seed') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_548221_seed') AS relationships;
DROP DATABASE `db_548221_seed`;
UNINSTALL EXTENSION vsql_schematron;
