INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 537029_users
--echo #
CREATE DATABASE `db_537029_users`;
USE `db_537029_users`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `web` TEXT,
  `contact_id` INT,
  `parent_id` INT,
  `created_at` TEXT,
  `updated_at` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_537029_users') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_537029_users') AS relationships;
DROP DATABASE `db_537029_users`;
UNINSTALL EXTENSION vsql_schematron;
