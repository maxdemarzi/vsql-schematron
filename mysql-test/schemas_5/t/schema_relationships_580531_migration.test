INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580531_migration
--echo #
CREATE DATABASE `db_580531_migration`;
USE `db_580531_migration`;

CREATE TABLE `User` (
  `address` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`address`)
) CHARACTER SET latin1;

CREATE TABLE `Token` (
  `address` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`address`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `id` INT,
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  `creatorAddress` VARCHAR(64),
  `commentId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_PostToToken` (
  `A` INT,
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `new_Post` (
  `id` INT,
  `createdAt` DATETIME,
  `title` VARCHAR(64),
  `expiration` DATETIME,
  `creatorAddress` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580531_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580531_migration') AS relationships;
DROP DATABASE `db_580531_migration`;
UNINSTALL EXTENSION vsql_schematron;
