INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 526863_blog_tables
--echo #
CREATE DATABASE `db_526863_blog_tables`;
USE `db_526863_blog_tables`;

CREATE TABLE `blog` (
  `blog_id` INT,
  `user_id` INT,
  `blog_title` VARCHAR(64),
  `created_datetime` DATETIME,
  `edited_datetime` DATETIME,
  `published_datetime` DATETIME,
  `blog_text` VARCHAR(64),
  `likes` INT,
  `dislikes` INT,
  `rating` INT,
  `active` BOOL,
  `comment_security` INT,
  `status` VARCHAR(64),
  `visibility` VARCHAR(64),
  PRIMARY KEY (`blog_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_like` (
  `blog_id` INT,
  `user_name` INT,
  PRIMARY KEY (`blog_id`, `user_name`)
) CHARACTER SET latin1;

CREATE TABLE `blog_category` (
  `category_id` INT,
  `blog_id` INT,
  `category_text` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_comment` (
  `comment_id` INT,
  `blog_id` INT,
  `comment_title` VARCHAR(64),
  `comment_text` VARCHAR(64),
  `comment_user` INT,
  `parent_comment_id` INT,
  `likes` INT,
  `dislikes` INT,
  `rating` INT,
  `active` BOOL,
  `created_datetime` DATETIME,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

CREATE TABLE `blog_history` (
  `history_id` INT,
  `history_type` VARCHAR(64),
  `history_table` VARCHAR(64),
  `table_id` INT,
  `table_column` VARCHAR(64),
  `username` VARCHAR(64),
  `old_value` VARCHAR(64),
  `new_value` VARCHAR(64),
  `message` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`history_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_526863_blog_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_526863_blog_tables') AS relationships;
DROP DATABASE `db_526863_blog_tables`;
UNINSTALL EXTENSION vsql_schematron;
