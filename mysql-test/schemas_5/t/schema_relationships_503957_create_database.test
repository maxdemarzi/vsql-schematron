INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 503957_create_database
--echo #
CREATE DATABASE `db_503957_create_database`;
USE `db_503957_create_database`;
CREATE TABLE `executed_file` (
  `id` INT NOT NULL,
  `file` TEXT,
  `drops` INT,
  `size` INT,
  `recorded_at` DECIMAL(10,2),
  `channel` TEXT,
  `title` TEXT,
  `channelName` TEXT,
  `duration` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `splitted_file` (
  `id` INT NOT NULL,
  `executed_file_id` INT,
  `file` TEXT,
  `size` INT,
  `duration` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_503957_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_503957_create_database') AS relationships;
DROP DATABASE `db_503957_create_database`;
UNINSTALL EXTENSION vsql_schematron;
