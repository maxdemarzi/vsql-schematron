INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 528774_download_statistics
--echo #
CREATE DATABASE `db_528774_download_statistics`;
USE `db_528774_download_statistics`;
CREATE TABLE `downloadable` (
  `file_id` INT NOT NULL,
  `filename` TEXT,
  `size` INT,
  `created` TIMESTAMP NULL,
  `deleted` TIMESTAMP NULL,
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
CREATE TABLE `download` (
  `file_id` INT,
  `filename` TEXT,
  `datetime` TIMESTAMP NULL,
  `size` INT,
  `complete` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_528774_download_statistics') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_528774_download_statistics') AS relationships;
DROP DATABASE `db_528774_download_statistics`;
UNINSTALL EXTENSION vsql_schematron;
