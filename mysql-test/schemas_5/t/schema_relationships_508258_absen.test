INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 508258_absen
--echo #
CREATE DATABASE `db_508258_absen`;
USE `db_508258_absen`;

CREATE TABLE `akun` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `nama` VARCHAR(64),
  `alamat` VARCHAR(64),
  `no_tlp` VARCHAR(64),
  `jabatan` VARCHAR(64),
  `tipe_akun` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `catatan_keluar` (
  `id` INT,
  `username` VARCHAR(64),
  `waktu_keluar` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `catatan_masuk` (
  `id` INT,
  `username` VARCHAR(64),
  `waktu_masuk` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_508258_absen') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_508258_absen') AS relationships;
DROP DATABASE `db_508258_absen`;
UNINSTALL EXTENSION vsql_schematron;
