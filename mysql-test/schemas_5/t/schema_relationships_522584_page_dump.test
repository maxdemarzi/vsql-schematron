INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 522584_page-dump
--echo #
CREATE DATABASE `db_522584_page_dump`;
USE `db_522584_page_dump`;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category_closure` (
  `ancestor` INT,
  `descendant` INT,
  `depth` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_522584_page_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_522584_page_dump') AS relationships;
DROP DATABASE `db_522584_page_dump`;
UNINSTALL EXTENSION vsql_schematron;
