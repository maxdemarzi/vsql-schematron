INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 580065_schema
--echo #
CREATE DATABASE `db_580065_schema`;
USE `db_580065_schema`;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `status` INT,
  `first_post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `group` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_group` (
  `id` INT,
  `user_id` INT,
  `group_id` INT,
  `date_added` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category_attribute` (
  `id` INT,
  `category_id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `category_tree` (
  `id` INT,
  `ancestor_id` INT,
  `descendant_id` INT,
  `distance` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `sku` VARCHAR(64),
  `name` VARCHAR(64),
  `price` DECIMAL(10,2),
  `stock_quantity` DECIMAL(10,2),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_category` (
  `id` INT,
  `product_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `delivery_address` (
  `id` INT,
  `street_address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `postal_code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `code` VARCHAR(64),
  `date_created` DATETIME,
  `user_id` INT,
  `delivery_address_id` INT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_item` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `quantity` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_shipping` (
  `order_id` INT,
  `status` INT,
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;

CREATE TABLE `order_shipping_event` (
  `id` INT,
  `order_shipping_id` INT,
  `event_time` DATETIME,
  `event_description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `store` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `store_product` (
  `id` INT,
  `store_id` INT,
  `product_id` INT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `id` INT,
  `title` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `post_id` INT,
  `parent_id` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_580065_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_580065_schema') AS relationships;
DROP DATABASE `db_580065_schema`;
UNINSTALL EXTENSION vsql_schematron;
