INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 546951_up
--echo #
CREATE DATABASE `db_546951_up`;
USE `db_546951_up`;

CREATE TABLE `blocks` (
  `id` INT,
  `block_type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `block_data` VARCHAR(64),
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `properties` (
  `id` INT,
  `property_name` VARCHAR(64),
  `parent_id` INT,
  `value_id` INT,
  `annotation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_546951_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_546951_up') AS relationships;
DROP DATABASE `db_546951_up`;
UNINSTALL EXTENSION vsql_schematron;
