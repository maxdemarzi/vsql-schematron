INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 575737_15_log.up
--echo #
CREATE DATABASE `db_575737_15_log_up`;
USE `db_575737_15_log_up`;

CREATE TABLE `log_events` (
  `id` INT,
  `user_id` INT,
  `add_datetime` DATETIME,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `log_events_articles` (
  `log_event_id` INT,
  `article_id` INT,
  PRIMARY KEY (`log_event_id`, `article_id`)
) CHARACTER SET latin1;

CREATE TABLE `log_events_item` (
  `log_event_id` INT,
  `item_id` INT,
  PRIMARY KEY (`log_event_id`, `item_id`)
) CHARACTER SET latin1;

CREATE TABLE `log_events_pictures` (
  `log_event_id` INT,
  `picture_id` INT,
  PRIMARY KEY (`log_event_id`, `picture_id`)
) CHARACTER SET latin1;

CREATE TABLE `log_events_user` (
  `log_event_id` INT,
  `user_id` INT,
  PRIMARY KEY (`log_event_id`, `user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_575737_15_log_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_575737_15_log_up') AS relationships;
DROP DATABASE `db_575737_15_log_up`;
UNINSTALL EXTENSION vsql_schematron;
