INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 510385_EP3_9790930_MODULE_PEOPLE_DDL
--echo #
CREATE DATABASE `db_510385_EP3_9790930_MODULE_PEOPLE_DDL`;
USE `db_510385_EP3_9790930_MODULE_PEOPLE_DDL`;

CREATE TABLE `b05_PESSOA` (
  `nusp` INT,
  `pnome` VARCHAR(64),
  `snome` VARCHAR(64),
  PRIMARY KEY (`nusp`)
) CHARACTER SET latin1;

CREATE TABLE `b07_PROFESSOR` (
  `pe_nusp` INT,
  `status` VARCHAR(64),
  `email` VARCHAR(64),
  `sala` VARCHAR(64),
  `site` VARCHAR(64),
  PRIMARY KEY (`pe_nusp`)
) CHARACTER SET latin1;

CREATE TABLE `b09_ALUNO` (
  `pe_nusp` INT,
  PRIMARY KEY (`pe_nusp`)
) CHARACTER SET latin1;

CREATE TABLE `b10_ADMINISTRADOR` (
  `pe_nusp` INT,
  `email` VARCHAR(64),
  PRIMARY KEY (`pe_nusp`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_510385_EP3_9790930_MODULE_PEOPLE_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_510385_EP3_9790930_MODULE_PEOPLE_DDL') AS relationships;
DROP DATABASE `db_510385_EP3_9790930_MODULE_PEOPLE_DDL`;
UNINSTALL EXTENSION vsql_schematron;
