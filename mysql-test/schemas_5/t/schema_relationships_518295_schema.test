INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 518295_schema
--echo #
CREATE DATABASE `db_518295_schema`;
USE `db_518295_schema`;
CREATE TABLE `license` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` INT NOT NULL,
  `count` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lend` (
  `license_id` INT,
  `book_id` INT,
  `returned` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_518295_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_518295_schema') AS relationships;
DROP DATABASE `db_518295_schema`;
UNINSTALL EXTENSION vsql_schematron;
