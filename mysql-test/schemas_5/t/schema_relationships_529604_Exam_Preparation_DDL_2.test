INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 529604_Exam_Preparation_DDL_2
--echo #
CREATE DATABASE `db_529604_Exam_Preparation_DDL_2`;
USE `db_529604_Exam_Preparation_DDL_2`;

CREATE TABLE `pictures` (
  `id` INT,
  `path` VARCHAR(64),
  `size` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `profile_picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `caption` VARCHAR(64),
  `user_id` INT,
  `picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `content` VARCHAR(64),
  `user_id` INT,
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_followers` (
  `user_id` INT,
  `follower_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_529604_Exam_Preparation_DDL_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_529604_Exam_Preparation_DDL_2') AS relationships;
DROP DATABASE `db_529604_Exam_Preparation_DDL_2`;
UNINSTALL EXTENSION vsql_schematron;
