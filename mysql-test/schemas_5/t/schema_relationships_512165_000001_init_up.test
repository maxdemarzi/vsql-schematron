INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 512165_000001_init_up
--echo #
CREATE DATABASE `db_512165_000001_init_up`;
USE `db_512165_000001_init_up`;

CREATE TABLE `rubric` (
  `id` INT,
  `name` VARCHAR(255),
  `parent_rubric_id` INT
) CHARACTER SET latin1;

CREATE TABLE `city` (
  `id` INT,
  `name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `street` (
  `id` INT,
  `city_id` INT,
  `name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `building` (
  `id` INT,
  `city_id` INT,
  `street_id` INT,
  `house` INT,
  `point` INT
) CHARACTER SET latin1;

CREATE TABLE `company` (
  `id` INT,
  `name` VARCHAR(255),
  `building_id` INT
) CHARACTER SET latin1;

CREATE TABLE `company_rubric` (
  `company_id` INT,
  `rubric_id` INT
) CHARACTER SET latin1;

CREATE TABLE `phone` (
  `id` INT,
  `company_id` INT,
  `number` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_512165_000001_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_512165_000001_init_up') AS relationships;
DROP DATABASE `db_512165_000001_init_up`;
UNINSTALL EXTENSION vsql_schematron;
