INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 513153_exalendar
--echo #
CREATE DATABASE `db_513153_exalendar`;
USE `db_513153_exalendar`;

CREATE TABLE `users` (
  `user_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `pwd_hash` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_settings` (
  `user_id` INT,
  `setting_id` INT,
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user_classes` (
  `user_id` INT,
  `class_id` INT
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `setting_id` INT,
  `setting_name` VARCHAR(64),
  `setting_type` VARCHAR(64),
  PRIMARY KEY (`setting_id`)
) CHARACTER SET latin1;

CREATE TABLE `classes` (
  `class_id` INT,
  `class_name` VARCHAR(64),
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `class_id` INT,
  `event_id` INT,
  `event_type` VARCHAR(64),
  `event_title` VARCHAR(64),
  `event_description` VARCHAR(64),
  `event_date` DATETIME,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `user_id` INT,
  `class_id` INT
) CHARACTER SET latin1;

CREATE TABLE `events_meta` (
  `id` INT,
  `event_id` INT,
  `repeat_start` INT,
  `repeat_interval` INT,
  `repeat_year` VARCHAR(64),
  `repeat_month` INT,
  `repeat_day` INT,
  `repeat_week` INT,
  `repeat_weekday` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_513153_exalendar') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_513153_exalendar') AS relationships;
DROP DATABASE `db_513153_exalendar`;
UNINSTALL EXTENSION vsql_schematron;
