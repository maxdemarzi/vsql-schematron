INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 568989_create_db
--echo #
CREATE DATABASE `db_568989_create_db`;
USE `db_568989_create_db`;

CREATE TABLE `users` (
  `user_id` INT,
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `library_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `songs` (
  `song_id` VARCHAR(64),
  `title` VARCHAR(64),
  `rating` INT,
  `duration` INT,
  PRIMARY KEY (`song_id`)
) CHARACTER SET latin1;

CREATE TABLE `artists` (
  `artist_id` VARCHAR(64),
  `name` VARCHAR(64),
  `song_id` VARCHAR(64),
  PRIMARY KEY (`song_id`, `artist_id`)
) CHARACTER SET latin1;

CREATE TABLE `playlists` (
  `playlist_id` INT,
  `title` VARCHAR(64),
  `song_id` VARCHAR(64),
  `number_songs` INT,
  `creator` VARCHAR(64),
  PRIMARY KEY (`playlist_id`, `song_id`)
) CHARACTER SET latin1;

CREATE TABLE `podcasts` (
  `podcast_id` VARCHAR(64),
  `title` VARCHAR(64),
  `duration` INT,
  PRIMARY KEY (`podcast_id`)
) CHARACTER SET latin1;

CREATE TABLE `broadcasters` (
  `broadcaster_id` VARCHAR(64),
  `name` VARCHAR(64),
  `podcast_id` VARCHAR(64),
  PRIMARY KEY (`broadcaster_id`, `podcast_id`)
) CHARACTER SET latin1;

CREATE TABLE `library` (
  `library_id` INT,
  `user_id` INT,
  `playlist_id` INT,
  `song_id` VARCHAR(64),
  `podcast_id` VARCHAR(64),
  PRIMARY KEY (`library_id`, `playlist_id`, `song_id`, `podcast_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_568989_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_568989_create_db') AS relationships;
DROP DATABASE `db_568989_create_db`;
UNINSTALL EXTENSION vsql_schematron;
