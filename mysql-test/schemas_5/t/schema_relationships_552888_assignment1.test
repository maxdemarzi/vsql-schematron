INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 552888_assignment1
--echo #
CREATE DATABASE `db_552888_assignment1`;
USE `db_552888_assignment1`;
CREATE TABLE `dept` (
  `deptno` DECIMAL(10,2) NOT NULL,
  `deptname` VARCHAR(50),
  PRIMARY KEY (`deptno`)
) CHARACTER SET latin1;
CREATE TABLE `emp` (
  `empno` DECIMAL(10,2) NOT NULL,
  `empname` VARCHAR(50),
  `city` VARCHAR(50),
  `sal` DECIMAL(10,2),
  `deptno` DECIMAL(10,2),
  PRIMARY KEY (`empno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_552888_assignment1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_552888_assignment1') AS relationships;
DROP DATABASE `db_552888_assignment1`;
UNINSTALL EXTENSION vsql_schematron;
