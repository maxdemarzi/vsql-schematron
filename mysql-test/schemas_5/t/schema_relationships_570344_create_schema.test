INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 570344_create_schema
--echo #
CREATE DATABASE `db_570344_create_schema`;
USE `db_570344_create_schema`;

CREATE TABLE `feature_type` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_type` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_status` (
  `id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `system_user` (
  `id` INT,
  `name` VARCHAR(64),
  `login` VARCHAR(64),
  `email` VARCHAR(64),
  `active` BOOL,
  `manager_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `feature` (
  `id` INT,
  `parent_id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `feature_type_id` INT,
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `access` (
  `role_id` INT,
  `feature_id` INT,
  PRIMARY KEY (`role_id`, `feature_id`)
) CHARACTER SET latin1;

CREATE TABLE `version` (
  `id` INT,
  `feature_id` INT,
  `release_date` DATETIME,
  `version_number` DECIMAL(10,2),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `mandatory` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `session` (
  `id` INT,
  `user_id` INT,
  `start_date` DATETIME,
  `end_date` DATETIME,
  `ip_address` VARCHAR(64),
  `host_name` VARCHAR(64),
  `external_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event` (
  `id` INT,
  `event_type_id` INT,
  `event_status_id` INT,
  `feature_id` INT,
  `session_id` INT,
  `event_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_detail` (
  `id` INT,
  `event_id` INT,
  `field_name` VARCHAR(64),
  `field_value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_570344_create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_570344_create_schema') AS relationships;
DROP DATABASE `db_570344_create_schema`;
UNINSTALL EXTENSION vsql_schematron;
