INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 590358_001-compas-store
--echo #
CREATE DATABASE `db_590358_001_compas_store`;
USE `db_590358_001_compas_store`;
CREATE TABLE `migration` (
  `namespace` VARCHAR(50),
  `number` INT,
  `name` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `hash` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `file` (
  `id` VARCHAR(50) NOT NULL,
  `contentLength` INT,
  `bucketName` VARCHAR(50),
  `contentType` VARCHAR(50),
  `name` VARCHAR(50),
  `meta` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `deletedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `id` VARCHAR(50) NOT NULL,
  `expires` TIMESTAMP NULL,
  `data` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job` (
  `id` VARCHAR(50) NOT NULL,
  `isComplete` BOOLEAN,
  `priority` INT,
  `retryCount` INT,
  `name` VARCHAR(50),
  `scheduledAt` TIMESTAMP NULL,
  `data` VARCHAR(50),
  `handlerTimeout` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fileGroup` (
  `id` VARCHAR(50) NOT NULL,
  `order` INT,
  `file` VARCHAR(50),
  `parent` VARCHAR(50),
  `name` VARCHAR(50),
  `meta` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `deletedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_590358_001_compas_store') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_590358_001_compas_store') AS relationships;
DROP DATABASE `db_590358_001_compas_store`;
UNINSTALL EXTENSION vsql_schematron;
