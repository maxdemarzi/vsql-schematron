INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 581027_database
--echo #
CREATE DATABASE `db_581027_database`;
USE `db_581027_database`;
CREATE TABLE `kutuphanedb.adresler` (
  `adres_no` INT NOT NULL,
  `adres` VARCHAR(50),
  PRIMARY KEY (`adres_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kutuphane` (
  `kutuphane_no` INT NOT NULL,
  `kutuphane_adi` VARCHAR(50),
  `adres_no` INT,
  PRIMARY KEY (`kutuphane_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.uyeler` (
  `uye_no` INT NOT NULL,
  `uye_adi` VARCHAR(50),
  `uye_soyadi` VARCHAR(50),
  `uye_tel_no` VARCHAR(50),
  `uye_eposta` VARCHAR(50),
  `uye_sifre` VARCHAR(50),
  `adres_no` INT,
  PRIMARY KEY (`uye_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kitaplar` (
  `isbn_no` VARCHAR(50) NOT NULL,
  `kitap_adi` VARCHAR(50),
  `yayin_evi` VARCHAR(50),
  PRIMARY KEY (`isbn_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.yazarlar` (
  `yazar_no` INT NOT NULL,
  `yazar_adi` VARCHAR(50),
  `yazar_soyadi` VARCHAR(50),
  PRIMARY KEY (`yazar_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kategoriler` (
  `kategori_no` INT NOT NULL,
  `kategori_ismi` VARCHAR(50),
  PRIMARY KEY (`kategori_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.emanet` (
  `emanet_no` INT NOT NULL,
  `kutuphane_no` INT,
  `uye_no` INT,
  `isbn_no` VARCHAR(50),
  `alim_tarihi` DATE,
  `teslim_tarihi` DATE,
  PRIMARY KEY (`emanet_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kitap_kategori` (
  `kitap_kategori_no` INT NOT NULL,
  `isbn_no` VARCHAR(50),
  `kategori_no` INT,
  PRIMARY KEY (`kitap_kategori_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kitap_yazar` (
  `kitap_yazar_no` INT NOT NULL,
  `isbn_no` VARCHAR(50),
  `yazar_no` INT,
  PRIMARY KEY (`kitap_yazar_no`)
) CHARACTER SET latin1;
CREATE TABLE `kutuphanedb.kutuphane_kitap` (
  `kutuphane_kitap_no` INT NOT NULL,
  `kutuphane_no` INT,
  `isbn_no` VARCHAR(50),
  `adet` INT,
  PRIMARY KEY (`kutuphane_kitap_no`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_581027_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_581027_database') AS relationships;
DROP DATABASE `db_581027_database`;
UNINSTALL EXTENSION vsql_schematron;
