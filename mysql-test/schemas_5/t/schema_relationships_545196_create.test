INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 545196_create
--echo #
CREATE DATABASE `db_545196_create`;
USE `db_545196_create`;

CREATE TABLE `Addresses` (
  `ID` INT,
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Department` (
  `ID` INT,
  `name` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `People` (
  `ID` INT,
  `fname` VARCHAR(64),
  `addr` INT,
  `deptName` VARCHAR(64),
  `deptCity` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Projects` (
  `lead` INT,
  `name` VARCHAR(64),
  `deptName` VARCHAR(64),
  `deptCity` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_545196_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_545196_create') AS relationships;
DROP DATABASE `db_545196_create`;
UNINSTALL EXTENSION vsql_schematron;
