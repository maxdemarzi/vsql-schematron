INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 576677_V1__create_tables_for_tests
--echo #
CREATE DATABASE `db_576677_V1_create_tables_for_tests`;
USE `db_576677_V1_create_tables_for_tests`;

CREATE TABLE `user` (
  `id` INT,
  `nome_usuario` VARCHAR(64),
  `senha` VARCHAR(64),
  `email` VARCHAR(64),
  `date_created` DATETIME,
  `last_updated` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `BLOG` (
  `id` INT,
  `titulo` VARCHAR(64),
  `id_usuario` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_576677_V1_create_tables_for_tests') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_576677_V1_create_tables_for_tests') AS relationships;
DROP DATABASE `db_576677_V1_create_tables_for_tests`;
UNINSTALL EXTENSION vsql_schematron;
