INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 573387_TPscriptEtudiant
--echo #
CREATE DATABASE `db_573387_TPscriptEtudiant`;
USE `db_573387_TPscriptEtudiant`;

CREATE TABLE `etudiant` (
  `matricule_etu` INT,
  `nom_etu` VARCHAR(64),
  `prenom_etu` VARCHAR(64),
  `date_naissance` DATETIME,
  PRIMARY KEY (`matricule_etu`)
) CHARACTER SET latin1;

CREATE TABLE `enseignant` (
  `matricule_ens` INT,
  `nom_ens` VARCHAR(64),
  `prenom_ens` VARCHAR(64),
  `age` INT,
  PRIMARY KEY (`matricule_ens`)
) CHARACTER SET latin1;

CREATE TABLE `etudiantunite` (
  `matricule_etu` INT,
  `code_unite` VARCHAR(64),
  `note_cc` INT,
  `note_tp` INT,
  `note_examen` INT,
  PRIMARY KEY (`matricule_etu`, `code_unite`)
) CHARACTER SET latin1;

CREATE TABLE `unite` (
  `code_unite` INT,
  `matricule_ens` INT,
  `libelle` VARCHAR(64),
  `nbr_heur` INT,
  PRIMARY KEY (`code_unite`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_573387_TPscriptEtudiant') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_573387_TPscriptEtudiant') AS relationships;
DROP DATABASE `db_573387_TPscriptEtudiant`;
UNINSTALL EXTENSION vsql_schematron;
