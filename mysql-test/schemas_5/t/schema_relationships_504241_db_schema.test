INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 504241_db_schema
--echo #
CREATE DATABASE `db_504241_db_schema`;
USE `db_504241_db_schema`;
CREATE TABLE `types` (
  `id` INT,
  `name` TEXT
) CHARACTER SET latin1;
CREATE TABLE `settings` (
  `id` INT,
  `profile` INT,
  `device` INT,
  `setting` TEXT
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
  `id` INT,
  `name` TEXT
) CHARACTER SET latin1;
CREATE TABLE `devices` (
  `id` INT,
  `mac` TEXT,
  `type` INT,
  `ip` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_504241_db_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_504241_db_schema') AS relationships;
DROP DATABASE `db_504241_db_schema`;
UNINSTALL EXTENSION vsql_schematron;
