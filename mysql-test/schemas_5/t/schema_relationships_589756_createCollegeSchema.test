INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 589756_createCollegeSchema
--echo #
CREATE DATABASE `db_589756_createCollegeSchema`;
USE `db_589756_createCollegeSchema`;

CREATE TABLE `Department` (
  `Name` VARCHAR(64),
  `Location` VARCHAR(64),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `ID` VARCHAR(64),
  `Name` VARCHAR(64),
  `Major` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_589756_createCollegeSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_589756_createCollegeSchema') AS relationships;
DROP DATABASE `db_589756_createCollegeSchema`;
UNINSTALL EXTENSION vsql_schematron;
