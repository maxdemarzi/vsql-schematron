INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 556215_createTables
--echo #
CREATE DATABASE `db_556215_createTables`;
USE `db_556215_createTables`;

CREATE TABLE `comment_thread` (
  `init_com_time` DATETIME,
  `recent_com_time` DATETIME,
  `thread_name` VARCHAR(64),
  `number_of_comments` INT,
  PRIMARY KEY (`init_com_time`)
) CHARACTER SET latin1;

CREATE TABLE `comment_entry` (
  `comment_time` DATETIME,
  `comment_text` VARCHAR(64),
  `parent_init_time` DATETIME,
  PRIMARY KEY (`comment_time`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_556215_createTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_556215_createTables') AS relationships;
DROP DATABASE `db_556215_createTables`;
UNINSTALL EXTENSION vsql_schematron;
