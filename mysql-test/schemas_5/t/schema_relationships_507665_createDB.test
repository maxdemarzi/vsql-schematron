INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 507665_createDB
--echo #
CREATE DATABASE `db_507665_createDB`;
USE `db_507665_createDB`;
CREATE TABLE `Faculties` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Classes` (
  `Id` INT NOT NULL,
  `Cipher` VARCHAR(50),
  `Code` INT,
  `FacultyId` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
  `Id` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `MiddleName` VARCHAR(50),
  `Birthday` DATE,
  `ClassID` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_507665_createDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_507665_createDB') AS relationships;
DROP DATABASE `db_507665_createDB`;
UNINSTALL EXTENSION vsql_schematron;
