INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 588858_migration
--echo #
CREATE DATABASE `db_588858_migration`;
USE `db_588858_migration`;
CREATE TABLE `schools` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `name` TEXT,
  `address` TEXT,
  `phone` TEXT,
  `logo` TEXT,
  `head_of_school` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student_id_cards` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `name` TEXT,
  `studentNumber` TEXT,
  `department` TEXT,
  `user_id` TEXT,
  `school_id` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_588858_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_588858_migration') AS relationships;
DROP DATABASE `db_588858_migration`;
UNINSTALL EXTENSION vsql_schematron;
