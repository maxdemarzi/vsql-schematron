INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 570025_securevision_schema_generated
--echo #
CREATE DATABASE `db_570025_securevision_schema_generated`;
USE `db_570025_securevision_schema_generated`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `user_pass` VARCHAR(64),
  `user_rights` INT,
  `num_feedback` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `camera` (
  `id` INT,
  `is_running` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `id` INT,
  `img_path` VARCHAR(64),
  `cam_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `detection` (
  `id` INT,
  `img_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `annotation` (
  `id` INT,
  `obj_type` VARCHAR(64),
  `left_x` DECIMAL(10,2),
  `left_y` DECIMAL(10,2),
  `length` DECIMAL(10,2),
  `width` DECIMAL(10,2),
  `detection_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `feedback` (
  `id` INT,
  `corr_obj_type` VARCHAR(64),
  `corr_left_x` DECIMAL(10,2),
  `corr_left_y` DECIMAL(10,2),
  `corr_length` DECIMAL(10,2),
  `corr_width` DECIMAL(10,2),
  `detection_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_570025_securevision_schema_generated') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_570025_securevision_schema_generated') AS relationships;
DROP DATABASE `db_570025_securevision_schema_generated`;
UNINSTALL EXTENSION vsql_schematron;
