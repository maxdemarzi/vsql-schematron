INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 594155_flights
--echo #
CREATE DATABASE `db_594155_flights`;
USE `db_594155_flights`;
CREATE TABLE `Users` (
  `id_user` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `id_card` VARCHAR(50),
  `passport` VARCHAR(50),
  `nationality` VARCHAR(50),
  `birthday` DATETIME,
  `email` VARCHAR(50),
  `password_user` VARCHAR(50),
  `phone` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `Flight` (
  `id_flight` INT NOT NULL,
  `plane_name` VARCHAR(50),
  `depart` VARCHAR(50),
  `distination` VARCHAR(50),
  `date_flight` DATETIME,
  `price` INT,
  `total_places` INT,
  `is_active` TINYINT,
  PRIMARY KEY (`id_flight`)
) CHARACTER SET latin1;
CREATE TABLE `Reservation` (
  `id_resevation` INT NOT NULL,
  `id_flight` INT,
  `id_user` INT,
  `date_resevation` DATETIME,
  PRIMARY KEY (`id_resevation`)
) CHARACTER SET latin1;
CREATE TABLE `Travler` (
  `id_travler` INT NOT NULL,
  `id_user` INT,
  `id_flight` INT,
  `id_resevation` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `passport` VARCHAR(50),
  PRIMARY KEY (`id_travler`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_594155_flights') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_594155_flights') AS relationships;
DROP DATABASE `db_594155_flights`;
UNINSTALL EXTENSION vsql_schematron;
