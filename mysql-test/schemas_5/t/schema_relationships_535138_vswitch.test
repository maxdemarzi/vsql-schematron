INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 535138_vswitch
--echo #
CREATE DATABASE `db_535138_vswitch`;
USE `db_535138_vswitch`;

CREATE TABLE `virtual_switch` (
  `id` INT,
  `name` VARCHAR(64),
  `comments` VARCHAR(64),
  `creation_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vswitch_cluster` (
  `virtual_switch_id` INT,
  `cluster_id` INT,
  PRIMARY KEY (`virtual_switch_id`, `cluster_id`)
) CHARACTER SET latin1;

CREATE TABLE `vswitch_host` (
  `virtual_switch_id` INT,
  `host_id` INT,
  PRIMARY KEY (`virtual_switch_id`, `host_id`)
) CHARACTER SET latin1;

CREATE TABLE `vswitch_pg` (
  `virtual_switch_id` INT,
  `port_group_id` INT,
  PRIMARY KEY (`virtual_switch_id`, `port_group_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_535138_vswitch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_535138_vswitch') AS relationships;
DROP DATABASE `db_535138_vswitch`;
UNINSTALL EXTENSION vsql_schematron;
