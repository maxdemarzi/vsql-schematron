INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543188_db
--echo #
CREATE DATABASE `db_543188_db`;
USE `db_543188_db`;
CREATE TABLE `project` (
  `uuid` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` VARCHAR(50) NOT NULL,
  `project_uuid` VARCHAR(50),
  `post` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543188_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543188_db') AS relationships;
DROP DATABASE `db_543188_db`;
UNINSTALL EXTENSION vsql_schematron;
