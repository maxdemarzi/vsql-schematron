INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 524329_schema_v1
--echo #
CREATE DATABASE `db_524329_schema_v1`;
USE `db_524329_schema_v1`;

CREATE TABLE `system_table` (
  `table_id` INT,
  `user_table_name` VARCHAR(64),
  PRIMARY KEY (`table_id`)
) CHARACTER SET latin1;

CREATE TABLE `system_columns` (
  `table_id` INT,
  `column_id` INT,
  `column_type` VARCHAR(64),
  `user_column_name` VARCHAR(64),
  `ordering` INT,
  `link_id` INT,
  `multilanguage` BOOL,
  PRIMARY KEY (`table_id`, `column_id`)
) CHARACTER SET latin1;

CREATE TABLE `system_link_table` (
  `link_id` INT,
  `table_id_1` INT,
  `table_id_2` INT,
  `column_id_1` INT,
  `column_id_2` INT,
  PRIMARY KEY (`link_id`)
) CHARACTER SET latin1;

CREATE TABLE `file_lang` (
  `uuid` VARCHAR(64),
  `langtag` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `internal_name` VARCHAR(64),
  `external_name` VARCHAR(64),
  `mime_type` VARCHAR(64),
  PRIMARY KEY (`uuid`, `langtag`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_524329_schema_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_524329_schema_v1') AS relationships;
DROP DATABASE `db_524329_schema_v1`;
UNINSTALL EXTENSION vsql_schematron;
