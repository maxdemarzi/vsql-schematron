INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 599051_create_db
--echo #
CREATE DATABASE `db_599051_create_db`;
USE `db_599051_create_db`;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `age` INT,
  `gender` VARCHAR(64),
  `city` VARCHAR(64),
  `x` DECIMAL(10,2),
  `y` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Activity` (
  `id` INT,
  `type` VARCHAR(64),
  `distance` DECIMAL(10,2),
  `date` DATETIME,
  `x` DECIMAL(10,2),
  `y` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Activities` (
  `activity_id` INT,
  `user_id` INT,
  PRIMARY KEY (`activity_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `Buddies` (
  `buddy1` INT,
  `buddy2` INT,
  PRIMARY KEY (`buddy1`, `buddy2`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_599051_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_599051_create_db') AS relationships;
DROP DATABASE `db_599051_create_db`;
UNINSTALL EXTENSION vsql_schematron;
