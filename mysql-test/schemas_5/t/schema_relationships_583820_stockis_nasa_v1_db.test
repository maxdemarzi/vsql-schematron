INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 583820_stockis_nasa_v1_db
--echo #
CREATE DATABASE `db_583820_stockis_nasa_v1_db`;
USE `db_583820_stockis_nasa_v1_db`;

CREATE TABLE `alamat_stockis` (
  `id` INT,
  `nama_alamat` VARCHAR(64),
  `alamat` VARCHAR(64),
  `provinsi_id` INT,
  `kabupaten_id` INT,
  `kecamatan_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `barang` (
  `id` INT,
  `kd_barang` VARCHAR(64),
  `nama_barang` VARCHAR(64),
  `jumlah_barang` INT,
  `volume_barang_tampilan` VARCHAR(64),
  `berat_barang_tampilan` VARCHAR(64),
  `berat_barang_asli` VARCHAR(64),
  `PV` INT,
  `BV` INT,
  `foto_barang` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`, `kd_barang`)
) CHARACTER SET latin1;

CREATE TABLE `barang_distributor` (
  `id` INT,
  `nama_barang` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `barang_reject` (
  `id` INT,
  `barang_id` INT,
  `jml` INT,
  `keterangan` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `detail_kelengkapan` (
  `id` INT,
