  `kode_upline` VARCHAR(64),
  `nama_upline` VARCHAR(64),
  `alamat` VARCHAR(64),
  `no_hp` VARCHAR(64),
  `foto` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `ekspedisi` (
  `id` INT,
  `kode_ekspedisi` VARCHAR(64),
  `nama_ekspedisi` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
