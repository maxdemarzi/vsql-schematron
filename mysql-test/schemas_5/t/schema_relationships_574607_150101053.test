INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 574607_150101053
--echo #
CREATE DATABASE `db_574607_150101053`;
USE `db_574607_150101053`;

CREATE TABLE `Course` (
  `course_id` VARCHAR(64),
  `division` VARCHAR(64),
  PRIMARY KEY (`course_id`, `division`)
) CHARACTER SET latin1;

CREATE TABLE `Department` (
  `department_id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;

CREATE TABLE `Slot` (
  `letter` VARCHAR(64),
  `day` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  PRIMARY KEY (`letter`, `day`)
) CHARACTER SET latin1;

CREATE TABLE `Room` (
  `room_number` VARCHAR(64),
  `location` VARCHAR(64),
  PRIMARY KEY (`room_number`)
) CHARACTER SET latin1;

CREATE TABLE `ScheduledIn` (
  `course_id` VARCHAR(64),
  `course_division` VARCHAR(64),
  `department` VARCHAR(64),
  `slot_letter` VARCHAR(64),
  `slot_day` VARCHAR(64),
  `room` VARCHAR(64),
  PRIMARY KEY (`course_id`, `slot_letter`, `slot_day`, `room`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_574607_150101053') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_574607_150101053') AS relationships;
DROP DATABASE `db_574607_150101053`;
UNINSTALL EXTENSION vsql_schematron;
