INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 540682_schema
--echo #
CREATE DATABASE `db_540682_schema`;
USE `db_540682_schema`;
CREATE TABLE `USERS` (
  `id` VARCHAR(50) NOT NULL,
  `user_name` VARCHAR(50),
  `hashed_password` VARCHAR(50),
  `email` VARCHAR(50),
  `is_admin` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `JWT` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `access_token` VARCHAR(50),
  `refresh_token` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `project_name` VARCHAR(50),
  `project_description` TEXT,
  `project_sector` VARCHAR(50),
  `project_status` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_540682_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_540682_schema') AS relationships;
DROP DATABASE `db_540682_schema`;
UNINSTALL EXTENSION vsql_schematron;
