INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 584431_03_schema
--echo #
CREATE DATABASE `db_584431_03_schema`;
USE `db_584431_03_schema`;

CREATE TABLE `ACTIVITIES` (
  `NAME` VARCHAR(255),
  `URI` VARCHAR(255),
  `PARAMS` VARCHAR(255),
  `INS_DATE` DATETIME,
  `UPD_DATE` DATETIME,
  PRIMARY KEY (`NAME`)
) CHARACTER SET latin1;

CREATE TABLE `JOBS` (
  `ID` DECIMAL(10,2),
  `ACTIVITY` VARCHAR(255),
  `PARAMS` VARCHAR(255),
  `EXPRESSION` VARCHAR(255),
  `LAST_EXECUTION` DATETIME,
  `LAST_RESULT` VARCHAR(255),
  `LAST_ERROR` VARCHAR(255),
  `ELAPSED` DECIMAL(10,2),
  `INS_DATE` DATETIME,
  `UPD_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `LOG_DATA` (
  `TABLENAME` VARCHAR(255),
  `DB_USER` VARCHAR(255),
  `PK_VALUE` VARCHAR(255),
  `INS_DATE` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_584431_03_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_584431_03_schema') AS relationships;
DROP DATABASE `db_584431_03_schema`;
UNINSTALL EXTENSION vsql_schematron;
