INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 506576_001-initial
--echo #
CREATE DATABASE `db_506576_001_initial`;
USE `db_506576_001_initial`;
CREATE TABLE `Setting` (
  `id` INT NOT NULL,
  `name` TEXT,
  `value` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
  `id` INT NOT NULL,
  `seriesName` TEXT,
  `seriesId` INT,
  `created` INT,
  `price` INT,
  `buyer` TEXT,
  `seller` TEXT,
  `issuer` TEXT,
  `extra` TEXT,
  `flags` INT,
  `pdfname` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LineItem` (
  `id` INT NOT NULL,
  `name` TEXT,
  `unit` TEXT,
  `amount` INT,
  `price` INT,
  `invoiceId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_506576_001_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_506576_001_initial') AS relationships;
DROP DATABASE `db_506576_001_initial`;
UNINSTALL EXTENSION vsql_schematron;
