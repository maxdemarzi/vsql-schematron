INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 529848_assert_oracle_spool
--echo #
CREATE DATABASE `db_529848_assert_oracle_spool`;
USE `db_529848_assert_oracle_spool`;

CREATE TABLE `TAB_A` (
  `TAB_A_ID` DECIMAL(10,2),
  `TAB_A_A_ID` DECIMAL(10,2),
  PRIMARY KEY (`TAB_A_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_529848_assert_oracle_spool') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_529848_assert_oracle_spool') AS relationships;
DROP DATABASE `db_529848_assert_oracle_spool`;
UNINSTALL EXTENSION vsql_schematron;
