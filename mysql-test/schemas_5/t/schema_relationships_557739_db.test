INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 557739_db
--echo #
CREATE DATABASE `db_557739_db`;
USE `db_557739_db`;

CREATE TABLE `aopaccount` (
  `id` INT,
  `name` VARCHAR(64),
  `money` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dept` (
  `id` INT,
  `dname` VARCHAR(64),
  `loc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `job` (
  `id` INT,
  `jname` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `province` (
  `id` INT,
  `province` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `regandlogin` (
  `id` INT,
  `user_name` VARCHAR(64),
  `user_pwd` VARCHAR(64),
  `gender` VARCHAR(64),
  `age` INT,
  `native_place` VARCHAR(64),
  `qq` VARCHAR(64),
  `email` VARCHAR(64),
  `oprate` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roletb` (
  `id` INT,
  `rolename` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `salarygrade` (
  `grade` INT,
  `losalary` INT,
  `hisalary` INT,
  PRIMARY KEY (`grade`)
) CHARACTER SET latin1;

CREATE TABLE `emp` (
  `id` INT,
  `ename` VARCHAR(64),
  `job_id` INT,
  `mgr` INT,
  `joindate` DATETIME,
  `salary` DECIMAL(10,2),
  `bonus` DECIMAL(10,2),
  `dept_id` INT,
  `salarygrade_grade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `sname` VARCHAR(64),
  `age` INT,
  `address` VARCHAR(64),
  `sex` VARCHAR(64),
  `money` INT,
  `ssubject` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `usertb` (
  `id` INT,
  `user_name` VARCHAR(64),
  `user_pwd` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cardtb` (
  `id` INT,
  `uid` INT,
  `cardNum` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usertbrole` (
  `id` INT,
  `uid` INT,
  `rid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_557739_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_557739_db') AS relationships;
DROP DATABASE `db_557739_db`;
UNINSTALL EXTENSION vsql_schematron;
