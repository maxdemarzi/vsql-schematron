INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582107_db_dump
--echo #
CREATE DATABASE `db_582107_db_dump`;
USE `db_582107_db_dump`;
CREATE TABLE `courses` (
  `course_id` VARCHAR(50) NOT NULL,
  `created` TIMESTAMP NULL,
  `modified` TIMESTAMP NULL,
  `course_name` VARCHAR(50),
  `course_description` VARCHAR(50),
  `user_id` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
  `version` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `created` TIMESTAMP NULL,
  `modified` TIMESTAMP NULL,
  `name` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `user_level` VARCHAR(50),
  `status` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582107_db_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582107_db_dump') AS relationships;
DROP DATABASE `db_582107_db_dump`;
UNINSTALL EXTENSION vsql_schematron;
