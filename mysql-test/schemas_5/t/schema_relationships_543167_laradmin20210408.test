INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 543167_laradmin20210408
--echo #
CREATE DATABASE `db_543167_laradmin20210408`;
USE `db_543167_laradmin20210408`;

CREATE TABLE `articles` (
  `id` INT,
  `source_id` VARCHAR(255),
  `author` VARCHAR(255),
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `url` VARCHAR(255),
  `urlToImage` VARCHAR(255),
  `publishedAt` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `connection` VARCHAR(255),
  `queue` VARCHAR(255),
  `payload` VARCHAR(255),
  `exception` VARCHAR(255),
  `failed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(255),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pages` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `url` VARCHAR(255),
  `model` VARCHAR(255),
  `template` VARCHAR(255),
  `orderby` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(255),
  `token` VARCHAR(255),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission_user` (
  `permission_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `role_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `sources` (
  `id` VARCHAR(255),
  `description` VARCHAR(255),
  `url` VARCHAR(255),
  `category` VARCHAR(255),
  `language` VARCHAR(255),
  `country` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stocks` (
  `id` INT,
  `name` VARCHAR(255),
  `symbol` VARCHAR(255),
  `date` DATETIME,
  `close` VARCHAR(255),
  `image` VARCHAR(255),
  `country` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `title` VARCHAR(255),
  `start_at` DATETIME,
  `end_at` DATETIME,
  `updated_at` DATETIME,
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `email_verified_at` DATETIME,
  `password` VARCHAR(255),
  `remember_token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `avatar` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_543167_laradmin20210408') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_543167_laradmin20210408') AS relationships;
DROP DATABASE `db_543167_laradmin20210408`;
UNINSTALL EXTENSION vsql_schematron;
