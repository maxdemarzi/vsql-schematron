INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 582990_V1_0_0_create_tables
--echo #
CREATE DATABASE `db_582990_V1_0_0_create_tables`;
USE `db_582990_V1_0_0_create_tables`;

CREATE TABLE `COUNTRY` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PROFESSION` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSON` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `GENDER` VARCHAR(64),
  `BIRTH` DATETIME,
  `PROFESSION` INT,
  `ADDRESS` VARCHAR(64),
  `CITY` VARCHAR(64),
  `STATE` VARCHAR(64),
  `ZIP_CODE` VARCHAR(64),
  `COUNTRY` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTACT_TYPE` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTACT` (
  `ID` INT,
  `PERSON` INT,
  `CONTACT_TYPE` INT,
  `VALUE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_582990_V1_0_0_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_582990_V1_0_0_create_tables') AS relationships;
DROP DATABASE `db_582990_V1_0_0_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
