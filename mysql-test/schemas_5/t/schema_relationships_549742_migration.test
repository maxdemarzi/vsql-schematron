INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 549742_migration
--echo #
CREATE DATABASE `db_549742_migration`;
USE `db_549742_migration`;

CREATE TABLE `User` (
  `id` INT,
  `bio` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `lastLogin` VARCHAR(64),
  `isAdmin` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Follow` (
  `userId` INT,
  `followerId` INT,
  `followedAt` VARCHAR(64),
  PRIMARY KEY (`followerId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `Post` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `contentType` VARCHAR(64),
  `visibility` VARCHAR(64),
  `authorId` INT,
  `createdAt` VARCHAR(64),
  `updatedAt` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `name` VARCHAR(64),
  `postId` INT,
  PRIMARY KEY (`name`, `postId`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `id` INT,
  `postId` INT,
  `authorId` INT,
  `content` VARCHAR(64),
  `createdAt` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Like` (
  `postId` INT,
  `authorId` INT,
  PRIMARY KEY (`postId`, `authorId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_549742_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_549742_migration') AS relationships;
DROP DATABASE `db_549742_migration`;
UNINSTALL EXTENSION vsql_schematron;
