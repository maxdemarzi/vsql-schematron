INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 570133_2010-11-17-v0.5-migrations
--echo #
CREATE DATABASE `db_570133_2010_11_17_v0_5_migrations`;
USE `db_570133_2010_11_17_v0_5_migrations`;
CREATE TABLE `position` (
  `id` INT NOT NULL,
  `portfolio_id` INT,
  `as_of_date` DATE,
  `symbol` VARCHAR(50),
  `quantity` DOUBLE,
  `cost_price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tax_lot` (
  `id` INT NOT NULL,
  `position_id` INT,
  `as_of_date` DATE,
  `quantity` DOUBLE,
  `cost_price` DOUBLE,
  `sold_quantity` DOUBLE,
  `sold_price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_570133_2010_11_17_v0_5_migrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_570133_2010_11_17_v0_5_migrations') AS relationships;
DROP DATABASE `db_570133_2010_11_17_v0_5_migrations`;
UNINSTALL EXTENSION vsql_schematron;
