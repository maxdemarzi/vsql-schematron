INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 597014_init
--echo #
CREATE DATABASE `db_597014_init`;
USE `db_597014_init`;
CREATE TABLE `TestClasses` (
  `Id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `TestClassLinks` (
  `Id` VARCHAR(50) NOT NULL,
  `FromTestClassId` VARCHAR(50),
  `ToTestClassId` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_597014_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_597014_init') AS relationships;
DROP DATABASE `db_597014_init`;
UNINSTALL EXTENSION vsql_schematron;
