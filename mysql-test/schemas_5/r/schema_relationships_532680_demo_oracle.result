INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 532680_demo_oracle
#
CREATE DATABASE `db_532680_demo_oracle`;
USE `db_532680_demo_oracle`;
CREATE TABLE `EXP_FRIEND` (
`FRIENDID` DECIMAL(10,2) NOT NULL,
`FRIENDNAME` VARCHAR(50),
`PHONE` VARCHAR(50),
`EMAIL` VARCHAR(50),
`ADDRESS` VARCHAR(50),
PRIMARY KEY (`FRIENDID`)
) CHARACTER SET latin1;
CREATE TABLE `EXP_UF_RELATION` (
`USERID` DECIMAL(10,2) NOT NULL,
`FRIENDID` DECIMAL(10,2) NOT NULL,
PRIMARY KEY (`USERID`, `FRIENDID`)
) CHARACTER SET latin1;
CREATE TABLE `EXP_USER` (
`USERID` DECIMAL(10,2) NOT NULL,
`PASSWD` VARCHAR(50),
`USERNAME` VARCHAR(50),
`EMAIL` VARCHAR(50),
`SEX` DECIMAL(10,2),
`BIRTHDAY` DATE,
PRIMARY KEY (`USERID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_532680_demo_oracle') AS relationships;
relationships
Database: db_532680_demo_oracle

Table Connections:
------------------
[Implied]  EXP_UF_RELATION.FRIENDID -> EXP_FRIEND.FRIENDID
[Implied]  EXP_UF_RELATION.USERID -> EXP_USER.USERID

DROP DATABASE `db_532680_demo_oracle`;
UNINSTALL EXTENSION vsql_schematron;
