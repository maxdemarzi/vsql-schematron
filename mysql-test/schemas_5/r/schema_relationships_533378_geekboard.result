) CHARACTER SET latin1;
CREATE TABLE `job_details` (
`id` INT,
`title` VARCHAR(64),
`details` VARCHAR(64),
`coding_task` VARCHAR(64),
`posted_on` DATETIME,
`company` VARCHAR(64),
`location` VARCHAR(64),
`posted_by` VARCHAR(64)
) CHARACTER SET latin1;
