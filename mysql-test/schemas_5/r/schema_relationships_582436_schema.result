CREATE DATABASE `db_582436_schema`;
USE `db_582436_schema`;
CREATE TABLE `votes` (
`observation_id` VARCHAR(64),
`upvotes` INT,
`downvotes` INT,
PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_observations` (
`observation_id` VARCHAR(64),
`user_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`_id` VARCHAR(64),
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `puntuation` (
`observation_id` VARCHAR(64),
`positive` INT,
`negative` INT,
PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;
CREATE TABLE `position` (
`observation_id` VARCHAR(64),
`x_position` INT,
`y_position` INT,
PRIMARY KEY (`observation_id`)
) CHARACTER SET latin1;
CREATE TABLE `policy` (
`_id` VARCHAR(64),
`_Policy__formula` VARCHAR(64),
`max_level` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `observation` (
`_id` VARCHAR(64),
`state` VARCHAR(64),
`image_id` VARCHAR(64),
`brightness` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `image` (
`_id` VARCHAR(64),
`x_size` INT,
`y_size` INT,
`probability` INT,
`fwhm` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
