INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 531449_init
#
CREATE DATABASE `db_531449_init`;
USE `db_531449_init`;
CREATE TABLE `clientes` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`documento` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `endereco` (
`id` INT NOT NULL,
`idCliente` INT,
`endereco` VARCHAR(50),
`principal` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `telefone` (
`id` INT NOT NULL,
`idCliente` INT,
`telefone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_531449_init') AS relationships;
relationships
