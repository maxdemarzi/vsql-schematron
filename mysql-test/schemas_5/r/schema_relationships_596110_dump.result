INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 596110_dump
#
CREATE DATABASE `db_596110_dump`;
USE `db_596110_dump`;
CREATE TABLE `post` (
`postId` VARCHAR(255),
`postUserId` VARCHAR(255),
`body` VARCHAR(255),
`title` VARCHAR(255),
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`userId` VARCHAR(255),
`email` VARCHAR(255),
`name` VARCHAR(255),
`phone` VARCHAR(255),
`username` VARCHAR(255),
`website` VARCHAR(255),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_596110_dump') AS relationships;
