[Implied]  project.major_id -> major.id
[Implied]  project_course.course_id -> course.id
[Implied]  project_course.project_id -> project.id
[Implied]  student.class_id -> classes.id
[Implied]  teach.class_id -> classes.id
[Implied]  teach.course_id -> course.id
[Implied]  teach.instructor_id -> instructor.id

DROP DATABASE `db_590724_model`;
UNINSTALL EXTENSION vsql_schematron;
