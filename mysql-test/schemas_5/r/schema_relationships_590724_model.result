INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 590724_model
#
CREATE DATABASE `db_590724_model`;
USE `db_590724_model`;
CREATE TABLE `department` (
`id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `major` (
`id` VARCHAR(64),
`dept_id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classes` (
`id` VARCHAR(64),
`major_id` VARCHAR(64),
`grade_year` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `student` (
`id` VARCHAR(64),
`class_id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instructor` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`optional` VARCHAR(64),
`opt_credit` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT,
`major_id` VARCHAR(64),
`grade_year` VARCHAR(64),
`planning_year` VARCHAR(64),
`opt_credit` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_course` (
`project_id` INT,
`course_id` VARCHAR(64),
`type` INT,
`credit` DECIMAL(10,2),
PRIMARY KEY (`project_id`, `course_id`)
) CHARACTER SET latin1;
CREATE TABLE `grade` (
`student_id` VARCHAR(64),
`course_id` VARCHAR(64),
`score` DECIMAL(10,2),
PRIMARY KEY (`student_id`, `course_id`)
) CHARACTER SET latin1;
CREATE TABLE `teach` (
`class_id` VARCHAR(64),
`instructor_id` INT,
`course_id` VARCHAR(64),
PRIMARY KEY (`class_id`, `instructor_id`, `course_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_590724_model') AS relationships;
relationships
Database: db_590724_model

