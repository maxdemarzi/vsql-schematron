INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 577101_dbsales
#
CREATE DATABASE `db_577101_dbsales`;
USE `db_577101_dbsales`;
CREATE TABLE `customers` (
`customerNumber` INT NOT NULL,
`customerName` VARCHAR(50),
`contactLastName` VARCHAR(50),
`contactFirstName` VARCHAR(50),
`phone` VARCHAR(50),
`addressLine1` VARCHAR(50),
`addressLine2` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`postalCode` VARCHAR(50),
`country` VARCHAR(50),
`creditLimit` DOUBLE,
PRIMARY KEY (`customerNumber`)
) CHARACTER SET latin1;
CREATE TABLE `orderdetails` (
`orderNumber` INT NOT NULL,
`productCode` VARCHAR(50) NOT NULL,
`quantityOrdered` INT,
`priceEach` DOUBLE,
`orderLineNumber` SMALLINT,
PRIMARY KEY (`orderNumber`, `productCode`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`productCode` VARCHAR(50) NOT NULL,
`productName` VARCHAR(50),
`productLine` VARCHAR(50),
`productScale` VARCHAR(50),
`productVendor` VARCHAR(50),
`productDescription` TEXT,
`quantityInStock` SMALLINT,
`buyPrice` DOUBLE,
`MSRP` DOUBLE,
PRIMARY KEY (`productCode`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_577101_dbsales') AS relationships;
relationships
