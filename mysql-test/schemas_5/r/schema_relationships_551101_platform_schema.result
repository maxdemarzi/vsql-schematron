INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 551101_platform_schema
#
CREATE DATABASE `db_551101_platform_schema`;
USE `db_551101_platform_schema`;
CREATE TABLE `projects` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` INT,
`name` VARCHAR(255),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(255),
`is_student` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_auth` (
`id` INT,
`token` VARCHAR(255),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students_in_groups` (
`id` INT,
`group_id` INT,
`student_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `integrations` (
`id` INT,
`name` VARCHAR(255),
`comment` VARCHAR(255),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stages` (
`id` INT,
`name` VARCHAR(255),
`start_date` DATETIME,
`end_date` DATETIME,
`comment` VARCHAR(255),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stages_in_integrations` (
`id` INT,
`name` VARCHAR(255),
`order_number` INT,
`stage_id` INT,
`integration_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_551101_platform_schema') AS relationships;
relationships
Database: db_551101_platform_schema

Table Connections:
------------------
[Implied]  groups.project_id -> projects.id
[Implied]  integrations.project_id -> projects.id
[Implied]  stages.project_id -> projects.id
[Implied]  stages_in_integrations.integration_id -> integrations.id
[Implied]  stages_in_integrations.stage_id -> stages.id
[Implied]  students_in_groups.group_id -> groups.id
[Implied]  students_in_groups.student_id -> users.id
[Implied]  users_auth.user_id -> users.id

DROP DATABASE `db_551101_platform_schema`;
UNINSTALL EXTENSION vsql_schematron;
