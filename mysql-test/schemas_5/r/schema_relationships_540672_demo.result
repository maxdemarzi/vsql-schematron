INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 540672_demo
#
CREATE DATABASE `db_540672_demo`;
USE `db_540672_demo`;
CREATE TABLE `languages` (
`lang_id` BIGINT NOT NULL,
`name` TEXT,
`code` TEXT,
PRIMARY KEY (`lang_id`)
) CHARACTER SET latin1;
CREATE TABLE `wordtypes` (
`wordtype_id` BIGINT NOT NULL,
`name` TEXT,
PRIMARY KEY (`wordtype_id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`tag_id` BIGINT NOT NULL,
`name` TEXT,
PRIMARY KEY (`tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
`entry_id` BIGINT NOT NULL,
`headword` TEXT,
`wordtype` BIGINT,
`definition` TEXT,
`hw_lang` BIGINT,
`def_lang` BIGINT,
PRIMARY KEY (`entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `entry_tags` (
`tag_id` BIGINT NOT NULL,
`entry_id` BIGINT NOT NULL,
PRIMARY KEY (`tag_id`, `entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`uid` BIGINT NOT NULL,
`username` TEXT,
`hash` TEXT,
`email` TEXT,
`dob` DATE,
`gender` TEXT,
`joindate` TIMESTAMP NULL,
`language` BIGINT,
`fluency` VARCHAR(50),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_540672_demo') AS relationships;
relationships
Database: db_540672_demo

Table Connections:
------------------
[Implied]  entries.def_lang -> languages.lang_id
[Implied]  entries.hw_lang -> languages.lang_id
[Implied]  entries.wordtype -> wordtypes.wordtype_id
[Implied]  entry_tags.entry_id -> entries.entry_id
[Implied]  entry_tags.tag_id -> tags.tag_id
[Implied]  users.language -> languages.lang_id

DROP DATABASE `db_540672_demo`;
UNINSTALL EXTENSION vsql_schematron;
