CREATE DATABASE `db_525667_payment_api`;
USE `db_525667_payment_api`;
CREATE TABLE `merchant` (
`id` INT,
`name` VARCHAR(64),
`code` INT
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`id` INT,
`invoice_id` INT,
`item_name` VARCHAR(64),
`amount` INT,
`payment_type` VARCHAR(64),
`customer_name` VARCHAR(64),
`merchant_id` INT,
`references_id` VARCHAR(64),
`number_va` INT,
`status` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_525667_payment_api') AS relationships;
