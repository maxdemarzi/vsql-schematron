CREATE TABLE `users` (
`_id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`affiliation` VARCHAR(64),
`points` INT,
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `shoutouts` (
`_id` INT,
`contents` VARCHAR(64),
`sender_id` INT,
`recipient_id` INT,
`timestamp` VARCHAR(64),
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
CREATE TABLE `stats` (
`totalShoutouts` INT,
`lastShoutoutId` VARCHAR(64),
`lastShoutoutTimestamp` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`_id` INT,
`user_id` INT,
`token` VARCHAR(64),
PRIMARY KEY (`_id`)
) CHARACTER SET latin1;
