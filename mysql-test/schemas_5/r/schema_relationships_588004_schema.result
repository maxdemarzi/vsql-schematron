INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 588004_schema
#
CREATE DATABASE `db_588004_schema`;
USE `db_588004_schema`;
CREATE TABLE `users` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`status` VARCHAR(64),
`date_added` DATETIME,
`profile_pic` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `urls` (
`suffix` VARCHAR(64),
`short_url` VARCHAR(64),
`long_url` VARCHAR(64),
`user_id` VARCHAR(64),
`description` VARCHAR(64),
`date_added` DATETIME,
`date_expire` DATETIME,
PRIMARY KEY (`suffix`)
) CHARACTER SET latin1;
CREATE TABLE `click_log` (
`date_added` DATETIME,
`click_source` VARCHAR(64),
`suffix_id` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588004_schema') AS relationships;
