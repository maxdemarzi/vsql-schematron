[Implied]  order_items.order_id -> orders.id
[Implied]  order_items.product_id -> products.id
[Implied]  orders.user_id -> users.id
[Implied]  products.category_id -> categories.id
[Implied]  products.user_id -> users.id

DROP DATABASE `db_545270_digibook`;
UNINSTALL EXTENSION vsql_schematron;
