[Implied]  relation.albumid -> album.albumid
[Implied]  relation.eleid -> ele.eleid
[Implied]  user_relation.userid -> album_user.userid

DROP DATABASE `db_533298_schema`;
UNINSTALL EXTENSION vsql_schematron;
