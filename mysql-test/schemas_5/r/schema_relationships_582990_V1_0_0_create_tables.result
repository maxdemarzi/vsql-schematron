PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CONTACT` (
`ID` INT,
`PERSON` INT,
`CONTACT_TYPE` INT,
`VALUE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
