CREATE TABLE `rok` (
`id` INT NOT NULL,
`rok` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `film_zanr` (
`idfilm` INT,
`idzanr` INT
) CHARACTER SET latin1;
