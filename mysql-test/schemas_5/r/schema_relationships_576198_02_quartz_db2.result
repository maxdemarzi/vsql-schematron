CREATE DATABASE `db_576198_02_quartz_db2`;
USE `db_576198_02_quartz_db2`;
CREATE TABLE `QRTZ_JOB_DETAILS` (
`SCHED_NAME` VARCHAR(255),
`JOB_NAME` VARCHAR(255),
`JOB_GROUP` VARCHAR(255),
`DESCRIPTION` VARCHAR(255),
`JOB_CLASS_NAME` VARCHAR(255),
`IS_DURABLE` INT,
`IS_NONCONCURRENT` INT,
`IS_UPDATE_DATA` INT,
`REQUESTS_RECOVERY` INT,
`JOB_DATA` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`JOB_NAME` VARCHAR(255),
`JOB_GROUP` VARCHAR(255),
`DESCRIPTION` VARCHAR(255),
`NEXT_FIRE_TIME` INT,
`PREV_FIRE_TIME` INT,
`PRIORITY` INT,
`TRIGGER_STATE` VARCHAR(255),
`TRIGGER_TYPE` VARCHAR(255),
`START_TIME` INT,
`END_TIME` INT,
`CALENDAR_NAME` VARCHAR(255),
`MISFIRE_INSTR` INT,
`JOB_DATA` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_SIMPLE_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`REPEAT_COUNT` INT,
`REPEAT_INTERVAL` INT,
`TIMES_TRIGGERED` INT,
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_CRON_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`CRON_EXPRESSION` VARCHAR(255),
`TIME_ZONE_ID` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_SIMPROP_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`STR_PROP_1` VARCHAR(255),
`STR_PROP_2` VARCHAR(255),
`STR_PROP_3` VARCHAR(255),
`INT_PROP_1` INT,
`INT_PROP_2` INT,
`LONG_PROP_1` INT,
`LONG_PROP_2` INT,
`DEC_PROP_1` DECIMAL(10,2),
`DEC_PROP_2` DECIMAL(10,2),
`BOOL_PROP_1` VARCHAR(255),
`BOOL_PROP_2` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_BLOB_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`BLOB_DATA` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_CALENDARS` (
`SCHED_NAME` VARCHAR(255),
`CALENDAR_NAME` VARCHAR(255),
`CALENDAR` VARCHAR(255),
PRIMARY KEY (`CALENDAR_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_FIRED_TRIGGERS` (
`SCHED_NAME` VARCHAR(255),
`ENTRY_ID` VARCHAR(255),
`TRIGGER_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
`INSTANCE_NAME` VARCHAR(255),
`FIRED_TIME` INT,
`SCHED_TIME` INT,
`PRIORITY` INT,
`STATE` VARCHAR(255),
`JOB_NAME` VARCHAR(255),
`JOB_GROUP` VARCHAR(255),
`IS_NONCONCURRENT` INT,
`REQUESTS_RECOVERY` INT,
PRIMARY KEY (`SCHED_NAME`, `ENTRY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_PAUSED_TRIGGER_GRPS` (
`SCHED_NAME` VARCHAR(255),
`TRIGGER_GROUP` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_SCHEDULER_STATE` (
`SCHED_NAME` VARCHAR(255),
`INSTANCE_NAME` VARCHAR(255),
`LAST_CHECKIN_TIME` INT,
`CHECKIN_INTERVAL` INT,
PRIMARY KEY (`SCHED_NAME`, `INSTANCE_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `QRTZ_LOCKS` (
`SCHED_NAME` VARCHAR(255),
`LOCK_NAME` VARCHAR(255),
PRIMARY KEY (`SCHED_NAME`, `LOCK_NAME`)
) CHARACTER SET latin1;
