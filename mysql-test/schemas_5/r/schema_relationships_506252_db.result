CREATE DATABASE `db_506252_db`;
USE `db_506252_db`;
CREATE TABLE `detail_servis` (
`tglServisTerakhir` DATETIME,
`tglServisSelanjutnya` DATETIME,
`noRangka` VARCHAR(64),
`kilometer` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `mobil` (
`noRangka` VARCHAR(64),
`model` VARCHAR(64),
`noMesin` VARCHAR(64),
`noPolisi` VARCHAR(64),
`deliveryDate` DATETIME,
`id` INT
) CHARACTER SET latin1;
CREATE TABLE `pelanggan` (
`id` INT,
`nama` VARCHAR(64),
`alamat` VARCHAR(64),
`telepon` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `riwayat` (
`idRiwayatBooking` INT,
`noRangka` VARCHAR(64),
`tanggalServis` DATETIME,
`kilometer` INT,
`namaBooking` VARCHAR(64),
`noTeleponBooking` VARCHAR(64),
`jamBooking` VARCHAR(64),
`status` INT,
`done` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_506252_db') AS relationships;
