CREATE DATABASE `db_582540_25_RSS_Feeds`;
USE `db_582540_25_RSS_Feeds`;
CREATE TABLE `channels` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` TEXT,
`link` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`description` TEXT,
`content` TEXT,
`link` VARCHAR(50),
`is_read` BOOLEAN,
`timestamp` TIMESTAMP NULL,
`channel` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_582540_25_RSS_Feeds') AS relationships;
