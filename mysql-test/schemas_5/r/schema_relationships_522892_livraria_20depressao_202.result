`idEditora` INT,
`nomeLivro` VARCHAR(50),
`isbn` VARCHAR(50),
`qtd` INT,
`precoUnidade` DOUBLE,
PRIMARY KEY (`idLivro`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVA` (
`idReserva` INT NOT NULL,
`idCliente` INT,
`idFuncionario` INT,
`idLivro` INT,
`idEmprestimo` INT,
`dataReserva` DATETIME,
`dataRetiradaPrevista` DATETIME,
`dataRetirada` DATETIME,
`statusReserva` VARCHAR(50),
PRIMARY KEY (`idReserva`)
) CHARACTER SET latin1;
CREATE TABLE `TIPOS_MULTA` (
`idTipoMulta` INT NOT NULL,
`nomeTipo` VARCHAR(50),
`valor` DOUBLE,
PRIMARY KEY (`idTipoMulta`)
) CHARACTER SET latin1;
CREATE TABLE `MULTA` (
`idMulta` INT NOT NULL,
`idTipoMulta` INT,
`idEmprestimo` INT,
`idFuncionario` INT,
`observacoes` VARCHAR(50),
`statusMulta` VARCHAR(50),
`totalMulta` DOUBLE,
PRIMARY KEY (`idMulta`)
) CHARACTER SET latin1;
