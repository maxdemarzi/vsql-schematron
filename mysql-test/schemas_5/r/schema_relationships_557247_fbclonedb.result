CREATE DATABASE `db_557247_fbclonedb`;
USE `db_557247_fbclonedb`;
CREATE TABLE `fbclonedb.users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.posts` (
`id` INT NOT NULL,
`content` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.comments` (
`id` INT NOT NULL,
`content` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`post_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fbclonedb.likes` (
`id` INT NOT NULL,
`like` TINYINT,
`created_at` DATETIME,
`updated_at` DATETIME,
`user_id` INT,
`post_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
