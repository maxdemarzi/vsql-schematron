CREATE DATABASE `db_501605_schema`;
USE `db_501605_schema`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_to_groups` (
`user_id` VARCHAR(50),
`group_id` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_501605_schema') AS relationships;
