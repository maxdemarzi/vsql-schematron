INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 571578_InitPSQLDB
#
CREATE DATABASE `db_571578_InitPSQLDB`;
USE `db_571578_InitPSQLDB`;
CREATE TABLE `repositories` (
`full_name` VARCHAR(255),
`is_uptodate` VARCHAR(255),
`latest_commit` VARCHAR(255),
`latest_analysed_commit` VARCHAR(255),
`default_branch` VARCHAR(255),
PRIMARY KEY (`full_name`)
) CHARACTER SET latin1;
CREATE TABLE `commits` (
`id` INT,
`repository_full_name` VARCHAR(255),
`commit_sha` VARCHAR(255),
`date_of_commit` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clusters` (
`id` INT,
`centroid_body` VARCHAR(255),
`source` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `methods` (
`id` INT,
`commit_id` INT,
`cluster_id` INT,
`filepath` VARCHAR(255),
`body` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `arules` (
`id` INT,
`les` VARCHAR(255),
`res` INT,
`support` DECIMAL(10,2),
`confidence` DECIMAL(10,2),
`lift` DECIMAL(10,2),
`ar_count` INT,
`sensitivity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
`execution_date` DATETIME,
`number_new_repositories` INT,
`number_updated_repositories` INT,
PRIMARY KEY (`execution_date`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_571578_InitPSQLDB') AS relationships;
relationships
Database: db_571578_InitPSQLDB

Table Connections:
------------------
[Implied]  commits.repository_full_name -> repositories.full_name
[Implied]  methods.cluster_id -> clusters.id
[Implied]  methods.commit_id -> commits.id

DROP DATABASE `db_571578_InitPSQLDB`;
UNINSTALL EXTENSION vsql_schematron;
