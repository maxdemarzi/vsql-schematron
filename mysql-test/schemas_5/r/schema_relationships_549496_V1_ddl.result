CREATE DATABASE `db_549496_V1_ddl`;
USE `db_549496_V1_ddl`;
CREATE TABLE `teacher` (
`id` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(64),
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`activated` BOOL,
`activation_key` VARCHAR(64),
`phone_number` VARCHAR(64),
`reset_key` VARCHAR(64),
`reset_date` DATETIME,
`verification_phone_code` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`role_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`role_name`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `town` (
`postcode` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`postcode`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` VARCHAR(64),
`road` VARCHAR(64),
`post_box` INT,
`house_number` INT,
`postcode` INT,
`user_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `models_options` (
`option_code` VARCHAR(64),
`seats_number` INT,
`has_air_conditioner` BOOL,
`is_automatic` BOOL,
`bags_number` INT,
`created_at` DATETIME,
PRIMARY KEY (`option_code`)
) CHARACTER SET latin1;
CREATE TABLE `pricing_class` (
`class_name` VARCHAR(64),
`daily_fine` INT,
`price_by_km` INT,
`allowed_km_per_day` INT,
`cost_per_day` INT,
`created_at` DATETIME,
PRIMARY KEY (`class_name`)
) CHARACTER SET latin1;
CREATE TABLE `models` (
`id` VARCHAR(64),
`model_type` VARCHAR(64),
`brand` VARCHAR(64),
`created_at` DATETIME,
`model_option` VARCHAR(64),
`pricing_class` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` VARCHAR(64),
`license_plate` VARCHAR(64),
`made_in_year` INT,
`purchased_price` VARCHAR(64),
`is_damaged` BOOL,
`model_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`id` VARCHAR(64),
`cancellation_date` DATETIME,
`booking_state` VARCHAR(64),
`withdrawal_date` DATETIME,
`return_date` DATETIME,
`user_id` VARCHAR(64),
`car_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rent` (
`id` VARCHAR(64),
`license_number` VARCHAR(64),
`withdrawal_km` INT,
`return_km` INT,
`effective_return_date` DATETIME,
`caution_payment` BOOL,
`booking_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
