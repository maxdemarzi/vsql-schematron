INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 538441_employeeManagement
#
CREATE DATABASE `db_538441_employeeManagement`;
USE `db_538441_employeeManagement`;
CREATE TABLE `departments` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`role_title` VARCHAR(64),
`role_salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_number` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_538441_employeeManagement') AS relationships;
relationships
Database: db_538441_employeeManagement

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_538441_employeeManagement`;
UNINSTALL EXTENSION vsql_schematron;
