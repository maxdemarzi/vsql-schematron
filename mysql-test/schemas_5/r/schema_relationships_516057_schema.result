INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 516057_schema
#
CREATE DATABASE `db_516057_schema`;
USE `db_516057_schema`;
CREATE TABLE `users` (
`user_id` INT,
`login` VARCHAR(255),
`password` VARCHAR(255),
`role_id` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT,
`role` VARCHAR(255),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `client_accounts` (
`client_account_id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`telephone` VARCHAR(255),
`user_id` INT,
PRIMARY KEY (`client_account_id`)
) CHARACTER SET latin1;
CREATE TABLE `manager_accounts` (
`manager_account_id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`telephone` VARCHAR(255),
`user_id` INT,
PRIMARY KEY (`manager_account_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`car_id` INT,
`client_account_id` INT,
`description` VARCHAR(255),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`car_id` INT,
`vin` VARCHAR(255),
`brand` VARCHAR(255),
`model` VARCHAR(255),
`production_year` VARCHAR(255),
`registration_number` VARCHAR(255),
`description` VARCHAR(255),
`client_account_id` INT,
PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_516057_schema') AS relationships;
relationships
Database: db_516057_schema

Table Connections:
------------------
[Implied]  cars.client_account_id -> client_accounts.client_account_id
[Implied]  client_accounts.user_id -> users.user_id
[Implied]  manager_accounts.user_id -> users.user_id
[Implied]  orders.car_id -> cars.car_id
[Implied]  orders.client_account_id -> client_accounts.client_account_id
[Implied]  users.role_id -> roles.role_id

DROP DATABASE `db_516057_schema`;
UNINSTALL EXTENSION vsql_schematron;
