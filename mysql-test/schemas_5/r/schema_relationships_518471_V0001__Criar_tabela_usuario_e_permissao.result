CREATE TABLE `permissao` (
`id` BIGINT NOT NULL,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario_permissao` (
`id_usuario` BIGINT NOT NULL,
`id_permissao` BIGINT NOT NULL,
PRIMARY KEY (`id_usuario`, `id_permissao`)
) CHARACTER SET latin1;
