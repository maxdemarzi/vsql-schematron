INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 552515_books_authors
#
CREATE DATABASE `db_552515_books_authors`;
USE `db_552515_books_authors`;
CREATE TABLE `Authors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`country` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Books` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BooksAuthors` (
`author_id` INT,
`book_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_552515_books_authors') AS relationships;
relationships
Database: db_552515_books_authors

Table Connections:
------------------
[Implied]  BooksAuthors.author_id -> Authors.id
[Implied]  BooksAuthors.book_id -> Books.id

DROP DATABASE `db_552515_books_authors`;
UNINSTALL EXTENSION vsql_schematron;
