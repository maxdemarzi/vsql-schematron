INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 515406_mysql_schema
#
CREATE DATABASE `db_515406_mysql_schema`;
USE `db_515406_mysql_schema`;
CREATE TABLE `address` (
`id` INT,
`address` VARCHAR(64),
`number` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`random` VARCHAR(64),
`age` INT,
`thing` INT,
`address_id` INT,
`occured_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `numeric_types` (
`id` INT,
`int_type` INT,
`smallint_type` INT,
`tinint_type` INT,
`mediumint_type` INT,
`bigint_type` INT,
`decimal_type` DECIMAL(10,2),
`demical_2_type` DECIMAL(10,2),
`float_type` DECIMAL(10,2),
`double_type` DECIMAL(10,2),
`bit_type` VARCHAR(64),
`unsigned_int_type` INT,
`unsigned_tinyint_type` INT,
`unsigned_bigint_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `date_types` (
`id` INT,
`date_type` DATETIME,
`datetime_type` DATETIME,
`timestamp_type` DATETIME,
`time_type` DATETIME,
`year_type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `string_types` (
`id` INT,
`char_type` VARCHAR(64),
`binary_type` VARCHAR(64),
`text_type` VARCHAR(64),
`blob_type` VARCHAR(64),
`varchar_type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `no_auto_increment` (
`id` INT,
`text` VARCHAR(64),
`address_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_515406_mysql_schema') AS relationships;
