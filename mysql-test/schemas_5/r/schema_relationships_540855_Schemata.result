INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 540855_Schemata
#
CREATE DATABASE `db_540855_Schemata`;
USE `db_540855_Schemata`;
CREATE TABLE `Department` (
`dept_no` VARCHAR(255),
`dept_name` VARCHAR(255),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
`emp_no` INT,
`birth_date` DATETIME,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`gender` VARCHAR(255),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `Dept_Emp` (
`emp_no` INT,
`dept_no` VARCHAR(255),
`from_date` DATETIME,
`to_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Dept_Managers` (
`dept_no` VARCHAR(255),
`emp_no` INT,
`from_date` DATETIME,
`to_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Salaries` (
`emp_no` INT,
`salary` INT,
`from_date` DATETIME,
`to_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Titles` (
`emp_no` INT,
`title` VARCHAR(255),
`from_date` DATETIME,
`to_date` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_540855_Schemata') AS relationships;
relationships
Database: db_540855_Schemata

Table Connections:
------------------
[Implied]  Dept_Emp.dept_no -> Department.dept_no
[Implied]  Dept_Emp.emp_no -> Employee.emp_no
[Implied]  Dept_Managers.dept_no -> Department.dept_no
[Implied]  Dept_Managers.emp_no -> Employee.emp_no
[Implied]  Salaries.emp_no -> Employee.emp_no
[Implied]  Titles.emp_no -> Employee.emp_no

DROP DATABASE `db_540855_Schemata`;
UNINSTALL EXTENSION vsql_schematron;
