INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 576470_Base
#
CREATE DATABASE `db_576470_Base`;
USE `db_576470_Base`;
CREATE TABLE `admin` (
`idadmin` INT NOT NULL,
`nom` VARCHAR(50),
`login` VARCHAR(50),
`mdp` VARCHAR(50),
PRIMARY KEY (`idadmin`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`iduser` INT NOT NULL,
`login` VARCHAR(50),
`nom` VARCHAR(50),
`prenom` VARCHAR(50),
`mdp` VARCHAR(50),
PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `categorie` (
`idcategorie` INT NOT NULL,
`nom` VARCHAR(50),
`icone` VARCHAR(50),
PRIMARY KEY (`idcategorie`)
) CHARACTER SET latin1;
CREATE TABLE `contenu` (
`idcontenu` INT NOT NULL,
`daty` DATE,
`titre` VARCHAR(50),
`categories` VARCHAR(50),
`typee` VARCHAR(50),
`texte` VARCHAR(50),
`photo` VARCHAR(50),
`video` VARCHAR(50),
`audio` VARCHAR(50),
`pdf` VARCHAR(50),
`etat` VARCHAR(50),
`visites` INT,
`prix` DOUBLE,
`iduser` INT,
`idadmin` INT,
`auteur` VARCHAR(50),
PRIMARY KEY (`idcontenu`)
) CHARACTER SET latin1;
CREATE TABLE `geolocalisation` (
`idcontenu` INT,
`latitude` DOUBLE,
`longitude` DOUBLE
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_576470_Base') AS relationships;
relationships
Database: db_576470_Base

Table Connections:
------------------
[Implied]  contenu.idadmin -> admin.idadmin
[Implied]  contenu.iduser -> user.iduser
[Implied]  geolocalisation.idcontenu -> contenu.idcontenu

DROP DATABASE `db_576470_Base`;
UNINSTALL EXTENSION vsql_schematron;
