INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 510333_V5__temperature_sensor
#
CREATE DATABASE `db_510333_V5_temperature_sensor`;
USE `db_510333_V5_temperature_sensor`;
CREATE TABLE `temperature_sensors` (
`id` INT,
`zone_id` INT,
`name` VARCHAR(64),
`min` DECIMAL(10,2),
`max` DECIMAL(10,2),
`active` BOOL,
`channel_id` INT,
`api_key` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `temperatures` (
`id` INT,
`sensor_id` INT,
`time` DATETIME,
`temperature` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_510333_V5_temperature_sensor') AS relationships;
