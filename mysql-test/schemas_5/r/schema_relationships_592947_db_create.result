PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `receipt` (
`id` INT,
`user_id` INT,
`status_id` INT,
`total` INT,
`manager_id` INT,
`create_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
