CREATE DATABASE `db_551897_Create_Datebase`;
USE `db_551897_Create_Datebase`;
CREATE TABLE `households` (
`hh_id` INT,
`hh_race` INT,
`hh_is_latinx` INT,
`hh_zip_code` INT,
`hh_state` VARCHAR(255),
`hh_income` INT,
`hh_size` INT,
`hh_residence_type` INT,
PRIMARY KEY (`hh_id`)
) CHARACTER SET latin1;
CREATE TABLE `trips` (
`hh_id` INT,
`TC_date` DATETIME,
`TC_retailer_code` INT,
`TC_retailer_code_store_code` INT,
`TC_retailer_code_store_zip3` INT,
`TC_total_spent` DECIMAL(10,2),
`TC_id` INT,
PRIMARY KEY (`TC_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`brand_at_prod_id` VARCHAR(255),
`department_at_prod_id` VARCHAR(255),
`prod_id` INT,
`group_at_prod_id` VARCHAR(255),
`module_at_prod_id` VARCHAR(255),
`amount_at_prod_id` DECIMAL(10,2),
`units_at_prod_id` VARCHAR(255),
PRIMARY KEY (`prod_id`)
) CHARACTER SET latin1;
CREATE TABLE `purchases` (
`TC_id` INT,
`quantity_at_TC_prod_id` INT,
`total_price_paid_at_TC_prod_id` DECIMAL(10,2),
`coupon_value_at_TC_prod_id` DECIMAL(10,2),
`deal_flag_at_TC_prod_id` INT,
`prod_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_551897_Create_Datebase') AS relationships;
