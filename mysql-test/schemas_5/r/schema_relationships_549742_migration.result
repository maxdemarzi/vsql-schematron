CREATE TABLE `User` (
`id` INT,
`bio` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`lastLogin` VARCHAR(64),
`isAdmin` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Follow` (
`userId` INT,
`followerId` INT,
`followedAt` VARCHAR(64),
PRIMARY KEY (`followerId`, `userId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`contentType` VARCHAR(64),
`visibility` VARCHAR(64),
`authorId` INT,
`createdAt` VARCHAR(64),
`updatedAt` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`name` VARCHAR(64),
`postId` INT,
PRIMARY KEY (`name`, `postId`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`id` INT,
`postId` INT,
`authorId` INT,
`content` VARCHAR(64),
`createdAt` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Like` (
`postId` INT,
`authorId` INT,
PRIMARY KEY (`postId`, `authorId`)
) CHARACTER SET latin1;
