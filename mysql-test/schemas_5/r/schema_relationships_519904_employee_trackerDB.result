INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 519904_employee_trackerDB
#
CREATE DATABASE `db_519904_employee_trackerDB`;
USE `db_519904_employee_trackerDB`;
CREATE TABLE `department` (
`id` INT,
`department` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_519904_employee_trackerDB') AS relationships;
relationships
Database: db_519904_employee_trackerDB

Table Connections:
