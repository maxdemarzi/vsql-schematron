INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 500532_sqlscript
#
CREATE DATABASE `db_500532_sqlscript`;
USE `db_500532_sqlscript`;
CREATE TABLE `Users` (
`id` INT,
`name` VARCHAR(64),
`pw` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Questions` (
`id` INT,
`header` VARCHAR(64),
`question` VARCHAR(64),
`userId` INT,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Answers` (
`id` INT,
`userId` INT,
`questionId` INT,
`answer` VARCHAR(64),
`accepted` BOOL,
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comments` (
`id` INT,
`answerId` INT,
`userId` INT,
`comment` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `QuestionTags` (
`id` INT,
`questionId` INT,
`tag` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `QuestionVotes` (
`id` INT,
`questionId` INT,
`voterId` INT,
`isUpvote` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AnswerVotes` (
`id` INT,
`answerId` INT,
`voterId` INT,
`isUpvote` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CommentVotes` (
`id` INT,
`commentId` INT,
`voterId` INT,
`isUpvote` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_500532_sqlscript') AS relationships;
relationships
