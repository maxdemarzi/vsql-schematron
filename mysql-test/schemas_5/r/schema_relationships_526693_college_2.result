INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 526693_college_2
#
CREATE DATABASE `db_526693_college_2`;
USE `db_526693_college_2`;
CREATE TABLE `professors` (
`prof_id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
PRIMARY KEY (`prof_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`student_id` VARCHAR(64),
`name` VARCHAR(64),
`gpa` DECIMAL(10,2),
`address` VARCHAR(64),
`phone` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`course_id` INT,
`course_name` VARCHAR(64),
`required` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `teaches` (
`prof_id` INT,
`course_id` INT,
`year` INT,
PRIMARY KEY (`prof_id`, `course_id`)
) CHARACTER SET latin1;
CREATE TABLE `takes` (
`course_id` INT,
`student_id` VARCHAR(64),
`grade` VARCHAR(64),
`year` INT,
PRIMARY KEY (`student_id`, `course_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_526693_college_2') AS relationships;
relationships
Database: db_526693_college_2

Table Connections:
------------------
[Implied]  takes.course_id -> courses.course_id
[Implied]  takes.student_id -> students.student_id
[Implied]  teaches.course_id -> courses.course_id
[Implied]  teaches.prof_id -> professors.prof_id

DROP DATABASE `db_526693_college_2`;
UNINSTALL EXTENSION vsql_schematron;
