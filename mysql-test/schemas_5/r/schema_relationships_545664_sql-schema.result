INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 545664_sql-schema
#
CREATE DATABASE `db_545664_sql_schema`;
USE `db_545664_sql_schema`;
CREATE TABLE `imstest.customers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `imstest.items` (
`item_id` INT NOT NULL,
`name` VARCHAR(50),
`value` DECIMAL(10,2),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `imstest.orders` (
`orders_id` INT NOT NULL,
`customer_id` INT,
PRIMARY KEY (`orders_id`)
) CHARACTER SET latin1;
CREATE TABLE `imstest.orders_items` (
`orders_items_id` INT NOT NULL,
`orders_id` INT,
`item_id` INT,
PRIMARY KEY (`orders_items_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_545664_sql_schema') AS relationships;
