INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 539151_Schema
#
CREATE DATABASE `db_539151_Schema`;
USE `db_539151_Schema`;
CREATE TABLE `questions` (
`id` INT,
`product_id` INT,
`body` VARCHAR(64),
`date_written` DATETIME,
`asker_name` VARCHAR(64),
`asker_email` VARCHAR(64),
`reported` INT,
`helpful` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
`id` INT,
`question_id` INT,
`body` VARCHAR(64),
`date_written` DATETIME,
`answerer_name` VARCHAR(64),
`answerer_email` VARCHAR(64),
`reported` INT,
`helpful` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answerphotos` (
`id` INT,
`answer_id` INT,
`url` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_539151_Schema') AS relationships;
relationships
