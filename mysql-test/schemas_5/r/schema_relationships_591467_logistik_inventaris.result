CREATE DATABASE `db_591467_logistik_inventaris`;
USE `db_591467_logistik_inventaris`;
CREATE TABLE `barang` (
`id` INT,
`kode` VARCHAR(64),
`nm_barang` VARCHAR(64),
`jml` INT,
`jenis_id` INT,
`ruangan_id` INT,
`ket` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `hilang` (
`id` INT,
