`kode` VARCHAR(64),
`nm_logistik` VARCHAR(64),
`jml` INT,
`jenis_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `masuk` (
`id` INT,
`logistik_id` INT,
`jml` INT,
`tgl` DATETIME,
`ket` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ruangan` (
`id` INT,
`nm_ruangan` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rusak` (
`id` INT,
`logistik_id` INT,
`jml` INT,
`tgl` DATETIME,
`ket` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
