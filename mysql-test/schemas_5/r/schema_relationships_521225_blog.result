INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 521225_blog
#
CREATE DATABASE `db_521225_blog`;
USE `db_521225_blog`;
CREATE TABLE `blog_entries` (
`id` INT,
`url` VARCHAR(64),
`status` VARCHAR(64),
`posted` INT,
`title` VARCHAR(64),
`markdown` VARCHAR(64),
`content` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blog_tags` (
`id` INT,
`name` VARCHAR(64),
`count` INT,
`lastused` INT,
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blog_entrytags` (
`tag` INT,
`entry` INT,
PRIMARY KEY (`tag`, `entry`)
) CHARACTER SET latin1;
CREATE TABLE `blog_comments` (
`id` INT,
`entry` INT,
`posted` INT,
`user` INT,
`name` VARCHAR(64),
`contacturl` VARCHAR(64),
`html` VARCHAR(64),
`markdown` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_521225_blog') AS relationships;
relationships
Database: db_521225_blog

Table Connections:
------------------
[Implied]  blog_comments.entry -> blog_entries.id
[Implied]  blog_comments.entry -> blog_entrytags.entry
[Implied]  blog_entrytags.entry -> blog_entries.id
[Implied]  blog_entrytags.tag -> blog_tags.id

DROP DATABASE `db_521225_blog`;
UNINSTALL EXTENSION vsql_schematron;
