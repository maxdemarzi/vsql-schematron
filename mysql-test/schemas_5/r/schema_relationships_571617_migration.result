CREATE DATABASE `db_571617_migration`;
USE `db_571617_migration`;
CREATE TABLE `accounts` (
`id` INT,
`compound_id` VARCHAR(64),
`user_id` INT,
`provider_type` VARCHAR(64),
`provider_id` VARCHAR(64),
`provider_account_id` VARCHAR(64),
`refresh_token` VARCHAR(64),
`access_token` VARCHAR(64),
`access_token_expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`id` INT,
`user_id` INT,
`expires` DATETIME,
`session_token` VARCHAR(64),
`access_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `verification_requests` (
`id` INT,
`identifier` VARCHAR(64),
`token` VARCHAR(64),
`expires` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified` DATETIME,
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lichess` (
`id` INT,
`lichessId` VARCHAR(64),
`username` VARCHAR(64),
`twitchName` VARCHAR(64),
`title` VARCHAR(64),
`countryCode` VARCHAR(64),
`updatedAt` DATETIME,
`bulletRating` INT,
`bulletProv` BOOL,
`blitzRating` INT,
`blitzProv` BOOL,
`rapidRating` INT,
`rapidProv` BOOL,
`topRating` INT,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LichessToken` (
`id` INT,
`refreshToken` VARCHAR(64),
`accessToken` VARCHAR(64),
`expiresAt` DATETIME,
`lichessDatabaseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Streamer` (
`id` INT,
`name` VARCHAR(64),
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `_LichessToStreamer` (
`A` INT,
`B` INT
) CHARACTER SET latin1;
