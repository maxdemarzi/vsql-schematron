CREATE DATABASE `db_542073_script`;
USE `db_542073_script`;
CREATE TABLE `Member` (
`member_id` VARCHAR(50) NOT NULL,
`nic` VARCHAR(50),
`name` VARCHAR(50),
`address` VARCHAR(50),
`contact` VARCHAR(50),
PRIMARY KEY (`member_id`)
) CHARACTER SET latin1;
CREATE TABLE `Issue` (
`member_id` VARCHAR(50),
`book_id` VARCHAR(50),
`issue_id` INT NOT NULL,
`date` DATE,
`detail` VARCHAR(50),
PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`user_id` INT NOT NULL,
`name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_542073_script') AS relationships;
