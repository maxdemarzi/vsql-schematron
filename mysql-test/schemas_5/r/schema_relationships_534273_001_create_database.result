INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 534273_001_create_database
#
CREATE DATABASE `db_534273_001_create_database`;
USE `db_534273_001_create_database`;
CREATE TABLE `classes` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `codes` (
`id` INT,
`class_id` INT,
`code_string` VARCHAR(64),
`coord_lat` DECIMAL(10,2),
`coord_lon` DECIMAL(10,2),
`date` DATETIME,
`timeslot` DATETIME,
`expiry_datetime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `attendances` (
`code_id` INT,
`student_id` INT,
`description` VARCHAR(64),
`present` INT,
PRIMARY KEY (`code_id`, `student_id`)
) CHARACTER SET latin1;
CREATE TABLE `class_students` (
`class_id` INT,
`student_id` INT,
PRIMARY KEY (`class_id`, `student_id`)
) CHARACTER SET latin1;
CREATE TABLE `class_teachers` (
`class_id` INT,
`teacher_id` INT,
PRIMARY KEY (`class_id`, `teacher_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_534273_001_create_database') AS relationships;
relationships
