INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 554790_schema
#
CREATE DATABASE `db_554790_schema`;
USE `db_554790_schema`;
CREATE TABLE `department` (
`dept_id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`role_id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`emp_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`emp_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_554790_schema') AS relationships;
relationships
Database: db_554790_schema

