INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 535309_up
#
CREATE DATABASE `db_535309_up`;
USE `db_535309_up`;
CREATE TABLE `entrepreneurs` (
`id` INT NOT NULL,
`account_id` INT,
`code` VARCHAR(50),
`name` VARCHAR(50),
`address` VARCHAR(50),
`account_number_country_code` VARCHAR(50),
`account_number_prefix` SMALLINT,
`vat` VARCHAR(50),
`account_number` BIGINT,
`account_bank_code` SMALLINT,
`email` VARCHAR(50),
`phone` VARCHAR(50),
`currency_code` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`settings` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
`id` INT NOT NULL,
`entrepreneur_id` INT,
`code` VARCHAR(50),
`name` VARCHAR(50),
`address` VARCHAR(50),
`vat` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `invoices` (
`id` INT NOT NULL,
`entrepreneur_id` INT,
`contact_id` INT,
`code` VARCHAR(50),
`created` DATE,
`pay_until` DATE,
`payed` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `login_sessions` (
`id` VARCHAR(50) NOT NULL,
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_535309_up') AS relationships;
relationships
Database: db_535309_up

Table Connections:
------------------
[Implied]  contacts.entrepreneur_id -> entrepreneurs.id
[Implied]  entrepreneurs.account_id -> accounts.id
[Implied]  invoices.contact_id -> contacts.id
[Implied]  invoices.entrepreneur_id -> entrepreneurs.id
[Implied]  login_sessions.account_id -> accounts.id

DROP DATABASE `db_535309_up`;
UNINSTALL EXTENSION vsql_schematron;
