INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 583044_data
#
CREATE DATABASE `db_583044_data`;
USE `db_583044_data`;
CREATE TABLE `personajes_peliculas` (
`id_pelicula` INT,
`id_personaje` INT
) CHARACTER SET latin1;
CREATE TABLE `peliculas` (
`id` INT,
`imagen` VARCHAR(50),
`titulo` VARCHAR(50),
`fecha_creacion` TIMESTAMP NULL,
`id_genero` INT,
`id_calificacion` INT
) CHARACTER SET latin1;
CREATE TABLE `calificaciones` (
`id` INT,
`calificacion` INT
) CHARACTER SET latin1;
CREATE TABLE `generos` (
`id` INT,
`nombre` VARCHAR(50),
`imagen` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `personajes` (
`id` INT,
`nombre` VARCHAR(50),
`imagen` VARCHAR(50),
`edad` INT,
`peso` INT,
`historia` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
`id` INT,
`username` VARCHAR(50),
`email` VARCHAR(50),
`passwordd` VARCHAR(50),
`rol` VARCHAR(50),
`lockedd` BOOLEAN,
`enablee` BOOLEAN
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_583044_data') AS relationships;
relationships
Database: db_583044_data

