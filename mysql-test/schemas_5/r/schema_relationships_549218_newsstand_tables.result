CREATE DATABASE `db_549218_newsstand_tables`;
USE `db_549218_newsstand_tables`;
CREATE TABLE `tblAuction` (
`house` INT,
`id` INT,
`item` INT,
`quantity` INT,
`bid` INT,
`buy` INT,
`timeleft` VARCHAR(64),
PRIMARY KEY (`house`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `tblAuctionBonus` (
`house` INT,
`id` INT,
`bonus` INT,
PRIMARY KEY (`house`, `id`, `bonus`)
) CHARACTER SET latin1;
CREATE TABLE `tblAuctionExtra` (
`house` INT,
`id` INT,
`rand` INT,
`seed` INT,
`context` INT,
`lootedlevel` INT,
`level` INT,
PRIMARY KEY (`house`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `tblAuctionPet` (
`house` INT,
`id` INT,
`species` INT,
`breed` INT,
`level` INT,
`quality` INT,
PRIMARY KEY (`house`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `tblAuctionRare` (
`house` INT,
`id` INT,
`prevseen` DATETIME,
PRIMARY KEY (`house`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `tblCaptcha` (
`id` INT,
`race` INT,
`gender` INT,
`helm` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tblDBCCurvePoint` (
`curve` INT,
`step` INT,
`key` DECIMAL(10,2),
`value` DECIMAL(10,2),
PRIMARY KEY (`curve`, `step`)
) CHARACTER SET latin1;
CREATE TABLE `tblDBCItem` (
`id` INT,
