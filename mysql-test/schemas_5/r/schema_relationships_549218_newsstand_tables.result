`auctionable` INT,
`type` INT,
`requiredlevel` INT,
`requiredskill` INT,
`requiredside` VARCHAR(64),
`display` INT,
`othersideitem` INT,
`flags` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tblDBCItemBonus` (
`id` INT,
