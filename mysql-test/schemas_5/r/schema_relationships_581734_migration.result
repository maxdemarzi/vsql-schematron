CREATE DATABASE `db_581734_migration`;
USE `db_581734_migration`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`photoURL` TEXT,
`password` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Invoice` (
`id` VARCHAR(50) NOT NULL,
`billerStreetAddress` TEXT,
`billerCity` TEXT,
`billerZipCode` TEXT,
`billerCountry` TEXT,
`clientName` TEXT,
`clientEmail` TEXT,
`clientStreetAddress` TEXT,
`clientCity` TEXT,
`clientZipCode` TEXT,
`clientCountry` TEXT,
`invoiceDate` TIMESTAMP NULL,
`paymentDueDate` TIMESTAMP NULL,
`createdAt` TIMESTAMP NULL,
`published` BOOLEAN,
`authorId` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `InvoiceItem` (
`id` VARCHAR(50) NOT NULL,
`itemName` TEXT,
`qty` INT,
`price` DOUBLE,
`invoiceId` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_581734_migration') AS relationships;
