INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 503915_oracle_create
#
CREATE DATABASE `db_503915_oracle_create`;
USE `db_503915_oracle_create`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(64),
`cpa` VARCHAR(64),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `url_mapping` (
`source` VARCHAR(64),
`destination` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `certificate_mapping` (
`id` VARCHAR(64),
`source` VARCHAR(64),
`destination` VARCHAR(64),
`cpa_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`time_stamp` DATETIME,
`cpa_id` VARCHAR(64),
`conversation_id` VARCHAR(64),
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`ref_to_message_id` VARCHAR(64),
`time_to_live` DATETIME,
`persist_time` DATETIME,
`from_party_id` VARCHAR(64),
`from_role` VARCHAR(64),
`to_party_id` VARCHAR(64),
`to_role` VARCHAR(64),
`service` VARCHAR(64),
`action` VARCHAR(64),
`content` VARCHAR(64),
`status` DECIMAL(10,2),
`status_time` DATETIME,
PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`order_nr` DECIMAL(10,2),
`name` VARCHAR(64),
`content_id` VARCHAR(64),
`content_type` VARCHAR(64),
`content` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `delivery_task` (
`cpa_id` VARCHAR(64),
`send_channel_id` VARCHAR(64),
`receive_channel_id` VARCHAR(64),
`message_id` VARCHAR(64),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`is_confidential` DECIMAL(10,2),
`retries` DECIMAL(10,2),
`server_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `delivery_log` (
`message_id` VARCHAR(64),
`time_stamp` DATETIME,
`uri` VARCHAR(64),
`status` DECIMAL(10,2),
`error_message` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `message_event` (
`message_id` VARCHAR(64),
`event_type` DECIMAL(10,2),
`time_stamp` DATETIME,
`processed` DECIMAL(10,2),
PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_503915_oracle_create') AS relationships;
relationships
Database: db_503915_oracle_create

Table Connections:
------------------
[Implied]  certificate_mapping.cpa_id -> cpa.cpa_id
[Implied]  delivery_log.error_message -> message_event.message_id
[Implied]  delivery_log.message_id -> message_event.message_id
[Implied]  delivery_task.cpa_id -> cpa.cpa_id
[Implied]  delivery_task.message_id -> message_event.message_id
[Implied]  ebms_attachment.message_id -> message_event.message_id
[Implied]  ebms_attachment.message_nr -> ebms_message.message_nr
[Implied]  ebms_message.cpa_id -> cpa.cpa_id
[Implied]  ebms_message.message_id -> message_event.message_id
[Implied]  ebms_message.ref_to_message_id -> message_event.message_id

DROP DATABASE `db_503915_oracle_create`;
UNINSTALL EXTENSION vsql_schematron;
