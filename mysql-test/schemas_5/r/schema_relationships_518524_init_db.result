INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 518524_init_db
#
CREATE DATABASE `db_518524_init_db`;
USE `db_518524_init_db`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`nickname` VARCHAR(50),
`reg_time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `decks` (
`id` SMALLINT NOT NULL,
`alias` VARCHAR(50),
`content` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `games` (
`id` BIGINT NOT NULL,
`description` VARCHAR(50),
`deck_id` SMALLINT,
`owner_id` INT,
`started_at` TIMESTAMP NULL,
`revealed_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`id` BIGINT NOT NULL,
`game_id` BIGINT,
`user_id` INT,
`choice` SMALLINT,
`voted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_518524_init_db') AS relationships;
relationships
Database: db_518524_init_db

Table Connections:
------------------
[Implied]  games.deck_id -> decks.id
[Implied]  games.owner_id -> users.id
[Implied]  votes.game_id -> games.id
[Implied]  votes.user_id -> users.id

DROP DATABASE `db_518524_init_db`;
UNINSTALL EXTENSION vsql_schematron;
