`price` INT,
`keyword` VARCHAR(50),
`content` VARCHAR(50),
`image` VARCHAR(50),
`location` VARCHAR(50),
`address` VARCHAR(50),
`created_on` BIGINT,
`modified_on` BIGINT,
`status` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
