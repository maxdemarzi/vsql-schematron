CREATE DATABASE `db_572081_quartz_tables`;
USE `db_572081_quartz_tables`;
CREATE TABLE `qrtz_job_details` (
`SCHED_NAME` VARCHAR(64),
`JOB_NAME` VARCHAR(64),
`JOB_GROUP` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`JOB_CLASS_NAME` VARCHAR(64),
`IS_DURABLE` VARCHAR(64),
`IS_NONCONCURRENT` VARCHAR(64),
`IS_UPDATE_DATA` VARCHAR(64),
`REQUESTS_RECOVERY` VARCHAR(64),
`JOB_DATA` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_triggers` (
`SCHED_NAME` VARCHAR(64),
`TRIGGER_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
`JOB_NAME` VARCHAR(64),
`JOB_GROUP` VARCHAR(64),
`DESCRIPTION` VARCHAR(64),
`NEXT_FIRE_TIME` INT,
`PREV_FIRE_TIME` INT,
`PRIORITY` INT,
`TRIGGER_STATE` VARCHAR(64),
`TRIGGER_TYPE` VARCHAR(64),
`START_TIME` INT,
`END_TIME` INT,
`CALENDAR_NAME` VARCHAR(64),
`MISFIRE_INSTR` INT,
`JOB_DATA` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_simple_trigger` (
`qrtz_simple_trigger_id` INT,
`qrtz_simple_trigger_name` VARCHAR(64),
`qrtz_simple_trigger_group` VARCHAR(64),
`executor_name` VARCHAR(64),
`repeat_count` INT,
`repeat_interval` INT,
`times_triggered` INT,
PRIMARY KEY (`qrtz_simple_trigger_id`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_cron_triggers` (
`SCHED_NAME` VARCHAR(64),
`TRIGGER_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
`CRON_EXPRESSION` VARCHAR(64),
`TIME_ZONE_ID` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_simprop_triggers` (
`SCHED_NAME` VARCHAR(64),
`TRIGGER_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
`STR_PROP_1` VARCHAR(64),
`STR_PROP_2` VARCHAR(64),
`STR_PROP_3` VARCHAR(64),
`INT_PROP_1` INT,
`INT_PROP_2` INT,
`LONG_PROP_1` INT,
`LONG_PROP_2` INT,
`DEC_PROP_1` DECIMAL(10,2),
`DEC_PROP_2` DECIMAL(10,2),
`BOOL_PROP_1` VARCHAR(64),
`BOOL_PROP_2` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_blob_triggers` (
`SCHED_NAME` VARCHAR(64),
`TRIGGER_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
`BLOB_DATA` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_calendars` (
`SCHED_NAME` VARCHAR(64),
`CALENDAR_NAME` VARCHAR(64),
`CALENDAR` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `CALENDAR_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_paused_trigger_grps` (
`SCHED_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_fired_triggers` (
`SCHED_NAME` VARCHAR(64),
`ENTRY_ID` VARCHAR(64),
`TRIGGER_NAME` VARCHAR(64),
`TRIGGER_GROUP` VARCHAR(64),
`INSTANCE_NAME` VARCHAR(64),
`FIRED_TIME` INT,
`SCHED_TIME` INT,
`PRIORITY` INT,
`STATE` VARCHAR(64),
`JOB_NAME` VARCHAR(64),
`JOB_GROUP` VARCHAR(64),
`IS_NONCONCURRENT` VARCHAR(64),
`REQUESTS_RECOVERY` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `ENTRY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_scheduler_state` (
`SCHED_NAME` VARCHAR(64),
`INSTANCE_NAME` VARCHAR(64),
`LAST_CHECKIN_TIME` INT,
`CHECKIN_INTERVAL` INT,
PRIMARY KEY (`SCHED_NAME`, `INSTANCE_NAME`)
) CHARACTER SET latin1;
CREATE TABLE `qrtz_locks` (
`SCHED_NAME` VARCHAR(64),
`LOCK_NAME` VARCHAR(64),
PRIMARY KEY (`SCHED_NAME`, `LOCK_NAME`)
) CHARACTER SET latin1;
