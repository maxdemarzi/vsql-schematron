`avatar` VARCHAR(255),
`balance` DECIMAL(10,2),
`created_at` INT,
`updated_at` INT,
`role` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_settings` (
`id` INT,
