) CHARACTER SET latin1;
CREATE TABLE `tickets_text` (
`id` INT,
`ticket_id` INT,
`date_time` DATETIME,
`text` VARCHAR(255),
`user_type` INT
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`user_id` INT,
`transaction_id` VARCHAR(255),
`payment_id` INT,
`status` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`email` VARCHAR(255),
`phone` VARCHAR(255),
`company_name` VARCHAR(255),
`password_hash` VARCHAR(255),
`password_reset_token` VARCHAR(255),
`auth_key` VARCHAR(255),
