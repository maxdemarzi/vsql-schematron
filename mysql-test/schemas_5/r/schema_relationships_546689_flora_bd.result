CREATE DATABASE `db_546689_flora_bd`;
USE `db_546689_flora_bd`;
CREATE TABLE `addition` (
`id` INT,
`created_at` INT,
`updated_at` INT,
`name` VARCHAR(255),
`cost` DECIMAL(10,2),
`about` VARCHAR(255),
`type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message_to_paid` (
`id` INT,
`user_id` INT,
`service_type` INT,
`service_id` INT,
`date_to_paid` DATETIME,
`amount` DECIMAL(10,2),
`debtor` INT
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(255),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`id` INT,
`user_id` INT,
`shop_id` INT,
`type_service` INT,
`service_id` INT,
`type` INT,
`way` INT,
`date` DATETIME,
`invoice_number` INT,
`invoice_date` DATETIME,
`amount` DECIMAL(10,2),
`description` VARCHAR(255),
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `service` (
`id` INT,
`user_id` INT,
`shop_id` INT,
`type_service` INT,
`type_serviceId` INT,
`connection_date` DATETIME,
`writeoff_date` DATETIME,
`writeoff_amount` DECIMAL(10,2),
`agree` INT,
`repeat_service` INT,
`deleted` INT,
`old_service_id` INT,
`old_connection_date` DATETIME,
`old_writeoff_date` DATETIME,
`old_writeoff_amount` DECIMAL(10,2),
`edit_description` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shops` (
`id` INT,
`created_at` INT,
`updated_at` INT,
`address` VARCHAR(255),
`tariff_id` INT,
`user_id` INT,
`on_check` INT,
`deleted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shops_addition` (
`shop_id` INT,
`addition_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `tariff` (
`id` INT,
`created_at` INT,
`updated_at` INT,
`name` VARCHAR(255),
`cost` DECIMAL(10,2),
`about` VARCHAR(255),
`drop` INT,
`status` INT,
`maximum` INT,
`term` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tariff_addition` (
`tariff_id` INT,
`addition_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `tariff_addition_quantity` (
`tariff_id` INT,
