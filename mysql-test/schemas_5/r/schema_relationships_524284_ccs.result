[Implied]  Chat_Room.owner_id -> User.user_id
[Implied]  City.state_id -> State.state_id
[Implied]  Friendship.friend_id -> User.user_id
[Implied]  Friendship.sender_id -> User.user_id
[Implied]  Friendship.user_id -> User.user_id
[Implied]  Message.room_id -> Chat_Room.room_id
[Implied]  Message.sender_id -> User.user_id
[Implied]  Message_Image.message_id -> Message.message_id
[Implied]  Participant.room_id -> Chat_Room.room_id
[Implied]  Participant.user_id -> User.user_id
[Implied]  RoomSecret.room_id -> Chat_Room.room_id
[Implied]  RoomSecret.user_id -> User.user_id
[Implied]  Student.user_id -> User.user_id
[Implied]  User.city_id -> City.city_id
[Implied]  UserActivityLog.user_id -> User.user_id

DROP DATABASE `db_524284_ccs`;
UNINSTALL EXTENSION vsql_schematron;
