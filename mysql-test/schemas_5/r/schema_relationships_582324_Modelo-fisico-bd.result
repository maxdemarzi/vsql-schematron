CREATE DATABASE `db_582324_Modelo_fisico_bd`;
USE `db_582324_Modelo_fisico_bd`;
CREATE TABLE `horario` (
`id_horario` INT NOT NULL,
`data_horario` VARCHAR(50),
`status_horario` VARCHAR(50),
`horario` VARCHAR(50),
PRIMARY KEY (`id_horario`)
) CHARACTER SET latin1;
CREATE TABLE `motivo_agendamento` (
`id_motivo_agendamento` INT NOT NULL,
`descricao_motivo` VARCHAR(50),
PRIMARY KEY (`id_motivo_agendamento`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`status_usuario` VARCHAR(50),
`nome_usuario` VARCHAR(50),
`cpf_usuario` CHAR(50),
`email_usuario` VARCHAR(50),
`senha_usuario` VARCHAR(50),
`imagem_usuario` VARCHAR(50),
`nivel_usuario` INT,
`data_criacao_usuario` TIMESTAMP NULL,
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `permanencia` (
`id_permanencia` INT NOT NULL,
`segunda_feira_manha` VARCHAR(50),
`terca_feira_manha` VARCHAR(50),
`quarta_feira_manha` VARCHAR(50),
`quinta_feira_manha` VARCHAR(50),
`sexta_feira_manha` VARCHAR(50),
`segunda_feira_tarde` VARCHAR(50),
`terca_feira_tarde` VARCHAR(50),
`quarta_feira_tarde` VARCHAR(50),
`quinta_feira_tarde` VARCHAR(50),
`sexta_feira_tarde` VARCHAR(50),
`id_usuario` INT,
PRIMARY KEY (`id_permanencia`)
) CHARACTER SET latin1;
CREATE TABLE `aviso` (
`id_aviso` INT NOT NULL,
`descricao_aviso` TEXT,
`data_publicacao` VARCHAR(50),
`id_usuario` INT,
`data_criacao_aviso` TIMESTAMP NULL,
PRIMARY KEY (`id_aviso`)
) CHARACTER SET latin1;
CREATE TABLE `laboratorio` (
`id_laboratorio` INT NOT NULL,
`nome_laboratorio` VARCHAR(50),
`imagem_laboratorio` VARCHAR(50),
`descricao_laboratorio` TEXT,
`id_usuario` INT,
PRIMARY KEY (`id_laboratorio`)
) CHARACTER SET latin1;
CREATE TABLE `agendamento` (
`id_agendamento` INT NOT NULL,
`descricao_agendamento` VARCHAR(50),
`data_criacao_agendamento` TIMESTAMP NULL,
`nome_produto` VARCHAR(50),
`nome_equipamento` VARCHAR(50),
`id_usuario` INT,
`id_motivo_agendamento` INT,
`id_laboratorio` INT,
`id_horario` INT,
PRIMARY KEY (`id_agendamento`)
) CHARACTER SET latin1;
CREATE TABLE `equipamento` (
`id_equipamento` INT NOT NULL,
`nome_equipamento` VARCHAR(50),
`status_equipamento` VARCHAR(50),
`imagem_equipamento` VARCHAR(50),
`numero_patrimonio` INT,
`quantidade_equipamento` INT,
`pertence_laboratorio` INT,
`data_criacao_equipamento` TIMESTAMP NULL,
PRIMARY KEY (`id_equipamento`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
`id_produto` INT NOT NULL,
`nome_produto` VARCHAR(50),
`status_produto` VARCHAR(50),
`imagem_produto` VARCHAR(50),
`formula_produto` VARCHAR(50),
`quantidade_produto` INT,
`pertence_laboratorio` INT,
`data_criacao_produto` TIMESTAMP NULL,
PRIMARY KEY (`id_produto`)
) CHARACTER SET latin1;
