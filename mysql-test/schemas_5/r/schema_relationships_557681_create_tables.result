CREATE DATABASE `db_557681_create_tables`;
USE `db_557681_create_tables`;
CREATE TABLE `address` (
`id` INT,
`address_line_1` VARCHAR(64),
`address_line_2` VARCHAR(64),
`address_line_3` VARCHAR(64),
`address_line_4` VARCHAR(64),
`postcode` VARCHAR(64),
`uprn` INT,
`approximation_concept_id` INT,
`property_type_concept_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organisation` (
`id` INT,
`service_id` VARCHAR(64),
`system_id` VARCHAR(64),
`ods_code` VARCHAR(64),
`name` VARCHAR(64),
`is_active` VARCHAR(64),
`parent_organisation_id` INT,
`type_concept_id` INT,
`main_location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `procedure` (
`id` INT,
`patient_id` INT,
`concept_id` INT,
`effective_date` DATETIME,
`effective_date_precision` INT,
`effective_practitioner_id` INT,
`entered_by_practitioner_id` INT,
`end_date` DATETIME,
`usual_practitioner_id` INT,
`encounter_id` INT,
`encounter_heading_concept_id` INT,
`owning_organisation_id` INT,
`status_concept_id` INT,
`is_confidential` VARCHAR(64),
`original_code` VARCHAR(64),
`original_term` VARCHAR(64),
`original_code_scheme` INT,
`original_system` INT,
`outcome_concept_id` INT,
`is_consent` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
