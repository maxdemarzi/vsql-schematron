INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 500010_db
#
CREATE DATABASE `db_500010_db`;
USE `db_500010_db`;
CREATE TABLE `usuario` (
`id` INT,
`nome_completo` VARCHAR(64),
`cpf` VARCHAR(64),
`email` VARCHAR(64),
`senha` VARCHAR(64),
`tipo` INT,
`carteira` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`id` INT,
`value` INT,
`payer` INT,
`payee` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_500010_db') AS relationships;
