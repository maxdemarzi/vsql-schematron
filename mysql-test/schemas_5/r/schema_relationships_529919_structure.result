INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 529919_structure
#
CREATE DATABASE `db_529919_structure`;
USE `db_529919_structure`;
CREATE TABLE `Participant` (
`id` VARCHAR(50) NOT NULL,
`userId` VARCHAR(50),
`eventId` VARCHAR(50),
`requestTime` DATETIME,
`approved` VARCHAR(50),
`disqualified` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`id` VARCHAR(50) NOT NULL,
`eventId` VARCHAR(50),
`userId` VARCHAR(50),
`Comment` VARCHAR(50),
`createTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
`id` VARCHAR(50) NOT NULL,
`participantId` VARCHAR(50),
`title` VARCHAR(50),
`description` VARCHAR(50),
`gitRepoUri` VARCHAR(50),
`demoPageUri` VARCHAR(50),
`createTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProjectBlog` (
`id` VARCHAR(50) NOT NULL,
`projectId` VARCHAR(50),
`title` VARCHAR(50),
`blogText` VARCHAR(50),
`createTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
`id` VARCHAR(50) NOT NULL,
`userId` VARCHAR(50),
`projectId` VARCHAR(50),
`creativity` VARCHAR(50),
`implementation` VARCHAR(50),
`structure` VARCHAR(50),
`technology` VARCHAR(50),
`scope` VARCHAR(50),
`submitTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_529919_structure') AS relationships;
