CREATE DATABASE `db_553403_schema_mysql`;
USE `db_553403_schema_mysql`;
CREATE TABLE `transfer_statements` (
`id` INT,
`transfer_code` VARCHAR(64),
`source_id` INT,
`target_id` INT,
`amount` INT,
`created_at` DATETIME,
`status` INT,
`message` VARCHAR(64),
`transfer_fee` INT,
`transfer_type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallets` (
`id` INT,
`balance` INT,
`owner_id` VARCHAR(64),
`ref_from` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_553403_schema_mysql') AS relationships;
