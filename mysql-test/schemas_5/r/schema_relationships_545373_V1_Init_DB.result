CREATE DATABASE `db_545373_V1_Init_DB`;
USE `db_545373_V1_Init_DB`;
CREATE TABLE `usr` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT,
`post_title` VARCHAR(64),
`main_text` VARCHAR(64),
`preview` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
`status` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`id` INT,
`tag_title` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
`tag_id` INT,
`post_id` INT,
PRIMARY KEY (`tag_id`, `post_id`)
) CHARACTER SET latin1;
