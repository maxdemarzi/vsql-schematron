CREATE DATABASE `db_506769_script`;
USE `db_506769_script`;
CREATE TABLE `links` (
`id` INT NOT NULL,
`base_url` VARCHAR(50),
`shortened_url` VARCHAR(50),
`is_anonymous` INT,
`user_id` INT,
`short_description` VARCHAR(50),
`expired_at` DATE,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
