INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 596843_V1_0_0_initial_schema
#
CREATE DATABASE `db_596843_V1_0_0_initial_schema`;
USE `db_596843_V1_0_0_initial_schema`;
CREATE TABLE `client_request` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `outbox` (
`id` INT,
`content` VARCHAR(64),
`creation_time` DATETIME,
`event_id` VARCHAR(64),
`event_state` VARCHAR(64),
`event_type_name` VARCHAR(64),
`times_sent` INT,
`topic` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `buyer` (
`id` VARCHAR(64),
`user_id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment_method` (
`id` VARCHAR(64),
`alias` VARCHAR(64),
`card_holder_name` VARCHAR(64),
`card_number` VARCHAR(64),
`card_type` VARCHAR(64),
`expiration` DATETIME,
`security_number` VARCHAR(64),
`buyer_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` VARCHAR(64),
`city` VARCHAR(64),
`country` VARCHAR(64),
`state` VARCHAR(64),
`street` VARCHAR(64),
`zip_code` VARCHAR(64),
`buyer_id` VARCHAR(64),
`description` VARCHAR(64),
`is_draft` VARCHAR(64),
`order_date` DATETIME,
`order_status` VARCHAR(64),
`payment_method_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
`id` VARCHAR(64),
`discount` DECIMAL(10,2),
`picture_url` VARCHAR(64),
`product_id` VARCHAR(64),
`product_name` VARCHAR(64),
`unit_price` DECIMAL(10,2),
`units` INT,
`order_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_596843_V1_0_0_initial_schema') AS relationships;
relationships
Database: db_596843_V1_0_0_initial_schema

Table Connections:
------------------
[Implied]  order_item.order_id -> orders.id
[Implied]  orders.buyer_id -> buyer.id
[Implied]  orders.payment_method_id -> payment_method.id
[Implied]  payment_method.buyer_id -> buyer.id

DROP DATABASE `db_596843_V1_0_0_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
