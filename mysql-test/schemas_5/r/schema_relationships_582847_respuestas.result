INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 582847_respuestas
#
CREATE DATABASE `db_582847_respuestas`;
USE `db_582847_respuestas`;
CREATE TABLE `alumno` (
`idalumno` INT NOT NULL,
`nombre` VARCHAR(50),
`apellidos` VARCHAR(50),
`fechaNac` DATE,
`email` VARCHAR(50),
`trabaja` TINYINT,
PRIMARY KEY (`idalumno`)
) CHARACTER SET latin1;
CREATE TABLE `asignatura` (
`idasignatura` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`idasignatura`)
) CHARACTER SET latin1;
CREATE TABLE `curso` (
`idclase` INT NOT NULL,
`idalumno` INT,
`idasignatura` INT,
`nombre` VARCHAR(50),
PRIMARY KEY (`idclase`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_582847_respuestas') AS relationships;
