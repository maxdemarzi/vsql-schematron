CREATE DATABASE `db_541281_migration`;
USE `db_541281_migration`;
CREATE TABLE `Device` (
`id` VARCHAR(64),
`active` BOOL,
`deleted` BOOL,
`createAt` DATETIME,
`updateAt` DATETIME,
`code` INT,
`description` VARCHAR(64),
`model` VARCHAR(64),
`equipmentNumber` VARCHAR(64),
`phone` VARCHAR(64),
`mobileOperator` VARCHAR(64),
`chipNumber` VARCHAR(64),
`timezone` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Info` (
`id` VARCHAR(64),
`active` BOOL,
`deleted` BOOL,
