`mcc` INT,
`mnc` INT,
`lac` INT,
`deviceId` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Status` (
`id` VARCHAR(64),
`active` BOOL,
