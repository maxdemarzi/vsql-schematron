INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 540699_schema-003
#
CREATE DATABASE `db_540699_schema_003`;
USE `db_540699_schema_003`;
CREATE TABLE `SchemaVersion` (
`version` INT
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
`id` INT NOT NULL,
`key_exponent` BLOB,
`key_modulus` BLOB,
`display_name` VARCHAR(50),
`hashed_phone_number` CHAR(50),
`password_hash` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `LoginChallenges` (
`id` INT NOT NULL,
`challenge` BLOB,
`account_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sessions` (
`id` INT NOT NULL,
`auth_token` TEXT,
`account_id` INT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GamesCompletedAt` (
`id` INT NOT NULL,
`completed_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Games` (
`id` INT NOT NULL,
`completed_at_id` INT,
`next_expiration` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Turns` (
`id` INT NOT NULL,
`account_id` INT,
`game_id` INT,
`is_complete` BOOLEAN,
`is_drawing` BOOLEAN,
`label` TEXT,
`drawing` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_540699_schema_003') AS relationships;
relationships
Database: db_540699_schema_003

Table Connections:
