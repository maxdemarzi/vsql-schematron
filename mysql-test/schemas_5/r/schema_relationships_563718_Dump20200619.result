CREATE DATABASE `db_563718_Dump20200619`;
USE `db_563718_Dump20200619`;
CREATE TABLE `bank_business` (
`idbank_business_id` INT,
`business_id` INT,
`score` INT,
PRIMARY KEY (`idbank_business_id`)
) CHARACTER SET latin1;
CREATE TABLE `business` (
`business_id` INT,
`name` VARCHAR(64),
`surplus` INT,
PRIMARY KEY (`business_id`)
) CHARACTER SET latin1;
CREATE TABLE `deal` (
`user_id` INT,
`goods_id` INT,
`deal_time` DATETIME,
`deal_num` INT,
`way_of_deal` INT,
`deal_id` INT,
PRIMARY KEY (`user_id`, `deal_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_information` (
`user_id` INT,
`user_name` VARCHAR(64),
`user_account` VARCHAR(64),
`user_secret` VARCHAR(64),
`surplus` INT,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_user_score` (
`send_id` INT,
`get_id` INT,
`score` INT,
`time` DATETIME,
PRIMARY KEY (`send_id`, `get_id`)
) CHARACTER SET latin1;
