[Implied]  shipping_address.user_id -> user.user_id
[Implied]  user.country_id -> country.country_id
[Implied]  user.gender_id -> gender.gender_id

DROP DATABASE `db_529184_database_schema`;
UNINSTALL EXTENSION vsql_schematron;
