CREATE TABLE `Cliente` (
`id_cli` INT,
`nome_cli` VARCHAR(64),
`endereco_cli` VARCHAR(64),
`cpf_cli` VARCHAR(64),
PRIMARY KEY (`id_cli`)
) CHARACTER SET latin1;
CREATE TABLE `Produto` (
`id_pro` INT,
`nome_pro` VARCHAR(64),
`valor_pro` DECIMAL(10,2),
`estoque_pro` VARCHAR(64),
PRIMARY KEY (`id_pro`)
) CHARACTER SET latin1;
CREATE TABLE `Setor` (
`id_set` INT,
`nome_set` VARCHAR(64),
PRIMARY KEY (`id_set`)
) CHARACTER SET latin1;
CREATE TABLE `Funcionario` (
`id_fun` INT,
`nome_fun` VARCHAR(64),
`funcao_fun` VARCHAR(64),
`id_set_fk` INT,
PRIMARY KEY (`id_fun`)
) CHARACTER SET latin1;
CREATE TABLE `Venda` (
`id_ven` INT,
`valor_ven` DECIMAL(10,2),
`data_ven` DATETIME,
`id_cli_fk` INT,
`id_pro_fk` INT,
`id_fun_fk` INT,
PRIMARY KEY (`id_ven`)
) CHARACTER SET latin1;
CREATE TABLE `Entrega` (
`id_ent` INT,
