`endereco_alternativo_ent` VARCHAR(64),
`hora_ent` DATETIME,
`id_ven_fk` INT,
PRIMARY KEY (`id_ent`)
) CHARACTER SET latin1;
CREATE TABLE `Caixa` (
`id_caixa` INT,
`saldo_inicial_caixa` DECIMAL(10,2),
`total_recebimentos_caixa` DECIMAL(10,2),
`total_retiradas_caixa` DECIMAL(10,2),
`saldo_final_caixa` DECIMAL(10,2),
PRIMARY KEY (`id_caixa`)
) CHARACTER SET latin1;
CREATE TABLE `Recebimento` (
`id_rec` INT,
`tipo_rec` VARCHAR(64),
`data_rec` DATETIME,
`id_ven_fk` INT,
`id_caixa_fk` INT,
PRIMARY KEY (`id_rec`)
) CHARACTER SET latin1;
CREATE TABLE `Fornecedor` (
`id_for` INT,
`nome_for` VARCHAR(64),
`cnpj_for` VARCHAR(64),
PRIMARY KEY (`id_for`)
) CHARACTER SET latin1;
CREATE TABLE `Compra` (
`id_com` INT,
`valor_com` DECIMAL(10,2),
`data_com` DATETIME,
`id_pro_fk` INT,
`id_fun_fk` INT,
`id_for_fk` INT,
PRIMARY KEY (`id_com`)
) CHARACTER SET latin1;
CREATE TABLE `Despesa` (
`id_des` INT,
`nome_des` VARCHAR(64),
`valor_des` DECIMAL(10,2),
`id_com_fk` INT,
PRIMARY KEY (`id_des`)
) CHARACTER SET latin1;
CREATE TABLE `Pagamento` (
`id_pag` INT,
`tipo_pag` VARCHAR(64),
`data_pag` DATETIME,
`id_caixa_fk` INT,
`id_des_fk` INT,
PRIMARY KEY (`id_pag`)
) CHARACTER SET latin1;
