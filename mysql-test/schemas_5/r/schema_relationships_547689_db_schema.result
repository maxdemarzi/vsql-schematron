INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 547689_db_schema
#
CREATE DATABASE `db_547689_db_schema`;
USE `db_547689_db_schema`;
CREATE TABLE `chatweb.rooms` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chatweb.messages` (
`id` INT,
`message` VARCHAR(64),
`room_id` INT,
`sender_id` INT,
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chatweb.user_room` (
`users_id` INT,
`rooms_id` INT,
PRIMARY KEY (`users_id`, `rooms_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_547689_db_schema') AS relationships;
