INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 597666_database
#
CREATE DATABASE `db_597666_database`;
USE `db_597666_database`;
CREATE TABLE `contacts` (
`id` INT NOT NULL,
`android_contact_id` INT,
`name` VARCHAR(50),
`is_synced` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone_numbers` (
`id` INT NOT NULL,
`contact_id` INT,
`phone_number` VARCHAR(50),
`phone_type` VARCHAR(50),
`is_synced` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `command_statuses` (
`id` INT NOT NULL,
`command_id` INT,
`status` VARCHAR(50),
`status_message` TEXT,
`created_at` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pending_deliveries` (
`id` INT NOT NULL,
`is_error` INT,
`is_being_uploaded` INT,
`data_type` TEXT,
`data` TEXT,
`message` VARCHAR(50),
`created_at` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT NOT NULL,
`android_message_id` INT,
`_from` VARCHAR(50),
`content` TEXT,
`_type` VARCHAR(50),
`delivery_time` TEXT,
`created_at` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pull_queue` (
`id` INT NOT NULL,
`file_path` TEXT,
`is_being_uploaded` INT,
`created_at` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_597666_database') AS relationships;
relationships
