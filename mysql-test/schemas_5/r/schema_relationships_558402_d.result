CREATE DATABASE `db_558402_d`;
USE `db_558402_d`;
CREATE TABLE `word` (
`id` INT NOT NULL,
`word` VARCHAR(50),
`mean` VARCHAR(50),
`pronounce` VARCHAR(50),
`regDt` TIMESTAMP NULL,
`wrong` BOOLEAN,
`userId` INT,
`category` VARCHAR(50),
`testNum` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`userId` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`nickname` VARCHAR(50),
`regDt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `testResults` (
`testNum` INT NOT NULL,
`tetName` VARCHAR(50),
`collect` INT,
`wrong` INT,
`userId` INT,
PRIMARY KEY (`testNum`)
) CHARACTER SET latin1;
