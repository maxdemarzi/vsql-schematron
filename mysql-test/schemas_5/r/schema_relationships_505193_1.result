CREATE DATABASE `db_505193_1`;
USE `db_505193_1`;
CREATE TABLE `system` (
`version` INT
) CHARACTER SET latin1;
CREATE TABLE `training` (
`id_training` INT NOT NULL,
`date` DATE,
`time` TIME,
`type` VARCHAR(50),
`formation` INT,
`note` VARCHAR(50),
PRIMARY KEY (`id_training`)
) CHARACTER SET latin1;
CREATE TABLE `coaches_at_trainings` (
`id_training` INT NOT NULL,
`id_coach` INT NOT NULL,
`id_job` INT,
`note` VARCHAR(50),
PRIMARY KEY (`id_training`, `id_coach`)
) CHARACTER SET latin1;
CREATE TABLE `assistant` (
`id_position` TINYINT NOT NULL,
`form` TINYINT,
`stamina` TINYINT,
`pace` TINYINT,
`technique` TINYINT,
`passing` TINYINT,
`keeper` TINYINT,
`defender` TINYINT,
`playmaker` TINYINT,
`scorer` TINYINT,
PRIMARY KEY (`id_position`)
) CHARACTER SET latin1;
CREATE TABLE `note` (
`id_note` INT NOT NULL,
`date` DATE,
`time` TIME,
`title` VARCHAR(50),
`text` VARCHAR(50),
`alert_date` DATE,
`alert_time` TIME,
`mod_date` DATE,
`mod_time` TIME,
`checked` BOOLEAN,
PRIMARY KEY (`id_note`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_505193_1') AS relationships;
