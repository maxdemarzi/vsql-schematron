CREATE TABLE `Artist` (
`artistID` INT,
`name` VARCHAR(64),
`thumbnail` VARCHAR(64),
PRIMARY KEY (`artistID`)
) CHARACTER SET latin1;
CREATE TABLE `Album` (
`albumID` INT,
`name` VARCHAR(64),
`releaseYear` VARCHAR(64),
`thumbnail` VARCHAR(64),
`artistID` INT,
PRIMARY KEY (`albumID`)
) CHARACTER SET latin1;
CREATE TABLE `Track` (
`trackID` INT,
`title` VARCHAR(64),
`length` VARCHAR(64),
`youtubeAddr` VARCHAR(64),
`artistID` INT,
`albumID` INT,
PRIMARY KEY (`trackID`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`userID` INT,
`username` VARCHAR(64),
`lName` VARCHAR(64),
`fName` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `Role` (
`roleID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`roleID`)
) CHARACTER SET latin1;
CREATE TABLE `UserRole` (
`roleID` INT,
`userID` INT,
PRIMARY KEY (`roleID`, `userID`)
) CHARACTER SET latin1;
CREATE TABLE `UserPlaylist` (
`playlistID` INT,
`userID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`playlistID`)
) CHARACTER SET latin1;
CREATE TABLE `Playlist` (
`ID` INT,
`playlistID` INT,
`trackID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
