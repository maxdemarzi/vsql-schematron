INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 510985_nsi-survey
#
CREATE DATABASE `db_510985_nsi_survey`;
USE `db_510985_nsi_survey`;
CREATE TABLE `survey_element` (
`id` INT,
`fd_id` INT,
`survey_event_id` INT,
`is_control` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `surveyor` (
`user_id` VARCHAR(64),
`user_name` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_assignment` (
`id` INT,
`se_id` INT,
`completed` BOOL,
`assigned_to` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_result` (
`id` INT,
`sa_id` INT,
`fd_id` INT,
`X` DECIMAL(10,2),
`Y` DECIMAL(10,2),
`invalid_structure` BOOL,
`no_street_view` BOOL,
`cbfips` VARCHAR(64),
`occtype` VARCHAR(64),
`st_damcat` VARCHAR(64),
`found_ht` DECIMAL(10,2),
`num_story` INT,
`sqft` DECIMAL(10,2),
`found_type` VARCHAR(64),
`rsmeans_type` VARCHAR(64),
`quality` VARCHAR(64),
`const_type` VARCHAR(64),
`garage` VARCHAR(64),
`roof_style` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_510985_nsi_survey') AS relationships;
