INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 515703_postgres
#
CREATE DATABASE `db_515703_postgres`;
USE `db_515703_postgres`;
CREATE TABLE `tournament` (
`id` INT,
`title` VARCHAR(64),
`t_date` DATETIME,
`current_rnd` INT,
`active` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `player` (
`id` INT,
`tid` INT,
`p_name` VARCHAR(64),
`corp_id` VARCHAR(64),
`runner_id` VARCHAR(64),
`score` INT,
`sos` DECIMAL(10,2),
`esos` DECIMAL(10,2),
`bias` INT,
`games_played` INT,
`received_bye` BOOL,
`is_bye` BOOL,
`active` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match` (
`id` INT,
`match_num` INT,
`tid` INT,
`corp_id` INT,
`runner_id` INT,
`rnd` INT,
`corp_score` INT,
`runner_score` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
