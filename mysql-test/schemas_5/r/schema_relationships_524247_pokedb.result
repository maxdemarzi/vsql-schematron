INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 524247_pokedb
#
CREATE DATABASE `db_524247_pokedb`;
USE `db_524247_pokedb`;
CREATE TABLE `pokemon_t` (
`pokemon_id` INT,
`pokemon_name` VARCHAR(64),
`pokemon_species_id` INT,
`pokemon_height` INT,
`pokemon_weight` INT,
`pokemon_base_exp` INT,
PRIMARY KEY (`pokemon_id`)
) CHARACTER SET latin1;
CREATE TABLE `type_t` (
`type_id` INT,
`type_name` VARCHAR(64),
`type_generation` INT,
`type_damage_class_id` INT,
`type_hexcolor` VARCHAR(64),
PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon_type_t` (
`pokemon_id` INT,
`type_id` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_pokemons` (
`userPokeId` INT,
`nickname` VARCHAR(64),
`userId` INT,
`pokeNo` INT,
`pokeName` VARCHAR(64),
PRIMARY KEY (`userPokeId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_524247_pokedb') AS relationships;
relationships
Database: db_524247_pokedb

Table Connections:
