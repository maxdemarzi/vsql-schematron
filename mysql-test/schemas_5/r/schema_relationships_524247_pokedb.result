[Implied]  pokemon_type_t.pokemon_id -> pokemon_t.pokemon_id
[Implied]  pokemon_type_t.type_id -> type_t.type_id
[Implied]  user_pokemons.userId -> users.id

DROP DATABASE `db_524247_pokedb`;
UNINSTALL EXTENSION vsql_schematron;
