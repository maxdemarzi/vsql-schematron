INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 550804_schema
#
CREATE DATABASE `db_550804_schema`;
USE `db_550804_schema`;
CREATE TABLE `department` (
`id` INT,
`dname` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_550804_schema') AS relationships;
relationships
Database: db_550804_schema

