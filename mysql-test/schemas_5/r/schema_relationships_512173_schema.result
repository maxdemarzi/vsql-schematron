INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 512173_schema
#
CREATE DATABASE `db_512173_schema`;
USE `db_512173_schema`;
CREATE TABLE `department` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`roles_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_512173_schema') AS relationships;
relationships
Database: db_512173_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.roles_id -> roles.id
[Implied]  roles.department_id -> department.id

DROP DATABASE `db_512173_schema`;
UNINSTALL EXTENSION vsql_schematron;
