INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 501284_query
#
CREATE DATABASE `db_501284_query`;
USE `db_501284_query`;
CREATE TABLE `authority` (
`id` BIGINT NOT NULL,
`authority_type` VARCHAR(50),
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`enabled` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`last_password_reset_date` DATETIME,
`password` VARCHAR(50),
`phone_number` VARCHAR(50),
`username` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_501284_query') AS relationships;
