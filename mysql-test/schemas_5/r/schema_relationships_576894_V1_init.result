CREATE DATABASE `db_576894_V1_init`;
USE `db_576894_V1_init`;
CREATE TABLE `ADDRESS` (
`ID` INT,
`CITY` VARCHAR(64),
`STATE` VARCHAR(64),
`STREET` VARCHAR(64),
`ZIP` VARCHAR(64),
`CREATED_DATE` DATETIME,
`LAST_MODIFIED_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEPARTMENT` (
`ID` INT,
`NAME` VARCHAR(64),
`CREATED_DATE` DATETIME,
`LAST_MODIFIED_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
`ID` INT,
`NAME` VARCHAR(64),
`SALARY` INT,
`FULL_TIME` VARCHAR(64),
`ADDRESS_ID` INT,
`BOSS_ID` INT,
`DEPARTMENT_ID` INT,
`CREATED_DATE` DATETIME,
`LAST_MODIFIED_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PHONE` (
`ID` INT,
`PHONENUMBER` VARCHAR(64),
`TYPE` VARCHAR(64),
`EMPLOYEE_ID` INT,
`CREATED_DATE` DATETIME,
`LAST_MODIFIED_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT` (
`DTYPE` VARCHAR(64),
`ID` INT,
`NAME` VARCHAR(64),
`CREATED_DATE` DATETIME,
`LAST_MODIFIED_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT_EMPLOYEES` (
`PROJECTS_ID` INT,
`EMPLOYEES_ID` INT,
PRIMARY KEY (`PROJECTS_ID`, `EMPLOYEES_ID`)
) CHARACTER SET latin1;
