CREATE DATABASE `db_580280_cjextintores`;
USE `db_580280_cjextintores`;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`usuario` VARCHAR(50),
`login` VARCHAR(50),
`senha` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`idcli` INT NOT NULL,
`nome` VARCHAR(50),
`cpf` VARCHAR(50),
`fone` VARCHAR(50),
`email` VARCHAR(50),
`cep` VARCHAR(50),
`endereco` VARCHAR(50),
`numero` VARCHAR(50),
`complemento` VARCHAR(50),
`cidade` VARCHAR(50),
`bairro` VARCHAR(50),
`estado` VARCHAR(50),
PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
`os` INT NOT NULL,
`modelo` VARCHAR(50),
`serie` VARCHAR(50),
`detalhes` VARCHAR(50),
`defeito` VARCHAR(50),
`diagnostico` VARCHAR(50),
`observacoes` VARCHAR(50),
`dataos` TIMESTAMP NULL,
`statusos` VARCHAR(50),
`valor` DECIMAL(10,2),
`idcli` INT,
PRIMARY KEY (`os`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_580280_cjextintores') AS relationships;
