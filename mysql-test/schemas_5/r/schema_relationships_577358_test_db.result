PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`guid` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`completed_training` TINYINT,
PRIMARY KEY (`guid`)
) CHARACTER SET latin1;
