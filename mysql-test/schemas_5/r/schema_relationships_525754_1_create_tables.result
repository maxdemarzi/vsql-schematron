CREATE DATABASE `db_525754_1_create_tables`;
USE `db_525754_1_create_tables`;
CREATE TABLE `flows_v3` (
`flow_id` VARCHAR(255),
`user_name` VARCHAR(255),
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`flow_id`)
) CHARACTER SET latin1;
CREATE TABLE `runs_v3` (
`flow_id` VARCHAR(255),
`run_number` INT,
`user_name` VARCHAR(255),
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`flow_id`, `run_number`)
) CHARACTER SET latin1;
CREATE TABLE `steps_v3` (
`flow_id` VARCHAR(255),
`run_number` INT,
`step_name` VARCHAR(255),
`user_name` VARCHAR(255),
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`flow_id`, `run_number`, `step_name`)
) CHARACTER SET latin1;
CREATE TABLE `tasks_v3` (
`flow_id` VARCHAR(255),
`run_number` INT,
`step_name` VARCHAR(255),
`task_id` INT,
`user_name` VARCHAR(255),
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
CREATE TABLE `metadata_v3` (
`flow_id` VARCHAR(255),
`run_number` INT,
`step_name` VARCHAR(255),
`task_id` INT,
`id` INT,
`field_name` VARCHAR(255),
`value` VARCHAR(255),
`type` VARCHAR(255),
`user_name` VARCHAR(255),
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`flow_id`, `run_number`, `step_name`, `task_id`, `field_name`)
) CHARACTER SET latin1;
CREATE TABLE `artifact_v3` (
`flow_id` VARCHAR(255),
`run_number` INT,
`step_name` VARCHAR(255),
`task_id` INT,
`name` VARCHAR(255),
`location` VARCHAR(255),
`ds_type` VARCHAR(255),
`sha` VARCHAR(255),
`type` VARCHAR(255),
`content_type` VARCHAR(255),
`user_name` VARCHAR(255),
`attempt_id` INT,
`ts_epoch` INT,
`tags` VARCHAR(255),
`system_tags` VARCHAR(255),
PRIMARY KEY (`flow_id`, `run_number`, `step_name`, `task_id`, `attempt_id`, `name`)
) CHARACTER SET latin1;
