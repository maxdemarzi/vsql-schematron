`MAX_TRANSACTION_AMOUNT` INT,
`MAX_PER_PERIOD_TRANSACTION_COUNT` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COUPON` (
