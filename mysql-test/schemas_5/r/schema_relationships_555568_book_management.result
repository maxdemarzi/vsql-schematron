INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 555568_book_management
#
CREATE DATABASE `db_555568_book_management`;
USE `db_555568_book_management`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`user_number` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`email` VARCHAR(50),
`adress` VARCHAR(50),
`postal_code` VARCHAR(50),
`city` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` VARCHAR(50) NOT NULL,
`autor` VARCHAR(50),
`title` VARCHAR(50),
`release_date` INT,
`literary_style` VARCHAR(50),
`status` VARCHAR(50),
`resume` TEXT,
`user_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_555568_book_management') AS relationships;
