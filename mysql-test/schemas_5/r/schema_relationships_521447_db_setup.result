`Signiert_SL_Id` INT,
`Fehlzeiten_Best_Id` INT,
PRIMARY KEY (`Block_Nr`, `Wochen_Nr`)
) CHARACTER SET latin1;
CREATE TABLE `Klassenbuch_KLASSE_ID_Tag` (
