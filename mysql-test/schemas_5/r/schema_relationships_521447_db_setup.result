`Best_Lehrer_Id` INT,
PRIMARY KEY (`Datum`, `Stunde`)
) CHARACTER SET latin1;
CREATE TABLE `Klassenbuch_KLASSE_ID_Fehlzeit` (
`Datum` DATETIME,
`Stunde` INT,
`Schueler_Id` INT,
`Fehlzeit_Typ_Id` INT,
`Infotext` VARCHAR(64),
PRIMARY KEY (`Datum`, `Stunde`, `Schueler_Id`)
) CHARACTER SET latin1;
