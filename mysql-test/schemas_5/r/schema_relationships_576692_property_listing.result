INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 576692_property_listing
#
CREATE DATABASE `db_576692_property_listing`;
USE `db_576692_property_listing`;
CREATE TABLE `addresses` (
`id` INT,
`line_1` VARCHAR(255),
`line_2` VARCHAR(255),
`landmark` VARCHAR(255),
`pincode` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `admins` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hibernate_sequence` (
`next_val` INT
) CHARACTER SET latin1;
CREATE TABLE `images` (
`id` INT,
`imageurl` VARCHAR(255),
`size` INT,
`property_id` INT
) CHARACTER SET latin1;
CREATE TABLE `locations` (
`id` INT,
`city` VARCHAR(255),
`state` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `properties` (
`id` INT,
`name` VARCHAR(255),
`price` DECIMAL(10,2),
`p_den` VARCHAR(255),
`description` VARCHAR(255),
`avg_rating` INT,
`address_id` INT,
`location_id` INT,
`category_id` INT,
`list_for` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`website_review` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_properties` (
`id` INT,
`user_id` INT,
`property_id` INT,
`list_in` VARCHAR(255),
`rating` INT,
`review` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_576692_property_listing') AS relationships;
relationships
Database: db_576692_property_listing

Table Connections:
------------------
[Implied]  images.property_id -> properties.id
[Implied]  properties.address_id -> addresses.id
[Implied]  properties.category_id -> categories.id
[Implied]  properties.location_id -> locations.id
[Implied]  users_properties.property_id -> properties.id
[Implied]  users_properties.user_id -> users.id

DROP DATABASE `db_576692_property_listing`;
UNINSTALL EXTENSION vsql_schematron;
