CREATE DATABASE `db_551323_schema_ddl`;
USE `db_551323_schema_ddl`;
CREATE TABLE `users` (
`user_id` VARCHAR(64),
`email` VARCHAR(64),
`user_name` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
`pic_url` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `queries` (
`query_id` VARCHAR(64),
`user_id` VARCHAR(64),
`created` DATETIME,
`img_url` VARCHAR(64),
`result` VARCHAR(64),
PRIMARY KEY (`query_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
`session_id` VARCHAR(64),
`user_id` VARCHAR(64),
`session_count` INT,
PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_551323_schema_ddl') AS relationships;
