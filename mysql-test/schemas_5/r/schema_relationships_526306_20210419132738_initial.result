CREATE DATABASE `db_526306_20210419132738_initial`;
USE `db_526306_20210419132738_initial`;
CREATE TABLE `banners` (
`id` VARCHAR(50) NOT NULL,
`description` TEXT,
`deleted` BOOLEAN,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `slots` (
`id` VARCHAR(50) NOT NULL,
`description` TEXT,
`deleted` BOOLEAN,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` VARCHAR(50) NOT NULL,
`description` TEXT,
`deleted` BOOLEAN,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rotations` (
`id` VARCHAR(50) NOT NULL,
`banner_id` VARCHAR(50),
`slot_id` VARCHAR(50),
`group_id` VARCHAR(50),
`shows` INT,
`clicks` INT,
`deleted` BOOLEAN,
`deleted_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` VARCHAR(50) NOT NULL,
`rotation_id` VARCHAR(50),
`stamp` TIMESTAMP NULL,
`event_type` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
