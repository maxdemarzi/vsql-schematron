INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 526462_wetu_shop
#
CREATE DATABASE `db_526462_wetu_shop`;
USE `db_526462_wetu_shop`;
CREATE TABLE `tbl_categories` (
`category_id` INT NOT NULL,
`category_name` INT,
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_orders` (
`order_id` INT,
`user_id` INT,
`product_id` INT,
`status` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`location` VARCHAR(50),
`product_name` VARCHAR(50),
`quantity` INT,
`total_price` INT
) CHARACTER SET latin1;
CREATE TABLE `tbl_products` (
`product_id` INT,
`product_name` VARCHAR(50),
`description` VARCHAR(50),
`stock` INT,
`price` INT,
`category` VARCHAR(50),
`date` DATE,
`category_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tbl_roles` (
`role_id` INT NOT NULL,
`role_name` VARCHAR(50),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_users` (
`user_id` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`phone_number` INT,
`location` VARCHAR(50),
`password` VARCHAR(50),
`national_id` VARCHAR(50),
`branch` VARCHAR(50),
`role_id` INT,
`date` DATE
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_526462_wetu_shop') AS relationships;
relationships
Database: db_526462_wetu_shop

Table Connections:
------------------
[Implied]  tbl_orders.product_id -> tbl_products.product_id
[Implied]  tbl_orders.user_id -> tbl_users.user_id
[Implied]  tbl_products.category_id -> tbl_categories.category_id
[Implied]  tbl_users.role_id -> tbl_roles.role_id

DROP DATABASE `db_526462_wetu_shop`;
UNINSTALL EXTENSION vsql_schematron;
