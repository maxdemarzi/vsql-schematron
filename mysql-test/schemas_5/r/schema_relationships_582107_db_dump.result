`version` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` VARCHAR(50) NOT NULL,
`created` TIMESTAMP NULL,
`modified` TIMESTAMP NULL,
`name` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`user_level` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
