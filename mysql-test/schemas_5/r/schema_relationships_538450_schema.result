INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 538450_schema
#
CREATE DATABASE `db_538450_schema`;
USE `db_538450_schema`;
CREATE TABLE `user` (
`id` INT,
`name` VARCHAR(64),
`provider` VARCHAR(64),
`provider_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookmark_list` (
`id` INT,
`name` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bookmark` (
`id` INT,
`name` VARCHAR(64),
`url` VARCHAR(64),
`list_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_538450_schema') AS relationships;
