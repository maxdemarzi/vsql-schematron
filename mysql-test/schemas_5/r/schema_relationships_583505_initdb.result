INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 583505_initdb
#
CREATE DATABASE `db_583505_initdb`;
USE `db_583505_initdb`;
CREATE TABLE `coffees` (
`id` INT,
`coffee_name` VARCHAR(64),
`price` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `salespeople` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`commission_rate` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT,
`company_name` VARCHAR(64),
`street_address` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`zip` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`customer_id` INT,
`salesperson_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`id` INT,
`order_id` INT,
`product_id` INT,
`product_quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_583505_initdb') AS relationships;
relationships
Database: db_583505_initdb

Table Connections:
------------------
[Implied]  order_items.order_id -> orders.id
[Implied]  orders.customer_id -> customers.id

DROP DATABASE `db_583505_initdb`;
UNINSTALL EXTENSION vsql_schematron;
