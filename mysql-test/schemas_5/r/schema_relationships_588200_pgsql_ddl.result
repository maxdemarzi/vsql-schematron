INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 588200_pgsql_ddl
#
CREATE DATABASE `db_588200_pgsql_ddl`;
USE `db_588200_pgsql_ddl`;
CREATE TABLE `organization` (
`id` INT NOT NULL,
`display_name` VARCHAR(50),
`ogrn` BIGINT,
`oktmo` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`organization_id` INT,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`middlename` VARCHAR(50),
`birthday` DATE,
`inn` BIGINT,
`snils` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_588200_pgsql_ddl') AS relationships;
