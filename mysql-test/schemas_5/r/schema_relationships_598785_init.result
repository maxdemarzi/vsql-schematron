INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 598785_init
#
CREATE DATABASE `db_598785_init`;
USE `db_598785_init`;
CREATE TABLE `poll` (
`team_id` VARCHAR(64),
`channel_id` VARCHAR(64),
`title` VARCHAR(64),
`user_id` VARCHAR(64),
PRIMARY KEY (`team_id`, `channel_id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
`id` INT,
`team_id` VARCHAR(64),
`channel_id` VARCHAR(64),
`option` VARCHAR(64),
PRIMARY KEY (`id`, `team_id`, `channel_id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`team_id` VARCHAR(64),
`channel_id` VARCHAR(64),
`user_id` VARCHAR(64),
`option_id` INT,
PRIMARY KEY (`team_id`, `channel_id`, `user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_598785_init') AS relationships;
