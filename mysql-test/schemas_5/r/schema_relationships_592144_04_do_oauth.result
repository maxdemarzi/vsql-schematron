CREATE DATABASE `db_592144_04_do_oauth`;
USE `db_592144_04_do_oauth`;
CREATE TABLE `user_token` (
`token` VARCHAR(64),
`user_id` INT,
`created` DATETIME,
`expires` DATETIME,
PRIMARY KEY (`token`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
`user_id` INT,
`role_id` INT,
`active` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_592144_04_do_oauth') AS relationships;
