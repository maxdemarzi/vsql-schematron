CREATE DATABASE `db_547111_11`;
USE `db_547111_11`;
CREATE TABLE `adhesion` (
`id` VARCHAR(50) NOT NULL,
`period` VARCHAR(50),
`user_id` VARCHAR(50),
`accepted` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `adhesion_member` (
`id` VARCHAR(50) NOT NULL,
`adhesion` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`birthday` TIMESTAMP NULL,
`activity` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
