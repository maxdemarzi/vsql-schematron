[Implied]  camera_nodes.Chk_Objects -> objects.ID
[Implied]  events.camera_id -> camera_nodes.ID
[Implied]  images.camera_id -> camera_nodes.ID
[Implied]  post.id -> objects.ID
[Implied]  post.user_id -> user.id
[Implied]  user.id -> objects.ID

DROP DATABASE `db_562844_imagehub_mariadb_database`;
UNINSTALL EXTENSION vsql_schematron;
