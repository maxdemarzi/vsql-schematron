INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 578493_pokedex
#
CREATE DATABASE `db_578493_pokedex`;
USE `db_578493_pokedex`;
CREATE TABLE `pokedex` (
`pokemon_id` INT,
`id` INT,
`num` INT,
`name` VARCHAR(64),
`img` VARCHAR(64),
`height` VARCHAR(64),
`weight` VARCHAR(64),
`candy` VARCHAR(64),
`candy_count` INT,
`egg` VARCHAR(64),
`spawn_chance` INT,
`avg_spawns` INT,
`spawn_time` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon_type` (
`type_id` INT,
`id` INT,
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon_multipliers` (
`type_id` INT,
`id` INT,
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon_weaknesses` (
`type_id` INT,
`id` INT,
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon_next_evolution` (
`type_id` INT,
`id` INT,
`num` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_578493_pokedex') AS relationships;
relationships
Database: db_578493_pokedex

Table Connections:
