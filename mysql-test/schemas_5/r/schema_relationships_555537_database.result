INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 555537_database
#
CREATE DATABASE `db_555537_database`;
USE `db_555537_database`;
CREATE TABLE `users` (
`id` INT,
`login` VARCHAR(64),
`passwd` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
`user_id1` INT,
`user_id2` INT,
PRIMARY KEY (`user_id1`, `user_id2`)
) CHARACTER SET latin1;
CREATE TABLE `group_messages` (
`id` INT,
`group_id` INT,
`author_id` INT,
`text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`group_id` INT,
`member_id` INT,
PRIMARY KEY (`group_id`, `member_id`)
) CHARACTER SET latin1;
CREATE TABLE `group_msg_views` (
`group_id` INT,
`msg_id` INT,
`viewer_id` INT,
`viewed` BOOL,
PRIMARY KEY (`group_id`, `msg_id`, `viewer_id`)
) CHARACTER SET latin1;
CREATE TABLE `priv_messages` (
`id` INT,
`sender_id` INT,
`receiver_id` INT,
`text` VARCHAR(64),
`viewed` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_555537_database') AS relationships;
relationships
