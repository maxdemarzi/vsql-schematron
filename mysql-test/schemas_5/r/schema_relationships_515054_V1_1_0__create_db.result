) CHARACTER SET latin1;
CREATE TABLE `endpoint` (
`id` VARCHAR(50) NOT NULL,
`lastSeen` TIMESTAMP NULL,
`lastVerified` TIMESTAMP NULL,
`host` TEXT,
`port` INT,
`identity` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nodeInfo` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`host` TEXT,
`port` INT,
`publickey` VARCHAR(50),
`p2pversion` INT,
`clientId` TEXT,
`capabilities` TEXT,
`genesisHash` TEXT,
`bestHash` TEXT,
`totalDifficulty` TEXT,
`identity` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
