INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 525348_blog_management
#
CREATE DATABASE `db_525348_blog_management`;
USE `db_525348_blog_management`;
CREATE TABLE `tbl_blogs` (
`id` VARCHAR(50),
`user_id` VARCHAR(50),
`blog_title` VARCHAR(50),
`blog_description` TEXT,
`image` VARCHAR(50),
`added_on` DATETIME,
`updated_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tbl_blog_tags` (
`id` VARCHAR(50),
`blog_id` VARCHAR(50),
`tag` VARCHAR(50),
`added_on` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `tbl_users` (
`id` VARCHAR(50) NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`email` VARCHAR(50),
`password` TEXT,
`added_on` DATETIME,
`updated_on` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_525348_blog_management') AS relationships;
relationships
Database: db_525348_blog_management

Table Connections:
------------------
[Implied]  tbl_blog_tags.blog_id -> tbl_blogs.id
[Implied]  tbl_blogs.user_id -> tbl_users.id

DROP DATABASE `db_525348_blog_management`;
