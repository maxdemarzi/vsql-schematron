CREATE TABLE `score_card` (
`id` INT,
`version` INT,
`created_by_id` INT,
`created_date` DATETIME,
`edited_by_id` INT,
`edited_date` DATETIME,
`score` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `score_card_item` (
`id` INT,
`version` INT,
`created_by_id` INT,
`created_date` DATETIME,
`description` VARCHAR(64),
`edited_by_id` INT,
`edited_date` DATETIME,
`is_standard_question` BOOL,
`question` VARCHAR(64),
`weight` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `score_card_item_response` (
`id` INT,
`version` INT,
`created_by_id` INT,
`created_date` DATETIME,
`edited_by_id` INT,
`edited_date` DATETIME,
`is_satisfied` BOOL,
`score_card_id` INT,
`score_card_item_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
