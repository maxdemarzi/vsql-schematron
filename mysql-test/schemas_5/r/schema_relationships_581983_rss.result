INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 581983_rss
#
CREATE DATABASE `db_581983_rss`;
USE `db_581983_rss`;
CREATE TABLE `channel` (
`title` VARCHAR(255),
`link` VARCHAR(255),
`description` VARCHAR(255),
`lastupdate` DATETIME,
PRIMARY KEY (`title`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`title` VARCHAR(255),
`link` VARCHAR(255),
`description` VARCHAR(255),
`imgurl` VARCHAR(255),
`ptime` DATETIME,
`chtitle` VARCHAR(255),
PRIMARY KEY (`title`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_581983_rss') AS relationships;
relationships
