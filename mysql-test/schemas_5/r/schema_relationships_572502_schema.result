CREATE DATABASE `db_572502_schema`;
USE `db_572502_schema`;
CREATE TABLE `todos` (
`id` INT NOT NULL,
`groupId` INT,
`task` VARCHAR(50),
`done` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`groupId` INT NOT NULL,
`groupName` VARCHAR(50),
PRIMARY KEY (`groupId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_572502_schema') AS relationships;
