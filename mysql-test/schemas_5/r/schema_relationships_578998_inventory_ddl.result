INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 578998_inventory_ddl
#
CREATE DATABASE `db_578998_inventory_ddl`;
USE `db_578998_inventory_ddl`;
CREATE TABLE `customers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`id` INT,
`customer_id` INT,
`street` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`zip` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`weight` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_number` INT,
`order_date` DATETIME,
`purchaser` INT,
`quantity` INT,
`product_id` INT,
PRIMARY KEY (`order_number`)
) CHARACTER SET latin1;
CREATE TABLE `products_on_hand` (
`product_id` INT,
`quantity` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_578998_inventory_ddl') AS relationships;
relationships
Database: db_578998_inventory_ddl

Table Connections:
------------------
[Implied]  addresses.customer_id -> customers.id
[Implied]  orders.product_id -> products.id
[Implied]  products_on_hand.product_id -> products.id

DROP DATABASE `db_578998_inventory_ddl`;
UNINSTALL EXTENSION vsql_schematron;
