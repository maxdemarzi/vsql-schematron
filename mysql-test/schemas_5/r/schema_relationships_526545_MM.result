INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 526545_MM
#
CREATE DATABASE `db_526545_MM`;
USE `db_526545_MM`;
CREATE TABLE `log` (
`id` INT,
`time` DATETIME,
`ip` VARCHAR(255),
`user_id` VARCHAR(255),
`client_id` VARCHAR(255),
`scheme` VARCHAR(255),
`host` VARCHAR(255),
`method` VARCHAR(255),
`uri` VARCHAR(255),
`status` INT,
`referer` VARCHAR(255),
`useragent` VARCHAR(255),
`accept` VARCHAR(255),
`received_content` VARCHAR(255),
`sent_content` VARCHAR(255),
`request_length` INT,
`response_length` INT,
`request_time` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `log_header` (
`id` INT,
`name` VARCHAR(255),
`value` VARCHAR(255),
PRIMARY KEY (`id`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `log_query` (
`id` INT,
`name` VARCHAR(255),
`value` VARCHAR(255),
PRIMARY KEY (`id`, `name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_526545_MM') AS relationships;
