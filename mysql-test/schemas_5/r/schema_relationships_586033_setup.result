INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 586033_setup
#
CREATE DATABASE `db_586033_setup`;
USE `db_586033_setup`;
CREATE TABLE `games` (
`id` INT NOT NULL,
`startTime` TIMESTAMP NULL,
`duration` INT,
`mode` INT,
`map` INT,
`winner` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `results` (
`id` INT NOT NULL,
`userid` INT,
`gameid` INT,
`kills` INT,
`assists` INT,
`deaths` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playerBadges` (
`id` INT NOT NULL,
`userid` INT,
`badgeid` INT,
`badgeAchieved` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `friends` (
`id` INT NOT NULL,
`userid` INT,
`friendid` INT,
`sentTime` TIMESTAMP NULL,
`accepted` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_586033_setup') AS relationships;
