`updated_at` DATETIME,
`deleted_at` DATETIME,
`db_user` VARCHAR(255),
`db_password` VARCHAR(255),
`db_ip` VARCHAR(255),
`db_name` VARCHAR(255),
`server_name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
`email` VARCHAR(255),
`server_id` INT,
`password` VARCHAR(255)
) CHARACTER SET latin1;
