CREATE DATABASE `db_505604_banco_20de_20dados_20elei_C3_A7_C3_A3o`;
USE `db_505604_banco_20de_20dados_20elei_C3_A7_C3_A3o`;
CREATE TABLE `bdEleicao.tblEleicao` (
`codEleicao` INT,
`tituloEleicao` VARCHAR(64),
`dataCadastramento` DATETIME,
`dataEleicao` DATETIME,
`paisEleicao` VARCHAR(64),
`statusEleicao` VARCHAR(64),
`quantidadeCandidatos` INT,
`votosValidos` INT,
PRIMARY KEY (`codEleicao`)
) CHARACTER SET latin1;
CREATE TABLE `bdEleicao.tblCandidato` (
`cpfCandidato` VARCHAR(64),
`nomeCandidato` VARCHAR(64),
`nomeAbreviado` VARCHAR(64),
`dataNascimento` DATETIME,
`codigoEleicao` INT,
`numeroDoPartido` INT,
`nomeDoPartido` VARCHAR(64),
`votoDoCandidato` INT,
PRIMARY KEY (`cpfCandidato`)
) CHARACTER SET latin1;
CREATE TABLE `bdEleicao.tblResultado` (
`id` INT,
`numeroPartido` INT,
`codigoEleicao` INT,
`dtaEleicao` DATETIME,
`votosBrancos` INT,
`votosNulos` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bdEleicao.logEleicao` (
`logCode` INT,
`logData` DATETIME,
`logStatus` VARCHAR(64),
PRIMARY KEY (`logCode`)
) CHARACTER SET latin1;
