INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 541034_schema
#
CREATE DATABASE `db_541034_schema`;
USE `db_541034_schema`;
CREATE TABLE `parties` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candidates` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`industry_connected` VARCHAR(255),
`party_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voters` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`email` VARCHAR(255),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
`id` INT,
`voter_id` INT,
`candidate_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_541034_schema') AS relationships;
relationships
Database: db_541034_schema

Table Connections:
------------------
[Implied]  candidates.party_id -> parties.id
[Implied]  votes.candidate_id -> candidates.id
[Implied]  votes.voter_id -> voters.id

DROP DATABASE `db_541034_schema`;
UNINSTALL EXTENSION vsql_schematron;
