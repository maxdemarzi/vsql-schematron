INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 510777_012tool-results-tables-create
#
CREATE DATABASE `db_510777_012tool_results_tables_create`;
USE `db_510777_012tool_results_tables_create`;
CREATE TABLE `raw_mac_addrs` (
`tool_run_id` VARCHAR(64),
`mac_addr` VARCHAR(64),
`is_responding` BOOL,
PRIMARY KEY (`tool_run_id`, `mac_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ip_addrs` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`is_responding` BOOL,
PRIMARY KEY (`tool_run_id`, `ip_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_mac_addrs_ip_addrs` (
`tool_run_id` VARCHAR(64),
`mac_addr` VARCHAR(64),
`ip_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `mac_addr`, `ip_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_hostnames` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`hostname` VARCHAR(64),
`reason` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `hostname`, `reason`)
) CHARACTER SET latin1;
CREATE TABLE `raw_vlans` (
`tool_run_id` VARCHAR(64),
`vlan` DECIMAL(10,2),
`description` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `vlan`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ip_nets` (
`tool_run_id` VARCHAR(64),
`ip_net` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_net`)
) CHARACTER SET latin1;
CREATE TABLE `ip_nets_extra_weights` (
`ip_net` VARCHAR(64),
`extra_weight` DECIMAL(10,2),
PRIMARY KEY (`ip_net`)
) CHARACTER SET latin1;
CREATE TABLE `raw_vlans_ip_nets` (
`tool_run_id` VARCHAR(64),
`vlan` DECIMAL(10,2),
`ip_net` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `vlan`, `ip_net`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ip_traceroutes` (
`tool_run_id` VARCHAR(64),
`hop_count` INT,
`rtr_ip_addr` VARCHAR(64),
`dst_ip_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `hop_count`, `rtr_ip_addr`, `dst_ip_addr`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ports` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`port_state` VARCHAR(64),
`port_reason` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`)
) CHARACTER SET latin1;
CREATE TABLE `raw_network_services` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`service_name` VARCHAR(64),
`service_description` VARCHAR(64),
`service_reason` VARCHAR(64),
`observer_ip_addr` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`)
) CHARACTER SET latin1;
CREATE TABLE `raw_nessus_results` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`plugin_id` INT,
`plugin_name` VARCHAR(64),
`plugin_family` VARCHAR(64),
`plugin_type` VARCHAR(64),
`plugin_output` VARCHAR(64),
`severity` INT,
`description` VARCHAR(64),
`solution` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `plugin_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_nessus_results_cves` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`plugin_id` INT,
`cve_id` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `plugin_id`, `cve_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_nessus_results_metasploit_modules` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`plugin_id` INT,
`metasploit_name` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `plugin_id`, `metasploit_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_nse_results` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`script_id` VARCHAR(64),
`script_output` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `script_id`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ssh_host_public_keys` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`ssh_key_type` VARCHAR(64),
`ssh_key_bits` INT,
`ssh_key_fingerprint` VARCHAR(64),
`ssh_key_public` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `ssh_key_type`, `ssh_key_bits`, `ssh_key_fingerprint`)
) CHARACTER SET latin1;
CREATE TABLE `raw_ssh_host_algorithms` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`protocol` VARCHAR(64),
`port` DECIMAL(10,2),
`ssh_algo_type` VARCHAR(64),
`ssh_algo_name` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `ip_addr`, `protocol`, `port`, `ssh_algo_type`, `ssh_algo_name`)
) CHARACTER SET latin1;
CREATE TABLE `raw_operating_systems` (
`tool_run_id` VARCHAR(64),
`ip_addr` VARCHAR(64),
`vendor_name` VARCHAR(64),
`product_name` VARCHAR(64),
`product_version` VARCHAR(64),
`cpe` VARCHAR(64),
`accuracy` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `raw_tool_observations` (
`tool_run_id` VARCHAR(64),
`category` VARCHAR(64),
`observation` VARCHAR(64),
PRIMARY KEY (`tool_run_id`, `category`, `observation`)
) CHARACTER SET latin1;
