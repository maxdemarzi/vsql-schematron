CREATE TABLE `projects` (
`folderName` VARCHAR(64),
`projectID` INT,
`projectName` VARCHAR(64),
`projectDescription` VARCHAR(64),
`exampleResources` VARCHAR(64),
`usedResources` VARCHAR(64),
`githubLink` VARCHAR(64),
`presentationDate` DATETIME,
`presentationTime` DATETIME,
`presentationLink` VARCHAR(64),
PRIMARY KEY (`folderName`, `projectID`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`folderName` VARCHAR(64),
`projectID` INT,
`facultyNumber` INT,
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`courseName` VARCHAR(64),
`courseYear` INT,
`projectTasks` VARCHAR(64),
`manHours` INT
) CHARACTER SET latin1;
