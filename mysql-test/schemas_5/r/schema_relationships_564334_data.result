INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 564334_data
#
CREATE DATABASE `db_564334_data`;
USE `db_564334_data`;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`enabled` BOOLEAN,
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`unit_price` DOUBLE,
`units_in_stock` INT,
`category_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `supplier` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`company` VARCHAR(50),
`address` VARCHAR(50),
`phone` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_564334_data') AS relationships;
