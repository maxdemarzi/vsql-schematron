) CHARACTER SET latin1;
CREATE TABLE `clicks` (
`id` INT NOT NULL,
`link_id` INT,
`click_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queue` (
`id` INT NOT NULL,
`channel` VARCHAR(50),
`job` BLOB,
`pushed_at` INT,
`ttr` INT,
`delay` INT,
`priority` VARCHAR(50),
`reserved_at` INT,
`attempt` INT,
`done_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
