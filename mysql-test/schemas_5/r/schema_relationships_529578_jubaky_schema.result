CREATE DATABASE `db_529578_jubaky_schema`;
USE `db_529578_jubaky_schema`;
CREATE TABLE `Applications` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`repository_addr` VARCHAR(50),
`create_time` DATETIME,
`update_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Groups` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`id` INT NOT NULL,
`email_id` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`create_time` DATETIME,
`last_login_time` DATETIME,
`is_disable` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Jobs` (
`id` INT NOT NULL,
`branch` VARCHAR(50),
`application_id` INT,
`last_build_number` INT,
`tag` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Builds` (
`id` INT NOT NULL,
`branch` VARCHAR(50),
`job_id` INT,
`tag` VARCHAR(50),
`result` TEXT,
`status` VARCHAR(50),
`application_id` INT,
`creator_id` INT,
`create_time` DATETIME,
`start_time` DATETIME,
`finish_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Templates` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`kind` VARCHAR(50),
`yaml` TEXT,
`application_id` INT,
`create_time` DATETIME,
`update_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Permissions` (
`id` INT NOT NULL,
`group_id` INT,
`application_id` INT,
`permission` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GroupMembers` (
`id` INT NOT NULL,
`group_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Deploys` (
`id` INT NOT NULL,
`build_id` INT,
`namespace` VARCHAR(50),
`status` VARCHAR(50),
`application_id` INT,
`template_id` INT,
`creator_id` INT,
`create_time` DATETIME,
`finish_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Credentials` (
`id` INT NOT NULL,
`user_id` INT,
`user_name` VARCHAR(50),
`password` VARCHAR(50),
`key` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
