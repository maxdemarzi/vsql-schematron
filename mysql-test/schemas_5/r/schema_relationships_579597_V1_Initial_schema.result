INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 579597_V1_Initial_schema
#
CREATE DATABASE `db_579597_V1_Initial_schema`;
USE `db_579597_V1_Initial_schema`;
CREATE TABLE `course_lectures` (
`course_id` VARCHAR(64),
`lecture_id` VARCHAR(64),
`lecture_ordinal` INT,
PRIMARY KEY (`course_id`, `lecture_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`course_id` VARCHAR(64),
`course_title` VARCHAR(64),
`course_description` VARCHAR(64),
`author_id` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `lecture_units` (
`lecture_id` VARCHAR(64),
`unit_id` VARCHAR(64),
`unit_ordinal` INT,
PRIMARY KEY (`lecture_id`, `unit_id`)
) CHARACTER SET latin1;
CREATE TABLE `lectures` (
`lecture_id` VARCHAR(64),
`lecture_title` VARCHAR(64),
`lecture_description` VARCHAR(64),
`author_id` VARCHAR(64),
PRIMARY KEY (`lecture_id`)
) CHARACTER SET latin1;
CREATE TABLE `units` (
`unit_id` VARCHAR(64),
`unit_type` VARCHAR(64),
`unit_title` VARCHAR(64),
`author_id` VARCHAR(64),
PRIMARY KEY (`unit_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` VARCHAR(64),
`user_email` VARCHAR(64),
`user_password` VARCHAR(64),
`user_name` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_579597_V1_Initial_schema') AS relationships;
relationships
Database: db_579597_V1_Initial_schema

Table Connections:
