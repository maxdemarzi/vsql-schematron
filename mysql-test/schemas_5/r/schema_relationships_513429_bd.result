INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 513429_bd
#
CREATE DATABASE `db_513429_bd`;
USE `db_513429_bd`;
CREATE TABLE `compradores` (
`Nome` VARCHAR(64),
`id` INT,
`email` VARCHAR(64),
`senha` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `livros` (
`id` INT,
`autor` VARCHAR(64),
`titulo` VARCHAR(64),
`editora` VARCHAR(64),
`preco` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
`idcliente` INT,
`idlivro` INT,
`preco` DECIMAL(10,2),
`nome` VARCHAR(64),
PRIMARY KEY (`idcliente`, `idlivro`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_513429_bd') AS relationships;
