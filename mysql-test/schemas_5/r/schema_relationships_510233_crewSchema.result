CREATE DATABASE `db_510233_crewSchema`;
USE `db_510233_crewSchema`;
CREATE TABLE `departments` (
`id` INT,
`dept` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`dept_id` INT,
`role_id` INT,
`mangr_id` INT,
`is_mangr` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_510233_crewSchema') AS relationships;
