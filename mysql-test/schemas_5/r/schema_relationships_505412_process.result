CREATE DATABASE `db_505412_process`;
USE `db_505412_process`;
CREATE TABLE `active_task` (
`id` INT,
`bpmn_id` VARCHAR(50),
`name` VARCHAR(50),
`type` VARCHAR(50),
`status` VARCHAR(50),
`instance_id` INT
) CHARACTER SET latin1;
CREATE TABLE `process` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`recipe` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `process_instance` (
`id` INT,
`satus` VARCHAR(50),
`process_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_505412_process') AS relationships;
