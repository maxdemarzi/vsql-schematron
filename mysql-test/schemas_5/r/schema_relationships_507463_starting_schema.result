CREATE DATABASE `db_507463_starting_schema`;
USE `db_507463_starting_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`token` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallets` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`fk_user_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`fk_wallet_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_507463_starting_schema') AS relationships;
