CREATE DATABASE `db_508822_cocok`;
USE `db_508822_cocok`;
CREATE TABLE `attribute` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `human` (
`id` INT,
`name` VARCHAR(64),
`jenis_kelamin` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `score` (
`id` INT,
`human_id` INT,
`sub_attribute_id` INT,
`value` INT
) CHARACTER SET latin1;
CREATE TABLE `sub_attribute` (
`id` INT,
`attribute_id` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_508822_cocok') AS relationships;
