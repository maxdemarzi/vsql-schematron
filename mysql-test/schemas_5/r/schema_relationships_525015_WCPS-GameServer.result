INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 525015_WCPS-GameServer
#
CREATE DATABASE `db_525015_WCPS_GameServer`;
USE `db_525015_WCPS_GameServer`;
CREATE TABLE `user_stats` (
`ID` VARCHAR(50),
`kills` VARCHAR(50),
`deaths` VARCHAR(50),
`headshots` VARCHAR(50),
`bombs_planted` VARCHAR(50),
`bombs_defused` VARCHAR(50),
`rounds_played` VARCHAR(50),
`flags_taken` VARCHAR(50),
`victories` VARCHAR(50),
`defeats` VARCHAR(50),
`vehicles_destroyed` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`ID` VARCHAR(50) NOT NULL,
`xp` VARCHAR(50),
`money` VARCHAR(50),
`premium` VARCHAR(50),
`premium_expiredate` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_525015_WCPS_GameServer') AS relationships;
relationships
Database: db_525015_WCPS_GameServer

Table Connections:
------------------
[Implied]  user_stats.ID -> users.ID

DROP DATABASE `db_525015_WCPS_GameServer`;
UNINSTALL EXTENSION vsql_schematron;
