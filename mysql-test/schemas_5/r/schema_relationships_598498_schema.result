[Implied]  configured_connector.connector_id -> connector.id
[Implied]  connector_property.connector_id -> connector.id
[Implied]  integration_step.action_instance_id -> action_instance.id
[Implied]  integration_step.integration_id -> integration.id

DROP DATABASE `db_598498_schema`;
UNINSTALL EXTENSION vsql_schematron;
