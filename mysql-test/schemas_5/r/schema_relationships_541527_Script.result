PRIMARY KEY (`vote_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT,
`username` VARCHAR(64),
`password_hash` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
