INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 577118_schema
#
CREATE DATABASE `db_577118_schema`;
USE `db_577118_schema`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`password_hash` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bugs` (
`id` INT,
`created_on` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`priority` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `archive` (
`id` INT,
`archived_on` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`resolved` VARCHAR(64),
`user_id` INT,
`archived_by` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_577118_schema') AS relationships;
