INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 517097_contacts
#
CREATE DATABASE `db_517097_contacts`;
USE `db_517097_contacts`;
CREATE TABLE `address` (
`address_id` INT,
`contact_id` INT,
`address_type` VARCHAR(255),
`address` VARCHAR(255),
`City` VARCHAR(255),
`State` VARCHAR(255),
`Zip` INT
) CHARACTER SET latin1;
CREATE TABLE `contact` (
`Contact_id` INT,
`Fname` VARCHAR(255),
`Mname` VARCHAR(255),
`Lname` VARCHAR(255),
PRIMARY KEY (`Contact_id`)
) CHARACTER SET latin1;
CREATE TABLE `date` (
`date_id` INT,
`contact_id` INT,
`date_type` VARCHAR(255),
`date` DATETIME,
PRIMARY KEY (`date_id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
`phone_id` INT,
`contact_id` INT,
`phone_type` VARCHAR(255),
`area_code` INT,
`number` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_517097_contacts') AS relationships;
relationships
Database: db_517097_contacts

Table Connections:
------------------
[Implied]  address.contact_id -> contact.Contact_id
[Implied]  date.contact_id -> contact.Contact_id
[Implied]  phone.contact_id -> contact.Contact_id

DROP DATABASE `db_517097_contacts`;
UNINSTALL EXTENSION vsql_schematron;
