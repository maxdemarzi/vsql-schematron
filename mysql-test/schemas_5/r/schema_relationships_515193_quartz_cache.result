INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 515193_quartz_cache
#
CREATE DATABASE `db_515193_quartz_cache`;
USE `db_515193_quartz_cache`;
CREATE TABLE `ruoyi.QRTZ_JOB_DETAILS` (
`sched_name` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`description` VARCHAR(64),
`job_class_name` VARCHAR(64),
`is_durable` VARCHAR(64),
`is_nonconcurrent` VARCHAR(64),
`is_update_data` VARCHAR(64),
`requests_recovery` VARCHAR(64),
`job_data` VARCHAR(64),
PRIMARY KEY (`sched_name`, `job_name`, `job_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_TRIGGERS` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`description` VARCHAR(64),
`next_fire_time` INT,
`prev_fire_time` INT,
`priority` INT,
`trigger_state` VARCHAR(64),
`trigger_type` VARCHAR(64),
`start_time` INT,
`end_time` INT,
`calendar_name` VARCHAR(64),
`misfire_instr` INT,
`job_data` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_SIMPLE_TRIGGERS` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`repeat_count` INT,
`repeat_interval` INT,
`times_triggered` INT,
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_CRON_TRIGGERS` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`cron_expression` VARCHAR(64),
`time_zone_id` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_BLOB_TRIGGERS` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`blob_data` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_CALENDARS` (
`sched_name` VARCHAR(64),
`calendar_name` VARCHAR(64),
`calendar` VARCHAR(64),
PRIMARY KEY (`sched_name`, `calendar_name`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_PAUSED_TRIGGER_GRPS` (
`sched_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_group`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_FIRED_TRIGGERS` (
`sched_name` VARCHAR(64),
`entry_id` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`instance_name` VARCHAR(64),
`fired_time` INT,
`sched_time` INT,
`priority` INT,
`state` VARCHAR(64),
`job_name` VARCHAR(64),
`job_group` VARCHAR(64),
`is_nonconcurrent` VARCHAR(64),
`requests_recovery` VARCHAR(64),
PRIMARY KEY (`sched_name`, `entry_id`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_SCHEDULER_STATE` (
`sched_name` VARCHAR(64),
`instance_name` VARCHAR(64),
`last_checkin_time` INT,
`checkin_interval` INT,
PRIMARY KEY (`sched_name`, `instance_name`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_LOCKS` (
`sched_name` VARCHAR(64),
`lock_name` VARCHAR(64),
PRIMARY KEY (`sched_name`, `lock_name`)
) CHARACTER SET latin1;
CREATE TABLE `ruoyi.QRTZ_SIMPROP_TRIGGERS` (
`sched_name` VARCHAR(64),
`trigger_name` VARCHAR(64),
`trigger_group` VARCHAR(64),
`str_prop_1` VARCHAR(64),
`str_prop_2` VARCHAR(64),
`str_prop_3` VARCHAR(64),
`int_prop_1` INT,
`int_prop_2` INT,
`long_prop_1` INT,
`long_prop_2` INT,
`dec_prop_1` DECIMAL(10,2),
`dec_prop_2` DECIMAL(10,2),
`bool_prop_1` VARCHAR(64),
`bool_prop_2` VARCHAR(64),
PRIMARY KEY (`sched_name`, `trigger_name`, `trigger_group`)
) CHARACTER SET latin1;
