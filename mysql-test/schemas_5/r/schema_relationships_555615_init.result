CREATE DATABASE `db_555615_init`;
USE `db_555615_init`;
CREATE TABLE `menu` (
`id` INT,
`name` VARCHAR(64),
`mtype` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dishes` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`rating` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`man_date` DATETIME,
`available_until` DATETIME,
`man_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PD` (
`pid` INT,
`did` INT,
PRIMARY KEY (`pid`, `did`)
) CHARACTER SET latin1;
CREATE TABLE `MD` (
`mid` INT,
`did` INT,
PRIMARY KEY (`did`, `mid`)
) CHARACTER SET latin1;
