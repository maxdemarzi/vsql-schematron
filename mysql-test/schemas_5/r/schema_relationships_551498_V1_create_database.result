INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 551498_V1_create_database
#
CREATE DATABASE `db_551498_V1_create_database`;
USE `db_551498_V1_create_database`;
CREATE TABLE `books` (
`isbn` VARCHAR(64),
`title` VARCHAR(64),
`authors` VARCHAR(64),
`description` VARCHAR(64),
`thumbnail_uri` VARCHAR(64),
`added` DATETIME,
PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `collections` (
`name` VARCHAR(64),
`preferred_sort` VARCHAR(64),
`sort_ascending` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `collection_books` (
`collection_name` VARCHAR(64),
`isbn` VARCHAR(64),
PRIMARY KEY (`collection_name`, `isbn`)
) CHARACTER SET latin1;
CREATE TABLE `currently_reading_books` (
`isbn` VARCHAR(64),
`started` DATETIME,
PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `read_books` (
`isbn` VARCHAR(64),
`started` DATETIME,
`finished` DATETIME,
PRIMARY KEY (`isbn`, `started`)
) CHARACTER SET latin1;
CREATE TABLE `rated_books` (
`isbn` VARCHAR(64),
`rating` INT,
PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_551498_V1_create_database') AS relationships;
relationships
Database: db_551498_V1_create_database

Table Connections:
------------------
[Implied]  collection_books.collection_name -> collections.name
[Implied]  collection_books.isbn -> books.isbn
[Implied]  currently_reading_books.isbn -> books.isbn
[Implied]  rated_books.isbn -> books.isbn
[Implied]  read_books.isbn -> books.isbn

DROP DATABASE `db_551498_V1_create_database`;
UNINSTALL EXTENSION vsql_schematron;
