INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 536174_init-tables
#
CREATE DATABASE `db_536174_init_tables`;
USE `db_536174_init_tables`;
CREATE TABLE `settings` (
`id` INT,
`data` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `people` (
`uid` VARCHAR(64),
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`uname` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`gid` VARCHAR(64),
`title` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
`uid` VARCHAR(64),
`mid` VARCHAR(64),
`time` VARCHAR(64),
`content` VARCHAR(64),
`gid` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `services` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subscriptions` (
`uid` VARCHAR(64),
`service` INT
) CHARACTER SET latin1;
CREATE TABLE `servicedays` (
`id` INT,
`day` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_536174_init_tables') AS relationships;
