`date` DATETIME,
`x` DECIMAL(10,2),
`y` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Activities` (
`activity_id` INT,
`user_id` INT,
PRIMARY KEY (`activity_id`, `user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Buddies` (
`buddy1` INT,
`buddy2` INT,
