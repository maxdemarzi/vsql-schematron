`id` INT,
`name` VARCHAR(64),
`username` VARCHAR(64),
`age` INT,
`gender` VARCHAR(64),
`city` VARCHAR(64),
`x` DECIMAL(10,2),
`y` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Activity` (
