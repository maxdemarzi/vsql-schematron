CREATE DATABASE `db_522235_V1_0_create_tables_script`;
USE `db_522235_V1_0_create_tables_script`;
CREATE TABLE `POST` (
`ID` INT,
`TITLE` VARCHAR(64),
`CONTENT` VARCHAR(64),
`created_on` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `POST_COMMENT` (
`id` INT,
`review` VARCHAR(64),
`created_on` DATETIME,
`POST_ID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_details` (
`created_by` VARCHAR(64),
`created_on` DATETIME,
`POST_ID` INT,
PRIMARY KEY (`POST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
`POST_ID` INT,
`TAG_ID` INT,
`created_on` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_522235_V1_0_create_tables_script') AS relationships;
