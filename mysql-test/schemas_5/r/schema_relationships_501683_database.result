CREATE DATABASE `db_501683_database`;
USE `db_501683_database`;
CREATE TABLE `reservations` (
`reservation_id` INT NOT NULL,
`user_id` INT,
`room_id` INT,
`booking_date` DATE,
`no_adults` INT,
`no_children` INT,
`reservation_created` TIMESTAMP NULL,
PRIMARY KEY (`reservation_id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`payment_id` INT NOT NULL,
`user_id` INT,
`reservation_id` INT,
`currency` VARCHAR(50),
`method` VARCHAR(50),
`amount` INT,
PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_501683_database') AS relationships;
