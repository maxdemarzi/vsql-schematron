INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 566232_schema
#
CREATE DATABASE `db_566232_schema`;
USE `db_566232_schema`;
CREATE TABLE `locations` (
`id` INT,
`search_query` VARCHAR(64),
`formatted_query` VARCHAR(64),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `weathers` (
`id` INT,
`summary` VARCHAR(64),
`time` VARCHAR(64),
`date_created` VARCHAR(64),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id` INT,
`title` VARCHAR(64),
`overview` VARCHAR(64),
`average_votes` DECIMAL(10,2),
`total_votes` INT,
`popularity` DECIMAL(10,2),
`released_on` VARCHAR(64),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `yelp` (
`id` INT,
`image_url` VARCHAR(64),
`name` VARCHAR(64),
`price` VARCHAR(64),
`rating` DECIMAL(10,2),
`url` VARCHAR(64),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trails` (
`id` INT,
`name` VARCHAR(64),
`location` VARCHAR(64),
`length` DECIMAL(10,2),
`stars` DECIMAL(10,2),
`star_votes` INT,
`summary` VARCHAR(64),
`trail_url` VARCHAR(64),
`conditions` VARCHAR(64),
`condition_date` VARCHAR(64),
`location_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_566232_schema') AS relationships;
relationships
Database: db_566232_schema

Table Connections:
