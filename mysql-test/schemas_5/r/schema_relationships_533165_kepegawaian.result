INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 533165_kepegawaian
#
CREATE DATABASE `db_533165_kepegawaian`;
USE `db_533165_kepegawaian`;
CREATE TABLE `levels` (
`level_id` INT NOT NULL,
`level_nama` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`level_id`)
) CHARACTER SET latin1;
CREATE TABLE `pegawai` (
`id_pegawai` INT NOT NULL,
`nip` VARCHAR(50),
`nama` VARCHAR(50),
`tmp_lahir` VARCHAR(50),
`tgl_lahir` DATE,
`jk` VARCHAR(50),
`foto` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id_pegawai`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id_user` INT,
`email` VARCHAR(50),
`password` VARCHAR(50),
`level_id` INT,
`foto_user` VARCHAR(50),
`active` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_533165_kepegawaian') AS relationships;
