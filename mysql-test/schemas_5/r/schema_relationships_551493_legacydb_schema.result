CREATE DATABASE `db_551493_legacydb_schema`;
USE `db_551493_legacydb_schema`;
CREATE TABLE `Booking` (
`id` INT,
`cancellationCode` VARCHAR(64),
`contactEmail` VARCHAR(64),
`createdOn` DATETIME,
`performance_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Ticket` (
`id` INT,
`price` DECIMAL(10,2),
`number` INT,
`rowNumber` INT,
`section_id` INT,
`ticketCategory_id` INT,
`tickets_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_551493_legacydb_schema') AS relationships;
