CREATE TABLE `mountains` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peaks` (
`id` INT,
`name` VARCHAR(64),
`mountain_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`name` VARCHAR(64),
`author_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
`id` INT,
`client_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT,
`client_id` INT,
`project_lead_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_502481_05_20Table_20Relations_20_20Lab') AS relationships;
