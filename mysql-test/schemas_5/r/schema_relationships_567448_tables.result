INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 567448_tables
#
CREATE DATABASE `db_567448_tables`;
USE `db_567448_tables`;
CREATE TABLE `user` (
`userId` VARCHAR(255),
`userActivationToken` VARCHAR(255),
`userBio` VARCHAR(255),
`userEmail` VARCHAR(255),
`userFirstName` VARCHAR(255),
`userHash` VARCHAR(255),
`userImage` VARCHAR(255),
`userLastName` VARCHAR(255),
`userSalt` VARCHAR(255),
`userUserName` VARCHAR(255),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `hub` (
`hubId` VARCHAR(255),
`hubUserId` VARCHAR(255),
`hubLocation` VARCHAR(255),
`hubName` VARCHAR(255),
PRIMARY KEY (`hubId`)
) CHARACTER SET latin1;
CREATE TABLE `level` (
`levelId` VARCHAR(255),
`levelName` VARCHAR(255),
`levelNumber` INT,
PRIMARY KEY (`levelId`)
) CHARACTER SET latin1;
CREATE TABLE `reputation` (
`reputationId` VARCHAR(255),
`reputationHubId` VARCHAR(255),
`reputationLevelId` VARCHAR(255),
`reputationUserId` VARCHAR(255),
`reputationPoint` INT,
PRIMARY KEY (`reputationId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_567448_tables') AS relationships;
relationships
Database: db_567448_tables

Table Connections:
------------------
[Implied]  hub.hubUserId -> user.userId
[Implied]  reputation.reputationHubId -> hub.hubId
[Implied]  reputation.reputationLevelId -> level.levelId
[Implied]  reputation.reputationUserId -> user.userId

DROP DATABASE `db_567448_tables`;
UNINSTALL EXTENSION vsql_schematron;
