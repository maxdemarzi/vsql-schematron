INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 566890_schema-postressql
#
CREATE DATABASE `db_566890_schema_postressql`;
USE `db_566890_schema_postressql`;
CREATE TABLE `GROUPS` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`IDENT` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GROUP_RIGHTS` (
`GROUP_ID` DECIMAL(10,2),
`RIGHT_ID` DECIMAL(10,2),
PRIMARY KEY (`GROUP_ID`, `RIGHT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RIGHTS` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`IDENT` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLES` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`IDENT` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ROLE_GROUPS` (
`ROLE_ID` DECIMAL(10,2),
`GROUP_ID` DECIMAL(10,2),
PRIMARY KEY (`ROLE_ID`, `GROUP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `USERS` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`SALT` VARCHAR(64),
`EMAIL` VARCHAR(64),
`ENABLED` DECIMAL(10,2),
`DT_CREATE` DATETIME,
`DT_UPDATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ACCOUNTS` (
`ID` DECIMAL(10,2),
`LAST_NAME` VARCHAR(64),
`FIRST_NAME` VARCHAR(64),
`MIDDLE_NAME` VARCHAR(64),
`LOCKED` DECIMAL(10,2),
`ACCOUNT_EXPIRED` DECIMAL(10,2),
`CREDENTIAL_EXPIRED` DECIMAL(10,2),
`DT_CREATE` DATETIME,
`DT_UPDATE` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLES` (
`USER_ID` DECIMAL(10,2),
`ROLE_ID` DECIMAL(10,2),
PRIMARY KEY (`USER_ID`, `ROLE_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_566890_schema_postressql') AS relationships;
relationships
Database: db_566890_schema_postressql

Table Connections:
------------------
[Implied]  GROUP_RIGHTS.GROUP_ID -> GROUPS.ID
[Implied]  GROUP_RIGHTS.RIGHT_ID -> RIGHTS.ID
