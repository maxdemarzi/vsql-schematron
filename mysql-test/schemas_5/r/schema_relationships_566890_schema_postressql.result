[Implied]  ROLE_GROUPS.ROLE_ID -> ROLES.ID
[Implied]  USER_ROLES.ROLE_ID -> ROLES.ID
[Implied]  USER_ROLES.USER_ID -> USERS.ID

DROP DATABASE `db_566890_schema_postressql`;
UNINSTALL EXTENSION vsql_schematron;
