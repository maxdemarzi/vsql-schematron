CREATE DATABASE `db_572419_V1_0_0_INITIAL_MODEL`;
USE `db_572419_V1_0_0_INITIAL_MODEL`;
CREATE TABLE `PARENTS` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`CREATED` DATETIME,
`MODIFIED` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHILDREN` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
`PARENT_ID` DECIMAL(10,2),
`CREATED` DATETIME,
`MODIFIED` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
