CREATE DATABASE `db_568191_10119254_Kepegawaian`;
USE `db_568191_10119254_Kepegawaian`;
CREATE TABLE `data_gaji` (
`kd_gaji` VARCHAR(50),
`nip` VARCHAR(50),
`tglMasuk` DATE,
`golongan` VARCHAR(50),
`tunjangan` INT,
`gajiPokok` INT
) CHARACTER SET latin1;
CREATE TABLE `data_pegawai` (
`nip` VARCHAR(50) NOT NULL,
`nama` VARCHAR(50),
`jenisKelamin` VARCHAR(50),
`tglLahir` DATE,
`alamat` TEXT,
`status` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`nip`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT NOT NULL,
`username` VARCHAR(50),
`nama` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
