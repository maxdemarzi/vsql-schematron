CREATE DATABASE `db_564220_pb`;
USE `db_564220_pb`;
CREATE TABLE `Activation` (
`id` INT,
`date_added` DATETIME,
`date_modyfication` DATETIME,
`activationLink` VARCHAR(255),
`captcha` VARCHAR(255),
`confirmPassword` VARCHAR(255),
`emailLogin` VARCHAR(255),
`password` VARCHAR(255),
`PrivacyPolicy` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Blog` (
`id` INT,
`DATE_ADDED` DATETIME,
`DATE_MODYFICATION` DATETIME,
`name` VARCHAR(255),
`owner_id` INT,
`category_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BlogEntry` (
`id` INT,
`DATE_ADDED` DATETIME,
`DATE_MODYFICATION` DATETIME,
`allowComment` INT,
`author` VARCHAR(255),
`content` VARCHAR(255),
`entryState` VARCHAR(255),
`publishDate` DATETIME,
`title` VARCHAR(255),
`blog_id` INT,
`comment_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`id` INT,
`date_added` DATETIME,
`date_modyfication` DATETIME,
`name` VARCHAR(255),
`PARENT_CATEGORY_ID` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`id` INT,
`DATE_ADDED` DATETIME,
`DATE_MODYFICATION` DATETIME,
`content` VARCHAR(255),
`title` VARCHAR(255),
`userName` VARCHAR(255),
`userId` INT,
`parent_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PageContent` (
`ID` INT,
`name` VARCHAR(255),
`value` VARCHAR(255),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Ranking` (
`id` INT,
`DATE_ADDED` DATETIME,
`DATE_MODYFICATION` DATETIME,
`clazzName` VARCHAR(255),
`objectId` VARCHAR(255),
`point` INT,
`summaryResult` DECIMAL(10,2),
`userName` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLE` (
`userId` INT,
`roleId` INT
) CHARACTER SET latin1;
CREATE TABLE `hibernate_sequences` (
`sequence_name` VARCHAR(255),
`sequence_next_hi_value` INT
) CHARACTER SET latin1;
