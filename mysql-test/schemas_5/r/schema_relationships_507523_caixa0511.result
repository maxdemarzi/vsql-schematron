) CHARACTER SET latin1;
CREATE TABLE `tb_produto` (
`idt_produto` INT NOT NULL,
`nme_produto` VARCHAR(50),
`vlr_produto` DECIMAL(10,2),
`vlr_produto_token` INT,
PRIMARY KEY (`idt_produto`)
) CHARACTER SET latin1;
