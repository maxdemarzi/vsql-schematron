INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 529981_schema
#
CREATE DATABASE `db_529981_schema`;
USE `db_529981_schema`;
CREATE TABLE `department` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`role_title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_529981_schema') AS relationships;
relationships
Database: db_529981_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.employee_id
[Implied]  employee.role_id -> roles.id
[Implied]  roles.department_id -> department.id

DROP DATABASE `db_529981_schema`;
UNINSTALL EXTENSION vsql_schematron;
