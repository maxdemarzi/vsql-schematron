INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 501563_bibliotheek
#
CREATE DATABASE `db_501563_bibliotheek`;
USE `db_501563_bibliotheek`;
CREATE TABLE `book` (
`ISBN` INT,
`Title` VARCHAR(64),
`Author` VARCHAR(64),
`ShortDescription` VARCHAR(64),
`Edition` VARCHAR(64),
`ImageURL` VARCHAR(64),
`UpdatedDate` DATETIME,
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `copy` (
`CopyID` INT,
`LendingPeriod` INT,
`BookISBN` INT,
`UpdatedDate` DATETIME,
PRIMARY KEY (`CopyID`)
) CHARACTER SET latin1;
CREATE TABLE `member` (
`MemberID` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`Street` VARCHAR(64),
`HouseNumber` VARCHAR(64),
`City` VARCHAR(64),
`PhoneNumber` VARCHAR(64),
`EmailAddress` VARCHAR(64),
`Fine` DECIMAL(10,2),
`UpdatedDate` DATETIME,
PRIMARY KEY (`MemberID`)
) CHARACTER SET latin1;
CREATE TABLE `reservation` (
`ReservationID` INT,
`ReservationDate` DATETIME,
`MemberID` INT,
`CopyID` INT,
`UpdatedDate` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_501563_bibliotheek') AS relationships;
relationships
Database: db_501563_bibliotheek

Table Connections:
------------------
[Implied]  copy.BookISBN -> book.ISBN
[Implied]  reservation.CopyID -> copy.CopyID
[Implied]  reservation.MemberID -> member.MemberID

DROP DATABASE `db_501563_bibliotheek`;
