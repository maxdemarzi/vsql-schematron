CREATE DATABASE `db_526815_table_create`;
USE `db_526815_table_create`;
CREATE TABLE `physical_unit` (
`id` INT NOT NULL,
`name` CHAR(50),
`description` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor_type` (
`id` INT NOT NULL,
`name` CHAR(50),
`physical_unit` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
`id` INT NOT NULL,
`description` CHAR(50),
`olc_code` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sensor` (
`id` INT NOT NULL,
`type` INT,
`location` INT,
`name` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurement` (
`id` INT NOT NULL,
`time` VARCHAR(50),
`sensor_id` INT,
`raw_value` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
