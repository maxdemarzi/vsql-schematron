CREATE DATABASE `db_578906_ddl`;
USE `db_578906_ddl`;
CREATE TABLE `customers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`address` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `credit_cards` (
`id` INT NOT NULL,
`provider` VARCHAR(50),
`number` VARCHAR(50),
`security_code` VARCHAR(50),
`expiry_date` VARCHAR(50),
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_578906_ddl') AS relationships;
