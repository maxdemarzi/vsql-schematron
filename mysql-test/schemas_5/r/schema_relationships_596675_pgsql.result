CREATE DATABASE `db_596675_pgsql`;
USE `db_596675_pgsql`;
CREATE TABLE `books` (
`id` INT,
`book_name` VARCHAR(64),
`author` VARCHAR(64),
`seller` VARCHAR(64),
`available` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `availability_zone` (
`id` INT,
`book_name` VARCHAR(64),
`address` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
