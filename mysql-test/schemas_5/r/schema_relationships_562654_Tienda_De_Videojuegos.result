CREATE DATABASE `db_562654_Tienda_De_Videojuegos`;
USE `db_562654_Tienda_De_Videojuegos`;
CREATE TABLE `usuario` (
`id_usu` INT,
`niv_usu` VARCHAR(64),
`nom_usu` VARCHAR(64),
`con_usu` VARCHAR(64),
PRIMARY KEY (`id_usu`)
) CHARACTER SET latin1;
CREATE TABLE `distribuidora` (
`id_dis` INT,
`nom_dis` VARCHAR(64),
`tel_dis` VARCHAR(64),
`dir_dis` VARCHAR(64),
`cue_dis` VARCHAR(64),
PRIMARY KEY (`id_dis`)
) CHARACTER SET latin1;
CREATE TABLE `videojuego` (
`id_vid` INT,
`iddis_vid` INT,
`nom_vid` VARCHAR(64),
`des_vid` VARCHAR(64),
`con_vid` VARCHAR(64),
`cla_vid` VARCHAR(64),
`gen_vid` VARCHAR(64),
`pre_vid` DECIMAL(10,2),
`stock_vid` INT,
PRIMARY KEY (`id_vid`)
) CHARACTER SET latin1;
CREATE TABLE `venta` (
`id_ven` VARCHAR(64),
`idusu_ven` INT,
`fec_ven` DATETIME,
`tot_ven` DECIMAL(10,2),
PRIMARY KEY (`id_ven`)
) CHARACTER SET latin1;
CREATE TABLE `detallesventa` (
`idvid_detven` INT,
`idven_detven` VARCHAR(64),
`can_detven` INT,
`tot_detven` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `compra` (
`id_com` VARCHAR(64),
`idusu_com` INT,
`iddis_com` INT,
`fec_com` DATETIME,
`tot_com` DECIMAL(10,2),
PRIMARY KEY (`id_com`)
) CHARACTER SET latin1;
CREATE TABLE `detallescompra` (
`idvid_detcom` INT,
`idcom_detcom` VARCHAR(64),
`can_detcom` INT,
`tot_detcom` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `corte` (
`id_cor` INT,
`idusu_cor` INT,
`fec_cor` DATETIME,
`mon_cor` DECIMAL(10,2),
PRIMARY KEY (`id_cor`)
) CHARACTER SET latin1;
