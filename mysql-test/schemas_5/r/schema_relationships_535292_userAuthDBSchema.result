CREATE DATABASE `db_535292_userAuthDBSchema`;
USE `db_535292_userAuthDBSchema`;
CREATE TABLE `tblUsers` (
`fldID` INT,
`fldFirstName` VARCHAR(64),
`fldLastName` VARCHAR(64),
`fldEmail` VARCHAR(64),
`fldPassword` VARCHAR(64),
`fldCreatedAt` DATETIME,
`fldUpdatedAt` DATETIME,
PRIMARY KEY (`fldID`)
) CHARACTER SET latin1;
CREATE TABLE `tblActivationTokens` (
`fldToken` VARCHAR(64),
`fldTokenDateIssued` DATETIME,
`fldTokenDateUsed` DATETIME,
`fldIsActivated` BOOL,
`fldFKUserID` INT,
PRIMARY KEY (`fldToken`, `fldFKUserID`)
) CHARACTER SET latin1;
CREATE TABLE `tblSessions` (
`fldSessionID` VARCHAR(64),
`fldCreatedAt` DATETIME,
`fldLastActive` DATETIME,
`fldFKUserID` INT,
PRIMARY KEY (`fldFKUserID`, `fldSessionID`)
) CHARACTER SET latin1;
