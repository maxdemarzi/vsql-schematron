INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 552952_circular_reference_emma
#
CREATE DATABASE `db_552952_circular_reference_emma`;
USE `db_552952_circular_reference_emma`;
CREATE TABLE `Teams` (
`team_name` VARCHAR(64),
`captain` VARCHAR(64),
PRIMARY KEY (`team_name`)
) CHARACTER SET latin1;
CREATE TABLE `Players` (
`player_name` VARCHAR(64),
`team` VARCHAR(64),
PRIMARY KEY (`player_name`)
) CHARACTER SET latin1;
CREATE TABLE `Fans` (
`fan_name` VARCHAR(64),
PRIMARY KEY (`fan_name`)
) CHARACTER SET latin1;
CREATE TABLE `Colours` (
`colour_id` INT,
`R_value` VARCHAR(64),
`G_value` VARCHAR(64),
`B_value` VARCHAR(64),
PRIMARY KEY (`colour_id`)
) CHARACTER SET latin1;
CREATE TABLE `Team_Colours` (
`team` VARCHAR(64),
`colour` INT,
PRIMARY KEY (`team`, `colour`)
) CHARACTER SET latin1;
CREATE TABLE `Fan_Fav_Colours` (
`fan` VARCHAR(64),
`colour` INT,
PRIMARY KEY (`fan`, `colour`)
) CHARACTER SET latin1;
CREATE TABLE `Fan_Fav_Players` (
`fan` VARCHAR(64),
`player` VARCHAR(64),
PRIMARY KEY (`fan`, `player`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_552952_circular_reference_emma') AS relationships;
