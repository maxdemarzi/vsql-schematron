INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 518863_schema
#
CREATE DATABASE `db_518863_schema`;
USE `db_518863_schema`;
CREATE TABLE `account` (
`id` INT,
`username` VARCHAR(64),
`verified` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `following` (
`id` INT,
`follower_id` INT,
`followed_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`account_id` INT,
`name` VARCHAR(64),
`type` VARCHAR(64),
`brand` VARCHAR(64),
`color` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` INT,
`account_id` INT,
`product_id` INT,
`category` INT,
`promotional` BOOL,
`price` DECIMAL(10,2),
`discount` DECIMAL(10,2),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_518863_schema') AS relationships;
relationships
