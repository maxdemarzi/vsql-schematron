INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 555841_setup
#
CREATE DATABASE `db_555841_setup`;
USE `db_555841_setup`;
CREATE TABLE `quiz` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
`id` VARCHAR(50) NOT NULL,
`quizId` VARCHAR(50),
`text` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
`id` VARCHAR(50) NOT NULL,
`questionId` VARCHAR(50),
`text` TEXT,
`correct` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_555841_setup') AS relationships;
relationships
Database: db_555841_setup

