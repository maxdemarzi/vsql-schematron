CREATE DATABASE `db_515844_schema`;
USE `db_515844_schema`;
CREATE TABLE `DEPT` (
`DEPTNO` INT,
`DNAME` VARCHAR(64),
`LOC` VARCHAR(64),
PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
`EMPNO` INT,
`ENAME` VARCHAR(64),
`JOB` VARCHAR(64),
`MGR` INT,
`HIREDATE` DATETIME,
`SAL` DECIMAL(10,2),
`COMM` DECIMAL(10,2),
`DEPTNO` INT,
PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_515844_schema') AS relationships;
