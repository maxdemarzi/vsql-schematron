INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 509719_031_entity_inventory.mysql
#
CREATE DATABASE `db_509719_031_entity_inventory_mysql`;
USE `db_509719_031_entity_inventory_mysql`;
CREATE TABLE `item_variant_codes` (
`variant_code` VARCHAR(64),
`variant_description` VARCHAR(64),
PRIMARY KEY (`variant_code`)
) CHARACTER SET latin1;
CREATE TABLE `item_variants` (
`entity_id` INT,
`product_id` INT,
`variant_code` VARCHAR(64),
`created_by` INT,
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `inv_master` (
`inventory_id` INT,
`entity_id` INT,
`product_id` INT,
`variant_code` VARCHAR(64),
`total_on_hand` DECIMAL(10,2),
`total_in_wip` DECIMAL(10,2),
`total_on_order` DECIMAL(10,2),
`total_reserved` DECIMAL(10,2),
`total_unshipped_sold` DECIMAL(10,2),
`total_shipped_sold` DECIMAL(10,2),
`created_by` INT,
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`inventory_id`)
) CHARACTER SET latin1;
CREATE TABLE `inv_transactions` (
`inv_transaction_id` INT,
`inv_transaction_type` VARCHAR(64),
`reference_note` VARCHAR(64),
`reference_table` VARCHAR(64),
`reference_key_int` INT,
`reference_key_char` VARCHAR(64),
`inventory_id_1` INT,
`inventory_id_2` INT,
`quantity_on_hand_delta_1` DECIMAL(10,2),
`quantity_on_hand_delta_2` DECIMAL(10,2),
`quantity_in_wip_delta_1` DECIMAL(10,2),
`quantity_in_wip_delta_2` DECIMAL(10,2),
`quantity_on_order_delta_1` DECIMAL(10,2),
`quantity_on_order_delta_2` DECIMAL(10,2),
`quantity_reserved_delta_1` DECIMAL(10,2),
`quantity_reserved_delta_2` DECIMAL(10,2),
`quantity_unshipped_delta_1` DECIMAL(10,2),
`quantity_unshipped_delta_2` DECIMAL(10,2),
`quantity_shipped_delta_1` DECIMAL(10,2),
`quantity_shipped_delta_2` DECIMAL(10,2),
`created_by` INT,
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`inv_transaction_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_509719_031_entity_inventory_mysql') AS relationships;
