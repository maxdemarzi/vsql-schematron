`turno` VARCHAR(64),
`telefone` VARCHAR(64),
`cpf` VARCHAR(64),
`endereco` VARCHAR(64),
`id_alunofk` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
