INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 540209_ddl
#
CREATE DATABASE `db_540209_ddl`;
USE `db_540209_ddl`;
CREATE TABLE `Bar` (
`bar_id` INT,
`created` INT,
`bar_name` VARCHAR(64),
`address` VARCHAR(64),
`phoneNumber` VARCHAR(64),
`comment` VARCHAR(64),
`url` VARCHAR(64),
`star_rating` INT,
PRIMARY KEY (`bar_id`)
) CHARACTER SET latin1;
CREATE TABLE `Drink` (
`drink_id` INT,
`created` INT,
`drink_name` VARCHAR(64),
`path` VARCHAR(64),
PRIMARY KEY (`drink_id`)
) CHARACTER SET latin1;
CREATE TABLE `DrinkRating` (
`drink_rating_id` INT,
`created` INT,
`drink_id` INT,
`bar_id` INT,
`star_rating` INT,
`comment` VARCHAR(64),
PRIMARY KEY (`drink_rating_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_540209_ddl') AS relationships;
