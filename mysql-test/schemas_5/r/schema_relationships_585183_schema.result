[Implied]  ReportComments.ReportID -> Report.ID
[Implied]  ReportInvestigations.InvestigatorID -> Investigator.ID
[Implied]  ReportInvestigations.ReportID -> Report.ID

DROP DATABASE `db_585183_schema`;
UNINSTALL EXTENSION vsql_schematron;
