CREATE DATABASE `db_594091_schema`;
USE `db_594091_schema`;
CREATE TABLE `experiment` (
`id` INT NOT NULL,
`project_id` INT,
`engine` VARCHAR(50),
`hyperparams` VARCHAR(50),
`metrics` VARCHAR(50),
`status` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `serving` (
`id` INT NOT NULL,
`project_id` INT,
`experiment_id` INT,
`payload` VARCHAR(50),
`api_key` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_594091_schema') AS relationships;
