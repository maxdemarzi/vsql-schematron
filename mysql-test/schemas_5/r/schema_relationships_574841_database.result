INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 574841_database
#
CREATE DATABASE `db_574841_database`;
USE `db_574841_database`;
CREATE TABLE `Customer` (
`Id` VARCHAR(50) NOT NULL,
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`Document` CHAR(50),
`Email` VARCHAR(50),
`Phone` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
`Id` VARCHAR(50) NOT NULL,
`CustomerId` VARCHAR(50),
`Number` VARCHAR(50),
`Complement` VARCHAR(50),
`District` VARCHAR(50),
`City` VARCHAR(50),
`State` CHAR(50),
`Country` CHAR(50),
`ZipCode` CHAR(50),
`Type` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`Id` VARCHAR(50) NOT NULL,
`Title` VARCHAR(50),
`Description` TEXT,
`Image` VARCHAR(50),
`Price` DECIMAL(10,2),
`QuantityOnHand` DECIMAL(10,2),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
`Id` VARCHAR(50) NOT NULL,
`CustomerId` VARCHAR(50),
`CreateDate` DATETIME,
`Status` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderItem` (
`Id` VARCHAR(50) NOT NULL,
`OrderId` VARCHAR(50),
`ProductId` VARCHAR(50),
`Quantity` DECIMAL(10,2),
`Price` DECIMAL(10,2),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Delivery` (
`Id` VARCHAR(50) NOT NULL,
`OrderId` VARCHAR(50),
`CreateDate` DATETIME,
`EstimatedDeliveryDate` DATETIME,
`Status` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_574841_database') AS relationships;
relationships
Database: db_574841_database

Table Connections:
------------------
[Implied]  Address.CustomerId -> Customer.Id
[Implied]  Delivery.OrderId -> Order.Id
[Implied]  Order.CustomerId -> Customer.Id
[Implied]  OrderItem.OrderId -> Order.Id
[Implied]  OrderItem.ProductId -> Product.Id

DROP DATABASE `db_574841_database`;
UNINSTALL EXTENSION vsql_schematron;
