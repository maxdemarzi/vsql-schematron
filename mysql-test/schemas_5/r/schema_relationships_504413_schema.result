INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 504413_schema
#
CREATE DATABASE `db_504413_schema`;
USE `db_504413_schema`;
CREATE TABLE `account` (
`id` INT NOT NULL,
`agency` VARCHAR(50),
`account_number` VARCHAR(50),
`balance` DECIMAL(10,2),
`account_limit` DECIMAL(10,2),
`account_type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`surname` VARCHAR(50),
`sex` CHAR(50),
`account_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bankstatement` (
`id` INT NOT NULL,
`transaction_type` CHAR(50),
`VALUE` DECIMAL(10,2),
`balance` DECIMAL(10,2),
`history` VARCHAR(50),
`movement_date` DATE,
`customer_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_504413_schema') AS relationships;
relationships
Database: db_504413_schema

Table Connections:
