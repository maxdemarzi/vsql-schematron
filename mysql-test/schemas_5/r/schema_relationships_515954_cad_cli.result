INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 515954_cad_cli
#
CREATE DATABASE `db_515954_cad_cli`;
USE `db_515954_cad_cli`;
CREATE TABLE `clientes` (
`id` INT,
`cpf` VARCHAR(64),
`nome` VARCHAR(64),
`credito_liberado` VARCHAR(64),
`data_nasc` DATETIME,
`user_id` INT,
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
`id` INT,
`descricao` VARCHAR(64),
`unidade` VARCHAR(64),
`user_id` INT,
`data_cadastro` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidos` (
`id` INT,
`quantidade` INT,
`preco_venda` DECIMAL(10,2),
`data_pedido` DATETIME,
`data_confirmacao` DATETIME,
`cliente_id` INT,
`user_id` INT,
`produto_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_515954_cad_cli') AS relationships;
relationships
Database: db_515954_cad_cli

Table Connections:
