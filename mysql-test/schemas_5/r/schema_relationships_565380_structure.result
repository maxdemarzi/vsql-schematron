) CHARACTER SET latin1;
CREATE TABLE `teams_users` (
`id` INT,
`team_id` INT,
`user_id` INT,
`roles` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(255),
`encrypted_password` VARCHAR(255),
