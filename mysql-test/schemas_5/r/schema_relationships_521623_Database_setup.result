`anime_id` INT,
`cover_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Watching` (
`anime_id` INT
) CHARACTER SET latin1;
CREATE TABLE `Covers` (
`anime_id` INT,
`cover_path` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Animes_Download_List` (
`anime_id` INT
) CHARACTER SET latin1;
