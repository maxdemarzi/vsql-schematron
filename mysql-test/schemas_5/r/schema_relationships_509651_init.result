INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 509651_init
#
CREATE DATABASE `db_509651_init`;
USE `db_509651_init`;
CREATE TABLE `guild` (
`id` VARCHAR(50) NOT NULL,
`command_prefix` VARCHAR(50),
`volume` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `slot` (
`id` VARCHAR(50) NOT NULL,
`guild_id` VARCHAR(50),
`slot_number` SMALLINT,
`value` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_509651_init') AS relationships;
relationships
