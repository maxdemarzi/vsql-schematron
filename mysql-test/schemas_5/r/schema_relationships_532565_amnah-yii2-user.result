INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 532565_amnah-yii2-user
#
CREATE DATABASE `db_532565_amnah_yii2_user`;
USE `db_532565_amnah_yii2_user`;
CREATE TABLE `migration` (
`version` VARCHAR(50) NOT NULL,
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`can_admin` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT NOT NULL,
`role_id` INT,
`status` SMALLINT,
`email` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`auth_key` VARCHAR(50),
`access_token` VARCHAR(50),
`logged_in_ip` VARCHAR(50),
`logged_in_at` TIMESTAMP NULL,
`created_ip` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`banned_at` TIMESTAMP NULL,
`banned_reason` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_token` (
`id` INT NOT NULL,
`user_id` INT,
`type` SMALLINT,
`token` VARCHAR(50),
`data` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`expired_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
`id` INT NOT NULL,
`user_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`full_name` VARCHAR(50),
`timezone` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_auth` (
`id` INT NOT NULL,
`user_id` INT,
`provider` VARCHAR(50),
`provider_id` VARCHAR(50),
`provider_attributes` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_532565_amnah_yii2_user') AS relationships;
relationships
Database: db_532565_amnah_yii2_user

Table Connections:
