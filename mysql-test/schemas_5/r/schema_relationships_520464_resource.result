CREATE DATABASE `db_520464_resource`;
USE `db_520464_resource`;
CREATE TABLE `IDN_UMA_RESOURCE` (
`ID` INT NOT NULL,
`RESOURCE_ID` VARCHAR(50),
`RESOURCE_NAME` VARCHAR(50),
`TIME_CREATED` TIMESTAMP NULL,
`RESOURCE_OWNER_NAME` VARCHAR(50),
`TENANT_ID` INT,
`CLIENT_ID` VARCHAR(50),
`USER_DOMAIN` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `IDN_UMA_RESOURCE_SCOPE` (
`ID` INT NOT NULL,
`RESOURCE_IDENTITY` INT,
`SCOPE_NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `IDN_UMA_RESOURCE_META_DATA` (
`ID` INT NOT NULL,
`RESOURCE_IDENTITY` INT,
`PROPERTY_KEY` VARCHAR(50),
`PROPERTY_VALUE` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_520464_resource') AS relationships;
