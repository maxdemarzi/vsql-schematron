INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 559988_script
#
CREATE DATABASE `db_559988_script`;
USE `db_559988_script`;
CREATE TABLE `customer` (
`customer_id` VARCHAR(50) NOT NULL,
`customer_name` VARCHAR(50),
`customer_address` VARCHAR(50),
`customer_contact` VARCHAR(50),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`item_id` VARCHAR(50) NOT NULL,
`item_name` VARCHAR(50),
`item_stock` INT,
`item_unit_price` DECIMAL(10,2),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
`order_id` VARCHAR(50) NOT NULL,
`order_date` DATE,
`customer_id` VARCHAR(50),
`total` DECIMAL(10,2),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_detail` (
`order_id` VARCHAR(50) NOT NULL,
`item_id` VARCHAR(50) NOT NULL,
`item_quantity` INT,
`item_total` DECIMAL(10,2),
PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT NOT NULL,
`user_name` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_559988_script') AS relationships;
relationships
Database: db_559988_script

Table Connections:
------------------
[Implied]  order.customer_id -> customer.customer_id
[Implied]  order_detail.item_id -> item.item_id
[Implied]  order_detail.order_id -> order.order_id

DROP DATABASE `db_559988_script`;
UNINSTALL EXTENSION vsql_schematron;
