INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 527012_DBTables
#
CREATE DATABASE `db_527012_DBTables`;
USE `db_527012_DBTables`;
CREATE TABLE `user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `playlist` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`creation_date` DATE,
`creator` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `song` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`image` VARCHAR(50),
`singer` VARCHAR(50),
`release_date` DATE,
`musical_genre` VARCHAR(50),
`file` VARCHAR(50),
`creator` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `association` (
`songid` INT NOT NULL,
`playlistid` INT NOT NULL,
`ordering` INT,
PRIMARY KEY (`songid`, `playlistid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_527012_DBTables') AS relationships;
relationships
Database: db_527012_DBTables

Table Connections:
