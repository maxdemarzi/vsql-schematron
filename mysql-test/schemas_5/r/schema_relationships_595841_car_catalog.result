INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 595841_car_catalog
#
CREATE DATABASE `db_595841_car_catalog`;
USE `db_595841_car_catalog`;
CREATE TABLE `car_body` (
`car_body_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`car_body_id`)
) CHARACTER SET latin1;
CREATE TABLE `engine` (
`engine_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`engine_id`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
`transmission_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`transmission_id`)
) CHARACTER SET latin1;
CREATE TABLE `cars` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`car_body_id` INT,
`engine_id` INT,
`transmission_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_595841_car_catalog') AS relationships;
