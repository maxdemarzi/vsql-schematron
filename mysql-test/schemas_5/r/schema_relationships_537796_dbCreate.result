`type` VARCHAR(64),
`x` INT,
`y` INT,
`z` VARCHAR(64),
`picture` VARCHAR(64),
`conservation` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `list` (
`site_id` INT,
`dino_id` INT
) CHARACTER SET latin1;
CREATE TABLE `remarks` (
`id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64)
) CHARACTER SET latin1;
