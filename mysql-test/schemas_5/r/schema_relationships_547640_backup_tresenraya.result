INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 547640_backup.tresenraya
#
CREATE DATABASE `db_547640_backup_tresenraya`;
USE `db_547640_backup_tresenraya`;
CREATE TABLE `activaciones` (
`aid` INT,
`uid` INT,
`clave` VARCHAR(64),
`fecha_limite` DATETIME,
`avisado` BOOL,
PRIMARY KEY (`aid`)
) CHARACTER SET latin1;
CREATE TABLE `partidas` (
`pid` VARCHAR(64),
`desafiante` INT,
`desafiado` INT,
`aceptado` INT
) CHARACTER SET latin1;
CREATE TABLE `recordarme` (
`id` VARCHAR(64),
`token` VARCHAR(64),
`salt` VARCHAR(64),
`uid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
`uid` INT,
`nombre` VARCHAR(64),
`contrasena` VARCHAR(64),
`correo` VARCHAR(64),
`activado` BOOL,
`pais` VARCHAR(64),
`fecha_registro` DATETIME,
`info_partidas` VARCHAR(64),
`fecha_conexion` DATETIME,
`direccion_ip` VARCHAR(64),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios_conectados` (
`uid` INT,
`nombre` VARCHAR(64),
`pais` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_547640_backup_tresenraya') AS relationships;
relationships
Database: db_547640_backup_tresenraya

Table Connections:
