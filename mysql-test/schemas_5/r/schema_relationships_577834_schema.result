CREATE DATABASE `db_577834_schema`;
USE `db_577834_schema`;
CREATE TABLE `uniparc` (
`uniparc_id` VARCHAR(255),
`sequence` VARCHAR(255),
`sequence_length` INT,
`sequence_checksum` VARCHAR(255),
PRIMARY KEY (`uniparc_id`)
) CHARACTER SET latin1;
CREATE TABLE `domain` (
`uniparc_id` VARCHAR(255),
`database` VARCHAR(255),
`database_id` VARCHAR(255),
`interpro_name` VARCHAR(255),
`interpro_id` VARCHAR(255),
`domain_start` INT,
`domain_end` INT
) CHARACTER SET latin1;
CREATE TABLE `xref` (
`uniparc_id` VARCHAR(255),
`xref_id` INT,
`db_type` VARCHAR(255),
`db_id` VARCHAR(255),
`version_i` VARCHAR(255),
`active` VARCHAR(255),
`version` VARCHAR(255),
`created` VARCHAR(255),
`last` VARCHAR(255),
PRIMARY KEY (`uniparc_id`, `xref_id`)
) CHARACTER SET latin1;
CREATE TABLE `component` (
