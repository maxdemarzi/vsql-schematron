CREATE DATABASE `db_537367_Bank_20script`;
USE `db_537367_Bank_20script`;
CREATE TABLE `Employees` (
`Emp_id` INT,
`First_name` VARCHAR(64),
`Last_name` VARCHAR(64),
`Sex` VARCHAR(64),
`Dob` DATETIME,
`Employement_year` VARCHAR(64),
`Marital_status` VARCHAR(64),
`Branch_id` INT,
PRIMARY KEY (`Emp_id`)
) CHARACTER SET latin1;
CREATE TABLE `Branch` (
`Branch_id` INT,
`Branch_name` VARCHAR(64),
`Mgr_id` INT,
PRIMARY KEY (`Branch_id`)
) CHARACTER SET latin1;
CREATE TABLE `Clients` (
`Client_id` INT,
`First_name` VARCHAR(64),
`Last_name` VARCHAR(64),
`Branch_id` INT,
`Account_officer_id` INT,
`Registered_Date` VARCHAR(64),
`Account_Balance` INT,
PRIMARY KEY (`Client_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_537367_Bank_20script') AS relationships;
