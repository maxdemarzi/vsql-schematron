CREATE DATABASE `db_531728_Database`;
USE `db_531728_Database`;
CREATE TABLE `galleries` (
`id` INT,
`title` VARCHAR(255),
`slug` VARCHAR(255),
`summary` VARCHAR(255),
`showHome` INT,
`image` VARCHAR(255),
`content` VARCHAR(255),
`design` VARCHAR(255),
`order` INT,
`metaTitle` VARCHAR(255),
`metaDescription` VARCHAR(255),
`metaKeywords` VARCHAR(255),
`status` VARCHAR(255),
`visited` INT,
`language` VARCHAR(255),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `gallery_images` (
`id` INT,
`galleryId` INT,
`title` VARCHAR(255),
`image` VARCHAR(255),
`content` VARCHAR(255),
`order` INT,
`status` VARCHAR(255),
`language` VARCHAR(255),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_531728_Database') AS relationships;
