`END_cCOMPLEMENTO` VARCHAR(64),
`END_cTIPO` VARCHAR(64),
`END_cUF` VARCHAR(64),
`CLI_nCOD` INT,
PRIMARY KEY (`END_nID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTO` (
`PRODUTO_nID` INT,
