CREATE DATABASE `db_585077_script`;
USE `db_585077_script`;
CREATE TABLE `CLIENTE` (
`CLI_nCOD` INT,
`CLI_cNOME` VARCHAR(64),
`CLI_cRG` VARCHAR(64),
`CLI_cCPF` VARCHAR(64),
`CLI_dDTNASC` DATETIME,
`CLI_cGENERO` VARCHAR(64),
`CLI_nTRESIDENCIAL` VARCHAR(64),
`CLI_nTCELULAR` VARCHAR(64),
`CLI_nTCOMERCIAL` VARCHAR(64),
`CLI_cEMAIL` VARCHAR(64),
`CLI_cSENHA` VARCHAR(64),
`CLI_dDTULTIMO_ACESSO` DATETIME,
`CLI_cSTATUS` VARCHAR(64),
`CLI_tPREFERENCIA` VARCHAR(64),
PRIMARY KEY (`CLI_nCOD`)
) CHARACTER SET latin1;
CREATE TABLE `ENDERECO` (
`END_nID` INT,
`END_nCEP` VARCHAR(64),
