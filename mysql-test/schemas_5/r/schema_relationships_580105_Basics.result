CREATE DATABASE `db_580105_Basics`;
USE `db_580105_Basics`;
CREATE TABLE `clothes_line` (
`collection` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `rlist` (
`num` INT,
`rname` VARCHAR(64),
`address` VARCHAR(64),
`income` INT,
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `menu` (
`num` INT,
`meal` VARCHAR(64),
`mealtype` VARCHAR(64),
`price` INT,
`rnum` INT,
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `planes` (
`num` INT,
`country_start` VARCHAR(64),
`country_arrival` VARCHAR(64),
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `ftype` (
`num` INT,
`flight_type` VARCHAR(64),
`food` VARCHAR(64),
`plane_num` INT,
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_580105_Basics') AS relationships;
