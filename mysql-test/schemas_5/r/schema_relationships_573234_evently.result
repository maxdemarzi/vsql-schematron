INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 573234_evently
#
CREATE DATABASE `db_573234_evently`;
USE `db_573234_evently`;
CREATE TABLE `user` (
`email` VARCHAR(64),
`password` VARCHAR(64),
`phone` VARCHAR(64),
`is_organizer` BOOL,
PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `organizer` (
`user` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`user`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`user` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`user`)
) CHARACTER SET latin1;
CREATE TABLE `event_type` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event_category` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
`id` INT,
`name` VARCHAR(64),
`tickets` INT,
`image` VARCHAR(64),
`start_time` INT,
`end_time` INT,
`speaker` VARCHAR(64),
`is_online` BOOL,
`meeting_link` VARCHAR(64),
`description` VARCHAR(64),
`organizer` VARCHAR(64),
`longitude` VARCHAR(64),
`latitude` VARCHAR(64),
`location` VARCHAR(64),
`type` INT,
`category` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reservation` (
`id` INT,
`person` VARCHAR(64),
`event` INT,
`reserved_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_573234_evently') AS relationships;
