) CHARACTER SET latin1;
CREATE TABLE `track` (
`id` INT NOT NULL,
`album_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_567059_artist_schema_1') AS relationships;
