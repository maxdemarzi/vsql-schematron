INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 535449_database
#
CREATE DATABASE `db_535449_database`;
USE `db_535449_database`;
CREATE TABLE `auth_assignment` (
`item_name` VARCHAR(64),
`user_id` VARCHAR(64),
`created_at` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_item` (
`name` VARCHAR(64),
`type` INT,
`description` VARCHAR(64),
`rule_name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT
) CHARACTER SET latin1;
CREATE TABLE `auth_item_child` (
`parent` VARCHAR(64),
`child` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `auth_rule` (
`name` VARCHAR(64),
`data` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `request` (
`id` INT,
`name` VARCHAR(64),
`categoryID` INT,
`statusID` INT,
`reject_msg` VARCHAR(64),
`img_before` VARCHAR(64),
`img_after` VARCHAR(64),
`created_by` INT,
`updated_by` INT,
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `status` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_535449_database') AS relationships;
relationships
Database: db_535449_database

Table Connections:
------------------
[Implied]  auth_assignment.item_name -> auth_item.name
[Implied]  auth_item.rule_name -> auth_rule.name
[Implied]  request.categoryID -> category.id
[Implied]  request.statusID -> status.id

DROP DATABASE `db_535449_database`;
UNINSTALL EXTENSION vsql_schematron;
