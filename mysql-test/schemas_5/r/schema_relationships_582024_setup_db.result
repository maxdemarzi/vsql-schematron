CREATE DATABASE `db_582024_setup_db`;
USE `db_582024_setup_db`;
CREATE TABLE `USERS` (
`USER_ID` BIGINT NOT NULL,
`USERNAME` VARCHAR(50),
`BALANCE` BIGINT,
PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TOURNAMENTS` (
`TOURNAMENT_ID` BIGINT NOT NULL,
`TOURNAMENT_NAME` VARCHAR(50),
`TOURNAMENT_STATUS` VARCHAR(50),
`DEPOSIT` BIGINT,
`PRIZE` BIGINT,
`WINNER_ID` BIGINT,
PRIMARY KEY (`TOURNAMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MTM_USER_TOURNAMENT` (
`ID` BIGINT NOT NULL,
`TOURNAMENT_ID` BIGINT,
`USER_ID` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
