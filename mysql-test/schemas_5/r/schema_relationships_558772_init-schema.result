INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 558772_init-schema
#
CREATE DATABASE `db_558772_init_schema`;
USE `db_558772_init_schema`;
CREATE TABLE `tbl_task` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`done` BOOLEAN,
`time_started` TIMESTAMP NULL,
`date_created` TIMESTAMP NULL,
`next_task` VARCHAR(50),
`parent_task` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_player` (
`id` VARCHAR(50) NOT NULL,
`name_alias` VARCHAR(50),
`date_joined` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_assignment` (
`player_id` VARCHAR(50) NOT NULL,
`task_id` VARCHAR(50) NOT NULL,
`date_assigned` TIMESTAMP NULL,
PRIMARY KEY (`player_id`, `task_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_558772_init_schema') AS relationships;
relationships
Database: db_558772_init_schema

Table Connections:
