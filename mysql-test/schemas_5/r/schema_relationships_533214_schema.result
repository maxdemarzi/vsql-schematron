INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 533214_schema
#
CREATE DATABASE `db_533214_schema`;
USE `db_533214_schema`;
CREATE TABLE `event` (
`event_id` INT NOT NULL,
`event_code` VARCHAR(50),
`event_name` VARCHAR(50),
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `seat` (
`seat_id` INT NOT NULL,
`venue_code` VARCHAR(50),
`seat_code` CHAR(50),
`aisle` BOOLEAN,
`seat_type` VARCHAR(50),
PRIMARY KEY (`seat_id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory` (
`inventory_id` INT NOT NULL,
`event_id` INT,
`seat_id` INT,
`available` BOOLEAN,
PRIMARY KEY (`inventory_id`)
) CHARACTER SET latin1;
CREATE TABLE `district` (
`id` BIGINT NOT NULL,
`email` VARCHAR(50),
`phone` VARCHAR(50),
`enrollment` INT,
`name` VARCHAR(50),
`number` INT,
`TYPE` VARCHAR(50),
`updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `school` (
`id` BIGINT NOT NULL,
`closed` BOOLEAN,
`email` VARCHAR(50),
`phone` VARCHAR(50),
`enrollment` INT,
`grade_high` VARCHAR(50),
`grade_low` VARCHAR(50),
`name` VARCHAR(50),
`number` BIGINT,
`district_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_533214_schema') AS relationships;
relationships
Database: db_533214_schema

Table Connections:
------------------
[Implied]  inventory.event_id -> event.event_id
[Implied]  inventory.seat_id -> seat.seat_id
[Implied]  school.district_id -> district.id

DROP DATABASE `db_533214_schema`;
UNINSTALL EXTENSION vsql_schematron;
