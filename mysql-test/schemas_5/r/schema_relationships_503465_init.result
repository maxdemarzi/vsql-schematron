INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 503465_init
#
CREATE DATABASE `db_503465_init`;
USE `db_503465_init`;
CREATE TABLE `user` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie` (
`id` INT,
`name` VARCHAR(255),
`brief` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movie_style` (
`movie_id` INT,
`style_id` INT
) CHARACTER SET latin1;
CREATE TABLE `user_movie` (
`user_id` INT,
`movie_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_503465_init') AS relationships;
