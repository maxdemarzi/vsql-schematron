INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 539880_schema
#
CREATE DATABASE `db_539880_schema`;
USE `db_539880_schema`;
CREATE TABLE `posts` (
`id` INT,
`id_user` INT,
`content` VARCHAR(64),
`id_parent` INT,
`at` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`id` INT,
`token` VARCHAR(64),
`id_user` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `codes` (
`code` VARCHAR(64),
`generated_at` VARCHAR(64),
`valid` INT,
`id_user` INT,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_539880_schema') AS relationships;
