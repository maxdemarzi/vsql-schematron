CREATE TABLE `Customer` (
`customerID` DECIMAL(10,2) NOT NULL,
`customerName` VARCHAR(50),
`customerPhone` VARCHAR(50),
`customerAddress` VARCHAR(50),
PRIMARY KEY (`customerID`)
) CHARACTER SET latin1;
CREATE TABLE `Specification` (
`specificationID` DECIMAL(10,2) NOT NULL,
`customerID` DECIMAL(10,2),
`specDate` DATE,
`returnDate` DATE,
`specDesc` VARCHAR(50),
`designerName` VARCHAR(50),
PRIMARY KEY (`specificationID`)
) CHARACTER SET latin1;
CREATE TABLE `LightStock` (
`itemID` DECIMAL(10,2) NOT NULL,
`ItemDesc` VARCHAR(50),
`ItemPrice` DECIMAL(10,2),
PRIMARY KEY (`itemID`)
) CHARACTER SET latin1;
CREATE TABLE `LightDesignItems` (
`specificationID` DECIMAL(10,2) NOT NULL,
`itemID` DECIMAL(10,2) NOT NULL,
PRIMARY KEY (`specificationID`, `itemID`)
) CHARACTER SET latin1;
