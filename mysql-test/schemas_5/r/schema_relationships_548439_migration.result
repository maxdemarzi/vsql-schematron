`creatorId` VARCHAR(64),
`assignedId` VARCHAR(64),
`complete` BOOL,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
