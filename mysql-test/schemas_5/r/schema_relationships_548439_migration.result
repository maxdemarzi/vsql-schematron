`password` VARCHAR(64),
`name` VARCHAR(64),
`role` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
