INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 597293_schema
#
CREATE DATABASE `db_597293_schema`;
USE `db_597293_schema`;
CREATE TABLE `denormalized.product` (
`product_id` INT NOT NULL,
`product_name` VARCHAR(50),
`product_brand_name` VARCHAR(50),
`product_weight` VARCHAR(50),
`product_size_description` VARCHAR(50),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `denormalized.customer` (
`customer_id` INT NOT NULL,
`customer_cpf` VARCHAR(50),
`customer_email` VARCHAR(50),
`customer_name` VARCHAR(50),
`customer_zipcode` VARCHAR(50),
`customer_street` VARCHAR(50),
`customer_created` TIMESTAMP NULL,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `denormalized.purchase` (
`purchase_id` INT NOT NULL,
`product_id` INT,
`customer_id` INT,
`purchase_detail_status` VARCHAR(50),
`purchase_product_quantity` INT,
`purchase_created` TIMESTAMP NULL,
`purchase_updated` TIMESTAMP NULL,
PRIMARY KEY (`purchase_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_597293_schema') AS relationships;
