INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 046210_02_binaryblobapp
--echo #
CREATE DATABASE `db_046210_02_binaryblobapp`;
USE `db_046210_02_binaryblobapp`;

CREATE TABLE `BlobCreator` (
  `CID` INT,
  `Name` VARCHAR(255),
  PRIMARY KEY (`CID`)
) CHARACTER SET latin1;

CREATE TABLE `BlobData` (
  `BlobID` INT,
  `DataBlob` VARCHAR(255),
  `BlobSize` INT,
  `TimeStamp` DATETIME,
  `CreatorID` INT,
  PRIMARY KEY (`BlobID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_046210_02_binaryblobapp') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_046210_02_binaryblobapp') AS relationships;
DROP DATABASE `db_046210_02_binaryblobapp`;
UNINSTALL EXTENSION vsql_schematron;
