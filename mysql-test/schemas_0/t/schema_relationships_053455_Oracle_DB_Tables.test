INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053455_Oracle_DB_Tables
--echo #
CREATE DATABASE `db_053455_Oracle_DB_Tables`;
USE `db_053455_Oracle_DB_Tables`;

CREATE TABLE `Item` (
  `IID` DECIMAL(10,2),
  `CID` DECIMAL(10,2),
  `Name` VARCHAR(255),
  `Description` VARCHAR(255),
  `Stock` DECIMAL(10,2),
  PRIMARY KEY (`IID`)
) CHARACTER SET latin1;

CREATE TABLE `Category` (
  `CID` DECIMAL(10,2),
  `Name` VARCHAR(255),
  `ItemCount` DECIMAL(10,2),
  PRIMARY KEY (`CID`)
) CHARACTER SET latin1;

CREATE TABLE `CL2CA` (
  `CLCAID` DECIMAL(10,2),
  `CID` DECIMAL(10,2),
  `CLID` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `Class` (
  `CLID` DECIMAL(10,2),
  `Name` VARCHAR(255),
  `CategoryCount` DECIMAL(10,2),
  PRIMARY KEY (`CLID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053455_Oracle_DB_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053455_Oracle_DB_Tables') AS relationships;
DROP DATABASE `db_053455_Oracle_DB_Tables`;
UNINSTALL EXTENSION vsql_schematron;
