INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013120_V0_1_init
--echo #
CREATE DATABASE `db_013120_V0_1_init`;
USE `db_013120_V0_1_init`;

CREATE TABLE `app_user` (
  `id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `app_role` (
  `id` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `app_user_role` (
  `user_id` VARCHAR(255),
  `role_id` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `firstname` VARCHAR(255),
  `lastname` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013120_V0_1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013120_V0_1_init') AS relationships;
DROP DATABASE `db_013120_V0_1_init`;
UNINSTALL EXTENSION vsql_schematron;
