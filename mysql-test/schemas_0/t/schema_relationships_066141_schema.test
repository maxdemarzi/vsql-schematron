INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066141_schema
--echo #
CREATE DATABASE `db_066141_schema`;
USE `db_066141_schema`;
CREATE TABLE `movies` (
  `id` INT NOT NULL,
  `movie_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
  `id` INT NOT NULL,
  `movie_id` INT,
  `review` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066141_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066141_schema') AS relationships;
DROP DATABASE `db_066141_schema`;
UNINSTALL EXTENSION vsql_schematron;
