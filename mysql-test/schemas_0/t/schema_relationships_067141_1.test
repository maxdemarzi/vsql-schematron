INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067141_1
--echo #
CREATE DATABASE `db_067141_1`;
USE `db_067141_1`;

CREATE TABLE `blogpost` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `username` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `biography` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067141_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067141_1') AS relationships;
DROP DATABASE `db_067141_1`;
UNINSTALL EXTENSION vsql_schematron;
