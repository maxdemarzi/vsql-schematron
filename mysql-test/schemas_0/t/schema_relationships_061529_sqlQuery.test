INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061529_sqlQuery
--echo #
CREATE DATABASE `db_061529_sqlQuery`;
USE `db_061529_sqlQuery`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `folders` (
  `id` INT NOT NULL,
  `user_id` INT,
  `name` VARCHAR(50),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `id` INT NOT NULL,
  `user_id` INT,
  `folder_id` INT,
  `title` VARCHAR(50),
  `is_done` BOOLEAN,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061529_sqlQuery') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061529_sqlQuery') AS relationships;
DROP DATABASE `db_061529_sqlQuery`;
UNINSTALL EXTENSION vsql_schematron;
