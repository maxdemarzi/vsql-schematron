INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 023098_dbPhysic
--echo #
CREATE DATABASE `db_023098_dbPhysic`;
USE `db_023098_dbPhysic`;
CREATE TABLE `player` (
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `pic` VARCHAR(50),
  `password` VARCHAR(50),
  `nick` VARCHAR(50),
  `id` INT NOT NULL,
  `wins` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `match` (
  `date` DATE,
  `status` CHAR(50),
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team` (
  `score` INT,
  `id` INT NOT NULL,
  `win` INT,
  `fk_match_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plays` (
  `fk_player_Id` INT,
  `fk_team_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_023098_dbPhysic') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_023098_dbPhysic') AS relationships;
DROP DATABASE `db_023098_dbPhysic`;
UNINSTALL EXTENSION vsql_schematron;
