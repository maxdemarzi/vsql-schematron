INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 055294_migration
--echo #
CREATE DATABASE `db_055294_migration`;
USE `db_055294_migration`;

CREATE TABLE `User` (
  `name` VARCHAR(64),
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Guild` (
  `name` VARCHAR(64),
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Channel` (
  `name` VARCHAR(64),
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `guildId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Message` (
  `id` VARCHAR(64),
  `authorId` VARCHAR(64),
  `channelId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_GuildToUser` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_055294_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_055294_migration') AS relationships;
DROP DATABASE `db_055294_migration`;
UNINSTALL EXTENSION vsql_schematron;
