INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048328_ddl
--echo #
CREATE DATABASE `db_048328_ddl`;
USE `db_048328_ddl`;

CREATE TABLE `Students` (
  `student_id` INT,
  `student_name` VARCHAR(64),
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;

CREATE TABLE `Courses` (
  `course_id` INT,
  `course_name` VARCHAR(64),
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;

CREATE TABLE `Marks` (
  `student_id` INT,
  `course_id` INT,
  `mark` VARCHAR(64),
  PRIMARY KEY (`student_id`, `course_id`)
) CHARACTER SET latin1;

CREATE TABLE `Lecturers` (
  `lecturer_id` INT,
  `lecturer_name` VARCHAR(64),
  PRIMARY KEY (`lecturer_id`)
) CHARACTER SET latin1;

CREATE TABLE `Groups` (
  `group_id` INT,
  `group_name` VARCHAR(64),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;

CREATE TABLE `GroupCourses` (
  `group_id` INT,
  `course_id` INT,
  `lecturer_id` INT,
  PRIMARY KEY (`group_id`, `course_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048328_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048328_ddl') AS relationships;
DROP DATABASE `db_048328_ddl`;
UNINSTALL EXTENSION vsql_schematron;
