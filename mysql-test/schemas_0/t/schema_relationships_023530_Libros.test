INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 023530_Libros
--echo #
CREATE DATABASE `db_023530_Libros`;
USE `db_023530_Libros`;
CREATE TABLE `Autores` (
  `IDAutor` INT NOT NULL,
  `NombrePila` VARCHAR(50),
  `ApellidoPaterno` VARCHAR(50),
  PRIMARY KEY (`IDAutor`)
) CHARACTER SET latin1;
CREATE TABLE `Titulos` (
  `ISBN` VARCHAR(50) NOT NULL,
  `Titulo` VARCHAR(50),
  `NumeroEdicion` INT,
  `Copyright` VARCHAR(50),
  PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `ISBNAutor` (
  `IDAutor` INT,
  `ISBN` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_023530_Libros') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_023530_Libros') AS relationships;
DROP DATABASE `db_023530_Libros`;
UNINSTALL EXTENSION vsql_schematron;
