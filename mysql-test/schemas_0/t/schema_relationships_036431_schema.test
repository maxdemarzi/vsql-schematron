INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036431_schema
--echo #
CREATE DATABASE `db_036431_schema`;
USE `db_036431_schema`;
CREATE TABLE `AUTH_SCHEMA.USER` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `LOGIN` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  `IS_BLOCKED` CHAR(50),
  `CREATED_AT` TIMESTAMP NULL,
  `UPDATED_AT` TIMESTAMP NULL,
  `IS_PASS_EXPIRED` CHAR(50),
  `PASS_EXPIRE_DATE` DATE,
  `IS_ENABLE` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_SCHEMA.APPLICATION` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `CREATED_AT` TIMESTAMP NULL,
  `UPDATED_AT` TIMESTAMP NULL,
  `DESCRIPTION` VARCHAR(50),
  `APP_ID` VARCHAR(50),
  `APP_SECRET` VARCHAR(50),
  `URL` VARCHAR(50),
  `WEB_CONTEXT` VARCHAR(50),
  `PORT` DECIMAL(10,2),
  `URI` VARCHAR(50),
  `IS_ENABLE` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_SCHEMA.ROLE` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `CREATED_AT` TIMESTAMP NULL,
  `UPDATED_AT` TIMESTAMP NULL,
  `DESCRIPTION` VARCHAR(50),
  `IS_ENABLE` CHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_SCHEMA.PRIVILEGE` (
  `ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `CREATED_AT` TIMESTAMP NULL,
  `UPDATED_AT` TIMESTAMP NULL,
  `IS_ENABLE` CHAR(50),
  `ROLE_ID` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_SCHEMA.ACCESS` (
  `ID` DECIMAL(10,2) NOT NULL,
  `APP_ID` DECIMAL(10,2),
  `ROLE_ID` DECIMAL(10,2),
  `USER_ID` DECIMAL(10,2),
  `CREATED_AT` TIMESTAMP NULL,
  `UPDATED_AT` TIMESTAMP NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036431_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036431_schema') AS relationships;
DROP DATABASE `db_036431_schema`;
UNINSTALL EXTENSION vsql_schematron;
