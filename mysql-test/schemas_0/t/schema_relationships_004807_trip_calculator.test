INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004807_trip_calculator
--echo #
CREATE DATABASE `db_004807_trip_calculator`;
USE `db_004807_trip_calculator`;

CREATE TABLE `trip_calculator.category` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `trip_calculator.user` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `trip_calculator.item_set` (
  `name` VARCHAR(64),
  `people` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `trip_calculator.user_has_item_set` (
  `user_name` VARCHAR(64),
  `item_set_name` VARCHAR(64),
  PRIMARY KEY (`user_name`, `item_set_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004807_trip_calculator') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004807_trip_calculator') AS relationships;
DROP DATABASE `db_004807_trip_calculator`;
UNINSTALL EXTENSION vsql_schematron;
