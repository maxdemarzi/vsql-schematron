INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079220_fbkt_login_1_0_0
--echo #
CREATE DATABASE `db_079220_fbkt_login_1_0_0`;
USE `db_079220_fbkt_login_1_0_0`;

CREATE TABLE `application` (
  `id` INT,
  `uid` VARCHAR(64),
  `name` VARCHAR(64),
  `version` VARCHAR(64),
  `require_promo_code_for_registration` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `location` (
  `id` INT,
  `uid` VARCHAR(64),
  `name` VARCHAR(64),
  `geo_json` VARCHAR(64),
  `geom` VARCHAR(64),
  `address_1` VARCHAR(64),
  `address_2` VARCHAR(64),
  `city` VARCHAR(64),
  `county` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `attributes_json` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `license_type` (
  `id` INT,
  `application_id` INT,
  `name` VARCHAR(64),
  `license_type_key` VARCHAR(64),
  `active` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `promo_code` (
  `id` INT,
  `license_type_id` INT,
  `name` VARCHAR(64),
  `expiration_date` DATETIME,
  `the_promo_code` VARCHAR(64),
  `attributes_json` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_login` (
  `id` INT,
  `contact_id` INT,
  `login` VARCHAR(64),
  `hashed_password` VARCHAR(64),
  `entity_filters_json` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `contact` (
  `id` INT,
  `uid` VARCHAR(64),
  `organization_id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `email` VARCHAR(64),
  `job_title` VARCHAR(64),
  `attributes_json` VARCHAR(64),
  `location_id` INT,
  `inactive` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `license` (
  `id` INT,
  `organization_id` INT,
  `contact_id` INT,
  `license_type_id` INT,
  `status` VARCHAR(64),
  `activation_date` DATETIME,
  `expiration_date` DATETIME,
  `promo_code_id` INT,
  `attributes_json` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permission` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `license_permission` (
  `id` INT,
  `license_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `license_type_permission` (
  `id` INT,
  `license_type_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `login_token` (
  `id` INT,
  `user_login_id` INT,
  `token` VARCHAR(64),
  `expiration_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `organization` (
  `id` INT,
  `uid` VARCHAR(64),
  `name` VARCHAR(64),
  `attributes_json` VARCHAR(64),
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `organization_reference` (
  `id` INT,
  `organization_reference_type` VARCHAR(64),
  `referencing_organization_id` INT,
  `referenced_organization_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `facility` (
  `id` INT,
  `organization_id` INT,
  `name` VARCHAR(64),
  `attributes_json` VARCHAR(64),
  `location_id` INT,
  `inactive` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079220_fbkt_login_1_0_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079220_fbkt_login_1_0_0') AS relationships;
DROP DATABASE `db_079220_fbkt_login_1_0_0`;
UNINSTALL EXTENSION vsql_schematron;
