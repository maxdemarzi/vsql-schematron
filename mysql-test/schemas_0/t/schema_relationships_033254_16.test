INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033254_16
--echo #
CREATE DATABASE `db_033254_16`;
USE `db_033254_16`;

CREATE TABLE `case` (
  `case_number` VARCHAR(64),
  `findings` VARCHAR(64),
  `DATE` DATETIME,
  PRIMARY KEY (`case_number`)
) CHARACTER SET latin1;

CREATE TABLE `rule` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `charge` (
  `id` INT,
  `case_id` VARCHAR(64),
  `person_id` INT,
  `rule_id` INT,
  `plea` VARCHAR(64),
  `resolution_plan` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033254_16') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033254_16') AS relationships;
DROP DATABASE `db_033254_16`;
UNINSTALL EXTENSION vsql_schematron;
