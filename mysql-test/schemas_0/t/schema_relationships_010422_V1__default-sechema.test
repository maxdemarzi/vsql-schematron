INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010422_V1__default-sechema
--echo #
CREATE DATABASE `db_010422_V1__default_sechema`;
USE `db_010422_V1__default_sechema`;
CREATE TABLE `requirement` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `registration_nomor` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test_script` (
  `id` VARCHAR(50) NOT NULL,
  `file_name` VARCHAR(50),
  `requirement_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `design_step` (
  `id` VARCHAR(50) NOT NULL,
  `step_name` VARCHAR(50),
  `test_script_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010422_V1__default_sechema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010422_V1__default_sechema') AS relationships;
DROP DATABASE `db_010422_V1__default_sechema`;
UNINSTALL EXTENSION vsql_schematron;
