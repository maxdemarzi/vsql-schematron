INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010256_createDatabase
--echo #
CREATE DATABASE `db_010256_createDatabase`;
USE `db_010256_createDatabase`;

CREATE TABLE `rooms` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `passwordHash` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` VARCHAR(64),
  `userID` VARCHAR(64),
  `roomID` VARCHAR(64),
  `postDate` DATETIME,
  `content` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `oldMessages` (
  `id` VARCHAR(64),
  `userID` VARCHAR(64),
  `roomID` VARCHAR(64),
  `postDate` DATETIME,
  `content` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010256_createDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010256_createDatabase') AS relationships;
DROP DATABASE `db_010256_createDatabase`;
UNINSTALL EXTENSION vsql_schematron;
