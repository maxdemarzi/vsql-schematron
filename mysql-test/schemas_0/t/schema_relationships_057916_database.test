INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057916_database
--echo #
CREATE DATABASE `db_057916_database`;
USE `db_057916_database`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nombre_usuario` VARCHAR(50),
  `correo` VARCHAR(50),
  `imagen` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `titulo` VARCHAR(50),
  `texto` TEXT,
  `pdf` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057916_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057916_database') AS relationships;
DROP DATABASE `db_057916_database`;
UNINSTALL EXTENSION vsql_schematron;
