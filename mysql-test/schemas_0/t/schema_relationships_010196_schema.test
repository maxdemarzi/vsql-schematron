INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010196_schema
--echo #
CREATE DATABASE `db_010196_schema`;
USE `db_010196_schema`;

CREATE TABLE `deptTbl` (
  `dept_ID` INT,
  `dept_name` VARCHAR(64),
  PRIMARY KEY (`dept_ID`)
) CHARACTER SET latin1;

CREATE TABLE `roleTbl` (
  `role_ID` INT,
  `title` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `dept_ID` INT,
  `is_Manager` BOOL,
  PRIMARY KEY (`role_ID`)
) CHARACTER SET latin1;

CREATE TABLE `employeeTbl` (
  `employee_ID` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `role_ID` INT,
  `is_Manager` BOOL,
  `manager_ID` INT,
  PRIMARY KEY (`employee_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010196_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010196_schema') AS relationships;
DROP DATABASE `db_010196_schema`;
UNINSTALL EXTENSION vsql_schematron;
