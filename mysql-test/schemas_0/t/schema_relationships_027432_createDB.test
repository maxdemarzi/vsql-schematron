INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 027432_createDB
--echo #
CREATE DATABASE `db_027432_createDB`;
USE `db_027432_createDB`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `refreshTokens` (
  `token` VARCHAR(64),
  `id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_027432_createDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_027432_createDB') AS relationships;
DROP DATABASE `db_027432_createDB`;
UNINSTALL EXTENSION vsql_schematron;
