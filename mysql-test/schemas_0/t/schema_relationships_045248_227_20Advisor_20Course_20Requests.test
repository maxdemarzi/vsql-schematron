INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045248_227_20Advisor_20Course_20Requests
--echo #
CREATE DATABASE `db_045248_227_20Advisor_20Course_20Requests`;
USE `db_045248_227_20Advisor_20Course_20Requests`;

CREATE TABLE `advisor_crsreq` (
  `uniqueid` DECIMAL(10,2),
  `student_id` DECIMAL(10,2),
  `priority` DECIMAL(10,2),
  `substitute` DECIMAL(10,2),
  `alternative` DECIMAL(10,2),
  `time_stamp` DATETIME,
  `changed_by` VARCHAR(255),
  `credit` VARCHAR(255),
  `course` VARCHAR(255),
  `course_offering_id` DECIMAL(10,2),
  `notes` VARCHAR(255),
  `free_time_id` DECIMAL(10,2),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;

CREATE TABLE `advisor_sect_pref` (
  `uniqueid` DECIMAL(10,2),
  `preference_type` DECIMAL(10,2),
  `request_id` DECIMAL(10,2),
  `required` DECIMAL(10,2),
  `class_id` DECIMAL(10,2),
  `instr_mthd_id` DECIMAL(10,2),
  `label` VARCHAR(255),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045248_227_20Advisor_20Course_20Requests') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045248_227_20Advisor_20Course_20Requests') AS relationships;
DROP DATABASE `db_045248_227_20Advisor_20Course_20Requests`;
UNINSTALL EXTENSION vsql_schematron;
