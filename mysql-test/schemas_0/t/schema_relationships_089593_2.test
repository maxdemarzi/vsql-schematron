INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 089593_2
--echo #
CREATE DATABASE `db_089593_2`;
USE `db_089593_2`;

CREATE TABLE `fabricante` (
  `codFabricante` INT,
  `nomeFabricante` VARCHAR(64),
  PRIMARY KEY (`codFabricante`)
) CHARACTER SET latin1;

CREATE TABLE `automovel` (
  `codAuto` INT,
  `codFabricante` INT,
  `modelo` VARCHAR(64),
  `ano` INT,
  `pais` VARCHAR(64),
  `preco_tabela` DECIMAL(10,2),
  PRIMARY KEY (`codAuto`)
) CHARACTER SET latin1;

CREATE TABLE `revendedora` (
  `cnpj` VARCHAR(64),
  `nome` VARCHAR(64),
  `cidade` VARCHAR(64),
  `estado` VARCHAR(64),
  PRIMARY KEY (`cnpj`)
) CHARACTER SET latin1;

CREATE TABLE `consumidor` (
  `identidade` VARCHAR(64),
  `nome` VARCHAR(64),
  `sobrenome` VARCHAR(64),
  PRIMARY KEY (`identidade`)
) CHARACTER SET latin1;

CREATE TABLE `negocio` (
  `codComprador` VARCHAR(64),
  `codRevenda` VARCHAR(64),
  `codAuto` INT,
  `data` DATETIME,
  `preco` DECIMAL(10,2),
  PRIMARY KEY (`codComprador`, `codRevenda`, `codAuto`, `data`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_089593_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_089593_2') AS relationships;
DROP DATABASE `db_089593_2`;
UNINSTALL EXTENSION vsql_schematron;
