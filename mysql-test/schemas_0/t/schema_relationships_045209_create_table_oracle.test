INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045209_create_table_oracle
--echo #
CREATE DATABASE `db_045209_create_table_oracle`;
USE `db_045209_create_table_oracle`;

CREATE TABLE `PARENTS` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(255),
  `AGE` DECIMAL(10,2),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHILDREN` (
  `PARENT_ID` DECIMAL(10,2),
  `NAME` VARCHAR(255),
  `AGE` DECIMAL(10,2),
  PRIMARY KEY (`PARENT_ID`, `NAME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045209_create_table_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045209_create_table_oracle') AS relationships;
DROP DATABASE `db_045209_create_table_oracle`;
UNINSTALL EXTENSION vsql_schematron;
