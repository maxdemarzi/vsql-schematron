INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076331_schema
--echo #
CREATE DATABASE `db_076331_schema`;
USE `db_076331_schema`;
CREATE TABLE `consumidor` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `telefone` INT,
  `senha` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurante` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `nome` VARCHAR(50),
  `descricao` TEXT,
  `categoria_id` INT,
  `taxa_entrega` INT,
  `tempo_entrega_minutos` INT,
  `valor_minimo_pedido` INT,
  `imagem` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
  `id` INT NOT NULL,
  `restaurante_id` INT,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `preco` INT,
  `ativo` BOOLEAN,
  `permite_observacoes` BOOLEAN,
  `imagem` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076331_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076331_schema') AS relationships;
DROP DATABASE `db_076331_schema`;
UNINSTALL EXTENSION vsql_schematron;
