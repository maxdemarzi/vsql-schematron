INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000282_schema
--echo #
CREATE DATABASE `db_000282_schema`;
USE `db_000282_schema`;

CREATE TABLE `tasks` (
  `id` VARCHAR(64),
  `data` VARCHAR(64),
  `queue` VARCHAR(64),
  `retry_queue` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `executions` (
  `task_id` VARCHAR(64),
  `execution_id` INT,
  `queued_at` INT,
  `started_at` INT,
  `finished_at` INT,
  `failed_count` INT,
  `reaped_count` INT,
  `success` VARCHAR(64),
  `error_id` VARCHAR(64),
  PRIMARY KEY (`task_id`, `execution_id`)
) CHARACTER SET latin1;

CREATE TABLE `task_tags` (
  `id` VARCHAR(64),
  `task_id` VARCHAR(64),
  PRIMARY KEY (`id`, `task_id`)
) CHARACTER SET latin1;

CREATE TABLE `execution_errors` (
  `id` VARCHAR(64),
  `error` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000282_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000282_schema') AS relationships;
DROP DATABASE `db_000282_schema`;
UNINSTALL EXTENSION vsql_schematron;
