INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 023501_Schema
--echo #
CREATE DATABASE `db_023501_Schema`;
USE `db_023501_Schema`;

CREATE TABLE `entry_type` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `document_subtype` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `image_gallery_subtype` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `video_subtype` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `book_genre` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `document_tag` (
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `source` (
  `name` VARCHAR(64),
  `type` INT
) CHARACTER SET latin1;

CREATE TABLE `rating` (
  `UUID` INT,
  `UID` INT,
  `rating` INT
) CHARACTER SET latin1;

CREATE TABLE `entry_history` (
  `UUID` INT,
  `version` INT,
  `path` VARCHAR(64),
  `date` INT
) CHARACTER SET latin1;

CREATE TABLE `user_progress_document` (
  `UUID` INT,
  `UID` INT,
  `number` INT,
  `chapter` INT,
  `page` INT
) CHARACTER SET latin1;

CREATE TABLE `user_progress_image_gallery` (
  `UUID` INT,
  `UID` INT,
  `number` INT,
  `image_number` INT
) CHARACTER SET latin1;

CREATE TABLE `user_progress_video` (
  `UUID` INT,
  `UID` INT,
  `number` INT,
  `video_second` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_023501_Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_023501_Schema') AS relationships;
DROP DATABASE `db_023501_Schema`;
UNINSTALL EXTENSION vsql_schematron;
