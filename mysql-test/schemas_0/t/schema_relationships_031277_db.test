INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 031277_db
--echo #
CREATE DATABASE `db_031277_db`;
USE `db_031277_db`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `info` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `periods` (
  `period_id` VARCHAR(50) NOT NULL,
  `user` VARCHAR(50),
  `start` TIMESTAMP NULL,
  `length` INT,
  `info` TEXT,
  PRIMARY KEY (`period_id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
  `task_id` VARCHAR(50) NOT NULL,
  `user` VARCHAR(50),
  `name` VARCHAR(50),
  `status` BOOLEAN,
  `date` TIMESTAMP NULL,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_031277_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_031277_db') AS relationships;
DROP DATABASE `db_031277_db`;
UNINSTALL EXTENSION vsql_schematron;
