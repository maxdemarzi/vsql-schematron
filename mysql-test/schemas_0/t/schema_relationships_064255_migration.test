INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064255_migration
--echo #
CREATE DATABASE `db_064255_migration`;
USE `db_064255_migration`;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `description` VARCHAR(64),
  `email` VARCHAR(64),
  `github` VARCHAR(64),
  `linkedin` VARCHAR(64),
  `location` VARCHAR(64),
  `image` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project` (
  `id` INT,
  `name` VARCHAR(64),
  `repo` VARCHAR(64),
  `description` VARCHAR(64),
  `link` VARCHAR(64),
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Language` (
  `id` INT,
  `name` VARCHAR(64),
  `color` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ProjectLanguage` (
  `projectId` INT,
  `languageId` INT,
  PRIMARY KEY (`projectId`, `languageId`)
) CHARACTER SET latin1;

CREATE TABLE `Photo` (
  `id` INT,
  `link` VARCHAR(64),
  `caption` VARCHAR(64),
  `projectId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064255_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064255_migration') AS relationships;
DROP DATABASE `db_064255_migration`;
UNINSTALL EXTENSION vsql_schematron;
