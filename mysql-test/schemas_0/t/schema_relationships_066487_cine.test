INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066487_cine
--echo #
CREATE DATABASE `db_066487_cine`;
USE `db_066487_cine`;
CREATE TABLE `SALAS` (
  `codsala` INT NOT NULL,
  `tipo_sonido` VARCHAR(50),
  `numfilas` INT,
  `numasiporfilas` INT,
  PRIMARY KEY (`codsala`)
) CHARACTER SET latin1;
CREATE TABLE `PELICULAS` (
  `codpelicula` INT NOT NULL,
  `titulo` VARCHAR(50),
  `fecha_prod` DATE,
  `genero` VARCHAR(50),
  PRIMARY KEY (`codpelicula`)
) CHARACTER SET latin1;
CREATE TABLE `PASES` (
  `codpase` INT NOT NULL,
  `codsala` INT,
  `codpelicula` INT,
  `fecha_pase` DATE,
  `tipo_pase` VARCHAR(50),
  PRIMARY KEY (`codpase`)
) CHARACTER SET latin1;
CREATE TABLE `ENTRADAS` (
  `codentrada` INT NOT NULL,
  `numfila` INT,
  `numenfila` INT,
  `codpase` INT,
  `vendido` CHAR(50),
  `comprador` VARCHAR(50),
  `pvp` INT,
  PRIMARY KEY (`codentrada`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066487_cine') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066487_cine') AS relationships;
DROP DATABASE `db_066487_cine`;
UNINSTALL EXTENSION vsql_schematron;
