INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008664_Invite
--echo #
CREATE DATABASE `db_008664_Invite`;
USE `db_008664_Invite`;

CREATE TABLE `Invite` (
  `token` VARCHAR(64),
  `email` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `text` VARCHAR(64),
  `sentTime` DATETIME,
  `sentBy` INT,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

CREATE TABLE `InviteAcceptAction` (
  `invite` VARCHAR(64),
  `memberAction` INT,
  PRIMARY KEY (`invite`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008664_Invite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008664_Invite') AS relationships;
DROP DATABASE `db_008664_Invite`;
UNINSTALL EXTENSION vsql_schematron;
