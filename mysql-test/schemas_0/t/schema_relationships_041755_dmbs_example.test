INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041755_dmbs_example
--echo #
CREATE DATABASE `db_041755_dmbs_example`;
USE `db_041755_dmbs_example`;

CREATE TABLE `admin` (
  `id` INT,
  `email` VARCHAR(255),
  `password` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie` (
  `id` INT,
  `name` VARCHAR(255),
  `category` VARCHAR(255),
  `duration` INT,
  `release_date` DATETIME,
  `rate_number` DECIMAL(10,2),
  `rate_count` INT,
  `director` VARCHAR(255),
  `star_1` VARCHAR(255),
  `star_2` VARCHAR(255),
  `image` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `rate` (
  `id` INT,
  `rate_value` INT,
  `movie_id` INT,
  `customer_id` INT
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `id` INT,
  `room_no` INT,
  `capacity` INT,
  `theater_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `seat` (
  `id` INT,
  `seat_no` VARCHAR(255),
  `isFull` INT,
  `room_id` INT,
  `theater_id` INT,
  `session_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` INT,
  `session_time` VARCHAR(255),
  `movie_id` INT,
  `theater_id` INT,
  `session_date` VARCHAR(255),
  `room_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `theater` (
  `id` INT,
  `location` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ticket` (
  `id` INT,
  `movie_id` INT,
  `theater_id` INT,
  `customer_id` INT,
  `room_id` INT,
  `seat_id` INT,
  `session_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041755_dmbs_example') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041755_dmbs_example') AS relationships;
DROP DATABASE `db_041755_dmbs_example`;
UNINSTALL EXTENSION vsql_schematron;
