INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015940_assert_postgres_spool
--echo #
CREATE DATABASE `db_015940_assert_postgres_spool`;
USE `db_015940_assert_postgres_spool`;

CREATE TABLE `TAB_D` (
  `tab d id` DECIMAL(10,2),
  PRIMARY KEY (`tab d id`)
) CHARACTER SET latin1;

CREATE TABLE `TAB_WRONG_DEFERRED` (
  `ID` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `TAB_INDEX_TEST` (
  `TAB_INDEX_TEST_ID` DECIMAL(10,2),
  PRIMARY KEY (`TAB_INDEX_TEST_ID`)
) CHARACTER SET latin1;

CREATE TABLE `TAB_INDEX_TEST_REF` (
  `TAB_A_ID` DECIMAL(10,2),
  `TAB_B_ID` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015940_assert_postgres_spool') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015940_assert_postgres_spool') AS relationships;
DROP DATABASE `db_015940_assert_postgres_spool`;
UNINSTALL EXTENSION vsql_schematron;
