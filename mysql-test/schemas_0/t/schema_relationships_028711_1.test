INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028711_1
--echo #
CREATE DATABASE `db_028711_1`;
USE `db_028711_1`;
CREATE TABLE `members` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `mail` VARCHAR(50),
  `password` VARCHAR(50),
  `postdate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message` (
  `id` BIGINT NOT NULL,
  `mail` VARCHAR(50),
  `message` VARCHAR(50),
  `postdate` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `message_members` (
  `message_id` BIGINT NOT NULL,
  `members_id` BIGINT NOT NULL,
  PRIMARY KEY (`message_id`, `members_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028711_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028711_1') AS relationships;
DROP DATABASE `db_028711_1`;
UNINSTALL EXTENSION vsql_schematron;
