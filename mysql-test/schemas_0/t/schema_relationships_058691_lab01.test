INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058691_lab01
--echo #
CREATE DATABASE `db_058691_lab01`;
USE `db_058691_lab01`;

CREATE TABLE `Log` (
  `id` INT,
  `_datetime` DATETIME,
  `statusCode` VARCHAR(64),
  `newRowId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Drivers` (
  `driverId` INT,
  `driverName` VARCHAR(64),
  `driverSurname` VARCHAR(64),
  `driverCode` INT,
  `driverDOB` DATETIME,
  PRIMARY KEY (`driverId`)
) CHARACTER SET latin1;

CREATE TABLE `Models` (
  `modelId` INT,
  `modelName` VARCHAR(64),
  `payloadCapacity` INT,
  PRIMARY KEY (`modelId`)
) CHARACTER SET latin1;

CREATE TABLE `Cars` (
  `carId` INT,
  `modelCode` INT,
  `releaseYear` INT,
  `markCode` INT,
  `carNum` INT,
  PRIMARY KEY (`carId`)
) CHARACTER SET latin1;

CREATE TABLE `Report` (
  `travelId` INT,
  `carId` INT,
  `driverId` INT,
  `dateOfExport` DATETIME,
  `timeOfExport` DATETIME,
  `cargoWeight` INT,
  `returnDate` DATETIME,
  `distanse` INT,
  PRIMARY KEY (`travelId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058691_lab01') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058691_lab01') AS relationships;
DROP DATABASE `db_058691_lab01`;
UNINSTALL EXTENSION vsql_schematron;
