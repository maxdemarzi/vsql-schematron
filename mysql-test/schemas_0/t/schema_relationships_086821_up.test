INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086821_up
--echo #
CREATE DATABASE `db_086821_up`;
USE `db_086821_up`;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `parent` INT,
  `depth` INT,
  `title` TEXT,
  `description` TEXT,
  `body` TEXT,
  `format` INT,
  `status` INT,
  `flagged` BOOLEAN,
  `uuid` BLOB,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086821_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086821_up') AS relationships;
DROP DATABASE `db_086821_up`;
UNINSTALL EXTENSION vsql_schematron;
