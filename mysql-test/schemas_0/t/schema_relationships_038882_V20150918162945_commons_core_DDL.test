INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038882_V20150918162945__commons_core_DDL
--echo #
CREATE DATABASE `db_038882_V20150918162945_commons_core_DDL`;
USE `db_038882_V20150918162945_commons_core_DDL`;

CREATE TABLE `eg_location` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `version` DECIMAL(10,2),
  `createdby` INT,
  `createddate` DATETIME,
  `lastModifiedBy` INT,
  `lastmodifieddate` DATETIME,
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eg_location_ipmap` (
  `id` INT,
  `locationid` INT,
  `ipaddress` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eg_usercounter_map` (
  `id` INT,
  `userid` INT,
  `counterid` INT,
  `fromdate` DATETIME,
  `todate` DATETIME,
  `version` DECIMAL(10,2),
  `createdby` INT,
  `createddate` DATETIME,
  `lastModifiedBy` INT,
  `lastmodifieddate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eg_modules` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038882_V20150918162945_commons_core_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038882_V20150918162945_commons_core_DDL') AS relationships;
DROP DATABASE `db_038882_V20150918162945_commons_core_DDL`;
UNINSTALL EXTENSION vsql_schematron;
