INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077678_redundant_join_fk_create
--echo #
CREATE DATABASE `db_077678_redundant_join_fk_create`;
USE `db_077678_redundant_join_fk_create`;
CREATE TABLE `professors` (
  `prof_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `nickname` VARCHAR(50),
  PRIMARY KEY (`prof_id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
  `course_id` VARCHAR(50) NOT NULL,
  `nb_students` INT,
  `duration` DECIMAL(10,2),
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `teaching` (
  `course_id` VARCHAR(50) NOT NULL,
  `prof_id` INT NOT NULL,
  PRIMARY KEY (`course_id`, `prof_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077678_redundant_join_fk_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077678_redundant_join_fk_create') AS relationships;
DROP DATABASE `db_077678_redundant_join_fk_create`;
UNINSTALL EXTENSION vsql_schematron;
