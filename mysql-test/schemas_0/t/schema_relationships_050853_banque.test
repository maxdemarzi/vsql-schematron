INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 050853_banque
--echo #
CREATE DATABASE `db_050853_banque`;
USE `db_050853_banque`;

CREATE TABLE `titulaire` (
  `id` INT,
  `nom` VARCHAR(64),
  `prenom` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `typecompte` (
  `id` INT,
  `nom` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `compte` (
  `id` INT,
  `numcompte` VARCHAR(64),
  `typecompte_id` INT,
  `date_ouverture` DATETIME,
  `derniere_op` DATETIME,
  `solde` DECIMAL(10,2),
  `titulaire_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `operation` (
  `id` INT,
  `compte_id` INT,
  `libelle` VARCHAR(64),
  `date_operation` DATETIME,
  `montant` DECIMAL(10,2),
  `type_operation` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_050853_banque') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_050853_banque') AS relationships;
DROP DATABASE `db_050853_banque`;
UNINSTALL EXTENSION vsql_schematron;
