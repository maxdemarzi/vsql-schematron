INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020878_Script_Creacion_estandar
--echo #
CREATE DATABASE `db_020878_Script_Creacion_estandar`;
USE `db_020878_Script_Creacion_estandar`;
CREATE TABLE `empleado` (
  `alta` TINYINT,
  `nif` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `administrador` TINYINT,
  `contraseña` VARCHAR(50),
  PRIMARY KEY (`nif`)
) CHARACTER SET latin1;
CREATE TABLE `fichaje` (
  `nif` VARCHAR(50),
  `horaEntrada` DATETIME,
  `horaSalida` DATETIME,
  `finalizar` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020878_Script_Creacion_estandar') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020878_Script_Creacion_estandar') AS relationships;
DROP DATABASE `db_020878_Script_Creacion_estandar`;
UNINSTALL EXTENSION vsql_schematron;
