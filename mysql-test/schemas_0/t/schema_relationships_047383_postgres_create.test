INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047383_postgres_create
--echo #
CREATE DATABASE `db_047383_postgres_create`;
USE `db_047383_postgres_create`;

CREATE TABLE `public.users` (
  `_id` INT,
  `email` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `public.job_apps` (
  `_id` INT,
  `company` VARCHAR(64),
  `role` VARCHAR(64),
  `status` VARCHAR(64),
  `date_applied` DATETIME,
  `priority` INT,
  `link` VARCHAR(64),
  `notes` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047383_postgres_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047383_postgres_create') AS relationships;
DROP DATABASE `db_047383_postgres_create`;
UNINSTALL EXTENSION vsql_schematron;
