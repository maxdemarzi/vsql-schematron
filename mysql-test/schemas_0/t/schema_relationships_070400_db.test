INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070400_db
--echo #
CREATE DATABASE `db_070400_db`;
USE `db_070400_db`;

CREATE TABLE `clientes` (
  `id` INT,
  `nome` VARCHAR(255),
  `email` VARCHAR(255),
  `cpf` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `compras` (
  `id` INT,
  `data` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `compra_itens` (
  `id` INT,
  `quantidade` INT,
  `preco_unitario` DECIMAL(10,2),
  `estoque_min` INT,
  `compra_id` INT,
  `produto_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `funcionarios` (
  `id` INT,
  `nome` VARCHAR(255),
  `email` VARCHAR(255),
  `cpf` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pedidos` (
  `id` INT,
  `data` DATETIME,
  `data_confirmacao` DATETIME,
  `cliente_id` INT,
  `funcionario_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `produtos` (
  `id` INT,
  `nome` VARCHAR(255),
  `data_cadastro` DATETIME,
  `quantidade` INT,
  `unidade_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `unidades` (
  `id` INT,
  `unidade` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070400_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070400_db') AS relationships;
DROP DATABASE `db_070400_db`;
UNINSTALL EXTENSION vsql_schematron;
