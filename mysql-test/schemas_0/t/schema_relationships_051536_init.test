INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051536_init
--echo #
CREATE DATABASE `db_051536_init`;
USE `db_051536_init`;
CREATE TABLE `FoodCategory` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Food` (
  `Id` INT NOT NULL,
  `CategoryId` INT,
  `Name` VARCHAR(50),
  `Price` DECIMAL(10,2),
  `Description` VARCHAR(50),
  `Picture` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `account` VARCHAR(50),
  `password` VARCHAR(50),
  `age` INT,
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051536_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051536_init') AS relationships;
DROP DATABASE `db_051536_init`;
UNINSTALL EXTENSION vsql_schematron;
