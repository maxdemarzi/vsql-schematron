INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 049918_db
--echo #
CREATE DATABASE `db_049918_db`;
USE `db_049918_db`;

CREATE TABLE `users` (
  `user_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `gender` VARCHAR(255),
  `birthday` DATETIME,
  `reg_date` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_files` (
  `file_id` INT,
  `user_id` INT,
  `add_date` DATETIME,
  `file_ext` VARCHAR(255),
  `real_name` VARCHAR(255),
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_049918_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_049918_db') AS relationships;
DROP DATABASE `db_049918_db`;
UNINSTALL EXTENSION vsql_schematron;
