INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086325_database
--echo #
CREATE DATABASE `db_086325_database`;
USE `db_086325_database`;

CREATE TABLE `permissions` (
  `perm_id` INT,
  `perm_module` VARCHAR(64),
  `perm_description` VARCHAR(64),
  PRIMARY KEY (`perm_id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `role_id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;

CREATE TABLE `roles_permissions` (
  `role_id` INT,
  `perm_id` INT,
  PRIMARY KEY (`role_id`, `perm_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `user_uuid` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_email` VARCHAR(64),
  `user_password` VARCHAR(64),
  `role_id` INT,
  PRIMARY KEY (`user_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `classes` (
  `class_uuid` VARCHAR(64),
  `class_name` VARCHAR(64),
  `class_description` VARCHAR(64),
  `slug` VARCHAR(64),
  `teacher_uuid` VARCHAR(64),
  PRIMARY KEY (`class_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `student_registrations` (
  `reg_uuid` VARCHAR(64),
  `class_uuid` VARCHAR(64),
  `student_uuid` VARCHAR(64),
  `grade` VARCHAR(64),
  `remarks` VARCHAR(64),
  PRIMARY KEY (`reg_uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086325_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086325_database') AS relationships;
DROP DATABASE `db_086325_database`;
UNINSTALL EXTENSION vsql_schematron;
