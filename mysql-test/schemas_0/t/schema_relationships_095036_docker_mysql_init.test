INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095036_docker_mysql_init
--echo #
CREATE DATABASE `db_095036_docker_mysql_init`;
USE `db_095036_docker_mysql_init`;

CREATE TABLE `channels` (
  `id` INT,
  `name` VARCHAR(255),
  `project_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `foreign_id` INT,
  `channel_id` INT,
  `inserted_at` DATETIME,
  `name` VARCHAR(255),
  `phone` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` INT,
  `name` VARCHAR(255),
  `creator_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095036_docker_mysql_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095036_docker_mysql_init') AS relationships;
DROP DATABASE `db_095036_docker_mysql_init`;
UNINSTALL EXTENSION vsql_schematron;
