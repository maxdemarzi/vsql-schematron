INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010758_V1_create_initial_tables
--echo #
CREATE DATABASE `db_010758_V1_create_initial_tables`;
USE `db_010758_V1_create_initial_tables`;

CREATE TABLE `customer` (
  `customer_id` VARCHAR(255),
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `allow_duplicate_email` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_password` (
  `customer_id` VARCHAR(255),
  `password` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_address` (
  `address_id` VARCHAR(255),
  `customer_id` VARCHAR(255),
  `number` VARCHAR(255),
  `street` VARCHAR(255),
  `city` VARCHAR(255),
  `postcode` VARCHAR(255),
  `country` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_card` (
  `card_id` VARCHAR(255),
  `customer_id` VARCHAR(255),
  `long_num` VARCHAR(255),
  `expires` DATETIME,
  `ccv` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`card_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010758_V1_create_initial_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010758_V1_create_initial_tables') AS relationships;
DROP DATABASE `db_010758_V1_create_initial_tables`;
UNINSTALL EXTENSION vsql_schematron;
