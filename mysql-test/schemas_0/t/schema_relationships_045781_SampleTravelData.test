INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045781_SampleTravelData
--echo #
CREATE DATABASE `db_045781_SampleTravelData`;
USE `db_045781_SampleTravelData`;

CREATE TABLE `employee_details` (
  `employee_id` INT,
  `employee_name` VARCHAR(64),
  `age` INT,
  `address` VARCHAR(64),
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `geo_cordinates` (
  `location_id` INT,
  `location` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;

CREATE TABLE `meeting_details` (
  `meeting_id` INT,
  `meeting_date` DATETIME,
  `meeting_by` INT,
  `client_name` VARCHAR(64),
  `meeting_purpose` VARCHAR(64),
  `meeting_impact` VARCHAR(64),
  `meet_cancellation_status` VARCHAR(64),
  `cancellation_reason` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `travel_details` (
  `travel_id` INT,
  `travel_date` DATETIME,
  `travel_type` VARCHAR(64),
  `travel_medium` VARCHAR(64),
  `source_id` INT,
  `source` VARCHAR(64),
  `destination_id` INT,
  `destination` VARCHAR(64),
  `travel_cost` INT,
  `mode_of_payment` VARCHAR(64),
  `booking_platform` VARCHAR(64),
  `travelled_by` INT,
  PRIMARY KEY (`travel_id`)
) CHARACTER SET latin1;

CREATE TABLE `dimdate` (
  `dim_id` INT,
  `fiscal_year` DATETIME,
  `modified_date` DATETIME,
  `date_key` VARCHAR(64),
  `day_number` VARCHAR(64),
  `fiscal_month_name` VARCHAR(64),
  `fiscal_month_label` VARCHAR(64),
  `created_date` VARCHAR(64),
  `created_time` VARCHAR(64),
  `rating` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045781_SampleTravelData') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045781_SampleTravelData') AS relationships;
DROP DATABASE `db_045781_SampleTravelData`;
UNINSTALL EXTENSION vsql_schematron;
