INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040212_Prueba1
--echo #
CREATE DATABASE `db_040212_Prueba1`;
USE `db_040212_Prueba1`;
CREATE TABLE `tbl_empleados` (
  `idEmpleado` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `apellido1` VARCHAR(50),
  `apellido2` VARCHAR(50),
  `fechaNacimiento` DATE,
  `codOficina` INT,
  PRIMARY KEY (`idEmpleado`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_oficina` (
  `codOficina` INT NOT NULL,
  `nombreOficina` VARCHAR(50),
  `direccion` VARCHAR(50),
  `codPostal` CHAR(50),
  `telefono` CHAR(50),
  PRIMARY KEY (`codOficina`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040212_Prueba1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040212_Prueba1') AS relationships;
DROP DATABASE `db_040212_Prueba1`;
UNINSTALL EXTENSION vsql_schematron;
