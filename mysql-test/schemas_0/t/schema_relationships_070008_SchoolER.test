INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070008_SchoolER
--echo #
CREATE DATABASE `db_070008_SchoolER`;
USE `db_070008_SchoolER`;
CREATE TABLE `RECORDS` (
  `record_id` INT NOT NULL,
  `student_id` INT,
  `subject_id` INT,
  `semester_id` INT,
  `grade` DOUBLE,
  PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `SEMESTERS` (
  `semester_id` INT NOT NULL,
  `name` VARCHAR(50),
  `year` INT,
  `period` SMALLINT,
  PRIMARY KEY (`semester_id`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENTS` (
  `student_id` INT NOT NULL,
  `last_name` VARCHAR(50),
  `first_name` VARCHAR(50),
  `nationality` VARCHAR(50),
  `current_semester_id` INT,
  PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `SUBJECTS` (
  `subject_id` INT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `credits` SMALLINT,
  PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070008_SchoolER') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070008_SchoolER') AS relationships;
DROP DATABASE `db_070008_SchoolER`;
UNINSTALL EXTENSION vsql_schematron;
