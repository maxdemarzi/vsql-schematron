INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097573_sap_hana
--echo #
CREATE DATABASE `db_097573_sap_hana`;
USE `db_097573_sap_hana`;

CREATE TABLE `DBLOAD.DEPARTMENTS` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DBLOAD.EMPLOYEES` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `BIRTHDAY` DATETIME,
  `DEPARTMENT_ID` INT,
  `TERMINATED` BOOL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DBLOAD.CLIENTS` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `PHONE` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `JOB_TITLE` VARCHAR(64),
  `POLICY` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DBLOAD.SALES` (
  `ID` INT,
  `SALE_DATE` DATETIME,
  `SALES_EMP_ID` INT,
  `CLIENT_ID` INT,
  `SUBJECT` VARCHAR(64),
  `AMOUNT` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097573_sap_hana') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097573_sap_hana') AS relationships;
DROP DATABASE `db_097573_sap_hana`;
UNINSTALL EXTENSION vsql_schematron;
