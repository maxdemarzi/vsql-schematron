INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058483_simap
--echo #
CREATE DATABASE `db_058483_simap`;
USE `db_058483_simap`;
CREATE TABLE `jumlah_pkh` (
  `id` INT,
  `idKecamatan` INT,
  `bulan` VARCHAR(50),
  `tahun` TEXT,
  `jumlah` INT
) CHARACTER SET latin1;
CREATE TABLE `kecamatan` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  `geojson` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kelurahan` (
  `id` INT,
  `idKecamatan` INT,
  `nama` VARCHAR(50),
  `geojson` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `perhitungan` (
  `id` INT,
  `idJumlah_pkh` INT,
  `nilai_sem` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `image` VARCHAR(50),
  `status` VARCHAR(50),
  `level_user` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058483_simap') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058483_simap') AS relationships;
DROP DATABASE `db_058483_simap`;
UNINSTALL EXTENSION vsql_schematron;
