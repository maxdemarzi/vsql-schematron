INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016073_database
--echo #
CREATE DATABASE `db_016073_database`;
USE `db_016073_database`;
CREATE TABLE `Line` (
  `Line_ID` INT NOT NULL,
  `Line_Name` VARCHAR(50),
  PRIMARY KEY (`Line_ID`)
) CHARACTER SET latin1;
CREATE TABLE `Station` (
  `Station_ID` INT NOT NULL,
  `Name` VARCHAR(50),
  `Line_ID` INT,
  `Prev_Station` INT,
  `Next_Station` INT,
  `Hybrid_ID` INT,
  PRIMARY KEY (`Station_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016073_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016073_database') AS relationships;
DROP DATABASE `db_016073_database`;
UNINSTALL EXTENSION vsql_schematron;
