INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097597_db
--echo #
CREATE DATABASE `db_097597_db`;
USE `db_097597_db`;

CREATE TABLE `File` (
  `filename` VARCHAR(64),
  `curhash` INT,
  `curversion` INT,
  `numversions` INT,
  PRIMARY KEY (`filename`)
) CHARACTER SET latin1;

CREATE TABLE `Version` (
  `id` INT,
  `filename` VARCHAR(64),
  `size` INT,
  `time` INT,
  `filemodtime` INT,
  `comment` VARCHAR(64),
  `version` INT,
  `hash` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Block` (
  `id` INT,
  `hash1` INT,
  `hash2` INT,
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `VtoB` (
  `id` INT,
  `versionid` INT,
  `blockid` INT,
  `versionindex` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097597_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097597_db') AS relationships;
DROP DATABASE `db_097597_db`;
UNINSTALL EXTENSION vsql_schematron;
