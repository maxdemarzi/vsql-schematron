INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014967_migration
--echo #
CREATE DATABASE `db_014967_migration`;
USE `db_014967_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `password` VARCHAR(64),
  `image` VARCHAR(64),
  `blocked` BOOL,
  `verified` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Organization` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `createdById` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Project` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `description` VARCHAR(64),
  `orgId` VARCHAR(64),
  `createdById` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Board` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `lists` VARCHAR(64),
  `orgId` VARCHAR(64),
  `createdById` VARCHAR(64),
  `projectId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Task` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `list` VARCHAR(64),
  `projectId` VARCHAR(64),
  `boardId` VARCHAR(64),
  `orgId` VARCHAR(64),
  `assignedById` VARCHAR(64),
  `priority` VARCHAR(64),
  `startDate` DATETIME,
  `dueDate` DATETIME,
  `createdById` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `completed` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `SubTask` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `assignedById` VARCHAR(64),
  `stateDate` DATETIME,
  `dueDate` DATETIME,
  `createdById` VARCHAR(64),
  `priority` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `completed` BOOL,
  `taskId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `orgId` VARCHAR(64),
  `taskId` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `id` VARCHAR(64),
  `content` VARCHAR(64),
  `reactions` VARCHAR(64),
  `createdById` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `taskId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Role` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `permissions` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserRoleOrg` (
  `id` VARCHAR(64),
  `orgId` VARCHAR(64),
  `userId` VARCHAR(64),
  `roleId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_OrganizationToUser` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_assignees` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_subTaskAssignees` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_members` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014967_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014967_migration') AS relationships;
DROP DATABASE `db_014967_migration`;
UNINSTALL EXTENSION vsql_schematron;
