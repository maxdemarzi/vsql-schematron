INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062757_1517299952_init_up
--echo #
CREATE DATABASE `db_062757_1517299952_init_up`;
USE `db_062757_1517299952_init_up`;

CREATE TABLE `org` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vpc` (
  `id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `region` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `facility_network_transit` (
  `src_facility_id` VARCHAR(64),
  `dst_facility_id` VARCHAR(64),
  `transport` VARCHAR(64),
  PRIMARY KEY (`src_facility_id`, `dst_facility_id`)
) CHARACTER SET latin1;

CREATE TABLE `vni` (
  `facility_id` VARCHAR(64),
  `vni` INT,
  `vpc_id` VARCHAR(64),
  `expired_at` DATETIME,
  `expire_after` INT,
  PRIMARY KEY (`facility_id`, `vni`)
) CHARACTER SET latin1;

CREATE TABLE `account_mac` (
  `id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `mac` VARCHAR(64),
  `vpc_id` VARCHAR(64),
  `subnet_id` VARCHAR(64),
  `expired_at` DATETIME,
  `expire_after` INT,
  PRIMARY KEY (`account_id`, `mac`)
) CHARACTER SET latin1;

CREATE TABLE `router` (
  `id` VARCHAR(64),
  `vpc_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `obj_type` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `vnic` (
  `id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `obj_id` VARCHAR(64),
  `obj_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `security_group` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `account_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cn` (
  `id` VARCHAR(64),
  `facility_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062757_1517299952_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062757_1517299952_init_up') AS relationships;
DROP DATABASE `db_062757_1517299952_init_up`;
UNINSTALL EXTENSION vsql_schematron;
