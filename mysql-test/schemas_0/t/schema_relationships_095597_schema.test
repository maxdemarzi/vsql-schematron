INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095597_schema
--echo #
CREATE DATABASE `db_095597_schema`;
USE `db_095597_schema`;

CREATE TABLE `user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `profile_image` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `teacher` (
  `username` VARCHAR(64),
  `bio` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `username` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `guest` INT,
  `category` VARCHAR(64),
  `creator` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_course` (
  `username` VARCHAR(64),
  `course` VARCHAR(64),
  PRIMARY KEY (`username`, `course`)
) CHARACTER SET latin1;

CREATE TABLE `lesson` (
  `id` INT,
  `title` VARCHAR(64),
  `course` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `material` (
  `id` INT,
  `name` VARCHAR(64),
  `lesson` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `question` (
  `id` INT,
  `question` VARCHAR(64),
  `answer` VARCHAR(64),
  `student` VARCHAR(64),
  `course` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095597_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095597_schema') AS relationships;
DROP DATABASE `db_095597_schema`;
UNINSTALL EXTENSION vsql_schematron;
