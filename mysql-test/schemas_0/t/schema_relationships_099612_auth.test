INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 099612_auth
--echo #
CREATE DATABASE `db_099612_auth`;
USE `db_099612_auth`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_099612_auth') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_099612_auth') AS relationships;
DROP DATABASE `db_099612_auth`;
UNINSTALL EXTENSION vsql_schematron;
