INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086054_BD_Alunos
--echo #
CREATE DATABASE `db_086054_BD_Alunos`;
USE `db_086054_BD_Alunos`;
CREATE TABLE `instituicao` (
  `cd_instituicao` VARCHAR(50) NOT NULL,
  `nm_instituicao` VARCHAR(50),
  PRIMARY KEY (`cd_instituicao`)
) CHARACTER SET latin1;
CREATE TABLE `cursos` (
  `cd_curso` VARCHAR(50) NOT NULL,
  `nm_curso` VARCHAR(50),
  `sg_curso` CHAR(50),
  `cd_instituicao` VARCHAR(50),
  PRIMARY KEY (`cd_curso`)
) CHARACTER SET latin1;
CREATE TABLE `alunos` (
  `cd_aluno` VARCHAR(50) NOT NULL,
  `nm_aluno` VARCHAR(50),
  `sg_sexoAluno` CHAR(50),
  `cd_curso` VARCHAR(50),
  `qt_notaAluno` DECIMAL(10,2),
  `qt_idade` INT,
  PRIMARY KEY (`cd_aluno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086054_BD_Alunos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086054_BD_Alunos') AS relationships;
DROP DATABASE `db_086054_BD_Alunos`;
UNINSTALL EXTENSION vsql_schematron;
