INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 083589_database
--echo #
CREATE DATABASE `db_083589_database`;
USE `db_083589_database`;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `bio` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `password` VARCHAR(64),
  `profile_pic` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `followers` (
  `id` INT,
  `date` DATETIME,
  `user_id` INT,
  `follower_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `description` VARCHAR(64),
  `user_id` INT,
  `location_id` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `locations` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `date` DATETIME,
  `message` VARCHAR(64),
  `comment_id` INT,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `id` INT,
  `date` DATETIME,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `saved_posts` (
  `id` INT,
  `date` DATETIME,
  `user_id` INT,
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `root` VARCHAR(64),
  `date` DATETIME,
  `post_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_083589_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_083589_database') AS relationships;
DROP DATABASE `db_083589_database`;
UNINSTALL EXTENSION vsql_schematron;
