CREATE DATABASE `db_072385_V20190423115420_bill_v1_create_ddl`;
USE `db_072385_V20190423115420_bill_v1_create_ddl`;

CREATE TABLE `egbs_bill_v1` (
  `id` VARCHAR(64),
  `tenantid` VARCHAR(64),
  `payername` VARCHAR(64),
  `payeraddress` VARCHAR(64),
  `payeremail` VARCHAR(64),
  `isactive` VARCHAR(64),
  `iscancelled` VARCHAR(64),
  `createdby` VARCHAR(64),
  `createddate` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodifieddate` INT,
  `mobilenumber` VARCHAR(64),
  PRIMARY KEY (`id`, `tenantid`)
) CHARACTER SET latin1;

CREATE TABLE `egbs_billdetail_v1` (
  `id` VARCHAR(64),
  `tenantid` VARCHAR(64),
  `billid` VARCHAR(64),
  `businessservice` VARCHAR(64),
  `billno` VARCHAR(64),
  `billdate` INT,
  `consumercode` VARCHAR(64),
  `consumertype` VARCHAR(64),
  `billdescription` VARCHAR(64),
  `displaymessage` VARCHAR(64),
  `minimumamount` DECIMAL(10,2),
  `totalamount` DECIMAL(10,2),
  `callbackforapportioning` VARCHAR(64),
  `partpaymentallowed` VARCHAR(64),
  `collectionmodesnotallowed` VARCHAR(64),
  `createdby` VARCHAR(64),
  `createddate` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodifieddate` INT,
  `receiptdate` INT,
  `receiptnumber` VARCHAR(64),
  `fromperiod` INT,
  `toperiod` INT,
  `demandid` VARCHAR(64),
  `isadvanceallowed` VARCHAR(64),
  `expirydate` INT,
  PRIMARY KEY (`id`, `tenantid`)
) CHARACTER SET latin1;

CREATE TABLE `egbs_billaccountdetail_v1` (
  `id` VARCHAR(64),
  `tenantid` VARCHAR(64),
  `billdetail` VARCHAR(64),
  `glcode` VARCHAR(64),
  `orderno` INT,
  `accountdescription` VARCHAR(64),
  `creditamount` DECIMAL(10,2),
  `debitamount` DECIMAL(10,2),
  `isactualdemand` VARCHAR(64),
  `purpose` VARCHAR(64),
  `createdby` VARCHAR(64),
  `createddate` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodifieddate` INT,
  `cramounttobepaid` DECIMAL(10,2),
  `taxheadcode` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `adjustedamount` DECIMAL(10,2),
  `demanddetailid` VARCHAR(64),
  PRIMARY KEY (`id`, `tenantid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
