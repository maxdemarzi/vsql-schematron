INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067515_pongo_codeigniter
--echo #
CREATE DATABASE `db_067515_pongo_codeigniter`;
USE `db_067515_pongo_codeigniter`;

CREATE TABLE `groups` (
  `id` INT,
  `group_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `parent_id` INT,
  `is_have_child` INT,
  `title` VARCHAR(64),
  `link` VARCHAR(64),
  `icon` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `migration` VARCHAR(64),
  `batch` INT
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `privileges` (
  `id` INT,
  `group_id` INT,
  `menu_id` INT
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `product_name` VARCHAR(64),
  `price` INT,
  `stock` INT,
  `images` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `meta_key` VARCHAR(64),
  `meta_value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transactions` (
  `id` INT,
  `invoice_number` VARCHAR(64),
  `client_name` VARCHAR(64),
  `client_address` VARCHAR(64),
  `client_phone` VARCHAR(64),
  `total_price` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction_details` (
  `id` INT,
  `transaction_id` INT,
  `product_id` INT,
  `price` INT,
  `qty` INT,
  `subtotal_price` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `group_id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067515_pongo_codeigniter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067515_pongo_codeigniter') AS relationships;
DROP DATABASE `db_067515_pongo_codeigniter`;
UNINSTALL EXTENSION vsql_schematron;
