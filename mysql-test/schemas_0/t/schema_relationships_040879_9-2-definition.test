INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040879_9-2-definition
--echo #
CREATE DATABASE `db_040879_9_2_definition`;
USE `db_040879_9_2_definition`;
CREATE TABLE `hosts` (
  `macid` CHAR(50),
  `macvendor` VARCHAR(50),
  `ip` VARCHAR(50),
  `hostname` VARCHAR(50),
  `updated` DATETIME,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ports` (
  `id` INT NOT NULL,
  `host_id` INT,
  `state` VARCHAR(50),
  `port` INT,
  `protocol` VARCHAR(50),
  `service` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `os` (
  `id` INT NOT NULL,
  `cpe` VARCHAR(50),
  `osname` VARCHAR(50),
  `accuracy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `oid` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040879_9_2_definition') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040879_9_2_definition') AS relationships;
DROP DATABASE `db_040879_9_2_definition`;
UNINSTALL EXTENSION vsql_schematron;
