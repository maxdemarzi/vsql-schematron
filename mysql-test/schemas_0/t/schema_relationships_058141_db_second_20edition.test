INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058141_db-second%20edition
--echo #
CREATE DATABASE `db_058141_db_second_20edition`;
USE `db_058141_db_second_20edition`;

CREATE TABLE `College` (
  `collegeID` INT,
  `name` VARCHAR(64),
  `addr1` VARCHAR(64),
  `addr2` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `county` VARCHAR(64),
  `contactNum` VARCHAR(64),
  PRIMARY KEY (`collegeID`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `collegeID` INT,
  `courseCode` VARCHAR(64),
  `courseName` VARCHAR(64),
  PRIMARY KEY (`courseCode`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `studentNumber` VARCHAR(64),
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `pass` VARCHAR(64),
  `email` VARCHAR(64),
  `addr1` VARCHAR(64),
  `addr2` VARCHAR(64),
  `county` VARCHAR(64),
  `country` VARCHAR(64),
  `nationality` VARCHAR(64),
  `courseCode` VARCHAR(64),
  PRIMARY KEY (`studentNumber`)
) CHARACTER SET latin1;

CREATE TABLE `Classes` (
  `className` VARCHAR(64),
  `lecturer` VARCHAR(64),
  `assistant` VARCHAR(64),
  `courseCode` VARCHAR(64),
  PRIMARY KEY (`className`, `courseCode`)
) CHARACTER SET latin1;

CREATE TABLE `Grade` (
  `ClassName` VARCHAR(64),
  `studentNumber` VARCHAR(64),
  `grade` VARCHAR(64),
  PRIMARY KEY (`studentNumber`, `ClassName`)
) CHARACTER SET latin1;

CREATE TABLE `TimeSlot` (
  `slotID` INT,
  `timeStart` DATETIME,
  `timeEnd` DATETIME,
  PRIMARY KEY (`slotID`)
) CHARACTER SET latin1;

CREATE TABLE `Timetable` (
  `she_Day` VARCHAR(64),
  `she_TimeSlot` INT,
  `className` VARCHAR(64),
  `courseCode` VARCHAR(64),
  PRIMARY KEY (`she_TimeSlot`, `className`, `courseCode`)
) CHARACTER SET latin1;

CREATE TABLE `Library` (
  `bookID` VARCHAR(64),
  `collegeID` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `description` VARCHAR(64),
  `image` VARCHAR(64),
  `category` VARCHAR(64),
  PRIMARY KEY (`bookID`, `collegeID`)
) CHARACTER SET latin1;

CREATE TABLE `MyBooks` (
  `bookID` VARCHAR(64),
  `studentID` VARCHAR(64),
  PRIMARY KEY (`bookID`, `studentID`)
) CHARACTER SET latin1;

CREATE TABLE `News` (
  `newsId` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `location` VARCHAR(64),
  `image` VARCHAR(64),
  `date` VARCHAR(64),
  `collegeID` INT,
  PRIMARY KEY (`newsId`)
) CHARACTER SET latin1;

CREATE TABLE `Support` (
  `supportName` VARCHAR(64),
  `desc` VARCHAR(64),
  `contactNum` VARCHAR(64),
  `location` VARCHAR(64),
  `collegeID` INT,
  PRIMARY KEY (`supportName`, `collegeID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058141_db_second_20edition') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058141_db_second_20edition') AS relationships;
DROP DATABASE `db_058141_db_second_20edition`;
UNINSTALL EXTENSION vsql_schematron;
