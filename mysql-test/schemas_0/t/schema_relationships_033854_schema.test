INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033854_schema
--echo #
CREATE DATABASE `db_033854_schema`;
USE `db_033854_schema`;

CREATE TABLE `RG_MODELS` (
  `RMD_ID` DECIMAL(10,2),
  `RMD_NAME` VARCHAR(255),
  `RMD_START` DATETIME,
  `RMD_END` DATETIME,
  `RMD_FORMAT` VARCHAR(255),
  PRIMARY KEY (`RMD_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_IMAGE_TYPES` (
  `RIT_ID` DECIMAL(10,2),
  `RIT_RMD_ID` DECIMAL(10,2),
  `RIT_NAME` VARCHAR(255),
  `RIT_DESC` VARCHAR(255),
  PRIMARY KEY (`RIT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_TEXT_TYPES` (
  `RTT_ID` DECIMAL(10,2),
  `RTT_RMD_ID` DECIMAL(10,2),
  `RTT_NAME` VARCHAR(255),
  `RTT_DESC` VARCHAR(255),
  PRIMARY KEY (`RTT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_TABLE_TYPES` (
  `RTP_ID` DECIMAL(10,2),
  `RTP_RMD_ID` DECIMAL(10,2),
  `RTP_NAME` VARCHAR(255),
  `RTP_DESC` VARCHAR(255),
  PRIMARY KEY (`RTP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_REPORTS` (
  `RRE_ID` DECIMAL(10,2),
  `RRE_RMD_ID` DECIMAL(10,2),
  `RRE_REF_ID` VARCHAR(255),
  `RRE_START` DATETIME,
  `RRE_END` DATETIME,
  `RRE_FILENAME` VARCHAR(255),
  `RRE_BINARY` VARCHAR(255),
  `RRE_ERROR` VARCHAR(255),
  PRIMARY KEY (`RRE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_IMAGES` (
  `RIM_ID` DECIMAL(10,2),
  `RIM_RRE_ID` DECIMAL(10,2),
  `RIM_RIT_ID` DECIMAL(10,2),
  `RIM_VALUE` VARCHAR(255),
  PRIMARY KEY (`RIM_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_TEXTS` (
  `RTE_ID` DECIMAL(10,2),
  `RTE_RRE_ID` DECIMAL(10,2),
  `RTE_RTT_ID` DECIMAL(10,2),
  `RTE_VALUE` VARCHAR(255),
  PRIMARY KEY (`RTE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `RG_TABLES` (
  `RTB_ID` DECIMAL(10,2),
  `RTB_RRE_ID` DECIMAL(10,2),
  `RTB_RTP_ID` DECIMAL(10,2),
  `RTB_CELL0` VARCHAR(255),
  `RTB_CELL1` VARCHAR(255),
  `RTB_CELL2` VARCHAR(255),
  `RTB_CELL3` VARCHAR(255),
  `RTB_CELL4` VARCHAR(255),
  `RTB_CELL5` VARCHAR(255),
  `RTB_CELL6` VARCHAR(255),
  `RTB_CELL7` VARCHAR(255),
  `RTB_CELL8` VARCHAR(255),
  `RTB_CELL9` VARCHAR(255),
  `RTB_CELL10` VARCHAR(255),
  `RTB_CELL11` VARCHAR(255),
  `RTB_CELL12` VARCHAR(255),
  `RTB_CELL13` VARCHAR(255),
  `RTB_CELL14` VARCHAR(255),
  `RTB_CELL15` VARCHAR(255),
  `RTB_CELL16` VARCHAR(255),
  `RTB_CELL17` VARCHAR(255),
  `RTB_CELL18` VARCHAR(255),
  `RTB_CELL19` VARCHAR(255),
  `RTB_CELL20` VARCHAR(255),
  `RTB_CELL21` VARCHAR(255),
  `RTB_CELL22` VARCHAR(255),
  `RTB_CELL23` VARCHAR(255),
  `RTB_CELL24` VARCHAR(255),
  `RTB_CELL25` VARCHAR(255),
  `RTB_CELL26` VARCHAR(255),
  `RTB_CELL27` VARCHAR(255),
  `RTB_CELL28` VARCHAR(255),
  `RTB_CELL29` VARCHAR(255),
  PRIMARY KEY (`RTB_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033854_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033854_schema') AS relationships;
DROP DATABASE `db_033854_schema`;
UNINSTALL EXTENSION vsql_schematron;
