INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037268_001_tablas.up
--echo #
CREATE DATABASE `db_037268_001_tablas_up`;
USE `db_037268_001_tablas_up`;
CREATE TABLE `empresas` (
  `id` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `rnc` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `empleados` (
  `id` VARCHAR(50) NOT NULL,
  `id_empresa` VARCHAR(50),
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `fecha_de_contratacion` TIMESTAMP NULL,
  `salario_mensual` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037268_001_tablas_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037268_001_tablas_up') AS relationships;
DROP DATABASE `db_037268_001_tablas_up`;
UNINSTALL EXTENSION vsql_schematron;
