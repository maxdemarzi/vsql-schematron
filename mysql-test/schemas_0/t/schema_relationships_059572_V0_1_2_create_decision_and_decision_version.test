INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 059572_V0.1.2__create_decision_and_decision_version
--echo #
CREATE DATABASE `db_059572_V0_1_2_create_decision_and_decision_version`;
USE `db_059572_V0_1_2_create_decision_and_decision_version`;

CREATE TABLE `DECISION` (
  `id` VARCHAR(64),
  `customer_id` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `lock_version` INT,
  `current_version_id` VARCHAR(64),
  `next_version_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `DECISION_VERSION` (
  `id` VARCHAR(64),
  `version` INT,
  `submitted_at` DATETIME,
  `published_at` DATETIME,
  `dmn_location` VARCHAR(64),
  `dmn_md5` VARCHAR(64),
  `kafka_source_topic` VARCHAR(64),
  `kafka_sink_topic` VARCHAR(64),
  `status` VARCHAR(64),
  `status_message` VARCHAR(64),
  `ccp_namespace` VARCHAR(64),
  `ccp_name` VARCHAR(64),
  `ccp_version_name` VARCHAR(64),
  `ccp_exposed_url` VARCHAR(64),
  `decision_id` VARCHAR(64),
  `lock_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `DECISION_VERSION_TAG` (
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `decision_version_id` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `DECISION_VERSION_CONFIG` (
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `decision_version_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_059572_V0_1_2_create_decision_and_decision_version') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_059572_V0_1_2_create_decision_and_decision_version') AS relationships;
DROP DATABASE `db_059572_V0_1_2_create_decision_and_decision_version`;
UNINSTALL EXTENSION vsql_schematron;
