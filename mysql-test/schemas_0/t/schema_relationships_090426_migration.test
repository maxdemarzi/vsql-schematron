INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 090426_migration
--echo #
CREATE DATABASE `db_090426_migration`;
USE `db_090426_migration`;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Event` (
  `title` TEXT,
  `time` TIMESTAMP NULL,
  `description` TEXT,
  `id` INT NOT NULL,
  `color_tag` VARCHAR(50),
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_090426_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_090426_migration') AS relationships;
DROP DATABASE `db_090426_migration`;
UNINSTALL EXTENSION vsql_schematron;
