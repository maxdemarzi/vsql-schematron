INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025653_create_db
--echo #
CREATE DATABASE `db_025653_create_db`;
USE `db_025653_create_db`;

CREATE TABLE `javathon.javathon_schema.user` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `phone_number` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `javathon.javathon_schema.hachaton` (
  `id` INT,
  `name` VARCHAR(255),
  `start_time` DATETIME,
  `end_time` DATETIME,
  `participants_limit` INT,
  `host` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `javathon.javathon_schema.PARTICIPANT` (
  `id` INT,
  `team_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `javathon_schema.history` (
  `id` INT,
  `key` VARCHAR(255),
  `value` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025653_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025653_create_db') AS relationships;
DROP DATABASE `db_025653_create_db`;
UNINSTALL EXTENSION vsql_schematron;
