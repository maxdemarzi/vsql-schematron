INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068365_computech_bk
--echo #
CREATE DATABASE `db_068365_computech_bk`;
USE `db_068365_computech_bk`;
CREATE TABLE `tbusuarios` (
  `iduser` INT NOT NULL,
  `usuario` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `perfil` VARCHAR(50),
  PRIMARY KEY (`iduser`)
) CHARACTER SET latin1;
CREATE TABLE `tbcliente` (
  `idcli` INT NOT NULL,
  `nomecli` VARCHAR(50),
  `cep` VARCHAR(50),
  `logradouro` VARCHAR(50),
  `numero` VARCHAR(50),
  `complemento` VARCHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `uf` CHAR(50),
  `rg` VARCHAR(50),
  `cpf` VARCHAR(50),
  `fonecli` VARCHAR(50),
  `fonecli2` VARCHAR(50),
  `emailcli` VARCHAR(50),
  `obs` VARCHAR(50),
  PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
  `os` INT NOT NULL,
  `dataOs` TIMESTAMP NULL,
  `tipoOs` VARCHAR(50),
  `statusOs` VARCHAR(50),
  `tecnico` VARCHAR(50),
  `modelo` VARCHAR(50),
  `marca` VARCHAR(50),
  `serialNumber` VARCHAR(50),
  `senha` VARCHAR(50),
  `acessorios` VARCHAR(50),
  `defeitoCli` VARCHAR(50),
  `diagnostico` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `sinal` DECIMAL(10,2),
  `dataPrevista` DATE,
  `dataRetirada` DATE,
  `formPag` VARCHAR(50),
  `garantiaData` DATE,
  `idcli` INT,
  PRIMARY KEY (`os`)
) CHARACTER SET latin1;
CREATE TABLE `tbTecnicos` (
  `idtec` INT NOT NULL,
  `nomeTec` VARCHAR(50),
  PRIMARY KEY (`idtec`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068365_computech_bk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068365_computech_bk') AS relationships;
DROP DATABASE `db_068365_computech_bk`;
UNINSTALL EXTENSION vsql_schematron;
