INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 021004_dbcreation
--echo #
CREATE DATABASE `db_021004_dbcreation`;
USE `db_021004_dbcreation`;
CREATE TABLE `Project` (
  `ProjectID` SMALLINT NOT NULL,
  `ProjectName` VARCHAR(50),
  PRIMARY KEY (`ProjectID`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
  `EmployeeID` SMALLINT NOT NULL,
  `ProjectID` SMALLINT,
  `Fname` VARCHAR(50),
  `Lname` VARCHAR(50),
  `City` VARCHAR(50),
  `Postcode` VARCHAR(50),
  `StreetAddress` VARCHAR(50),
  `SortCode` CHAR(50),
  `BAN` CHAR(50),
  `Salary` INT,
  `NIN` CHAR(50),
  `Department` CHAR(50),
  PRIMARY KEY (`EmployeeID`)
) CHARACTER SET latin1;
CREATE TABLE `SalesEmployee` (
  `EmployeeID` SMALLINT,
  `CommissionRate` DECIMAL(10,2),
  `TotalSales` INT
) CHARACTER SET latin1;
CREATE TABLE `TechnicalEmployee` (
  `EmployeeID` SMALLINT,
  `CV` VARCHAR(50),
  `Image` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_021004_dbcreation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_021004_dbcreation') AS relationships;
DROP DATABASE `db_021004_dbcreation`;
UNINSTALL EXTENSION vsql_schematron;
