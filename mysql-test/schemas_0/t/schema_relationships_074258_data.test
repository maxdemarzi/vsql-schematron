INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 074258_data
--echo #
CREATE DATABASE `db_074258_data`;
USE `db_074258_data`;
CREATE TABLE `taxonomies` (
  `taxonomy_id` INT NOT NULL,
  `taxonomy_common_name` VARCHAR(50),
  `taxonomy_scientific_name` VARCHAR(50),
  PRIMARY KEY (`taxonomy_id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
  `project_id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `source_type` VARCHAR(50),
  `study_type` VARCHAR(50),
  `eva_center_name` VARCHAR(50),
  `center_name` VARCHAR(50),
  `taxonomy_id` INT,
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_074258_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_074258_data') AS relationships;
DROP DATABASE `db_074258_data`;
UNINSTALL EXTENSION vsql_schematron;
