INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 012777_affiliation_db_v1
--echo #
CREATE DATABASE `db_012777_affiliation_db_v1`;
USE `db_012777_affiliation_db_v1`;

CREATE TABLE `meta` (
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`key`)
) CHARACTER SET latin1;

CREATE TABLE `eq_classes` (
  `id` INT,
  `last_update_time` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eq_class_members` (
  `id` INT,
  `facet_uri` VARCHAR(64),
  `set_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_012777_affiliation_db_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_012777_affiliation_db_v1') AS relationships;
DROP DATABASE `db_012777_affiliation_db_v1`;
UNINSTALL EXTENSION vsql_schematron;
