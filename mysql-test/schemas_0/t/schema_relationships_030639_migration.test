INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 030639_migration
--echo #
CREATE DATABASE `db_030639_migration`;
USE `db_030639_migration`;
CREATE TABLE `GroceryItem` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `quantitycount` INT,
  `quantityunit` VARCHAR(50),
  `category` VARCHAR(50),
  `recipeId` INT,
  `nutrition` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Recipe` (
  `id` INT NOT NULL,
  `name` TEXT,
  `servings` INT,
  `link` TEXT,
  `nutrition` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_030639_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_030639_migration') AS relationships;
DROP DATABASE `db_030639_migration`;
UNINSTALL EXTENSION vsql_schematron;
