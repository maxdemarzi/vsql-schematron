INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 059669_migration
--echo #
CREATE DATABASE `db_059669_migration`;
USE `db_059669_migration`;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `passwordResetToken` VARCHAR(64),
  `passwordResetIssuedAt` DATETIME,
  `passwordResetRedeemedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Product` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `photo` INT,
  `status` VARCHAR(64),
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ProductImage` (
  `id` INT,
  `image` VARCHAR(64),
  `altText` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CartItem` (
  `id` INT,
  `quantity` INT,
  `product` INT,
  `user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `OrderItem` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `photo` INT,
  `price` INT,
  `quantity` INT,
  `order` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `id` INT,
  `total` INT,
  `user` INT,
  `charge` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_059669_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_059669_migration') AS relationships;
DROP DATABASE `db_059669_migration`;
UNINSTALL EXTENSION vsql_schematron;
