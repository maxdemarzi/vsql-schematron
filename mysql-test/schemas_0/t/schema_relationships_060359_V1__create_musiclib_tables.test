INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060359_V1__create_musiclib_tables
--echo #
CREATE DATABASE `db_060359_V1__create_musiclib_tables`;
USE `db_060359_V1__create_musiclib_tables`;
CREATE TABLE `artists` (
  `id` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `albums` (
  `id` VARCHAR(50) NOT NULL,
  `name` CHAR(50),
  `release_date` DATE,
  `artist_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060359_V1__create_musiclib_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060359_V1__create_musiclib_tables') AS relationships;
DROP DATABASE `db_060359_V1__create_musiclib_tables`;
UNINSTALL EXTENSION vsql_schematron;
