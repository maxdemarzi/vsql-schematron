INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081930_20180606152700
--echo #
CREATE DATABASE `db_081930_20180606152700`;
USE `db_081930_20180606152700`;
CREATE TABLE `serviceaccess` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `appKey` CHAR(50),
  `appSecret` CHAR(50),
  `description` VARCHAR(50),
  `active` VARCHAR(50),
  `updated` DATETIME,
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `serviceaccessvalues` (
  `id` VARCHAR(50) NOT NULL,
  `serviceaccessid` VARCHAR(50),
  `name` VARCHAR(50),
  `content` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081930_20180606152700') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081930_20180606152700') AS relationships;
DROP DATABASE `db_081930_20180606152700`;
UNINSTALL EXTENSION vsql_schematron;
