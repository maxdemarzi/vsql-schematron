INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058690_schema
--echo #
CREATE DATABASE `db_058690_schema`;
USE `db_058690_schema`;

CREATE TABLE `Ingredient` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Taco_Ingredients` (
  `taco_id` INT,
  `ingredients_id` VARCHAR(64),
  PRIMARY KEY (`taco_id`, `ingredients_id`)
) CHARACTER SET latin1;

CREATE TABLE `Taco_Order_Tacos` (
  `taco_order_id` INT,
  `taco_id` INT,
  PRIMARY KEY (`taco_order_id`, `taco_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058690_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058690_schema') AS relationships;
DROP DATABASE `db_058690_schema`;
UNINSTALL EXTENSION vsql_schematron;
