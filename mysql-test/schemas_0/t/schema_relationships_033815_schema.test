INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033815_schema
--echo #
CREATE DATABASE `db_033815_schema`;
USE `db_033815_schema`;

CREATE TABLE `lesson_types` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teacher_positions` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `groups_table` (
  `id` INT,
  `name` VARCHAR(64),
  `students_number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `id` INT,
  `name` VARCHAR(64),
  `hours_number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `id` INT,
  `name` VARCHAR(64),
  `course` INT,
  `phone_number` VARCHAR(64),
  `email` VARCHAR(64),
  `group_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `id` INT,
  `name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `position` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lessons` (
  `uuid` INT,
  `subject_id` INT,
  `teacher_id` INT,
  `lesson_type` INT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `progress` (
  `uuid` INT,
  `student_id` INT,
  `subject_id` INT,
  `grade` INT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033815_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033815_schema') AS relationships;
DROP DATABASE `db_033815_schema`;
UNINSTALL EXTENSION vsql_schematron;
