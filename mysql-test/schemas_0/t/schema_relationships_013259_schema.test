INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013259_schema
--echo #
CREATE DATABASE `db_013259_schema`;
USE `db_013259_schema`;
CREATE TABLE `owners` (
  `id` VARCHAR(50) NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` VARCHAR(50),
  `city` VARCHAR(50),
  `telephone` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rewardpoints` (
  `id` VARCHAR(50) NOT NULL,
  `owner_id` VARCHAR(50),
  `points` INT,
  `rewardpoint_date` DATE,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013259_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013259_schema') AS relationships;
DROP DATABASE `db_013259_schema`;
UNINSTALL EXTENSION vsql_schematron;
