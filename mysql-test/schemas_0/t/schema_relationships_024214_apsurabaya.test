INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 024214_apsurabaya
--echo #
CREATE DATABASE `db_024214_apsurabaya`;
USE `db_024214_apsurabaya`;

CREATE TABLE `email_template` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `content` VARCHAR(64),
  `name` VARCHAR(64),
  `subject` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `example` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `status_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `folder` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `folder_id` INT,
  `resource` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `form` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `table_name` VARCHAR(64),
  `read` INT,
  `edit` INT,
  `add` INT,
  `delete` INT,
  `pagination` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `form_field` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `browse` INT,
  `read` INT,
  `edit` INT,
  `add` INT,
  `relation_table` VARCHAR(64),
  `relation_column` VARCHAR(64),
  `form_id` INT,
  `column_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `kategori` (
  `id` INT,
  `nama` VARCHAR(64),
  `kategori` VARCHAR(64),
  `prioritas` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menulist` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `name` VARCHAR(64),
  `href` VARCHAR(64),
  `icon` VARCHAR(64),
  `slug` VARCHAR(64),
  `parent_id` INT,
  `menu_id` INT,
  `sequence` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_role` (
  `id` INT,
  `role_name` VARCHAR(64),
  `menus_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_has_permissions` (
  `permission_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `model_has_roles` (
  `role_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `note_type` VARCHAR(64),
  `applies_to_date` DATETIME,
  `users_id` INT,
  `status_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_has_permissions` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `role_hierarchy` (
  `id` INT,
  `role_id` INT,
  `hierarchy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `status` (
  `id` INT,
  `name` VARCHAR(64),
  `class` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `menuroles` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_024214_apsurabaya') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_024214_apsurabaya') AS relationships;
DROP DATABASE `db_024214_apsurabaya`;
UNINSTALL EXTENSION vsql_schematron;
