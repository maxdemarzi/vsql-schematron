INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054147_CreateTables
--echo #
CREATE DATABASE `db_054147_CreateTables`;
USE `db_054147_CreateTables`;
CREATE TABLE `Customers` (
  `customerNumber` INT,
  `customerName` VARCHAR(50),
  `contactLastName` VARCHAR(50),
  `contactFirstName` VARCHAR(50),
  `phone` VARCHAR(50),
  `addressLine1` VARCHAR(50),
  `addressLine2` VARCHAR(50),
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `postalCode` VARCHAR(50),
  `country` VARCHAR(50),
  `salesRepEmployeeNumber` INT,
  `creditLimit` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `Employees` (
  `employeeNumber` INT,
  `lastName` VARCHAR(50),
  `firstName` VARCHAR(50),
  `extension` VARCHAR(50),
  `email` VARCHAR(50),
  `officeCode` VARCHAR(50),
  `reportsTo` INT,
  `jobTitle` VARCHAR(50),
  `salary` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `Offices` (
  `officeCode` VARCHAR(50),
  `city` VARCHAR(50),
  `phone` VARCHAR(50),
  `addressLine1` VARCHAR(50),
  `addressLine2` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50),
  `postalCode` VARCHAR(50),
  `territory` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
  `studentNumber` INT,
  `name` VARCHAR(50),
  `phone` VARCHAR(50),
  `state` VARCHAR(50),
  `country` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Products` (
  `productCode` VARCHAR(50),
  `productName` VARCHAR(50),
  `productLine` VARCHAR(50),
  `productScale` VARCHAR(50),
  `productVendor` VARCHAR(50),
  `productDescription` VARCHAR(50),
  `quantityInStock` INT,
  `buyPrice` DOUBLE,
  `MSRP` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `ProductLines` (
  `productLine` VARCHAR(50),
  `textDescription` VARCHAR(50),
  `htmlDescription` VARCHAR(50),
  `image` BLOB
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `orderNumber` INT,
  `orderDate` DATE,
  `requiredDate` DATE,
  `shippedDate` DATE,
  `status` VARCHAR(50),
  `comments` VARCHAR(50),
  `customerNumber` INT
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
  `orderNumber` INT,
  `productCode` VARCHAR(50),
  `quantityOrdered` INT,
  `priceEach` DOUBLE,
  `orderLineNumber` SMALLINT
) CHARACTER SET latin1;
CREATE TABLE `Payments` (
  `customerNumber` INT,
  `checkNumber` VARCHAR(50),
  `paymentDate` DATE,
  `amount` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `department` (
  `id` INT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Files` (
  `fileName` VARCHAR(50) NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`fileName`)
) CHARACTER SET latin1;
CREATE TABLE `FileRecords` (
  `fileRecordId` INT NOT NULL,
  `data` BLOB,
  `fileName` VARCHAR(50),
  PRIMARY KEY (`fileRecordId`)
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
  `accountId` INT NOT NULL,
  `balance` DOUBLE,
  PRIMARY KEY (`accountId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054147_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054147_CreateTables') AS relationships;
DROP DATABASE `db_054147_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
