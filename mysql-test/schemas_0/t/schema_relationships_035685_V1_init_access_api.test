INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035685_V1_init_access_api
--echo #
CREATE DATABASE `db_035685_V1_init_access_api`;
USE `db_035685_V1_init_access_api`;

CREATE TABLE `user` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `ENABLED` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `PASSWORD` VARCHAR(255),
  `SALT` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `application` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `ENABLED` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `APP_ID` VARCHAR(255),
  `API_KEY` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `issuer` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `UUID` VARCHAR(255),
  `ENABLED` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `PUBLIC_KEY_BASE64` VARCHAR(255),
  `PRIVATE_KEY_BASE64` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `device` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `ENABLED` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `PUBLIC_KEY_BASE64` VARCHAR(255),
  `SERIAL_NUMBER` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `vehicle` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `ENABLED` INT,
  `NAME` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `PUBLIC_KEY_BASE64` VARCHAR(255),
  `SERIAL_NUMBER` VARCHAR(255),
  `ISSUER_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `application_vehicle` (
  `CREATED_AT` DATETIME,
  `APPLICATION_ID` INT,
  `VEHICLE_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `device_certificate` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `UUID` VARCHAR(255),
  `DEVICE_ID` INT,
  `ISSUER_ID` INT,
  `APPLICATION_ID` INT,
  `SIGNED_CERTIFICATE_BASE64` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `access_certificate` (
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  `ID` INT,
  `UUID` VARCHAR(255),
  `VALID_FROM` DATETIME,
  `VALID_UNTIL` DATETIME,
  `ISSUER_ID` INT,
  `APPLICATION_ID` INT,
  `VEHICLE_ID` INT,
  `DEVICE_ID` INT,
  `DEVICE_ACCESS_CERTIFICATE_BASE64` VARCHAR(255),
  `DEVICE_ACCESS_CERTIFICATE_SIGNATURE_BASE64` VARCHAR(255),
  `SIGNED_DEVICE_ACCESS_CERTIFICATE_BASE64` VARCHAR(255),
  `VEHICLE_ACCESS_CERTIFICATE_BASE64` VARCHAR(255),
  `VEHICLE_ACCESS_CERTIFICATE_SIGNATURE_BASE64` VARCHAR(255),
  `SIGNED_VEHICLE_ACCESS_CERTIFICATE_BASE64` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035685_V1_init_access_api') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035685_V1_init_access_api') AS relationships;
DROP DATABASE `db_035685_V1_init_access_api`;
UNINSTALL EXTENSION vsql_schematron;
