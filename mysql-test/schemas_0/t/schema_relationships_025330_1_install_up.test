INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025330_1_install.up
--echo #
CREATE DATABASE `db_025330_1_install_up`;
USE `db_025330_1_install_up`;

CREATE TABLE `carts` (
  `id` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart_products` (
  `cart_id` INT,
  `product_id` INT,
  `quantity` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`cart_id`, `product_id`)
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `cart_id` INT,
  `address` VARCHAR(64),
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025330_1_install_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025330_1_install_up') AS relationships;
DROP DATABASE `db_025330_1_install_up`;
UNINSTALL EXTENSION vsql_schematron;
