INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005868_movies-create
--echo #
CREATE DATABASE `db_005868_movies_create`;
USE `db_005868_movies_create`;
CREATE TABLE `movie_category` (
  `category_code` VARCHAR(50) NOT NULL,
  `category_name` VARCHAR(50),
  PRIMARY KEY (`category_code`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
  `client_num` VARCHAR(50) NOT NULL,
  `client_lname` VARCHAR(50),
  `client_fname` VARCHAR(50),
  `client_phone` CHAR(50),
  `client_credit_rtg` DECIMAL(10,2),
  `client_fave_cat` CHAR(50),
  PRIMARY KEY (`client_num`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005868_movies_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005868_movies_create') AS relationships;
DROP DATABASE `db_005868_movies_create`;
UNINSTALL EXTENSION vsql_schematron;
