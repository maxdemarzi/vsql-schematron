INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077234_requests
--echo #
CREATE DATABASE `db_077234_requests`;
USE `db_077234_requests`;

CREATE TABLE `additional_charges` (
  `option` INT,
  `daily_situation_choice` INT,
  `charge` DECIMAL(10,2),
  PRIMARY KEY (`option`, `daily_situation_choice`)
) CHARACTER SET latin1;

CREATE TABLE `choices` (
  `id` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `daily_situation_choices` (
  `id` INT,
  `daily_situation` INT,
  `choice` INT,
  `concludes` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `daily_situations` (
  `id` INT,
  `day` INT,
  `event` INT,
  `locked` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `financial_choice_costs` (
  `financial_situation` INT,
  `daily_situation_choice` INT,
  `min_cost` DECIMAL(10,2),
  `max_cost` DECIMAL(10,2),
  PRIMARY KEY (`financial_situation`, `daily_situation_choice`)
) CHARACTER SET latin1;

CREATE TABLE `financial_daily_situations` (
  `financial_situation` INT,
  `daily_situation` INT,
  PRIMARY KEY (`financial_situation`, `daily_situation`)
) CHARACTER SET latin1;

CREATE TABLE `financial_situations` (
  `id` INT,
  `label` VARCHAR(64),
  `budget` DECIMAL(10,2),
  `family_situation` INT,
  `professional_situation` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `glossary` (
  `id` INT,
  `label` VARCHAR(64),
  `definition` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `option_daily_situations` (
  `option` INT,
  `daily_situation` INT,
  PRIMARY KEY (`option`, `daily_situation`)
) CHARACTER SET latin1;

CREATE TABLE `option_groups` (
  `id` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `options` (
  `id` INT,
  `option_group` INT,
  `label` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `unlock_daily_situations` (
  `daily_situation` INT,
  `daily_situation_choice` INT,
  PRIMARY KEY (`daily_situation`, `daily_situation_choice`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077234_requests') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077234_requests') AS relationships;
DROP DATABASE `db_077234_requests`;
UNINSTALL EXTENSION vsql_schematron;
