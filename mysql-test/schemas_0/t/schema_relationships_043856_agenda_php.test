INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 043856_agenda_php
--echo #
CREATE DATABASE `db_043856_agenda_php`;
USE `db_043856_agenda_php`;
CREATE TABLE `agenda` (
  `id` INT,
  `nombre` VARCHAR(50),
  `telefono` VARCHAR(50),
  `correo` VARCHAR(50),
  `usuario_id` INT,
  `editado` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
  `id` INT,
  `token` VARCHAR(50),
  `fecha` VARCHAR(50),
  `activo` INT,
  `usuario_id` INT
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id` INT,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_043856_agenda_php') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_043856_agenda_php') AS relationships;
DROP DATABASE `db_043856_agenda_php`;
UNINSTALL EXTENSION vsql_schematron;
