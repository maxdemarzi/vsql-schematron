INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 052050_db_definition
--echo #
CREATE DATABASE `db_052050_db_definition`;
USE `db_052050_db_definition`;

CREATE TABLE `StateTerritory` (
  `stateID` INT,
  `stateName` VARCHAR(64),
  `stateAbbrev` VARCHAR(64),
  `activeFlag` INT,
  PRIMARY KEY (`stateID`)
) CHARACTER SET latin1;

CREATE TABLE `Location` (
  `locationID` INT,
  `locationName` VARCHAR(64),
  `stateID` INT,
  `postcodeNumber` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `activeFlag` INT,
  PRIMARY KEY (`locationID`)
) CHARACTER SET latin1;

CREATE TABLE `OtherLanguages` (
  `languageID` INT,
