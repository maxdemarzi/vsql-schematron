) CHARACTER SET latin1;

CREATE TABLE `SupportWorkerOther` (
  `supportWorkerID` INT,
  `otherPersonality` VARCHAR(64),
  `otherHobbies` VARCHAR(64),
  `otherGaming` VARCHAR(64),
  `otherPets` VARCHAR(64),
  `otherAllergies` VARCHAR(64),
  `otherFears` VARCHAR(64),
  `otherTechnology` VARCHAR(64),
  `otherQualifications` VARCHAR(64),
  `otherExperienceAreas` VARCHAR(64),
  `otherAvailability` VARCHAR(64),
  `otherGeneral` VARCHAR(64),
  `activeFlag` INT,
  PRIMARY KEY (`supportWorkerID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_052050_db_definition') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_052050_db_definition') AS relationships;
DROP DATABASE `db_052050_db_definition`;
UNINSTALL EXTENSION vsql_schematron;
