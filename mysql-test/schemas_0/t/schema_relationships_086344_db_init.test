INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086344_db_init
--echo #
CREATE DATABASE `db_086344_db_init`;
USE `db_086344_db_init`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `salt` VARCHAR(64),
  `hash` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `role` VARCHAR(64),
  `valid` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `id` VARCHAR(64),
  `tid` VARCHAR(64),
  `group` INT,
  `research_opt` INT,
  `f6e_opt` INT,
  `f6e_token` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `uid` VARCHAR(64),
  `tid` VARCHAR(64),
  `token` VARCHAR(64),
  `expires` DATETIME,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `trials` (
  `tid` VARCHAR(64),
  `uid` VARCHAR(64),
  `title` VARCHAR(64),
  `regopen` DATETIME,
  `regclose` DATETIME,
  `trialstart` DATETIME,
  `trialend` DATETIME,
  `trialtype` VARCHAR(64),
  `timezone` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`tid`)
) CHARACTER SET latin1;

CREATE TABLE `groups` (
  `tid` VARCHAR(64),
  `gid` INT,
  `name` VARCHAR(64),
  `size` VARCHAR(64),
  `size_n` INT,
  PRIMARY KEY (`tid`, `gid`)
) CHARACTER SET latin1;

CREATE TABLE `surveys` (
  `tid` VARCHAR(64),
  `sid` INT,
  `name` VARCHAR(64),
  `time` INT,
  `intro` VARCHAR(64),
  `groups` VARCHAR(64),
  `pre` BOOL,
  `during` BOOL,
  `post` BOOL,
  `interval` INT,
  `frequency` VARCHAR(64),
  PRIMARY KEY (`tid`, `sid`)
) CHARACTER SET latin1;

CREATE TABLE `questions` (
  `tid` VARCHAR(64),
  `sid` INT,
  `qid` INT,
  `text` VARCHAR(64),
  `type` VARCHAR(64),
  `options` VARCHAR(64),
  PRIMARY KEY (`tid`, `sid`, `qid`)
) CHARACTER SET latin1;

CREATE TABLE `answers` (
  `tid` VARCHAR(64),
  `sid` INT,
  `qid` INT,
  `uid` VARCHAR(64),
  `text` VARCHAR(64),
  `timestamp` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `f6e_logs` (
  `timestamp` DATETIME,
  `uid` VARCHAR(64),
  `group` INT,
  `tid` VARCHAR(64),
  `sid` INT,
  `last_answer` DATETIME,
  `f6e_response` VARCHAR(64),
  PRIMARY KEY (`timestamp`, `uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086344_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086344_db_init') AS relationships;
DROP DATABASE `db_086344_db_init`;
UNINSTALL EXTENSION vsql_schematron;
