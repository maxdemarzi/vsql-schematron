INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025551_8
--echo #
CREATE DATABASE `db_025551_8`;
USE `db_025551_8`;

CREATE TABLE `USERS` (
  `ID` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `FIRSTNAME` VARCHAR(64),
  `LASTNAME` VARCHAR(64),
  `ROLE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EVENTS` (
  `ID` VARCHAR(64),
  `REPORT_ID` VARCHAR(64),
  `USER_ID` VARCHAR(64),
  `CREATION_DATE` DATETIME,
  `EVENT_TYPE` VARCHAR(64),
  `ACTION` VARCHAR(64),
  `RESULT_ACTION` VARCHAR(64),
  `DETAIL` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025551_8') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025551_8') AS relationships;
DROP DATABASE `db_025551_8`;
UNINSTALL EXTENSION vsql_schematron;
