INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025648_schema-mysql
--echo #
CREATE DATABASE `db_025648_schema_mysql`;
USE `db_025648_schema_mysql`;
CREATE TABLE `bael_users` (
  `name` VARCHAR(50),
  `email` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  `enabled` TINYINT,
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
  `email` VARCHAR(50),
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025648_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025648_schema_mysql') AS relationships;
DROP DATABASE `db_025648_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
