INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013343_V_46__create_prt
--echo #
CREATE DATABASE `db_013343_V_46_create_prt`;
USE `db_013343_V_46_create_prt`;

CREATE TABLE `prt_schema_version` (
  `version_key` VARCHAR(64),
  `version_value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `prt_node` (
  `id` INT,
  `oid` INT,
  `portfolio_id` INT,
  `portfolio_oid` INT,
  `parent_node_id` INT,
  `parent_node_oid` INT,
  `depth` INT,
  `tree_left` INT,
  `tree_right` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `prt_position` (
  `node_id` INT,
  `key_scheme` VARCHAR(64),
  `key_value` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013343_V_46_create_prt') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013343_V_46_create_prt') AS relationships;
DROP DATABASE `db_013343_V_46_create_prt`;
UNINSTALL EXTENSION vsql_schematron;
