INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020876_SPJNAS
--echo #
CREATE DATABASE `db_020876_SPJNAS`;
USE `db_020876_SPJNAS`;

CREATE TABLE `Users` (
  `U_ID` INT,
  `Title` VARCHAR(64),
  `First_Name` VARCHAR(64),
  `Other_Name` VARCHAR(64),
  `Last_Name` VARCHAR(64),
  `Degree` VARCHAR(64),
  `Password` VARCHAR(64),
  `Email` VARCHAR(64),
  `Date_Create` DATETIME,
  `Area_of_Speciality` VARCHAR(64),
  `Access_level` VARCHAR(64),
  `Phone_Number` VARCHAR(64),
  `Account_Active` BOOL,
  PRIMARY KEY (`U_ID`)
) CHARACTER SET latin1;

CREATE TABLE `LOG_FILE` (
  `ID` INT,
  `U_ID` INT,
  `Date_login` DATETIME,
  `Date_logout` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Manuscript` (
  `ID` INT,
  `ArticleType` VARCHAR(64),
  `Title` VARCHAR(64),
  `Abstract` VARCHAR(64),
  `KeyWords` VARCHAR(64),
  `Classifications` VARCHAR(64),
  `Highlights` VARCHAR(64),
  `Manuscript` VARCHAR(64),
  `Cover_Letter` VARCHAR(64),
  `Date_Upload` DATETIME,
  `Submit` BOOL,
  `Review_Process` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ManuscriptAuthor` (
  `ID` INT,
  `U_ID` INT,
  PRIMARY KEY (`ID`, `U_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Suggested_Reviewer` (
  `S_ID` INT,
  `ID` INT,
  `Title` VARCHAR(64),
  `First_Name` VARCHAR(64),
  `Other_Name` VARCHAR(64),
  `Last_Name` VARCHAR(64),
  `Degree` VARCHAR(64),
  `Email` VARCHAR(64),
  `Reason` VARCHAR(64),
  PRIMARY KEY (`S_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Response` (
  `R_ID` INT,
  `ID` INT,
  `U_ID` INT,
  `Decision` VARCHAR(64),
  `Comments` VARCHAR(64),
  `Originality` VARCHAR(64),
  `Justify` VARCHAR(64),
  `Credit` VARCHAR(64),
  `STitle` VARCHAR(64),
  `Clear_Text` VARCHAR(64),
  `Shorten` VARCHAR(64),
  `References_C` VARCHAR(64),
  `Illustrations` VARCHAR(64),
  `Figures` VARCHAR(64),
  `Review_Done` BOOL,
  PRIMARY KEY (`R_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Editor_Response` (
  `E_ID` INT,
  `ID` INT,
  `U_ID` INT,
  `Decision` VARCHAR(64),
  `Comments` VARCHAR(64),
  PRIMARY KEY (`E_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020876_SPJNAS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020876_SPJNAS') AS relationships;
DROP DATABASE `db_020876_SPJNAS`;
UNINSTALL EXTENSION vsql_schematron;
