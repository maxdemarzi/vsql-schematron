INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097456_0-accounts-schema
--echo #
CREATE DATABASE `db_097456_0_accounts_schema`;
USE `db_097456_0_accounts_schema`;

CREATE TABLE `users` (
  `accountid` VARCHAR(64),
  `username` VARCHAR(64),
  `passhash` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `birthday` DATETIME,
  `timezone` VARCHAR(64),
  `address` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `ssn` VARCHAR(64),
  PRIMARY KEY (`accountid`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `username` VARCHAR(64),
  `label` VARCHAR(64),
  `account_num` VARCHAR(64),
  `routing_num` VARCHAR(64),
  `is_external` BOOL
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097456_0_accounts_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097456_0_accounts_schema') AS relationships;
DROP DATABASE `db_097456_0_accounts_schema`;
UNINSTALL EXTENSION vsql_schematron;
