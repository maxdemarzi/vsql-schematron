INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008582_auth-services-schema-mysql
--echo #
CREATE DATABASE `db_008582_auth_services_schema_mysql`;
USE `db_008582_auth_services_schema_mysql`;

CREATE TABLE `user_table` (
  `id` INT,
  `uid` VARCHAR(64),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_table` (
  `id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authority_table` (
  `id` INT,
  `uid` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `username_password_table` (
  `id` INT,
  `user_name` VARCHAR(64),
  `password` VARCHAR(64),
  `uid` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client_id_table` (
  `id` INT,
  `uid` VARCHAR(64),
  `client_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `api_key_table` (
  `id` INT,
  `client_id` VARCHAR(64),
  `api_key` VARCHAR(64),
  `api_key_desc` VARCHAR(64),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008582_auth_services_schema_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008582_auth_services_schema_mysql') AS relationships;
DROP DATABASE `db_008582_auth_services_schema_mysql`;
UNINSTALL EXTENSION vsql_schematron;
