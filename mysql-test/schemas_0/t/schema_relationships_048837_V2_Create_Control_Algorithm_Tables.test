INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048837_V2__Create_Control_Algorithm_Tables
--echo #
CREATE DATABASE `db_048837_V2_Create_Control_Algorithm_Tables`;
USE `db_048837_V2_Create_Control_Algorithm_Tables`;

CREATE TABLE `rule` (
  `id` INT,
  `project_id` VARCHAR(64),
  `control_action_id` INT,
  `controller_id` INT,
  `rule` VARCHAR(64),
  `last_edited` DATETIME,
  `last_editor_displayname` VARCHAR(64),
  `lock_holder_id` VARCHAR(64),
  `lock_holder_displayname` VARCHAR(64),
  `lock_exp_time` DATETIME,
  PRIMARY KEY (`id`, `controller_id`, `project_id`)
) CHARACTER SET latin1;

CREATE TABLE `rule_control_action_link` (
  `rule_id` INT,
  `control_action_id` INT,
  `project_id` VARCHAR(64),
  `controller_id` INT,
  PRIMARY KEY (`rule_id`, `control_action_id`, `project_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048837_V2_Create_Control_Algorithm_Tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048837_V2_Create_Control_Algorithm_Tables') AS relationships;
DROP DATABASE `db_048837_V2_Create_Control_Algorithm_Tables`;
UNINSTALL EXTENSION vsql_schematron;
