INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062570_CodersTrust_DDL
--echo #
CREATE DATABASE `db_062570_CodersTrust_DDL`;
USE `db_062570_CodersTrust_DDL`;
CREATE TABLE `Users` (
  `UserID` INT NOT NULL,
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `Passwords` VARCHAR(50),
  `Birthday` VARCHAR(50),
  `Nationality` VARCHAR(50),
  `Occupation` VARCHAR(50),
  `E_mail` VARCHAR(50),
  PRIMARY KEY (`UserID`)
) CHARACTER SET latin1;
CREATE TABLE `Questions` (
  `QuestionNumber` INT NOT NULL,
  `Question` VARCHAR(50),
  `CategoryNumber` INT,
  `CategoryName` VARCHAR(50),
  PRIMARY KEY (`QuestionNumber`)
) CHARACTER SET latin1;
CREATE TABLE `Area_of_interest` (
  `UserID` INT,
  `Category1` INT,
  `Category2` INT,
  `Category3` INT,
  `ShowsNo` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062570_CodersTrust_DDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062570_CodersTrust_DDL') AS relationships;
DROP DATABASE `db_062570_CodersTrust_DDL`;
UNINSTALL EXTENSION vsql_schematron;
