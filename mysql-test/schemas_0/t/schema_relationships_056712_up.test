INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 056712_up
--echo #
CREATE DATABASE `db_056712_up`;
USE `db_056712_up`;
CREATE TABLE `public.users` (
  `id` VARCHAR(50) NOT NULL,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.tokens` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_056712_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_056712_up') AS relationships;
DROP DATABASE `db_056712_up`;
UNINSTALL EXTENSION vsql_schematron;
