INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051395_create_tables
--echo #
CREATE DATABASE `db_051395_create_tables`;
USE `db_051395_create_tables`;
CREATE TABLE `coupon` (
  `id` INT NOT NULL,
  `code` VARCHAR(50),
  `expiry_date` DATETIME,
  `availability_count` INT,
  `product_id` VARCHAR(50),
  `promo_type` VARCHAR(50),
  `discount_fixed` DECIMAL(10,2),
  `discount_variable` DECIMAL(10,2),
  `valid` BOOLEAN,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
  `id` INT NOT NULL,
  `coupon_id` INT,
  `client_id` INT,
  `status` VARCHAR(50),
  `created_at` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051395_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051395_create_tables') AS relationships;
DROP DATABASE `db_051395_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
