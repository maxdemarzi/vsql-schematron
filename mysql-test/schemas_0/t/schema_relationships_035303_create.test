INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035303_create
--echo #
CREATE DATABASE `db_035303_create`;
USE `db_035303_create`;

CREATE TABLE `Movie` (
  `id` INT,
  `title` VARCHAR(64),
  `year` INT,
  `rating` VARCHAR(64),
  `company` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Actor` (
  `id` INT,
  `last` VARCHAR(64),
  `first` VARCHAR(64),
  `sex` VARCHAR(64),
  `dob` DATETIME,
  `dod` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Director` (
  `id` INT,
  `last` VARCHAR(64),
  `first` VARCHAR(64),
  `dob` DATETIME,
  `dod` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `MovieGenre` (
  `mid` INT,
  `genre` VARCHAR(64),
  PRIMARY KEY (`mid`, `genre`)
) CHARACTER SET latin1;

CREATE TABLE `MovieDirector` (
  `mid` INT,
  `did` INT,
  PRIMARY KEY (`mid`, `did`)
) CHARACTER SET latin1;

CREATE TABLE `MovieActor` (
  `mid` INT,
  `aid` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`mid`, `aid`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `Review` (
  `name` VARCHAR(64),
  `time` DATETIME,
  `mid` INT,
  `rating` INT,
  `comment` VARCHAR(64),
  PRIMARY KEY (`name`, `time`)
) CHARACTER SET latin1;

CREATE TABLE `MaxPersonID` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `MaxMovieID` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035303_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035303_create') AS relationships;
DROP DATABASE `db_035303_create`;
UNINSTALL EXTENSION vsql_schematron;
