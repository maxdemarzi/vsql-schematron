INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002105_initDatabase
--echo #
CREATE DATABASE `db_002105_initDatabase`;
USE `db_002105_initDatabase`;

CREATE TABLE `LANG` (
  `id` INT,
  `code` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WORD` (
  `id` INT,
  `libelle` VARCHAR(255),
  `lang_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ACTION` (
  `id` INT,
  `name` VARCHAR(255),
  `libelle` VARCHAR(255),
  `type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `WORD_ACTION` (
  `id` INT,
  `word_id` INT,
  `action_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `USER` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `name` VARCHAR(255),
  `admin` INT,
  `lang_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002105_initDatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002105_initDatabase') AS relationships;
DROP DATABASE `db_002105_initDatabase`;
UNINSTALL EXTENSION vsql_schematron;
