INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064592_schema
--echo #
CREATE DATABASE `db_064592_schema`;
USE `db_064592_schema`;

CREATE TABLE `locations` (
  `id` INT,
  `search_query` VARCHAR(64),
  `formatted_query` VARCHAR(64),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `weather` (
  `id` INT,
  `location_id` INT,
  `forecast` VARCHAR(64),
  `time` VARCHAR(64),
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `id` INT,
  `search_query` VARCHAR(64),
  `link` VARCHAR(64),
  `name` VARCHAR(64),
  `event_date` VARCHAR(64),
  `summary` VARCHAR(64),
  `location_id` INT,
  `created_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `yelps` (
  `id` INT,
  `name` VARCHAR(64),
  `image_url` VARCHAR(64),
  `price` VARCHAR(64),
  `rating` DECIMAL(10,2),
  `url` VARCHAR(64),
  `created_at` INT,
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` INT,
  `title` VARCHAR(64),
  `overview` VARCHAR(64),
  `average_votes` DECIMAL(10,2),
  `total_votes` INT,
  `image_url` VARCHAR(64),
  `popularity` DECIMAL(10,2),
  `released_on` VARCHAR(64),
  `created_at` INT,
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `trails` (
  `id` INT,
  `trail_url` VARCHAR(64),
  `name` VARCHAR(64),
  `location` VARCHAR(64),
  `length` DECIMAL(10,2),
  `condition_date` VARCHAR(64),
  `condition_time` VARCHAR(64),
  `conditions` VARCHAR(64),
  `stars` DECIMAL(10,2),
  `star_votes` INT,
  `summary` VARCHAR(64),
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064592_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064592_schema') AS relationships;
DROP DATABASE `db_064592_schema`;
UNINSTALL EXTENSION vsql_schematron;
