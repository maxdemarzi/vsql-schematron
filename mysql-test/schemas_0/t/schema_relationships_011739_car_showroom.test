INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011739_car_showroom
--echo #
CREATE DATABASE `db_011739_car_showroom`;
USE `db_011739_car_showroom`;

CREATE TABLE `dealership` (
  `d_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`d_id`)
) CHARACTER SET latin1;

CREATE TABLE `manufacturer` (
  `m_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`m_id`)
) CHARACTER SET latin1;

CREATE TABLE `model` (
  `model` INT,
  `m_id` INT,
  `name` VARCHAR(64),
  `year` VARCHAR(64),
  `basic_spec` VARCHAR(64),
  PRIMARY KEY (`model`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011739_car_showroom') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011739_car_showroom') AS relationships;
DROP DATABASE `db_011739_car_showroom`;
UNINSTALL EXTENSION vsql_schematron;
