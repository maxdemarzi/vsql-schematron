INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060578_sda_book_class
--echo #
CREATE DATABASE `db_060578_sda_book_class`;
USE `db_060578_sda_book_class`;

CREATE TABLE `profiles` (
  `id` INT,
  `username` VARCHAR(64),
  `name` VARCHAR(64),
  `age` INT,
  `birth_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passwords` (
  `id` INT,
  `pass` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060578_sda_book_class') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060578_sda_book_class') AS relationships;
DROP DATABASE `db_060578_sda_book_class`;
UNINSTALL EXTENSION vsql_schematron;
