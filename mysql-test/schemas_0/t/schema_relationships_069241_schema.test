INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069241_schema
--echo #
CREATE DATABASE `db_069241_schema`;
USE `db_069241_schema`;
CREATE TABLE `movie` (
  `title` VARCHAR(50) NOT NULL,
  `release` INT,
  `uri` VARCHAR(50),
  `director` VARCHAR(50),
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
  `review_id` INT NOT NULL,
  `title` VARCHAR(50),
  `ip_address` VARCHAR(50),
  `reviewer` VARCHAR(50),
  `rating` INT,
  `comment` VARCHAR(50),
  `review_date` TIMESTAMP NULL,
  PRIMARY KEY (`review_id`)
) CHARACTER SET latin1;
CREATE TABLE `audit` (
  `row_id` VARCHAR(50) NOT NULL,
  `entity_type` VARCHAR(50),
  `entity_id` VARCHAR(50),
  `event` VARCHAR(50),
  `host_name` VARCHAR(50),
  `create_date` TIMESTAMP NULL,
  PRIMARY KEY (`row_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069241_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069241_schema') AS relationships;
DROP DATABASE `db_069241_schema`;
UNINSTALL EXTENSION vsql_schematron;
