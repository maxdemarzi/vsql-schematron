INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004708_Query_4
--echo #
CREATE DATABASE `db_004708_Query_4`;
USE `db_004708_Query_4`;
CREATE TABLE `Visit` (
  `visit_id` DECIMAL(10,2) NOT NULL,
  `visit_date` DATE,
  `start_time` TIMESTAMP NULL,
  `end_time` TIMESTAMP NULL,
  `patient_id` DECIMAL(10,2),
  PRIMARY KEY (`visit_id`)
) CHARACTER SET latin1;
CREATE TABLE `Bill` (
  `bill_id` DECIMAL(10,2) NOT NULL,
  `total_charged` DECIMAL(10,2),
  `total_paid_patient` DECIMAL(10,2),
  `total_paid_insurance` DECIMAL(10,2),
  `visit_id` DECIMAL(10,2),
  PRIMARY KEY (`bill_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004708_Query_4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004708_Query_4') AS relationships;
DROP DATABASE `db_004708_Query_4`;
UNINSTALL EXTENSION vsql_schematron;
