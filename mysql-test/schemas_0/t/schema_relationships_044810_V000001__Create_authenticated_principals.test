CREATE DATABASE `db_044810_V000001__Create_authenticated_principals`;
USE `db_044810_V000001__Create_authenticated_principals`;
CREATE TABLE `authenticated_principals` (
  `authenticated_principal_id` VARCHAR(50) NOT NULL,
  `principal` VARCHAR(50),
  `authorized_client_registration_id` VARCHAR(50),
  PRIMARY KEY (`authenticated_principal_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` VARCHAR(50) NOT NULL,
  `user_code` VARCHAR(50),
  `authenticated_principal_id` VARCHAR(50),
  `user_name` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
