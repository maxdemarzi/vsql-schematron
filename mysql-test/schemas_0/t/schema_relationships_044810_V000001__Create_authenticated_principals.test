while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_044810_V000001__Create_authenticated_principals') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_044810_V000001__Create_authenticated_principals') AS relationships;
DROP DATABASE `db_044810_V000001__Create_authenticated_principals`;
