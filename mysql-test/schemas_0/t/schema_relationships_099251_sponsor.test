INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 099251_sponsor
--echo #
CREATE DATABASE `db_099251_sponsor`;
USE `db_099251_sponsor`;

CREATE TABLE `post` (
  `id_p` INT,
  `id_u_fk` INT,
  `name` VARCHAR(64),
  `post` VARCHAR(64),
  `created` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id_u` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id_u`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_099251_sponsor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_099251_sponsor') AS relationships;
DROP DATABASE `db_099251_sponsor`;
UNINSTALL EXTENSION vsql_schematron;
