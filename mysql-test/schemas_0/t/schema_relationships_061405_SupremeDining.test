INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061405_SupremeDining
--echo #
CREATE DATABASE `db_061405_SupremeDining`;
USE `db_061405_SupremeDining`;
CREATE TABLE `DIETARY_PROVISIONS` (
  `Diet_code` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Diet_code`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM_DIET` (
  `Item_id` VARCHAR(50),
  `Diet_code` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `MENU` (
  `Item_id` VARCHAR(50) NOT NULL,
  `Item_name` VARCHAR(50),
  `Description` VARCHAR(50),
  `Category_id` VARCHAR(50),
  `Price` DOUBLE,
  PRIMARY KEY (`Item_id`)
) CHARACTER SET latin1;
CREATE TABLE `ORDER_DETAILS` (
  `Order_number` INT,
  `Item_id` VARCHAR(50),
  `Quantity` INT,
  `Sub_total` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `STAFF` (
  `Staff_id` VARCHAR(50) NOT NULL,
  `Title` VARCHAR(50),
  `First_name` VARCHAR(50),
  `Surname` VARCHAR(50),
  `Address` VARCHAR(50),
  `Phone_no` INT,
  `Email` VARCHAR(50),
  PRIMARY KEY (`Staff_id`)
) CHARACTER SET latin1;
CREATE TABLE `LOGIN` (
  `Username` VARCHAR(50) NOT NULL,
  `Password` VARCHAR(50),
  `Staff_id` VARCHAR(50),
  `Login_status` VARCHAR(50),
  PRIMARY KEY (`Username`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
  `Customer_id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Table_number` VARCHAR(50),
  `Email` VARCHAR(50),
  PRIMARY KEY (`Customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
  `Order_number` INT NOT NULL,
  `Order_date` DATE,
  `Time` TIME,
  `Table_number` VARCHAR(50),
  `Order_completed` BOOLEAN,
  `Staff_id` VARCHAR(50),
  `Customer_id` INT,
  PRIMARY KEY (`Order_number`)
) CHARACTER SET latin1;
CREATE TABLE `CATEGORY` (
  `Category_id` VARCHAR(50) NOT NULL,
  `Name` VARCHAR(50),
  PRIMARY KEY (`Category_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061405_SupremeDining') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061405_SupremeDining') AS relationships;
DROP DATABASE `db_061405_SupremeDining`;
UNINSTALL EXTENSION vsql_schematron;
