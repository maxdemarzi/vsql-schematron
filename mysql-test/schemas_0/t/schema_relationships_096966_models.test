INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 096966_models
--echo #
CREATE DATABASE `db_096966_models`;
USE `db_096966_models`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `location` VARCHAR(64),
  `games_won` INT,
  `games_lost` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `games` (
  `id` INT,
  `name` VARCHAR(64),
  `public` BOOL,
  `tournament` BOOL,
  `creation_date` DATETIME,
  `end_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pairs` (
  `id` INT,
  `winned` BOOL,
  `game_points` INT,
  `game_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `players` (
  `id` INT,
  `user_id` INT,
  `pair_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_096966_models') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_096966_models') AS relationships;
DROP DATABASE `db_096966_models`;
UNINSTALL EXTENSION vsql_schematron;
