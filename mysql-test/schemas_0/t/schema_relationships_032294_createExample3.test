INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 032294_createExample3
--echo #
CREATE DATABASE `db_032294_createExample3`;
USE `db_032294_createExample3`;
CREATE TABLE `CURRENCY` (
  `CODE` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`CODE`)
) CHARACTER SET latin1;
CREATE TABLE `INSTRUMENT` (
  `INSTRUMENT_ID` INT NOT NULL,
  `CURRENCY` CHAR(50),
  `INSTRUMENT_TYPE_ID` INT,
  `DESCRIPTION` VARCHAR(50),
  `VALID` CHAR(50),
  `PRICE` DOUBLE,
  PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_032294_createExample3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_032294_createExample3') AS relationships;
DROP DATABASE `db_032294_createExample3`;
UNINSTALL EXTENSION vsql_schematron;
