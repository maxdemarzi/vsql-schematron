INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 039743_1-edge
--echo #
CREATE DATABASE `db_039743_1_edge`;
USE `db_039743_1_edge`;

CREATE TABLE `relations` (
  `id` VARCHAR(64),
  `parent_schema_id` VARCHAR(64),
  `child_schema_id` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `edges` (
  `relation_id` VARCHAR(64),
  `parent_object_id` VARCHAR(64),
  `child_object_id` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_039743_1_edge') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_039743_1_edge') AS relationships;
DROP DATABASE `db_039743_1_edge`;
UNINSTALL EXTENSION vsql_schematron;
