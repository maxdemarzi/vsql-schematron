INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038659_db-init
--echo #
CREATE DATABASE `db_038659_db_init`;
USE `db_038659_db_init`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `document_number` VARCHAR(50),
  `credit_limit` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operation_type` (
  `id` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
  `id` INT NOT NULL,
  `account_id` INT,
  `operation_type_id` INT,
  `amount` DECIMAL(10,2),
  `event_date` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038659_db_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038659_db_init') AS relationships;
DROP DATABASE `db_038659_db_init`;
UNINSTALL EXTENSION vsql_schematron;
