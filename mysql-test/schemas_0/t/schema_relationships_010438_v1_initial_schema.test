INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010438_v1_initial_schema
--echo #
CREATE DATABASE `db_010438_v1_initial_schema`;
USE `db_010438_v1_initial_schema`;

CREATE TABLE `AUTOMATA` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `VERSION` INT,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `AUTOMATA_STATUS_MAPPING` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `NAME` VARCHAR(64),
  `IS_RETRYABLE` BOOL,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `STATE` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `NAME` VARCHAR(64),
  `IS_INITIAL` BOOL,
  `IS_TERMINAL` BOOL,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EVENT` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `NAME` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TASK_DEFINITION` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `STATE_ID` INT,
  `NAME` VARCHAR(64),
  `QUEUE_NAME` VARCHAR(64),
  `INPUT_PARAMETERS` VARCHAR(64),
  `RETRY_POLICY` VARCHAR(64),
  `MAX_RETRIES` INT,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TASK_STATUS_MAPPING` (
  `ID` INT,
  `TASK_DEFINITION_ID` INT,
  `NAME` VARCHAR(64),
  `IS_RETRYABLE` BOOL,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TASK_EVENT_MAPPING` (
  `ID` INT,
  `EVENT_ID` INT,
  `TASK_STATUS_ID` INT,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TRANSITION` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `FROM_STATE_ID` INT,
  `TO_STATE_ID` INT,
  `EVENT_ID` INT,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `STATE_MACHINE` (
  `ID` INT,
  `AUTOMATA_ID` INT,
  `STATUS_ID` INT,
  `INITIAL_INPUT` VARCHAR(64),
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FSM_STATE_GROUP` (
  `ID` INT,
  `STATE_MACHINE_ID` INT,
  `STATE_ID` INT,
  `IS_CURRENT` BOOL,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TASK` (
  `ID` INT,
  `TASK_DEFINITION_ID` INT,
  `STATE_MACHINE_ID` INT,
  `INPUT` VARCHAR(64),
  `STATUS_ID` INT,
  `RETRY_COUNT` INT,
  `CREATED` DATETIME,
  `UPDATED` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010438_v1_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010438_v1_initial_schema') AS relationships;
DROP DATABASE `db_010438_v1_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
