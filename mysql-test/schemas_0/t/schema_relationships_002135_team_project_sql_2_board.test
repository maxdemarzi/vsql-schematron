INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002135_team-project-sql_2_board
--echo #
CREATE DATABASE `db_002135_team_project_sql_2_board`;
USE `db_002135_team_project_sql_2_board`;

CREATE TABLE `BOARD` (
  `bd_code` DECIMAL(10,2),
  `bd_num` DECIMAL(10,2),
  `m_id` VARCHAR(64),
  `subject` VARCHAR(64),
  `content` VARCHAR(64),
  `category` DECIMAL(10,2),
  `read_count` DECIMAL(10,2),
  `reg_date` DATETIME,
  `tags` VARCHAR(64),
  `is_adopted` DECIMAL(10,2),
  `file_name` VARCHAR(64),
  `ref` DECIMAL(10,2),
  `re_step` DECIMAL(10,2),
  `re_level` DECIMAL(10,2),
  PRIMARY KEY (`bd_code`, `bd_num`)
) CHARACTER SET latin1;

CREATE TABLE `COMMENTS` (
  `bd_code` DECIMAL(10,2),
  `bd_num` DECIMAL(10,2),
  `bd_cm_num` DECIMAL(10,2),
  `content` VARCHAR(64),
  `reg_date` DATETIME,
  `ref` DECIMAL(10,2),
  `re_step` DECIMAL(10,2),
  `re_level` DECIMAL(10,2),
  PRIMARY KEY (`bd_code`, `bd_num`, `bd_cm_num`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002135_team_project_sql_2_board') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002135_team_project_sql_2_board') AS relationships;
DROP DATABASE `db_002135_team_project_sql_2_board`;
UNINSTALL EXTENSION vsql_schematron;
