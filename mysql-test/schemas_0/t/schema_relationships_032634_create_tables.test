INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 032634_create_tables
--echo #
CREATE DATABASE `db_032634_create_tables`;
USE `db_032634_create_tables`;

CREATE TABLE `tweet` (
  `id` INT,
  `message` VARCHAR(255),
  `lang` VARCHAR(255),
  `created_at` DATETIME,
  `aggregate_sentiment` VARCHAR(255),
  `aggregate_score` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sentiment` (
  `id` VARCHAR(255),
  `tweet_id` INT,
  `sentiment` VARCHAR(255),
  `topic` VARCHAR(255),
  `score` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_032634_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_032634_create_tables') AS relationships;
DROP DATABASE `db_032634_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
