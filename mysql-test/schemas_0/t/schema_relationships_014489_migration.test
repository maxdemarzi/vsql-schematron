INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014489_migration
--echo #
CREATE DATABASE `db_014489_migration`;
USE `db_014489_migration`;
CREATE TABLE `GuestUser` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GuestRoom` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `GuestMessage` (
  `id` VARCHAR(50) NOT NULL,
  `username` TEXT,
  `text` TEXT,
  `roomId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014489_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014489_migration') AS relationships;
DROP DATABASE `db_014489_migration`;
UNINSTALL EXTENSION vsql_schematron;
