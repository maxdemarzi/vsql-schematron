INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041563_mysql_3
--echo #
CREATE DATABASE `db_041563_mysql_3`;
USE `db_041563_mysql_3`;

CREATE TABLE `user` (
  `id` INT,
  `name` VARCHAR(64),
  `passwd` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pyq` (
  `id` INT,
  `image` VARCHAR(64),
  `content` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mylike` (
  `id` INT,
  `uid` INT,
  `pid` INT,
  `comment` VARCHAR(64),
  `lk` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041563_mysql_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041563_mysql_3') AS relationships;
DROP DATABASE `db_041563_mysql_3`;
UNINSTALL EXTENSION vsql_schematron;
