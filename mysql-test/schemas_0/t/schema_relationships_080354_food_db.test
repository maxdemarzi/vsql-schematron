INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 080354_food_db
--echo #
CREATE DATABASE `db_080354_food_db`;
USE `db_080354_food_db`;

CREATE TABLE `user` (
  `userId` INT,
  `userName` VARCHAR(64),
  `loginStatus` BOOL,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  `birthDate` DATETIME,
  `registerDate` DATETIME,
  `lastLogin` DATETIME,
  `admin` BOOL,
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `voteId` INT,
  `foodStatusName` VARCHAR(64),
  `numVotes` INT,
  `lastUpdated` DATETIME,
  PRIMARY KEY (`voteId`)
) CHARACTER SET latin1;

CREATE TABLE `food` (
  `foodId` INT,
  `foodName` VARCHAR(64),
  `comfortRating` INT,
  `origin` VARCHAR(64),
  `voteFriendly` INT,
  `voteAvoid` INT,
  `voteTry` INT,
  PRIMARY KEY (`foodId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_080354_food_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_080354_food_db') AS relationships;
DROP DATABASE `db_080354_food_db`;
UNINSTALL EXTENSION vsql_schematron;
