INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076189_bdconsulta
--echo #
CREATE DATABASE `db_076189_bdconsulta`;
USE `db_076189_bdconsulta`;

CREATE TABLE `aluno` (
  `CPF` INT,
  `Name` VARCHAR(64),
  `DATANASCIMENTO` DATETIME,
  PRIMARY KEY (`CPF`)
) CHARACTER SET latin1;

CREATE TABLE `notas` (
  `ID_notas` INT,
  `valor_notaav1` DECIMAL(10,2),
  `valor_notaav2` DECIMAL(10,2),
  `valor_notafinal` DECIMAL(10,2),
  PRIMARY KEY (`ID_notas`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076189_bdconsulta') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076189_bdconsulta') AS relationships;
DROP DATABASE `db_076189_bdconsulta`;
UNINSTALL EXTENSION vsql_schematron;
