INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011015_ncc
--echo #
CREATE DATABASE `db_011015_ncc`;
USE `db_011015_ncc`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `event` (
  `event_id` INT,
  `event_username` VARCHAR(255),
  `event_name` VARCHAR(255),
  `event_desc` VARCHAR(255),
  `event_date` DATETIME,
  `time` VARCHAR(255),
  `venue` VARCHAR(255),
  `status1` VARCHAR(255),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

CREATE TABLE `eventJoin` (
  `event_id` INT,
  `username` VARCHAR(255),
  `status2` VARCHAR(255),
  PRIMARY KEY (`event_id`, `username`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011015_ncc') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011015_ncc') AS relationships;
DROP DATABASE `db_011015_ncc`;
UNINSTALL EXTENSION vsql_schematron;
