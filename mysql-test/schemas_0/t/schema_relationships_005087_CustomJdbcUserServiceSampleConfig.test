INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005087_CustomJdbcUserServiceSampleConfig
--echo #
CREATE DATABASE `db_005087_CustomJdbcUserServiceSampleConfig`;
USE `db_005087_CustomJdbcUserServiceSampleConfig`;
CREATE TABLE `users` (
  `principal` VARCHAR(50) NOT NULL,
  `credentials` VARCHAR(50),
  PRIMARY KEY (`principal`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `principal` VARCHAR(50),
  `role` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` BIGINT NOT NULL,
  `group_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_authorities` (
  `group_id` BIGINT,
  `authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `group_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005087_CustomJdbcUserServiceSampleConfig') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005087_CustomJdbcUserServiceSampleConfig') AS relationships;
DROP DATABASE `db_005087_CustomJdbcUserServiceSampleConfig`;
UNINSTALL EXTENSION vsql_schematron;
