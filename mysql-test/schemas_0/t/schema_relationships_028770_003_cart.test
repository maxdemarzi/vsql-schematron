INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028770_003_cart
--echo #
CREATE DATABASE `db_028770_003_cart`;
USE `db_028770_003_cart`;
CREATE TABLE `carts` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cart_items` (
  `id` INT NOT NULL,
  `cart_id` INT,
  `product_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028770_003_cart') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028770_003_cart') AS relationships;
DROP DATABASE `db_028770_003_cart`;
UNINSTALL EXTENSION vsql_schematron;
