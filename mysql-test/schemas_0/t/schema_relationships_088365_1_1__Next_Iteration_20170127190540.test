INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 088365_1.1__Next_Iteration_20170127190540
--echo #
CREATE DATABASE `db_088365_1_1__Next_Iteration_20170127190540`;
USE `db_088365_1_1__Next_Iteration_20170127190540`;
CREATE TABLE `ciudad` (
  `id` BIGINT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `direccion` (
  `id` BIGINT NOT NULL,
  `calle` VARCHAR(50),
  `nro` VARCHAR(50),
  `persona_id` BIGINT,
  `ciudad_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `persona` (
  `id` BIGINT NOT NULL,
  `nombre` VARCHAR(50),
  `apellido` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_088365_1_1__Next_Iteration_20170127190540') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_088365_1_1__Next_Iteration_20170127190540') AS relationships;
DROP DATABASE `db_088365_1_1__Next_Iteration_20170127190540`;
UNINSTALL EXTENSION vsql_schematron;
