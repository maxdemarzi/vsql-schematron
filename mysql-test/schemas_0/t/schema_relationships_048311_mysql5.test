INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048311_mysql5
--echo #
CREATE DATABASE `db_048311_mysql5`;
USE `db_048311_mysql5`;
CREATE TABLE `oc_transcription_service_provider` (
  `id` BIGINT NOT NULL,
  `provider` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `oc_transcription_service_job` (
  `id` BIGINT NOT NULL,
  `mediapackage_id` VARCHAR(50),
  `track_id` VARCHAR(50),
  `job_id` VARCHAR(50),
  `date_created` DATETIME,
  `date_expected` DATETIME,
  `date_completed` DATETIME,
  `status` VARCHAR(50),
  `track_duration` BIGINT,
  `provider_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048311_mysql5') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048311_mysql5') AS relationships;
DROP DATABASE `db_048311_mysql5`;
UNINSTALL EXTENSION vsql_schematron;
