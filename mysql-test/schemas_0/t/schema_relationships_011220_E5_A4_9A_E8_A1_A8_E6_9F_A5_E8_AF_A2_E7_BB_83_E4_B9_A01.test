INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011220_%E5%A4%9A%E8%A1%A8%E6%9F%A5%E8%AF%A2%E7%BB%83%E4%B9%A01
--echo #
CREATE DATABASE `db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9`;
USE `db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9`;

CREATE TABLE `dept` (
  `id` INT,
  `dname` VARCHAR(64),
  `loc` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `job` (
  `id` INT,
  `jname` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `emp` (
  `id` INT,
  `ename` VARCHAR(64),
  `job_id` INT,
  `mgr` INT,
  `joindate` DATETIME,
  `salary` DECIMAL(10,2),
  `bonus` DECIMAL(10,2),
  `dept_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `salarygrads` (
  `grade` INT,
  `losalary` INT,
  `hisalary` INT,
  PRIMARY KEY (`grade`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9') AS relationships;
DROP DATABASE `db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9`;
UNINSTALL EXTENSION vsql_schematron;
