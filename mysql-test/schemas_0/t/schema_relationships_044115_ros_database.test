INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 044115_ros_database
--echo #
CREATE DATABASE `db_044115_ros_database`;
USE `db_044115_ros_database`;

CREATE TABLE `mes_types` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `x_par` VARCHAR(64),
  `y_par` VARCHAR(64),
  `t_par` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `robots` (
  `id` INT,
  `user_id` INT,
  `ip_address` VARCHAR(64),
  `port` VARCHAR(64),
  `topic_id` INT
) CHARACTER SET latin1;

CREATE TABLE `topics` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `mes_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `activation_code` VARCHAR(64),
  `activated` INT,
  `forgotten_password_code` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_044115_ros_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_044115_ros_database') AS relationships;
DROP DATABASE `db_044115_ros_database`;
UNINSTALL EXTENSION vsql_schematron;
