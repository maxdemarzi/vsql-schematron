INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061804_example
--echo #
CREATE DATABASE `db_061804_example`;
USE `db_061804_example`;

CREATE TABLE `author` (
  `authorId` VARCHAR(64),
  `authorActivationToken` VARCHAR(64),
  `authorAvatarUrl` VARCHAR(64),
  `authorEmail` VARCHAR(64),
  `authorHash` VARCHAR(64),
  `authorUsername` VARCHAR(64),
  PRIMARY KEY (`authorId`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `tagId` VARCHAR(64),
  `tagName` VARCHAR(64),
  PRIMARY KEY (`tagId`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `articleId` VARCHAR(64),
  `articleAuthorId` VARCHAR(64),
  `articleContent` VARCHAR(64),
  `articleDate` DATETIME,
  `articleImage` VARCHAR(64),
  PRIMARY KEY (`articleId`)
) CHARACTER SET latin1;

CREATE TABLE `articleTag` (
  `articleTagArticleId` VARCHAR(64),
  `articleTagTagId` VARCHAR(64),
  PRIMARY KEY (`articleTagArticleId`, `articleTagTagId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061804_example') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061804_example') AS relationships;
DROP DATABASE `db_061804_example`;
UNINSTALL EXTENSION vsql_schematron;
