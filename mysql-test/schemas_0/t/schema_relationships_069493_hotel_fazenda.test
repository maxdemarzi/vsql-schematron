INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069493_hotel_fazenda
--echo #
CREATE DATABASE `db_069493_hotel_fazenda`;
USE `db_069493_hotel_fazenda`;
CREATE TABLE `cliente` (
  `cod_cli` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  `rg` CHAR(50),
  `bairro` VARCHAR(50),
  `cidade` VARCHAR(50),
  `estado` CHAR(50),
  `cep` CHAR(50),
  `dataNascimento` DATE,
  PRIMARY KEY (`cod_cli`)
) CHARACTER SET latin1;
CREATE TABLE `chale` (
  `cod_chale` VARCHAR(50) NOT NULL,
  `localizacao` VARCHAR(50),
  `capacidade` INT,
  `valorAltaEstacao` DECIMAL(10,2),
  `valorBaixaEstacao` DECIMAL(10,2),
  PRIMARY KEY (`cod_chale`)
) CHARACTER SET latin1;
CREATE TABLE `hospedagem` (
  `cod_hosp` VARCHAR(50) NOT NULL,
  `codChale` CHAR(50),
  `estado` CHAR(50),
  `dataInicio` DATE,
  `dataFim` DATE,
  `qtdPessoas` INT,
  `desconto` DECIMAL(10,2),
  `valorFinal` DECIMAL(10,2),
  PRIMARY KEY (`cod_hosp`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069493_hotel_fazenda') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069493_hotel_fazenda') AS relationships;
DROP DATABASE `db_069493_hotel_fazenda`;
UNINSTALL EXTENSION vsql_schematron;
