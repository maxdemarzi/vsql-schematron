INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 042721_initGlobalDb
--echo #
CREATE DATABASE `db_042721_initGlobalDb`;
USE `db_042721_initGlobalDb`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` TEXT,
  `pw` TEXT,
  `register_date` DECIMAL(10,2),
  `plan` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emails` (
  `id` INT NOT NULL,
  `user_id` INT,
  `email` TEXT,
  `token` TEXT,
  `verified` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pushregs` (
  `endpoint_uri` VARCHAR(50) NOT NULL,
  `p256dh` VARCHAR(50) NOT NULL,
  `auth` VARCHAR(50) NOT NULL,
  `seed` INT,
  `avg_interval` INT,
  PRIMARY KEY (`endpoint_uri`, `p256dh`, `auth`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_042721_initGlobalDb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_042721_initGlobalDb') AS relationships;
DROP DATABASE `db_042721_initGlobalDb`;
UNINSTALL EXTENSION vsql_schematron;
