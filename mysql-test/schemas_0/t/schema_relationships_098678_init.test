INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098678_init
--echo #
CREATE DATABASE `db_098678_init`;
USE `db_098678_init`;

CREATE TABLE `season` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `animal` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hunt_type` (
  `id` INT,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hunter` (
  `guid` VARCHAR(64),
  `first_name` VARCHAR(64),
  `middle_initial` VARCHAR(64),
  `last_name` VARCHAR(64),
  `cin` VARCHAR(64),
  `email` VARCHAR(64),
  `cell_number` VARCHAR(64),
  `day_number` VARCHAR(64),
  `user_name` VARCHAR(64),
  `passwd` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `home_state` VARCHAR(64),
  `zip` VARCHAR(64),
  `dob` DATETIME,
  `social` VARCHAR(64),
  `sex` VARCHAR(64),
  `height` INT,
  `weight` INT,
  `hair_color` VARCHAR(64),
  `eye_color` VARCHAR(64),
  PRIMARY KEY (`guid`)
) CHARACTER SET latin1;

CREATE TABLE `hunt` (
  `guid` VARCHAR(64),
  `client_guid` VARCHAR(64),
  `season` VARCHAR(64),
  `year` INT,
  `animal` VARCHAR(64),
  `hunt_type` VARCHAR(64),
  PRIMARY KEY (`guid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098678_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098678_init') AS relationships;
DROP DATABASE `db_098678_init`;
UNINSTALL EXTENSION vsql_schematron;
