INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010152_17
--echo #
CREATE DATABASE `db_010152_17`;
USE `db_010152_17`;

CREATE TABLE `testify_record` (
  `case_number` VARCHAR(64),
  `person_id` INT,
  PRIMARY KEY (`case_number`, `person_id`)
) CHARACTER SET latin1;

CREATE TABLE `meeting` (
  `id` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person_at_meeting` (
  `meeting_id` INT,
  `person_id` INT,
  `role` INT,
  PRIMARY KEY (`meeting_id`, `person_id`, `role`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010152_17') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010152_17') AS relationships;
DROP DATABASE `db_010152_17`;
UNINSTALL EXTENSION vsql_schematron;
