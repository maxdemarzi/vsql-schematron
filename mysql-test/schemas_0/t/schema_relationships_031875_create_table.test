INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 031875_create_table
--echo #
CREATE DATABASE `db_031875_create_table`;
USE `db_031875_create_table`;
CREATE TABLE `SuspicionOrders` (
  `OrderId` VARCHAR(50) NOT NULL,
  `AppCodeId` VARCHAR(50) NOT NULL,
  `MarketCodeId` VARCHAR(50) NOT NULL,
  `OrderStatusId` VARCHAR(50),
  `SuspicionTypeId` VARCHAR(50),
  `CreatedAtId` VARCHAR(50),
  `UpdateAtId` VARCHAR(50),
  `OrderCode` VARCHAR(50),
  `TongTienChuaThanhToan` DECIMAL(10,2),
  `TongTienDaThanhToan` DECIMAL(10,2),
  `TongTienPhaiThu` DECIMAL(10,2),
  `TongTienThanhToan` DECIMAL(10,2),
  PRIMARY KEY (`OrderId`, `AppCodeId`, `MarketCodeId`)
) CHARACTER SET latin1;
CREATE TABLE `SuspicionTypes` (
  `Id` VARCHAR(50) NOT NULL,
  `MoTa` VARCHAR(50),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_031875_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_031875_create_table') AS relationships;
DROP DATABASE `db_031875_create_table`;
UNINSTALL EXTENSION vsql_schematron;
