INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086432_migration
--echo #
CREATE DATABASE `db_086432_migration`;
USE `db_086432_migration`;

CREATE TABLE `Argument` (
  `id` INT,
  `assertionId` INT,
  `sourceId` INT,
  `userId` INT,
  `side` BOOL,
  `score` DECIMAL(10,2),
  `text` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Assertion` (
  `id` INT,
  `urlToken` VARCHAR(64),
  `userId` INT,
  `sourceId` INT,
  `score` DECIMAL(10,2),
  `text` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Rating` (
  `userId` INT,
  `argumentId` INT,
  `rating` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`userId`, `argumentId`)
) CHARACTER SET latin1;

CREATE TABLE `Source` (
  `id` INT,
  `domain` VARCHAR(64),
  `score` DECIMAL(10,2),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `passwordHash` VARCHAR(64),
  `role` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_SourceToUser` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086432_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086432_migration') AS relationships;
DROP DATABASE `db_086432_migration`;
UNINSTALL EXTENSION vsql_schematron;
