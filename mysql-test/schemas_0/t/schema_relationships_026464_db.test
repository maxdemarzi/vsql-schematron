INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 026464_db
--echo #
CREATE DATABASE `db_026464_db`;
USE `db_026464_db`;

CREATE TABLE `bidirectional_schema.PARENT` (
  `PARENT_ID` INT,
  `PARENT_CONTENT` VARCHAR(64),
  PRIMARY KEY (`PARENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `bidirectional_schema.CHILD` (
  `CHILD_ID` INT,
  `CHILD_CONTENT` VARCHAR(64),
  `PARENT_PARENT_ID` INT,
  PRIMARY KEY (`CHILD_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_026464_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_026464_db') AS relationships;
DROP DATABASE `db_026464_db`;
UNINSTALL EXTENSION vsql_schematron;
