INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077871_synappV1_schema
--echo #
CREATE DATABASE `db_077871_synappV1_schema`;
USE `db_077871_synappV1_schema`;

CREATE TABLE `types` (
  `typeid` INT,
  `typedesc` VARCHAR(255),
  PRIMARY KEY (`typeid`)
) CHARACTER SET latin1;

CREATE TABLE `test_types` (
  `ttypeid` INT,
  `ttypedesc` VARCHAR(255),
  PRIMARY KEY (`ttypeid`)
) CHARACTER SET latin1;

CREATE TABLE `test_resources` (
  `tresourceid` INT,
  `tresourcelang` VARCHAR(255),
  `tresourcedesc` VARCHAR(255),
  PRIMARY KEY (`tresourceid`, `tresourcelang`)
) CHARACTER SET latin1;

CREATE TABLE `group_resources` (
  `resourceid` INT,
  `groupid` INT,
  `stage` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077871_synappV1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077871_synappV1_schema') AS relationships;
DROP DATABASE `db_077871_synappV1_schema`;
UNINSTALL EXTENSION vsql_schematron;
