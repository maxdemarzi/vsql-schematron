INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037986_category_test
--echo #
CREATE DATABASE `db_037986_category_test`;
USE `db_037986_category_test`;

CREATE TABLE `category` (
  `id` INT,
  `title` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `session` VARCHAR(64),
  `total` INT,
  `qty` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_product` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `title` VARCHAR(64),
  `price` INT,
  `qty` INT,
  `total` INT
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `category_id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `price` INT,
  `img` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037986_category_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037986_category_test') AS relationships;
DROP DATABASE `db_037986_category_test`;
UNINSTALL EXTENSION vsql_schematron;
