INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086732_V1.0.10__Skema_Dokumen_dosen
--echo #
CREATE DATABASE `db_086732_V1_0_10_Skema_Dokumen_dosen`;
USE `db_086732_V1_0_10_Skema_Dokumen_dosen`;

CREATE TABLE `t_dosen_document_profile` (
  `id` VARCHAR(64),
  `filename` VARCHAR(64),
  `status` VARCHAR(64),
  `id_dosen_profile` VARCHAR(64),
  `id_jenis_dokumen_profile` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `m_jenis_pengajuan_dokumen_profile` (
  `id` VARCHAR(64),
  `keterangan` VARCHAR(64),
  `nama` VARCHAR(64),
  `required` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086732_V1_0_10_Skema_Dokumen_dosen') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086732_V1_0_10_Skema_Dokumen_dosen') AS relationships;
DROP DATABASE `db_086732_V1_0_10_Skema_Dokumen_dosen`;
UNINSTALL EXTENSION vsql_schematron;
