CREATE DATABASE `db_026738_V76_7_1_Add_competition_user_for_assessor_invites`;
USE `db_026738_V76_7_1_Add_competition_user_for_assessor_invites`;

CREATE TABLE `competition_user_status` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `competition_role` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `competition_user_rejection_reason` (
  `id` INT,
  `reason` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `competition_user` (
  `id` INT,
  `competition_role_id` INT,
  `competition_id` INT,
  `user_id` INT,
  `invite_id` INT,
  `competition_user_status_name` VARCHAR(64),
  `rejection_reason_id` INT,
  `rejection_comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

