  `TENANT_ID_` VARCHAR(64),
  PRIMARY KEY (`ID_`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_RU_DEADLETTER_JOB` (
  `ID_` VARCHAR(64),
  `REV_` INT,
