--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_065196_flowable_mssql_upgradestep_5_99_0_to_6_0_0_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_065196_flowable_mssql_upgradestep_5_99_0_to_6_0_0_all') AS relationships;
DROP DATABASE `db_065196_flowable_mssql_upgradestep_5_99_0_to_6_0_0_all`;
