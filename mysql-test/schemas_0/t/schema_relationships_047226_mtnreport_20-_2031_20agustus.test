INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047226_mtnreport%20-%2031%20agustus
--echo #
CREATE DATABASE `db_047226_mtnreport_20__2031_20agustus`;
USE `db_047226_mtnreport_20__2031_20agustus`;
CREATE TABLE `area` (
  `id_area` INT NOT NULL,
  `area` VARCHAR(50),
  PRIMARY KEY (`id_area`)
) CHARACTER SET latin1;
CREATE TABLE `detail_work_order` (
  `id_detail_work_order` INT NOT NULL,
  `id_work_order` VARCHAR(50),
  `approved_order` TIMESTAMP NULL,
  `execution` TIMESTAMP NULL,
  `approved_work` TIMESTAMP NULL,
  PRIMARY KEY (`id_detail_work_order`)
) CHARACTER SET latin1;
CREATE TABLE `detail_wo_status` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `laporan` (
  `id_laporan` INT NOT NULL,
  `tanggal` DATE,
  `type_wo` VARCHAR(50),
  `grup` VARCHAR(50),
  `area` VARCHAR(50),
  `pekerjaan` TEXT,
  `analisis` TEXT,
  `sparepart` TEXT,
  `jam_mulai` TIME,
  `jam_selesai` TIME,
  `durasi` VARCHAR(50),
  `shift` INT,
  `total_person` INT,
  `nama_teknisi` VARCHAR(50),
  `made_by` VARCHAR(50),
  `status` VARCHAR(50),
  `photo` VARCHAR(50),
  PRIMARY KEY (`id_laporan`)
) CHARACTER SET latin1;
CREATE TABLE `work_order` (
  `id_work_order` VARCHAR(50) NOT NULL,
  `waktu` TIMESTAMP NULL,
  `grup` VARCHAR(50),
  `area` VARCHAR(50),
  `permasalahan` TEXT,
  `bagian_teknisi` VARCHAR(50),
  `photo` VARCHAR(50),
  `request_by` VARCHAR(50),
  `approved_by` VARCHAR(50),
  `wo_status` INT,
  PRIMARY KEY (`id_work_order`)
) CHARACTER SET latin1;
CREATE TABLE `work_order_ditolak` (
  `id` INT NOT NULL,
  `id_work_order` VARCHAR(50),
  `alasan` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047226_mtnreport_20__2031_20agustus') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047226_mtnreport_20__2031_20agustus') AS relationships;
DROP DATABASE `db_047226_mtnreport_20__2031_20agustus`;
UNINSTALL EXTENSION vsql_schematron;
