INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 019728_T_CONS5_2
--echo #
CREATE DATABASE `db_019728_T_CONS5_2`;
USE `db_019728_T_CONS5_2`;
CREATE TABLE `DEPARTMENT` (
  `DEPTNO` VARCHAR(50) NOT NULL,
  `DNAME` VARCHAR(50),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
  `사번` VARCHAR(50) NOT NULL,
  `이름` VARCHAR(50),
  `DEPTNO` VARCHAR(50),
  PRIMARY KEY (`사번`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_019728_T_CONS5_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_019728_T_CONS5_2') AS relationships;
DROP DATABASE `db_019728_T_CONS5_2`;
UNINSTALL EXTENSION vsql_schematron;
