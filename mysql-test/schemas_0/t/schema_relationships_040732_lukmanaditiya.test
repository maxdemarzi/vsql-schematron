INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040732_lukmanaditiya
--echo #
CREATE DATABASE `db_040732_lukmanaditiya`;
USE `db_040732_lukmanaditiya`;
CREATE TABLE `banners` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `text` VARCHAR(50),
  `photo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `identity` (
  `id` INT NOT NULL,
  `meta_title` VARCHAR(50),
  `meta_description` TEXT,
  `meta_keyword` TEXT,
  `photo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lagu` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `seo_title` VARCHAR(50),
  `content` TEXT,
  `photo` VARCHAR(50),
  `is_active` CHAR(50),
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menus` (
  `id` INT NOT NULL,
  `user_id` INT,
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `icon` VARCHAR(50),
  `is_active` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `opening` (
  `id` INT NOT NULL,
  `content` TEXT,
  `photo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `seo_title` VARCHAR(50),
  `content` TEXT,
  `photo` VARCHAR(50),
  `is_active` CHAR(50),
  `date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `submenus` (
  `id` INT,
  `menu_id` INT,
  `sub_title` VARCHAR(50),
  `sub_url` VARCHAR(50),
  `is_active` CHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040732_lukmanaditiya') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040732_lukmanaditiya') AS relationships;
DROP DATABASE `db_040732_lukmanaditiya`;
UNINSTALL EXTENSION vsql_schematron;
