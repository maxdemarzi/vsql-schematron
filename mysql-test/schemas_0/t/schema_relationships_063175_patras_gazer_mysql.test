INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 063175_patras_gazer.mysql
--echo #
CREATE DATABASE `db_063175_patras_gazer_mysql`;
USE `db_063175_patras_gazer_mysql`;

CREATE TABLE `activity` (
  `UID` VARCHAR(64),
  `fileID` INT,
  `timestampMs` INT,
  `type` VARCHAR(64),
  `confidence` INT,
  `location_id` INT,
  `main_activity` INT,
  `activity_id` INT,
  `uploadTime` DATETIME,
  PRIMARY KEY (`UID`, `fileID`, `location_id`, `main_activity`, `activity_id`)
) CHARACTER SET latin1;

CREATE TABLE `score` (
  `userID` VARCHAR(64),
  `ecoScore` INT,
  `updateTime` DATETIME,
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `userID` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `reg_date` DATETIME,
  `type` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_063175_patras_gazer_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_063175_patras_gazer_mysql') AS relationships;
DROP DATABASE `db_063175_patras_gazer_mysql`;
UNINSTALL EXTENSION vsql_schematron;
