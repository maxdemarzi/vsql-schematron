INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025227_DatabaseCreation_mysql
--echo #
CREATE DATABASE `db_025227_DatabaseCreation_mysql`;
USE `db_025227_DatabaseCreation_mysql`;
CREATE TABLE `Author` (
  `AuthorId` INT NOT NULL,
  `Name` VARCHAR(50),
  `Lastname` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`AuthorId`)
) CHARACTER SET latin1;
CREATE TABLE `Website` (
  `WebsiteId` INT NOT NULL,
  `Name` VARCHAR(50),
  `Url` VARCHAR(50),
  PRIMARY KEY (`WebsiteId`)
) CHARACTER SET latin1;
CREATE TABLE `Profile` (
  `ProfileId` INT NOT NULL,
  `AuthorId` INT,
  `WebsiteId` INT,
  `Name` VARCHAR(50),
  `TemplateKey` VARCHAR(50),
  `ProfileUrl` VARCHAR(50),
  PRIMARY KEY (`ProfileId`)
) CHARACTER SET latin1;
CREATE TABLE `Post` (
  `PostId` INT NOT NULL,
  `ProfileId` INT,
  `PostingDateTime` DATETIME,
  `Content` VARCHAR(50),
  `ThreadTitle` VARCHAR(50),
  `PostLink` VARCHAR(50),
  `Forum` VARCHAR(50),
  `ForumLink` VARCHAR(50),
  PRIMARY KEY (`PostId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025227_DatabaseCreation_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025227_DatabaseCreation_mysql') AS relationships;
DROP DATABASE `db_025227_DatabaseCreation_mysql`;
UNINSTALL EXTENSION vsql_schematron;
