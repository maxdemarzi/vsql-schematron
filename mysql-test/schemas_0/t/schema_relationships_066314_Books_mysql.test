INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066314_Books_mysql
--echo #
CREATE DATABASE `db_066314_Books_mysql`;
USE `db_066314_Books_mysql`;

CREATE TABLE `AUTHOR` (
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `biography` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  PRIMARY KEY (`firstname`)
) CHARACTER SET latin1;

CREATE TABLE `REVIEW` (
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `rating` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  `username` VARCHAR(64),
  `title_1` VARCHAR(64),
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;

CREATE TABLE `WRITE_IN` (
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK` (
  `title` VARCHAR(64),
  `image` VARCHAR(64),
  `summary` VARCHAR(64),
  `nbr_page` VARCHAR(64),
  `price` VARCHAR(64),
  `publishedat` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  `firstname` VARCHAR(64),
  PRIMARY KEY (`title`)
) CHARACTER SET latin1;

CREATE TABLE `RELEASED_IN` (
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;

CREATE TABLE `FORMAT` (
  `name` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `USER` (
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `LANGUAGE` (
  `name` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `HAVE` (
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;

CREATE TABLE `GENRE` (
  `name` VARCHAR(64),
  `createdat` VARCHAR(64),
  `updatedat` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066314_Books_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066314_Books_mysql') AS relationships;
DROP DATABASE `db_066314_Books_mysql`;
UNINSTALL EXTENSION vsql_schematron;
