INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069439_text_form_db
--echo #
CREATE DATABASE `db_069439_text_form_db`;
USE `db_069439_text_form_db`;

CREATE TABLE `detail` (
  `ID_detail` INT,
  `detail` VARCHAR(64),
  `content` VARCHAR(64),
  `ID_text_form` INT,
  PRIMARY KEY (`ID_detail`)
) CHARACTER SET latin1;

CREATE TABLE `test` (
  `ID` VARCHAR(64),
  `descript` VARCHAR(64),
  `ID_parent` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `text_form` (
  `ID_text_form` INT,
  `type_text_form` VARCHAR(64),
  PRIMARY KEY (`ID_text_form`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069439_text_form_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069439_text_form_db') AS relationships;
DROP DATABASE `db_069439_text_form_db`;
UNINSTALL EXTENSION vsql_schematron;
