INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045051_Aula05
--echo #
CREATE DATABASE `db_045051_Aula05`;
USE `db_045051_Aula05`;

CREATE TABLE `tblestados` (
  `estid` INT,
  `estsigla` VARCHAR(64),
  PRIMARY KEY (`estid`)
) CHARACTER SET latin1;

CREATE TABLE `tblcursos` (
  `curid` INT,
  `curnome` VARCHAR(64),
  PRIMARY KEY (`curid`)
) CHARACTER SET latin1;

CREATE TABLE `tblalunos` (
  `aluid` INT,
  `alunome` VARCHAR(64),
  `alunomesocial` VARCHAR(64),
  `alucpf` DECIMAL(10,2),
  `alurg` VARCHAR(64),
  `curid` INT,
  `estid` INT,
  PRIMARY KEY (`aluid`)
) CHARACTER SET latin1;

CREATE TABLE `tblfaculdades` (
  `facid` INT,
  `facnome` VARCHAR(64),
  PRIMARY KEY (`facid`)
) CHARACTER SET latin1;

CREATE TABLE `tblcursosfaculdades` (
  `curid` INT,
  `facid` INT,
  PRIMARY KEY (`curid`, `facid`)
) CHARACTER SET latin1;

CREATE TABLE `tbldisciplinas` (
  `disid` INT,
  `disnome` VARCHAR(64),
  PRIMARY KEY (`disid`)
) CHARACTER SET latin1;

CREATE TABLE `tbldisciplinascurso` (
  `disid` INT,
  `curid` INT,
  PRIMARY KEY (`disid`, `curid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045051_Aula05') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045051_Aula05') AS relationships;
DROP DATABASE `db_045051_Aula05`;
UNINSTALL EXTENSION vsql_schematron;
