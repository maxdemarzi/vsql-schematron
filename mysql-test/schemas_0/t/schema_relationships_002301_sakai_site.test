INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002301_sakai_site
--echo #
CREATE DATABASE `db_002301_sakai_site`;
USE `db_002301_sakai_site`;

CREATE TABLE `SAKAI_SITE_PROPERTY` (
  `SITE_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `VALUE` VARCHAR(64),
  PRIMARY KEY (`SITE_ID`, `NAME`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE` (
  `SITE_ID` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `TYPE` VARCHAR(64),
  `SHORT_DESC` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `ICON_URL` VARCHAR(64),
  `INFO_URL` VARCHAR(64),
  `SKIN` VARCHAR(64),
  `PUBLISHED` INT,
  `JOINABLE` VARCHAR(64),
  `PUBVIEW` VARCHAR(64),
  `JOIN_ROLE` VARCHAR(64),
  `CREATEDBY` VARCHAR(64),
  `MODIFIEDBY` VARCHAR(64),
  `CREATEDON` DATETIME,
  `MODIFIEDON` DATETIME,
  `IS_SPECIAL` VARCHAR(64),
  `IS_USER` VARCHAR(64),
  `CUSTOM_PAGE_ORDERED` VARCHAR(64),
  `IS_SOFTLY_DELETED` VARCHAR(64),
  `SOFTLY_DELETED_DATE` DATETIME,
  PRIMARY KEY (`SITE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE_PAGE` (
  `PAGE_ID` VARCHAR(64),
  `SITE_ID` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `LAYOUT` VARCHAR(64),
  `SITE_ORDER` INT,
  `POPUP` VARCHAR(64),
  PRIMARY KEY (`PAGE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE_PAGE_PROPERTY` (
  `SITE_ID` VARCHAR(64),
  `PAGE_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `VALUE` VARCHAR(64),
  PRIMARY KEY (`PAGE_ID`, `NAME`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE_TOOL` (
  `TOOL_ID` VARCHAR(64),
  `PAGE_ID` VARCHAR(64),
  `SITE_ID` VARCHAR(64),
  `REGISTRATION` VARCHAR(64),
  `PAGE_ORDER` INT,
  `TITLE` VARCHAR(64),
  `LAYOUT_HINTS` VARCHAR(64),
  PRIMARY KEY (`TOOL_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE_TOOL_PROPERTY` (
  `SITE_ID` VARCHAR(64),
  `TOOL_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `VALUE` VARCHAR(64),
  PRIMARY KEY (`TOOL_ID`, `NAME`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_SITE_USER` (
  `SITE_ID` VARCHAR(64),
  `USER_ID` VARCHAR(64),
  `PERMISSION` INT,
  PRIMARY KEY (`SITE_ID`, `USER_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002301_sakai_site') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002301_sakai_site') AS relationships;
DROP DATABASE `db_002301_sakai_site`;
UNINSTALL EXTENSION vsql_schematron;
