INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036068_testetrabalho21
--echo #
CREATE DATABASE `db_036068_testetrabalho21`;
USE `db_036068_testetrabalho21`;

CREATE TABLE `pessoa` (
  `cpf` INT,
  `nome` VARCHAR(64),
  `estado_civil` VARCHAR(64),
  `nascimento` DATETIME,
  `endereco` VARCHAR(64),
  `telefone` INT,
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;

CREATE TABLE `paciente` (
  `nra_pront` INT,
  `pcpf` INT,
  PRIMARY KEY (`nra_pront`)
) CHARACTER SET latin1;

CREATE TABLE `funcionario` (
  `cod_func` INT,
  `nome_funcionario` VARCHAR(64),
  PRIMARY KEY (`cod_func`)
) CHARACTER SET latin1;

CREATE TABLE `atendimento` (
  `nro_atendimento` INT,
  `nro_pront` INT,
  `cod_func` INT,
  `data_consulta` DATETIME,
  `hora` VARCHAR(64),
  `data_atual` DATETIME,
  PRIMARY KEY (`nro_atendimento`)
) CHARACTER SET latin1;

CREATE TABLE `secretaria` (
  `cod_func` INT,
  `idioma` VARCHAR(64),
  `tipo` VARCHAR(64),
  PRIMARY KEY (`cod_func`)
) CHARACTER SET latin1;

CREATE TABLE `dentista` (
  `cod_func` INT,
  `crm` INT,
  `especializacao` VARCHAR(64),
  PRIMARY KEY (`cod_func`)
) CHARACTER SET latin1;

CREATE TABLE `procedimento` (
  `nro_procedimento` INT,
  `cod_func` INT,
  `nro_pront` INT,
  `data_consulta` DATETIME,
  PRIMARY KEY (`nro_procedimento`)
) CHARACTER SET latin1;

CREATE TABLE `cirurgia` (
  `nro_procedimento` INT,
  `procedimento` VARCHAR(64),
  PRIMARY KEY (`nro_procedimento`)
) CHARACTER SET latin1;

CREATE TABLE `consulta` (
  `nro_procedimento` INT,
  `medicamento` VARCHAR(64),
  PRIMARY KEY (`nro_procedimento`)
) CHARACTER SET latin1;

CREATE TABLE `atestado` (
  `nro_procedimento` INT,
  `descricao` VARCHAR(64),
  PRIMARY KEY (`nro_procedimento`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036068_testetrabalho21') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036068_testetrabalho21') AS relationships;
DROP DATABASE `db_036068_testetrabalho21`;
UNINSTALL EXTENSION vsql_schematron;
