INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076642_V3__region__create
--echo #
CREATE DATABASE `db_076642_V3_region_create`;
USE `db_076642_V3_region_create`;

CREATE TABLE `region` (
  `region_id` DECIMAL(10,2),
  `region_name` VARCHAR(64),
  `region_kuerzel` VARCHAR(64),
  `region_typ` VARCHAR(64),
  `region_uebergeordnet` DECIMAL(10,2),
  `created_at_utc` DATETIME,
  `created_by` DECIMAL(10,2),
  `last_modified_at_utc` DATETIME,
  `last_modified_by` DECIMAL(10,2),
  `version` DECIMAL(10,2),
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076642_V3_region_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076642_V3_region_create') AS relationships;
DROP DATABASE `db_076642_V3_region_create`;
UNINSTALL EXTENSION vsql_schematron;
