INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062581_1_create_table
--echo #
CREATE DATABASE `db_062581_1_create_table`;
USE `db_062581_1_create_table`;
CREATE TABLE `players` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `jankens` (
  `id` INT NOT NULL,
  `played_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `janken_details` (
  `id` INT NOT NULL,
  `janken_id` INT,
  `player_id` INT,
  `hand` INT,
  `result` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062581_1_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062581_1_create_table') AS relationships;
DROP DATABASE `db_062581_1_create_table`;
UNINSTALL EXTENSION vsql_schematron;
