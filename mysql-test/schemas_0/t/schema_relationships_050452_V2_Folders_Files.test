INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 050452_V2__Folders_Files
--echo #
CREATE DATABASE `db_050452_V2_Folders_Files`;
USE `db_050452_V2_Folders_Files`;

CREATE TABLE `folders` (
  `id` INT,
  `userId` VARCHAR(64),
  `name` VARCHAR(64),
  `parentFolder` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` INT,
  `userId` VARCHAR(64),
  `name` VARCHAR(64),
  `mimeType` VARCHAR(64),
  `folder` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_050452_V2_Folders_Files') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_050452_V2_Folders_Files') AS relationships;
DROP DATABASE `db_050452_V2_Folders_Files`;
UNINSTALL EXTENSION vsql_schematron;
