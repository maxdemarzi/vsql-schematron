INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 090691_tables
--echo #
CREATE DATABASE `db_090691_tables`;
USE `db_090691_tables`;
CREATE TABLE `recipes` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `prep_time` INT,
  `cook_time` INT,
  `cuisine` VARCHAR(50),
  `complex` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instructions` (
  `id` INT NOT NULL,
  `recipe_id` INT,
  `step_number` INT,
  `instructions` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_ingredients` (
  `recipe_id` INT,
  `ingredient_id` INT,
  `ingredient_amount` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_090691_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_090691_tables') AS relationships;
DROP DATABASE `db_090691_tables`;
UNINSTALL EXTENSION vsql_schematron;
