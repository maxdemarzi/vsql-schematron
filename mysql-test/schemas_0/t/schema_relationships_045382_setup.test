INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045382_setup
--echo #
CREATE DATABASE `db_045382_setup`;
USE `db_045382_setup`;

CREATE TABLE `comments` (
  `id` INT,
  `create_ts` INT,
  `uri` VARCHAR(64),
  `author` VARCHAR(64),
  `comment` VARCHAR(64),
  `hidden` BOOL,
  `replies_to` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045382_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045382_setup') AS relationships;
DROP DATABASE `db_045382_setup`;
UNINSTALL EXTENSION vsql_schematron;
