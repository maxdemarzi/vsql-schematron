INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094475_V1.0__create_database
--echo #
CREATE DATABASE `db_094475_V1_0__create_database`;
USE `db_094475_V1_0__create_database`;
CREATE TABLE `city` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `time_zone` VARCHAR(50),
  `country_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `continent` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
  `id` BIGINT NOT NULL,
  `code` VARCHAR(50),
  `name` VARCHAR(50),
  `continent_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094475_V1_0__create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094475_V1_0__create_database') AS relationships;
DROP DATABASE `db_094475_V1_0__create_database`;
UNINSTALL EXTENSION vsql_schematron;
