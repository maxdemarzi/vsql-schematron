INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069173_ddl
--echo #
CREATE DATABASE `db_069173_ddl`;
USE `db_069173_ddl`;

CREATE TABLE `food_category` (
  `id` INT,
  `title` VARCHAR(64),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `food` (
  `id` INT,
  `name` VARCHAR(64),
  `kcal` DECIMAL(10,2),
  `carbohydrates` DECIMAL(10,2),
  `proteins` DECIMAL(10,2),
  `total_fats` DECIMAL(10,2),
  `saturated_fats` DECIMAL(10,2),
  `trans_fats` DECIMAL(10,2),
  `dietary_fiber` DECIMAL(10,2),
  `sodium` DECIMAL(10,2),
  `food_category_id` INT,
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `active` BOOL,
  `professional_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipe` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `client_id` INT,
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recipe_food` (
  `id` INT,
  `recipe_id` INT,
  `food_id` INT,
  `quantity` DECIMAL(10,2),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `professional` (
  `id` INT,
  `name` VARCHAR(64),
  `cpf` VARCHAR(64),
  `email` VARCHAR(64),
  `telefone` VARCHAR(64),
  `register` VARCHAR(64),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `reference` VARCHAR(64),
  `description` VARCHAR(64),
  `professional_id` INT,
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069173_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069173_ddl') AS relationships;
DROP DATABASE `db_069173_ddl`;
UNINSTALL EXTENSION vsql_schematron;
