INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 083248_mariadb10
--echo #
CREATE DATABASE `db_083248_mariadb10`;
USE `db_083248_mariadb10`;
CREATE TABLE `mh_blocking_job` (
  `id` BIGINT,
  `blocking_job_list` BIGINT,
  `job_index` INT
) CHARACTER SET latin1;
CREATE TABLE `mh_event_comment` (
  `id` BIGINT NOT NULL,
  `organization` VARCHAR(50),
  `event` VARCHAR(50),
  `creation_date` DATETIME,
  `author` VARCHAR(50),
  `text` VARCHAR(50),
  `reason` VARCHAR(50),
  `modification_date` DATETIME,
  `resolved_status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mh_event_comment_reply` (
  `id` BIGINT NOT NULL,
  `event_comment_id` BIGINT,
  `creation_date` DATETIME,
  `author` VARCHAR(50),
  `text` VARCHAR(50),
  `modification_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_083248_mariadb10') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_083248_mariadb10') AS relationships;
DROP DATABASE `db_083248_mariadb10`;
UNINSTALL EXTENSION vsql_schematron;
