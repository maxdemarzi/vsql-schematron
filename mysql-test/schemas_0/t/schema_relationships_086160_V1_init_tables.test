INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086160_V1__init_tables
--echo #
CREATE DATABASE `db_086160_V1_init_tables`;
USE `db_086160_V1_init_tables`;

CREATE TABLE `asset` (
  `id` INT,
  `asset_path` VARCHAR(64),
  `asset_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `identity` VARCHAR(64),
  `secret` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `id` INT,
  `secret` VARCHAR(64),
  `identity` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer` (
  `id` INT,
  `identity` VARCHAR(64),
  `email` VARCHAR(64),
  `thumbnail_id` INT,
  `pr_text` VARCHAR(64),
  `secret` VARCHAR(64),
  `pr_text_short` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer_apply_history` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer_schedule` (
  `id` INT,
  `begin_datetime` DATETIME,
  `end_datetime` DATETIME,
  `lecturer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer_room` (
  `id` INT,
  `lecturer_id` INT,
  `room_name` VARCHAR(64),
  `room_detail` VARCHAR(64),
  `begin_datetime` DATETIME,
  `end_datetime` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086160_V1_init_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086160_V1_init_tables') AS relationships;
DROP DATABASE `db_086160_V1_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
