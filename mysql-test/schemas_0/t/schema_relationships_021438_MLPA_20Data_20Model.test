INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 021438_MLPA%20Data%20Model
--echo #
CREATE DATABASE `db_021438_MLPA_20Data_20Model`;
USE `db_021438_MLPA_20Data_20Model`;

CREATE TABLE `genes` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genes_variants` (
  `gene_id` INT,
  `variation_id` INT
) CHARACTER SET latin1;

CREATE TABLE `variations` (
  `id` INT,
  `variation` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `variations_results` (
  `variation_id` INT,
  `result_id` INT
) CHARACTER SET latin1;

CREATE TABLE `results` (
  `id` INT,
  `result` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `interpretations` (
  `id` INT,
  `interpretations` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `results_interpretations` (
  `result_id` INT,
  `interpretations_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_021438_MLPA_20Data_20Model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_021438_MLPA_20Data_20Model') AS relationships;
DROP DATABASE `db_021438_MLPA_20Data_20Model`;
UNINSTALL EXTENSION vsql_schematron;
