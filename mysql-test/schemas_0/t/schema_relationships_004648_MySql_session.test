INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004648_MySql.session
--echo #
CREATE DATABASE `db_004648_MySql_session`;
USE `db_004648_MySql_session`;
CREATE TABLE `posts` (
  `userId` VARCHAR(50),
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `postId` VARCHAR(50),
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `body` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004648_MySql_session') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004648_MySql_session') AS relationships;
DROP DATABASE `db_004648_MySql_session`;
UNINSTALL EXTENSION vsql_schematron;
