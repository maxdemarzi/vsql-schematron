INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 083759_mhshop
--echo #
CREATE DATABASE `db_083759_mhshop`;
USE `db_083759_mhshop`;
CREATE TABLE `admin-customer` (
  `id` INT NOT NULL,
  `password` VARCHAR(50),
  `is_admin` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categroy` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `image_url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` INT,
  `name` VARCHAR(50),
  `type` VARCHAR(50),
  `price` DOUBLE,
  `image` VARCHAR(50),
  `categroy_id` INT,
  `discount` DOUBLE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_083759_mhshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_083759_mhshop') AS relationships;
DROP DATABASE `db_083759_mhshop`;
UNINSTALL EXTENSION vsql_schematron;
