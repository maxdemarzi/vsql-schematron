INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 055370_01-setup-tables
--echo #
CREATE DATABASE `db_055370_01_setup_tables`;
USE `db_055370_01_setup_tables`;
CREATE TABLE `regions` (
  `region_id` INT NOT NULL,
  `region_name` VARCHAR(50),
  PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `country_id` VARCHAR(50) NOT NULL,
  `country_name` VARCHAR(50),
  `region_id` INT,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `location_id` INT NOT NULL,
  `street_address` VARCHAR(50),
  `postal_code` VARCHAR(50),
  `city` VARCHAR(50),
  `state_province` VARCHAR(50),
  `country_id` CHAR(50),
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_055370_01_setup_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_055370_01_setup_tables') AS relationships;
DROP DATABASE `db_055370_01_setup_tables`;
UNINSTALL EXTENSION vsql_schematron;
