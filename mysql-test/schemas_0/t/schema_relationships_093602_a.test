INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093602_a
--echo #
CREATE DATABASE `db_093602_a`;
USE `db_093602_a`;

CREATE TABLE `a` (
  `id` INT,
  `val` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `a2` (
  `id` INT,
  `val` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `a3` (
  `id` INT,
  `val` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093602_a') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093602_a') AS relationships;
DROP DATABASE `db_093602_a`;
UNINSTALL EXTENSION vsql_schematron;
