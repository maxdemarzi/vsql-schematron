INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 065789_migration
--echo #
CREATE DATABASE `db_065789_migration`;
USE `db_065789_migration`;
CREATE TABLE `Account` (
  `id` INT NOT NULL,
  `userId` INT,
  `providerType` TEXT,
  `providerId` TEXT,
  `providerAccountId` TEXT,
  `refreshToken` TEXT,
  `accessToken` TEXT,
  `accessTokenExpires` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
  `id` INT NOT NULL,
  `userId` INT,
  `expires` DATETIME,
  `sessionToken` TEXT,
  `accessToken` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
  `id` INT NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `emailVerified` DATETIME,
  `image` TEXT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `VerificationRequest` (
  `id` INT NOT NULL,
  `identifier` TEXT,
  `token` TEXT,
  `expires` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_065789_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_065789_migration') AS relationships;
DROP DATABASE `db_065789_migration`;
UNINSTALL EXTENSION vsql_schematron;
