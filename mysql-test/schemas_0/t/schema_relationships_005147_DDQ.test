INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005147_DDQ
--echo #
CREATE DATABASE `db_005147_DDQ`;
USE `db_005147_DDQ`;
CREATE TABLE `groups` (
  `group_id` INT NOT NULL,
  `group_name` VARCHAR(50),
  `group_discount` DECIMAL(10,2),
  PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `customer_id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `group_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `alpacas` (
  `alpaca_id` INT NOT NULL,
  `alpaca_name` VARCHAR(50),
  `age` INT,
  `breed` VARCHAR(50),
  PRIMARY KEY (`alpaca_id`)
) CHARACTER SET latin1;
CREATE TABLE `experiences` (
  `experience_id` INT NOT NULL,
  `experience_name` VARCHAR(50),
  `experience_price` DECIMAL(10,2),
  PRIMARY KEY (`experience_id`)
) CHARACTER SET latin1;
CREATE TABLE `experiences_alpacas` (
  `ea_id` INT NOT NULL,
  `experience_id` INT,
  `alpaca_id` INT,
  PRIMARY KEY (`ea_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `order_id` INT NOT NULL,
  `customer_id` INT,
  `ea_id` INT,
  `ticket_quantity` INT,
  `order_date` DATE,
  `order_subtotal` DECIMAL(10,2),
  PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005147_DDQ') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005147_DDQ') AS relationships;
DROP DATABASE `db_005147_DDQ`;
UNINSTALL EXTENSION vsql_schematron;
