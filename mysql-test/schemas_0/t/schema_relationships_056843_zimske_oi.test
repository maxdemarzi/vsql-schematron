INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 056843_zimske_oi
--echo #
CREATE DATABASE `db_056843_zimske_oi`;
USE `db_056843_zimske_oi`;

CREATE TABLE `disciplina` (
  `id` INT,
  `ime` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `drzava` (
  `kratica` VARCHAR(64),
  `ime` VARCHAR(64),
  PRIMARY KEY (`kratica`)
) CHARACTER SET latin1;

CREATE TABLE `licenca` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `olimpijskeIgre` (
  `leto` INT,
  `drzava` VARCHAR(64),
  PRIMARY KEY (`leto`)
) CHARACTER SET latin1;

CREATE TABLE `poddisciplina` (
  `id` INT,
  `ime` VARCHAR(64),
  `disciplina` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `popravi` (
  `uporabnik` VARCHAR(64),
  `tekmovalec` INT,
  `kajNaredi` VARCHAR(64),
  `razlog` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `rezultat` (
  `id` INT,
  `leto` INT,
  `disciplina` INT,
  `tekmovalec` INT,
  `drzava` VARCHAR(64),
  `mesto` INT,
  `rezultat` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tekmovalec` (
  `id` INT,
  `ime` VARCHAR(64),
  `rojen` DATETIME,
  `drzava` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `uporabnik` (
  `uporabniskoIme` VARCHAR(64),
  `geslo` VARCHAR(64),
  `licenca` VARCHAR(64),
  PRIMARY KEY (`uporabniskoIme`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_056843_zimske_oi') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_056843_zimske_oi') AS relationships;
DROP DATABASE `db_056843_zimske_oi`;
UNINSTALL EXTENSION vsql_schematron;
