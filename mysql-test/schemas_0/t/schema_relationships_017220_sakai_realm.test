INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 017220_sakai_realm
--echo #
CREATE DATABASE `db_017220_sakai_realm`;
USE `db_017220_sakai_realm`;

CREATE TABLE `SAKAI_REALM` (
  `REALM_KEY` INT,
  `REALM_ID` VARCHAR(64),
  `PROVIDER_ID` VARCHAR(64),
  `MAINTAIN_ROLE` INT,
  `CREATEDBY` VARCHAR(64),
  `MODIFIEDBY` VARCHAR(64),
  `CREATEDON` DATETIME,
  `MODIFIEDON` DATETIME,
  PRIMARY KEY (`REALM_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_PROPERTY` (
  `REALM_KEY` INT,
  `NAME` VARCHAR(64),
  `VALUE` VARCHAR(64),
  PRIMARY KEY (`REALM_KEY`, `NAME`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_ROLE` (
  `ROLE_KEY` INT,
  `ROLE_NAME` VARCHAR(64),
  PRIMARY KEY (`ROLE_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_ROLE_DESC` (
  `REALM_KEY` INT,
  `ROLE_KEY` INT,
  `DESCRIPTION` VARCHAR(64),
  `PROVIDER_ONLY` VARCHAR(64),
  PRIMARY KEY (`REALM_KEY`, `ROLE_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_FUNCTION` (
  `FUNCTION_KEY` INT,
  `FUNCTION_NAME` VARCHAR(64),
  PRIMARY KEY (`FUNCTION_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_PROVIDER` (
  `REALM_KEY` INT,
  `PROVIDER_ID` VARCHAR(64),
  PRIMARY KEY (`REALM_KEY`, `PROVIDER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_RL_FN` (
  `REALM_KEY` INT,
  `ROLE_KEY` INT,
  `FUNCTION_KEY` INT,
  PRIMARY KEY (`REALM_KEY`, `ROLE_KEY`, `FUNCTION_KEY`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_RL_GR` (
  `REALM_KEY` INT,
  `USER_ID` VARCHAR(64),
  `ROLE_KEY` INT,
  `ACTIVE` VARCHAR(64),
  `PROVIDED` VARCHAR(64),
  PRIMARY KEY (`REALM_KEY`, `USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SAKAI_REALM_LOCKS` (
  `REALM_KEY` INT,
  `REFERENCE` VARCHAR(64),
  `LOCK_MODE` INT,
  PRIMARY KEY (`REALM_KEY`, `REFERENCE`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_017220_sakai_realm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_017220_sakai_realm') AS relationships;
DROP DATABASE `db_017220_sakai_realm`;
UNINSTALL EXTENSION vsql_schematron;
