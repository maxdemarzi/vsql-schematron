INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015442_1_create_tables
--echo #
CREATE DATABASE `db_015442_1_create_tables`;
USE `db_015442_1_create_tables`;

CREATE TABLE `advisor_users` (
  `steamid64` VARCHAR(64),
  `joined_at` INT,
  `last_seen` INT,
  PRIMARY KEY (`steamid64`)
) CHARACTER SET latin1;

CREATE TABLE `advisor_user_aliases` (
  `steamid64` VARCHAR(64),
  `aliases` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `advisor_roles` (
  `id` INT,
  `name` VARCHAR(64),
  `color` INT,
  `position` INT,
  `hoisted` BOOL,
  `weight` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `advisor_role_permissions` (
  `role_id` INT,
  `permission` VARCHAR(64),
  `value` BOOL
) CHARACTER SET latin1;

CREATE TABLE `advisor_user_permissions` (
  `steamid64` INT,
  `permission` VARCHAR(64),
  `value` BOOL
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015442_1_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015442_1_create_tables') AS relationships;
DROP DATABASE `db_015442_1_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
