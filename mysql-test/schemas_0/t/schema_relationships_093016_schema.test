INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093016_schema
--echo #
CREATE DATABASE `db_093016_schema`;
USE `db_093016_schema`;
CREATE TABLE `run` (
  `file_path` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  `error_message` VARCHAR(50),
  `is_endless` BOOLEAN,
  `left_too_early` BOOLEAN,
  `character` VARCHAR(50),
  `ascension` VARCHAR(50),
  `host` VARCHAR(50),
  `language` VARCHAR(50),
  `victory` BOOLEAN,
  `neow_bonus` VARCHAR(50),
  `play_time` INT,
  `time` INT,
  `floor_reached` INT,
  `score` INT,
  `play_id` VARCHAR(50),
  `local_time` VARCHAR(50),
  `is_ascension_mode` BOOLEAN,
  `circlet_count` INT,
  `seed_played` VARCHAR(50),
  `is_trial` BOOLEAN,
  `campfire_rested` INT,
  `gold` INT,
  `is_daily` BOOLEAN,
  `chose_seed` BOOLEAN,
  `campfire_upgraded` INT,
  `win_rate` DOUBLE,
  `timestamp` INT,
  `build_version` VARCHAR(50),
  `purchased_purges` INT,
  `player_experience` INT,
  `is_beta` BOOLEAN,
  PRIMARY KEY (`file_path`)
) CHARACTER SET latin1;
CREATE TABLE `damage_taken` (
  `run_file_path` VARCHAR(50),
  `enemies` VARCHAR(50),
  `damage` INT,
  `floor` INT,
  `turns` INT
) CHARACTER SET latin1;
CREATE TABLE `killed_by` (
  `run_file_path` VARCHAR(50),
  `enemy_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `card_choice` (
  `run_file_path` VARCHAR(50),
  `card_id` VARCHAR(50),
  `picked` BOOLEAN
) CHARACTER SET latin1;
CREATE TABLE `master_deck` (
  `run_file_path` VARCHAR(50),
  `card_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `relic` (
  `run_file_path` VARCHAR(50),
  `relic_id` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `act_visited` (
  `run_file_path` VARCHAR(50),
  `act_name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `mod` (
  `run_file_path` VARCHAR(50),
  `mod_name` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093016_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093016_schema') AS relationships;
DROP DATABASE `db_093016_schema`;
UNINSTALL EXTENSION vsql_schematron;
