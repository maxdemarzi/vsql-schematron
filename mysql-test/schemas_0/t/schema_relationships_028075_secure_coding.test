INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028075_secure_coding
--echo #
CREATE DATABASE `db_028075_secure_coding`;
USE `db_028075_secure_coding`;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(255),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(255),
  `token` VARCHAR(255),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permission_role` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `permission_user` (
  `permission_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(255),
  `display_name` VARCHAR(255),
  `description` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `role_id` INT,
  `user_id` INT,
  `user_type` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `avatar` VARCHAR(255),
  `ngay_sinh` DATETIME,
  `que_quan` VARCHAR(255),
  `luong` DECIMAL(10,2),
  `phone_number` VARCHAR(255),
  `active` INT,
  `remember_token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028075_secure_coding') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028075_secure_coding') AS relationships;
DROP DATABASE `db_028075_secure_coding`;
UNINSTALL EXTENSION vsql_schematron;
