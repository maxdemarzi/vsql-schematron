INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054823_banco
--echo #
CREATE DATABASE `db_054823_banco`;
USE `db_054823_banco`;
CREATE TABLE `BOMBA` (
  `COD_BOMBA` INT NOT NULL,
  `DES_BOM` VARCHAR(50),
  PRIMARY KEY (`COD_BOMBA`)
) CHARACTER SET latin1;
CREATE TABLE `COMBUSTIVEL` (
  `COD_COMBUSTIVEL` INT NOT NULL,
  `DES_COMBUSTIVEL` VARCHAR(50),
  `PRC_COMBUSTIVEL` DOUBLE,
  `IMPOSTO` DOUBLE,
  PRIMARY KEY (`COD_COMBUSTIVEL`)
) CHARACTER SET latin1;
CREATE TABLE `FRENTISTA` (
  `COD_FRENTISTA` INT NOT NULL,
  `DES_FRENTISTA` VARCHAR(50),
  PRIMARY KEY (`COD_FRENTISTA`)
) CHARACTER SET latin1;
CREATE TABLE `TANQUE` (
  `COD_TANQUE` INT NOT NULL,
  `DES_TANQUE` VARCHAR(50),
  `QTD_VOLUME` DOUBLE,
  PRIMARY KEY (`COD_TANQUE`)
) CHARACTER SET latin1;
CREATE TABLE `VENDA` (
  `COD_MOVIMENTO` INT NOT NULL,
  `DAT_MOVIMENTO` DATE,
  `COD_TANQUE` INT,
  `COD_BOMBA` INT,
  `COD_COMBUSTIVEL` INT,
  `COD_FRENTISTA` INT,
  `QTD_LITRO` DOUBLE,
  `PRC_LITRO` DOUBLE,
  `IMPOSTO` DOUBLE,
  `VAL_IMPOSTO` DOUBLE,
  `VAL_VENDA` DOUBLE,
  PRIMARY KEY (`COD_MOVIMENTO`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054823_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054823_banco') AS relationships;
DROP DATABASE `db_054823_banco`;
UNINSTALL EXTENSION vsql_schematron;
