INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070947_schema.pgsql
--echo #
CREATE DATABASE `db_070947_schema_pgsql`;
USE `db_070947_schema_pgsql`;
CREATE TABLE `pictures` (
  `id` INT NOT NULL,
  `digest` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sentpictures` (
  `id` INT NOT NULL,
  `url` CHAR(50),
  `sender` CHAR(50),
  `picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signatures` (
  `id` INT NOT NULL,
  `compressed_signature` VARCHAR(50),
  `picture_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `words` (
  `pos_and_word` VARCHAR(50),
  `signature_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070947_schema_pgsql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070947_schema_pgsql') AS relationships;
DROP DATABASE `db_070947_schema_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
