INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 082284_V1__create_tables
--echo #
CREATE DATABASE `db_082284_V1_create_tables`;
USE `db_082284_V1_create_tables`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `image_url` VARCHAR(64),
  `role` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `links` (
  `id` INT,
  `url` VARCHAR(64),
  `title` VARCHAR(64),
  `created_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `link_tag` (
  `link_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_082284_V1_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_082284_V1_create_tables') AS relationships;
DROP DATABASE `db_082284_V1_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
