INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000795_V002__init
--echo #
CREATE DATABASE `db_000795_V002_init`;
USE `db_000795_V002_init`;

CREATE TABLE `contents` (
  `sha224` VARCHAR(64),
  `contents` VARCHAR(64),
  PRIMARY KEY (`sha224`)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `id` INT,
  `name` VARCHAR(64),
  `mimetype` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `files` (
  `id` VARCHAR(64),
  `type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `versions` (
  `id` VARCHAR(64),
  `file_id` VARCHAR(64),
  `contents_sha` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `documents` (
  `id` VARCHAR(64),
  `external_id` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `documents_files` (
  `document_id` VARCHAR(64),
  `file_id` VARCHAR(64),
  PRIMARY KEY (`document_id`, `file_id`)
) CHARACTER SET latin1;

CREATE TABLE `documents_metadata` (
  `document_id` VARCHAR(64),
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`document_id`, `key`)
) CHARACTER SET latin1;

CREATE TABLE `files_metadata` (
  `file_id` VARCHAR(64),
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`file_id`, `key`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000795_V002_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000795_V002_init') AS relationships;
DROP DATABASE `db_000795_V002_init`;
UNINSTALL EXTENSION vsql_schematron;
