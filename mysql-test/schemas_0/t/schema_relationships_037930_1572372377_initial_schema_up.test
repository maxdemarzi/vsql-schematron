INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037930_1572372377_initial_schema_up
--echo #
CREATE DATABASE `db_037930_1572372377_initial_schema_up`;
USE `db_037930_1572372377_initial_schema_up`;

CREATE TABLE `mvds_messages` (
  `id` VARCHAR(255),
  `group_id` VARCHAR(255),
  `timestamp` INT,
  `body` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mvds_parents` (
  `message_id` VARCHAR(255),
  `parent_id` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037930_1572372377_initial_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037930_1572372377_initial_schema_up') AS relationships;
DROP DATABASE `db_037930_1572372377_initial_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
