INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 052281_migration
--echo #
CREATE DATABASE `db_052281_migration`;
USE `db_052281_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `location` VARCHAR(64),
  `avatarUrl` VARCHAR(64),
  `githubUsername` VARCHAR(64),
  `createAt` DATETIME,
  `updateAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CoffeeShop` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `latitude` VARCHAR(64),
  `longitude` VARCHAR(64),
  `userId` VARCHAR(64),
  `createAt` DATETIME,
  `updateAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CoffeeShopPhoto` (
  `id` VARCHAR(64),
  `url` VARCHAR(64),
  `shopId` VARCHAR(64),
  `createAt` DATETIME,
  `updateAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Category` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `createAt` DATETIME,
  `updateAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CoffeeShopToCategory` (
  `shopId` VARCHAR(64),
  `categoryId` VARCHAR(64),
  `createAt` DATETIME,
  `updateAt` DATETIME,
  PRIMARY KEY (`shopId`, `categoryId`)
) CHARACTER SET latin1;

CREATE TABLE `_followRelation` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_052281_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_052281_migration') AS relationships;
DROP DATABASE `db_052281_migration`;
UNINSTALL EXTENSION vsql_schematron;
