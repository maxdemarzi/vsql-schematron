INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061458_GB
--echo #
CREATE DATABASE `db_061458_GB`;
USE `db_061458_GB`;
CREATE TABLE `BRANCH` (
  `branch_num` VARCHAR(50) NOT NULL,
  `branch_manager_email` VARCHAR(50),
  `branch_address` VARCHAR(50),
  `branch_phone` VARCHAR(50),
  `branch_img` VARCHAR(50),
  `branch_website` VARCHAR(50),
  `branch_point` DECIMAL(10,2),
  `branch_option_shower` VARCHAR(50),
  `branch_option_park` VARCHAR(50),
  `branch_option_uniform` VARCHAR(50),
  `branch_option_shoes` VARCHAR(50),
  `branch_option_ball` VARCHAR(50),
  `branch_option_inout` VARCHAR(50),
  `branch_delete_status` VARCHAR(50),
  PRIMARY KEY (`branch_num`)
) CHARACTER SET latin1;
CREATE TABLE `REVIEW` (
  `review_num` DECIMAL(10,2) NOT NULL,
  `review_email` VARCHAR(50),
  `branch_num` VARCHAR(50),
  `review_content` VARCHAR(50),
  `review_point` DECIMAL(10,2),
  PRIMARY KEY (`review_num`)
) CHARACTER SET latin1;
CREATE TABLE `STADIUM` (
  `stadium_num` DECIMAL(10,2) NOT NULL,
  `stadium_branch_num` VARCHAR(50),
  `stadium_name` VARCHAR(50),
  `stadium_match_member` VARCHAR(50),
  `stadium_reservation_start_time` DECIMAL(10,2),
  `stadium_reservation_end_time` DECIMAL(10,2),
  `stadium_delete_status` VARCHAR(50),
  PRIMARY KEY (`stadium_num`)
) CHARACTER SET latin1;
CREATE TABLE `BOARD` (
  `board_num` DECIMAL(10,2) NOT NULL,
  `writer_email` VARCHAR(50),
  `board_title` VARCHAR(50),
  `board_content` VARCHAR(50),
  `board_img` VARCHAR(50),
  `board_date` DATE,
  PRIMARY KEY (`board_num`)
) CHARACTER SET latin1;
CREATE TABLE `TEAM` (
  `team_code` VARCHAR(50) NOT NULL,
  `team_leader` VARCHAR(50),
  `team_num` DECIMAL(10,2),
  `team_name` VARCHAR(50),
  `team_gender` VARCHAR(50),
  `team_age` VARCHAR(50),
  `team_region` VARCHAR(50),
  `team_point` DECIMAL(10,2),
  `team_mark_img` VARCHAR(50),
  `team_active_lastday` DATE,
  `team_delete_status` VARCHAR(50),
  PRIMARY KEY (`team_code`)
) CHARACTER SET latin1;
CREATE TABLE `NOTICE` (
  `notice_email` VARCHAR(50),
  `notice_type` VARCHAR(50),
  `notice_content` VARCHAR(50),
  `notice_start_time` DATE,
  `notice_delete_status` VARCHAR(50),
  `notice_team_code` VARCHAR(50),
  `notice_reservation_code` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `TEAMMEMBER` (
  `supporter_email` VARCHAR(50),
  `support_team` VARCHAR(50),
  `teammember_num` DECIMAL(10,2),
  `position` VARCHAR(50),
  `application_status` VARCHAR(50),
  `delete_status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `MATCHREGIST` (
  `regist_num` DECIMAL(10,2) NOT NULL,
  `regist_team` VARCHAR(50),
  `regist_reservation_code` VARCHAR(50),
  `regist_status` VARCHAR(50),
  `regist_stadium_num` DECIMAL(10,2),
  PRIMARY KEY (`regist_num`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVATION` (
  `reservation_code` VARCHAR(50) NOT NULL,
  `reservation_email` VARCHAR(50),
  `reservation_stadium_num` DECIMAL(10,2),
  `reservation_num` DECIMAL(10,2),
  `reservation_price` DECIMAL(10,2),
  `reservation_usage_start_time` DECIMAL(10,2),
  `reservation_usage_time` DECIMAL(10,2),
  `reservation_usage_end_time` DECIMAL(10,2),
  `reservation_usage_start_date` DATE,
  `reservation_status` VARCHAR(50),
  PRIMARY KEY (`reservation_code`)
) CHARACTER SET latin1;
CREATE TABLE `MATCH` (
  `match_regist_num` DECIMAL(10,2),
  `match_team` VARCHAR(50),
  `match_num` DECIMAL(10,2),
  `match_application_status` VARCHAR(50),
  `match_winlose` VARCHAR(50),
  `manager_point_status` VARCHAR(50),
  `match_stadium_num` DECIMAL(10,2),
  `match_branch_num` VARCHAR(50),
  `match_reservation_code` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061458_GB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061458_GB') AS relationships;
DROP DATABASE `db_061458_GB`;
UNINSTALL EXTENSION vsql_schematron;
