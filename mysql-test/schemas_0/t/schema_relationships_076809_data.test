INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076809_data
--echo #
CREATE DATABASE `db_076809_data`;
USE `db_076809_data`;
CREATE TABLE `RESTAURANT` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `ADDRESS` VARCHAR(50),
  `CITY` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REVIEW` (
  `ID` INT NOT NULL,
  `MESSAGE` VARCHAR(50),
  `RATING` INT,
  `RESTAURANT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REPLY` (
  `ID` INT NOT NULL,
  `MESSAGE` VARCHAR(50),
  `REVIEW_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076809_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076809_data') AS relationships;
DROP DATABASE `db_076809_data`;
UNINSTALL EXTENSION vsql_schematron;
