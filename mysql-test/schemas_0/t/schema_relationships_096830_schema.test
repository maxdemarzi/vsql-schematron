INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 096830_schema
--echo #
CREATE DATABASE `db_096830_schema`;
USE `db_096830_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tests` (
  `id` INT NOT NULL,
  `user_id` INT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `issues` (
  `id` INT NOT NULL,
  `test_id` INT,
  `description` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_096830_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_096830_schema') AS relationships;
DROP DATABASE `db_096830_schema`;
UNINSTALL EXTENSION vsql_schematron;
