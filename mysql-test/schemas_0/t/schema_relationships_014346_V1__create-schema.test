INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014346_V1__create-schema
--echo #
CREATE DATABASE `db_014346_V1__create_schema`;
USE `db_014346_V1__create_schema`;
CREATE TABLE `tenants` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `tenant_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `username` VARCHAR(50) NOT NULL,
  `encoded_password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `groups_users` (
  `id` INT NOT NULL,
  `group_id` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014346_V1__create_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014346_V1__create_schema') AS relationships;
DROP DATABASE `db_014346_V1__create_schema`;
UNINSTALL EXTENSION vsql_schematron;
