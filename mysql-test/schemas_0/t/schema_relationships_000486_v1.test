INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000486_v1
--echo #
CREATE DATABASE `db_000486_v1`;
USE `db_000486_v1`;
CREATE TABLE `pings` (
  `id` VARCHAR(50) NOT NULL,
  `date` INT,
  `userId` TEXT,
  `isFirstPing` INT,
  `ip` TEXT,
  `beakerVersion` TEXT,
  `os` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
  `id` VARCHAR(50) NOT NULL,
  `computeDate` INT,
  `activeUserCount` INT,
  `totalUserCount` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `report_data` (
  `reportId` TEXT,
  `data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `report_active_user_cohorts` (
  `reportId` TEXT,
  `startWeek` TEXT,
  `totalCount` INT,
  `stillActiveCount` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000486_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000486_v1') AS relationships;
DROP DATABASE `db_000486_v1`;
UNINSTALL EXTENSION vsql_schematron;
