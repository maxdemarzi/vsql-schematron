INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 089760_clean
--echo #
CREATE DATABASE `db_089760_clean`;
USE `db_089760_clean`;

CREATE TABLE `zv_accounts` (
  `id` INT,
  `organization_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_credentials` (
  `id` INT,
  `account_id` INT,
  `section_id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `value` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_organizations` (
  `id` INT,
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_sections` (
  `id` INT,
  `account_id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_tags` (
  `id` INT,
  `name` VARCHAR(64),
  `encrypted` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_tag_accounts` (
  `tag_id` INT,
  `account_id` INT,
  PRIMARY KEY (`tag_id`, `account_id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_tag_credentials` (
  `tag_id` INT,
  `credential_id` INT,
  PRIMARY KEY (`tag_id`, `credential_id`)
) CHARACTER SET latin1;

CREATE TABLE `zv_tag_sections` (
  `tag_id` INT,
  `section_id` INT,
  PRIMARY KEY (`tag_id`, `section_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_089760_clean') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_089760_clean') AS relationships;
DROP DATABASE `db_089760_clean`;
UNINSTALL EXTENSION vsql_schematron;
