INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062668_tables
--echo #
CREATE DATABASE `db_062668_tables`;
USE `db_062668_tables`;

CREATE TABLE `category` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `id` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `published` DATETIME,
  `edited` DATETIME,
  `image` VARCHAR(64),
  `caption` VARCHAR(64),
  `lead` VARCHAR(64),
  `text` VARCHAR(64),
  `category` VARCHAR(64),
  `priority` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `nickname` VARCHAR(64),
  `text` VARCHAR(64),
  `published` DATETIME,
  `articleId` INT,
  PRIMARY KEY (`nickname`, `text`)
) CHARACTER SET latin1;

CREATE TABLE `rating` (
  `id` INT,
  `value` INT,
  `articleId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062668_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062668_tables') AS relationships;
DROP DATABASE `db_062668_tables`;
UNINSTALL EXTENSION vsql_schematron;
