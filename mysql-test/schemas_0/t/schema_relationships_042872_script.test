INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 042872_script
--echo #
CREATE DATABASE `db_042872_script`;
USE `db_042872_script`;
CREATE TABLE `termo` (
  `id_termo` VARCHAR(50) NOT NULL,
  `ds_termo` VARCHAR(50),
  PRIMARY KEY (`id_termo`)
) CHARACTER SET latin1;
CREATE TABLE `pesquisa` (
  `id_pesquisa` VARCHAR(50) NOT NULL,
  `dt_pesquisa` DATETIME,
  `id_termo` VARCHAR(50),
  PRIMARY KEY (`id_pesquisa`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id_post` VARCHAR(50) NOT NULL,
  `ds_post` VARCHAR(50),
  PRIMARY KEY (`id_post`)
) CHARACTER SET latin1;
CREATE TABLE `pesquisa_post` (
  `id_pesquisa_post` VARCHAR(50) NOT NULL,
  `id_pesquisa` VARCHAR(50),
  `id_post` VARCHAR(50),
  PRIMARY KEY (`id_pesquisa_post`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_042872_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_042872_script') AS relationships;
DROP DATABASE `db_042872_script`;
UNINSTALL EXTENSION vsql_schematron;
