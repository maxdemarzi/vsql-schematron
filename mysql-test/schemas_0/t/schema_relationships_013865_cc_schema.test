INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013865_cc_schema
--echo #
CREATE DATABASE `db_013865_cc_schema`;
USE `db_013865_cc_schema`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `subject` VARCHAR(64),
  `consent_given` VARCHAR(64),
  `delete_requested` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `events` (
  `event_id` VARCHAR(64),
  `event_name` VARCHAR(64),
  `point_value` INT,
  `location` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  `description` VARCHAR(64),
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_event` (
  `usr` VARCHAR(64),
  `event` VARCHAR(64),
  PRIMARY KEY (`usr`, `event`)
) CHARACTER SET latin1;

CREATE TABLE `transactions` (
  `transaction_id` VARCHAR(64),
  `usr` VARCHAR(64),
  `transaction_name` VARCHAR(64),
  `amount` DECIMAL(10,2),
  `category` VARCHAR(64),
  `points_earned` DECIMAL(10,2),
  `processed` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`transaction_id`, `usr`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013865_cc_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013865_cc_schema') AS relationships;
DROP DATABASE `db_013865_cc_schema`;
UNINSTALL EXTENSION vsql_schematron;
