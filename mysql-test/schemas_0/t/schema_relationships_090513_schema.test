INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 090513_schema
--echo #
CREATE DATABASE `db_090513_schema`;
USE `db_090513_schema`;
CREATE TABLE `USER` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `EMAIL` VARCHAR(50),
  `PASSWORD` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ADVERTISEMENT` (
  `ID` INT NOT NULL,
  `CREATE_DATE` DATE,
  `TITLE` VARCHAR(50),
  `TEXT` VARCHAR(50),
  `USER_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_090513_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_090513_schema') AS relationships;
DROP DATABASE `db_090513_schema`;
UNINSTALL EXTENSION vsql_schematron;
