INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041291_create_table_model
--echo #
CREATE DATABASE `db_041291_create_table_model`;
USE `db_041291_create_table_model`;

CREATE TABLE `org.Contact` (
  `ContactId` VARCHAR(255),
  `DateOfBirth` DATETIME,
  `FirstName` VARCHAR(255),
  `LastName` VARCHAR(255),
  `HeightFt` INT,
  `HeightInch` INT,
  `Picture` VARCHAR(255),
  `PreferredHeight` VARCHAR(255),
  PRIMARY KEY (`ContactId`)
) CHARACTER SET latin1;

CREATE TABLE `org.Organization` (
  `OrganizationId` VARCHAR(255),
  `Name` VARCHAR(255),
  PRIMARY KEY (`OrganizationId`)
) CHARACTER SET latin1;

CREATE TABLE `org.WorkHistory` (
  `WorkHistoryId` VARCHAR(255),
  `ContactId` VARCHAR(255),
  `OrganizationId` VARCHAR(255),
  `StartMonth` VARCHAR(255),
  `StartYear` VARCHAR(255),
  `EndMonth` VARCHAR(255),
  `EndYear` VARCHAR(255),
  `JobDescription` VARCHAR(255),
  `JobTitle` VARCHAR(255),
  PRIMARY KEY (`WorkHistoryId`)
) CHARACTER SET latin1;

CREATE TABLE `org.ContactLink` (
  `SourceContactId` VARCHAR(255),
  `TargetContactId` VARCHAR(255),
  `WorkHistoryId` VARCHAR(255),
  PRIMARY KEY (`SourceContactId`, `TargetContactId`, `WorkHistoryId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041291_create_table_model') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041291_create_table_model') AS relationships;
DROP DATABASE `db_041291_create_table_model`;
UNINSTALL EXTENSION vsql_schematron;
