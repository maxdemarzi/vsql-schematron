INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 089131_database
--echo #
CREATE DATABASE `db_089131_database`;
USE `db_089131_database`;

CREATE TABLE `KvKickstart.presentors` (
  `id` INT,
  `name` VARCHAR(64),
  `company` VARCHAR(64),
  `email` VARCHAR(64),
  `twitter` VARCHAR(64),
  `linkedIn` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `KvKickstart.presentations` (
  `id` INT,
  `title` VARCHAR(64),
  `city` VARCHAR(64),
  `time` DATETIME,
  `presenterId` INT,
  `building` VARCHAR(64),
  `distance` VARCHAR(64),
  `content` VARCHAR(64),
  `impresentationsageUrl` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_089131_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_089131_database') AS relationships;
DROP DATABASE `db_089131_database`;
UNINSTALL EXTENSION vsql_schematron;
