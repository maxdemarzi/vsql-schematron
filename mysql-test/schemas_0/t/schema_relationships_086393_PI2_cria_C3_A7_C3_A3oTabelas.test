INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086393_PI2_cria%C3%A7%C3%A3oTabelas
--echo #
CREATE DATABASE `db_086393_PI2_cria_C3_A7_C3_A3oTabelas`;
USE `db_086393_PI2_cria_C3_A7_C3_A3oTabelas`;
CREATE TABLE `Pacientes` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `cpf` VARCHAR(50),
  `telefone` VARCHAR(50),
  `endereco` VARCHAR(50),
  `dataNascimento` DATE,
  `senha` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Medicos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `especialidade` VARCHAR(50),
  `CRM` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Agenda` (
  `id` INT NOT NULL,
  `horario` TIME,
  `dia` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Agenda_Medico` (
  `id` INT NOT NULL,
  `idMedico` INT,
  `idAgenda` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consulta_paciente` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `medico` VARCHAR(50),
  `especialidade` VARCHAR(50),
  `horario` TIME,
  `dia` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086393_PI2_cria_C3_A7_C3_A3oTabelas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086393_PI2_cria_C3_A7_C3_A3oTabelas') AS relationships;
DROP DATABASE `db_086393_PI2_cria_C3_A7_C3_A3oTabelas`;
UNINSTALL EXTENSION vsql_schematron;
