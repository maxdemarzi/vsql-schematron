INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 075618_database_schema
--echo #
CREATE DATABASE `db_075618_database_schema`;
USE `db_075618_database_schema`;

CREATE TABLE `users` (
  `user_id` INT,
  `user_url` VARCHAR(64),
  `user_image` VARCHAR(64),
  `user_alias` VARCHAR(64),
  `user_address` VARCHAR(64),
  `data_signature` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `campaigns` (
  `campaign_id` INT,
  `title` VARCHAR(64),
  `starts` INT,
  `expires` INT,
  `proposal` VARCHAR(64),
  `abstract` VARCHAR(64),
  `proposalZH` VARCHAR(64),
  `abstractZH` VARCHAR(64),
  `proposalES` VARCHAR(64),
  `abstractES` VARCHAR(64),
  `proposalJA` VARCHAR(64),
  `abstractJA` VARCHAR(64),
  PRIMARY KEY (`campaign_id`)
) CHARACTER SET latin1;

CREATE TABLE `fullfillments` (
  `fullfillment_id` INT,
  `fullfillment_timestamp` INT,
  `fullfillment_transaction` VARCHAR(64),
  `campaign_id` INT,
  PRIMARY KEY (`fullfillment_id`)
) CHARACTER SET latin1;

CREATE TABLE `recipients` (
  `recipient_id` INT,
  `recipient_satoshis` INT,
  `user_id` INT,
  `campaign_id` INT,
  PRIMARY KEY (`recipient_id`)
) CHARACTER SET latin1;

CREATE TABLE `revocations` (
  `revocation_id` INT,
  `revocation_timestamp` INT,
  `revocation_transaction` VARCHAR(64),
  `commitment_id` INT,
  PRIMARY KEY (`revocation_id`)
) CHARACTER SET latin1;

CREATE TABLE `commitments` (
  `commitment_id` INT,
  `previous_transaction_hash` VARCHAR(64),
  `previous_transaction_index` INT,
  `unlock_script` VARCHAR(64),
  `sequence_number` INT,
  `satoshis` INT,
  `address` VARCHAR(64),
  PRIMARY KEY (`commitment_id`)
) CHARACTER SET latin1;

CREATE TABLE `contributions` (
  `contribution_id` INT,
  `user_id` INT,
  `campaign_id` INT,
  `contribution_timestamp` INT,
  `contribution_comment` VARCHAR(64),
  PRIMARY KEY (`contribution_id`)
) CHARACTER SET latin1;

CREATE TABLE `contributionCommitments` (
  `contribution_id` INT,
  `commitment_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_075618_database_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_075618_database_schema') AS relationships;
DROP DATABASE `db_075618_database_schema`;
UNINSTALL EXTENSION vsql_schematron;
