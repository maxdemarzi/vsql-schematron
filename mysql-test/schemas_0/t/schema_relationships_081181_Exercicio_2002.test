INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081181_Exercicio%2002
--echo #
CREATE DATABASE `db_081181_Exercicio_2002`;
USE `db_081181_Exercicio_2002`;
CREATE TABLE `tb_categorias` (
  `id_categoria` INT NOT NULL,
  `nome_categoria` VARCHAR(50),
  `preco` DOUBLE,
  `validade_pizza` DATE,
  PRIMARY KEY (`id_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pizza` (
  `id_venda` INT NOT NULL,
  `hora_venda` TIME,
  `tipo_entrega` VARCHAR(50),
  `metodo_pagamento` VARCHAR(50),
  `complemento` VARCHAR(50),
  `fk_categorias` INT,
  PRIMARY KEY (`id_venda`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081181_Exercicio_2002') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081181_Exercicio_2002') AS relationships;
DROP DATABASE `db_081181_Exercicio_2002`;
UNINSTALL EXTENSION vsql_schematron;
