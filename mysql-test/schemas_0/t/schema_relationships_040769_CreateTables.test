INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040769_CreateTables
--echo #
CREATE DATABASE `db_040769_CreateTables`;
USE `db_040769_CreateTables`;
CREATE TABLE `Users` (
  `id` INT NOT NULL,
  `name` TEXT,
  `lastname` TEXT,
  `tag` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Checks` (
  `id` INT,
  `userId` INT,
  `time` TEXT,
  `inout` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040769_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040769_CreateTables') AS relationships;
DROP DATABASE `db_040769_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
