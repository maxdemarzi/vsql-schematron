INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002708_schema
--echo #
CREATE DATABASE `db_002708_schema`;
USE `db_002708_schema`;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `display_name` VARCHAR(50),
  `importance` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `email` VARCHAR(50),
  `pass` VARCHAR(50),
  `salt` VARCHAR(50),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sessions` (
  `id` INT NOT NULL,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002708_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002708_schema') AS relationships;
DROP DATABASE `db_002708_schema`;
UNINSTALL EXTENSION vsql_schematron;
