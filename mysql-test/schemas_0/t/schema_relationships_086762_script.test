INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086762_script
--echo #
CREATE DATABASE `db_086762_script`;
USE `db_086762_script`;

CREATE TABLE `users` (
  `id` INT,
  `pp` VARCHAR(64),
  `fullname` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `pass` VARCHAR(64),
  `nid` VARCHAR(64),
  `dob` VARCHAR(64),
  `gender` VARCHAR(64),
  `address` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `zip` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cases` (
  `id` INT,
  `case_title` VARCHAR(64),
  `case_description` VARCHAR(64),
  `date_added` VARCHAR(64),
  `hearing_date` VARCHAR(64),
  `case_status` VARCHAR(64),
  `document` VARCHAR(64),
  `client_id` INT,
  `complainant_id` INT,
  `judge_id` INT,
  `lawyer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chats` (
  `id` INT,
  `message` VARCHAR(64),
  `sender_id` INT,
  `receiver_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clients` (
  `id` INT,
  `client_id` INT,
  `lawyer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `documents` (
  `id` INT,
  `document` VARCHAR(64),
  `viewer_id` INT,
  `uploader_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `meetings` (
  `id` INT,
  `attandee_name` VARCHAR(64),
  `organizer_name` VARCHAR(64),
  `meeting_title` VARCHAR(64),
  `meeting_description` VARCHAR(64),
  `meeting_time` VARCHAR(64),
  `attandee_id` INT,
  `organizer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `id` INT,
  `due` VARCHAR(64),
  `paid` VARCHAR(64),
  `balance` VARCHAR(64),
  `due_date` VARCHAR(64),
  `payment_date` VARCHAR(64),
  `payer_id` INT,
  `receiver_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reports` (
  `id` INT,
  `monthly` VARCHAR(64),
  `weekly` VARCHAR(64),
  `transactions` VARCHAR(64),
  `date_generated` VARCHAR(64),
  `generator_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `review` VARCHAR(64),
  `rating` VARCHAR(64),
  `reviewer_id` INT,
  `reviewee_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086762_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086762_script') AS relationships;
DROP DATABASE `db_086762_script`;
UNINSTALL EXTENSION vsql_schematron;
