INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097732_music_schema
--echo #
CREATE DATABASE `db_097732_music_schema`;
USE `db_097732_music_schema`;

CREATE TABLE `Artist` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Album` (
  `id` INT,
  `name` VARCHAR(64),
  `release_date` DATETIME,
  `artist` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Membership` (
  `artist` INT,
  `band` INT
) CHARACTER SET latin1;

CREATE TABLE `Track` (
  `id` INT,
  `name` VARCHAR(64),
  `album` INT,
  `length` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Songwriter` (
  `song` INT,
  `writer` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097732_music_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097732_music_schema') AS relationships;
DROP DATABASE `db_097732_music_schema`;
UNINSTALL EXTENSION vsql_schematron;
