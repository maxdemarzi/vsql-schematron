INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 012366_dbinfox
--echo #
CREATE DATABASE `db_012366_dbinfox`;
USE `db_012366_dbinfox`;
CREATE TABLE `tbclientes` (
  `idcli` INT NOT NULL,
  `nomecli` VARCHAR(50),
  `endcli` VARCHAR(50),
  `fonecli` VARCHAR(50),
  `emailcli` VARCHAR(50),
  PRIMARY KEY (`idcli`)
) CHARACTER SET latin1;
CREATE TABLE `tbos` (
  `os` INT,
  `data_os` TIMESTAMP NULL,
  `equipanto` VARCHAR(50),
  `defeito` VARCHAR(50),
  `servico` VARCHAR(50),
  `tecnico` VARCHAR(50),
  `valor` DECIMAL(10,2),
  `idcli` INT
) CHARACTER SET latin1;
CREATE TABLE `tbusuarios` (
  `iduser` INT,
  `usuario` VARCHAR(50),
  `fone` VARCHAR(50),
  `login` VARCHAR(50),
  `senha` VARCHAR(50),
  `perfil` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_012366_dbinfox') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_012366_dbinfox') AS relationships;
DROP DATABASE `db_012366_dbinfox`;
UNINSTALL EXTENSION vsql_schematron;
