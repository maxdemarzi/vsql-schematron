INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086174_mysql_schema_v2
--echo #
CREATE DATABASE `db_086174_mysql_schema_v2`;
USE `db_086174_mysql_schema_v2`;
CREATE TABLE `time_kind` (
  `kind_id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`kind_id`)
) CHARACTER SET latin1;
CREATE TABLE `code` (
  `code_id` INT NOT NULL,
  `code_ir` TEXT,
  `code_raw` TEXT,
  PRIMARY KEY (`code_id`)
) CHARACTER SET latin1;
CREATE TABLE `time` (
  `time_id` INT NOT NULL,
  `code_id` INT,
  `arch_id` INT,
  `kind_id` INT,
  `cycle_count` INT,
  PRIMARY KEY (`time_id`)
) CHARACTER SET latin1;
CREATE TABLE `time_metadata` (
  `metadata_id` INT NOT NULL,
  `time_id` INT,
  `l1drmisses` INT,
  `l1dwmisses` INT,
  `l1imisses` INT,
  `conswitch` INT,
  PRIMARY KEY (`metadata_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086174_mysql_schema_v2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086174_mysql_schema_v2') AS relationships;
DROP DATABASE `db_086174_mysql_schema_v2`;
UNINSTALL EXTENSION vsql_schematron;
