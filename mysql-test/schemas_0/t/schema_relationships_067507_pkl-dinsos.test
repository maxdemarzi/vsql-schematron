INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067507_pkl-dinsos
--echo #
CREATE DATABASE `db_067507_pkl_dinsos`;
USE `db_067507_pkl_dinsos`;
CREATE TABLE `laporan` (
  `id_laporan` INT,
  `id_user` INT,
  `nama_tksk` VARCHAR(50),
  `tanggal` DATE,
  `uraian_tempat` VARCHAR(50),
  `pelaksana` VARCHAR(50),
  `sasaran` VARCHAR(50),
  `materi` VARCHAR(50),
  `hasil_kegiatan` VARCHAR(50),
  `faktor_pendukung_penghambat` VARCHAR(50),
  `upaya_pemecahan` VARCHAR(50),
  `rencana_kerja` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `login` (
  `id_user` INT NOT NULL,
  `nama_lengkap` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `level` VARCHAR(50),
  `email` VARCHAR(50),
  `kecamatan` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067507_pkl_dinsos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067507_pkl_dinsos') AS relationships;
DROP DATABASE `db_067507_pkl_dinsos`;
UNINSTALL EXTENSION vsql_schematron;
