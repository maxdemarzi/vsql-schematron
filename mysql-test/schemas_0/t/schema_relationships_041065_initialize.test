INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041065_initialize
--echo #
CREATE DATABASE `db_041065_initialize`;
USE `db_041065_initialize`;

CREATE TABLE `player` (
  `player_id` INT,
  `player_name` VARCHAR(255),
  `current_room` VARCHAR(255),
  `creation_timestamp` DATETIME,
  PRIMARY KEY (`player_id`)
) CHARACTER SET latin1;

CREATE TABLE `room` (
  `room_id` VARCHAR(255),
  `room_name` VARCHAR(255),
  `admin_id` INT,
  PRIMARY KEY (`room_id`)
) CHARACTER SET latin1;

CREATE TABLE `ticket` (
  `ticket_id` INT,
  `ticket_name` VARCHAR(255),
  `order_index` INT,
  `state` VARCHAR(255),
  `room_id` VARCHAR(255),
  PRIMARY KEY (`ticket_id`)
) CHARACTER SET latin1;

CREATE TABLE `vote` (
  `player_id` INT,
  `ticket_id` INT,
  `vote_value` INT,
  PRIMARY KEY (`player_id`, `ticket_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041065_initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041065_initialize') AS relationships;
DROP DATABASE `db_041065_initialize`;
UNINSTALL EXTENSION vsql_schematron;
