INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054798_question_answer.postgres
--echo #
CREATE DATABASE `db_054798_question_answer_postgres`;
USE `db_054798_question_answer_postgres`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password_digest` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `questions` (
  `id` INT,
  `author_id` INT,
  `best_answer_id` INT,
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answers` (
  `id` INT,
  `author_id` INT,
  `question_id` INT,
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answer_votes` (
  `id` INT,
  `answer_id` INT,
  `voter_id` INT,
  `score` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054798_question_answer_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054798_question_answer_postgres') AS relationships;
DROP DATABASE `db_054798_question_answer_postgres`;
UNINSTALL EXTENSION vsql_schematron;
