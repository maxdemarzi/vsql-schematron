INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 012320_20200906203539-initial
--echo #
CREATE DATABASE `db_012320_20200906203539_initial`;
USE `db_012320_20200906203539_initial`;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_012320_20200906203539_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_012320_20200906203539_initial') AS relationships;
DROP DATABASE `db_012320_20200906203539_initial`;
UNINSTALL EXTENSION vsql_schematron;
