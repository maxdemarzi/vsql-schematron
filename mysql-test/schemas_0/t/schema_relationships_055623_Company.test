INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 055623_Company
--echo #
CREATE DATABASE `db_055623_Company`;
USE `db_055623_Company`;

CREATE TABLE `EMPLOYEE` (
  `SSN` VARCHAR(64),
  `Name` VARCHAR(64),
  `Address` VARCHAR(64),
  `Sex` VARCHAR(64),
  `Salary` DECIMAL(10,2),
  `SuperSSN` VARCHAR(64),
  `DNo` VARCHAR(64),
  PRIMARY KEY (`SSN`)
) CHARACTER SET latin1;

CREATE TABLE `DEPARTMENT` (
  `DNo` VARCHAR(64),
  `DName` VARCHAR(64),
  `MgrSSN` VARCHAR(64),
  `MgrStartDate` DATETIME,
  PRIMARY KEY (`DNo`)
) CHARACTER SET latin1;

CREATE TABLE `DLOCATION` (
  `DNo` VARCHAR(64),
  `DLoc` VARCHAR(64),
  PRIMARY KEY (`DNo`, `DLoc`)
) CHARACTER SET latin1;

CREATE TABLE `PROJECT` (
  `PNo` VARCHAR(64),
  `PName` VARCHAR(64),
  `PLocation` VARCHAR(64),
  `DNo` VARCHAR(64),
  PRIMARY KEY (`PNo`)
) CHARACTER SET latin1;

CREATE TABLE `WORKS_ON` (
  `SSN` VARCHAR(64),
  `PNo` VARCHAR(64),
  `Hours` DECIMAL(10,2),
  PRIMARY KEY (`PNo`, `SSN`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_055623_Company') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_055623_Company') AS relationships;
DROP DATABASE `db_055623_Company`;
UNINSTALL EXTENSION vsql_schematron;
