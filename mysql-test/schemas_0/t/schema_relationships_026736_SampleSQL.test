INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 026736_SampleSQL
--echo #
CREATE DATABASE `db_026736_SampleSQL`;
USE `db_026736_SampleSQL`;

CREATE TABLE `sa47.mentor` (
  `id` INT,
  `mname` VARCHAR(64),
  `mnick` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sa47.student` (
  `id` INT,
  `name` VARCHAR(64),
  `nick` VARCHAR(64),
  `mid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_026736_SampleSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_026736_SampleSQL') AS relationships;
DROP DATABASE `db_026736_SampleSQL`;
UNINSTALL EXTENSION vsql_schematron;
