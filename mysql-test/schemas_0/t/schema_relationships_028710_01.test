INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028710_01
--echo #
CREATE DATABASE `db_028710_01`;
USE `db_028710_01`;
CREATE TABLE `habitmodel` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `created_date` DATE,
  `frequency` INT,
  `quantum` DOUBLE,
  `units` VARCHAR(50),
  `magica` TEXT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activitymodel` (
  `id` INT NOT NULL,
  `for_habit_id` INT,
  `quantum` DOUBLE,
  `update_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028710_01') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028710_01') AS relationships;
DROP DATABASE `db_028710_01`;
UNINSTALL EXTENSION vsql_schematron;
