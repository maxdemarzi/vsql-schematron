INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093471_V0_0_1_Create_tables
--echo #
CREATE DATABASE `db_093471_V0_0_1_Create_tables`;
USE `db_093471_V0_0_1_Create_tables`;

CREATE TABLE `user_data` (
  `id` INT,
  `login` VARCHAR(255),
  `password_hash` VARCHAR(255),
  `password_salt` VARCHAR(255),
  `notebook_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `note` (
  `id` INT,
  `parent_id` INT,
  `user_id` INT,
  `title` VARCHAR(255),
  `link` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093471_V0_0_1_Create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093471_V0_0_1_Create_tables') AS relationships;
DROP DATABASE `db_093471_V0_0_1_Create_tables`;
UNINSTALL EXTENSION vsql_schematron;
