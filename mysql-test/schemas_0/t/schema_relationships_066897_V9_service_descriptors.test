INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066897_V9__service_descriptors
--echo #
CREATE DATABASE `db_066897_V9_service_descriptors`;
USE `db_066897_V9_service_descriptors`;

CREATE TABLE `service_descriptor_sets` (
  `id` INT,
  `base_url` VARCHAR(64),
  `health_url` VARCHAR(64),
  `status` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `service_descriptors` (
  `id` INT,
  `set_id` INT,
  `sd_id` VARCHAR(64),
  `status` VARCHAR(64),
  `sd_json` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066897_V9_service_descriptors') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066897_V9_service_descriptors') AS relationships;
DROP DATABASE `db_066897_V9_service_descriptors`;
UNINSTALL EXTENSION vsql_schematron;
