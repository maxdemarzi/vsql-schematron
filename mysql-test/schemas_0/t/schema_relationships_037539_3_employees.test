INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037539_3_employees
--echo #
CREATE DATABASE `db_037539_3_employees`;
USE `db_037539_3_employees`;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `role_id` INT,
  `manager_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037539_3_employees') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037539_3_employees') AS relationships;
DROP DATABASE `db_037539_3_employees`;
UNINSTALL EXTENSION vsql_schematron;
