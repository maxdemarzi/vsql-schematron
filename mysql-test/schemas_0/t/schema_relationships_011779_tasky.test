INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011779_tasky
--echo #
CREATE DATABASE `db_011779_tasky`;
USE `db_011779_tasky`;

CREATE TABLE `lists` (
  `id` INT,
  `name` VARCHAR(64),
  `descrip` VARCHAR(64),
  `create_date` DATETIME,
  `edit_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `subtasks` (
  `id` INT,
  `name` VARCHAR(64),
  `descrip` VARCHAR(64),
  `state` INT,
  `create_date` DATETIME,
  `edit_date` DATETIME,
  `task_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `name` VARCHAR(64),
  `descrip` VARCHAR(64),
  `priori` INT,
  `expir` DATETIME,
  `memo` DATETIME,
  `colour` VARCHAR(64),
  `state` INT,
  `create_date` DATETIME,
  `edit_date` DATETIME,
  `list_id` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `pass` VARCHAR(64),
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_list` (
  `user_id` INT,
  `list_id` INT,
  `perm` INT,
  `link_date` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011779_tasky') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011779_tasky') AS relationships;
DROP DATABASE `db_011779_tasky`;
UNINSTALL EXTENSION vsql_schematron;
