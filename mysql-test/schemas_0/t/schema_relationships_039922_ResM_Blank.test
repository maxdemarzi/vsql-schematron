INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 039922_ResM-Blank
--echo #
CREATE DATABASE `db_039922_ResM_Blank`;
USE `db_039922_ResM_Blank`;

CREATE TABLE `resources` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  `cont` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `id` INT,
  `name` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `res2pro_map` (
  `res_id` INT,
  `pro_id` INT,
  PRIMARY KEY (`res_id`, `pro_id`)
) CHARACTER SET latin1;

CREATE TABLE `res2tag_map` (
  `res_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`res_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_039922_ResM_Blank') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_039922_ResM_Blank') AS relationships;
DROP DATABASE `db_039922_ResM_Blank`;
UNINSTALL EXTENSION vsql_schematron;
