INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 042418_Script%20SQL
--echo #
CREATE DATABASE `db_042418_Script_20SQL`;
USE `db_042418_Script_20SQL`;
CREATE TABLE `Produit` (
  `Codart` INT NOT NULL,
  `Libart` VARCHAR(50),
  `STKALE` INT,
  `STKPHY` INT,
  `QTEANN` INT,
  `UNIMES` CHAR(50),
  PRIMARY KEY (`Codart`)
) CHARACTER SET latin1;
CREATE TABLE `vente` (
  `NUMFOU` INT NOT NULL,
  `Codart` INT NOT NULL,
  `DELLIV` SMALLINT,
  `QTE1` INT,
  `PRIX1` VARCHAR(50),
  `QTE2` INT,
  `PRIX2` VARCHAR(50),
  `QTE3` INT,
  `PRIX3` VARCHAR(50),
  PRIMARY KEY (`NUMFOU`, `Codart`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_042418_Script_20SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_042418_Script_20SQL') AS relationships;
DROP DATABASE `db_042418_Script_20SQL`;
UNINSTALL EXTENSION vsql_schematron;
