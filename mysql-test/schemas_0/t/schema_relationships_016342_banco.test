INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016342_banco
--echo #
CREATE DATABASE `db_016342_banco`;
USE `db_016342_banco`;

CREATE TABLE `ci_sessions` (
  `id` VARCHAR(255),
  `ip_address` VARCHAR(255),
  `timestamp` INT,
  `data` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `categorias` (
  `idCategorias` INT,
  `categoria` VARCHAR(255),
  `cadastro` DATETIME,
  `status` INT,
  `tipo` VARCHAR(255),
  PRIMARY KEY (`idCategorias`)
) CHARACTER SET latin1;

CREATE TABLE `contas` (
  `idContas` INT,
  `conta` VARCHAR(255),
  `banco` VARCHAR(255),
  `numero` VARCHAR(255),
  `saldo` DECIMAL(10,2),
  `cadastro` DATETIME,
  `status` INT,
  `tipo` VARCHAR(255),
  PRIMARY KEY (`idContas`)
) CHARACTER SET latin1;

CREATE TABLE `permissoes` (
  `idPermissao` INT,
  `nome` VARCHAR(255),
  `permissoes` VARCHAR(255),
  `situacao` INT,
  `data` DATETIME,
  PRIMARY KEY (`idPermissao`)
) CHARACTER SET latin1;

CREATE TABLE `garantias` (
  `idGarantias` INT,
  `dataGarantia` DATETIME,
  `refGarantia` VARCHAR(255),
  `textoGarantia` VARCHAR(255),
  `usuarios_id` INT,
  PRIMARY KEY (`idGarantias`)
) CHARACTER SET latin1;

CREATE TABLE `vendas` (
  `idVendas` INT,
  `dataVenda` DATETIME,
  `valorTotal` VARCHAR(255),
  `desconto` VARCHAR(255),
  `faturado` INT,
  `observacoes` VARCHAR(255),
  `observacoes_cliente` VARCHAR(255),
  `clientes_id` INT,
  `usuarios_id` INT,
  `lancamentos_id` INT,
  PRIMARY KEY (`idVendas`)
) CHARACTER SET latin1;

CREATE TABLE `cobrancas` (
  `idCobranca` INT,
  `charge_id` INT,
  `conditional_discount_date` DATETIME,
  `created_at` DATETIME,
  `custom_id` INT,
  `expire_at` DATETIME,
  `message` VARCHAR(255),
  `payment_method` VARCHAR(255),
  `payment_url` VARCHAR(255),
  `request_delivery_address` VARCHAR(255),
  `status` VARCHAR(255),
  `total` VARCHAR(255),
  `barcode` VARCHAR(255),
  `link` VARCHAR(255),
  `payment_gateway` VARCHAR(255),
  `payment` VARCHAR(255),
  `pdf` VARCHAR(255),
  `vendas_id` INT,
  `os_id` INT,
  `clientes_id` INT,
  PRIMARY KEY (`idCobranca`)
) CHARACTER SET latin1;

CREATE TABLE `itens_de_vendas` (
  `idItens` INT,
  `subTotal` VARCHAR(255),
  `quantidade` INT,
  `preco` VARCHAR(255),
  `vendas_id` INT,
  `produtos_id` INT,
  PRIMARY KEY (`idItens`)
) CHARACTER SET latin1;

CREATE TABLE `anexos` (
  `idAnexos` INT,
  `anexo` VARCHAR(255),
  `thumb` VARCHAR(255),
  `url` VARCHAR(255),
  `path` VARCHAR(255),
  `os_id` INT,
  PRIMARY KEY (`idAnexos`)
) CHARACTER SET latin1;

CREATE TABLE `documentos` (
  `idDocumentos` INT,
  `documento` VARCHAR(255),
  `descricao` VARCHAR(255),
  `file` VARCHAR(255),
  `path` VARCHAR(255),
  `url` VARCHAR(255),
  `cadastro` DATETIME,
  `categoria` VARCHAR(255),
  `tipo` VARCHAR(255),
  `tamanho` VARCHAR(255),
  PRIMARY KEY (`idDocumentos`)
) CHARACTER SET latin1;

CREATE TABLE `marcas` (
  `idMarcas` INT,
  `marca` VARCHAR(255),
  `cadastro` DATETIME,
  `situacao` INT,
  PRIMARY KEY (`idMarcas`)
) CHARACTER SET latin1;

CREATE TABLE `equipamentos` (
  `idEquipamentos` INT,
  `equipamento` VARCHAR(255),
  `num_serie` VARCHAR(255),
  `modelo` VARCHAR(255),
  `cor` VARCHAR(255),
  `descricao` VARCHAR(255),
  `tensao` VARCHAR(255),
  `potencia` VARCHAR(255),
  `voltagem` VARCHAR(255),
  `data_fabricacao` DATETIME,
  `marcas_id` INT,
  `clientes_id` INT,
  PRIMARY KEY (`idEquipamentos`)
) CHARACTER SET latin1;

CREATE TABLE `equipamentos_os` (
  `idEquipamentos_os` INT,
  `defeito_declarado` VARCHAR(255),
  `defeito_encontrado` VARCHAR(255),
  `solucao` VARCHAR(255),
  `equipamentos_id` INT,
  `os_id` INT,
  PRIMARY KEY (`idEquipamentos_os`)
) CHARACTER SET latin1;

CREATE TABLE `logs` (
  `idLogs` INT,
  `usuario` VARCHAR(255),
  `tarefa` VARCHAR(255),
  `data` DATETIME,
  `hora` DATETIME,
  `ip` VARCHAR(255),
  PRIMARY KEY (`idLogs`)
) CHARACTER SET latin1;

CREATE TABLE `emitente` (
  `id` INT,
  `nome` VARCHAR(255),
  `cnpj` VARCHAR(255),
  `ie` VARCHAR(255),
  `rua` VARCHAR(255),
  `numero` VARCHAR(255),
  `bairro` VARCHAR(255),
  `cidade` VARCHAR(255),
  `uf` VARCHAR(255),
  `telefone` VARCHAR(255),
  `email` VARCHAR(255),
  `url_logo` VARCHAR(255),
  `cep` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `email_queue` (
  `id` INT,
  `to` VARCHAR(255),
  `cc` VARCHAR(255),
  `bcc` VARCHAR(255),
  `message` VARCHAR(255),
  `status` VARCHAR(255),
  `date` DATETIME,
  `headers` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `anotacoes_os` (
  `idAnotacoes` INT,
  `anotacao` VARCHAR(255),
  `data_hora` DATETIME,
  `os_id` INT,
  PRIMARY KEY (`idAnotacoes`)
) CHARACTER SET latin1;

CREATE TABLE `configuracoes` (
  `idConfig` INT,
  `config` VARCHAR(255),
  `valor` VARCHAR(255),
  PRIMARY KEY (`idConfig`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `version` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016342_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016342_banco') AS relationships;
DROP DATABASE `db_016342_banco`;
UNINSTALL EXTENSION vsql_schematron;
