INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057647_V3_add_account_type
--echo #
CREATE DATABASE `db_057647_V3_add_account_type`;
USE `db_057647_V3_add_account_type`;
CREATE TABLE `sec.account_type` (
  `id` INT NOT NULL,
  `code` CHAR(50),
  `name` CHAR(50),
  `description` CHAR(50),
  `user_level` CHAR(50),
  `status` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sec.account_type_role` (
  `account_type_id` INT NOT NULL,
  `role_id` INT NOT NULL,
  `org_default_role` BOOLEAN,
  PRIMARY KEY (`account_type_id`, `role_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057647_V3_add_account_type') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057647_V3_add_account_type') AS relationships;
DROP DATABASE `db_057647_V3_add_account_type`;
UNINSTALL EXTENSION vsql_schematron;
