INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053325_sleepydb_setup_mysql
--echo #
CREATE DATABASE `db_053325_sleepydb_setup_mysql`;
USE `db_053325_sleepydb_setup_mysql`;

CREATE TABLE `timezones` (
  `timezone_id` VARCHAR(255),
  `timezone_name` VARCHAR(255),
  `utc_offset` INT,
  `dst_offset` INT,
  PRIMARY KEY (`timezone_id`)
) CHARACTER SET latin1;

CREATE TABLE `area_cache` (
  `area_id` INT,
  `area_name` VARCHAR(255),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `timezone_id` VARCHAR(255),
  PRIMARY KEY (`area_id`)
) CHARACTER SET latin1;

CREATE TABLE `server_linked_channels` (
  `server_id` INT,
  `channel_id` INT
) CHARACTER SET latin1;

CREATE TABLE `sleep_tracker` (
  `user_id` INT,
  `area_id` INT,
  `server_id` INT,
  `bedtime_offset` INT,
  `aggressive_ping` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053325_sleepydb_setup_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053325_sleepydb_setup_mysql') AS relationships;
DROP DATABASE `db_053325_sleepydb_setup_mysql`;
UNINSTALL EXTENSION vsql_schematron;
