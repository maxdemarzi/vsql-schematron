INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 099299_database
--echo #
CREATE DATABASE `db_099299_database`;
USE `db_099299_database`;
CREATE TABLE `recipes` (
  `id` INT NOT NULL,
  `chef_id` INT,
  `title` TEXT,
  `ingredients` VARCHAR(50),
  `preparation` VARCHAR(50),
  `information` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `name` TEXT,
  `path` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes_files` (
  `id` INT NOT NULL,
  `recipe_id` INT,
  `file_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_099299_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_099299_database') AS relationships;
DROP DATABASE `db_099299_database`;
UNINSTALL EXTENSION vsql_schematron;
