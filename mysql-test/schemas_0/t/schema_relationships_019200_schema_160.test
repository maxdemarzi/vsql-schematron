  `ADDRESS` VARCHAR(64),
  `ADDRESS_TYPE` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `LINK_DATA` (
  `DATA_ID` VARCHAR(64),
  PRIMARY KEY (`DATA_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTENT_COPIES` (
  `ID` VARCHAR(64),
  `LOCATION_TYPE` VARCHAR(64),
  `DATA_ID` VARCHAR(64),
  `EDMS_ID` VARCHAR(64),
  `EXTERNAL_CODE` VARCHAR(64),
  `PATH` VARCHAR(64),
  `GIT_COMMIT_HASH` VARCHAR(64),
  `LOCATION_UNIQUE_CHECK` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `METAPROJECTS` (
  `ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `OWNER` VARCHAR(64),
  `PRIVATE` BOOL,
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `METAPROJECT_ASSIGNMENTS_ALL` (
  `ID` VARCHAR(64),
  `MEPR_ID` VARCHAR(64),
  `EXPE_ID` VARCHAR(64),
  `SAMP_ID` VARCHAR(64),
  `DATA_ID` VARCHAR(64),
  `MATE_ID` VARCHAR(64),
  `DEL_ID` VARCHAR(64),
  `CREATION_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `OPERATION_EXECUTIONS` (
  `ID` VARCHAR(64),
  `CODE` VARCHAR(64),
  `STATE` VARCHAR(64),
  `OWNER` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `NOTIFICATION` VARCHAR(64),
  `AVAILABILITY` VARCHAR(64),
  `AVAILABILITY_TIME` INT,
  `SUMMARY_OPERATIONS` VARCHAR(64),
  `SUMMARY_PROGRESS` VARCHAR(64),
  `SUMMARY_ERROR` VARCHAR(64),
  `SUMMARY_RESULTS` VARCHAR(64),
  `SUMMARY_AVAILABILITY` VARCHAR(64),
  `SUMMARY_AVAILABILITY_TIME` INT,
  `DETAILS_PATH` VARCHAR(64),
  `DETAILS_AVAILABILITY` VARCHAR(64),
  `DETAILS_AVAILABILITY_TIME` INT,
  `CREATION_DATE` DATETIME,
  `START_DATE` DATETIME,
  `FINISH_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

