INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000078_001_init
--echo #
CREATE DATABASE `db_000078_001_init`;
USE `db_000078_001_init`;

CREATE TABLE `user` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `year` INT,
  `major` VARCHAR(64),
  `is_admin` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `year_name` (
  `year` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`year`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `advisor_email` VARCHAR(64),
  `advisor_name` VARCHAR(64),
  `est_num_students` INT,
  `designation_name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `project_requirement` (
  `name` VARCHAR(64),
  `requirement` VARCHAR(64),
  PRIMARY KEY (`name`, `requirement`)
) CHARACTER SET latin1;

CREATE TABLE `designation` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `major` (
  `name` VARCHAR(64),
  `department_name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `name` VARCHAR(64),
  `course_number` VARCHAR(64),
  `instructor` VARCHAR(64),
  `est_num_students` INT,
  `designation_name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `application` (
  `project_name` VARCHAR(64),
  `student_name` VARCHAR(64),
  `application_date` DATETIME,
  `status` VARCHAR(64),
  PRIMARY KEY (`project_name`, `student_name`)
) CHARACTER SET latin1;

CREATE TABLE `project_category` (
  `project_name` VARCHAR(64),
  `category_name` VARCHAR(64),
  PRIMARY KEY (`project_name`, `category_name`)
) CHARACTER SET latin1;

CREATE TABLE `course_category` (
  `course_name` VARCHAR(64),
  `category_name` VARCHAR(64),
  PRIMARY KEY (`course_name`, `category_name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000078_001_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000078_001_init') AS relationships;
DROP DATABASE `db_000078_001_init`;
UNINSTALL EXTENSION vsql_schematron;
