INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095129_db_setup
--echo #
CREATE DATABASE `db_095129_db_setup`;
USE `db_095129_db_setup`;

CREATE TABLE `webShop.role` (
  `idRole` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`idRole`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.item` (
  `idItem` INT,
  `count` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `isActive` INT,
  `picture` VARCHAR(64),
  `thumb` VARCHAR(64),
  PRIMARY KEY (`idItem`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.orderLocation` (
  `idOrderLocation` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`idOrderLocation`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.tbl_order` (
  `idOrder` INT,
  `webShopUser_idWebShopUser` INT,
  `eventName` VARCHAR(64),
  `eventPlace` VARCHAR(64),
  `pickUpDatetime` DATETIME,
  `returnDatetime` DATETIME,
  `orderLocation_idOrderLocation` INT,
  `isReady` INT,
  `isReturned` INT,
  PRIMARY KEY (`idOrder`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.order_has_item` (
  `order_idOrder` INT,
  `item_idItem` INT,
  `quantity` INT,
  PRIMARY KEY (`order_idOrder`, `item_idItem`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.category` (
  `idCategory` INT,
  `name` VARCHAR(64),
  `category_idCategory` INT,
  PRIMARY KEY (`idCategory`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.item_has_category` (
  `item_idItem` INT,
  `category_idCategory` INT,
  PRIMARY KEY (`item_idItem`, `category_idCategory`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.passwordResetToken` (
  `token` VARCHAR(64),
  `webShopUser_idWebShopUser` INT,
  `expire` DATETIME,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

CREATE TABLE `webShop.rememberMeToken` (
  `token` VARCHAR(64),
  `webShopUser_idWebShopUser` INT,
  `expire` DATETIME,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095129_db_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095129_db_setup') AS relationships;
DROP DATABASE `db_095129_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
