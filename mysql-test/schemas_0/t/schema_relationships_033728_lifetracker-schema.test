INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033728_lifetracker-schema
--echo #
CREATE DATABASE `db_033728_lifetracker_schema`;
USE `db_033728_lifetracker_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `first_name` TEXT,
  `last_name` TEXT,
  `username` TEXT,
  `email` TEXT,
  `password` TEXT,
  `is_admin` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercise_items` (
  `id` INT NOT NULL,
  `user_id` INT,
  `name` TEXT,
  `duration` INT,
  `intensity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sleep_items` (
  `id` INT NOT NULL,
  `user_id` INT,
  `start_date` DATE,
  `end_date` DATE,
  `start_time` TIME,
  `end_time` TIME,
  `hours` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nutritional_items` (
  `id` INT NOT NULL,
  `user_id` INT,
  `name` TEXT,
  `calories` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033728_lifetracker_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033728_lifetracker_schema') AS relationships;
DROP DATABASE `db_033728_lifetracker_schema`;
UNINSTALL EXTENSION vsql_schematron;
