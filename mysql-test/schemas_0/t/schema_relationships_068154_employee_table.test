INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068154_employee_table
--echo #
CREATE DATABASE `db_068154_employee_table`;
USE `db_068154_employee_table`;

CREATE TABLE `employee` (
  `first_name` VARCHAR(64),
  `mid_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `ssn_number` VARCHAR(64),
  `birthday` DATETIME,
  `address` VARCHAR(64),
  `sex` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `supervisor_ssn` VARCHAR(64),
  `department_number` DECIMAL(10,2),
  PRIMARY KEY (`ssn_number`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068154_employee_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068154_employee_table') AS relationships;
DROP DATABASE `db_068154_employee_table`;
UNINSTALL EXTENSION vsql_schematron;
