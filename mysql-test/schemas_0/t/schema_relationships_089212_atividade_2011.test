INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 089212_atividade%2011
--echo #
CREATE DATABASE `db_089212_atividade_2011`;
USE `db_089212_atividade_2011`;
CREATE TABLE `fabricante` (
  `cod` INT NOT NULL,
  `nome_fab` VARCHAR(50),
  `cidade` VARCHAR(50),
  PRIMARY KEY (`cod`)
) CHARACTER SET latin1;
CREATE TABLE `veiculo` (
  `codigo` INT NOT NULL,
  `nome_veiculo` VARCHAR(50),
  `estoque` INT,
  `valor` DECIMAL(10,2),
  `cod_fab` INT,
  `ano` INT,
  PRIMARY KEY (`codigo`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_089212_atividade_2011') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_089212_atividade_2011') AS relationships;
DROP DATABASE `db_089212_atividade_2011`;
UNINSTALL EXTENSION vsql_schematron;
