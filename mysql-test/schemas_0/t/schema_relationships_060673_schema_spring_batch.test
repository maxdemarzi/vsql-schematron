INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060673_schema_spring_batch
--echo #
CREATE DATABASE `db_060673_schema_spring_batch`;
USE `db_060673_schema_spring_batch`;

CREATE TABLE `BATCH_JOB_INSTANCE` (
  `JOB_INSTANCE_ID` INT,
  `VERSION` INT,
  `JOB_NAME` VARCHAR(64),
  `JOB_KEY` VARCHAR(64),
  PRIMARY KEY (`JOB_INSTANCE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BATCH_JOB_EXECUTION` (
  `JOB_EXECUTION_ID` INT,
  `VERSION` INT,
  `JOB_INSTANCE_ID` INT,
  `CREATE_TIME` DATETIME,
  `START_TIME` DATETIME,
  `END_TIME` DATETIME,
  `STATUS` VARCHAR(64),
  `EXIT_CODE` VARCHAR(64),
  `EXIT_MESSAGE` VARCHAR(64),
  `LAST_UPDATED` DATETIME,
  PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BATCH_JOB_PARAMS` (
  `JOB_INSTANCE_ID` INT,
  `TYPE_CD` VARCHAR(64),
  `KEY_NAME` VARCHAR(64),
  `STRING_VAL` VARCHAR(64),
  `DATE_VAL` DATETIME,
  `LONG_VAL` INT,
  `DOUBLE_VAL` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `BATCH_STEP_EXECUTION` (
  `STEP_EXECUTION_ID` INT,
  `VERSION` INT,
  `STEP_NAME` VARCHAR(64),
  `JOB_EXECUTION_ID` INT,
  `START_TIME` DATETIME,
  `END_TIME` DATETIME,
  `STATUS` VARCHAR(64),
  `COMMIT_COUNT` INT,
  `READ_COUNT` INT,
  `FILTER_COUNT` INT,
  `WRITE_COUNT` INT,
  `READ_SKIP_COUNT` INT,
  `WRITE_SKIP_COUNT` INT,
  `PROCESS_SKIP_COUNT` INT,
  `ROLLBACK_COUNT` INT,
  `EXIT_CODE` VARCHAR(64),
  `EXIT_MESSAGE` VARCHAR(64),
  `LAST_UPDATED` DATETIME,
  PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BATCH_STEP_EXECUTION_CONTEXT` (
  `STEP_EXECUTION_ID` INT,
  `SHORT_CONTEXT` VARCHAR(64),
  `SERIALIZED_CONTEXT` VARCHAR(64),
  PRIMARY KEY (`STEP_EXECUTION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BATCH_JOB_EXECUTION_CONTEXT` (
  `JOB_EXECUTION_ID` INT,
  `SHORT_CONTEXT` VARCHAR(64),
  `SERIALIZED_CONTEXT` VARCHAR(64),
  PRIMARY KEY (`JOB_EXECUTION_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060673_schema_spring_batch') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060673_schema_spring_batch') AS relationships;
DROP DATABASE `db_060673_schema_spring_batch`;
UNINSTALL EXTENSION vsql_schematron;
