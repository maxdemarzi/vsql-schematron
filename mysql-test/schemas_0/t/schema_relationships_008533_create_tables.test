INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008533_create_tables
--echo #
CREATE DATABASE `db_008533_create_tables`;
USE `db_008533_create_tables`;

CREATE TABLE `_allowed_types` (
  `type_name` VARCHAR(64),
  PRIMARY KEY (`type_name`)
) CHARACTER SET latin1;

CREATE TABLE `_refined_types_base` (
  `type_name` VARCHAR(64),
  `refined_type_name` VARCHAR(64),
  PRIMARY KEY (`type_name`, `refined_type_name`)
) CHARACTER SET latin1;

CREATE TABLE `_vertexes` (
  `vertex_id` VARCHAR(64),
  `type_name` VARCHAR(64),
  PRIMARY KEY (`vertex_id`)
) CHARACTER SET latin1;

CREATE TABLE `_ports` (
  `port_id` VARCHAR(64),
  `vertex_id` VARCHAR(64),
  `type_name` VARCHAR(64),
  PRIMARY KEY (`vertex_id`, `port_id`)
) CHARACTER SET latin1;

CREATE TABLE `_properties` (
  `prop_id` VARCHAR(64),
  `vertex_id` VARCHAR(64),
  `prop_value` VARCHAR(64),
  PRIMARY KEY (`vertex_id`, `prop_id`)
) CHARACTER SET latin1;

CREATE TABLE `_edges` (
  `source_vertex_id` VARCHAR(64),
  `target_vertex_id` VARCHAR(64),
  `source_vertex_port_id` VARCHAR(64),
  `target_vertex_port_id` VARCHAR(64),
  `type_name` VARCHAR(64),
  PRIMARY KEY (`source_vertex_id`, `target_vertex_id`, `source_vertex_port_id`, `target_vertex_port_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008533_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008533_create_tables') AS relationships;
DROP DATABASE `db_008533_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
