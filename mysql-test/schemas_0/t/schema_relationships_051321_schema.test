INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051321_schema
--echo #
CREATE DATABASE `db_051321_schema`;
USE `db_051321_schema`;

CREATE TABLE `user` (
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `username` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`username`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `todo_list` (
  `todo_list_id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `is_public` BOOL,
  `owner` VARCHAR(64),
  PRIMARY KEY (`todo_list_id`)
) CHARACTER SET latin1;

CREATE TABLE `todo_list_item` (
  `todo_item_id` DECIMAL(10,2),
  `todo_list_id` DECIMAL(10,2),
  `name` VARCHAR(64),
  `is_done` BOOL,
  PRIMARY KEY (`todo_item_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051321_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051321_schema') AS relationships;
DROP DATABASE `db_051321_schema`;
UNINSTALL EXTENSION vsql_schematron;
