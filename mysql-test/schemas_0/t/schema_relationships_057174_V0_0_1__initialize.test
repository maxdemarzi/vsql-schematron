INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057174_V0_0_1__initialize
--echo #
CREATE DATABASE `db_057174_V0_0_1__initialize`;
USE `db_057174_V0_0_1__initialize`;
CREATE TABLE `Greeting` (
  `id` VARCHAR(50) NOT NULL,
  `referenceId` VARCHAR(50),
  `text` VARCHAR(50),
  `version` VARCHAR(50),
  `createdBy` VARCHAR(50),
  `createdAt` DATETIME,
  `updatedBy` VARCHAR(50),
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
  `id` VARCHAR(50) NOT NULL,
  `referenceId` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `enabled` VARCHAR(50),
  `credentialsexpired` VARCHAR(50),
  `expired` VARCHAR(50),
  `locked` VARCHAR(50),
  `version` VARCHAR(50),
  `createdBy` VARCHAR(50),
  `createdAt` DATETIME,
  `updatedBy` VARCHAR(50),
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Role` (
  `id` VARCHAR(50) NOT NULL,
  `code` VARCHAR(50),
  `label` VARCHAR(50),
  `ordinal` VARCHAR(50),
  `effectiveAt` DATETIME,
  `expiresAt` DATETIME,
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AccountRole` (
  `accountId` VARCHAR(50) NOT NULL,
  `roleId` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`accountId`, `roleId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057174_V0_0_1__initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057174_V0_0_1__initialize') AS relationships;
DROP DATABASE `db_057174_V0_0_1__initialize`;
UNINSTALL EXTENSION vsql_schematron;
