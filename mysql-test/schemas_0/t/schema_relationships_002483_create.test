INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002483_create
--echo #
CREATE DATABASE `db_002483_create`;
USE `db_002483_create`;

CREATE TABLE `BATCH_REQUEST` (
  `BATCH_REQUEST_ID` VARCHAR(255),
  `BATCH_REQUEST_NAME` VARCHAR(255),
  `PROCESS_HALT_FLG` VARCHAR(255),
  `PROCESS_ACTIVE_FLG` VARCHAR(255),
  `SERVICE_AVAILABLE` VARCHAR(255),
  `RESUME_POINT` INT,
  PRIMARY KEY (`BATCH_REQUEST_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BUSINESS_DATE` (
  `SEGMENT_ID` VARCHAR(255),
  `BIZ_DATE` VARCHAR(255),
  PRIMARY KEY (`SEGMENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CODE_NAME` (
  `CODE_ID` VARCHAR(255),
  `CODE_VALUE` VARCHAR(255),
  `LANG` VARCHAR(255),
  `SORT_ORDER` INT,
  `CODE_NAME` VARCHAR(255),
  `SHORT_NAME` VARCHAR(255),
  `OPTION01` VARCHAR(255),
  `OPTION02` VARCHAR(255),
  `OPTION03` VARCHAR(255),
  `OPTION04` VARCHAR(255),
  `OPTION05` VARCHAR(255),
  `OPTION06` VARCHAR(255),
  `OPTION07` VARCHAR(255),
  `OPTION08` VARCHAR(255),
  `OPTION09` VARCHAR(255),
  `OPTION10` VARCHAR(255),
  PRIMARY KEY (`CODE_ID`, `CODE_VALUE`, `LANG`)
) CHARACTER SET latin1;

CREATE TABLE `CODE_PATTERN` (
  `CODE_ID` VARCHAR(255),
  `CODE_VALUE` VARCHAR(255),
  `PATTERN01` VARCHAR(255),
  `PATTERN02` VARCHAR(255),
  `PATTERN03` VARCHAR(255),
  `PATTERN04` VARCHAR(255),
  `PATTERN05` VARCHAR(255),
  `PATTERN06` VARCHAR(255),
  `PATTERN07` VARCHAR(255),
  `PATTERN08` VARCHAR(255),
  `PATTERN09` VARCHAR(255),
  `PATTERN10` VARCHAR(255),
  `PATTERN11` VARCHAR(255),
  `PATTERN12` VARCHAR(255),
  `PATTERN13` VARCHAR(255),
  `PATTERN14` VARCHAR(255),
  `PATTERN15` VARCHAR(255),
  `PATTERN16` VARCHAR(255),
  `PATTERN17` VARCHAR(255),
  `PATTERN18` VARCHAR(255),
  `PATTERN19` VARCHAR(255),
  `PATTERN20` VARCHAR(255),
  PRIMARY KEY (`CODE_ID`, `CODE_VALUE`)
) CHARACTER SET latin1;

CREATE TABLE `MAIL_RECIPIENT` (
  `MAIL_REQUEST_ID` VARCHAR(255),
  `SERIAL_NUMBER` INT,
  `RECIPIENT_TYPE` VARCHAR(255),
  `MAIL_ADDRESS` VARCHAR(255),
  PRIMARY KEY (`MAIL_REQUEST_ID`, `SERIAL_NUMBER`)
) CHARACTER SET latin1;

CREATE TABLE `MAIL_REQUEST` (
  `MAIL_REQUEST_ID` VARCHAR(255),
  `MAIL_SEND_PATTERN_ID` VARCHAR(255),
  `SUBJECT` VARCHAR(255),
  `MAIL_BODY` VARCHAR(255),
  `MAIL_FROM` VARCHAR(255),
  `REPLY_TO` VARCHAR(255),
  `RETURN_PATH` VARCHAR(255),
  `CHARSET` VARCHAR(255),
  `STATUS` VARCHAR(255),
  `REQUEST_DATETIME` DATETIME,
  `SEND_DATETIME` DATETIME,
  `PROCESS_ID` VARCHAR(255),
  PRIMARY KEY (`MAIL_REQUEST_ID`)
) CHARACTER SET latin1;

CREATE TABLE `MAIL_TEMPLATE` (
  `MAIL_TEMPLATE_ID` VARCHAR(255),
  `LANG` VARCHAR(255),
  `SUBJECT` VARCHAR(255),
  `MAIL_BODY` VARCHAR(255),
  `CHARSET` VARCHAR(255),
  PRIMARY KEY (`MAIL_TEMPLATE_ID`, `LANG`)
) CHARACTER SET latin1;

CREATE TABLE `SAMPLE_USER` (
  `USER_INFO_ID` VARCHAR(255),
  `LOGIN_ID` VARCHAR(255),
  `KANJI_NAME` VARCHAR(255),
  `KANA_NAME` VARCHAR(255),
  `STATUS` VARCHAR(255),
  PRIMARY KEY (`USER_INFO_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002483_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002483_create') AS relationships;
DROP DATABASE `db_002483_create`;
UNINSTALL EXTENSION vsql_schematron;
