INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010016_2_skills_up
--echo #
CREATE DATABASE `db_010016_2_skills_up`;
USE `db_010016_2_skills_up`;

CREATE TABLE `skills` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `job_skill` (
  `id` INT,
  `job_id` INT,
  `skill_id` INT,
  `level` INT,
  `complexity` INT,
  `cost` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pc_skill_proficiency` (
  `id` INT,
  `player_character_id` INT,
  `skill_id` INT,
  `proficiency` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010016_2_skills_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010016_2_skills_up') AS relationships;
DROP DATABASE `db_010016_2_skills_up`;
UNINSTALL EXTENSION vsql_schematron;
