INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010257_bunnies
--echo #
CREATE DATABASE `db_010257_bunnies`;
USE `db_010257_bunnies`;

CREATE TABLE `bunnies` (
  `bunny_id` INT,
  `name` VARCHAR(255),
  `age` INT,
  `category_id` INT,
  `date_created` DATETIME,
  `date_deleted` DATETIME,
  PRIMARY KEY (`bunny_id`)
) CHARACTER SET latin1;

CREATE TABLE `bunny_categories` (
  `category_id` INT,
  `name` VARCHAR(255),
  `date_created` DATETIME,
  `date_deleted` DATETIME,
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `owners` (
  `owner_id` INT,
  `name` VARCHAR(255),
  `age` INT,
  `information` VARCHAR(255),
  `date_created` DATETIME,
  `date_deleted` DATETIME,
  PRIMARY KEY (`owner_id`)
) CHARACTER SET latin1;

CREATE TABLE `owners_bunnies` (
  `owner_id` INT,
  `bunny_id` INT,
  `id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010257_bunnies') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010257_bunnies') AS relationships;
DROP DATABASE `db_010257_bunnies`;
UNINSTALL EXTENSION vsql_schematron;
