INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025377_hsqldb
--echo #
CREATE DATABASE `db_025377_hsqldb`;
USE `db_025377_hsqldb`;

CREATE TABLE `pasystem_popup_screens` (
  `uuid` VARCHAR(64),
  `descriptor` VARCHAR(64),
  `start_time` INT,
  `end_time` INT,
  `open_campaign` INT,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `pasystem_popup_content` (
  `uuid` VARCHAR(64),
  `template_content` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `pasystem_popup_assign` (
  `uuid` VARCHAR(64),
  `user_eid` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `pasystem_popup_dismissed` (
  `uuid` VARCHAR(64),
  `user_eid` VARCHAR(64),
  `state` VARCHAR(64),
  `dismiss_time` INT
) CHARACTER SET latin1;

CREATE TABLE `pasystem_banner_alert` (
  `uuid` VARCHAR(64),
  `message` VARCHAR(64),
  `hosts` VARCHAR(64),
  `active` INT,
  `dismissible` INT,
  `start_time` INT,
  `end_time` INT,
  `banner_type` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `pasystem_banner_dismissed` (
  `uuid` VARCHAR(64),
  `user_eid` VARCHAR(64),
  `state` VARCHAR(64),
  `dismiss_time` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025377_hsqldb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025377_hsqldb') AS relationships;
DROP DATABASE `db_025377_hsqldb`;
UNINSTALL EXTENSION vsql_schematron;
