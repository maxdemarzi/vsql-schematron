INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072053_CreateTables
--echo #
CREATE DATABASE `db_072053_CreateTables`;
USE `db_072053_CreateTables`;

CREATE TABLE `customer` (
  `custid` INT,
  `custname` VARCHAR(64),
  `custusername` VARCHAR(64),
  `custpassword` VARCHAR(64),
  PRIMARY KEY (`custid`)
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `empid` INT,
  `empname` VARCHAR(64),
  `empusername` VARCHAR(64),
  `emppassword` VARCHAR(64),
  `isanadmin` VARCHAR(64),
  PRIMARY KEY (`empid`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `accid` INT,
  `name` VARCHAR(64),
  `status` VARCHAR(64),
  `balance` INT,
  `ownerid` INT,
  `coownerid` INT,
  PRIMARY KEY (`accid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072053_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072053_CreateTables') AS relationships;
DROP DATABASE `db_072053_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
