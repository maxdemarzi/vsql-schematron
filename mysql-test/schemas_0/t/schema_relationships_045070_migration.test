INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 045070_migration
--echo #
CREATE DATABASE `db_045070_migration`;
USE `db_045070_migration`;

CREATE TABLE `Link` (
  `id` INT,
  `createdAt` DATETIME,
  `href` VARCHAR(64),
  `readingTime` VARCHAR(64),
  `userId` INT,
  `timeout` DATETIME,
  `notify` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` INT,
  `tag` VARCHAR(64),
  `notify` BOOL,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `createdAt` DATETIME,
  `notify` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `EmailLog` (
  `id` INT,
  `mailId` VARCHAR(64),
  `createdAt` DATETIME,
  `userId` INT,
  `text` VARCHAR(64),
  `html` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_LinkToTag` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_045070_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_045070_migration') AS relationships;
DROP DATABASE `db_045070_migration`;
UNINSTALL EXTENSION vsql_schematron;
