) CHARACTER SET latin1;

CREATE TABLE `couch_table` (
  `id` INT,
  `jcode` VARCHAR(64),
  `cut_fabric_id` INT,
  `sew_fabric_id` INT,
  `quilt_fabric_id` INT,
  `cut_hb_id` INT,
  `strip_cut_hb_id` INT,
  `l_cut_hb_id` INT,
  `drill_hb_id` INT,
  `casing_id` INT,
  `frame_cut_id` INT,
  `rubber_pile_id` INT,
  `whitening_sponge_id` INT,
  `wrapping_cb_id` INT,
  `dressing_fabric_id` INT,
  `furnish_fabric_id` INT,
  `package_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079198_create_process_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079198_create_process_tables') AS relationships;
DROP DATABASE `db_079198_create_process_tables`;
UNINSTALL EXTENSION vsql_schematron;
