INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079198_create_process_tables
--echo #
CREATE DATABASE `db_079198_create_process_tables`;
USE `db_079198_create_process_tables`;

CREATE TABLE `personnel_table` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `tc` VARCHAR(64),
  `workStartDate` DATETIME,
  `birthDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `machine_table` (
  `id` INT,
  `name` VARCHAR(64),
  `brand` VARCHAR(64),
  `modelDate` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_cut_fabric_table` (
  `id` INT,
  `personnel1_id` INT,
  `personnel2_id` INT,
  `processDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_sew_fabric_table` (
  `id` INT,
