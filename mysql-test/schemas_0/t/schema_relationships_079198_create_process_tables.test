  `personnel2_id` INT,
  `processDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_rubber_pile_table` (
  `id` INT,
  `personnel1_id` INT,
  `personnel2_id` INT,
  `personnel3_id` INT,
  `personnel4_id` INT,
  `processDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_frame_cut_table` (
  `id` INT,
