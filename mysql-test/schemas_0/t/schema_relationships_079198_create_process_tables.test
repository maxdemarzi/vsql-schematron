  `processDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_wrapping_cardboard_table` (
  `id` INT,
  `personnel1_id` INT,
  `processDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `couch_dressing_fabric_table` (
  `id` INT,
  `personnel1_id` INT,
