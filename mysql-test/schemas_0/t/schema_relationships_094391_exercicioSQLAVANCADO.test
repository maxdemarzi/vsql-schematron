INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094391_exercicioSQLAVANCADO
--echo #
CREATE DATABASE `db_094391_exercicioSQLAVANCADO`;
USE `db_094391_exercicioSQLAVANCADO`;

CREATE TABLE `alunos` (
  `id` INT,
  `email` VARCHAR(64),
  `nome` VARCHAR(64),
  `idade` INT,
  `ativo` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `avaliacoes` (
  `id` INT,
  `titulo` VARCHAR(64),
  `descricao` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `respostas_avaliacoes` (
  `id` INT,
  `aluno_id` INT,
  `avaliacao_id` INT,
  `resposta` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `resposta_mentor` (
  `id` INT,
  `resposta_id` INT,
  `correcao_resposta` VARCHAR(64),
  `nota` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094391_exercicioSQLAVANCADO') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094391_exercicioSQLAVANCADO') AS relationships;
DROP DATABASE `db_094391_exercicioSQLAVANCADO`;
UNINSTALL EXTENSION vsql_schematron;
