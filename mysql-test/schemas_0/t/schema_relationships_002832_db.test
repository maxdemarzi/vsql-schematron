INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002832_db
--echo #
CREATE DATABASE `db_002832_db`;
USE `db_002832_db`;
CREATE TABLE `seeds` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `thought` VARCHAR(50),
  `daily_reading` VARCHAR(50),
  `prayer` VARCHAR(50),
  `assignment` VARCHAR(50),
  `quote` VARCHAR(50),
  `resource` VARCHAR(50),
  `date` DATETIME,
  `day` INT,
  `month` INT,
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `artist_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002832_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002832_db') AS relationships;
DROP DATABASE `db_002832_db`;
UNINSTALL EXTENSION vsql_schematron;
