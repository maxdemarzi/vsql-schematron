INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057594_views_recursive
--echo #
CREATE DATABASE `db_057594_views_recursive`;
USE `db_057594_views_recursive`;

CREATE TABLE `funcionarios` (
  `id` INT,
  `nome` VARCHAR(64),
  `gerente` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057594_views_recursive') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057594_views_recursive') AS relationships;
DROP DATABASE `db_057594_views_recursive`;
UNINSTALL EXTENSION vsql_schematron;
