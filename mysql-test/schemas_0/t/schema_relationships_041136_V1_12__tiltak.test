INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041136_V1_12__tiltak
--echo #
CREATE DATABASE `db_041136_V1_12__tiltak`;
USE `db_041136_V1_12__tiltak`;
CREATE TABLE `TILTAKKODEVERK` (
  `KODE` VARCHAR(50) NOT NULL,
  `VERDI` VARCHAR(50),
  PRIMARY KEY (`KODE`)
) CHARACTER SET latin1;
CREATE TABLE `BRUKERTILTAK` (
  `AKTOERID` VARCHAR(50),
  `PERSONID` VARCHAR(50),
  `TILTAKSKODE` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `ENHETTILTAK` (
  `ENHETID` VARCHAR(50),
  `TILTAKSKODE` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041136_V1_12__tiltak') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041136_V1_12__tiltak') AS relationships;
DROP DATABASE `db_041136_V1_12__tiltak`;
UNINSTALL EXTENSION vsql_schematron;
