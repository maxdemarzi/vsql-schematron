INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005115_jilo
--echo #
CREATE DATABASE `db_005115_jilo`;
USE `db_005115_jilo`;

CREATE TABLE `article` (
  `id` INT,
  `title` VARCHAR(255),
  `text` VARCHAR(255),
  `activated` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authority` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `article_id` INT,
  `text` VARCHAR(255),
  `activated` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `login` VARCHAR(255),
  `password` VARCHAR(255),
  `activated` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_authority` (
  `user_id` INT,
  `authorithy_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005115_jilo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005115_jilo') AS relationships;
DROP DATABASE `db_005115_jilo`;
UNINSTALL EXTENSION vsql_schematron;
