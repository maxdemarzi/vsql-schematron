INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084257_db
--echo #
CREATE DATABASE `db_084257_db`;
USE `db_084257_db`;
CREATE TABLE `usuario` (
  `id_usuario` INT NOT NULL,
  `usuario` VARCHAR(50),
  `password` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `habitacion` (
  `id_habitacion` INT NOT NULL,
  `habitacion` VARCHAR(50),
  `precio` DOUBLE,
  `cantidad_estrella` INT,
  `cantidad_persona` INT,
  `metro_cuadrado` INT,
  `descripcion` TEXT,
  `imagen` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_habitacion`)
) CHARACTER SET latin1;
CREATE TABLE `habitacion_imagen` (
  `id_habitacion_imagen` INT NOT NULL,
  `id_habitacion` INT,
  `imagen` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_habitacion_imagen`)
) CHARACTER SET latin1;
CREATE TABLE `habitacion_mas_pedida` (
  `id_habitacion_mas_pedida` INT NOT NULL,
  `id_habitacion` INT,
  `puesto` INT,
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_habitacion_mas_pedida`)
) CHARACTER SET latin1;
CREATE TABLE `galeria` (
  `id_galeria` INT NOT NULL,
  `imagen` VARCHAR(50),
  `titulo` VARCHAR(50),
  `sub_titulo` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_galeria`)
) CHARACTER SET latin1;
CREATE TABLE `servicio` (
  `id_servicio` INT NOT NULL,
  `titulo` VARCHAR(50),
  `sub_titulo` VARCHAR(50),
  `descripcion` TEXT,
  `imagen` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_servicio`)
) CHARACTER SET latin1;
CREATE TABLE `informacion` (
  `id_informacion` INT NOT NULL,
  `telefono` VARCHAR(50),
  `lugar` VARCHAR(50),
  `calle` VARCHAR(50),
  `colonia` VARCHAR(50),
  `observacion` VARCHAR(50),
  `fecha_nuevo` DATETIME,
  `fecha_editar` DATETIME,
  `fecha_eliminar` DATETIME,
  PRIMARY KEY (`id_informacion`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084257_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084257_db') AS relationships;
DROP DATABASE `db_084257_db`;
UNINSTALL EXTENSION vsql_schematron;
