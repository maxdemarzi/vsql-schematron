INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060159_photos
--echo #
CREATE DATABASE `db_060159_photos`;
USE `db_060159_photos`;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Photo` (
  `id` INT,
  `caption` VARCHAR(64),
  `creationDate` DATETIME,
  `uploadDate` DATETIME,
  `user` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Likes` (
  `user` INT,
  `photo` INT,
  PRIMARY KEY (`user`, `photo`)
) CHARACTER SET latin1;

CREATE TABLE `AppearsIn` (
  `user` INT,
  `photo` INT,
  PRIMARY KEY (`user`, `photo`)
) CHARACTER SET latin1;

CREATE TABLE `Friend` (
  `user1` INT,
  `user2` INT,
  PRIMARY KEY (`user1`, `user2`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060159_photos') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060159_photos') AS relationships;
DROP DATABASE `db_060159_photos`;
UNINSTALL EXTENSION vsql_schematron;
