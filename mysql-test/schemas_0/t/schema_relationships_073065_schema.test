INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 073065_schema
--echo #
CREATE DATABASE `db_073065_schema`;
USE `db_073065_schema`;

CREATE TABLE `city` (
  `id` INT,
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `locationdata` (
  `id` INT,
  `city_id` INT,
  `map_url` VARCHAR(64),
  `city_url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hoteldata` (
  `id` INT,
  `city_id` INT,
  `hotel_image` VARCHAR(64),
  `hotel_name` VARCHAR(64),
  `hotel_price` VARCHAR(64),
  `hotel_rate` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transportdata` (
  `id` INT,
  `city_id` INT,
  `station_name` VARCHAR(64),
  `station_type` VARCHAR(64),
  `transport_price` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `booking` (
  `id` INT,
  `city` VARCHAR(64),
  `map_url` VARCHAR(64),
  `city_url` VARCHAR(64),
  `time` VARCHAR(64),
  `hotel_name` VARCHAR(64),
  `hotel_price` VARCHAR(64),
  `hotel_rate` VARCHAR(64),
  `hotel_img` VARCHAR(64),
  `station_name` VARCHAR(64),
  `station_type` VARCHAR(64),
  `transport_price` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_073065_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_073065_schema') AS relationships;
DROP DATABASE `db_073065_schema`;
UNINSTALL EXTENSION vsql_schematron;
