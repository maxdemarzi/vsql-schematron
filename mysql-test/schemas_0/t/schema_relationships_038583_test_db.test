INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038583_test_db
--echo #
CREATE DATABASE `db_038583_test_db`;
USE `db_038583_test_db`;
CREATE TABLE `project_user` (
  `user_id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `oauth_id` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
  `project_id` VARCHAR(50) NOT NULL,
  `project_name` VARCHAR(50),
  `channel_id` VARCHAR(50),
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
  `task_id` VARCHAR(50) NOT NULL,
  `project_id` VARCHAR(50),
  `task_name` VARCHAR(50),
  `task_status` VARCHAR(50),
  `assigned_to` VARCHAR(50),
  `estimated_time` INT,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_member` (
  `user_user_id` VARCHAR(50) NOT NULL,
  `project_project_id` VARCHAR(50) NOT NULL,
  `member_role` VARCHAR(50),
  `member_status` VARCHAR(50),
  PRIMARY KEY (`user_user_id`, `project_project_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038583_test_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038583_test_db') AS relationships;
DROP DATABASE `db_038583_test_db`;
UNINSTALL EXTENSION vsql_schematron;
