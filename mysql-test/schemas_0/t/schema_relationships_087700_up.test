INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087700_up
--echo #
CREATE DATABASE `db_087700_up`;
USE `db_087700_up`;

CREATE TABLE `pages` (
  `uuid` VARCHAR(255),
  `page_name` VARCHAR(255),
  `page_url` VARCHAR(255),
  `page_title` VARCHAR(255),
  `time_created` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `module_category` (
  `uuid` VARCHAR(255),
  `page_uuid` VARCHAR(255),
  `title` VARCHAR(255),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `modules` (
  `uuid` VARCHAR(255),
  `page_uuid` VARCHAR(255),
  `category_uuid` VARCHAR(255),
  `title` VARCHAR(255),
  `content` VARCHAR(255),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087700_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087700_up') AS relationships;
DROP DATABASE `db_087700_up`;
UNINSTALL EXTENSION vsql_schematron;
