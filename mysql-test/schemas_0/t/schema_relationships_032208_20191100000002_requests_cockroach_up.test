CREATE DATABASE `db_032208_20191100000002_requests_cockroach_up`;
USE `db_032208_20191100000002_requests_cockroach_up`;

CREATE TABLE `selfservice_login_requests` (
  `id` VARCHAR(255),
  `request_url` VARCHAR(255),
  `issued_at` DATETIME,
  `expires_at` DATETIME,
  `active_method` VARCHAR(255),
  `csrf_token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `selfservice_login_request_methods` (
  `id` VARCHAR(255),
  `method` VARCHAR(255),
  `selfservice_login_request_id` VARCHAR(255),
  `config` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `selfservice_registration_requests` (
  `id` VARCHAR(255),
  `request_url` VARCHAR(255),
  `issued_at` DATETIME,
  `expires_at` DATETIME,
  `active_method` VARCHAR(255),
  `csrf_token` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `selfservice_registration_request_methods` (
  `id` VARCHAR(255),
  `method` VARCHAR(255),
  `selfservice_registration_request_id` VARCHAR(255),
  `config` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `selfservice_profile_management_requests` (
  `id` VARCHAR(255),
  `request_url` VARCHAR(255),
  `issued_at` DATETIME,
  `expires_at` DATETIME,
  `form` VARCHAR(255),
  `update_successful` VARCHAR(255),
  `identity_id` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

