INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076876_1
--echo #
CREATE DATABASE `db_076876_1`;
USE `db_076876_1`;

CREATE TABLE `convenio` (
  `cod_convenio` VARCHAR(64),
  `desc_convenio` VARCHAR(64),
  PRIMARY KEY (`cod_convenio`)
) CHARACTER SET latin1;

CREATE TABLE `paciente` (
  `cd_pac` INT,
  `nm_pac` VARCHAR(64),
  `dt_nasc` DATETIME,
  `conv_pac` VARCHAR(64),
  PRIMARY KEY (`cd_pac`)
) CHARACTER SET latin1;

CREATE TABLE `atendimento` (
  `cd_pac` INT,
  `dia_atend` DATETIME,
  `diag` VARCHAR(64),
  PRIMARY KEY (`cd_pac`, `dia_atend`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076876_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076876_1') AS relationships;
DROP DATABASE `db_076876_1`;
UNINSTALL EXTENSION vsql_schematron;
