INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 049378_results
--echo #
CREATE DATABASE `db_049378_results`;
USE `db_049378_results`;

CREATE TABLE `results` (
  `parent` VARCHAR(64),
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `annotations` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  `etag` VARCHAR(64),
  PRIMARY KEY (`parent`, `id`)
) CHARACTER SET latin1;

CREATE TABLE `records` (
  `parent` VARCHAR(64),
  `result_id` VARCHAR(64),
  `id` VARCHAR(64),
  `result_name` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `data` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  `etag` VARCHAR(64),
  PRIMARY KEY (`parent`, `result_id`, `id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_049378_results') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_049378_results') AS relationships;
DROP DATABASE `db_049378_results`;
UNINSTALL EXTENSION vsql_schematron;
