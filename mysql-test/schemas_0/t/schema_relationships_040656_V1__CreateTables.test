INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040656_V1__CreateTables
--echo #
CREATE DATABASE `db_040656_V1__CreateTables`;
USE `db_040656_V1__CreateTables`;
CREATE TABLE `hibernate_sequence` (
  `next_val` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
  `user_id` BIGINT NOT NULL,
  `role_id` BIGINT NOT NULL,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `created` DATETIME,
  `password` VARCHAR(50),
  `username` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040656_V1__CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040656_V1__CreateTables') AS relationships;
DROP DATABASE `db_040656_V1__CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
