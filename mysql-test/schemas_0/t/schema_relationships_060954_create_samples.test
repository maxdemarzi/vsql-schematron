INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060954_create_samples
--echo #
CREATE DATABASE `db_060954_create_samples`;
USE `db_060954_create_samples`;
CREATE TABLE `products` (
  `id` VARCHAR(50) NOT NULL,
  `title` TEXT,
  `description` TEXT,
  `price` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stocks` (
  `id` VARCHAR(50) NOT NULL,
  `product_id` VARCHAR(50),
  `count` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060954_create_samples') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060954_create_samples') AS relationships;
DROP DATABASE `db_060954_create_samples`;
UNINSTALL EXTENSION vsql_schematron;
