INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061400_query
--echo #
CREATE DATABASE `db_061400_query`;
USE `db_061400_query`;

CREATE TABLE `t_user` (
  `iuser` INT,
  `email` VARCHAR(64),
  `provider` VARCHAR(64),
  `pw` VARCHAR(64),
  `nm` VARCHAR(64),
  `nick` VARCHAR(64),
  `tel` VARCHAR(64),
  `authCd` VARCHAR(64),
  `profileImg` VARCHAR(64),
  `regdt` DATETIME,
  PRIMARY KEY (`iuser`)
) CHARACTER SET latin1;

CREATE TABLE `t_board` (
  `iboard` INT,
  `provider` VARCHAR(64),
  `iuser` INT,
  `title` VARCHAR(64),
  `ctnt` VARCHAR(64),
  `regdt` DATETIME,
  `delYN` VARCHAR(64),
  PRIMARY KEY (`iboard`)
) CHARACTER SET latin1;

CREATE TABLE `t_cmt` (
  `icmt` INT,
  `iuser` INT,
  `iboard` INT,
  `cmt` VARCHAR(64),
  `regdt` DATETIME,
  PRIMARY KEY (`icmt`)
) CHARACTER SET latin1;

CREATE TABLE `t_board_img` (
  `iboardimg` INT,
  `iboard` INT,
  `img` VARCHAR(64),
  PRIMARY KEY (`iboardimg`)
) CHARACTER SET latin1;

CREATE TABLE `t_board_fav` (
  `iuser` INT,
  `iboard` INT,
  `regdt` DATETIME,
  PRIMARY KEY (`iuser`, `iboard`)
) CHARACTER SET latin1;

CREATE TABLE `t_user_profile` (
  `iprofile` INT,
  `iuser` INT,
  `profileImg` VARCHAR(64),
  `regdt` DATETIME,
  PRIMARY KEY (`iprofile`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061400_query') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061400_query') AS relationships;
DROP DATABASE `db_061400_query`;
UNINSTALL EXTENSION vsql_schematron;
