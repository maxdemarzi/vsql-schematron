INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067679_048-HIVE-14498.oracle
--echo #
CREATE DATABASE `db_067679_048_HIVE_14498_oracle`;
USE `db_067679_048_HIVE_14498_oracle`;
CREATE TABLE `MV_CREATION_METADATA` (
  `MV_CREATION_METADATA_ID` DECIMAL(10,2) NOT NULL,
  `DB_NAME` VARCHAR(50),
  `TBL_NAME` VARCHAR(50),
  `TXN_LIST` VARCHAR(50),
  PRIMARY KEY (`MV_CREATION_METADATA_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MV_TABLES_USED` (
  `MV_CREATION_METADATA_ID` DECIMAL(10,2),
  `TBL_ID` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067679_048_HIVE_14498_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067679_048_HIVE_14498_oracle') AS relationships;
DROP DATABASE `db_067679_048_HIVE_14498_oracle`;
UNINSTALL EXTENSION vsql_schematron;
