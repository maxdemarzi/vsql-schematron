  `id` INT,
  `id_master` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053597_ColumnDomainColumnUsedInFK_00_Target') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
