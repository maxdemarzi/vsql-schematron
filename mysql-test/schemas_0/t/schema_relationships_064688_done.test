INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064688_done
--echo #
CREATE DATABASE `db_064688_done`;
USE `db_064688_done`;

CREATE TABLE `t1` (
  `id` INT,
  `str` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `t2` (
  `id` INT,
  `str` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064688_done') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064688_done') AS relationships;
DROP DATABASE `db_064688_done`;
UNINSTALL EXTENSION vsql_schematron;
