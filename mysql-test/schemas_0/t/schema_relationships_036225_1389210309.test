INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036225_1389210309
--echo #
CREATE DATABASE `db_036225_1389210309`;
USE `db_036225_1389210309`;

CREATE TABLE `kvstore` (
  `type` VARCHAR(64),
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`type`, `key`)
) CHARACTER SET latin1;

CREATE TABLE `lookup` (
  `name_type` INT,
  `name` VARCHAR(64),
  `key_type` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`name_type`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `key_import_log` (
  `fingerprint` VARCHAR(64),
  `uid` VARCHAR(64),
  `ctime` INT,
  `mtime` INT,
  `state` INT,
  PRIMARY KEY (`fingerprint`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036225_1389210309') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036225_1389210309') AS relationships;
DROP DATABASE `db_036225_1389210309`;
UNINSTALL EXTENSION vsql_schematron;
