INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 071970_schema
--echo #
CREATE DATABASE `db_071970_schema`;
USE `db_071970_schema`;
CREATE TABLE `lines` (
  `name` TEXT,
  `description` TEXT,
  `start_time` TEXT,
  `end_time` TEXT,
  `frequency` INT,
  `speed` INT,
  `color` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `coordinates` TEXT,
  `map_id` INT,
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `maps` (
  `id` INT NOT NULL,
  `name` TEXT,
  `center` TEXT,
  `zoom_level` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schema_info` (
  `version` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_071970_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_071970_schema') AS relationships;
DROP DATABASE `db_071970_schema`;
UNINSTALL EXTENSION vsql_schematron;
