CREATE TABLE `bail` (
  `id` INT,
  `amount` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `casestatus` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `casetype` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

