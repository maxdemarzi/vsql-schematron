INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015178_filehosting
--echo #
CREATE DATABASE `db_015178_filehosting`;
USE `db_015178_filehosting`;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `original_name` CHAR(50),
  `path` CHAR(50),
  `thumbnail_path` CHAR(50),
  `description` CHAR(50),
  `size` INT,
  `mime_type` CHAR(50),
  `date` TIMESTAMP NULL,
  `downloads` INT,
  `user_id` INT,
  `user_token` CHAR(50),
  `media_info` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` CHAR(50),
  `avatar` CHAR(50),
  `email` CHAR(50),
  `password` CHAR(50),
  `auth_token` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `file_id` INT,
  `parent_id` INT,
  `user_id` INT,
  `date` TIMESTAMP NULL,
  `text` CHAR(50),
  `matpath` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015178_filehosting') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015178_filehosting') AS relationships;
DROP DATABASE `db_015178_filehosting`;
UNINSTALL EXTENSION vsql_schematron;
