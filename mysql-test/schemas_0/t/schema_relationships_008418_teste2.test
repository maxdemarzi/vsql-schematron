INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008418_teste2
--echo #
CREATE DATABASE `db_008418_teste2`;
USE `db_008418_teste2`;

CREATE TABLE `Pais` (
  `id_pai` INT,
  `nome_pai` VARCHAR(64),
  `continente_pai` VARCHAR(64),
  PRIMARY KEY (`id_pai`)
) CHARACTER SET latin1;

CREATE TABLE `Estado` (
  `id_est` INT,
  `nome_est` VARCHAR(64),
  `sigla_est` VARCHAR(64),
  `regiao_est` VARCHAR(64),
  `id_pai_fk` INT,
  PRIMARY KEY (`id_est`)
) CHARACTER SET latin1;

CREATE TABLE `Cidade` (
  `id_cid` INT,
  `nome_cid` VARCHAR(64),
  `data_criacao_cid` DATETIME,
  `id_est_fk` INT,
  PRIMARY KEY (`id_cid`)
) CHARACTER SET latin1;

CREATE TABLE `Endereco` (
  `id_end` INT,
  `rua_end` VARCHAR(64),
  `numero_end` INT,
  `bairro_end` VARCHAR(64),
  `id_cid_fk` INT,
  PRIMARY KEY (`id_end`)
) CHARACTER SET latin1;

CREATE TABLE `Cliente` (
  `id_cli` INT,
  `nome_cli` VARCHAR(64),
  `cpf_cli` VARCHAR(64),
  `data_nasc_cli` DATETIME,
  `sexo_cli` VARCHAR(64),
  `email_cli` VARCHAR(64),
  `id_end_fk` INT,
  PRIMARY KEY (`id_cli`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008418_teste2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008418_teste2') AS relationships;
DROP DATABASE `db_008418_teste2`;
UNINSTALL EXTENSION vsql_schematron;
