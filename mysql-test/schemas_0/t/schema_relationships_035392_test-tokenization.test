INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035392_test-tokenization
--echo #
CREATE DATABASE `db_035392_test_tokenization`;
USE `db_035392_test_tokenization`;
CREATE TABLE `format_scheme` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `database_owner` (
  `db_name` VARCHAR(50) NOT NULL,
  `description` VARCHAR(50),
  `owner_id` VARCHAR(50),
  `owner_email` VARCHAR(50),
  PRIMARY KEY (`db_name`)
) CHARACTER SET latin1;
CREATE TABLE `client_database` (
  `client_id` VARCHAR(50) NOT NULL,
  `db_name` VARCHAR(50),
  PRIMARY KEY (`client_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035392_test_tokenization') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035392_test_tokenization') AS relationships;
DROP DATABASE `db_035392_test_tokenization`;
UNINSTALL EXTENSION vsql_schematron;
