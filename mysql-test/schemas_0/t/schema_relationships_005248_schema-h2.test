INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005248_schema-h2
--echo #
CREATE DATABASE `db_005248_schema_h2`;
USE `db_005248_schema_h2`;
CREATE TABLE `PRODUCT` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `MANUFACTURER` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SUPPLY_CHAIN` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REGION` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SUPPLY_CHAIN_REF` (
  `ID` INT NOT NULL,
  `SUPPLY_CHAIN_ID` INT,
  `PRODUCT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REGION_REF` (
  `ID` INT NOT NULL,
  `REGION_ID` INT,
  `PRODUCT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005248_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005248_schema_h2') AS relationships;
DROP DATABASE `db_005248_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
