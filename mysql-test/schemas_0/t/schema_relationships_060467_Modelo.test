INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060467_Modelo
--echo #
CREATE DATABASE `db_060467_Modelo`;
USE `db_060467_Modelo`;

CREATE TABLE `cliente` (
  `cedula` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  `direccion` VARCHAR(64),
  PRIMARY KEY (`cedula`)
) CHARACTER SET latin1;

CREATE TABLE `danio` (
  `id` DECIMAL(10,2),
  `descricion_problema` VARCHAR(64),
  `tipo_anomalia_id` DECIMAL(10,2),
  `solicitud_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `funcionario` (
  `id` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `producto` (
  `id` DECIMAL(10,2),
  `fecha_inicio` DATETIME,
  `fecha_retiro` DATETIME,
  `estado_producto` VARCHAR(64),
  `cliente_cedula` DECIMAL(10,2),
  `tipo_producto_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `solicitud` (
  `id` DECIMAL(10,2),
  `observacion` VARCHAR(64),
  `fecha_solicitud` DATETIME,
  `fecha_atencion` DATETIME,
  `estado_atencion` VARCHAR(64),
  `cliente_cedula` DECIMAL(10,2),
  `tiposolicitud_id` DECIMAL(10,2),
  `funcionario_id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tipo_anomalia` (
  `id` DECIMAL(10,2),
  `nombre_anomalia` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tipo_producto` (
  `id` DECIMAL(10,2),
  `nombre_tipo_producto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tiposolicitud` (
  `id` DECIMAL(10,2),
  `nombre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060467_Modelo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060467_Modelo') AS relationships;
DROP DATABASE `db_060467_Modelo`;
UNINSTALL EXTENSION vsql_schematron;
