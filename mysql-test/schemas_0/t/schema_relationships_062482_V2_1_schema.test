INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062482_V2_1_schema
--echo #
CREATE DATABASE `db_062482_V2_1_schema`;
USE `db_062482_V2_1_schema`;

CREATE TABLE `mapping.organisation_class` (
  `organisation_class` VARCHAR(64),
  `organisation_class_name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`organisation_class`)
) CHARACTER SET latin1;

CREATE TABLE `mapping.organisation` (
  `ods_code` VARCHAR(64),
  `organisation_name` VARCHAR(64),
  `organisation_class` VARCHAR(64),
  `organisation_type` VARCHAR(64),
  `address_line1` VARCHAR(64),
  `address_line2` VARCHAR(64),
  `town` VARCHAR(64),
  `county` VARCHAR(64),
  `postcode` VARCHAR(64),
  `is_mapped` VARCHAR(64),
  `manual_mapping` VARCHAR(64),
  `last_updated` DATETIME,
  PRIMARY KEY (`ods_code`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062482_V2_1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062482_V2_1_schema') AS relationships;
DROP DATABASE `db_062482_V2_1_schema`;
UNINSTALL EXTENSION vsql_schematron;
