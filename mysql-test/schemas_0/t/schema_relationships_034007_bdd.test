INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 034007_bdd
--echo #
CREATE DATABASE `db_034007_bdd`;
USE `db_034007_bdd`;
CREATE TABLE `cards` (
  `card_id` INT NOT NULL,
  `gifted_client_id` INT,
  `user_client_id` INT,
  `user_id` INT,
  `value` INT,
  PRIMARY KEY (`card_id`)
) CHARACTER SET latin1;
CREATE TABLE `gifted_clients` (
  `gifted_client_id` INT NOT NULL,
  `user_id` INT,
  `user_client_id` INT,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  `address` VARCHAR(50),
  `phone` VARCHAR(50),
  `sale_nb` INT,
  PRIMARY KEY (`gifted_client_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_034007_bdd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_034007_bdd') AS relationships;
DROP DATABASE `db_034007_bdd`;
UNINSTALL EXTENSION vsql_schematron;
