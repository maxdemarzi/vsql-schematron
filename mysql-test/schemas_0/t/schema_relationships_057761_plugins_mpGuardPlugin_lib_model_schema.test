INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057761_plugins.mpGuardPlugin.lib.model.schema
--echo #
CREATE DATABASE `db_057761_plugins_mpGuardPlugin_lib_model_schema`;
USE `db_057761_plugins_mpGuardPlugin_lib_model_schema`;

CREATE TABLE `sf_guard_group_permission` (
  `group_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`group_id`, `permission_id`)
) CHARACTER SET latin1;

CREATE TABLE `sf_guard_permission` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sf_guard_user_group` (
  `user_id` INT,
  `group_id` INT,
  PRIMARY KEY (`user_id`, `group_id`)
) CHARACTER SET latin1;

CREATE TABLE `sf_guard_user_permission` (
  `user_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`user_id`, `permission_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057761_plugins_mpGuardPlugin_lib_model_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057761_plugins_mpGuardPlugin_lib_model_schema') AS relationships;
DROP DATABASE `db_057761_plugins_mpGuardPlugin_lib_model_schema`;
UNINSTALL EXTENSION vsql_schematron;
