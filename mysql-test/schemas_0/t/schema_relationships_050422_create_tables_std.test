INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 050422_create-tables-std
--echo #
CREATE DATABASE `db_050422_create_tables_std`;
USE `db_050422_create_tables_std`;

CREATE TABLE `match` (
  `paysl` VARCHAR(64),
  `paysv` VARCHAR(64),
  `butsl` INT,
  `butsv` INT,
  `type` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`paysl`, `paysv`, `type`)
) CHARACTER SET latin1;

CREATE TABLE `pays` (
  `nom` VARCHAR(64),
  `groupe` VARCHAR(64),
  PRIMARY KEY (`nom`)
) CHARACTER SET latin1;

CREATE TABLE `typematch` (
  `type` VARCHAR(64),
  PRIMARY KEY (`type`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_050422_create_tables_std') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_050422_create_tables_std') AS relationships;
DROP DATABASE `db_050422_create_tables_std`;
UNINSTALL EXTENSION vsql_schematron;
