INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 078772_employees
--echo #
CREATE DATABASE `db_078772_employees`;
USE `db_078772_employees`;
CREATE TABLE `department` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `id` VARCHAR(50) NOT NULL,
  `firstname` VARCHAR(50),
  `lastname` VARCHAR(50),
  `role_id` VARCHAR(50),
  `manager_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_078772_employees') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_078772_employees') AS relationships;
DROP DATABASE `db_078772_employees`;
UNINSTALL EXTENSION vsql_schematron;
