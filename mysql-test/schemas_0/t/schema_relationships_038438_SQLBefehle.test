INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038438_SQLBefehle
--echo #
CREATE DATABASE `db_038438_SQLBefehle`;
USE `db_038438_SQLBefehle`;
CREATE TABLE `categories` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
  `id` VARCHAR(50) NOT NULL,
  `a` VARCHAR(50),
  `b` VARCHAR(50),
  `c` VARCHAR(50),
  `d` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` VARCHAR(50) NOT NULL,
  `question` VARCHAR(50),
  `difficulty` INT,
  `answer_id` VARCHAR(50),
  `solution` INT,
  `category_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038438_SQLBefehle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038438_SQLBefehle') AS relationships;
DROP DATABASE `db_038438_SQLBefehle`;
UNINSTALL EXTENSION vsql_schematron;
