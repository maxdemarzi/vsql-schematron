INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010987_schemafooddelivery
--echo #
CREATE DATABASE `db_010987_schemafooddelivery`;
USE `db_010987_schemafooddelivery`;

CREATE TABLE `fdcategory` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `categoryname` VARCHAR(64),
  `categoryphoto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fddishes` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `dishname` VARCHAR(64),
  `dishcategory` INT,
  `dishdescription` VARCHAR(64),
  `dishingredients` VARCHAR(64),
  `dishphoto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdgallery` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `dish` INT,
  `dishphoto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdprises` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `dish` INT,
  `price` DECIMAL(10,2),
  `productcost` DECIMAL(10,2),
  `active` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdcomments` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `dish` INT,
  `comment` VARCHAR(64),
  `rate` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdclients` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `clientname` VARCHAR(64),
  `clientsphonenumber` VARCHAR(64),
  `clientsaddress` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdorderstatus` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `statusname` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdorders` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `orderdate` DATETIME,
  `client` INT,
  `deliveryaddress` VARCHAR(64),
  `status` INT,
  `totalcost` DECIMAL(10,2),
  `ordercomment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fdorderlist` (
  `id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `dish` INT,
  `price` DECIMAL(10,2),
  `quantity` INT,
  `cost` DECIMAL(10,2),
  `ordernumber` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010987_schemafooddelivery') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010987_schemafooddelivery') AS relationships;
DROP DATABASE `db_010987_schemafooddelivery`;
UNINSTALL EXTENSION vsql_schematron;
