INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033831_db
--echo #
CREATE DATABASE `db_033831_db`;
USE `db_033831_db`;
CREATE TABLE `teamb-2019winter.users` (
  `e_mail` VARCHAR(50),
  `fname` VARCHAR(50),
  `lname` VARCHAR(50),
  `hash_pwd` VARCHAR(50),
  `sex` VARCHAR(50),
  `user_seq_num` INT NOT NULL,
  `admin` TINYINT,
  `hash` VARCHAR(50),
  `active` TINYINT,
  PRIMARY KEY (`user_seq_num`)
) CHARACTER SET latin1;
CREATE TABLE `teamb-2019winter.sensor` (
  `mac_addr` CHAR(50),
  `dev_id` INT NOT NULL,
  `dev_name` VARCHAR(50),
  `users_user_seq_num` INT,
  PRIMARY KEY (`dev_id`)
) CHARACTER SET latin1;
CREATE TABLE `teamb-2019winter.air_sensor` (
  `air_date` DATETIME,
  `lat` DOUBLE,
  `log` DOUBLE,
  `RAW_pm` DOUBLE,
  `RAW_CO` DOUBLE,
  `RAW_SO2` DOUBLE,
  `RAW_NO2` DOUBLE,
  `RAW_O3` DOUBLE,
  `air_id` INT NOT NULL,
  `AQI_PM` INT,
  `AQI_CO` INT,
  `AQI_NO2` INT,
  `AQI_SO2` INT,
  `AQI_O3` INT,
  `sensor_dev_id` INT,
  PRIMARY KEY (`air_id`)
) CHARACTER SET latin1;
CREATE TABLE `teamb-2019winter.heart_sensor` (
  `heart_date` DATETIME,
  `heart_rate` INT,
  `rr_inter` DOUBLE,
  `heart_id` INT NOT NULL,
  `heart_lat` DOUBLE,
  `heart_log` DOUBLE,
  `users_user_seq_num` INT,
  PRIMARY KEY (`heart_id`)
) CHARACTER SET latin1;
CREATE TABLE `teamb-2019winter.temp_sensor` (
  `temperature` DOUBLE,
  `temp_code` INT,
  `climate_today` DATETIME,
  `temp_id` INT NOT NULL,
  `sensor_dev_id` INT,
  PRIMARY KEY (`temp_id`)
) CHARACTER SET latin1;
CREATE TABLE `teamb-2019winter.sign_state` (
  `sign_inout` TINYINT,
  `sign_id` VARCHAR(50) NOT NULL,
  `users_user_seq_num` INT,
  PRIMARY KEY (`sign_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033831_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033831_db') AS relationships;
DROP DATABASE `db_033831_db`;
UNINSTALL EXTENSION vsql_schematron;
