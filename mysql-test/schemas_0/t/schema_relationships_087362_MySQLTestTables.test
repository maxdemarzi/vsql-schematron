INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087362_MySQLTestTables
--echo #
CREATE DATABASE `db_087362_MySQLTestTables`;
USE `db_087362_MySQLTestTables`;
CREATE TABLE `product` (
  `id` VARCHAR(50) NOT NULL,
  `ean` VARCHAR(50),
  `stock` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `productExtension` (
  `id` VARCHAR(50) NOT NULL,
  `productId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087362_MySQLTestTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087362_MySQLTestTables') AS relationships;
DROP DATABASE `db_087362_MySQLTestTables`;
UNINSTALL EXTENSION vsql_schematron;
