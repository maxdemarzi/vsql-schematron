INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 085573_consulting
--echo #
CREATE DATABASE `db_085573_consulting`;
USE `db_085573_consulting`;
CREATE TABLE `consultant` (
  `id` INT NOT NULL,
  `lastname` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
  `id` INT NOT NULL,
  `lastname` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consulting` (
  `id` INT NOT NULL,
  `consultant_k` INT,
  `client_k` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_085573_consulting') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_085573_consulting') AS relationships;
DROP DATABASE `db_085573_consulting`;
UNINSTALL EXTENSION vsql_schematron;
