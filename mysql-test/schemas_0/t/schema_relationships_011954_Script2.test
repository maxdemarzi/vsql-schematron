INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 011954_Script2
--echo #
CREATE DATABASE `db_011954_Script2`;
USE `db_011954_Script2`;
CREATE TABLE `permissions` (
  `id` INT NOT NULL,
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `id` INT NOT NULL,
  `role_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role_sets` (
  `role_id` INT,
  `permission_id` INT
) CHARACTER SET latin1;
CREATE TABLE `states` (
  `id` INT NOT NULL,
  `state_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `category_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `user_name` VARCHAR(50),
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `author_id` INT,
  `assignee_id` INT,
  `state_id` INT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `ticket_id` INT,
  `comment_text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
  `id` INT NOT NULL,
  `ticket_id` INT,
  `file_data` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_011954_Script2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_011954_Script2') AS relationships;
DROP DATABASE `db_011954_Script2`;
UNINSTALL EXTENSION vsql_schematron;
