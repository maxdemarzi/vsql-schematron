INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005831_database
--echo #
CREATE DATABASE `db_005831_database`;
USE `db_005831_database`;
CREATE TABLE `pet_types` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pets` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `pet_type_id` INT,
  `age` SMALLINT,
  `has_microchip` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owners` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet_owners` (
  `id` INT NOT NULL,
  `pet_id` INT,
  `owner_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005831_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005831_database') AS relationships;
DROP DATABASE `db_005831_database`;
UNINSTALL EXTENSION vsql_schematron;
