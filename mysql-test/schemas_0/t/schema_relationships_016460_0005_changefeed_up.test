INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016460_0005_changefeed.up
--echo #
CREATE DATABASE `db_016460_0005_changefeed_up`;
USE `db_016460_0005_changefeed_up`;
CREATE TABLE `change_category` (
  `category` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`category`)
) CHARACTER SET latin1;
CREATE TABLE `changefeed` (
  `id` INT NOT NULL,
  `created_at` TIMESTAMP NULL,
  `gun` VARCHAR(50),
  `version` INT,
  `sha256` CHAR(50),
  `category` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016460_0005_changefeed_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016460_0005_changefeed_up') AS relationships;
DROP DATABASE `db_016460_0005_changefeed_up`;
UNINSTALL EXTENSION vsql_schematron;
