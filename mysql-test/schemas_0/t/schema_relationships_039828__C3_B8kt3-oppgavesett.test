CREATE DATABASE `db_039828__C3_B8kt3_oppgavesett`;
USE `db_039828__C3_B8kt3_oppgavesett`;
CREATE TABLE `person` (
  `ID` INT NOT NULL,
  `Personnummer` CHAR(50),
  `Navn` VARCHAR(50),
  `EPost` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `mailtest` (
  `Adresse` VARCHAR(50) NOT NULL,
  `Type` VARCHAR(50),
  `Person_ID` INT,
  PRIMARY KEY (`Adresse`)
) CHARACTER SET latin1;
CREATE TABLE `personCopy` (
  `ID` INT NOT NULL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
