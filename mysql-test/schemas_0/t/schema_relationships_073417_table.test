INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 073417_table
--echo #
CREATE DATABASE `db_073417_table`;
USE `db_073417_table`;

CREATE TABLE `public.migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.user_roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `enabled` VARCHAR(64),
  `user_role_id` INT,
  `photo` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `public.channels` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.topics` (
  `id` INT,
  `name` VARCHAR(64),
  `channel_id` INT,
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.discussions` (
  `id` INT,
  `user_id` INT,
  `topic_id` INT,
  `title` VARCHAR(64),
  `slug` VARCHAR(64),
  `content` VARCHAR(64),
  `views` INT,
  `archived` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.report_reasons` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.topic_bookmarks` (
  `id` INT,
  `user_id` INT,
  `topic_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.discussion_bookmarks` (
  `id` INT,
  `user_id` INT,
  `discussion_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.discussion_reports` (
  `id` INT,
  `user_id` INT,
  `discussion_id` INT,
  `content` VARCHAR(64),
  `report_reason_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.replies` (
  `id` INT,
  `user_id` INT,
  `discussion_id` INT,
  `content` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.reply_downvotes` (
  `id` INT,
  `user_id` INT,
  `reply_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.reply_reports` (
  `id` INT,
  `user_id` INT,
  `reply_id` INT,
  `content` VARCHAR(64),
  `report_reason_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.reply_upvotes` (
  `id` INT,
  `user_id` INT,
  `reply_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_073417_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_073417_table') AS relationships;
DROP DATABASE `db_073417_table`;
UNINSTALL EXTENSION vsql_schematron;
