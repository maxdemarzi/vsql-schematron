INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 076574_migration
--echo #
CREATE DATABASE `db_076574_migration`;
USE `db_076574_migration`;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Byte` (
  `id` VARCHAR(64),
  `userId` VARCHAR(64),
  `css` VARCHAR(64),
  `xml` VARCHAR(64),
  `js` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Stylesheet` (
  `id` VARCHAR(64),
  `userId` VARCHAR(64),
  `locked` BOOL,
  `css` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` VARCHAR(64),
  `slug` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ByteToStylesheet` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_ByteToTag` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_076574_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_076574_migration') AS relationships;
DROP DATABASE `db_076574_migration`;
UNINSTALL EXTENSION vsql_schematron;
