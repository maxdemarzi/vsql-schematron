INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 036964_url_title
--echo #
CREATE DATABASE `db_036964_url_title`;
USE `db_036964_url_title`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `id` INT,
  `name` VARCHAR(64),
  `parent` INT,
  `route` VARCHAR(64),
  `order` INT,
  `data` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `url_title` (
  `id` INT,
  `url` VARCHAR(64),
  `title` VARCHAR(64),
  `status_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `auth_key` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `password_reset_token` VARCHAR(64),
  `email` VARCHAR(64),
  `status` INT,
  `created_at` INT,
  `updated_at` INT,
  `verification_token` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_036964_url_title') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_036964_url_title') AS relationships;
DROP DATABASE `db_036964_url_title`;
UNINSTALL EXTENSION vsql_schematron;
