INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058067_V_54__migrate_sec
--echo #
CREATE DATABASE `db_058067_V_54__migrate_sec`;
USE `db_058067_V_54__migrate_sec`;
CREATE TABLE `sec_stubtype` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sec_cds` (
  `id` BIGINT NOT NULL,
  `security_id` BIGINT,
  `notional` DOUBLE,
  `recovery_rate` DOUBLE,
  `spread` DOUBLE,
  `currency_id` BIGINT,
  `maturity_date` DATETIME,
  `maturity_date_zone` VARCHAR(50),
  `start_date` DATETIME,
  `start_date_zone` VARCHAR(50),
  `premium_frequency_id` BIGINT,
  `daycountconvention_id` BIGINT,
  `businessdayconvention_id` BIGINT,
  `stubtype_id` BIGINT,
  `settlement_days` INT,
  `underlying_issuer` VARCHAR(50),
  `underlying_currency_id` BIGINT,
  `underlying_seniority` VARCHAR(50),
  `restructuring_clause` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058067_V_54__migrate_sec') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058067_V_54__migrate_sec') AS relationships;
DROP DATABASE `db_058067_V_54__migrate_sec`;
UNINSTALL EXTENSION vsql_schematron;
