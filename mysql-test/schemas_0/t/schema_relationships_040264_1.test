INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 040264_1
--echo #
CREATE DATABASE `db_040264_1`;
USE `db_040264_1`;

CREATE TABLE `account` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_client` (
  `id` INT,
  `owner_id` INT,
  `grant_type` VARCHAR(64),
  `client_id` VARCHAR(64),
  `client_secret` VARCHAR(64),
  `redirect_uri` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_authorization_code` (
  `id` INT,
  `account_id` INT,
  `oauth_client_id` INT,
  `code` VARCHAR(64),
  `redirect_uri` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `oauth_access_token` (
  `id` INT,
  `account_id` INT,
  `oauth_client_id` INT,
  `access_token` VARCHAR(64),
  `refresh_token` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_040264_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_040264_1') AS relationships;
DROP DATABASE `db_040264_1`;
UNINSTALL EXTENSION vsql_schematron;
