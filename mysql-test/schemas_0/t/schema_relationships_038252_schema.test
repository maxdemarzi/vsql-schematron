INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 038252_schema
--echo #
CREATE DATABASE `db_038252_schema`;
USE `db_038252_schema`;
CREATE TABLE `customer` (
  `customer_id` BIGINT NOT NULL,
  `id` BLOB,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `product_id` BIGINT NOT NULL,
  `id` BLOB,
  `customer_id` BIGINT,
  `price` DOUBLE,
  `image` VARCHAR(50),
  `brand` VARCHAR(50),
  `title` VARCHAR(50),
  `review_score` DOUBLE,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `username` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
  `username` VARCHAR(50) NOT NULL,
  `role` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`username`, `role`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_038252_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_038252_schema') AS relationships;
DROP DATABASE `db_038252_schema`;
UNINSTALL EXTENSION vsql_schematron;
