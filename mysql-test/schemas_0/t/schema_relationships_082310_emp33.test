INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 082310_emp33
--echo #
CREATE DATABASE `db_082310_emp33`;
USE `db_082310_emp33`;
CREATE TABLE `emp33` (
  `eno` VARCHAR(50) NOT NULL,
  `ename` VARCHAR(50),
  `job_type` VARCHAR(50),
  `manager` CHAR(50),
  `hire_date` DATE,
  `dno` INT,
  `commission` DECIMAL(10,2),
  `salary` DECIMAL(10,2),
  PRIMARY KEY (`eno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_082310_emp33') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_082310_emp33') AS relationships;
DROP DATABASE `db_082310_emp33`;
UNINSTALL EXTENSION vsql_schematron;
