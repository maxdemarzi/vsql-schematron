INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070742_db
--echo #
CREATE DATABASE `db_070742_db`;
USE `db_070742_db`;

CREATE TABLE `tbl_training` (
  `cod` INT,
  `entrenamiento` VARCHAR(64),
  PRIMARY KEY (`cod`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_horarios` (
  `codhorario` INT,
  `nombre` VARCHAR(64),
  `codentrenamiento` INT,
  PRIMARY KEY (`codhorario`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_clientes` (
  `idcliente` INT,
  `cedula` VARCHAR(64),
  `nombre` VARCHAR(64),
  `telefono` VARCHAR(64),
  `correo` VARCHAR(64),
  `codentrenamiento` INT,
  PRIMARY KEY (`idcliente`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070742_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070742_db') AS relationships;
DROP DATABASE `db_070742_db`;
UNINSTALL EXTENSION vsql_schematron;
