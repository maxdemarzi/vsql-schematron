INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002801_PL02-SQL%20DML%20SELECT-Ex%20Campeonato-Criar%20BD
--echo #
CREATE DATABASE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;
USE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;

CREATE TABLE `equipas` (
  `id_equipa` INT,
  `nome` VARCHAR(64),
  `cidade` VARCHAR(64),
  `diretor` VARCHAR(64),
  PRIMARY KEY (`id_equipa`)
) CHARACTER SET latin1;

CREATE TABLE `treinadores` (
  `id_treinador` INT,
  `nome` VARCHAR(64),
  `idade` INT,
  `telefone` VARCHAR(64),
  PRIMARY KEY (`id_treinador`)
) CHARACTER SET latin1;

CREATE TABLE `bolas` (
  `referencia` VARCHAR(64),
  `id_equipa` INT,
  `fabricante` VARCHAR(64),
  PRIMARY KEY (`id_equipa`, `referencia`)
) CHARACTER SET latin1;

CREATE TABLE `experiencias` (
  `id_equipa` INT,
  `id_treinador` INT,
  `escalao` VARCHAR(64),
  `anos` DECIMAL(10,2),
  PRIMARY KEY (`id_equipa`, `id_treinador`, `escalao`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD') AS relationships;
DROP DATABASE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;
UNINSTALL EXTENSION vsql_schematron;
