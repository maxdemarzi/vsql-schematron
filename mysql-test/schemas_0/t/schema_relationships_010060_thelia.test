INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010060_thelia
--echo #
CREATE DATABASE `db_010060_thelia`;
USE `db_010060_thelia`;

CREATE TABLE `choice_filter_other` (
  `id` INT,
  `type` VARCHAR(64),
  `visible` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `choice_filter` (
  `id` INT,
  `feature_id` INT,
  `attribute_id` INT,
  `other_id` INT,
  `category_id` INT,
  `template_id` INT,
  `position` INT,
  `visible` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `choice_filter_other_i18n` (
  `id` INT,
  `locale` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`, `locale`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010060_thelia') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010060_thelia') AS relationships;
DROP DATABASE `db_010060_thelia`;
UNINSTALL EXTENSION vsql_schematron;
