INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 071177_csfdoh
--echo #
CREATE DATABASE `db_071177_csfdoh`;
USE `db_071177_csfdoh`;
CREATE TABLE `accounts` (
  `accID` INT NOT NULL,
  `name` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`accID`)
) CHARACTER SET latin1;
CREATE TABLE `account_logs` (
  `id` INT NOT NULL,
  `accID` INT,
  `log` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_071177_csfdoh') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_071177_csfdoh') AS relationships;
DROP DATABASE `db_071177_csfdoh`;
UNINSTALL EXTENSION vsql_schematron;
