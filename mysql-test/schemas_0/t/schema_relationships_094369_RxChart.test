INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094369_RxChart
--echo #
CREATE DATABASE `db_094369_RxChart`;
USE `db_094369_RxChart`;

CREATE TABLE `MedHistory` (
  `Id` INT,
  `ResidentId` INT,
  `MedicineId` INT,
  `UserId` INT,
  `Notes` VARCHAR(64),
  `In` INT,
  `Out` INT,
  `Created` DATETIME,
  `Updated` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Medicine` (
  `Id` INT,
  `ResidentId` INT,
  `UserId` INT,
  `MedicineId` INT,
  `Drug` VARCHAR(64),
  `OtherNames` VARCHAR(64),
  `Strength` VARCHAR(64),
  `Barcode` VARCHAR(64),
  `Directions` VARCHAR(64),
  `FillDateMonth` INT,
  `FillDateDay` INT,
  `FillDateYear` INT,
  `Notes` VARCHAR(64),
  `Active` INT,
  `OTC` INT,
  `Pillbox` INT,
  `Quantity` INT,
  `Created` DATETIME,
  `Updated` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094369_RxChart') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094369_RxChart') AS relationships;
DROP DATABASE `db_094369_RxChart`;
UNINSTALL EXTENSION vsql_schematron;
