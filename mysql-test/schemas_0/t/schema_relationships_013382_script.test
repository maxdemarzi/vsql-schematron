INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 013382_script
--echo #
CREATE DATABASE `db_013382_script`;
USE `db_013382_script`;
CREATE TABLE `tienda` (
  `id_tienda` INT NOT NULL,
  `nombre` VARCHAR(50),
  `provincia` VARCHAR(50),
  `direccion` VARCHAR(50),
  `telefono` INT,
  `email` VARCHAR(50),
  PRIMARY KEY (`id_tienda`)
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `dni` VARCHAR(50) NOT NULL,
  `nombre` VARCHAR(50),
  `apellido1` VARCHAR(50),
  `apellido2` VARCHAR(50),
  `telefono` INT,
  `rol` VARCHAR(50),
  `id_tienda` INT,
  `usuario` VARCHAR(50) NOT NULL,
  `password` VARCHAR(50),
  PRIMARY KEY (`dni`, `usuario`)
) CHARACTER SET latin1;
CREATE TABLE `juegos` (
  `id_juego` INT NOT NULL,
  `titulo` VARCHAR(50),
  `plataforma` VARCHAR(50),
  `estudio` VARCHAR(50),
  `genero` VARCHAR(50),
  PRIMARY KEY (`id_juego`)
) CHARACTER SET latin1;
CREATE TABLE `ejemplares` (
  `id_ejemplar` INT NOT NULL,
  `estado` VARCHAR(50),
  `id_juego` INT,
  PRIMARY KEY (`id_ejemplar`)
) CHARACTER SET latin1;
CREATE TABLE `juegos_venta` (
  `id_venta` INT NOT NULL,
  `dni` VARCHAR(50),
  `fecha` DATE,
  `id_ejemplar` INT,
  PRIMARY KEY (`id_venta`)
) CHARACTER SET latin1;
CREATE TABLE `juegos_alquiler` (
  `id_alquiler` INT NOT NULL,
  `dni` VARCHAR(50),
  `fecha` DATE,
  `id_ejemplar` INT,
  PRIMARY KEY (`id_alquiler`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_013382_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_013382_script') AS relationships;
DROP DATABASE `db_013382_script`;
UNINSTALL EXTENSION vsql_schematron;
