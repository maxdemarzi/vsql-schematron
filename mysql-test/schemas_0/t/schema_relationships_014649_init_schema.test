INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014649_init_schema
--echo #
CREATE DATABASE `db_014649_init_schema`;
USE `db_014649_init_schema`;

CREATE TABLE `Users` (
  `Album` INT,
  `FirstName` VARCHAR(64),
  `LastName` VARCHAR(64),
  `Password` VARCHAR(64),
  `PasswordSalt` VARCHAR(64),
  `Email` VARCHAR(64),
  `Photo` VARCHAR(64),
  `IsAdmin` BOOL,
  `IsActive` BOOL,
  `CreatedOn` DATETIME,
  PRIMARY KEY (`Album`)
) CHARACTER SET latin1;

CREATE TABLE `Groups` (
  `ID` INT,
  `ModeOfStudy` VARCHAR(64),
  `FieldOfStudy` VARCHAR(64),
  `GroupNumber` VARCHAR(64),
  `GroupHalf` VARCHAR(64),
  `CourseName` VARCHAR(64),
  `Link` VARCHAR(64),
  `Description` VARCHAR(64),
  `IsActive` BOOL,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `GroupAssignments` (
  `ID` INT,
  `StudentID` INT,
  `GroupID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Classes` (
  `ID` INT,
  `GroupID` INT,
  `ClassNumber` INT,
  `TakenOn` DATETIME,
  `Title` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ClassAttendances` (
  `ID` INT,
  `ClassID` INT,
  `GroupID` INT,
  `UserID` INT,
  `IsPresent` BOOL,
  `IsReportRequired` BOOL,
  `ReportFile` VARCHAR(64),
  `ReportGrade` INT,
  `ReportAddedOn` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Theses` (
  `ID` INT,
  `Type` VARCHAR(64),
  `Year` INT,
  `GraduateName` VARCHAR(64),
  `GraduateID` INT,
  `Title` VARCHAR(64),
  `UsedTechnologies` VARCHAR(64),
  `Goal` VARCHAR(64),
  `Sketch` VARCHAR(64),
  `Link` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ThesisVolunteers` (
  `ID` INT,
  `ThesisID` INT,
  `StudentID` INT,
  `CreatedOn` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Consultations` (
  `ID` INT,
  `StudentID` INT,
  `ReservationOn` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Questionnaires` (
  `ID` INT,
  `CreatedOn` DATETIME,
  `GroupID` INT,
  `Grade` INT,
  `Speed` INT,
  `Value` INT,
  `Comments` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Articles` (
  `ID` INT,
  `Title` VARCHAR(64),
  `Content` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014649_init_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014649_init_schema') AS relationships;
DROP DATABASE `db_014649_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
