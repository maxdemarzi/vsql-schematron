INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028559_movies
--echo #
CREATE DATABASE `db_028559_movies`;
USE `db_028559_movies`;

CREATE TABLE `actors` (
  `act_id` INT,
  `act_name` VARCHAR(64),
  `act_gender` VARCHAR(64),
  PRIMARY KEY (`act_id`)
) CHARACTER SET latin1;

CREATE TABLE `directors` (
  `dir_id` INT,
  `dir_name` VARCHAR(64),
  `dir_phone` VARCHAR(64),
  PRIMARY KEY (`dir_id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `mov_id` INT,
  `mov_title` VARCHAR(64),
  `mov_year` INT,
  `mov_lang` VARCHAR(64),
  `dir_id` INT,
  PRIMARY KEY (`mov_id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_casts` (
  `act_id` INT,
  `mov_id` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`act_id`, `mov_id`)
) CHARACTER SET latin1;

CREATE TABLE `ratings` (
  `mov_id` INT,
  `rev_stars` INT,
  PRIMARY KEY (`mov_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028559_movies') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028559_movies') AS relationships;
DROP DATABASE `db_028559_movies`;
UNINSTALL EXTENSION vsql_schematron;
