CREATE TABLE `VHF_ACCESSOIRES_TYPES` (
  `idVhfAccessoireType` INT NOT NULL,
  `libelleVhfAccessoireType` TEXT,
  PRIMARY KEY (`idVhfAccessoireType`)
) CHARACTER SET latin1;
