  `idVhfAccessoire` INT NOT NULL,
  `libelleVhfAccessoire` TEXT,
  `marqueModeleVhfAccessoire` TEXT,
  `idVhfAccessoireType` INT,
  `idVhfEquipement` INT,
  `SnVhfAccessoire` VARCHAR(50),
  `remarquesVhfAccessoire` TEXT,
  PRIMARY KEY (`idVhfAccessoire`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
