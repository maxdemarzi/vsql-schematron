INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 003470_ALL
--echo #
CREATE DATABASE `db_003470_ALL`;
USE `db_003470_ALL`;

CREATE TABLE `USER` (
  `ID` VARCHAR(255),
  `USERNAME` VARCHAR(255),
  `EMAIL` VARCHAR(255),
  `PASSWORD` VARCHAR(255),
  `FULL_NAME` VARCHAR(255),
  `NAME_ALT` VARCHAR(255),
  `PHONE` VARCHAR(255),
  `GENDER` INT,
  `AVATAR` VARCHAR(255),
  `IDENTITY_NUMBER` VARCHAR(255),
  `IDENTITY_PICTURE` VARCHAR(255),
  `ADDRESS` VARCHAR(255),
  `DEVICE_ID` VARCHAR(255),
  `ID_CREATE` VARCHAR(255),
  `DATE_CREATE` DATETIME,
  `ID_UPDATE` VARCHAR(255),
  `DATE_UPDATE` DATETIME,
  `TYPE` INT,
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HELP_TYPE` (
  `ID` VARCHAR(255),
  `VECHILE` INT,
  `NAME` VARCHAR(255),
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_HELP_CONF` (
  `ID` VARCHAR(255),
  `ID_USER` VARCHAR(255),
  `ID_HELP_TYPE` VARCHAR(255),
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HELP_RESPONSE` (
  `ID` VARCHAR(255),
  `ID_USER` VARCHAR(255),
  `ID_HELP_REQUEST` VARCHAR(255),
  `RESPONSE` INT,
  `RATING` INT,
  `ID_CREATE` VARCHAR(255),
  `DATE_CREATE` DATETIME,
  `ID_UPDATE` VARCHAR(255),
  `DATE_UPDATE` DATETIME,
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HELP_REQUEST` (
  `ID` VARCHAR(255),
  `ID_USER` VARCHAR(255),
  `ID_HELP_TYPE` VARCHAR(255),
  `MESSAGE` VARCHAR(255),
  `LATITUDE` DECIMAL(10,2),
  `LONGTITUDE` DECIMAL(10,2),
  `LOCATION_NAME` VARCHAR(255),
  `ID_CREATE` VARCHAR(255),
  `DATE_CREATE` DATETIME,
  `ID_UPDATE` VARCHAR(255),
  `DATE_UPDATE` DATETIME,
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_LOCATION` (
  `ID` VARCHAR(255),
  `ID_USER` VARCHAR(255),
  `LATITUDE` DECIMAL(10,2),
  `LONGTITUDE` DECIMAL(10,2),
  `DATE` DATETIME,
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `GARAGE` (
  `ID` VARCHAR(255),
  `ID_USER` VARCHAR(255),
  `NAME` VARCHAR(255),
  `OPEN_HOUR` DATETIME,
  `CLOSE_HOUR` DATETIME,
  `ADDRESS` VARCHAR(255),
  `LATITUDE` DECIMAL(10,2),
  `LONGTITUDE` DECIMAL(10,2),
  `ID_CREATE` VARCHAR(255),
  `DATE_CREATE` VARCHAR(255),
  `ID_UPDATE` VARCHAR(255),
  `DATE_UPDATE` VARCHAR(255),
  `TYPE` INT,
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_003470_ALL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_003470_ALL') AS relationships;
DROP DATABASE `db_003470_ALL`;
UNINSTALL EXTENSION vsql_schematron;
