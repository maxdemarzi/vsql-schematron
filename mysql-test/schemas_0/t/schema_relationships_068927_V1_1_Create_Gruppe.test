INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068927_V1_1_Create_Gruppe
--echo #
CREATE DATABASE `db_068927_V1_1_Create_Gruppe`;
USE `db_068927_V1_1_Create_Gruppe`;

CREATE TABLE `T_GRUPPE` (
  `GRUPPE_ID` DECIMAL(10,2),
  `NAVN` VARCHAR(255),
  `BESKRIVELSE` VARCHAR(255),
  `OPPRETTET_DATO` DATETIME,
  `OPPRETTET_AV` VARCHAR(255),
  `ENDRET_DATO` DATETIME,
  `ENDRET_AV` VARCHAR(255),
  PRIMARY KEY (`GRUPPE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_TAG` (
  `TAG_ID` DECIMAL(10,2),
  `NAVN` VARCHAR(255),
  PRIMARY KEY (`TAG_ID`)
) CHARACTER SET latin1;

CREATE TABLE `T_GRUPPE_TAG` (
  `GRUPPE_ID` DECIMAL(10,2),
  `TAG_ID` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068927_V1_1_Create_Gruppe') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068927_V1_1_Create_Gruppe') AS relationships;
DROP DATABASE `db_068927_V1_1_Create_Gruppe`;
UNINSTALL EXTENSION vsql_schematron;
