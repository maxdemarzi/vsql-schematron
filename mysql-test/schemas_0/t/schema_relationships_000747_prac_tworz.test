INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000747_prac_tworz
--echo #
CREATE DATABASE `db_000747_prac_tworz`;
USE `db_000747_prac_tworz`;

CREATE TABLE `dzialy` (
  `id_dzialu` DECIMAL(10,2),
  `nazwa` VARCHAR(64),
  `siedziba` VARCHAR(64),
  PRIMARY KEY (`id_dzialu`)
) CHARACTER SET latin1;

CREATE TABLE `stanowiska` (
  `stanowisko` VARCHAR(64),
  `placa_min` DECIMAL(10,2),
  `placa_max` DECIMAL(10,2),
  PRIMARY KEY (`stanowisko`)
) CHARACTER SET latin1;

CREATE TABLE `pracownicy` (
  `nr_akt` DECIMAL(10,2),
  `nazwisko` VARCHAR(64),
  `stanowisko` VARCHAR(64),
  `kierownik` DECIMAL(10,2),
  `data_zatr` DATETIME,
  `data_zwol` DATETIME,
  `placa` DECIMAL(10,2),
  `dod_funkcyjny` DECIMAL(10,2),
  `prowizja` DECIMAL(10,2),
  `id_dzialu` DECIMAL(10,2),
  PRIMARY KEY (`nr_akt`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000747_prac_tworz') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000747_prac_tworz') AS relationships;
DROP DATABASE `db_000747_prac_tworz`;
UNINSTALL EXTENSION vsql_schematron;
