INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053001_plantr
--echo #
CREATE DATABASE `db_053001_plantr`;
USE `db_053001_plantr`;

CREATE TABLE `profile` (
  `profileId` VARCHAR(64),
  `profileActivationToken` VARCHAR(64),
  `profileLogin` VARCHAR(64),
  `profileEmail` VARCHAR(64),
  `profileHash` VARCHAR(64),
  PRIMARY KEY (`profileId`)
) CHARACTER SET latin1;

CREATE TABLE `plant` (
  `plantId` VARCHAR(64),
  `plantBloomPeriod` VARCHAR(64),
  `plantCommonName` VARCHAR(64),
  `plantDuration` VARCHAR(64),
  `plantDroughtTolerance` INT,
  `plantGrowthHabit` VARCHAR(64),
  `plantGrowthPeriod` VARCHAR(64),
  `plantMatureHeight` INT,
  `plantMinFrostFreeDays` INT,
  `plantPrecipitationMax` INT,
  `plantPrecipitationMin` INT,
  `plantRootDepthMinimum` INT,
  `plantScientificName` VARCHAR(64),
  `plantShadeTolerance` INT,
  `plantToxicity` INT,
  PRIMARY KEY (`plantId`)
) CHARACTER SET latin1;

CREATE TABLE `profilePlant` (
  `profilePlantId` VARCHAR(64),
  `profilePlantPlantId` VARCHAR(64),
  `profilePlantProfileId` VARCHAR(64),
  `profilePlantNotes` VARCHAR(64),
  PRIMARY KEY (`profilePlantId`)
) CHARACTER SET latin1;

CREATE TABLE `reminder` (
  `reminderId` VARCHAR(64),
  `reminderProfilePlantId` VARCHAR(64),
  `reminderDescription` VARCHAR(64),
  `reminderRecurrence` INT,
  `reminderStartDate` DATETIME,
  PRIMARY KEY (`reminderId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053001_plantr') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053001_plantr') AS relationships;
DROP DATABASE `db_053001_plantr`;
UNINSTALL EXTENSION vsql_schematron;
