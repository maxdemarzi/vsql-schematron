INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016356_index_cardinality_005
--echo #
CREATE DATABASE `db_016356_index_cardinality_005`;
USE `db_016356_index_cardinality_005`;

CREATE TABLE `foo` (
  `a` INT,
  `b` VARCHAR(64),
  `c` VARCHAR(64),
  `d` VARCHAR(64),
  PRIMARY KEY (`a`, `b`)
) CHARACTER SET latin1;

CREATE TABLE `coo` (
  `a` INT,
  `b` VARCHAR(64),
  `c` DECIMAL(10,2),
  PRIMARY KEY (`a`, `b`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016356_index_cardinality_005') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016356_index_cardinality_005') AS relationships;
DROP DATABASE `db_016356_index_cardinality_005`;
UNINSTALL EXTENSION vsql_schematron;
