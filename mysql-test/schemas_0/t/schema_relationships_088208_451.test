INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 088208_451
--echo #
CREATE DATABASE `db_088208_451`;
USE `db_088208_451`;

CREATE TABLE `Customers` (
  `ssno` INT,
  `name` VARCHAR(64),
  `addr` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`ssno`)
) CHARACTER SET latin1;

CREATE TABLE `Flights` (
  `number` INT,
  `day` INT,
  `aircraft` VARCHAR(64),
  PRIMARY KEY (`number`, `day`)
) CHARACTER SET latin1;

CREATE TABLE `Bookings` (
  `row` INT,
  `seat` INT,
  `c_id` INT,
  `f_id` INT,
  `f_day` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_088208_451') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_088208_451') AS relationships;
DROP DATABASE `db_088208_451`;
UNINSTALL EXTENSION vsql_schematron;
