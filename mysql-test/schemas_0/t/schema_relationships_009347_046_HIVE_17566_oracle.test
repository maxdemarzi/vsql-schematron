INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 009347_046-HIVE-17566.oracle
--echo #
CREATE DATABASE `db_009347_046_HIVE_17566_oracle`;
USE `db_009347_046_HIVE_17566_oracle`;

CREATE TABLE `WM_RESOURCEPLAN` (
  `RP_ID` INT,
  `NAME` VARCHAR(64),
  `QUERY_PARALLELISM` INT,
  `STATUS` VARCHAR(64),
  `DEFAULT_POOL_ID` INT,
  PRIMARY KEY (`RP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_POOL` (
  `POOL_ID` INT,
  `RP_ID` INT,
  `PATH` VARCHAR(64),
  `ALLOC_FRACTION` DECIMAL(10,2),
  `QUERY_PARALLELISM` INT,
  `SCHEDULING_POLICY` VARCHAR(64),
  PRIMARY KEY (`POOL_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_TRIGGER` (
  `TRIGGER_ID` INT,
  `RP_ID` INT,
  `NAME` VARCHAR(64),
  `TRIGGER_EXPRESSION` VARCHAR(64),
  `ACTION_EXPRESSION` VARCHAR(64),
  `IS_IN_UNMANAGED` DECIMAL(10,2),
  PRIMARY KEY (`TRIGGER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_POOL_TO_TRIGGER` (
  `POOL_ID` INT,
  `TRIGGER_ID` INT,
  PRIMARY KEY (`POOL_ID`, `TRIGGER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `WM_MAPPING` (
  `MAPPING_ID` INT,
  `RP_ID` INT,
  `ENTITY_TYPE` VARCHAR(64),
  `ENTITY_NAME` VARCHAR(64),
  `POOL_ID` INT,
  `ORDERING` INT,
  PRIMARY KEY (`MAPPING_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_009347_046_HIVE_17566_oracle') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_009347_046_HIVE_17566_oracle') AS relationships;
DROP DATABASE `db_009347_046_HIVE_17566_oracle`;
UNINSTALL EXTENSION vsql_schematron;
