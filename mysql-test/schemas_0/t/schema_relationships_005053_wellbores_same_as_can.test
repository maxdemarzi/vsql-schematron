INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 005053_wellbores-same-as-can
--echo #
CREATE DATABASE `db_005053_wellbores_same_as_can`;
USE `db_005053_wellbores_same_as_can`;

CREATE TABLE `T1` (
  `id` INT,
  `well` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `T2` (
  `id` INT,
  `well` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `T3` (
  `id` INT,
  `well` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `W1` (
  `id` INT,
  `name` VARCHAR(64),
  `wellbore` INT
) CHARACTER SET latin1;

CREATE TABLE `T_can_link` (
  `can_id` INT,
  `can_prov` INT,
  `id1` INT,
  `id2` INT,
  `id3` INT,
  PRIMARY KEY (`can_id`, `can_prov`)
) CHARACTER SET latin1;

CREATE TABLE `T_can_well_link` (
  `can_id` INT,
  `can_prov` VARCHAR(64),
  `id1` VARCHAR(64),
  `id2` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_005053_wellbores_same_as_can') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_005053_wellbores_same_as_can') AS relationships;
DROP DATABASE `db_005053_wellbores_same_as_can`;
UNINSTALL EXTENSION vsql_schematron;
