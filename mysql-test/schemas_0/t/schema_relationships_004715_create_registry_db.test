INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004715_create_registry_db
--echo #
CREATE DATABASE `db_004715_create_registry_db`;
USE `db_004715_create_registry_db`;
CREATE TABLE `sql` (
  `table_name` VARCHAR(50) NOT NULL,
  `sql_definition` TEXT,
  PRIMARY KEY (`table_name`)
) CHARACTER SET latin1;
CREATE TABLE `table_index` (
  `index_name` VARCHAR(50) NOT NULL,
  `table_name` TEXT,
  `column_name` TEXT,
  `partition_number` INT NOT NULL,
  PRIMARY KEY (`index_name`, `partition_number`)
) CHARACTER SET latin1;
CREATE TABLE `history` (
  `h_query_name` TEXT,
  `h_session_id` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004715_create_registry_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004715_create_registry_db') AS relationships;
DROP DATABASE `db_004715_create_registry_db`;
UNINSTALL EXTENSION vsql_schematron;
