INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 065653_migration
--echo #
CREATE DATABASE `db_065653_migration`;
USE `db_065653_migration`;
CREATE TABLE `Book` (
  `bookId` INT NOT NULL,
  `title` TEXT,
  `authorId` INT,
  PRIMARY KEY (`bookId`)
) CHARACTER SET latin1;
CREATE TABLE `Author` (
  `authorId` INT NOT NULL,
  `username` TEXT,
  PRIMARY KEY (`authorId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_065653_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_065653_migration') AS relationships;
DROP DATABASE `db_065653_migration`;
UNINSTALL EXTENSION vsql_schematron;
