INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 051482_upgrade-pre-0.9.10
--echo #
CREATE DATABASE `db_051482_upgrade_pre_0_9_10`;
USE `db_051482_upgrade_pre_0_9_10`;

CREATE TABLE `guacamole_sharing_profile` (
  `sharing_profile_id` INT,
  `sharing_profile_name` VARCHAR(64),
  `primary_connection_id` INT,
  PRIMARY KEY (`sharing_profile_id`)
) CHARACTER SET latin1;

CREATE TABLE `guacamole_sharing_profile_parameter` (
  `sharing_profile_id` INT,
  `parameter_name` VARCHAR(64),
  `parameter_value` VARCHAR(64),
  PRIMARY KEY (`sharing_profile_id`, `parameter_name`)
) CHARACTER SET latin1;

CREATE TABLE `guacamole_sharing_profile_permission` (
  `user_id` INT,
  `sharing_profile_id` INT,
  `permission` VARCHAR(64),
  PRIMARY KEY (`user_id`, `sharing_profile_id`, `permission`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_051482_upgrade_pre_0_9_10') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_051482_upgrade_pre_0_9_10') AS relationships;
DROP DATABASE `db_051482_upgrade_pre_0_9_10`;
UNINSTALL EXTENSION vsql_schematron;
