CREATE TABLE `customer_company` (
  `company_location_id` INT,
  `customer_id` INT,
  `sale_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_075916_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_075916_schema') AS relationships;
DROP DATABASE `db_075916_schema`;
UNINSTALL EXTENSION vsql_schematron;
