CREATE DATABASE `db_061961_V1_0_1_init_pickup_invitations`;
USE `db_061961_V1_0_1_init_pickup_invitations`;

CREATE TABLE `happy_takeaway.delivery_tasks` (
  `id` VARCHAR(255),
  `status` VARCHAR(255),
  `rider_id` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `happy_takeaway.delivery_pickups` (
  `task_id` VARCHAR(255),
  `rider_id` VARCHAR(255),
  `status` VARCHAR(255),
  PRIMARY KEY (`task_id`, `rider_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
