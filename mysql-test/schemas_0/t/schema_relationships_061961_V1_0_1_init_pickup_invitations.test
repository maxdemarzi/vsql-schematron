  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061961_V1_0_1_init_pickup_invitations') AS relationships;
DROP DATABASE `db_061961_V1_0_1_init_pickup_invitations`;
