INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087279_V2__ischool_worksheetLibrary
--echo #
CREATE DATABASE `db_087279_V2__ischool_worksheetLibrary`;
USE `db_087279_V2__ischool_worksheetLibrary`;
CREATE TABLE `ischool_grades` (
  `id` BIGINT NOT NULL,
  `gradenumber` BIGINT,
  `gradename` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ischool_subjects` (
  `id` BIGINT NOT NULL,
  `subjectname` VARCHAR(50),
  `subjectid` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ischool_degreeofdifficulty` (
  `id` BIGINT NOT NULL,
  `degreeofdifficulty` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ischool_worksheets` (
  `id` BIGINT NOT NULL,
  `worksheetname` VARCHAR(50),
  `gradeid` BIGINT,
  `subjectid` BIGINT,
  `degreeofdifficultyid` BIGINT,
  `tags` VARCHAR(50),
  `worksheetpath` VARCHAR(50),
  `createdby` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087279_V2__ischool_worksheetLibrary') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087279_V2__ischool_worksheetLibrary') AS relationships;
DROP DATABASE `db_087279_V2__ischool_worksheetLibrary`;
UNINSTALL EXTENSION vsql_schematron;
