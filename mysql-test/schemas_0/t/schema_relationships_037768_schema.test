INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037768_schema
--echo #
CREATE DATABASE `db_037768_schema`;
USE `db_037768_schema`;

CREATE TABLE `category` (
  `id` INT,
  `description` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `credit_cards` (
  `id` INT,
  `cvv` INT,
  `expiration_month` INT,
  `expiration_year` INT,
  `holder_name` VARCHAR(64),
  `number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hibernate_sequence` (
  `next_val` INT
) CHARACTER SET latin1;

CREATE TABLE `platform` (
  `id` INT,
  `description` VARCHAR(64),
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `application` (
  `id` INT,
  `company` VARCHAR(64),
  `description` VARCHAR(64),
  `income_estimation` INT,
  `language` VARCHAR(64),
  `name` VARCHAR(64),
  `oculusdbid` VARCHAR(64),
  `picture` VARCHAR(64),
  `price` DECIMAL(10,2),
  `release_date` DATETIME,
  `sales_estimations` INT,
  `total_reviews` INT,
  `type_of_app` INT,
  `type_of_gameplay` INT,
  `website` VARCHAR(64),
  `category_id` INT,
  `platform_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `application_positive_words` (
  `application_id` INT,
  `positive_words_id` INT
) CHARACTER SET latin1;

CREATE TABLE `application_negative_words` (
  `application_id` INT,
  `negative_words_id` INT
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `content` VARCHAR(64),
  `title` VARCHAR(64),
  `application_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `content` VARCHAR(64),
  `oculus_id` VARCHAR(64),
  `publish_date` DATETIME,
  `title` VARCHAR(64),
  `usefull` BOOL,
  `application_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_account` (
  `id` INT,
  `authority` VARCHAR(64),
  `nick` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `administrator` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `user_account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `developer` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `company` VARCHAR(64),
  `company_description` VARCHAR(64),
  `webpage` VARCHAR(64),
  `user_account_id` INT,
  `credit_card_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sponsors` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `user_account_id` INT,
  `credit_card_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sponsorship` (
  `id` INT,
  `attachmenturl` VARCHAR(64),
  `title` VARCHAR(64),
  `sponsor_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `user_account_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `word` (
  `id` INT,
  `letters` VARCHAR(64),
  `repeats` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037768_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037768_schema') AS relationships;
DROP DATABASE `db_037768_schema`;
UNINSTALL EXTENSION vsql_schematron;
