INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061727_informacion_usuarios
--echo #
CREATE DATABASE `db_061727_informacion_usuarios`;
USE `db_061727_informacion_usuarios`;
CREATE TABLE `publicaciones` (
  `id_publicacion` INT,
  `titulo` VARCHAR(50),
  `texto` TEXT,
  `id_usuario` INT
) CHARACTER SET latin1;
CREATE TABLE `usuarios` (
  `id_usuario` INT NOT NULL,
  `correo_electronico` VARCHAR(50),
  `password` VARCHAR(50),
  `usuario` VARCHAR(50),
  `nombres` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `edad` VARCHAR(50),
  `fecha_nacimiento` DATE,
  `fecha_registro` DATE,
  `ciudad` VARCHAR(50),
  `pais` VARCHAR(50),
  `idioma` VARCHAR(50),
  `cuenta_facebook` TEXT,
  `cuenta_twitter` TEXT,
  `cuenta_github` TEXT,
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061727_informacion_usuarios') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061727_informacion_usuarios') AS relationships;
DROP DATABASE `db_061727_informacion_usuarios`;
UNINSTALL EXTENSION vsql_schematron;
