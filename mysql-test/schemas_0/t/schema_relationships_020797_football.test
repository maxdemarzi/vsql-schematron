INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020797_football
--echo #
CREATE DATABASE `db_020797_football`;
USE `db_020797_football`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `active` BOOL,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teams` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stat` (
  `id` INT,
  `speed` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `players` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `img` VARCHAR(64),
  `team_id` INT,
  `stat_id` INT,
  `pos` VARCHAR(64),
  `num` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020797_football') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020797_football') AS relationships;
DROP DATABASE `db_020797_football`;
UNINSTALL EXTENSION vsql_schematron;
