INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010706_meals
--echo #
CREATE DATABASE `db_010706_meals`;
USE `db_010706_meals`;
CREATE TABLE `kitchen` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `date_created` DATE,
  `date_deleted` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `meal_type` (
  `id` INT,
  `name` VARCHAR(50),
  `kitchen_id` INT,
  `date_created` DATE,
  `date_deleted` DATE,
  `description` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010706_meals') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010706_meals') AS relationships;
DROP DATABASE `db_010706_meals`;
UNINSTALL EXTENSION vsql_schematron;
