INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 033145_db
--echo #
CREATE DATABASE `db_033145_db`;
USE `db_033145_db`;

CREATE TABLE `account` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  `created_at` DATETIME,
  `last_updated` DATETIME,
  `subscribe_newsletter` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `address` (
  `id` INT,
  `account_id` INT,
  `name` VARCHAR(64),
  `is_default` BOOL,
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `region` VARCHAR(64),
  `postal_code` VARCHAR(64),
  `country` VARCHAR(64),
  `created_at` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payment_info` (
  `id` INT,
  `account_id` INT,
  `name` VARCHAR(64),
  `is_default` BOOL,
  `number` VARCHAR(64),
  `cvv` INT,
  `exp_date` DATETIME,
  `method` INT,
  `created_at` DATETIME,
  `last_updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_type` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account_history` (
  `id` INT,
  `account_id` INT,
  `event_type_id` INT,
  `requested_by_id` VARCHAR(64),
  `ref_id` INT,
  `ref_type_id` INT,
  `ip` VARCHAR(64),
  `info` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_033145_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_033145_db') AS relationships;
DROP DATABASE `db_033145_db`;
UNINSTALL EXTENSION vsql_schematron;
