INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072356_ddl
--echo #
CREATE DATABASE `db_072356_ddl`;
USE `db_072356_ddl`;

CREATE TABLE `users` (
  `id` INT,
  `Email` VARCHAR(64),
  `firstname` VARCHAR(64),
  `surname` VARCHAR(64),
  `avatar` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profiles` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usersprofiles` (
  `id` INT,
  `idusers` INT,
  `idprofiles` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `profilespermissions` (
  `id` INT,
  `idprofiles` INT,
  `idpermissions` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `formsorigins` (
  `id` INT,
  `name` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forms` (
  `id` INT,
  `idformsorigins` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `dtcreation` DATETIME,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fieldsdatatypes` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fields` (
  `id` INT,
  `idfieldsdatatypes` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `fillingclue` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `formsfields` (
  `id` INT,
  `idforms` INT,
  `idfields` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `alternatives` (
  `id` INT,
  `response` VARCHAR(64),
  `shortresponse` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fieldsalternatives` (
  `id` INT,
  `idfields` INT,
  `idalternatives` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `formsanswers` (
  `id` INT,
  `idforms` INT,
  `idusersinformer` INT,
  `dtfilling` DATETIME,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `fieldsanswers` (
  `id` INT,
  `idfields` INT,
  `idformsanswers` INT,
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usersendorsementfieldsanswers` (
  `id` INT,
  `idusersendorsement` INT,
  `idfieldsanswers` INT,
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `istrustable` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `preliminarydata` (
  `id` INT,
  `idfieldsanswers` INT,
  `dtinsert` DATETIME,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `trusteddata` (
  `id` INT,
  `idfieldsanswers` INT,
  `dtinsert` DATETIME,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072356_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072356_ddl') AS relationships;
DROP DATABASE `db_072356_ddl`;
UNINSTALL EXTENSION vsql_schematron;
