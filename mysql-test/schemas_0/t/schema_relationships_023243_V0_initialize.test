INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 023243_V0_initialize
--echo #
CREATE DATABASE `db_023243_V0_initialize`;
USE `db_023243_V0_initialize`;

CREATE TABLE `accounts` (
  `account_id` INT,
  `account_name` VARCHAR(64),
  `email_address` VARCHAR(64),
  `password_digest` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;

CREATE TABLE `account_activations` (
  `account_id` INT,
  `activation_digest` VARCHAR(64),
  `activated` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `account_cookies` (
  `account_id` INT,
  `remember_digest` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `account_relationships` (
  `account_relationship_id` INT,
  `follower_account_id` INT,
  `followed_account_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`account_relationship_id`)
) CHARACTER SET latin1;

CREATE TABLE `account_resets` (
  `account_id` INT,
  `reset_digest` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `lunches` (
  `lunch_id` INT,
  `account_id` INT,
  `lunch_date` DATETIME,
  `comment` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`lunch_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_023243_V0_initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_023243_V0_initialize') AS relationships;
DROP DATABASE `db_023243_V0_initialize`;
UNINSTALL EXTENSION vsql_schematron;
