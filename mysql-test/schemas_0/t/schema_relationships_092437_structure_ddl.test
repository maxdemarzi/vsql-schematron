INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 092437_structure.ddl
--echo #
CREATE DATABASE `db_092437_structure_ddl`;
USE `db_092437_structure_ddl`;

CREATE TABLE `users` (
  `id` INT,
  `login` VARCHAR(64),
  `email` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_actions` (
  `userId` INT,
  `code` VARCHAR(64),
  `action` VARCHAR(64),
  `params` VARCHAR(64),
  `created` DATETIME,
  `expired` DATETIME,
  PRIMARY KEY (`userId`, `code`)
) CHARACTER SET latin1;

CREATE TABLE `auth` (
  `userId` INT,
  `provider` VARCHAR(64),
  `foreignKey` VARCHAR(64),
  `token` VARCHAR(64),
  `tokenSecret` VARCHAR(64),
  `tokenType` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  `expired` DATETIME,
  PRIMARY KEY (`userId`, `provider`)
) CHARACTER SET latin1;

CREATE TABLE `acl_roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`id`, `name`)
) CHARACTER SET latin1;

CREATE TABLE `acl_privileges` (
  `roleId` INT,
  `module` VARCHAR(64),
  `privilege` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `acl_users_roles` (
  `userId` INT,
  `roleId` INT,
  PRIMARY KEY (`userId`, `roleId`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `rootId` INT,
  `parentId` INT,
  `name` VARCHAR(64),
  `alias` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `media` (
  `id` INT,
  `userId` INT,
  `module` VARCHAR(64),
  `title` VARCHAR(64),
  `type` VARCHAR(64),
  `file` VARCHAR(64),
  `thumb` VARCHAR(64),
  `size` INT,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pages` (
  `id` INT,
  `userId` INT,
  `title` VARCHAR(64),
  `alias` VARCHAR(64),
  `content` VARCHAR(64),
  `keywords` VARCHAR(64),
  `description` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `com_settings` (
  `id` INT,
  `alias` VARCHAR(64),
  `options` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  `countPerPage` INT,
  `relatedTable` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `com_content` (
  `id` INT,
  `settingsId` INT,
  `foreignKey` INT,
  `userId` INT,
  `parentId` INT,
  `content` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_092437_structure_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_092437_structure_ddl') AS relationships;
DROP DATABASE `db_092437_structure_ddl`;
UNINSTALL EXTENSION vsql_schematron;
