INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 034704_1
--echo #
CREATE DATABASE `db_034704_1`;
USE `db_034704_1`;

CREATE TABLE `product` (
  `id` INT,
  `ean` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `picture` VARCHAR(64),
  `path_local_picture` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `url_entity` (
  `url_entity_number` INT,
  `url` VARCHAR(64),
  PRIMARY KEY (`url_entity_number`)
) CHARACTER SET latin1;

CREATE TABLE `url_entity_web_search` (
  `url_entity_url_entity_number` INT,
  `web_search_id` INT,
  PRIMARY KEY (`url_entity_url_entity_number`, `web_search_id`)
) CHARACTER SET latin1;

CREATE TABLE `web_search` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `web_search_url_entity` (
  `web_search_id` INT,
  `url_entity_url_entity_number` INT,
  PRIMARY KEY (`web_search_id`, `url_entity_url_entity_number`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_034704_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_034704_1') AS relationships;
DROP DATABASE `db_034704_1`;
UNINSTALL EXTENSION vsql_schematron;
