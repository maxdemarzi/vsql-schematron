INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028283_03_imagestorage
--echo #
CREATE DATABASE `db_028283_03_imagestorage`;
USE `db_028283_03_imagestorage`;

CREATE TABLE `ImageOwners` (
  `OID` INT,
  `FacebookID` INT,
  PRIMARY KEY (`OID`)
) CHARACTER SET latin1;

CREATE TABLE `ImageData` (
  `ImageID` INT,
  `Image` VARCHAR(255),
  `TimeStamp` DATETIME,
  `OwnerID` INT,
  PRIMARY KEY (`ImageID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028283_03_imagestorage') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028283_03_imagestorage') AS relationships;
DROP DATABASE `db_028283_03_imagestorage`;
UNINSTALL EXTENSION vsql_schematron;
