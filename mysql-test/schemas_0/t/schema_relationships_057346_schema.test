INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 057346_schema
--echo #
CREATE DATABASE `db_057346_schema`;
USE `db_057346_schema`;

CREATE TABLE `company` (
  `id` INT,
  `name` VARCHAR(64),
  `timezone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `id` INT,
  `name` VARCHAR(64),
  `timezone` VARCHAR(64),
  `company_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `car` (
  `id` INT,
  `model` VARCHAR(64),
  `chassis_number` VARCHAR(64),
  `color` VARCHAR(64),
  `registration_number` VARCHAR(64),
  `branch_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `driver` (
  `id` INT,
  `name` VARCHAR(64),
  `license_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `trip` (
  `id` INT,
  `timezone` VARCHAR(64),
  `start_on` DATETIME,
  `end_at` DATETIME,
  `distance` DECIMAL(10,2),
  `status` VARCHAR(64),
  `car_id` INT,
  `driver_id` INT,
  `customer_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_057346_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_057346_schema') AS relationships;
DROP DATABASE `db_057346_schema`;
UNINSTALL EXTENSION vsql_schematron;
