INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047303_apple_database
--echo #
CREATE DATABASE `db_047303_apple_database`;
USE `db_047303_apple_database`;
CREATE TABLE `cities` (
  `city_id` INT NOT NULL,
  `city_name` VARCHAR(50),
  `rate` INT,
  `postal_code` INT,
  PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `product_type` (
  `type_id` INT NOT NULL,
  `city_id` INT,
  `type_name` VARCHAR(50),
  `base_shipping` INT,
  PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `specifications` (
  `spec_id` INT NOT NULL,
  `spec_name` VARCHAR(50),
  `price` INT,
  `type_id` INT,
  PRIMARY KEY (`spec_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `city` VARCHAR(50),
  `password` INT,
  `full_name` VARCHAR(50),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047303_apple_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047303_apple_database') AS relationships;
DROP DATABASE `db_047303_apple_database`;
UNINSTALL EXTENSION vsql_schematron;
