INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069719_schema
--echo #
CREATE DATABASE `db_069719_schema`;
USE `db_069719_schema`;
CREATE TABLE `AUTHOR` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `COUNTRY` VARCHAR(50),
  `BIRTHDATE` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PUBLISHER` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `COUNTRY` VARCHAR(50),
  `BIRTHDATE` DATE,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
  `AUTHOR_ID` INT,
  `PUBLISHER_ID` INT,
  `NAME` VARCHAR(50),
  `CONTENT` VARCHAR(50),
  `PRICE` INT,
  `PUBLISHED_AT` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `COUNTRY` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `POPULATION` VARCHAR(50),
  `LAND_AREA` VARCHAR(50),
  `DENSITY` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069719_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069719_schema') AS relationships;
DROP DATABASE `db_069719_schema`;
UNINSTALL EXTENSION vsql_schematron;
