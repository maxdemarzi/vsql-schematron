INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000526_migration
--echo #
CREATE DATABASE `db_000526_migration`;
USE `db_000526_migration`;
CREATE TABLE `BookingReference` (
  `id` INT NOT NULL,
  `type` TEXT,
  `uid` TEXT,
  `bookingId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Attendee` (
  `id` INT NOT NULL,
  `email` TEXT,
  `name` TEXT,
  `timeZone` TEXT,
  `bookingId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Booking` (
  `id` INT NOT NULL,
  `uid` TEXT,
  `userId` INT,
  `eventTypeId` INT,
  `title` TEXT,
  `description` TEXT,
  `startTime` TIMESTAMP NULL,
  `endTime` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000526_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000526_migration') AS relationships;
DROP DATABASE `db_000526_migration`;
UNINSTALL EXTENSION vsql_schematron;
