INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 068287_ofeel_portfolio
--echo #
CREATE DATABASE `db_068287_ofeel_portfolio`;
USE `db_068287_ofeel_portfolio`;

CREATE TABLE `ofeel_portfolio.works` (
  `id` INT,
  `title` VARCHAR(255),
  `resume` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.categories` (
  `id` INT,
  `name` VARCHAR(255),
  `icone` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.workcomments` (
  `id` INT,
  `pseudo` VARCHAR(255),
  `content` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `works_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.articles` (
  `id` INT,
  `title` VARCHAR(255),
  `description` VARCHAR(255),
  `image` VARCHAR(255),
  `resume` VARCHAR(255),
  `created_at` VARCHAR(255),
  `updated_at` VARCHAR(255),
  `categorie_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.tags` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.artcomments` (
  `id` INT,
  `pseudo` VARCHAR(255),
  `content` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `articles_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.works_has_categories` (
  `work_id` INT,
  `categorie_id` INT,
  PRIMARY KEY (`work_id`, `categorie_id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.works_has_tags` (
  `work_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `ofeel_portfolio.articles_has_tags` (
  `article_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_068287_ofeel_portfolio') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_068287_ofeel_portfolio') AS relationships;
DROP DATABASE `db_068287_ofeel_portfolio`;
UNINSTALL EXTENSION vsql_schematron;
