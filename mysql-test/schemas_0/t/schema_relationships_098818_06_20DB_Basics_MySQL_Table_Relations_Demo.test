INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098818_06_20DB_Basics_MySQL_Table_Relations_Demo
--echo #
CREATE DATABASE `db_098818_06_20DB_Basics_MySQL_Table_Relations_Demo`;
USE `db_098818_06_20DB_Basics_MySQL_Table_Relations_Demo`;

CREATE TABLE `mountains` (
  `mountain_id` INT,
  `mountain_name` VARCHAR(64),
  PRIMARY KEY (`mountain_id`)
) CHARACTER SET latin1;

CREATE TABLE `peaks` (
  `peak_id` INT,
  `peak_name` VARCHAR(64),
  `mountain_id` INT,
  PRIMARY KEY (`peak_id`)
) CHARACTER SET latin1;

CREATE TABLE `drivers` (
  `driver_id` INT,
  `driver_name` VARCHAR(64),
  PRIMARY KEY (`driver_id`)
) CHARACTER SET latin1;

CREATE TABLE `cars` (
  `car_id` INT,
  `name` VARCHAR(64),
  `driver_id` INT,
  PRIMARY KEY (`car_id`)
) CHARACTER SET latin1;

CREATE TABLE `Employees` (
  `EmployeeID` INT,
  `FirstName` VARCHAR(64),
  PRIMARY KEY (`EmployeeID`)
) CHARACTER SET latin1;

CREATE TABLE `Projects` (
  `ProjectID` INT,
  `ProjectName` VARCHAR(64),
  PRIMARY KEY (`ProjectID`)
) CHARACTER SET latin1;

CREATE TABLE `EmployeesProjects` (
  `EmployeeID` INT,
  `ProjectID` INT,
  PRIMARY KEY (`EmployeeID`, `ProjectID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098818_06_20DB_Basics_MySQL_Table_Relations_Demo') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098818_06_20DB_Basics_MySQL_Table_Relations_Demo') AS relationships;
DROP DATABASE `db_098818_06_20DB_Basics_MySQL_Table_Relations_Demo`;
UNINSTALL EXTENSION vsql_schematron;
