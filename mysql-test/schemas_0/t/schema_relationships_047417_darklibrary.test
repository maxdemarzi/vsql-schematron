INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047417_darklibrary
--echo #
CREATE DATABASE `db_047417_darklibrary`;
USE `db_047417_darklibrary`;
CREATE TABLE `Invitations` (
  `idInvitation` INT,
  `idUser` INT,
  `code` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Permissions` (
  `idPermission` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`idPermission`)
) CHARACTER SET latin1;
CREATE TABLE `Settings` (
  `idOperationMode` INT NOT NULL,
  `voting` TINYINT,
  PRIMARY KEY (`idOperationMode`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `idUser` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `approved` TINYINT,
  PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047417_darklibrary') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047417_darklibrary') AS relationships;
DROP DATABASE `db_047417_darklibrary`;
UNINSTALL EXTENSION vsql_schematron;
