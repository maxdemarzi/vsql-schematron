INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 064010_schema2
--echo #
CREATE DATABASE `db_064010_schema2`;
USE `db_064010_schema2`;

CREATE TABLE `roles` (
  `_id` INT,
  `role` VARCHAR(255),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `_id` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `phone` VARCHAR(255),
  `role` VARCHAR(255),
  `role_id` INT,
  `contact_pref` VARCHAR(255),
  `mem_threshold` INT,
  `cpu_threshold` INT,
  `container_stops` VARCHAR(255),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_064010_schema2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_064010_schema2') AS relationships;
DROP DATABASE `db_064010_schema2`;
UNINSTALL EXTENSION vsql_schematron;
