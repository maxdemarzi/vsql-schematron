INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 047193_migration
--echo #
CREATE DATABASE `db_047193_migration`;
USE `db_047193_migration`;

CREATE TABLE `RoleGrant` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `roleKey` VARCHAR(64),
  `profileId` VARCHAR(64),
  `subjectTable` VARCHAR(64),
  `subjectId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `username` VARCHAR(64),
  `isActive` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Profile` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `email` VARCHAR(64),
  `displayName` VARCHAR(64),
  `picture` VARCHAR(64),
  `content` VARCHAR(64),
  `city` VARCHAR(64),
  `stateProvince` VARCHAR(64),
  `userId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Universe` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `picture` VARCHAR(64),
  `ownerProfileId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Series` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `picture` VARCHAR(64),
  `universeId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Story` (
  `id` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `name` VARCHAR(64),
  `volume` INT,
  `issue` INT,
  `summary` VARCHAR(64),
  `content` VARCHAR(64),
  `picture` VARCHAR(64),
  `seriesId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_047193_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_047193_migration') AS relationships;
DROP DATABASE `db_047193_migration`;
UNINSTALL EXTENSION vsql_schematron;
