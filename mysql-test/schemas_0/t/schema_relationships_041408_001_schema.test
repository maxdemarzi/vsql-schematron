INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 041408_001_schema
--echo #
CREATE DATABASE `db_041408_001_schema`;
USE `db_041408_001_schema`;

CREATE TABLE `supplier` (
  `id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `supplier_id` VARCHAR(64),
  `name` VARCHAR(64),
  `price` DECIMAL(10,2),
  `other_product_details` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_l10n` (
  `product_id` VARCHAR(64),
  `lang` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `id` INT,
  `name` VARCHAR(64),
  `contact_person_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_payment_method` (
  `id` INT,
  `customer_id` VARCHAR(64),
  `payment_method_code` VARCHAR(64),
  `card_number` VARCHAR(64),
  `from_date` DATETIME,
  `to_date` DATETIME,
  `other_details` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_order` (
  `id` INT,
  `customer_id` VARCHAR(64),
  `customer_payment_method_id` VARCHAR(64),
  `order_status` VARCHAR(64),
  `order_placed_date` DATETIME,
  `order_paid_date` DATETIME,
  `total_order_price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_order_product` (
  `order_id` VARCHAR(64),
  `product_id` VARCHAR(64),
  `quantity` INT,
  `comments` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `customer_order_delivery` (
  `order_id` VARCHAR(64),
  `reported_date` DATETIME,
  `delivery_status_code` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `address` (
  `id` INT,
  `street` VARCHAR(64),
  `zip` VARCHAR(64),
  `town` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `other_details` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `customer_address` (
  `customer_id` VARCHAR(64),
  `address_id` VARCHAR(64),
  `from_date` DATETIME,
  `to_date` DATETIME,
  `address_type_code` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_041408_001_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_041408_001_schema') AS relationships;
DROP DATABASE `db_041408_001_schema`;
UNINSTALL EXTENSION vsql_schematron;
