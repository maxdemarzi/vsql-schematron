INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086645_schema_postgresql
--echo #
CREATE DATABASE `db_086645_schema_postgresql`;
USE `db_086645_schema_postgresql`;

CREATE TABLE `login` (
  `login_id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`login_id`)
) CHARACTER SET latin1;

CREATE TABLE `survey` (
  `survey_id` INT,
  `survey_name` VARCHAR(64),
  PRIMARY KEY (`survey_id`)
) CHARACTER SET latin1;

CREATE TABLE `question` (
  `question_id` INT,
  `survey_id` INT,
  `question_type` VARCHAR(64),
  `question_text` VARCHAR(64),
  `is_required` INT,
  `question_order` INT,
  PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;

CREATE TABLE `choice` (
  `choice_id` INT,
  `question_id` INT,
  `choice_text` VARCHAR(64),
  `choice_order` INT,
  PRIMARY KEY (`choice_id`)
) CHARACTER SET latin1;

CREATE TABLE `survey_response` (
  `survey_response_id` INT,
  `survey_id` INT,
  `time_taken` VARCHAR(64),
  PRIMARY KEY (`survey_response_id`)
) CHARACTER SET latin1;

CREATE TABLE `survey_answer` (
  `survey_answer_id` INT,
  `survey_response_id` INT,
  `question_id` INT,
  `answer_value` VARCHAR(64),
  PRIMARY KEY (`survey_answer_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086645_schema_postgresql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086645_schema_postgresql') AS relationships;
DROP DATABASE `db_086645_schema_postgresql`;
UNINSTALL EXTENSION vsql_schematron;
