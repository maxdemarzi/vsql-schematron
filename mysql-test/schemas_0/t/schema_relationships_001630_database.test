INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 001630_database
--echo #
CREATE DATABASE `db_001630_database`;
USE `db_001630_database`;

CREATE TABLE `users` (
  `id` INT,
  `full_name` VARCHAR(64),
  `enabled` BOOL,
  `last_login` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `addresses` (
  `user_id` INT,
  `street` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `published_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reviews` (
  `id` INT,
  `book_id` INT,
  `reviewer_name` VARCHAR(64),
  `content` VARCHAR(64),
  `rating` INT,
  `published_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `checkouts` (
  `id` INT,
  `user_id` INT,
  `book_id` INT,
  `checkout_date` DATETIME,
  `return_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_001630_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_001630_database') AS relationships;
DROP DATABASE `db_001630_database`;
UNINSTALL EXTENSION vsql_schematron;
