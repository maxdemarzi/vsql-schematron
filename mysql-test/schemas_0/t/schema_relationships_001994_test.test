INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 001994_test
--echo #
CREATE DATABASE `db_001994_test`;
USE `db_001994_test`;

CREATE TABLE `DEMO_COMPANY` (
  `ID` DECIMAL(10,2),
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DEMO_USER` (
  `DTYPE` VARCHAR(64),
  `ID` DECIMAL(10,2),
  `USERNAME` VARCHAR(64),
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `WORKS_AT` DECIMAL(10,2),
  `DAY` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_001994_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_001994_test') AS relationships;
DROP DATABASE `db_001994_test`;
UNINSTALL EXTENSION vsql_schematron;
