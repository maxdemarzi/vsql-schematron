INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066566_modelagem
--echo #
CREATE DATABASE `db_066566_modelagem`;
USE `db_066566_modelagem`;
CREATE TABLE `curso` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `carga_horaria` INT,
  `id_instituicao` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `municipio` (
  `id` INT NOT NULL,
  `nm_municipio` VARCHAR(50),
  `cod_mun` INT,
  `qt_popula` VARCHAR(50),
  `area_mun` VARCHAR(50),
  `coord` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `usuario` VARCHAR(50),
  `senha` VARCHAR(50),
  `id_aluno` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aluno` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `sobrenome` VARCHAR(50),
  `endereco` VARCHAR(50),
  `bairro` VARCHAR(50),
  `contato` VARCHAR(50),
  `sexo` VARCHAR(50),
  `data_nascimento` DATE,
  `uf` CHAR(50),
  `id_municipio` INT,
  `id_curso` INT,
  `id_instituicao` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instituicao` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `site` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066566_modelagem') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066566_modelagem') AS relationships;
DROP DATABASE `db_066566_modelagem`;
UNINSTALL EXTENSION vsql_schematron;
