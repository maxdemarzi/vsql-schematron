INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062197_migration
--echo #
CREATE DATABASE `db_062197_migration`;
USE `db_062197_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `email` TEXT,
  `password` TEXT,
  `firstname` TEXT,
  `lastname` TEXT,
  `role` VARCHAR(50),
  `storeId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Store` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `address` TEXT,
  `updatedAt` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `price` DOUBLE,
  `discount` DOUBLE,
  `mediaUrl` VARCHAR(50),
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `storeId` TEXT,
  `category` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  `userId` TEXT,
  `productId` TEXT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062197_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062197_migration') AS relationships;
DROP DATABASE `db_062197_migration`;
UNINSTALL EXTENSION vsql_schematron;
