INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 018540_schema
--echo #
CREATE DATABASE `db_018540_schema`;
USE `db_018540_schema`;

CREATE TABLE `SINGER` (
  `ID` INT,
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `BIRTH_DATE` DATETIME,
  `VERSION` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ALBUM` (
  `ID` INT,
  `SINGER_ID` INT,
  `TITLE` VARCHAR(64),
  `RELEASE_DATE` DATETIME,
  `VERSION` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `INSTRUMENT` (
  `INSTRUMENT_ID` VARCHAR(64),
  PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SINGER_INSTRUMENT` (
  `SINGER_ID` INT,
  `INSTRUMENT_ID` VARCHAR(64),
  PRIMARY KEY (`SINGER_ID`, `INSTRUMENT_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_018540_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_018540_schema') AS relationships;
DROP DATABASE `db_018540_schema`;
UNINSTALL EXTENSION vsql_schematron;
