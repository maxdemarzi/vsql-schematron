INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 008503_037_sqlite_upgrade
--echo #
CREATE DATABASE `db_008503_037_sqlite_upgrade`;
USE `db_008503_037_sqlite_upgrade`;

CREATE TABLE `images_backup` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `size` INT,
  `status` VARCHAR(64),
  `is_public` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  `disk_format` VARCHAR(64),
  `container_format` VARCHAR(64),
  `checksum` VARCHAR(64),
  `owner` VARCHAR(64),
  `min_disk` INT,
  `min_ram` INT,
  `protected` BOOL,
  `virtual_size` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `size` INT,
  `status` VARCHAR(64),
  `is_public` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  `disk_format` VARCHAR(64),
  `container_format` VARCHAR(64),
  `checksum` VARCHAR(64),
  `owner` VARCHAR(64),
  `min_disk` INT,
  `min_ram` INT,
  `protected` BOOL,
  `virtual_size` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_members_backup` (
  `id` INT,
  `image_id` VARCHAR(64),
  `member` VARCHAR(64),
  `can_share` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_members` (
  `id` INT,
  `image_id` VARCHAR(64),
  `member` VARCHAR(64),
  `can_share` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_properties_backup` (
  `id` INT,
  `image_id` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `image_properties` (
  `id` INT,
  `image_id` VARCHAR(64),
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_008503_037_sqlite_upgrade') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_008503_037_sqlite_upgrade') AS relationships;
DROP DATABASE `db_008503_037_sqlite_upgrade`;
UNINSTALL EXTENSION vsql_schematron;
