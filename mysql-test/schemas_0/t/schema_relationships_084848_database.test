INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084848_database
--echo #
CREATE DATABASE `db_084848_database`;
USE `db_084848_database`;

CREATE TABLE `marks` (
  `id` VARCHAR(255),
  `title` VARCHAR(255),
  `mark` VARCHAR(255),
  `date` VARCHAR(255),
  `username` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `planning` (
  `id` VARCHAR(255),
  `room` VARCHAR(255),
  `teacher` VARCHAR(255),
  `date` VARCHAR(255),
  `start` VARCHAR(255),
  `end` VARCHAR(255),
  `subject` VARCHAR(255),
  `username` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  `email` VARCHAR(255)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084848_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084848_database') AS relationships;
DROP DATABASE `db_084848_database`;
UNINSTALL EXTENSION vsql_schematron;
