INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087024_V202006020600__sw_create_ddl
--echo #
CREATE DATABASE `db_087024_V202006020600_sw_create_ddl`;
USE `db_087024_V202006020600_sw_create_ddl`;

CREATE TABLE `eg_sw_connection` (
  `id` VARCHAR(64),
  `property_id` VARCHAR(64),
  `tenantid` VARCHAR(64),
  `applicationno` VARCHAR(64),
  `applicationstatus` VARCHAR(64),
  `status` VARCHAR(64),
  `connectionno` VARCHAR(64),
  `oldconnectionno` VARCHAR(64),
  `roadCuttingArea` DECIMAL(10,2),
  `action` VARCHAR(64),
  `roadType` VARCHAR(64),
  `adhocrebate` DECIMAL(10,2),
  `adhocpenalty` DECIMAL(10,2),
  `adhocpenaltyreason` VARCHAR(64),
  `adhocpenaltycomment` VARCHAR(64),
  `adhocrebatereason` VARCHAR(64),
  `adhocrebatecomment` VARCHAR(64),
  `createdBy` VARCHAR(64),
  `lastModifiedBy` VARCHAR(64),
  `createdTime` INT,
  `lastModifiedTime` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `eg_sw_service` (
  `connection_id` VARCHAR(64),
  `connectionExecutionDate` INT,
  `noOfWaterClosets` INT,
  `noOfToilets` INT,
  `connectiontype` VARCHAR(64),
  `proposedWaterClosets` INT,
  `proposedToilets` INT,
  `appCreatedDate` INT,
  `detailsprovidedby` VARCHAR(64),
  `estimationfileStoreId` VARCHAR(64),
  `sanctionfileStoreId` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087024_V202006020600_sw_create_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087024_V202006020600_sw_create_ddl') AS relationships;
DROP DATABASE `db_087024_V202006020600_sw_create_ddl`;
UNINSTALL EXTENSION vsql_schematron;
