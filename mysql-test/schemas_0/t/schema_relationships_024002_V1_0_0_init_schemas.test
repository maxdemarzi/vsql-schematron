INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 024002_V1_0_0_init_schemas
--echo #
CREATE DATABASE `db_024002_V1_0_0_init_schemas`;
USE `db_024002_V1_0_0_init_schemas`;

CREATE TABLE `users` (
  `id` VARCHAR(255),
  `fullname` VARCHAR(255),
  `email` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_followers` (
  `user_id` VARCHAR(255),
  `follower_id` VARCHAR(255),
  PRIMARY KEY (`user_id`, `follower_id`)
) CHARACTER SET latin1;

CREATE TABLE `woofs` (
  `id` INT,
  `author_id` VARCHAR(255),
  `datetime` DATETIME,
  `message` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_024002_V1_0_0_init_schemas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_024002_V1_0_0_init_schemas') AS relationships;
DROP DATABASE `db_024002_V1_0_0_init_schemas`;
UNINSTALL EXTENSION vsql_schematron;
