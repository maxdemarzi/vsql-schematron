INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069059_create-test-db
--echo #
CREATE DATABASE `db_069059_create_test_db`;
USE `db_069059_create_test_db`;
CREATE TABLE `TRAIN` (
  `TRAIN_ID` INT NOT NULL,
  `TRAIN_NAME` VARCHAR(50),
  `TRAIN_DESTINATION` VARCHAR(50),
  `TRAIN_DEPARTURE_DATE` DATE,
  PRIMARY KEY (`TRAIN_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PASSENGER` (
  `PASSENGER_ID` INT NOT NULL,
  `PASSENGER_NAME` VARCHAR(50),
  `TRAIN_ID` INT,
  PRIMARY KEY (`PASSENGER_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069059_create_test_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069059_create_test_db') AS relationships;
DROP DATABASE `db_069059_create_test_db`;
UNINSTALL EXTENSION vsql_schematron;
