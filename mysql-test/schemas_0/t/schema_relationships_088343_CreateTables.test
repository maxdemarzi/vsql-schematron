INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 088343_CreateTables
--echo #
CREATE DATABASE `db_088343_CreateTables`;
USE `db_088343_CreateTables`;

CREATE TABLE `Users` (
  `user_ID` VARCHAR(64),
  `followers_num` INT,
  `followees_num` INT,
  `agrees_num` INT,
  `thanks_num` INT,
  `asks_num` INT,
  `answers_num` INT,
  `collections_num` INT,
  `education` VARCHAR(64),
  `education_extra` VARCHAR(64),
  `location` VARCHAR(64),
  `business` VARCHAR(64),
  `employment` VARCHAR(64),
  PRIMARY KEY (`user_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Questions` (
  `question_ID` VARCHAR(64),
  `asker_ID` VARCHAR(64),
  `detail` VARCHAR(64),
  `title` VARCHAR(64),
  `answers_num` INT,
  `followers_num` INT,
  PRIMARY KEY (`question_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Topic` (
  `topic_id` VARCHAR(64),
  `topic_name` VARCHAR(64),
  `question_num` INT,
  `followers_num` INT,
  PRIMARY KEY (`topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `Answers` (
  `answer_ID` VARCHAR(64),
  `question_ID` VARCHAR(64),
  `author_ID` VARCHAR(64),
  `detail` VARCHAR(64),
  `upvote` INT,
  `visit_times` INT,
  PRIMARY KEY (`answer_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Comment` (
  `author_ID` VARCHAR(64),
  `answer_ID` VARCHAR(64),
  PRIMARY KEY (`author_ID`, `answer_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Collection` (
  `name` VARCHAR(64),
  `creator` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `Follow_Question` (
  `question_ID` VARCHAR(64),
  `follower_ID` VARCHAR(64),
  PRIMARY KEY (`question_ID`, `follower_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Follow_User` (
  `follower_ID` VARCHAR(64),
  `followee_ID` VARCHAR(64),
  PRIMARY KEY (`followee_ID`, `follower_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Follow_Topic` (
  `follower_id` VARCHAR(64),
  `topic_id` VARCHAR(64),
  PRIMARY KEY (`follower_id`, `topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `Question_Topics` (
  `question_ID` VARCHAR(64),
  `topic_id` VARCHAR(64),
  PRIMARY KEY (`question_ID`, `topic_id`)
) CHARACTER SET latin1;

CREATE TABLE `Vote_Answer` (
  `voter_id` VARCHAR(64),
  `answer_id` VARCHAR(64),
  PRIMARY KEY (`voter_id`, `answer_id`)
) CHARACTER SET latin1;

CREATE TABLE `Collection_Answers` (
  `collection_name` VARCHAR(64),
  `answer_ID` VARCHAR(64),
  PRIMARY KEY (`collection_name`, `answer_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_088343_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_088343_CreateTables') AS relationships;
DROP DATABASE `db_088343_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
