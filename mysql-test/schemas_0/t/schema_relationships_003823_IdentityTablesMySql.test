INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 003823_IdentityTablesMySql
--echo #
CREATE DATABASE `db_003823_IdentityTablesMySql`;
USE `db_003823_IdentityTablesMySql`;

CREATE TABLE `identitylogin` (
  `LoginProvider` VARCHAR(64),
  `ProviderKey` VARCHAR(64),
  `UserId` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`ProviderKey`, `UserId`, `LoginProvider`)
) CHARACTER SET latin1;

CREATE TABLE `identityrole` (
  `Id` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `identityuser` (
  `Id` INT,
  `Username` VARCHAR(64),
  `Email` VARCHAR(64),
  `EmailConfirmed` BOOL,
  `PasswordHash` VARCHAR(64),
  `SecurityStamp` VARCHAR(64),
  `PhoneNumber` VARCHAR(64),
  `PhoneNumberConfirmed` BOOL,
  `TwoFactorEnabled` BOOL,
  `LockoutEnd` DATETIME,
  `LockoutEnabled` BOOL,
  `AccessFailedCount` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `identityuserclaim` (
  `Id` INT,
  `UserId` INT,
  `ClaimType` VARCHAR(64),
  `ClaimValue` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `identityuserrole` (
  `UserId` INT,
  `RoleId` INT,
  PRIMARY KEY (`UserId`, `RoleId`)
) CHARACTER SET latin1;

CREATE TABLE `identityroleclaim` (
  `Id` INT,
  `RoleId` INT,
  `ClaimType` VARCHAR(64),
  `ClaimValue` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_003823_IdentityTablesMySql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_003823_IdentityTablesMySql') AS relationships;
DROP DATABASE `db_003823_IdentityTablesMySql`;
UNINSTALL EXTENSION vsql_schematron;
