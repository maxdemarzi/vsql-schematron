INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 049487_tabelas
--echo #
CREATE DATABASE `db_049487_tabelas`;
USE `db_049487_tabelas`;

CREATE TABLE `Conta` (
  `cpf` VARCHAR(64),
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  `nome` VARCHAR(64),
  `sexo` VARCHAR(64),
  `dataNascimento` DATETIME,
  `telefone` INT,
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;

CREATE TABLE `Cliente` (
  `cpf` VARCHAR(64),
  PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;

CREATE TABLE `Endereco` (
  `endereco_cliente_cpf` VARCHAR(64),
  `rua` VARCHAR(64),
  `cidade` VARCHAR(64),
  `cep` INT,
  `numero` INT,
  `bairro` VARCHAR(64),
  `referencia` VARCHAR(64),
  PRIMARY KEY (`endereco_cliente_cpf`)
) CHARACTER SET latin1;

CREATE TABLE `Cartao` (
  `cpfCliente` VARCHAR(64),
  `numeroCartao` VARCHAR(64),
  `dataCartao` DATETIME,
  `nomeCartao` VARCHAR(64),
  PRIMARY KEY (`cpfCliente`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_049487_tabelas') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_049487_tabelas') AS relationships;
DROP DATABASE `db_049487_tabelas`;
UNINSTALL EXTENSION vsql_schematron;
