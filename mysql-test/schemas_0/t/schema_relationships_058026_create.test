INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058026_create
--echo #
CREATE DATABASE `db_058026_create`;
USE `db_058026_create`;

CREATE TABLE `orders` (
  `id` INT,
  `order_date` DATETIME,
  `order_sent` DATETIME,
  `postal_code` VARCHAR(64),
  `street` VARCHAR(64),
  `number` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `toppings` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sizes` (
  `id` INT,
  `radius` INT,
  `base_price` DECIMAL(10,2),
  `topping_price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pizzas` (
  `id` INT,
  `size_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pizza_topping` (
  `pizza_id` INT,
  `topping_id` INT,
  `amount` INT,
  PRIMARY KEY (`pizza_id`, `topping_id`)
) CHARACTER SET latin1;

CREATE TABLE `pizza_order` (
  `order_id` INT,
  `pizza_id` INT,
  PRIMARY KEY (`order_id`, `pizza_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058026_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058026_create') AS relationships;
DROP DATABASE `db_058026_create`;
UNINSTALL EXTENSION vsql_schematron;
