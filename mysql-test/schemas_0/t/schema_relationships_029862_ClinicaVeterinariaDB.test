INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 029862_ClinicaVeterinariaDB
--echo #
CREATE DATABASE `db_029862_ClinicaVeterinariaDB`;
USE `db_029862_ClinicaVeterinariaDB`;

CREATE TABLE `ClinicaVeterinariaDB.animal` (
  `id` INT,
  `nome` VARCHAR(64),
  `especie` VARCHAR(64),
  `raca` VARCHAR(64),
  `idade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ClinicaVeterinariaDB.consulta` (
  `id` INT,
  `descricao` VARCHAR(64),
  `valor` DECIMAL(10,2),
  `data_consulta` DATETIME,
  `data_prevista` DATETIME,
  `data_agendamento` DATETIME,
  `fk_animal` INT,
  `fk_atendente` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ClinicaVeterinariaDB.cliente_animal` (
  `fk_cliente` INT,
  `fk_animal` INT,
  PRIMARY KEY (`fk_cliente`, `fk_animal`)
) CHARACTER SET latin1;

CREATE TABLE `ClinicaVeterinariaDB.veterinario_consulta` (
  `fk_veterinario` INT,
  `fk_consulta` INT,
  PRIMARY KEY (`fk_veterinario`, `fk_consulta`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_029862_ClinicaVeterinariaDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_029862_ClinicaVeterinariaDB') AS relationships;
DROP DATABASE `db_029862_ClinicaVeterinariaDB`;
UNINSTALL EXTENSION vsql_schematron;
