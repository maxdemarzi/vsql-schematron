INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 093112_schema-h2
--echo #
CREATE DATABASE `db_093112_schema_h2`;
USE `db_093112_schema_h2`;
CREATE TABLE `users` (
  `user_id` INT NOT NULL,
  `username` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
  `role_id` INT NOT NULL,
  `role_name` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;
CREATE TABLE `persistent_logins` (
  `username` VARCHAR(50),
  `series` VARCHAR(50) NOT NULL,
  `token` VARCHAR(50),
  `last_used` TIMESTAMP NULL,
  PRIMARY KEY (`series`)
) CHARACTER SET latin1;
CREATE TABLE `locations` (
  `id` INT NOT NULL,
  `address_str` VARCHAR(50),
  `city` VARCHAR(50),
  `state_cd` VARCHAR(50),
  `POSTAL_CODE` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hotels` (
  `id` INT NOT NULL,
  `hotel_name` VARCHAR(50),
  `location_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `room_types` (
  `id` INT NOT NULL,
  `room_type_str` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rooms` (
  `id` INT NOT NULL,
  `room_name` VARCHAR(50),
  `guests` INT,
  `room_type_id` INT,
  `hotel_id` INT,
  `cost_per_night` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reservations` (
  `id` INT NOT NULL,
  `start_dt` DATE,
  `end_dt` DATE,
  `user_id` INT,
  `room_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PAYMENT` (
  `id` INT NOT NULL,
  `USER_ID` INT,
  `CARD_TYPE` VARCHAR(50),
  `CARD_HOLDER_NAME` VARCHAR(50),
  `CARD_NUMBER` VARCHAR(50),
  `CVV` VARCHAR(50),
  `exp_dt` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_093112_schema_h2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_093112_schema_h2') AS relationships;
DROP DATABASE `db_093112_schema_h2`;
UNINSTALL EXTENSION vsql_schematron;
