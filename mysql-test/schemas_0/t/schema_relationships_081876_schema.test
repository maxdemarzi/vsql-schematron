INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081876_schema
--echo #
CREATE DATABASE `db_081876_schema`;
USE `db_081876_schema`;

CREATE TABLE `customers` (
  `customer_id` INT,
  `name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `notes` VARCHAR(64),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `employee_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;

CREATE TABLE `employees_skills` (
  `skill_name` VARCHAR(64),
  `employee_id` INT
) CHARACTER SET latin1;

CREATE TABLE `employees_availability` (
  `weekday` VARCHAR(64),
  `employee_id` INT
) CHARACTER SET latin1;

CREATE TABLE `pets` (
  `pet_id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `birth_date` DATETIME,
  `notes` VARCHAR(64),
  `owner_id` INT,
  PRIMARY KEY (`pet_id`)
) CHARACTER SET latin1;

CREATE TABLE `schedules` (
  `schedule_id` INT,
  `delivery_date` DATETIME,
  `activities` VARCHAR(64),
  PRIMARY KEY (`schedule_id`)
) CHARACTER SET latin1;

CREATE TABLE `schedules_pets` (
  `schedule_id` INT,
  `pet_id` INT
) CHARACTER SET latin1;

CREATE TABLE `schedules_employees` (
  `schedule_id` INT,
  `employee_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081876_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081876_schema') AS relationships;
DROP DATABASE `db_081876_schema`;
UNINSTALL EXTENSION vsql_schematron;
