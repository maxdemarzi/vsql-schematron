INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020019_PartyModel
--echo #
CREATE DATABASE `db_020019_PartyModel`;
USE `db_020019_PartyModel`;

CREATE TABLE `company` (
  `party_id` INT,
  PRIMARY KEY (`party_id`)
) CHARACTER SET latin1;

CREATE TABLE `party` (
  `party_id` INT,
  `party_type_code` VARCHAR(64),
  PRIMARY KEY (`party_id`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `party_id` INT,
  PRIMARY KEY (`party_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020019_PartyModel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020019_PartyModel') AS relationships;
DROP DATABASE `db_020019_PartyModel`;
UNINSTALL EXTENSION vsql_schematron;
