INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060460_chatbot
--echo #
CREATE DATABASE `db_060460_chatbot`;
USE `db_060460_chatbot`;
CREATE TABLE `dotaz` (
  `id` INT,
  `odpoved_id` INT,
  `text` TEXT,
  `priorita` INT
) CHARACTER SET latin1;
CREATE TABLE `historie` (
  `id` INT NOT NULL,
  `message` TEXT,
  `date` DATETIME,
  `type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `odpoved` (
  `id` INT NOT NULL,
  `text` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060460_chatbot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060460_chatbot') AS relationships;
DROP DATABASE `db_060460_chatbot`;
UNINSTALL EXTENSION vsql_schematron;
