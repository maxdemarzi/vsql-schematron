INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 032235_create_tables
--echo #
CREATE DATABASE `db_032235_create_tables`;
USE `db_032235_create_tables`;
CREATE TABLE `Conversations` (
  `ID` INT NOT NULL,
  `Title` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
  `Name` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;
CREATE TABLE `Participants` (
  `ID` INT NOT NULL,
  `Conversation_ID` INT,
  `User_Name` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Messages` (
  `ID` INT NOT NULL,
  `Conversation_ID` INT,
  `User_Name` VARCHAR(50),
  `Timestamp` INT,
  `Content` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_032235_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_032235_create_tables') AS relationships;
DROP DATABASE `db_032235_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
