INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 012925_create-tables
--echo #
CREATE DATABASE `db_012925_create_tables`;
USE `db_012925_create_tables`;

CREATE TABLE `Users` (
  `userId` VARCHAR(64),
  `username` VARCHAR(64),
  `salt` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `Admins` (
  `userId` VARCHAR(64),
  `canReview` VARCHAR(64),
  `canMakeAdmin` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `Templates` (
  `templateId` VARCHAR(64),
  `userId` VARCHAR(64),
  `filetype` VARCHAR(64),
  `overlayFiletype` VARCHAR(64),
  `positions` VARCHAR(64),
  `reviewState` VARCHAR(64),
  `timeAdded` INT,
  `timeReviewed` INT,
  `reviewedBy` VARCHAR(64),
  PRIMARY KEY (`templateId`)
) CHARACTER SET latin1;

CREATE TABLE `SourceImages` (
  `sourceId` VARCHAR(64),
  `userId` VARCHAR(64),
  `filetype` VARCHAR(64),
  `reviewState` VARCHAR(64),
  `timeAdded` INT,
  `timeReviewed` INT,
  `reviewedBy` VARCHAR(64),
  PRIMARY KEY (`sourceId`)
) CHARACTER SET latin1;

CREATE TABLE `TemplateRatings` (
  `userId` VARCHAR(64),
  `templateId` VARCHAR(64),
  `isPositive` VARCHAR(64),
  PRIMARY KEY (`userId`, `templateId`)
) CHARACTER SET latin1;

CREATE TABLE `SourceRatings` (
  `userId` VARCHAR(64),
  `sourceId` VARCHAR(64),
  `isPositive` VARCHAR(64),
  PRIMARY KEY (`userId`, `sourceId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_012925_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_012925_create_tables') AS relationships;
DROP DATABASE `db_012925_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
