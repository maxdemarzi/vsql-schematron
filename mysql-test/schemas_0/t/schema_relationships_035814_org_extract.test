INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035814_org_extract
--echo #
CREATE DATABASE `db_035814_org_extract`;
USE `db_035814_org_extract`;

CREATE TABLE `employees` (
  `employeeNumber` INT,
  `lastName` VARCHAR(64),
  `firstName` VARCHAR(64),
  `extension` VARCHAR(64),
  `email` VARCHAR(64),
  `officeCode` VARCHAR(64),
  `reportsTo` INT,
  `jobTitle` VARCHAR(64),
  PRIMARY KEY (`employeeNumber`)
) CHARACTER SET latin1;

CREATE TABLE `offices` (
  `officeCode` VARCHAR(64),
  `city` VARCHAR(64),
  `phone` VARCHAR(64),
  `addressLine1` VARCHAR(64),
  `addressLine2` VARCHAR(64),
  `state` VARCHAR(64),
  `country` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `territory` VARCHAR(64),
  PRIMARY KEY (`officeCode`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035814_org_extract') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035814_org_extract') AS relationships;
DROP DATABASE `db_035814_org_extract`;
UNINSTALL EXTENSION vsql_schematron;
