INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 031991_V1.13.0__NOTIF-150_behavior_groups_phase1
--echo #
CREATE DATABASE `db_031991_V1_13_0_NOTIF_150_behavior_groups_phase1`;
USE `db_031991_V1_13_0_NOTIF_150_behavior_groups_phase1`;

CREATE TABLE `behavior_group` (
  `id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `name` VARCHAR(64),
  `display_name` VARCHAR(64),
  `bundle_id` VARCHAR(64),
  `default_behavior` VARCHAR(64),
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `event_type_behavior` (
  `event_type_id` VARCHAR(64),
  `behavior_group_id` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`event_type_id`, `behavior_group_id`)
) CHARACTER SET latin1;

CREATE TABLE `behavior_group_action` (
  `behavior_group_id` VARCHAR(64),
  `endpoint_id` VARCHAR(64),
  `created` DATETIME,
  PRIMARY KEY (`behavior_group_id`, `endpoint_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_031991_V1_13_0_NOTIF_150_behavior_groups_phase1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_031991_V1_13_0_NOTIF_150_behavior_groups_phase1') AS relationships;
DROP DATABASE `db_031991_V1_13_0_NOTIF_150_behavior_groups_phase1`;
UNINSTALL EXTENSION vsql_schematron;
