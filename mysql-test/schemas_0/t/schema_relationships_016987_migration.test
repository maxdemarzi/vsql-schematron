INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016987_migration
--echo #
CREATE DATABASE `db_016987_migration`;
USE `db_016987_migration`;

CREATE TABLE `User` (
  `id` INT,
  `account` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `gender` VARCHAR(64),
  `birth` DATETIME,
  `avatar` VARCHAR(64),
  `scope` VARCHAR(64),
  `token` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Supplier` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Merchandise` (
  `id` INT,
  `title` VARCHAR(64),
  `unit` VARCHAR(64),
  `price` DECIMAL(10,2),
  `on` VARCHAR(64),
  `avatar` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `supplierId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Inventory` (
  `id` INT,
  `cost` DECIMAL(10,2),
  `quantity` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `merchandiseId` INT,
  `adjustmentId` INT,
  `purchaseId` INT,
  `saleId` INT,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Adjustment` (
  `id` INT,
  `amount` DECIMAL(10,2),
  `unitCost` DECIMAL(10,2),
  `type` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `merchandiseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Purchase` (
  `id` INT,
  `amount` DECIMAL(10,2),
  `unitCost` DECIMAL(10,2),
  `type` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `merchandiseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sale` (
  `id` INT,
  `amount` DECIMAL(10,2),
  `unitCost` DECIMAL(10,2),
  `unitPrice` DECIMAL(10,2),
  `type` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `merchandiseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Order` (
  `id` INT,
  `status` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `OrderDetail` (
  `id` INT,
  `price` DECIMAL(10,2),
  `amount` DECIMAL(10,2),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `orderId` INT,
  `merchandiseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Cart` (
  `amount` INT,
  `userId` INT,
  `merchandiseId` INT,
  PRIMARY KEY (`userId`, `merchandiseId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016987_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016987_migration') AS relationships;
DROP DATABASE `db_016987_migration`;
UNINSTALL EXTENSION vsql_schematron;
