INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095101_init
--echo #
CREATE DATABASE `db_095101_init`;
USE `db_095101_init`;

CREATE TABLE `user.users` (
  `user_id` INT,
  `username` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `community.communities` (
  `community_id` INT,
  `community_name` VARCHAR(255),
  `owner_id` INT,
  PRIMARY KEY (`community_id`)
) CHARACTER SET latin1;

CREATE TABLE `event.events` (
  `event_id` INT,
  `owner_id` INT,
  `community_id` INT,
  PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095101_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095101_init') AS relationships;
DROP DATABASE `db_095101_init`;
UNINSTALL EXTENSION vsql_schematron;
