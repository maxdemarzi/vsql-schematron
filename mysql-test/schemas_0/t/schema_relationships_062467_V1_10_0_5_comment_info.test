INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062467_V1_10_0_5__comment_info
--echo #
CREATE DATABASE `db_062467_V1_10_0_5_comment_info`;
USE `db_062467_V1_10_0_5_comment_info`;

CREATE TABLE `COMMENT_INFO` (
  `ID` INT,
  `PARENT_ID` INT,
  `CONTENT` VARCHAR(64),
  `CREATE_TIME` DATETIME,
  `UPDATE_TIME` DATETIME,
  `LIKES` INT,
  `DISLIKES` INT,
  `USER_ID` VARCHAR(64),
  `USER_NAME` VARCHAR(64),
  `USER_AVATAR` VARCHAR(64),
  `THREAD_ID` INT,
  `MODE` VARCHAR(64),
  `IP` VARCHAR(64),
  `URL` VARCHAR(64),
  `CONVERSATION` VARCHAR(64),
  `REPLY_ID` INT,
  `TENANT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062467_V1_10_0_5_comment_info') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062467_V1_10_0_5_comment_info') AS relationships;
DROP DATABASE `db_062467_V1_10_0_5_comment_info`;
UNINSTALL EXTENSION vsql_schematron;
