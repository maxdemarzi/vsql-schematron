INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 091041_create%20tables
--echo #
CREATE DATABASE `db_091041_create_20tables`;
USE `db_091041_create_20tables`;

CREATE TABLE `PUBLISHER` (
  `NAME` VARCHAR(64),
  `PHONE` INT,
  `ADDRESS` VARCHAR(64),
  PRIMARY KEY (`NAME`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK` (
  `BOOK_ID` INT,
  `TITLE` VARCHAR(64),
  `PUB_YEAR` VARCHAR(64),
  `PUB_NAME` VARCHAR(64),
  PRIMARY KEY (`BOOK_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK_AUTHORS` (
  `AUTHOR_NAME` VARCHAR(64),
  `BOOK_ID` INT,
  PRIMARY KEY (`BOOK_ID`, `AUTHOR_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `LIBRARY_PROGRAMME` (
  `PROGRAMME_ID` INT,
  `PROGRAMME_NAME` VARCHAR(64),
  `ADDRESS` VARCHAR(64),
  PRIMARY KEY (`PROGRAMME_ID`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK_COPIES` (
  `NO_OF_COPIES` INT,
  `BOOK_ID` INT,
  `PROGRAMME_ID` INT,
  PRIMARY KEY (`BOOK_ID`, `PROGRAMME_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CARD` (
  `CARD_NO` INT,
  PRIMARY KEY (`CARD_NO`)
) CHARACTER SET latin1;

CREATE TABLE `BOOK_LENDING` (
  `BOOK_ID` INT,
  `PROGRAMME_ID` INT,
  `CARD_NO` INT,
  `DATE_OUT` DATETIME,
  `DUE_DATE` DATETIME,
  PRIMARY KEY (`BOOK_ID`, `PROGRAMME_ID`, `CARD_NO`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_091041_create_20tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_091041_create_20tables') AS relationships;
DROP DATABASE `db_091041_create_20tables`;
UNINSTALL EXTENSION vsql_schematron;
