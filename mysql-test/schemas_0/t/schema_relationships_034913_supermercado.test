INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 034913_supermercado
--echo #
CREATE DATABASE `db_034913_supermercado`;
USE `db_034913_supermercado`;
CREATE TABLE `cargos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `setores` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fornecedores` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `cnpj` VARCHAR(50),
  `telefone` VARCHAR(50),
  `email` VARCHAR(50),
  `ativo` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `volumes` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `volume_id` INT,
  `fornecedor_id` INT,
  `setor_id` INT,
  `preco` DOUBLE,
  `ativo` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
  `id` INT NOT NULL,
  `cpf` VARCHAR(50),
  `nome` VARCHAR(50),
  `telefone` VARCHAR(50),
  `email` VARCHAR(50),
  `ativo` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funcionarios` (
  `id` INT NOT NULL,
  `cpf` VARCHAR(50),
  `nome` VARCHAR(50),
  `matricula` VARCHAR(50),
  `setor_id` INT,
  `cargo_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vendas` (
  `id` INT NOT NULL,
  `nf` VARCHAR(50),
  `total` DOUBLE,
  `cliente_id` INT,
  `produto_id` INT,
  `quantidade` INT,
  `datahora` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `compras` (
  `id` INT NOT NULL,
  `nf` VARCHAR(50),
  `total` DOUBLE,
  `produto_id` INT,
  `quantidade` INT,
  `datahora` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_034913_supermercado') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_034913_supermercado') AS relationships;
DROP DATABASE `db_034913_supermercado`;
UNINSTALL EXTENSION vsql_schematron;
