INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 010617_dctime
--echo #
CREATE DATABASE `db_010617_dctime`;
USE `db_010617_dctime`;
CREATE TABLE `game` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `translated_name` VARCHAR(50),
  `cover_image` VARCHAR(50),
  `pitctures` VARCHAR(50),
  `platform` VARCHAR(50),
  `release_date` DATE,
  `tag` VARCHAR(50),
  `official_website` VARCHAR(50),
  `developer` VARCHAR(50),
  `publisher` VARCHAR(50),
  `description` VARCHAR(50),
  `number_of_judges` BIGINT,
  `total_score` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `game_topic_related` (
  `game_id` BIGINT NOT NULL,
  `topic_id` BIGINT NOT NULL,
  PRIMARY KEY (`game_id`, `topic_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_010617_dctime') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_010617_dctime') AS relationships;
DROP DATABASE `db_010617_dctime`;
UNINSTALL EXTENSION vsql_schematron;
