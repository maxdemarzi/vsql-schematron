INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 020356_V005__cria-tabelas-pedido-item-pedido
--echo #
CREATE DATABASE `db_020356_V005__cria_tabelas_pedido_item_pedido`;
USE `db_020356_V005__cria_tabelas_pedido_item_pedido`;
CREATE TABLE `pedido` (
  `id` BIGINT NOT NULL,
  `subtotal` DECIMAL(10,2),
  `taxa_frete` DECIMAL(10,2),
  `valor_total` DECIMAL(10,2),
  `restaurante_id` INT,
  `usuario_cliente_id` INT,
  `forma_pagamento_id` INT,
  `endereco_cidade_id` INT,
  `endereco_cep` VARCHAR(50),
  `endereco_logradouro` VARCHAR(50),
  `endereco_numero` VARCHAR(50),
  `endereco_complemento` VARCHAR(50),
  `endereco_bairro` VARCHAR(50),
  `status` VARCHAR(50),
  `data_criacao` TIMESTAMP NULL,
  `data_confirmacao` TIMESTAMP NULL,
  `data_cancelamento` TIMESTAMP NULL,
  `data_entrega` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item_pedido` (
  `id` BIGINT NOT NULL,
  `quantidade` INT,
  `preco_unitario` DECIMAL(10,2),
  `preco_total` DECIMAL(10,2),
  `observacao` VARCHAR(50),
  `pedido_id` INT,
  `produto_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_020356_V005__cria_tabelas_pedido_item_pedido') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_020356_V005__cria_tabelas_pedido_item_pedido') AS relationships;
DROP DATABASE `db_020356_V005__cria_tabelas_pedido_item_pedido`;
UNINSTALL EXTENSION vsql_schematron;
