INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095317_Assignment2
--echo #
CREATE DATABASE `db_095317_Assignment2`;
USE `db_095317_Assignment2`;

CREATE TABLE `DEPARTMENT` (
  `Dname` VARCHAR(64),
  `Dnumber` INT,
  `Mgr_ssn` VARCHAR(64),
  `Mgr_start_date` DATETIME,
  PRIMARY KEY (`Dnumber`)
) CHARACTER SET latin1;

CREATE TABLE `EMPLOYEE` (
  `Fname` VARCHAR(64),
  `Minit` VARCHAR(64),
  `Lname` VARCHAR(64),
  `Ssn` VARCHAR(64),
  `Bdate` DATETIME,
  `Address` VARCHAR(64),
  `Sex` VARCHAR(64),
  `Salary` DECIMAL(10,2),
  `Super_ssn` VARCHAR(64),
  `Dno` INT,
  PRIMARY KEY (`Ssn`)
) CHARACTER SET latin1;

CREATE TABLE `DEPENDENT` (
  `Essn` VARCHAR(64),
  `Dependent_name` VARCHAR(64),
  `Sex` VARCHAR(64),
  `Bdate` DATETIME,
  `Relationship` VARCHAR(64),
  PRIMARY KEY (`Essn`, `Dependent_name`)
) CHARACTER SET latin1;

CREATE TABLE `DEPT_LOCATIONS` (
  `Dnumber` INT,
  `Dlocation` VARCHAR(64),
  PRIMARY KEY (`Dnumber`, `Dlocation`)
) CHARACTER SET latin1;

CREATE TABLE `PROJECT` (
  `Pname` VARCHAR(64),
  `Pnumber` INT,
  `Plocation` VARCHAR(64),
  `Dnum` INT,
  PRIMARY KEY (`Pnumber`)
) CHARACTER SET latin1;

CREATE TABLE `WORKS_ON` (
  `Essn` VARCHAR(64),
  `Pno` INT,
  `Hours` DECIMAL(10,2),
  PRIMARY KEY (`Essn`, `Pno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095317_Assignment2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095317_Assignment2') AS relationships;
DROP DATABASE `db_095317_Assignment2`;
UNINSTALL EXTENSION vsql_schematron;
