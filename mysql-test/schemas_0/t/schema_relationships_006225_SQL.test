INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 006225_SQL
--echo #
CREATE DATABASE `db_006225_SQL`;
USE `db_006225_SQL`;

CREATE TABLE `users` (
  `id_user` INT,
  `name_user` VARCHAR(255),
  `email_user` VARCHAR(255),
  `password_user` VARCHAR(255),
  `created_at` DATETIME,
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

CREATE TABLE `user_records` (
  `id_record` INT,
  `name_record` VARCHAR(255),
  `quantity_record` INT,
  `type_record` VARCHAR(255),
  `price_record` DECIMAL(10,2),
  `deleted` VARCHAR(255),
  `timeDeleted` DATETIME,
  `fk_user` INT,
  PRIMARY KEY (`id_record`)
) CHARACTER SET latin1;

CREATE TABLE `user_picture` (
  `id_photo` INT,
  `filename` VARCHAR(255),
  `fk_user` INT,
  PRIMARY KEY (`id_photo`)
) CHARACTER SET latin1;

CREATE TABLE `pwdreset` (
  `id_pwdReset` INT,
  `ipRequest` VARCHAR(255),
  `dateRequest` DATETIME,
  `pwdResetEmail` VARCHAR(255),
  `pwdResetSelector` VARCHAR(255),
  `pwdResetToken` VARCHAR(255),
  `pwdResetExpires` VARCHAR(255),
  PRIMARY KEY (`id_pwdReset`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_006225_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_006225_SQL') AS relationships;
DROP DATABASE `db_006225_SQL`;
UNINSTALL EXTENSION vsql_schematron;
