INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070403_EF_CreateTables
--echo #
CREATE DATABASE `db_070403_EF_CreateTables`;
USE `db_070403_EF_CreateTables`;

CREATE TABLE `Users` (
  `userID` INT,
  `fName` VARCHAR(64),
  `lName` VARCHAR(64),
  `facebookURL` VARCHAR(64),
  `githubURL` VARCHAR(64),
  `twitterURL` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `UserProfile` (
  `userID` INT,
  `profileImage` VARCHAR(64),
  `profileTitle` VARCHAR(64),
  `profileBio` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `CourseTerms` (
  `courseTermID` INT,
  `courseSeason` VARCHAR(64),
  `courseYear` VARCHAR(64),
  PRIMARY KEY (`courseTermID`)
) CHARACTER SET latin1;

CREATE TABLE `Skill` (
  `skillID` INT,
  `skillName` VARCHAR(64),
  PRIMARY KEY (`skillID`)
) CHARACTER SET latin1;

CREATE TABLE `Industry` (
  `industryID` INT,
  `industryName` VARCHAR(64),
  PRIMARY KEY (`industryID`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `courseID` INT,
  `courseName` VARCHAR(64),
  PRIMARY KEY (`courseID`)
) CHARACTER SET latin1;

CREATE TABLE `User_Skill` (
  `userID` INT,
  `skillID` INT,
  `yearsExperience` INT
) CHARACTER SET latin1;

CREATE TABLE `User_Industry` (
  `userID` INT,
  `industryID` INT,
  `yearsExperience` INT
) CHARACTER SET latin1;

CREATE TABLE `User_Course` (
  `userID` INT,
  `courseID` INT,
  `courseTermID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070403_EF_CreateTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070403_EF_CreateTables') AS relationships;
DROP DATABASE `db_070403_EF_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
