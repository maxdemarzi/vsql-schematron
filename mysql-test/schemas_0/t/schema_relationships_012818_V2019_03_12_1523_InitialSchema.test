INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 012818_V2019.03.12_1523__InitialSchema
--echo #
CREATE DATABASE `db_012818_V2019_03_12_1523_InitialSchema`;
USE `db_012818_V2019_03_12_1523_InitialSchema`;

CREATE TABLE `orderlyweb_user` (
  `username` VARCHAR(64),
  `display_name` VARCHAR(64),
  `email` VARCHAR(64),
  `disabled` INT,
  `user_source` VARCHAR(64),
  `last_logged_in` VARCHAR(64),
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group_user` (
  `email` VARCHAR(64),
  `user_group` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_permission` (
  `id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group_permission` (
  `id` INT,
  `user_group` VARCHAR(64),
  `permission` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group_report_permission` (
  `id` INT,
  `report` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group_version_permission` (
  `id` INT,
  `version` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_user_group_global_permission` (
  `id` INT
) CHARACTER SET latin1;

CREATE TABLE `orderlyweb_pinned_report_global` (
  `ordering` INT,
  `report` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_012818_V2019_03_12_1523_InitialSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_012818_V2019_03_12_1523_InitialSchema') AS relationships;
DROP DATABASE `db_012818_V2019_03_12_1523_InitialSchema`;
UNINSTALL EXTENSION vsql_schematron;
