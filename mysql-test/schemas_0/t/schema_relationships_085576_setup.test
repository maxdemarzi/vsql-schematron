INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 085576_setup
--echo #
CREATE DATABASE `db_085576_setup`;
USE `db_085576_setup`;

CREATE TABLE `users` (
  `id` INT,
  `likes` INT
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `id` INT,
  `type` INT,
  `owner` INT,
  `material` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `material_types` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `materials` (
  `id` INT,
  `owner` INT,
  `type` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_085576_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_085576_setup') AS relationships;
DROP DATABASE `db_085576_setup`;
UNINSTALL EXTENSION vsql_schematron;
