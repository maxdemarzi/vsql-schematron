INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 096152_kh-schema
--echo #
CREATE DATABASE `db_096152_kh_schema`;
USE `db_096152_kh_schema`;

CREATE TABLE `GENRE` (
  `GENRE_ID` INT,
  `GENRE_NAME` VARCHAR(64),
  PRIMARY KEY (`GENRE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `KOALIBEE` (
  `KOALIBEE_ID` INT,
  `FIRST_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `ETA_BALANCE` INT,
  `AVATAR` VARCHAR(64),
  `AVATAR_TYPE` VARCHAR(64),
  `CREDENTIALS_ID` INT,
  PRIMARY KEY (`KOALIBEE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CREDENTIALS` (
  `CREDENTIALS_ID` INT,
  `EMAIL` VARCHAR(64),
  `PASSWORD_HASH` VARCHAR(64),
  `PASSWORD_SALT` VARCHAR(64),
  PRIMARY KEY (`CREDENTIALS_ID`)
) CHARACTER SET latin1;

CREATE TABLE `MOMENT` (
  `MOMENT_ID` INT,
  `POST_DATE` DATETIME,
  `POST_COMMENT` VARCHAR(64),
  `KOALIBEE_ID` INT,
  PRIMARY KEY (`MOMENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ALBUM` (
  `ALBUM_ID` INT,
  `ALBUM_NAME` VARCHAR(64),
  `ARTIST` VARCHAR(64),
  `ARTWORK` VARCHAR(64),
  `ARTWORK_TYPE` VARCHAR(64),
  `ETA_PRICE` INT,
  `IS_PROMOTED` VARCHAR(64),
  `IS_PUBLISHED` VARCHAR(64),
  `GENRE_ID` INT,
  `KOALIBEE_ID` INT,
  PRIMARY KEY (`ALBUM_ID`)
) CHARACTER SET latin1;

CREATE TABLE `TRACK` (
  `TRACK_ID` INT,
  `TRACK_NAME` VARCHAR(64),
  `COMPOSER` VARCHAR(64),
  `TRACK_LENGTH` INT,
  `AUDIO` VARCHAR(64),
  `AUDIO_TYPE` VARCHAR(64),
  `IS_DEMO` VARCHAR(64),
  `ALBUM_ID` INT,
  PRIMARY KEY (`TRACK_ID`)
) CHARACTER SET latin1;

CREATE TABLE `REVIEW` (
  `REVIEW_ID` INT,
  `RATING` INT,
  `REVIEW_COMMENT` VARCHAR(64),
  `ALBUM_ID` INT,
  `KOALIBEE_ID` INT,
  PRIMARY KEY (`REVIEW_ID`)
) CHARACTER SET latin1;

CREATE TABLE `KOALIBEE_ALBUM` (
  `KOALIBEE_ID` INT,
  `ALBUM_ID` INT,
  PRIMARY KEY (`KOALIBEE_ID`, `ALBUM_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_096152_kh_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_096152_kh_schema') AS relationships;
DROP DATABASE `db_096152_kh_schema`;
UNINSTALL EXTENSION vsql_schematron;
