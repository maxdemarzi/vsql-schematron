INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061263_41-rename-implicit-index
--echo #
CREATE DATABASE `db_061263_41_rename_implicit_index`;
USE `db_061263_41_rename_implicit_index`;
CREATE TABLE `bbb` (
  `id` INT NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `aaa` (
  `id` INT,
  `bbb_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061263_41_rename_implicit_index') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061263_41_rename_implicit_index') AS relationships;
DROP DATABASE `db_061263_41_rename_implicit_index`;
UNINSTALL EXTENSION vsql_schematron;
