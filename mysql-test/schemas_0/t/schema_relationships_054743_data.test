INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054743_data
--echo #
CREATE DATABASE `db_054743_data`;
USE `db_054743_data`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
  `id` INT NOT NULL,
  `id_usuario` INT,
  `number` INT,
  `citycode` INT,
  `countrycode` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054743_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054743_data') AS relationships;
DROP DATABASE `db_054743_data`;
UNINSTALL EXTENSION vsql_schematron;
