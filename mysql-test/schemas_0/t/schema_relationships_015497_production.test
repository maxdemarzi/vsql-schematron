INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 015497_production
--echo #
CREATE DATABASE `db_015497_production`;
USE `db_015497_production`;

CREATE TABLE `production_result` (
  `production_actual` DATETIME,
  `SCHEDULE_ID` INT,
  PRIMARY KEY (`SCHEDULE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `production_schedule` (
  `ID` INT,
  `product_name` VARCHAR(64),
  `production_expected` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_015497_production') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_015497_production') AS relationships;
DROP DATABASE `db_015497_production`;
UNINSTALL EXTENSION vsql_schematron;
