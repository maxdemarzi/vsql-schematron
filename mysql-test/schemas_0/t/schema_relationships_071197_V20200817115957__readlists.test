INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 071197_V20200817115957__readlists
--echo #
CREATE DATABASE `db_071197_V20200817115957__readlists`;
USE `db_071197_V20200817115957__readlists`;
CREATE TABLE `READLIST` (
  `ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  `BOOK_COUNT` INT,
  `CREATED_DATE` DATETIME,
  `LAST_MODIFIED_DATE` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `READLIST_BOOK` (
  `READLIST_ID` VARCHAR(50) NOT NULL,
  `BOOK_ID` VARCHAR(50) NOT NULL,
  `NUMBER` INT,
  PRIMARY KEY (`READLIST_ID`, `BOOK_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_071197_V20200817115957__readlists') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_071197_V20200817115957__readlists') AS relationships;
DROP DATABASE `db_071197_V20200817115957__readlists`;
UNINSTALL EXTENSION vsql_schematron;
