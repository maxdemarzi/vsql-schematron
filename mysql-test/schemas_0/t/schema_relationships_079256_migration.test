INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079256_migration
--echo #
CREATE DATABASE `db_079256_migration`;
USE `db_079256_migration`;
CREATE TABLE `User` (
  `id` VARCHAR(50) NOT NULL,
  `email` TEXT,
  `github` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Thought` (
  `id` VARCHAR(50) NOT NULL,
  `subject` TEXT,
  `text` TEXT,
  `authorId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
  `id` VARCHAR(50) NOT NULL,
  `text` TEXT,
  `authorId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Thumb` (
  `id` VARCHAR(50) NOT NULL,
  `userId` TEXT,
  `thoughtId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079256_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079256_migration') AS relationships;
DROP DATABASE `db_079256_migration`;
UNINSTALL EXTENSION vsql_schematron;
