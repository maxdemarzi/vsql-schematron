INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037616_db_create
--echo #
CREATE DATABASE `db_037616_db_create`;
USE `db_037616_db_create`;
CREATE TABLE `BRANDS` (
  `BRAND_ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `STATE` DECIMAL(10,2),
  PRIMARY KEY (`BRAND_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRICES` (
  `PRICES_ID` INT NOT NULL,
  `BRAND_ID` DECIMAL(10,2),
  `START_DATE` DATE,
  `END_DATE` DATE,
  `PRICE_LIST_ID` DECIMAL(10,2),
  `PRODUCT_ID` DECIMAL(10,2),
  `PRIORITY` DECIMAL(10,2),
  `PRICE` DECIMAL(10,2),
  `CURR` VARCHAR(50),
  PRIMARY KEY (`PRICES_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRICES_LIST` (
  `PRICE_LIST_ID` DECIMAL(10,2) NOT NULL,
  `PRODUCT_ID` DECIMAL(10,2),
  `STATE` DECIMAL(10,2),
  PRIMARY KEY (`PRICE_LIST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUCTS` (
  `PRODUCT_ID` DECIMAL(10,2) NOT NULL,
  `NAME` VARCHAR(50),
  `TYPE_ID` VARCHAR(50),
  `STATE` DECIMAL(10,2),
  PRIMARY KEY (`PRODUCT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TYPE_PRODUCTS` (
  `TYPE_ID` VARCHAR(50) NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`TYPE_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037616_db_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037616_db_create') AS relationships;
DROP DATABASE `db_037616_db_create`;
UNINSTALL EXTENSION vsql_schematron;
