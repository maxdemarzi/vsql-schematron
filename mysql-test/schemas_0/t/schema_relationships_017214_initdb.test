INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 017214_initdb
--echo #
CREATE DATABASE `db_017214_initdb`;
USE `db_017214_initdb`;

CREATE TABLE `portfolio` (
  `portfolioId` INT,
  `clientId` VARCHAR(64),
  `total` DECIMAL(10,2),
  `loyalty` VARCHAR(64),
  `balance` DECIMAL(10,2),
  `commissions` DECIMAL(10,2),
  `freeTrades` INT,
  PRIMARY KEY (`portfolioId`)
) CHARACTER SET latin1;

CREATE TABLE `stock` (
  `portfolioId` INT,
  `symbol` VARCHAR(64),
  `shares` INT,
  `price` DECIMAL(10,2),
  `total` DECIMAL(10,2),
  `lastQuoted` DATETIME,
  `commission` DECIMAL(10,2),
  PRIMARY KEY (`portfolioId`, `symbol`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `clientId` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `preferredContactMethod` VARCHAR(64),
  `salesforceContactId` VARCHAR(64),
  PRIMARY KEY (`clientId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_017214_initdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_017214_initdb') AS relationships;
DROP DATABASE `db_017214_initdb`;
UNINSTALL EXTENSION vsql_schematron;
