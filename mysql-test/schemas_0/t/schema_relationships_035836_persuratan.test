INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 035836_persuratan
--echo #
CREATE DATABASE `db_035836_persuratan`;
USE `db_035836_persuratan`;
CREATE TABLE `surat` (
  `id_surat` INT,
  `id_user` INT,
  `dari` VARCHAR(50),
  `Perihal` VARCHAR(50),
  `tgl_masuk` DATE,
  `tgl_diterima` DATE,
  `status` VARCHAR(50),
  `keterangan` VARCHAR(50),
  `file_surat` VARCHAR(50),
  `lampiran` VARCHAR(50),
  `surat_jadi` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `nama` VARCHAR(50),
  `email` VARCHAR(50),
  `no_telp` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `foto` VARCHAR(50),
  `jabatan` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_035836_persuratan') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_035836_persuratan') AS relationships;
DROP DATABASE `db_035836_persuratan`;
UNINSTALL EXTENSION vsql_schematron;
