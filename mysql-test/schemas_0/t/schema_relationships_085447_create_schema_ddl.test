INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 085447_create_schema_ddl
--echo #
CREATE DATABASE `db_085447_create_schema_ddl`;
USE `db_085447_create_schema_ddl`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `logged_in_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `topics` (
  `id` INT NOT NULL,
  `topic` VARCHAR(50),
  `description` VARCHAR(50),
  `topic_created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` INT NOT NULL,
  `user_id` INT,
  `topic_id` INT,
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `post` TEXT,
  `post_created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
  `id` INT NOT NULL,
  `user_id` INT,
  `post_id` INT,
  `comment` TEXT,
  `parent_comment_id` INT,
  `comment_created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `votes` (
  `id` INT NOT NULL,
  `user_id` INT,
  `post_id` INT,
  `vote` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_085447_create_schema_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_085447_create_schema_ddl') AS relationships;
DROP DATABASE `db_085447_create_schema_ddl`;
UNINSTALL EXTENSION vsql_schematron;
