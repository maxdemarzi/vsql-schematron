INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 095657_01aCreateDbTables_test
--echo #
CREATE DATABASE `db_095657_01aCreateDbTables_test`;
USE `db_095657_01aCreateDbTables_test`;

CREATE TABLE `market` (
  `marketId` INT,
  `name` VARCHAR(64),
  `sortName` VARCHAR(64),
  `url` VARCHAR(64),
  `imageUrl` VARCHAR(64),
  `dateEnd` DATETIME,
  PRIMARY KEY (`marketId`)
) CHARACTER SET latin1;

CREATE TABLE `contract` (
  `imageUrl` VARCHAR(64),
  `contractId` INT,
  `marketId` INT,
  `contractName` VARCHAR(64),
  `contractShortName` VARCHAR(64),
  `dateEnd` DATETIME,
  PRIMARY KEY (`contractId`)
) CHARACTER SET latin1;

CREATE TABLE `querySource` (
  `querySourceId` INT,
  `name` VARCHAR(64),
  `shortName` VARCHAR(64),
  PRIMARY KEY (`querySourceId`)
) CHARACTER SET latin1;

CREATE TABLE `marketNotExist` (
  `marketId` INT,
  `querySourceId` INT,
  PRIMARY KEY (`marketId`, `querySourceId`)
) CHARACTER SET latin1;

CREATE TABLE `image` (
  `imageUrl` VARCHAR(64),
  `image` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`imageUrl`)
) CHARACTER SET latin1;

CREATE TABLE `marketChartData` (
  `marketId` INT,
  `contractId` INT,
  `dateTimeStamp` DATETIME,
  `querySourceId` INT,
  `openSharePrice` DECIMAL(10,2),
  `highSharePrice` DECIMAL(10,2),
  `lowSharePrice` DECIMAL(10,2),
  `closeSharePrice` DECIMAL(10,2),
  `tradeVolume` DECIMAL(10,2),
  PRIMARY KEY (`contractId`, `dateTimeStamp`, `querySourceId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_095657_01aCreateDbTables_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_095657_01aCreateDbTables_test') AS relationships;
DROP DATABASE `db_095657_01aCreateDbTables_test`;
UNINSTALL EXTENSION vsql_schematron;
