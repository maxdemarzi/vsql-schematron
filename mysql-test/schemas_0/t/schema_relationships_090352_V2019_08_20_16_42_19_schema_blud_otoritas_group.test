INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 090352_V2019_08_20_16_42_19__schema-blud-otoritas-group
--echo #
CREATE DATABASE `db_090352_V2019_08_20_16_42_19_schema_blud_otoritas_group`;
USE `db_090352_V2019_08_20_16_42_19_schema_blud_otoritas_group`;

CREATE TABLE `AUTH_OTORITAS_BLUD` (
  `id` VARCHAR(64),
  `otoritas_name` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `AUTH_GROUP_BLUD` (
  `id` VARCHAR(64),
  `group_name` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `AUTH_GROUP_OTORITAS` (
  `id` VARCHAR(64),
  `group_id` VARCHAR(64),
  `otoritas_id` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `component_menu_map_by_otoritas` (
  `id` VARCHAR(64),
  `otoritas_id` VARCHAR(64),
  `menu_id` VARCHAR(64),
  `created_by` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_090352_V2019_08_20_16_42_19_schema_blud_otoritas_group') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_090352_V2019_08_20_16_42_19_schema_blud_otoritas_group') AS relationships;
DROP DATABASE `db_090352_V2019_08_20_16_42_19_schema_blud_otoritas_group`;
