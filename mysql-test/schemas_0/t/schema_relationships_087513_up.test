INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087513_up
--echo #
CREATE DATABASE `db_087513_up`;
USE `db_087513_up`;
CREATE TABLE `users` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `last_name` TEXT,
  `email` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `alias` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `confirmed_users` (
  `user_id` VARCHAR(50) NOT NULL,
  `will_attend` VARCHAR(50),
  `table_id` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087513_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087513_up') AS relationships;
DROP DATABASE `db_087513_up`;
UNINSTALL EXTENSION vsql_schematron;
