INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 083078_0000-feature-flags
--echo #
CREATE DATABASE `db_083078_0000_feature_flags`;
USE `db_083078_0000_feature_flags`;
CREATE TABLE `public.tb_feature_flags` (
  `id` INT NOT NULL,
  `name` TEXT,
  `open` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `public.tb_guild_features` (
  `guild_id` BIGINT NOT NULL,
  `feature_id` INT NOT NULL,
  PRIMARY KEY (`guild_id`, `feature_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_083078_0000_feature_flags') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_083078_0000_feature_flags') AS relationships;
DROP DATABASE `db_083078_0000_feature_flags`;
UNINSTALL EXTENSION vsql_schematron;
