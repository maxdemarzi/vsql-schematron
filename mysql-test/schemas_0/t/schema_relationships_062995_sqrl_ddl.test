INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062995_sqrl.ddl
--echo #
CREATE DATABASE `db_062995_sqrl_ddl`;
USE `db_062995_sqrl_ddl`;

CREATE TABLE `sqrl_identity` (
  `id` INT,
  `idk` VARCHAR(64),
  `native_user_xref` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_correlator` (
  `id` INT,
  `authenticationStatus` VARCHAR(64),
  `expiryTime` DATETIME,
  `value` VARCHAR(64),
  `authenticated_identity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_identity_flag` (
  `id` INT,
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_identity_data` (
  `id` INT,
  `value` VARCHAR(64),
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_transient_auth_data` (
  `id` INT,
  `value` VARCHAR(64),
  `name` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_used_nut_token` (
  `value` VARCHAR(64),
  `expiryTime` DATETIME,
  PRIMARY KEY (`value`)
) CHARACTER SET latin1;

CREATE TABLE `sqrl_db_id_gen` (
  `name` VARCHAR(64),
  `value` DECIMAL(10,2),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062995_sqrl_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062995_sqrl_ddl') AS relationships;
DROP DATABASE `db_062995_sqrl_ddl`;
UNINSTALL EXTENSION vsql_schematron;
