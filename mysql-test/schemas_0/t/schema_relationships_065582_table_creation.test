INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 065582_table_creation
--echo #
CREATE DATABASE `db_065582_table_creation`;
USE `db_065582_table_creation`;

CREATE TABLE `Accommodation` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `location` VARCHAR(64),
  `price` INT,
  `rooms` INT,
  `rating` DECIMAL(10,2),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Rating` (
  `userId` VARCHAR(64),
  `accoId` VARCHAR(64),
  `rating` INT,
  PRIMARY KEY (`accoId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `Recommendation` (
  `userId` VARCHAR(64),
  `accoId` VARCHAR(64),
  `prediction` DECIMAL(10,2),
  PRIMARY KEY (`userId`, `accoId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_065582_table_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_065582_table_creation') AS relationships;
DROP DATABASE `db_065582_table_creation`;
UNINSTALL EXTENSION vsql_schematron;
