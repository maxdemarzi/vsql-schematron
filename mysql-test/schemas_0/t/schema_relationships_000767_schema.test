INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 000767_schema
--echo #
CREATE DATABASE `db_000767_schema`;
USE `db_000767_schema`;

CREATE TABLE `members` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `pass` VARCHAR(64),
  `dob` DATETIME,
  `gender` VARCHAR(64),
  `iscommittee` BOOL,
  `iscoach` BOOL,
  `isactive` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `certs` (
  `id` INT,
  `certname` VARCHAR(64),
  `recordtype` VARCHAR(64),
  `authority` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `records` (
  `id` INT,
  `member_id` INT,
  `cert_id` INT,
  `auth_id` INT,
  `auth_date` DATETIME,
  `completed` DATETIME,
  `expiry` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_000767_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_000767_schema') AS relationships;
DROP DATABASE `db_000767_schema`;
UNINSTALL EXTENSION vsql_schematron;
