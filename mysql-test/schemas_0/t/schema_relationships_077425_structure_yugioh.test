INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 077425_structure_yugioh
--echo #
CREATE DATABASE `db_077425_structure_yugioh`;
USE `db_077425_structure_yugioh`;

CREATE TABLE `Monster_Type` (
  `Monster_Type_ID` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Monster_Type_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Card_Type` (
  `Type_ID` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`Type_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Yugioh_card` (
  `Cards_ID` INT,
  `Name` VARCHAR(64),
  `Description` VARCHAR(64),
  `Reference` VARCHAR(64),
  `Level` INT,
  `Atk` INT,
  `Def` INT,
  `Monster_Type_ID` INT,
  `Type_ID` INT,
  `Picture` VARCHAR(64),
  PRIMARY KEY (`Cards_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_077425_structure_yugioh') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_077425_structure_yugioh') AS relationships;
DROP DATABASE `db_077425_structure_yugioh`;
UNINSTALL EXTENSION vsql_schematron;
