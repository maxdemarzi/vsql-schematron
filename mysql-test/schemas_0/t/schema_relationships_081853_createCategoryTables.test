INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081853_createCategoryTables
--echo #
CREATE DATABASE `db_081853_createCategoryTables`;
USE `db_081853_createCategoryTables`;
CREATE TABLE `userlogins5.TargetCategory` (
  `target_category_id` DECIMAL(10,2) NOT NULL,
  `category` VARCHAR(50),
  `comment_target_id` VARCHAR(50),
  PRIMARY KEY (`target_category_id`)
) CHARACTER SET latin1;
CREATE TABLE `userlogins5.CommentTargetCategory` (
  `comment_target_category_id` DECIMAL(10,2) NOT NULL,
  `comment_id` DECIMAL(10,2),
  `target_category_id` DECIMAL(10,2),
  PRIMARY KEY (`comment_target_category_id`)
) CHARACTER SET latin1;
CREATE TABLE `userlogins5.CommentReference` (
  `comment_reference_id` DECIMAL(10,2) NOT NULL,
  `source_id` VARCHAR(50),
  `database_name` VARCHAR(50),
  `comment_id` DECIMAL(10,2),
  PRIMARY KEY (`comment_reference_id`)
) CHARACTER SET latin1;
CREATE TABLE `userlogins5.CommentSequence` (
  `comment_sequence_id` DECIMAL(10,2) NOT NULL,
  `sequence` VARCHAR(50),
  `comment_id` DECIMAL(10,2),
  PRIMARY KEY (`comment_sequence_id`)
) CHARACTER SET latin1;
CREATE TABLE `userlogins5.CommentFile` (
  `file_id` DECIMAL(10,2) NOT NULL,
  `name` VARCHAR(50),
  `notes` VARCHAR(50),
  `comment_id` DECIMAL(10,2),
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
CREATE TABLE `userlogins5.CommentStableId` (
  `comment_stable_id` DECIMAL(10,2) NOT NULL,
  `stable_id` VARCHAR(50),
  `comment_id` DECIMAL(10,2),
  PRIMARY KEY (`comment_stable_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081853_createCategoryTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081853_createCategoryTables') AS relationships;
DROP DATABASE `db_081853_createCategoryTables`;
UNINSTALL EXTENSION vsql_schematron;
