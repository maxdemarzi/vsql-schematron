INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 029693_install_config_derby.ddl
--echo #
CREATE DATABASE `db_029693_install_config_derby_ddl`;
USE `db_029693_install_config_derby_ddl`;

CREATE TABLE `CONFIG_BEAN` (
  `BEAN_ID` VARCHAR(64),
  `BEAN_SCHEMA_NAME` VARCHAR(64),
  PRIMARY KEY (`BEAN_ID`, `BEAN_SCHEMA_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `CONFIG_BEAN_SINGLETON` (
  `BEAN_SCHEMA_NAME` VARCHAR(64),
  PRIMARY KEY (`BEAN_SCHEMA_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `CONFIG_BEAN_REF` (
  `UUID` VARCHAR(64),
  `FK_SOURCE_BEAN_SCHEMA_NAME` VARCHAR(64),
  `FK_SOURCE_BEAN_ID` VARCHAR(64),
  `PROP_NAME` VARCHAR(64),
  `FK_TARGET_BEAN_ID` VARCHAR(64),
  `FK_TARGET_BEAN_SCHEMA_NAME` VARCHAR(64),
  PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;

CREATE TABLE `CONFIG_PROPERTY` (
  `UUID` VARCHAR(64),
  `FK_BEAN_ID` VARCHAR(64),
  `PROP_NAME` VARCHAR(64),
  `FK_BEAN_SCHEMA_NAME` VARCHAR(64),
  `PROP_VALUE` VARCHAR(64),
  PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_029693_install_config_derby_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_029693_install_config_derby_ddl') AS relationships;
DROP DATABASE `db_029693_install_config_derby_ddl`;
UNINSTALL EXTENSION vsql_schematron;
