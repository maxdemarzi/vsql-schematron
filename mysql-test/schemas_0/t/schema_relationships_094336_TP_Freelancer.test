INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094336_TP_Freelancer
--echo #
CREATE DATABASE `db_094336_TP_Freelancer`;
USE `db_094336_TP_Freelancer`;
CREATE TABLE `customers_cats` (
  `cat_id` INT NOT NULL,
  `cat_name` VARCHAR(50),
  `cat_description` TEXT,
  PRIMARY KEY (`cat_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
  `customer_id` INT NOT NULL,
  `customer_name` VARCHAR(50),
  `customer_email` VARCHAR(50),
  `cat_id` INT,
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
  `job_id` INT NOT NULL,
  `job_state` CHAR(50),
  `job_title` VARCHAR(50),
  `job_start` DATETIME,
  `job_end` DATETIME,
  `job_description` TEXT,
  `customer_id` INT,
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
  `quote_id` INT NOT NULL,
  `quote_state` CHAR(50),
  `quote_date` DATE,
  `quote_amount` INT,
  `quote_final_date` DATE,
  `quote_final_amount` INT,
  `job_id` INT,
  PRIMARY KEY (`quote_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094336_TP_Freelancer') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094336_TP_Freelancer') AS relationships;
DROP DATABASE `db_094336_TP_Freelancer`;
UNINSTALL EXTENSION vsql_schematron;
