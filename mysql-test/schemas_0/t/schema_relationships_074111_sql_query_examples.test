INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 074111_sql_query_examples
--echo #
CREATE DATABASE `db_074111_sql_query_examples`;
USE `db_074111_sql_query_examples`;

CREATE TABLE `employee` (
  `employee_ID` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `birthday` DATETIME,
  `sex` VARCHAR(64),
  `salary` INT,
  `supervisor_ID` INT,
  `branch_ID` INT,
  PRIMARY KEY (`employee_ID`)
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `branch_ID` INT,
  `branch_name` VARCHAR(64),
  `manager_ID` INT,
  `manager_start_date` DATETIME,
  PRIMARY KEY (`branch_ID`)
) CHARACTER SET latin1;

CREATE TABLE `client` (
  `client_ID` INT,
  `client_name` VARCHAR(64),
  `branch_id` INT,
  PRIMARY KEY (`client_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_074111_sql_query_examples') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_074111_sql_query_examples') AS relationships;
DROP DATABASE `db_074111_sql_query_examples`;
UNINSTALL EXTENSION vsql_schematron;
