INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 037719_schema
--echo #
CREATE DATABASE `db_037719_schema`;
USE `db_037719_schema`;
CREATE TABLE `tenants` (
  `id` INT NOT NULL,
  `handle` VARCHAR(50),
  `name` VARCHAR(50),
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `login` VARCHAR(50),
  `active` BOOLEAN,
  `phone` VARCHAR(50),
  `password` VARCHAR(50),
  `tenant_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
  `id` INT NOT NULL,
  `msg` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `news` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `published` BOOLEAN,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hash` (
  `id` INT NOT NULL,
  `k` VARCHAR(50),
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_037719_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_037719_schema') AS relationships;
DROP DATABASE `db_037719_schema`;
UNINSTALL EXTENSION vsql_schematron;
