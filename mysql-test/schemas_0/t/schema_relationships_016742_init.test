INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016742_init
--echo #
CREATE DATABASE `db_016742_init`;
USE `db_016742_init`;

CREATE TABLE `friends` (
  `one` INT,
  `two` INT
) CHARACTER SET latin1;

CREATE TABLE `game` (
  `id` INT,
  `current_index` INT,
  `start_state` VARCHAR(64),
  `game_state` VARCHAR(64),
  `created` DATETIME,
  `lastUpdated` DATETIME,
  `deleted` INT,
  `deletedDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `game_event` (
  `game_id` INT,
  `current_index` INT,
  `event_data` VARCHAR(64),
  PRIMARY KEY (`game_id`, `current_index`)
) CHARACTER SET latin1;

CREATE TABLE `game_players` (
  `user_id` INT,
  `game_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016742_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016742_init') AS relationships;
DROP DATABASE `db_016742_init`;
UNINSTALL EXTENSION vsql_schematron;
