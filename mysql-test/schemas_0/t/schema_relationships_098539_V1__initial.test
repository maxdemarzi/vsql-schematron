INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 098539_V1__initial
--echo #
CREATE DATABASE `db_098539_V1__initial`;
USE `db_098539_V1__initial`;
CREATE TABLE `recipes` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `servings` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `quantity` INT,
  `unit` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `recipe_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `id` VARCHAR(50) NOT NULL,
  `description` TEXT,
  `duration` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `recipe_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_098539_V1__initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_098539_V1__initial') AS relationships;
DROP DATABASE `db_098539_V1__initial`;
UNINSTALL EXTENSION vsql_schematron;
