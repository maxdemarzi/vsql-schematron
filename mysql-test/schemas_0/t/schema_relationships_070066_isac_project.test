INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070066_isac_project
--echo #
CREATE DATABASE `db_070066_isac_project`;
USE `db_070066_isac_project`;

CREATE TABLE `alumni_user` (
  `alumni_id` INT,
  `stu_id` INT,
  `password` VARCHAR(64),
  `name_prefix` VARCHAR(64),
  `alumni_fname` VARCHAR(64),
  `alumni_lname` VARCHAR(64),
  `alumni_fname_eng` VARCHAR(64),
  `alumni_lname_eng` VARCHAR(64),
  `alumni_code` VARCHAR(64),
  `sex` VARCHAR(64),
  `d_m_y_birth` DATETIME,
  `nationality` VARCHAR(64),
  `religion` VARCHAR(64),
  `blood_type` VARCHAR(64),
  PRIMARY KEY (`alumni_id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_address` (
  `address_id` INT,
  `numhome_b` VARCHAR(64),
  `village_b` VARCHAR(64),
  `sub_distric_b` VARCHAR(64),
  `district_b` VARCHAR(64),
  `province_b` VARCHAR(64),
  `zipcode_b` INT,
  `numhome_c` VARCHAR(64),
  `village_c` VARCHAR(64),
  `sub_district_c` VARCHAR(64),
  `district_c` VARCHAR(64),
  `province_c` VARCHAR(64),
  `zipcode_c` INT,
  PRIMARY KEY (`address_id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_social` (
  `social_id` INT,
  `facebook` VARCHAR(64),
  `line` VARCHAR(64),
  `phone_number` INT,
  PRIMARY KEY (`social_id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_education` (
  `education_id` INT,
  `education_level` VARCHAR(64),
  `year_first` INT,
  `year_finish` INT,
  `faculty` VARCHAR(64),
  `major` VARCHAR(64),
  `section` VARCHAR(64),
  PRIMARY KEY (`education_id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_job` (
  `job_id` INT,
  `occupation` VARCHAR(64),
  `start_date` DATETIME,
  `company_name` VARCHAR(64),
  `company_address` VARCHAR(64),
  `contact` INT,
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_img` (
  `img_id` INT,
  `imges` VARCHAR(64),
  PRIMARY KEY (`img_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070066_isac_project') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070066_isac_project') AS relationships;
DROP DATABASE `db_070066_isac_project`;
UNINSTALL EXTENSION vsql_schematron;
