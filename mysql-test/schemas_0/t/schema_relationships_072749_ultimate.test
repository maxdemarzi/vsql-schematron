INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 072749_ultimate
--echo #
CREATE DATABASE `db_072749_ultimate`;
USE `db_072749_ultimate`;

CREATE TABLE `categories` (
  `id` INT,
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `image` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chat` (
  `id` INT,
  `msg` VARCHAR(64),
  `from_user` INT,
  `booking_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `to_user` INT,
  `msg_type` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `complete_excercises` (
  `id` INT,
  `programme_id` INT,
  `day_num` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `countries` (
  `id` INT,
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `msg` VARCHAR(64),
  `send_date` DATETIME,
  `from_user` INT,
  `request_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `muscles` (
  `id` INT,
  `title` VARCHAR(64),
  `title_ar` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` INT,
  `msg` VARCHAR(64),
  `send_date` DATETIME,
  `user_id` INT,
  `is_send` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `send_from` INT
) CHARACTER SET latin1;

CREATE TABLE `package_user_plan` (
  `day_num` INT,
  `package_id` INT,
  `user_id` INT,
  `programme_design_id` INT,
  `recepe_id` INT,
  `section_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `transaction_id` INT,
  `id` INT,
  `set_num` VARCHAR(64),
  `suplement_serving_size` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `programe_design_integrent` (
  `id` INT,
  `programme_id` INT,
  `serving_size` VARCHAR(64),
  `calories` DECIMAL(10,2),
  `carbs` DECIMAL(10,2),
  `protein` DECIMAL(10,2),
  `fat` DECIMAL(10,2),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `programme_images` (
  `id` INT,
  `image` VARCHAR(64),
  `programme_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `programm_designs` (
  `id` INT,
  `title` VARCHAR(64),
  `desc` VARCHAR(64),
  `vedio` VARCHAR(64),
  `media_type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `type` VARCHAR(64),
  `number_of_sets` VARCHAR(64),
  `serving_size` VARCHAR(64),
  `title_ar` VARCHAR(64),
  `desc_ar` VARCHAR(64),
  `num_of_reps` INT,
  `muscles` VARCHAR(64),
  `exercise_type` VARCHAR(64),
  `equipment` VARCHAR(64),
  `mechanics_type` VARCHAR(64),
  `level` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `programm_design_calendar` (
  `id` INT,
  `start` DATETIME,
  `end` DATETIME,
  `booking_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `programme_id` INT
) CHARACTER SET latin1;

CREATE TABLE `questionaire` (
  `id` INT,
  `message` VARCHAR(64),
  `answer` VARCHAR(64),
  `user_id` INT,
  `transaction_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `questions` (
  `id` INT,
  `title` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `title_ar` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `questions_answers` (
  `id` INT,
  `question_id` INT,
  `answer` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `transaction_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ready_plan` (
  `id` INT,
  `day_num` INT,
  `programme_design_id` INT,
  `recepe_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `set_num` VARCHAR(64),
  `suplement_serving_size` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `receips` (
  `id` INT,
  `name` VARCHAR(64),
  `desciption` VARCHAR(64),
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `receips_integration` (
  `recep_id` INT,
  `integrate_programme_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `serving` INT,
  `programme_id` INT
) CHARACTER SET latin1;

CREATE TABLE `recepis_sections` (
  `id` INT,
  `section_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `requests` (
  `id` INT,
  `msg` VARCHAR(64),
  `send_date` DATETIME,
  `user_id` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `subject` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sliders` (
  `id` INT,
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tickets` (
  `id` INT,
  `title` VARCHAR(64),
  `msg` VARCHAR(64),
  `send_date` DATETIME,
  `user_id` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `assign_to_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `role_id` INT,
  `image` VARCHAR(64),
  `desc` VARCHAR(64),
  `category_id` INT,
  `city_id` VARCHAR(64),
  `name_ar` VARCHAR(64),
  `description_ar` VARCHAR(64),
  `city_ar` VARCHAR(64),
  `google_id` VARCHAR(64),
  `apple_id` VARCHAR(64),
  `phone` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `id` INT,
  `user_id` INT,
  `permssion_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_072749_ultimate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_072749_ultimate') AS relationships;
DROP DATABASE `db_072749_ultimate`;
UNINSTALL EXTENSION vsql_schematron;
