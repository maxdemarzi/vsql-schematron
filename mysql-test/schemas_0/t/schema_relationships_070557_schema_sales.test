INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 070557_schema_sales
--echo #
CREATE DATABASE `db_070557_schema_sales`;
USE `db_070557_schema_sales`;
CREATE TABLE `party_salesman` (
  `party_id` VARCHAR(50) NOT NULL,
  `status_id` VARCHAR(50),
  `last_updated_stamp` TIMESTAMP NULL,
  `created_stamp` TIMESTAMP NULL,
  PRIMARY KEY (`party_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer_salesman` (
  `customer_salesman_id` VARCHAR(50) NOT NULL,
  `party_customer_id` VARCHAR(50),
  `party_salesman_id` VARCHAR(50),
  `from_date` TIMESTAMP NULL,
  `thru_date` TIMESTAMP NULL,
  PRIMARY KEY (`customer_salesman_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_070557_schema_sales') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_070557_schema_sales') AS relationships;
DROP DATABASE `db_070557_schema_sales`;
UNINSTALL EXTENSION vsql_schematron;
