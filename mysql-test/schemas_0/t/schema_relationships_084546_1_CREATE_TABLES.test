INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 084546_1_CREATE_TABLES
--echo #
CREATE DATABASE `db_084546_1_CREATE_TABLES`;
USE `db_084546_1_CREATE_TABLES`;

CREATE TABLE `Postcode` (
  `POST` INT,
  `CITY` VARCHAR(64),
  `POSTSTATE` VARCHAR(64),
  PRIMARY KEY (`POST`)
) CHARACTER SET latin1;

CREATE TABLE `Customer` (
  `C_ID` INT,
  `CNAME` VARCHAR(64),
  `CPOST` INT,
  PRIMARY KEY (`C_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Supplier` (
  `S_ID` INT,
  `SNAME` VARCHAR(64),
  `SPOST` INT,
  PRIMARY KEY (`S_ID`)
) CHARACTER SET latin1;

CREATE TABLE `Item` (
  `I_ID` INT,
  `INAME` VARCHAR(64),
  `SALEPRICE` DECIMAL(10,2),
  PRIMARY KEY (`I_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SupplierItem` (
  `S_ID` INT,
  `I_ID` INT,
  `PURCHPRICE` DECIMAL(10,2),
  PRIMARY KEY (`S_ID`, `I_ID`)
) CHARACTER SET latin1;

CREATE TABLE `SupplierItemCustomer` (
  `S_ID` INT,
  `I_ID` INT,
  `C_ID` INT,
  PRIMARY KEY (`S_ID`, `I_ID`, `C_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_084546_1_CREATE_TABLES') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_084546_1_CREATE_TABLES') AS relationships;
DROP DATABASE `db_084546_1_CREATE_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
