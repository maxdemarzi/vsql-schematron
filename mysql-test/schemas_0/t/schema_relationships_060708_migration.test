INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 060708_migration
--echo #
CREATE DATABASE `db_060708_migration`;
USE `db_060708_migration`;

CREATE TABLE `UserQuiz` (
  `id` VARCHAR(255),
  `userId` VARCHAR(255),
  `quizId` VARCHAR(255),
  `timeStart` DATETIME,
  `timeFinish` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserQuizQuestion` (
  `id` VARCHAR(255),
  `userQuizId` VARCHAR(255),
  `quizQuestionId` VARCHAR(255),
  `grade` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserQuestionAnswer` (
  `id` VARCHAR(255),
  `userQuizQuestionId` VARCHAR(255),
  `questionAnswerId` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_060708_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_060708_migration') AS relationships;
DROP DATABASE `db_060708_migration`;
UNINSTALL EXTENSION vsql_schematron;
