INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 097911_V4__create_program_tables
--echo #
CREATE DATABASE `db_097911_V4__create_program_tables`;
USE `db_097911_V4__create_program_tables`;
CREATE TABLE `ptcore.in_program` (
  `id` BIGINT NOT NULL,
  `in_user_id` BIGINT,
  `created` TIMESTAMP NULL,
  `name` VARCHAR(50),
  `d_program_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptcore.in_workout` (
  `id` BIGINT NOT NULL,
  `in_program_id` BIGINT,
  `created` TIMESTAMP NULL,
  `d_workout_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptcore.in_workout_item` (
  `id` BIGINT NOT NULL,
  `in_workout_id` BIGINT,
  `created` TIMESTAMP NULL,
  `d_exercise_id` VARCHAR(50),
  `d_exercise_name` VARCHAR(50),
  `sets` INT,
  `repetitions` INT,
  `weight` INT,
  `bodyweight` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_097911_V4__create_program_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_097911_V4__create_program_tables') AS relationships;
DROP DATABASE `db_097911_V4__create_program_tables`;
UNINSTALL EXTENSION vsql_schematron;
