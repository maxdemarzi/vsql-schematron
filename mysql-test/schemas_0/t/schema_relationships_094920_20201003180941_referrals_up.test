INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094920_20201003180941_referrals_up
--echo #
CREATE DATABASE `db_094920_20201003180941_referrals_up`;
USE `db_094920_20201003180941_referrals_up`;

CREATE TABLE `partners` (
  `id` INT,
  `isActive` VARCHAR(64),
  `name` VARCHAR(64),
  `dateAdded` DATETIME,
  `dateModified` DATETIME,
  `addedBy` INT,
  `modifiedBy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `partnerServices` (
  `id` INT,
  `partnerId` INT,
  `name` VARCHAR(64),
  `isActive` VARCHAR(64),
  `dateAdded` DATETIME,
  `dateModified` DATETIME,
  `addedBy` INT,
  `modifiedBy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `leadReferrals` (
  `id` INT,
  `leadId` INT,
  `partnerServiceId` INT,
  `addedBy` INT,
  `dateAdded` DATETIME,
  `isDeleted` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `clientReferrals` (
  `id` INT,
  `clientId` INT,
  `partnerServiceId` INT,
  `isDeleted` VARCHAR(64),
  `addedBy` INT,
  `dateAdded` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094920_20201003180941_referrals_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094920_20201003180941_referrals_up') AS relationships;
DROP DATABASE `db_094920_20201003180941_referrals_up`;
UNINSTALL EXTENSION vsql_schematron;
