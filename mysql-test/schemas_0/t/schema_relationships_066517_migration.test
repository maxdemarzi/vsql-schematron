INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 066517_migration
--echo #
CREATE DATABASE `db_066517_migration`;
USE `db_066517_migration`;

CREATE TABLE `User` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `logo` VARCHAR(64),
  `status` VARCHAR(64),
  `biography` VARCHAR(64),
  `isConfirmed` BOOL,
  `temporaryToken` VARCHAR(64),
  `temporaryExpirationToken` DATETIME,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserSetting` (
  `id` INT,
  `language` VARCHAR(64),
  `theme` VARCHAR(64),
  `isPublicEmail` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `RefreshToken` (
  `id` INT,
  `token` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `OAuth` (
  `id` INT,
  `providerId` VARCHAR(64),
  `provider` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Member` (
  `id` INT,
  `isOwner` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `userId` INT,
  `guildId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Guild` (
  `id` INT,
  `name` VARCHAR(64),
  `icon` VARCHAR(64),
  `description` VARCHAR(64),
  `type` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Channel` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `guildId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Message` (
  `id` INT,
  `value` VARCHAR(64),
  `type` VARCHAR(64),
  `mimetype` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `memberId` INT,
  `channelId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_066517_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_066517_migration') AS relationships;
DROP DATABASE `db_066517_migration`;
UNINSTALL EXTENSION vsql_schematron;
