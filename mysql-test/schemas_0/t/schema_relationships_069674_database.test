INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 069674_database
--echo #
CREATE DATABASE `db_069674_database`;
USE `db_069674_database`;
CREATE TABLE `confederations` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
  `id` INT,
  `confederation_id` INT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
  `id` INT,
  `country_id` INT,
  `url_image` TEXT,
  `name` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_069674_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_069674_database') AS relationships;
DROP DATABASE `db_069674_database`;
UNINSTALL EXTENSION vsql_schematron;
