INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 048864_V2.0.0__schema
--echo #
CREATE DATABASE `db_048864_V2_0_0_schema`;
USE `db_048864_V2_0_0_schema`;

CREATE TABLE `BaremetalPxeServerVO` (
  `uuid` VARCHAR(64),
  `dhcpInterface` VARCHAR(64),
  `dhcpRangeBegin` VARCHAR(64),
  `dhcpRangeEnd` VARCHAR(64),
  `dhcpRangeNetmask` VARCHAR(64),
  `status` VARCHAR(64),
  `lastOpDate` DATETIME,
  `createDate` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `BaremetalChassisVO` (
  `uuid` VARCHAR(64),
  `ipmiAddress` VARCHAR(64),
  `ipmiUsername` VARCHAR(64),
  `ipmiPassword` VARCHAR(64),
  `provisioned` INT,
  `lastOpDate` DATETIME,
  `createDate` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `BaremetalHostCfgVO` (
  `uuid` VARCHAR(64),
  `chassisUuid` VARCHAR(64),
  `password` VARCHAR(64),
  `vnc` INT,
  `unattended` INT,
  `lastOpDate` DATETIME,
  `createDate` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `BaremetalHostNicCfgVO` (
  `uuid` VARCHAR(64),
  `hostCfgUuid` VARCHAR(64),
  `mac` VARCHAR(64),
  `ip` VARCHAR(64),
  `netmask` VARCHAR(64),
  `gateway` VARCHAR(64),
  `dns` VARCHAR(64),
  `pxe` INT,
  `lastOpDate` DATETIME,
  `createDate` DATETIME,
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_048864_V2_0_0_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_048864_V2_0_0_schema') AS relationships;
DROP DATABASE `db_048864_V2_0_0_schema`;
UNINSTALL EXTENSION vsql_schematron;
