INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 087934_20201103_1_tags
--echo #
CREATE DATABASE `db_087934_20201103_1_tags`;
USE `db_087934_20201103_1_tags`;
CREATE TABLE `tags` (
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `id` VARCHAR(50) NOT NULL,
  `tag_name` VARCHAR(50),
  `user_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags_posts_attachment` (
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `id` VARCHAR(50) NOT NULL,
  `post_id` VARCHAR(50),
  `tag_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_087934_20201103_1_tags') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_087934_20201103_1_tags') AS relationships;
DROP DATABASE `db_087934_20201103_1_tags`;
UNINSTALL EXTENSION vsql_schematron;
