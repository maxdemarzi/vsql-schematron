INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 080912_collegesManager_upgrade_1-2
--echo #
CREATE DATABASE `db_080912_collegesManager_upgrade_1_2`;
USE `db_080912_collegesManager_upgrade_1_2`;

CREATE TABLE `major_names` (
  `_id` INT,
  `major_name` VARCHAR(64),
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

CREATE TABLE `majors` (
  `_id` INT,
  `college_id` INT,
  `major` INT,
  PRIMARY KEY (`_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_080912_collegesManager_upgrade_1_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_080912_collegesManager_upgrade_1_2') AS relationships;
DROP DATABASE `db_080912_collegesManager_upgrade_1_2`;
UNINSTALL EXTENSION vsql_schematron;
