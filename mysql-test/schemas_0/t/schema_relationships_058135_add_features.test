INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 058135_add_features
--echo #
CREATE DATABASE `db_058135_add_features`;
USE `db_058135_add_features`;
CREATE TABLE `feature` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `feature_type` VARCHAR(50),
  `post_personality` SMALLINT,
  `creation_date` DATE,
  `comments` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature_link` (
  `id` INT NOT NULL,
  `feature_id` INT,
  `model_id` INT,
  `archetype_id` INT,
  `personality_id` INT,
  `interface_name` VARCHAR(50),
  `creation_date` DATE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_058135_add_features') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_058135_add_features') AS relationships;
DROP DATABASE `db_058135_add_features`;
UNINSTALL EXTENSION vsql_schematron;
