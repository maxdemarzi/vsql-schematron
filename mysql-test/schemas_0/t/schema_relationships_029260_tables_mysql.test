INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 029260_tables_mysql
--echo #
CREATE DATABASE `db_029260_tables_mysql`;
USE `db_029260_tables_mysql`;

CREATE TABLE `QRTZ_JOB_DETAILS` (
  `JOB_NAME` VARCHAR(255),
  `JOB_GROUP` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `JOB_CLASS_NAME` VARCHAR(255),
  `IS_DURABLE` VARCHAR(255),
  `IS_VOLATILE` VARCHAR(255),
  `IS_STATEFUL` VARCHAR(255),
  `REQUESTS_RECOVERY` VARCHAR(255),
  `JOB_DATA` VARCHAR(255),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_JOB_LISTENERS` (
  `JOB_NAME` VARCHAR(255),
  `JOB_GROUP` VARCHAR(255),
  `JOB_LISTENER` VARCHAR(255),
  PRIMARY KEY (`JOB_NAME`, `JOB_GROUP`, `JOB_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `JOB_NAME` VARCHAR(255),
  `JOB_GROUP` VARCHAR(255),
  `IS_VOLATILE` VARCHAR(255),
  `DESCRIPTION` VARCHAR(255),
  `NEXT_FIRE_TIME` INT,
  `PREV_FIRE_TIME` INT,
  `TRIGGER_STATE` VARCHAR(255),
  `TRIGGER_TYPE` VARCHAR(255),
  `START_TIME` INT,
  `END_TIME` INT,
  `CALENDAR_NAME` VARCHAR(255),
  `MISFIRE_INSTR` INT,
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SIMPLE_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `REPEAT_COUNT` INT,
  `REPEAT_INTERVAL` INT,
  `TIMES_TRIGGERED` INT,
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CRON_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `CRON_EXPRESSION` VARCHAR(255),
  `TIME_ZONE_ID` VARCHAR(255),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_BLOB_TRIGGERS` (
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `BLOB_DATA` VARCHAR(255),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_TRIGGER_LISTENERS` (
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `TRIGGER_LISTENER` VARCHAR(255),
  PRIMARY KEY (`TRIGGER_NAME`, `TRIGGER_GROUP`, `TRIGGER_LISTENER`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_CALENDARS` (
  `CALENDAR_NAME` VARCHAR(255),
  `CALENDAR` VARCHAR(255),
  PRIMARY KEY (`CALENDAR_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_PAUSED_TRIGGER_GRPS` (
  `TRIGGER_GROUP` VARCHAR(255),
  PRIMARY KEY (`TRIGGER_GROUP`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_FIRED_TRIGGERS` (
  `ENTRY_ID` VARCHAR(255),
  `TRIGGER_NAME` VARCHAR(255),
  `TRIGGER_GROUP` VARCHAR(255),
  `IS_VOLATILE` VARCHAR(255),
  `INSTANCE_NAME` VARCHAR(255),
  `FIRED_TIME` INT,
  `STATE` VARCHAR(255),
  `JOB_NAME` VARCHAR(255),
  `JOB_GROUP` VARCHAR(255),
  `IS_STATEFUL` VARCHAR(255),
  `REQUESTS_RECOVERY` VARCHAR(255),
  PRIMARY KEY (`ENTRY_ID`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_SCHEDULER_STATE` (
  `INSTANCE_NAME` VARCHAR(255),
  `LAST_CHECKIN_TIME` INT,
  `CHECKIN_INTERVAL` INT,
  `RECOVERER` VARCHAR(255),
  PRIMARY KEY (`INSTANCE_NAME`)
) CHARACTER SET latin1;

CREATE TABLE `QRTZ_LOCKS` (
  `LOCK_NAME` VARCHAR(255),
  PRIMARY KEY (`LOCK_NAME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_029260_tables_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_029260_tables_mysql') AS relationships;
DROP DATABASE `db_029260_tables_mysql`;
UNINSTALL EXTENSION vsql_schematron;
