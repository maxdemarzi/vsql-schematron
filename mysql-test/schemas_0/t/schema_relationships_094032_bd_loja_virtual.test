INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 094032_bd_loja_virtual
--echo #
CREATE DATABASE `db_094032_bd_loja_virtual`;
USE `db_094032_bd_loja_virtual`;
CREATE TABLE `tb_descricoes_tecnicas` (
  `id_descricao_tecnica` INT NOT NULL,
  `id_produto` INT,
  `descricao_tecnica` TEXT,
  PRIMARY KEY (`id_descricao_tecnica`)
) CHARACTER SET latin1;
CREATE TABLE `tb_imagens` (
  `id_imagem` INT NOT NULL,
  `id_produto` INT,
  `url_imagem` VARCHAR(50),
  PRIMARY KEY (`id_imagem`)
) CHARACTER SET latin1;
CREATE TABLE `tb_clientes` (
  `id_cliente` INT NOT NULL,
  `nome` VARCHAR(50),
  `idade` INT,
  PRIMARY KEY (`id_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos` (
  `id_pedido` INT NOT NULL,
  `id_cliente` INT,
  `data_hora` DATETIME,
  PRIMARY KEY (`id_pedido`)
) CHARACTER SET latin1;
CREATE TABLE `tb_pedidos_produto` (
  `id_pedido` INT,
  `id_produto` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_094032_bd_loja_virtual') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_094032_bd_loja_virtual') AS relationships;
DROP DATABASE `db_094032_bd_loja_virtual`;
UNINSTALL EXTENSION vsql_schematron;
