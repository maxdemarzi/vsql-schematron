INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 062602_schema
--echo #
CREATE DATABASE `db_062602_schema`;
USE `db_062602_schema`;

CREATE TABLE `event` (
  `id` INT,
  `item_type` VARCHAR(255),
  `batch_id` INT,
  `line_id` INT,
  `process` VARCHAR(255),
  `action` VARCHAR(255),
  `operator` VARCHAR(255),
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `slide` (
  `id` INT,
  `label` VARCHAR(255),
  `batch_id` INT,
  `member` INT,
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `slot` (
  `id` INT,
  `slide_id` INT,
  `line_id` INT,
  `position` INT,
  `is_redo` INT,
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `queue` (
  `id` INT,
  `line` VARCHAR(255),
  `effector` VARCHAR(255),
  `queue_type` VARCHAR(255),
  `comment` VARCHAR(255),
  `priority` INT,
  `operator` VARCHAR(255),
  `create_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_062602_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_062602_schema') AS relationships;
DROP DATABASE `db_062602_schema`;
UNINSTALL EXTENSION vsql_schematron;
