INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067304_table_structure
--echo #
CREATE DATABASE `db_067304_table_structure`;
USE `db_067304_table_structure`;

CREATE TABLE `hierarchy` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hierarchy_level_type` (
  `id` VARCHAR(64),
  `level` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hierarchy_entry` (
  `id` VARCHAR(64),
  `code` VARCHAR(64),
  `display_order` INT,
  `name` VARCHAR(64),
  `hierarchy_id` VARCHAR(64),
  `hierarchy_level_type_id` VARCHAR(64),
  `parent` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067304_table_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067304_table_structure') AS relationships;
DROP DATABASE `db_067304_table_structure`;
UNINSTALL EXTENSION vsql_schematron;
