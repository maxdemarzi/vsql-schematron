INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 061596_scripts
--echo #
CREATE DATABASE `db_061596_scripts`;
USE `db_061596_scripts`;

CREATE TABLE `tbcidade` (
  `pkcodcid` INT,
  `nodemid` VARCHAR(64),
  `ufcid` VARCHAR(64),
  PRIMARY KEY (`pkcodcid`)
) CHARACTER SET latin1;

CREATE TABLE `tbcliente` (
  `pkcodcli` INT,
  `nomecli` VARCHAR(64),
  `datanasccli` DATETIME,
  `salariocli` DECIMAL(10,2),
  `fkcodcid` INT,
  PRIMARY KEY (`pkcodcli`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_061596_scripts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_061596_scripts') AS relationships;
DROP DATABASE `db_061596_scripts`;
UNINSTALL EXTENSION vsql_schematron;
