INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 075210_0001_create
--echo #
CREATE DATABASE `db_075210_0001_create`;
USE `db_075210_0001_create`;

CREATE TABLE `user` (
  `idUser` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;

CREATE TABLE `useraddress` (
  `idUserAddress` INT,
  `idUser` INT,
  `address` VARCHAR(64),
  PRIMARY KEY (`idUserAddress`)
) CHARACTER SET latin1;

CREATE TABLE `usercontact` (
  `idUser` INT,
  `idContact` INT,
  PRIMARY KEY (`idUser`, `idContact`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_075210_0001_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_075210_0001_create') AS relationships;
DROP DATABASE `db_075210_0001_create`;
UNINSTALL EXTENSION vsql_schematron;
