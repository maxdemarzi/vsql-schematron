INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 082139_schema
--echo #
CREATE DATABASE `db_082139_schema`;
USE `db_082139_schema`;

CREATE TABLE `Users` (
  `ID` INT,
  `Username` VARCHAR(64),
  `Password` VARCHAR(64),
  `Salt` VARCHAR(64),
  `Iterations` INT,
  `Keysize` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `Apps` (
  `AppID` INT,
  `Name` VARCHAR(64),
  PRIMARY KEY (`AppID`)
) CHARACTER SET latin1;

CREATE TABLE `Transactions` (
  `TID` INT,
  `UID` INT,
  `Value` DECIMAL(10,2),
  `Description` VARCHAR(64),
  PRIMARY KEY (`TID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_082139_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_082139_schema') AS relationships;
DROP DATABASE `db_082139_schema`;
UNINSTALL EXTENSION vsql_schematron;
