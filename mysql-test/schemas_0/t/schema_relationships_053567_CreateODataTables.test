INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 053567_CreateODataTables
--echo #
CREATE DATABASE `db_053567_CreateODataTables`;
USE `db_053567_CreateODataTables`;

CREATE TABLE `Files` (
  `fileName` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`fileName`)
) CHARACTER SET latin1;

CREATE TABLE `FileRecords` (
  `fileRecordId` INT,
  `data` VARCHAR(64),
  `fileName` VARCHAR(64),
  PRIMARY KEY (`fileRecordId`)
) CHARACTER SET latin1;

CREATE TABLE `Accounts` (
  `accountId` INT,
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`accountId`)
) CHARACTER SET latin1;

CREATE TABLE `Student` (
  `studentId` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  PRIMARY KEY (`studentId`)
) CHARACTER SET latin1;

CREATE TABLE `Customers` (
  `customerNumber` INT,
  `customerName` VARCHAR(64),
  `contactLastName` VARCHAR(64),
  `contactFirstName` VARCHAR(64),
  `phone` VARCHAR(64),
  `addressLine1` VARCHAR(64),
  `addressLine2` VARCHAR(64),
  `city` VARCHAR(64),
  `state` VARCHAR(64),
  `postalCode` VARCHAR(64),
  `country` VARCHAR(64),
  `salesRepEmployeeNumber` INT,
  `creditLimit` DECIMAL(10,2),
  PRIMARY KEY (`customerNumber`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_053567_CreateODataTables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_053567_CreateODataTables') AS relationships;
DROP DATABASE `db_053567_CreateODataTables`;
UNINSTALL EXTENSION vsql_schematron;
