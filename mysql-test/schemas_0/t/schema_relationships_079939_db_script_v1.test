INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079939_db_script_v1
--echo #
CREATE DATABASE `db_079939_db_script_v1`;
USE `db_079939_db_script_v1`;

CREATE TABLE `USERS` (
  `USER_ID` INT,
  `USER_NAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `CREATED_TS` DATETIME,
  `UPDATED_TS` DATETIME,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTACTS` (
  `CONTACT_ID` INT,
  `FIRST_NAME` VARCHAR(64),
  `MIDDLE_NAME` VARCHAR(64),
  `LAST_NAME` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `MOBILE_NUMBER` VARCHAR(64),
  `LANDLINE_NUMBER` VARCHAR(64),
  `NOTE` VARCHAR(64),
  `CREATED_TS` DATETIME,
  `UPDATED_TS` DATETIME,
  `USER_ID` INT,
  PRIMARY KEY (`CONTACT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_VIEWS` (
  `CONTACT_ID` INT,
  `EVENT_TS` INT
) CHARACTER SET latin1;

CREATE TABLE `AGGREGATED_USER_VIEWS` (
  `CONTACT_ID` INT,
  `AGG_DATE` DATETIME,
  `COUNT` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079939_db_script_v1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079939_db_script_v1') AS relationships;
DROP DATABASE `db_079939_db_script_v1`;
UNINSTALL EXTENSION vsql_schematron;
