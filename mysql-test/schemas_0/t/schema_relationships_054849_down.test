INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054849_down
--echo #
CREATE DATABASE `db_054849_down`;
USE `db_054849_down`;

CREATE TABLE `sensor_types` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sensors` (
  `id` INT,
  `public_id` INT,
  `node_id` INT,
  `type_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `measurements` (
  `id` INT,
  `sensor_id` INT,
  `value` DECIMAL(10,2),
  `measured_at` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054849_down') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054849_down') AS relationships;
DROP DATABASE `db_054849_down`;
UNINSTALL EXTENSION vsql_schematron;
