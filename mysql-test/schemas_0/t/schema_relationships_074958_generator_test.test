INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 074958_generator_test
--echo #
CREATE DATABASE `db_074958_generator_test`;
USE `db_074958_generator_test`;

CREATE TABLE `self_reference` (
  `id` INT,
  `name` VARCHAR(64),
  `parent` INT,
  `table_a_pk_col_one` INT,
  `table_a_pk_col_two` VARCHAR(64),
  `table_a_pk_col_three` DATETIME,
  PRIMARY KEY (`id`, `table_a_pk_col_one`, `table_a_pk_col_two`, `table_a_pk_col_three`)
) CHARACTER SET latin1;

CREATE TABLE `table1` (
  `id` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `table_a` (
  `pk_col_one` INT,
  `pk_col_two` VARCHAR(64),
  `pk_col_three` DATETIME,
  `another_col` VARCHAR(64),
  `and_another` VARCHAR(64),
  `table_b_id` DATETIME,
  `table_c_id` INT,
  PRIMARY KEY (`pk_col_one`, `pk_col_two`, `pk_col_three`)
) CHARACTER SET latin1;

CREATE TABLE `table_b` (
  `id` DATETIME,
  `you` VARCHAR(64),
  `he` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `table_c` (
  `id` INT,
  `title` VARCHAR(64),
  `table1_id` INT,
  PRIMARY KEY (`id`, `table1_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_074958_generator_test') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_074958_generator_test') AS relationships;
DROP DATABASE `db_074958_generator_test`;
UNINSTALL EXTENSION vsql_schematron;
