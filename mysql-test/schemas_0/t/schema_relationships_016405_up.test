INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 016405_up
--echo #
CREATE DATABASE `db_016405_up`;
USE `db_016405_up`;
CREATE TABLE `self_referential_fk` (
  `id` INT NOT NULL,
  `parent_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `fk_doesnt_reference_pk` (
  `id` INT NOT NULL,
  `random` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `composite_fk` (
  `id` INT NOT NULL,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_016405_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_016405_up') AS relationships;
DROP DATABASE `db_016405_up`;
UNINSTALL EXTENSION vsql_schematron;
