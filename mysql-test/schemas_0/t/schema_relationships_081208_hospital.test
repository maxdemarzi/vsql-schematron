INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081208_hospital
--echo #
CREATE DATABASE `db_081208_hospital`;
USE `db_081208_hospital`;
CREATE TABLE `Up` (
  `Uname` VARCHAR(50) NOT NULL,
  `Password` CHAR(50),
  PRIMARY KEY (`Uname`)
) CHARACTER SET latin1;
CREATE TABLE `Ato` (
  `Aname` VARCHAR(50) NOT NULL,
  `Atele` CHAR(50),
  PRIMARY KEY (`Aname`)
) CHARACTER SET latin1;
CREATE TABLE `Doctor` (
  `Dno` VARCHAR(50) NOT NULL,
  `Dname` CHAR(50),
  `Dsex` CHAR(50),
  `Dzc` CHAR(50),
  `lz_Aname` CHAR(50),
  `Dstate` INT,
  PRIMARY KEY (`Dno`)
) CHARACTER SET latin1;
CREATE TABLE `Bed` (
  `Cno` VARCHAR(50) NOT NULL,
  `Cuse` INT,
  `bc_Aname` CHAR(50),
  PRIMARY KEY (`Cno`)
) CHARACTER SET latin1;
CREATE TABLE `Patient` (
  `Pno` VARCHAR(50) NOT NULL,
  `Pname` CHAR(50),
  `Psex` CHAR(50),
  `Pbirth` DATE,
  `Padd` CHAR(50),
  `Ptele` CHAR(50),
  `Dno` CHAR(50),
  `Cno` CHAR(50),
  `Idate` DATE,
  `Pmark` CHAR(50),
  `Odate` DATETIME,
  PRIMARY KEY (`Pno`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081208_hospital') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081208_hospital') AS relationships;
DROP DATABASE `db_081208_hospital`;
UNINSTALL EXTENSION vsql_schematron;
