INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 002136_schema-pgsql
--echo #
CREATE DATABASE `db_002136_schema_pgsql`;
USE `db_002136_schema_pgsql`;

CREATE TABLE `source_message` (
  `id` INT,
  `category` VARCHAR(64),
  `message` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `message` (
  `id` INT,
  `language` VARCHAR(64),
  `translation` VARCHAR(64),
  PRIMARY KEY (`id`, `language`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_002136_schema_pgsql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_002136_schema_pgsql') AS relationships;
DROP DATABASE `db_002136_schema_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
