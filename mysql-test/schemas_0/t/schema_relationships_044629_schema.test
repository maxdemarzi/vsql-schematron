INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 044629_schema
--echo #
CREATE DATABASE `db_044629_schema`;
USE `db_044629_schema`;

CREATE TABLE `authors` (
  `id` INT,
  `full_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `id` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `id` INT,
  `title` VARCHAR(64),
  `publication_year` INT,
  `author_id` INT,
  `genre_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book_comments` (
  `id` INT,
  `author` VARCHAR(64),
  `text` VARCHAR(64),
  `book_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `user_name` VARCHAR(64),
  `password` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_044629_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_044629_schema') AS relationships;
DROP DATABASE `db_044629_schema`;
UNINSTALL EXTENSION vsql_schematron;
