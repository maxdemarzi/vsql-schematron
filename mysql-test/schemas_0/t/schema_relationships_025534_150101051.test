INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 025534_150101051
--echo #
CREATE DATABASE `db_025534_150101051`;
USE `db_025534_150101051`;

CREATE TABLE `Department` (
  `department_id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;

CREATE TABLE `Slot` (
  `letter` VARCHAR(64),
  `day` VARCHAR(64),
  `start_time` DATETIME,
  `end_time` DATETIME,
  PRIMARY KEY (`letter`, `day`)
) CHARACTER SET latin1;

CREATE TABLE `Room` (
  `room_no` VARCHAR(64),
  `location` VARCHAR(64),
  PRIMARY KEY (`room_no`)
) CHARACTER SET latin1;

CREATE TABLE `ScheduledIn` (
  `course_id` VARCHAR(64),
  `division` VARCHAR(64),
  `department_id` VARCHAR(64),
  `letter` VARCHAR(64),
  `day` VARCHAR(64),
  `room_no` VARCHAR(64),
  PRIMARY KEY (`course_id`, `division`, `department_id`, `letter`, `day`, `room_no`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_025534_150101051') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_025534_150101051') AS relationships;
DROP DATABASE `db_025534_150101051`;
UNINSTALL EXTENSION vsql_schematron;
