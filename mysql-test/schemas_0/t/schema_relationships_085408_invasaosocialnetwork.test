INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 085408_invasaosocialnetwork
--echo #
CREATE DATABASE `db_085408_invasaosocialnetwork`;
USE `db_085408_invasaosocialnetwork`;

CREATE TABLE `coment_invs` (
  `com_id` INT,
  `post_id` INT,
  `usuario_id` INT,
  `comentario` VARCHAR(64),
  `autor_coment` VARCHAR(64),
  `data_coment` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `pedidos_amizade` (
  `requestId` INT,
  `req_from_id` INT,
  `req_to_id` INT,
  `status_req` VARCHAR(64),
  `req_noti_st` VARCHAR(64),
  `req_date` DATETIME,
  PRIMARY KEY (`requestId`)
) CHARACTER SET latin1;

CREATE TABLE `timelinef` (
  `id` INT,
  `id_usuario` INT,
  `nome` VARCHAR(64),
  `sobrenome` VARCHAR(64),
  `titulo` VARCHAR(64),
  `descricao` VARCHAR(64),
  `timepb` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `usr_invs` (
  `id` INT,
  `nome` VARCHAR(64),
  `sexo` VARCHAR(64),
  `email` VARCHAR(64),
  `senha` VARCHAR(64),
  `log_usr` INT,
  `create_date` DATETIME,
  `sobrenome` VARCHAR(64),
  `data_nasc` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_085408_invasaosocialnetwork') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_085408_invasaosocialnetwork') AS relationships;
DROP DATABASE `db_085408_invasaosocialnetwork`;
UNINSTALL EXTENSION vsql_schematron;
