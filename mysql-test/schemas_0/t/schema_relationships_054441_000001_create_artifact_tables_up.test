INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 054441_000001_create_artifact_tables.up
--echo #
CREATE DATABASE `db_054441_000001_create_artifact_tables_up`;
USE `db_054441_000001_create_artifact_tables_up`;

CREATE TABLE `artifacts` (
  `id` VARCHAR(64),
  `artifact_name` VARCHAR(64),
  `create_time` DATETIME,
  `commit_hash` VARCHAR(64),
  `version_str` VARCHAR(64),
  `available_artifacts` VARCHAR(64),
  PRIMARY KEY (`id`, `artifact_name`, `version_str`)
) CHARACTER SET latin1;

CREATE TABLE `artifact_changelogs` (
  `artifacts_id` VARCHAR(64),
  `changelog` VARCHAR(64),
  PRIMARY KEY (`artifacts_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_054441_000001_create_artifact_tables_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_054441_000001_create_artifact_tables_up') AS relationships;
DROP DATABASE `db_054441_000001_create_artifact_tables_up`;
UNINSTALL EXTENSION vsql_schematron;
