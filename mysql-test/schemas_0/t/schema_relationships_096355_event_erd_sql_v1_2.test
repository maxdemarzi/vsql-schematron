INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 096355_event_erd_sql_v1.2
--echo #
CREATE DATABASE `db_096355_event_erd_sql_v1_2`;
USE `db_096355_event_erd_sql_v1_2`;
CREATE TABLE `cust_app_res` (
  `APP_ID` INT NOT NULL,
  `EVT_ID` INT,
  `CUST_ID` INT,
  `PRIZE` INT,
  PRIMARY KEY (`APP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `evt_evt` (
  `EVT_ID` INT NOT NULL,
  `EVT_NM` VARCHAR(50),
  `EVT_DT` VARCHAR(50),
  `ST_DATE` DATE,
  `END_DATE` DATE,
  `EVT_ST` INT,
  `EVT_FILE_URL` VARCHAR(50),
  `EVT_CTG` VARCHAR(50),
  `EVT_TRG` VARCHAR(50),
  `EVT_PHONE` VARCHAR(50),
  `EVT_TRG_DATE` DATE,
  PRIMARY KEY (`EVT_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_096355_event_erd_sql_v1_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_096355_event_erd_sql_v1_2') AS relationships;
DROP DATABASE `db_096355_event_erd_sql_v1_2`;
UNINSTALL EXTENSION vsql_schematron;
