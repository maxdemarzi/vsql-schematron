INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 086099_DdlEnderecoUf
--echo #
CREATE DATABASE `db_086099_DdlEnderecoUf`;
USE `db_086099_DdlEnderecoUf`;
CREATE TABLE `TB_UF` (
  `SIGLA` VARCHAR(50) NOT NULL,
  `NOME` VARCHAR(50),
  PRIMARY KEY (`SIGLA`)
) CHARACTER SET latin1;
CREATE TABLE `TB_ENDERECO` (
  `COD` INT NOT NULL,
  `CEP` INT,
  `SIGLA_UF` VARCHAR(50),
  `ENDERECO` VARCHAR(50),
  `NUMERO` INT,
  `BAIRRO` VARCHAR(50),
  PRIMARY KEY (`COD`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_086099_DdlEnderecoUf') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_086099_DdlEnderecoUf') AS relationships;
DROP DATABASE `db_086099_DdlEnderecoUf`;
UNINSTALL EXTENSION vsql_schematron;
