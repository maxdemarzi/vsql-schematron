INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 003138_migrate
--echo #
CREATE DATABASE `db_003138_migrate`;
USE `db_003138_migrate`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `bio` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `post` (
  `id` INT,
  `username` VARCHAR(64),
  `text` VARCHAR(64),
  `timestamp` DATETIME,
  `comment_on` INT,
  `attachment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `hashtag` (
  `hashtag` VARCHAR(64),
  `occurence` INT,
  `last_updated` DATETIME,
  PRIMARY KEY (`hashtag`)
) CHARACTER SET latin1;

CREATE TABLE `post_have_hashtags` (
  `id_post` INT,
  `hashtag` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_003138_migrate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_003138_migrate') AS relationships;
DROP DATABASE `db_003138_migrate`;
UNINSTALL EXTENSION vsql_schematron;
