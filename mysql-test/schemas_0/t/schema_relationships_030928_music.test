INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 030928_music
--echo #
CREATE DATABASE `db_030928_music`;
USE `db_030928_music`;
CREATE TABLE `Artist` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `BirthYear` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Song` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Album` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `WorkedOn` (
  `Artist` INT,
  `Song` INT
) CHARACTER SET latin1;
CREATE TABLE `Album` (
  `Id` INT NOT NULL,
  `Name` VARCHAR(50),
  `Year` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Publisher` (
  `Id` INT NOT NULL,
  `Uuid` INT,
  `Year` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_030928_music') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_030928_music') AS relationships;
DROP DATABASE `db_030928_music`;
UNINSTALL EXTENSION vsql_schematron;
