INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 079208_leavideo.ddl
--echo #
CREATE DATABASE `db_079208_leavideo_ddl`;
USE `db_079208_leavideo_ddl`;

CREATE TABLE `Playlist` (
  `playlistID` INT,
  PRIMARY KEY (`playlistID`)
) CHARACTER SET latin1;

CREATE TABLE `PlaylistItem` (
  `playlistItemID` INT,
  `playlistID` INT,
  `galerieID` INT,
  `videoID` INT,
  PRIMARY KEY (`playlistItemID`)
) CHARACTER SET latin1;

CREATE TABLE `Galerie` (
  `galerieID` INT,
  PRIMARY KEY (`galerieID`)
) CHARACTER SET latin1;

CREATE TABLE `Picture` (
  `pictureID` INT,
  `width` INT,
  `height` INT,
  `format` VARCHAR(64),
  PRIMARY KEY (`pictureID`)
) CHARACTER SET latin1;

CREATE TABLE `Galerie_Picture` (
  `galerieID` INT,
  `pictureID` INT,
  PRIMARY KEY (`galerieID`, `pictureID`)
) CHARACTER SET latin1;

CREATE TABLE `Video` (
  `videoID` INT,
  `lengthSeconds` INT,
  `thumbnailPictureID` INT,
  PRIMARY KEY (`videoID`)
) CHARACTER SET latin1;

CREATE TABLE `Movie` (
  `videoID` INT,
  `imdbID` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `tagID` INT,
  `parentTagID` INT,
  `defaultTag` INT,
  PRIMARY KEY (`tagID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Video` (
  `tagID` INT,
  `videoID` INT,
  PRIMARY KEY (`tagID`, `videoID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Picture` (
  `tagID` INT,
  `pictureID` INT,
  PRIMARY KEY (`tagID`, `pictureID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Galerie` (
  `tagID` INT,
  `galerieID` INT,
  PRIMARY KEY (`tagID`, `galerieID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Playlist` (
  `tagID` INT,
  `playlistID` INT,
  PRIMARY KEY (`tagID`, `playlistID`)
) CHARACTER SET latin1;

CREATE TABLE `Media` (
  `mediaID` INT,
  `VideovideoID` INT,
  `hasAudio` INT,
  `audioBitrate` INT,
  `audioEncoding` VARCHAR(64),
  `hasVideo` INT,
  `videoBitrate` INT,
  `videoEncoding` VARCHAR(64),
  PRIMARY KEY (`mediaID`)
) CHARACTER SET latin1;

CREATE TABLE `Snippet` (
  `startFrame` INT,
  `endFrame` INT,
  `sourceVideoID` INT,
  `videoID` INT
) CHARACTER SET latin1;

CREATE TABLE `Celebrity` (
  `celebrityID` INT,
  `avatarPictureID` INT,
  PRIMARY KEY (`celebrityID`)
) CHARACTER SET latin1;

CREATE TABLE `Name` (
  `nameID` INT,
  `language` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Regisseur` (
  `celebrityID` INT,
  `videoID` INT,
  PRIMARY KEY (`celebrityID`, `videoID`)
) CHARACTER SET latin1;

CREATE TABLE `Actor` (
  `videoID` INT,
  `celebrityID` INT,
  PRIMARY KEY (`videoID`, `celebrityID`)
) CHARACTER SET latin1;

CREATE TABLE `Playlist_Name` (
  `playlistID` INT,
  `nameID` INT,
  PRIMARY KEY (`playlistID`, `nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Galerie_Name` (
  `galerieID` INT,
  `nameID` INT,
  PRIMARY KEY (`galerieID`, `nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Picture_Name` (
  `pictureID` INT,
  `nameID` INT,
  PRIMARY KEY (`pictureID`, `nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Name` (
  `tagID` INT,
  `nameID` INT,
  PRIMARY KEY (`tagID`, `nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Video_Name` (
  `videoID` INT,
  `nameID` INT,
  PRIMARY KEY (`videoID`, `nameID`)
) CHARACTER SET latin1;

CREATE TABLE `Name_Celebrity` (
  `nameID` INT,
  `celebrityID` INT,
  PRIMARY KEY (`nameID`, `celebrityID`)
) CHARACTER SET latin1;

CREATE TABLE `Celebrity_Picture` (
  `celebrityID` INT,
  `pictureID` INT,
  PRIMARY KEY (`celebrityID`, `pictureID`)
) CHARACTER SET latin1;

CREATE TABLE `Celebrity_Tag` (
  `celebrityID` INT,
  `tagID` INT,
  PRIMARY KEY (`celebrityID`, `tagID`)
) CHARACTER SET latin1;

CREATE TABLE `Artist` (
  `videoID` INT,
  `celebrityID` INT,
  PRIMARY KEY (`videoID`, `celebrityID`)
) CHARACTER SET latin1;

CREATE TABLE `Variation` (
  `variationID` INT,
  PRIMARY KEY (`variationID`)
) CHARACTER SET latin1;

CREATE TABLE `Video_Variation` (
  `videoID` INT,
  `variationID` INT,
  `isDefaultVideo` INT,
  `isDefaultAudio` INT,
  PRIMARY KEY (`videoID`, `variationID`)
) CHARACTER SET latin1;

CREATE TABLE `Variation_Name` (
  `nameID` INT,
  `variationID` INT,
  PRIMARY KEY (`nameID`, `variationID`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `userID` INT,
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `Group` (
  `groupID` INT,
  `parentGroupID` INT,
  PRIMARY KEY (`groupID`)
) CHARACTER SET latin1;

CREATE TABLE `User_Group` (
  `userID` INT,
  `groupID` INT,
  PRIMARY KEY (`userID`, `groupID`)
) CHARACTER SET latin1;

CREATE TABLE `Tag_Group` (
  `tagID` INT,
  `groupID` INT,
  PRIMARY KEY (`tagID`, `groupID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_079208_leavideo_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_079208_leavideo_ddl') AS relationships;
DROP DATABASE `db_079208_leavideo_ddl`;
UNINSTALL EXTENSION vsql_schematron;
