INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 014501_script%20banco
--echo #
CREATE DATABASE `db_014501_script_20banco`;
USE `db_014501_script_20banco`;
CREATE TABLE `BANCO` (
  `CNPJ` BIGINT NOT NULL,
  PRIMARY KEY (`CNPJ`)
) CHARACTER SET latin1;
CREATE TABLE `AGENCIA` (
  `nAgencia` INT NOT NULL,
  `nomeAgencia` VARCHAR(50),
  `endereco` VARCHAR(50),
  `UF` CHAR(50),
  `cidade` VARCHAR(50),
  `telefone` BIGINT,
  `CNPJ` BIGINT,
  PRIMARY KEY (`nAgencia`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENTE` (
  `codCliente` INT NOT NULL,
  `nome` VARCHAR(50),
  `endereco` VARCHAR(50),
  `cidade` VARCHAR(50),
  `UF` CHAR(50),
  `telefone` BIGINT,
  `CPF` BIGINT,
  `RG` BIGINT,
  PRIMARY KEY (`codCliente`)
) CHARACTER SET latin1;
CREATE TABLE `CONTA` (
  `nConta` INT NOT NULL,
  `tipoConta` VARCHAR(50),
  `saldoConta` BIGINT,
  `nAgencia` INT,
  `codCliente` INT,
  PRIMARY KEY (`nConta`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_014501_script_20banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_014501_script_20banco') AS relationships;
DROP DATABASE `db_014501_script_20banco`;
UNINSTALL EXTENSION vsql_schematron;
