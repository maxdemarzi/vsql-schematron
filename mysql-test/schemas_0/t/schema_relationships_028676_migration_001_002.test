INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 028676_migration-001-002
--echo #
CREATE DATABASE `db_028676_migration_001_002`;
USE `db_028676_migration_001_002`;

CREATE TABLE `FEATURE_DEFS` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `DS_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `FEATURE_VALUES` (
  `ID` INT,
  `Z_in_M` DECIMAL(10,2),
  `T_in_SEC` DECIMAL(10,2),
  `VALUES` VARCHAR(64),
  `FD_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_028676_migration_001_002') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_028676_migration_001_002') AS relationships;
DROP DATABASE `db_028676_migration_001_002`;
UNINSTALL EXTENSION vsql_schematron;
