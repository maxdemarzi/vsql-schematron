  `site_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `django_comments` (
  `id` INT,
  `object_pk` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_email` VARCHAR(64),
  `user_url` VARCHAR(64),
  `comment` VARCHAR(64),
  `submit_date` DATETIME,
  `ip_address` VARCHAR(64),
  `is_public` INT,
  `is_removed` INT,
