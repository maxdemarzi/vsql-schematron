CREATE DATABASE `db_088153_mep_schema_0_19`;
USE `db_088153_mep_schema_0_19`;

CREATE TABLE `accounts_borrow` (
  `event_ptr_id` INT,
  `item_status` VARCHAR(64),
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_purchase` (
  `event_ptr_id` INT,
  `price` DECIMAL(10,2),
  `currency` VARCHAR(64),
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_reimbursement` (
  `event_ptr_id` INT,
  `refund` DECIMAL(10,2),
  `currency` VARCHAR(64),
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts_subscription` (
  `event_ptr_id` INT,
  `duration` INT,
  `volumes` DECIMAL(10,2),
  `price_paid` DECIMAL(10,2),
  `deposit` DECIMAL(10,2),
  `currency` VARCHAR(64),
  `subtype` VARCHAR(64),
  `category_id` INT,
  PRIMARY KEY (`event_ptr_id`)
) CHARACTER SET latin1;

CREATE TABLE `books_edition` (
  `id` INT,
  `notes` VARCHAR(64),
  `title` VARCHAR(64),
  `volume` INT,
