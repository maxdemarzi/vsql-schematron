INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 018862_create
--echo #
CREATE DATABASE `db_018862_create`;
USE `db_018862_create`;

CREATE TABLE `nodes` (
  `id` INT,
  `color` INT,
  `description` VARCHAR(64),
  `weight` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `edges` (
  `node1` INT,
  `node2` INT,
  `weight` DECIMAL(10,2),
  `direction` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`node1`, `node2`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_018862_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_018862_create') AS relationships;
DROP DATABASE `db_018862_create`;
UNINSTALL EXTENSION vsql_schematron;
