INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 022210_schema
--echo #
CREATE DATABASE `db_022210_schema`;
USE `db_022210_schema`;

CREATE TABLE `role` (
  `id` INT,
  `rolename` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `registration_info` (
  `id` INT,
  `registration_date` DATETIME,
  `hash` VARCHAR(64),
  `activation_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `is_activated` BOOL,
  `is_enabled` BOOL,
  `role_id` INT,
  `registration_info_id` INT,
  `user_info_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_022210_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_022210_schema') AS relationships;
DROP DATABASE `db_022210_schema`;
UNINSTALL EXTENSION vsql_schematron;
