INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 004269_schema
--echo #
CREATE DATABASE `db_004269_schema`;
USE `db_004269_schema`;

CREATE TABLE `public.accounts` (
  `id` VARCHAR(64),
  `account_id` VARCHAR(64),
  `birth_date` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.posts` (
  `id` VARCHAR(64),
  `author_id` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.comments` (
  `id` VARCHAR(64),
  `post_id` VARCHAR(64),
  `author_id` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.relationships` (
  `id` VARCHAR(64),
  `follower_id` VARCHAR(64),
  `followee_id` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_004269_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_004269_schema') AS relationships;
DROP DATABASE `db_004269_schema`;
UNINSTALL EXTENSION vsql_schematron;
