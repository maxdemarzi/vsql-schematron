INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 029948_databaseInit_homework
--echo #
CREATE DATABASE `db_029948_databaseInit_homework`;
USE `db_029948_databaseInit_homework`;
CREATE TABLE `FACULTY` (
  `NUM` INT NOT NULL,
  PRIMARY KEY (`NUM`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
  `ID` INT NOT NULL,
  `FIRST_NAME` VARCHAR(50),
  `LAST_NAME` VARCHAR(50),
  `FAC_NUM` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE` (
  `ID` INT NOT NULL,
  `NAME` VARCHAR(50),
  `DESCRIPTION` VARCHAR(50),
  `CREDITS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE_STUDENT` (
  `ID` INT NOT NULL,
  `COURSE_ID` INT,
  `STUDENT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_029948_databaseInit_homework') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_029948_databaseInit_homework') AS relationships;
DROP DATABASE `db_029948_databaseInit_homework`;
UNINSTALL EXTENSION vsql_schematron;
