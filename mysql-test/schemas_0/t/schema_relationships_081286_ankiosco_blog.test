INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 081286_ankiosco_blog
--echo #
CREATE DATABASE `db_081286_ankiosco_blog`;
USE `db_081286_ankiosco_blog`;

CREATE TABLE `comments` (
  `Id` INT,
  `commentText` VARCHAR(255),
  `dateTime` DATETIME,
  `deleted` VARCHAR(255),
  `modifiedDateTime` DATETIME,
  `parent_id` INT,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `comment_ratings` (
  `Id` INT,
  `value` INT,
  `user_id` INT,
  `comment_id` INT
) CHARACTER SET latin1;

CREATE TABLE `persistent_logins` (
  `username` VARCHAR(255),
  `series` VARCHAR(255),
  `token` VARCHAR(255),
  `last_used` DATETIME,
  PRIMARY KEY (`series`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `Id` INT,
  `dateTime` DATETIME,
  `fullPostText` VARCHAR(255),
  `hidden` VARCHAR(255),
  `shortTextPart` VARCHAR(255),
  `title` VARCHAR(255),
  `category` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_tags` (
  `post_id` INT,
  `tag_id` INT
) CHARACTER SET latin1;

CREATE TABLE `post_ratings` (
  `Id` INT,
  `value` INT,
  `user_id` INT,
  `post_id` INT
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `Id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `Id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `Id` INT,
  `aboutText` VARCHAR(255),
  `bigAvatarLink` VARCHAR(255),
  `email` VARCHAR(255),
  `enabled` VARCHAR(255),
  `password` VARCHAR(255),
  `registrationDate` DATETIME,
  `smallAvatarLink` VARCHAR(255),
  `username` VARCHAR(255),
  `websiteLink` VARCHAR(255),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `users_roles` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_081286_ankiosco_blog') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_081286_ankiosco_blog') AS relationships;
DROP DATABASE `db_081286_ankiosco_blog`;
UNINSTALL EXTENSION vsql_schematron;
