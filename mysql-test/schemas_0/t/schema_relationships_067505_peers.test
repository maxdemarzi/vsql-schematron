INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 067505_peers
--echo #
CREATE DATABASE `db_067505_peers`;
USE `db_067505_peers`;

CREATE TABLE `peers` (
  `id` INT,
  `name` VARCHAR(64),
  `port` INT,
  `lastSentVersion` INT,
  `lastPokeSucceededAt` INT,
  `active` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `peer_pubkeys` (
  `id` INT,
  `peername` VARCHAR(64),
  `alg` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_067505_peers') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_067505_peers') AS relationships;
DROP DATABASE `db_067505_peers`;
UNINSTALL EXTENSION vsql_schematron;
