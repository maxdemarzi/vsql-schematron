INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 071713_schema
#
CREATE DATABASE `db_071713_schema`;
USE `db_071713_schema`;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`department_id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`role_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_071713_schema') AS relationships;
relationships
Database: db_071713_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> roles.id
[Implied]  roles.department_id -> department.id

DROP DATABASE `db_071713_schema`;
UNINSTALL EXTENSION vsql_schematron;
