INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 053275_koin
#
CREATE DATABASE `db_053275_koin`;
USE `db_053275_koin`;
CREATE TABLE `tbl_data` (
`id` INT,
`id_coin` INT,
`high` DECIMAL(10,2),
`low` DECIMAL(10,2),
`vol_coin` DECIMAL(10,2),
`vol_pair` DECIMAL(10,2),
`last` DECIMAL(10,2),
`buy` DECIMAL(10,2),
`sell` DECIMAL(10,2),
`server_time` DATETIME,
`nilai_range` DECIMAL(10,2),
`top_range` DECIMAL(10,2),
`lower_range` DECIMAL(10,2),
`percent_range` DECIMAL(10,2),
`percent_top_range` DECIMAL(10,2),
`percent_lower_range` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `tbl_market` (
`id` INT,
`nama_market` VARCHAR(64),
`pair` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_053275_koin') AS relationships;
