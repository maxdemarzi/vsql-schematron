CREATE DATABASE `db_012767_10schema`;
USE `db_012767_10schema`;
CREATE TABLE `breach` (
`id` BIGINT NOT NULL,
`contract_uuid` VARCHAR(50),
`datetime` DATETIME,
`kpi_name` VARCHAR(50),
`value` VARCHAR(50),
`violation_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `business_value_list` (
`id` BIGINT NOT NULL,
`importance` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `enforcement_job` (
`id` BIGINT NOT NULL,
`enabled` VARCHAR(50),
`first_executed` DATETIME,
`last_executed` DATETIME,
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guarantee_term` (
`id` BIGINT NOT NULL,
`kpi_name` VARCHAR(50),
`lastSampledDate` DATETIME,
`name` VARCHAR(50),
`samplingPeriodFactor` INT,
`service_level` VARCHAR(50),
`service_name` VARCHAR(50),
`service_scope` VARCHAR(50),
`status` INT,
`business_value_id` BIGINT,
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penalty` (
`id` BIGINT NOT NULL,
`agreement_id` VARCHAR(50),
`datetime` DATETIME,
`kpi_name` VARCHAR(50),
`uuid` VARCHAR(50),
`definition_id` BIGINT,
`violation_id` BIGINT,
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penaltydefinition` (
`id` BIGINT NOT NULL,
`action` VARCHAR(50),
`number` INT,
`kind` VARCHAR(50),
`time_interval` DATETIME,
`validity` VARCHAR(50),
`value_expression` VARCHAR(50),
`value_unit` VARCHAR(50),
`business_value_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `policy` (
`id` BIGINT NOT NULL,
`number` INT,
`time_interval` DATETIME,
`variable` VARCHAR(50),
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `service_properties` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`service_name` VARCHAR(50),
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `variable` (
`id` BIGINT NOT NULL,
`location` VARCHAR(50),
`metric` VARCHAR(50),
`name` VARCHAR(50),
`service_properties_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `violation` (
`id` BIGINT NOT NULL,
`actual_value` VARCHAR(50),
`contract_uuid` VARCHAR(50),
`datetime` DATETIME,
`expected_value` VARCHAR(50),
`kpi_name` VARCHAR(50),
`service_name` VARCHAR(50),
`service_scope` VARCHAR(50),
`uuid` VARCHAR(50),
`policy_id` BIGINT,
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
