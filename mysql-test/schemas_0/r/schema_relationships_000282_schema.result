INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 000282_schema
#
CREATE DATABASE `db_000282_schema`;
USE `db_000282_schema`;
CREATE TABLE `tasks` (
`id` VARCHAR(64),
`data` VARCHAR(64),
`queue` VARCHAR(64),
`retry_queue` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `executions` (
`task_id` VARCHAR(64),
`execution_id` INT,
`queued_at` INT,
`started_at` INT,
`finished_at` INT,
`failed_count` INT,
`reaped_count` INT,
`success` VARCHAR(64),
`error_id` VARCHAR(64),
PRIMARY KEY (`task_id`, `execution_id`)
) CHARACTER SET latin1;
CREATE TABLE `task_tags` (
`id` VARCHAR(64),
`task_id` VARCHAR(64),
PRIMARY KEY (`id`, `task_id`)
) CHARACTER SET latin1;
CREATE TABLE `execution_errors` (
`id` VARCHAR(64),
`error` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_000282_schema') AS relationships;
relationships
Database: db_000282_schema

Table Connections:
------------------
[Implied]  executions.error_id -> execution_errors.id
[Implied]  executions.task_id -> tasks.id
[Implied]  task_tags.task_id -> tasks.id

DROP DATABASE `db_000282_schema`;
UNINSTALL EXTENSION vsql_schematron;
