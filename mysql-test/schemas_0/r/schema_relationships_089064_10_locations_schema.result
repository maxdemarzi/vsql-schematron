INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 089064_10-locations.schema
#
CREATE DATABASE `db_089064_10_locations_schema`;
USE `db_089064_10_locations_schema`;
CREATE TABLE `locations` (
`id` VARCHAR(64),
`address1` VARCHAR(64),
`address2` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
`zip` VARCHAR(64),
`lat` DECIMAL(10,2),
`lng` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`id` VARCHAR(64),
`entity_id` VARCHAR(64),
`label` VARCHAR(64),
`idx` INT,
PRIMARY KEY (`id`, `entity_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_089064_10_locations_schema') AS relationships;
relationships
