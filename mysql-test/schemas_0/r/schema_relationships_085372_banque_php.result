CREATE DATABASE `db_085372_banque_php`;
USE `db_085372_banque_php`;
CREATE TABLE `Customer` (
`id` VARCHAR(50) NOT NULL,
`lastname` VARCHAR(50),
`firstname` VARCHAR(50),
`phone` INT,
`email` VARCHAR(50),
`sex` CHAR(50),
`password` VARCHAR(50),
`birth_date` DATE,
`city` VARCHAR(50),
`city_code` CHAR(50),
`street_number` INT,
`street` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
`id` VARCHAR(50) NOT NULL,
`account_number` VARCHAR(50),
`account_type` VARCHAR(50),
`amount` DECIMAL(10,2),
`operation_date` DATE,
`customer_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Operation` (
`id` VARCHAR(50) NOT NULL,
`operation_type` VARCHAR(50),
`amount` DECIMAL(10,2),
`label` VARCHAR(50),
`executed` TIMESTAMP NULL,
`account_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_085372_banque_php') AS relationships;
