CREATE DATABASE `db_067304_table_structure`;
USE `db_067304_table_structure`;
CREATE TABLE `hierarchy` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hierarchy_level_type` (
`id` VARCHAR(64),
`level` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hierarchy_entry` (
`id` VARCHAR(64),
`code` VARCHAR(64),
`display_order` INT,
`name` VARCHAR(64),
`hierarchy_id` VARCHAR(64),
`hierarchy_level_type_id` VARCHAR(64),
`parent` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_067304_table_structure') AS relationships;
