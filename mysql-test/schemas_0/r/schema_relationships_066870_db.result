CREATE DATABASE `db_066870_db`;
USE `db_066870_db`;
CREATE TABLE `test.city` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test.student` (
`id` INT NOT NULL,
`number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test.course` (
`id` INT NOT NULL,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `test.student_has_course` (
`student_id` INT NOT NULL,
`course_id` INT NOT NULL,
PRIMARY KEY (`student_id`, `course_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_066870_db') AS relationships;
