INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 022125_schema
#
CREATE DATABASE `db_022125_schema`;
USE `db_022125_schema`;
CREATE TABLE `userTypes` (
`id` INT NOT NULL,
`type_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`email_verified` INT,
`password` VARCHAR(50),
`district` VARCHAR(50),
`nic` VARCHAR(50),
`phone_no` VARCHAR(50),
`phone_no_verified` INT,
`type_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
`id` INT NOT NULL,
`subject_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `papers` (
`id` INT NOT NULL,
`paper_name` VARCHAR(50),
`year` INT,
`school` VARCHAR(50),
`subject_id` INT,
`district` VARCHAR(50),
`total_time` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
`id` INT NOT NULL,
`question_id` INT,
`is_image` BOOLEAN,
`answer_no` INT,
`answers` VARCHAR(50),
`image_url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_022125_schema') AS relationships;
relationships
Database: db_022125_schema

Table Connections:
------------------
[Implied]  papers.subject_id -> subjects.id
[Implied]  users.type_id -> userTypes.id

DROP DATABASE `db_022125_schema`;
UNINSTALL EXTENSION vsql_schematron;
