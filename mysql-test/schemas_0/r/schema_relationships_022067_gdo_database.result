INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 022067_gdo_database
#
CREATE DATABASE `db_022067_gdo_database`;
USE `db_022067_gdo_database`;
CREATE TABLE `applicant` (
`ApplicantId` INT,
`RecordId` VARCHAR(64),
`TimeSubmitted` DATETIME,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`Address` VARCHAR(64),
`City` VARCHAR(64),
`State` VARCHAR(64),
`ZipCode` INT,
`DateOfBirth` DATETIME,
`Ethnicity` VARCHAR(64),
`Allergies` VARCHAR(64),
`Medications` VARCHAR(64),
`ParentsWithBachelors` VARCHAR(64),
`MilitaryRelatives` INT,
`RisingGradeLevel` VARCHAR(64),
`AttendingSchool` VARCHAR(64),
`CollegeOfInterest` VARCHAR(64),
`ShirtSize` VARCHAR(64),
`WaiverStatus` VARCHAR(64),
`ApplicationStatus` VARCHAR(64),
PRIMARY KEY (`ApplicantId`)
) CHARACTER SET latin1;
CREATE TABLE `applicant_stem_interests` (
`ApplicantId` INT,
`DisciplineId` INT,
PRIMARY KEY (`ApplicantId`, `DisciplineId`)
) CHARACTER SET latin1;
CREATE TABLE `emergency_contact` (
`EmergencyId` INT,
`ApplicantId` INT,
`Name` VARCHAR(64),
`Relationship` VARCHAR(64),
`Address` VARCHAR(64),
`City` VARCHAR(64),
`State` VARCHAR(64),
`ZipCode` INT,
`MobilePhone` INT,
`HomePhone` INT,
`WorkPhone` INT,
`InitialSignature` VARCHAR(64),
PRIMARY KEY (`EmergencyId`)
) CHARACTER SET latin1;
CREATE TABLE `parent` (
`ParentId` INT,
`ApplicantId` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`Email` VARCHAR(64),
`Address` VARCHAR(64),
`City` VARCHAR(64),
`State` VARCHAR(64),
`ZipCode` INT,
`MobilePhone` INT,
`WorkPhone` INT,
`HomePhone` INT,
`OtherParentFName` VARCHAR(64),
`OtherParentLName` VARCHAR(64),
PRIMARY KEY (`ParentId`)
) CHARACTER SET latin1;
CREATE TABLE `waivers` (
`ApplicantId` INT,
`WaiverType` INT,
`WaiverStatus` VARCHAR(64),
`WaiverLocation` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `max_applicants` (
`max_applicants` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_022067_gdo_database') AS relationships;
