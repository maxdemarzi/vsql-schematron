`start_day` DATETIME,
`end_day` DATETIME,
`start_time` DATETIME,
`end_time` DATETIME,
`is_full_day` VARCHAR(64),
`created_by` INT,
`time_created` DATETIME,
`program_id` INT,
PRIMARY KEY (`id_event_exception`)
) CHARACTER SET latin1;
