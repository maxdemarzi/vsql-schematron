CREATE DATABASE `db_072414_yii2advanced_2019_08_14`;
USE `db_072414_yii2advanced_2019_08_14`;
CREATE TABLE `booking` (
`id` INT,
`user_id` INT,
`film_id` INT,
`cinema_hall_id` INT,
`cinema_hall_row_id` INT,
`cinema_hall_seat_id` INT,
`price` DECIMAL(10,2),
`status` INT,
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cinema_hall` (
`id` INT,
`title` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cinema_hall_rows` (
`id` INT,
`number` INT,
`cinema_hall_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cinema_hall_seats` (
`id` INT,
`number` INT,
`cinema_hall_id` INT,
`cinema_hall_row_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `films` (
`id` INT,
`cinema_hall_id` INT,
`title` VARCHAR(64),
`image` VARCHAR(64),
`price` DECIMAL(10,2),
`start_at` INT,
`status` INT,
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
