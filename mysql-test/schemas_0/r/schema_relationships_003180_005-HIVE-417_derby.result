CREATE TABLE `INDEX_PARAMS` (
`INDEX_ID` BIGINT NOT NULL,
`PARAM_KEY` VARCHAR(50) NOT NULL,
`PARAM_VALUE` VARCHAR(50),
PRIMARY KEY (`INDEX_ID`, `PARAM_KEY`)
) CHARACTER SET latin1;
