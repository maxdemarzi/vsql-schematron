INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 083881_schema
#
CREATE DATABASE `db_083881_schema`;
USE `db_083881_schema`;
CREATE TABLE `schema_migrations` (
`version` VARCHAR(50) NOT NULL,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`is_admin` BOOLEAN,
`hashed_password` TEXT,
`joined` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apis` (
`id` INT NOT NULL,
`title` TEXT,
`endpoints` TEXT,
`user_id` INT,
`created` TEXT,
`updated` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_083881_schema') AS relationships;
