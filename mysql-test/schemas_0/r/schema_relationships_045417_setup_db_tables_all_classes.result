INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 045417_setup_db_tables_all_classes
#
CREATE DATABASE `db_045417_setup_db_tables_all_classes`;
USE `db_045417_setup_db_tables_all_classes`;
CREATE TABLE `states` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(50),
`state_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`email` VARCHAR(50),
`password` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `amenities` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `places` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(50),
`city_id` VARCHAR(50),
`user_id` VARCHAR(50),
`description` VARCHAR(50),
`number_rooms` INT,
`number_bathrooms` INT,
`max_guest` INT,
`price_by_night` INT,
`latitude` DOUBLE,
`longitude` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `place_amenity` (
`id` INT NOT NULL,
`place_id` VARCHAR(50),
`amenity_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_045417_setup_db_tables_all_classes') AS relationships;
relationships
Database: db_045417_setup_db_tables_all_classes

Table Connections:
------------------
[Implied]  cities.state_id -> states.id
[Implied]  place_amenity.amenity_id -> amenities.id
[Implied]  place_amenity.place_id -> places.id
[Implied]  places.city_id -> cities.id
[Implied]  places.user_id -> users.id

DROP DATABASE `db_045417_setup_db_tables_all_classes`;
UNINSTALL EXTENSION vsql_schematron;
