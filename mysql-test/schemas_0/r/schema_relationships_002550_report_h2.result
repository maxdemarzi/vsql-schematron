INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002550_report_h2
#
CREATE DATABASE `db_002550_report_h2`;
USE `db_002550_report_h2`;
CREATE TABLE `suite_result` (
`SUITE_RESULT_ID` VARCHAR(255),
`SUITE_NAME` VARCHAR(255),
`PROJECT_NAME` VARCHAR(255),
`JOB_NAME` VARCHAR(255),
`JOB_BUILD_NUMBER` INT,
`JOB_BUILD_URL` VARCHAR(255),
`EXECUTION_RESULT` VARCHAR(255),
`START_TIME` INT,
`STOP_TIME` INT,
`NUMBER_OF_CASES` INT,
`NUMBER_OF_FAILURE` INT,
`INVISIBLE_ENTRY` INT,
`PRODUCT_UNDER_TASK` VARCHAR(255),
PRIMARY KEY (`SUITE_RESULT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `suite_property` (
`SUITE_PROPERTY_ID` INT,
`SUITE_RESULT_ID` VARCHAR(255),
`PROPERTY_NAME` VARCHAR(255),
`PROPERTY_VALUE` VARCHAR(255),
PRIMARY KEY (`SUITE_PROPERTY_ID`)
) CHARACTER SET latin1;
CREATE TABLE `case_result` (
`CASE_RESULT_ID` VARCHAR(255),
`SUITE_RESULT` VARCHAR(255),
`TASK_CASE_ID` INT,
`EXECUTION_RESULT` VARCHAR(255),
`AUT` VARCHAR(255),
`START_TIME` INT,
`STOP_TIME` INT,
`RETRY` INT,
`CASE_STATION` VARCHAR(255),
`LOG_DIR` VARCHAR(255),
`EXTERNAL_ID` VARCHAR(255),
`CASE_ENV` VARCHAR(255),
PRIMARY KEY (`CASE_RESULT_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002550_report_h2') AS relationships;
