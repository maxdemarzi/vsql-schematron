INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 067390_schema
#
CREATE DATABASE `db_067390_schema`;
USE `db_067390_schema`;
CREATE TABLE `songs` (
`id` VARCHAR(50) NOT NULL,
`samples` VARCHAR(50),
`sample_rate` INT,
`channels` INT,
`bit_rate` INT,
`codec` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs_external_metadata` (
`id` VARCHAR(50) NOT NULL,
`title` TEXT,
`artist` TEXT,
`album` TEXT,
`year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `songs_features` (
`id` VARCHAR(50) NOT NULL,
`length` DOUBLE,
`average_loudness` DOUBLE,
`bpm` DOUBLE,
`hpcp` VARCHAR(50),
`chords_histogram` VARCHAR(50),
`tags` VARCHAR(50),
`tags_intensity` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_067390_schema') AS relationships;
relationships
