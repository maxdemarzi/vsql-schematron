INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 001300_Biometria_CIGS
#
CREATE DATABASE `db_001300_Biometria_CIGS`;
USE `db_001300_Biometria_CIGS`;
CREATE TABLE `Evento` (
`id_tipo` INT,
`data` DATE,
`id_usuario` INT,
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Usuario` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`Cod_PG` INT,
`OM` VARCHAR(50),
`Biometria` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `admins` (
`usuario` VARCHAR(50) NOT NULL,
`senha` VARCHAR(50),
`nivel` INT,
PRIMARY KEY (`usuario`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_001300_Biometria_CIGS') AS relationships;
