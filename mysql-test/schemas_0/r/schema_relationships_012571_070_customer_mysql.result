CREATE DATABASE `db_012571_070_customer_mysql`;
USE `db_012571_070_customer_mysql`;
CREATE TABLE `cust_types` (
`cust_type_code` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`cust_type_code`)
) CHARACTER SET latin1;
CREATE TABLE `cust_master` (
`customer_id` INT,
