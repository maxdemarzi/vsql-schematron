`rev_number` INT,
`created_by` INT,
`creation_date` DATETIME,
`last_update_by` INT,
`last_update_date` DATETIME,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `cust_contacts` (
