CREATE TABLE `user` (
`id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `producttable` (
`id` VARCHAR(50) NOT NULL,
`productCode` VARCHAR(50),
`productName` VARCHAR(50),
`productSource` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shoprecords` (
`id` VARCHAR(50) NOT NULL,
`userId` VARCHAR(50),
`productId` VARCHAR(50),
`number` VARCHAR(50),
`shopDate` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
