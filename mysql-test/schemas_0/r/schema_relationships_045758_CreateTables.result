[Implied]  transaction.responded_by -> user.email
[Implied]  wishlist.advert_id -> advert.id
[Implied]  wishlist.user_id -> user.email

DROP DATABASE `db_045758_CreateTables`;
UNINSTALL EXTENSION vsql_schematron;
