INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 045758_CreateTables
#
CREATE DATABASE `db_045758_CreateTables`;
USE `db_045758_CreateTables`;
CREATE TABLE `user` (
`email` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`phone_number` VARCHAR(64),
PRIMARY KEY (`email`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`product_name` VARCHAR(64),
`product_description` VARCHAR(64),
`cat_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `advert` (
`id` INT,
`product_id` INT,
`posted_by` VARCHAR(64),
`action` INT,
`quantity` INT,
`image_url` VARCHAR(64),
`time_stamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
`action_id` INT,
`action_name` VARCHAR(64),
`action_description` VARCHAR(64),
PRIMARY KEY (`action_id`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`transaction_id` INT,
`responded_by` VARCHAR(64),
`action_id` INT,
`advert_id` INT,
`time_stamp` DATETIME,
PRIMARY KEY (`transaction_id`)
) CHARACTER SET latin1;
CREATE TABLE `wishlist` (
`wishlist_id` INT,
`user_id` VARCHAR(64),
`advert_id` INT,
PRIMARY KEY (`wishlist_id`)
) CHARACTER SET latin1;
CREATE TABLE `barter` (
`id` INT,
`barter_adv_id` INT,
`barter_adv_with_id` INT,
`barterer` VARCHAR(64),
`barteree` VARCHAR(64),
`barter_duration` VARCHAR(64),
`barter_status` INT,
`time_stamp` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_045758_CreateTables') AS relationships;
relationships
