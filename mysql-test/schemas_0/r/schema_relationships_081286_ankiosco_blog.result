INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 081286_ankiosco_blog
#
CREATE DATABASE `db_081286_ankiosco_blog`;
USE `db_081286_ankiosco_blog`;
CREATE TABLE `comments` (
`Id` INT,
`commentText` VARCHAR(64),
`dateTime` DATETIME,
`deleted` VARCHAR(64),
`modifiedDateTime` DATETIME,
`parent_id` INT,
`post_id` INT,
`user_id` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `comment_ratings` (
`Id` INT,
`value` INT,
`user_id` INT,
`comment_id` INT
) CHARACTER SET latin1;
CREATE TABLE `persistent_logins` (
`username` VARCHAR(64),
`series` VARCHAR(64),
`token` VARCHAR(64),
`last_used` DATETIME,
PRIMARY KEY (`series`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`Id` INT,
`dateTime` DATETIME,
`fullPostText` VARCHAR(64),
`hidden` VARCHAR(64),
`shortTextPart` VARCHAR(64),
`title` VARCHAR(64),
`category` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `posts_tags` (
`post_id` INT,
`tag_id` INT
) CHARACTER SET latin1;
CREATE TABLE `post_ratings` (
`Id` INT,
`value` INT,
`user_id` INT,
`post_id` INT
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`Id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`Id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`Id` INT,
`aboutText` VARCHAR(64),
`bigAvatarLink` VARCHAR(64),
`email` VARCHAR(64),
`enabled` VARCHAR(64),
`password` VARCHAR(64),
`registrationDate` DATETIME,
`smallAvatarLink` VARCHAR(64),
`username` VARCHAR(64),
`websiteLink` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
`user_id` INT,
`role_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_081286_ankiosco_blog') AS relationships;
relationships
