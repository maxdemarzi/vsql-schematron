CREATE TABLE `harta` (
`id_harta` VARCHAR(50),
`id_profil` VARCHAR(50),
`jenis` VARCHAR(50),
`jumlah` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `profil` (
`id_profil` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`nama` VARCHAR(50),
`alamat` VARCHAR(50),
`tempat_lahir` VARCHAR(50),
`tanggal_lahir` VARCHAR(50),
`gender` VARCHAR(50),
`no_telp` VARCHAR(50),
`foto_profil` VARCHAR(50),
PRIMARY KEY (`id_profil`)
) CHARACTER SET latin1;
