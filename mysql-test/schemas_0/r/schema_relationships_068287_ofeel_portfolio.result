CREATE DATABASE `db_068287_ofeel_portfolio`;
USE `db_068287_ofeel_portfolio`;
CREATE TABLE `ofeel_portfolio.works` (
`id` INT,
`title` VARCHAR(64),
`resume` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.categories` (
`id` INT,
`name` VARCHAR(64),
`icone` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.workcomments` (
`id` INT,
`pseudo` VARCHAR(64),
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`works_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.articles` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`resume` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`categorie_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.tags` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.artcomments` (
`id` INT,
`pseudo` VARCHAR(64),
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`articles_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.works_has_categories` (
`work_id` INT,
`categorie_id` INT,
PRIMARY KEY (`work_id`, `categorie_id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.works_has_tags` (
`work_id` INT,
`tag_id` INT,
PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `ofeel_portfolio.articles_has_tags` (
`article_id` INT,
`tag_id` INT,
PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;
