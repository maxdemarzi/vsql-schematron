`description` VARCHAR(50),
`source_type` VARCHAR(50),
`study_type` VARCHAR(50),
`eva_center_name` VARCHAR(50),
`center_name` VARCHAR(50),
`taxonomy_id` INT,
PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;
