INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 042872_script
#
CREATE DATABASE `db_042872_script`;
USE `db_042872_script`;
CREATE TABLE `termo` (
`id_termo` VARCHAR(50) NOT NULL,
`ds_termo` VARCHAR(50),
PRIMARY KEY (`id_termo`)
) CHARACTER SET latin1;
CREATE TABLE `pesquisa` (
`id_pesquisa` VARCHAR(50) NOT NULL,
`dt_pesquisa` DATETIME,
`id_termo` VARCHAR(50),
PRIMARY KEY (`id_pesquisa`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id_post` VARCHAR(50) NOT NULL,
`ds_post` VARCHAR(50),
PRIMARY KEY (`id_post`)
) CHARACTER SET latin1;
CREATE TABLE `pesquisa_post` (
`id_pesquisa_post` VARCHAR(50) NOT NULL,
`id_pesquisa` VARCHAR(50),
`id_post` VARCHAR(50),
PRIMARY KEY (`id_pesquisa_post`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_042872_script') AS relationships;
relationships
Database: db_042872_script

Table Connections:
------------------
[Implied]  pesquisa.id_termo -> termo.id_termo
[Implied]  pesquisa_post.id_pesquisa -> pesquisa.id_pesquisa
[Implied]  pesquisa_post.id_post -> post.id_post

DROP DATABASE `db_042872_script`;
UNINSTALL EXTENSION vsql_schematron;
