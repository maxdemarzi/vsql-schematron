INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 018540_schema
#
CREATE DATABASE `db_018540_schema`;
USE `db_018540_schema`;
CREATE TABLE `SINGER` (
`ID` INT,
`FIRST_NAME` VARCHAR(64),
`LAST_NAME` VARCHAR(64),
`BIRTH_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ALBUM` (
`ID` INT,
`SINGER_ID` INT,
`TITLE` VARCHAR(64),
`RELEASE_DATE` DATETIME,
`VERSION` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `INSTRUMENT` (
`INSTRUMENT_ID` VARCHAR(64),
PRIMARY KEY (`INSTRUMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SINGER_INSTRUMENT` (
`SINGER_ID` INT,
`INSTRUMENT_ID` VARCHAR(64),
PRIMARY KEY (`SINGER_ID`, `INSTRUMENT_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_018540_schema') AS relationships;
relationships
