USE `db_003858_1452198349`;
CREATE TABLE `Job` (
`Id` INT,
`StateId` INT,
`StateName` VARCHAR(64),
`InvocationData` VARCHAR(64),
`Arguments` VARCHAR(64),
`CreatedAt` DATETIME,
`ExpireAt` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Counter` (
`Id` INT,
`Key` VARCHAR(64),
`Value` INT,
`ExpireAt` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `JobParameter` (
`Id` INT,
`JobId` INT,
`Name` VARCHAR(64),
`Value` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `JobState` (
`Id` INT,
`JobId` INT,
`Name` VARCHAR(64),
`Reason` VARCHAR(64),
`CreatedAt` DATETIME,
`Data` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Server` (
`Id` VARCHAR(64),
`Data` VARCHAR(64),
`LastHeartbeat` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
