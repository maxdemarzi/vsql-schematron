INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 083106_Employees_DB
#
CREATE DATABASE `db_083106_Employees_DB`;
USE `db_083106_Employees_DB`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`name_first` VARCHAR(50),
`name_last` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_083106_Employees_DB') AS relationships;
relationships
Database: db_083106_Employees_DB

