INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 031001_create_tables
#
CREATE DATABASE `db_031001_create_tables`;
USE `db_031001_create_tables`;
CREATE TABLE `Student` (
`regno` VARCHAR(64),
`sname` VARCHAR(64),
`major` VARCHAR(64),
`bdate` DATETIME,
PRIMARY KEY (`regno`)
) CHARACTER SET latin1;
CREATE TABLE `Course` (
`course` INT,
`cname` VARCHAR(64),
`dept` VARCHAR(64),
PRIMARY KEY (`course`)
) CHARACTER SET latin1;
CREATE TABLE `Enroll` (
`regno` VARCHAR(64),
`course` INT,
`sem` INT,
`marks` INT,
PRIMARY KEY (`regno`, `course`, `sem`)
) CHARACTER SET latin1;
CREATE TABLE `Text` (
`bookisbn` INT,
`booktitle` VARCHAR(64),
`publisher` VARCHAR(64),
`author` VARCHAR(64),
PRIMARY KEY (`bookisbn`)
) CHARACTER SET latin1;
CREATE TABLE `BookAdoption` (
`course` INT,
`sem` INT,
`bookisbn` INT,
PRIMARY KEY (`course`, `sem`, `bookisbn`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_031001_create_tables') AS relationships;
relationships
Database: db_031001_create_tables

Table Connections:
------------------
[Implied]  BookAdoption.bookisbn -> Text.bookisbn
[Implied]  BookAdoption.course -> Course.course
[Implied]  Enroll.course -> Course.course
[Implied]  Enroll.regno -> Student.regno

DROP DATABASE `db_031001_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
