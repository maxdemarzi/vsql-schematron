INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002105_initDatabase
#
CREATE DATABASE `db_002105_initDatabase`;
USE `db_002105_initDatabase`;
CREATE TABLE `LANG` (
`id` INT,
`code` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WORD` (
`id` INT,
`libelle` VARCHAR(255),
`lang_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ACTION` (
`id` INT,
`name` VARCHAR(255),
`libelle` VARCHAR(255),
`type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `WORD_ACTION` (
`id` INT,
`word_id` INT,
`action_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`name` VARCHAR(255),
`admin` INT,
`lang_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002105_initDatabase') AS relationships;
relationships
Database: db_002105_initDatabase

