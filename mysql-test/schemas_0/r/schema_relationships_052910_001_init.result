INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 052910_001-init
#
CREATE DATABASE `db_052910_001_init`;
USE `db_052910_001_init`;
CREATE TABLE `photos` (
`id` INT,
`master_dir` VARCHAR(64),
`master_filename` VARCHAR(64),
`master_width` INT,
`master_height` INT,
`master_is_raw` VARCHAR(64),
`date_section` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`imported_at` DATETIME,
`orientation` INT,
`camera` VARCHAR(64),
`exposure_time` DECIMAL(10,2),
`iso` INT,
`focal_length` INT,
`aperture` DECIMAL(10,2),
`flag` VARCHAR(64),
`trashed` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT,
`title` VARCHAR(64),
`slug` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos_tags` (
`photo_id` INT,
`tag_id` INT,
PRIMARY KEY (`photo_id`, `tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `versions` (
`id` INT,
`type` VARCHAR(64),
`master` VARCHAR(64),
`output` VARCHAR(64),
`thumbnail` VARCHAR(64),
`version` INT,
`photo_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_052910_001_init') AS relationships;
relationships
Database: db_052910_001_init

Table Connections:
------------------
[Implied]  photos_tags.photo_id -> photos.id
[Implied]  photos_tags.tag_id -> tags.id
[Implied]  versions.photo_id -> photos.id

DROP DATABASE `db_052910_001_init`;
UNINSTALL EXTENSION vsql_schematron;
