INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 037986_category_test
#
CREATE DATABASE `db_037986_category_test`;
USE `db_037986_category_test`;
CREATE TABLE `category` (
`id` INT,
`title` VARCHAR(64),
`active` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `order` (
`id` INT,
`session` VARCHAR(64),
`total` INT,
`qty` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_product` (
`id` INT,
`order_id` INT,
`product_id` INT,
`title` VARCHAR(64),
`price` INT,
`qty` INT,
`total` INT
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`category_id` INT,
`title` VARCHAR(64),
`content` VARCHAR(64),
`price` INT,
`img` VARCHAR(64),
`active` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_037986_category_test') AS relationships;
