INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 070008_SchoolER
#
CREATE DATABASE `db_070008_SchoolER`;
USE `db_070008_SchoolER`;
CREATE TABLE `RECORDS` (
`record_id` INT NOT NULL,
`student_id` INT,
`subject_id` INT,
`semester_id` INT,
`grade` DOUBLE,
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `SEMESTERS` (
`semester_id` INT NOT NULL,
`name` VARCHAR(50),
`year` INT,
`period` SMALLINT,
PRIMARY KEY (`semester_id`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENTS` (
`student_id` INT NOT NULL,
`last_name` VARCHAR(50),
`first_name` VARCHAR(50),
`nationality` VARCHAR(50),
`current_semester_id` INT,
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `SUBJECTS` (
`subject_id` INT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
`credits` SMALLINT,
PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_070008_SchoolER') AS relationships;
relationships
Database: db_070008_SchoolER

Table Connections:
------------------
[Implied]  RECORDS.semester_id -> SEMESTERS.semester_id
[Implied]  RECORDS.student_id -> STUDENTS.student_id
[Implied]  RECORDS.subject_id -> SUBJECTS.subject_id
[Implied]  STUDENTS.current_semester_id -> SEMESTERS.semester_id

DROP DATABASE `db_070008_SchoolER`;
UNINSTALL EXTENSION vsql_schematron;
