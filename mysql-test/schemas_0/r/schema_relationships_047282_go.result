INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 047282_go
#
CREATE DATABASE `db_047282_go`;
USE `db_047282_go`;
CREATE TABLE `menu` (
`m_id` INT NOT NULL,
`m_name` VARCHAR(50),
`price` DECIMAL(10,2),
`category` VARCHAR(50),
PRIMARY KEY (`m_id`)
) CHARACTER SET latin1;
CREATE TABLE `branch` (
`b_id` INT NOT NULL,
`b_name` VARCHAR(50),
`b_address` VARCHAR(50),
PRIMARY KEY (`b_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`c_id` INT NOT NULL,
`c_name` VARCHAR(50),
`c_address` VARCHAR(50),
`c_phone` DECIMAL(10,2),
`b_id` INT,
PRIMARY KEY (`c_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`o_id` INT NOT NULL,
`o_date` DATE,
`o_quantity` INT,
`c_id` INT,
`m_id` INT,
`b_id` INT,
PRIMARY KEY (`o_id`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`RID` INT NOT NULL,
`duration` VARCHAR(50),
`RDate` DATE,
`RTime` VARCHAR(50),
`c_id` INT,
PRIMARY KEY (`RID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_047282_go') AS relationships;
relationships
Database: db_047282_go

Table Connections:
------------------
[Implied]  booking.c_id -> customer.c_id
[Implied]  customer.b_id -> branch.b_id
[Implied]  orders.b_id -> branch.b_id
[Implied]  orders.c_id -> customer.c_id
[Implied]  orders.m_id -> menu.m_id

DROP DATABASE `db_047282_go`;
UNINSTALL EXTENSION vsql_schematron;
