CREATE TABLE `AUTHOR` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MICROBLOG` (
`ID` INT NOT NULL,
`AUTHOR_ID` INT,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CHIRP` (
`ID` INT NOT NULL,
`MICROBLOG_ID` INT,
`CONTENT` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
