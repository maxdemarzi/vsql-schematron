INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 001630_database
#
CREATE DATABASE `db_001630_database`;
USE `db_001630_database`;
CREATE TABLE `users` (
`id` INT,
`full_name` VARCHAR(64),
`enabled` BOOL,
`last_login` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`user_id` INT,
`street` VARCHAR(64),
`city` VARCHAR(64),
`state` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`title` VARCHAR(64),
`author` VARCHAR(64),
`published_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT,
`book_id` INT,
`reviewer_name` VARCHAR(64),
`content` VARCHAR(64),
`rating` INT,
`published_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `checkouts` (
`id` INT,
`user_id` INT,
`book_id` INT,
`checkout_date` DATETIME,
`return_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_001630_database') AS relationships;
relationships
Database: db_001630_database

