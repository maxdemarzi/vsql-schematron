`issue_name` TEXT,
`issue_text` TEXT,
`issue_author` TEXT,
`entity_id` BIGINT,
`entity_class` TEXT,
`created_date` TIMESTAMP NULL,
`updated_date` TIMESTAMP NULL,
`issue_status` BIGINT,
`labels` VARCHAR(50),
PRIMARY KEY (`issue_id`)
) CHARACTER SET latin1;
CREATE TABLE `pipeline.issue_comment` (
`comment_id` BIGINT NOT NULL,
`issue_id` BIGINT,
`comment_text` TEXT,
`comment_author` TEXT,
`created_date` TIMESTAMP NULL,
`updated_date` TIMESTAMP NULL,
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
