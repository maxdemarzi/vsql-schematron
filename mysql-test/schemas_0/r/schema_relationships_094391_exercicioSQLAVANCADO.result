INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 094391_exercicioSQLAVANCADO
#
CREATE DATABASE `db_094391_exercicioSQLAVANCADO`;
USE `db_094391_exercicioSQLAVANCADO`;
CREATE TABLE `alunos` (
`id` INT,
`email` VARCHAR(64),
`nome` VARCHAR(64),
`idade` INT,
`ativo` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `avaliacoes` (
`id` INT,
`titulo` VARCHAR(64),
`descricao` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `respostas_avaliacoes` (
`id` INT,
`aluno_id` INT,
`avaliacao_id` INT,
`resposta` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resposta_mentor` (
`id` INT,
`resposta_id` INT,
`correcao_resposta` VARCHAR(64),
`nota` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_094391_exercicioSQLAVANCADO') AS relationships;
relationships
