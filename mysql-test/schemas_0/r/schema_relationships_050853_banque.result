INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 050853_banque
#
CREATE DATABASE `db_050853_banque`;
USE `db_050853_banque`;
CREATE TABLE `titulaire` (
`id` INT,
`nom` VARCHAR(64),
`prenom` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `typecompte` (
`id` INT,
`nom` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `compte` (
`id` INT,
`numcompte` VARCHAR(64),
`typecompte_id` INT,
`date_ouverture` DATETIME,
`derniere_op` DATETIME,
`solde` DECIMAL(10,2),
`titulaire_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operation` (
`id` INT,
`compte_id` INT,
`libelle` VARCHAR(64),
`date_operation` DATETIME,
`montant` DECIMAL(10,2),
`type_operation` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_050853_banque') AS relationships;
relationships
Database: db_050853_banque

Table Connections:
