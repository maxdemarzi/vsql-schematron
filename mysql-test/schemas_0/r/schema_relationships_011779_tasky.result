CREATE DATABASE `db_011779_tasky`;
USE `db_011779_tasky`;
CREATE TABLE `lists` (
`id` INT,
`name` VARCHAR(64),
`descrip` VARCHAR(64),
`create_date` DATETIME,
`edit_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subtasks` (
`id` INT,
`name` VARCHAR(64),
`descrip` VARCHAR(64),
`state` INT,
`create_date` DATETIME,
`edit_date` DATETIME,
`task_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT,
`name` VARCHAR(64),
`descrip` VARCHAR(64),
`priori` INT,
`expir` DATETIME,
`memo` DATETIME,
`colour` VARCHAR(64),
`state` INT,
`create_date` DATETIME,
`edit_date` DATETIME,
`list_id` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`pass` VARCHAR(64),
`create_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_list` (
`user_id` INT,
`list_id` INT,
`perm` INT,
`link_date` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_011779_tasky') AS relationships;
