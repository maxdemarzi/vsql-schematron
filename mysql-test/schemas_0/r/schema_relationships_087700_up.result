INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 087700_up
#
CREATE DATABASE `db_087700_up`;
USE `db_087700_up`;
CREATE TABLE `pages` (
`uuid` VARCHAR(255),
`page_name` VARCHAR(255),
`page_url` VARCHAR(255),
`page_title` VARCHAR(255),
`time_created` DATETIME,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `module_category` (
`uuid` VARCHAR(255),
`page_uuid` VARCHAR(255),
`title` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `modules` (
`uuid` VARCHAR(255),
`page_uuid` VARCHAR(255),
`category_uuid` VARCHAR(255),
`title` VARCHAR(255),
`content` VARCHAR(255),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_087700_up') AS relationships;
