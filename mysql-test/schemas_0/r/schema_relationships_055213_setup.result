INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 055213_setup
#
CREATE DATABASE `db_055213_setup`;
USE `db_055213_setup`;
CREATE TABLE `user` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usergroup` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `userorganization` (
`id` INT,
`name` VARCHAR(64),
`country` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `membership` (
`id` INT,
`user_group` INT,
`user` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_055213_setup') AS relationships;
relationships
Database: db_055213_setup

