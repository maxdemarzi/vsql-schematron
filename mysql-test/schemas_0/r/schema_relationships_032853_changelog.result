CREATE DATABASE `db_032853_changelog`;
USE `db_032853_changelog`;
CREATE TABLE `sizes` (
`id` INT NOT NULL,
`code` VARCHAR(50),
`sort_order` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `colors` (
`id` INT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`size_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_colors` (
`product_id` INT,
`color_id` INT
) CHARACTER SET latin1;
CREATE TABLE `product_sizes` (
`product_id` INT,
`size_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_032853_changelog') AS relationships;
relationships
