INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 062416_schema
#
CREATE DATABASE `db_062416_schema`;
USE `db_062416_schema`;
CREATE TABLE `parties` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `candidates` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`party_id` INT,
`industry_connected` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `voters` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_062416_schema') AS relationships;
relationships
