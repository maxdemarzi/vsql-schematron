INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 029948_databaseInit_homework
#
CREATE DATABASE `db_029948_databaseInit_homework`;
USE `db_029948_databaseInit_homework`;
CREATE TABLE `FACULTY` (
`NUM` INT NOT NULL,
PRIMARY KEY (`NUM`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENT` (
`ID` INT NOT NULL,
`FIRST_NAME` VARCHAR(50),
`LAST_NAME` VARCHAR(50),
`FAC_NUM` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`CREDITS` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSE_STUDENT` (
`ID` INT NOT NULL,
`COURSE_ID` INT,
`STUDENT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_029948_databaseInit_homework') AS relationships;
relationships
Database: db_029948_databaseInit_homework

Table Connections:
------------------
[Implied]  COURSE_STUDENT.COURSE_ID -> COURSE.ID
[Implied]  COURSE_STUDENT.STUDENT_ID -> STUDENT.ID
[Implied]  STUDENT.FAC_NUM -> FACULTY.NUM

DROP DATABASE `db_029948_databaseInit_homework`;
UNINSTALL EXTENSION vsql_schematron;
