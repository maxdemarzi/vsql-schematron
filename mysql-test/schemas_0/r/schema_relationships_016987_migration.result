`createdAt` DATETIME,
`updatedAt` DATETIME,
`merchandiseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Sale` (
`id` INT,
`amount` DECIMAL(10,2),
`unitCost` DECIMAL(10,2),
`unitPrice` DECIMAL(10,2),
`type` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`merchandiseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order` (
`id` INT,
`status` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetail` (
`id` INT,
`price` DECIMAL(10,2),
`amount` DECIMAL(10,2),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`orderId` INT,
`merchandiseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cart` (
`amount` INT,
`userId` INT,
`merchandiseId` INT,
PRIMARY KEY (`userId`, `merchandiseId`)
) CHARACTER SET latin1;
