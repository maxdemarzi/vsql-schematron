CREATE TABLE `User` (
`id` INT,
`account` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`phone` VARCHAR(64),
`gender` VARCHAR(64),
`birth` DATETIME,
`avatar` VARCHAR(64),
`scope` VARCHAR(64),
