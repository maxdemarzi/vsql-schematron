`phone` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Merchandise` (
`id` INT,
`title` VARCHAR(64),
`unit` VARCHAR(64),
`price` DECIMAL(10,2),
`on` VARCHAR(64),
`avatar` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`supplierId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Inventory` (
`id` INT,
`cost` DECIMAL(10,2),
`quantity` INT,
`createdAt` DATETIME,
`updatedAt` DATETIME,
`merchandiseId` INT,
`adjustmentId` INT,
`purchaseId` INT,
`saleId` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Adjustment` (
`id` INT,
`amount` DECIMAL(10,2),
`unitCost` DECIMAL(10,2),
`type` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`merchandiseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Purchase` (
`id` INT,
`amount` DECIMAL(10,2),
`unitCost` DECIMAL(10,2),
