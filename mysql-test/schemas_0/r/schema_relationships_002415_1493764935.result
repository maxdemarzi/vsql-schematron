CREATE DATABASE `db_002415_1493764935`;
USE `db_002415_1493764935`;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`status` VARCHAR(64),
`dateCreated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_details` (
`userId` INT,
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`phone` VARCHAR(64),
`address` VARCHAR(64),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `user_message` (
`id` INT,
`email` VARCHAR(64),
`name` VARCHAR(64),
`subject` VARCHAR(64),
`message` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_roles` (
`userId` INT,
`roleId` INT,
PRIMARY KEY (`userId`, `roleId`)
) CHARACTER SET latin1;
CREATE TABLE `user_token` (
`id` INT,
`userId` INT,
`selector` VARCHAR(64),
`token` VARCHAR(64),
`expire` INT,
`type` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
