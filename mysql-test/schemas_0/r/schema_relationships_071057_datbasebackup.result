INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 071057_datbasebackup
#
CREATE DATABASE `db_071057_datbasebackup`;
USE `db_071057_datbasebackup`;
CREATE TABLE `tb_card` (
`kode` VARCHAR(50) NOT NULL,
`card_number` INT,
`card_type` BLOB,
`Card_Room` VARCHAR(50),
`card_state` VARCHAR(50),
PRIMARY KEY (`kode`)
) CHARACTER SET latin1;
CREATE TABLE `tb_guest` (
`id_guest` VARCHAR(50) NOT NULL,
`guest_card` VARCHAR(50),
`name` VARCHAR(50),
`address` TEXT,
`phone` DOUBLE,
`email` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`id_guest`)
) CHARACTER SET latin1;
CREATE TABLE `tb_room` (
`id_room` VARCHAR(50) NOT NULL,
`name_room` VARCHAR(50),
`owner` VARCHAR(50),
`state` VARCHAR(50),
PRIMARY KEY (`id_room`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_071057_datbasebackup') AS relationships;
