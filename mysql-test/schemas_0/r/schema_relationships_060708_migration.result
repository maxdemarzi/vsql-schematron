CREATE DATABASE `db_060708_migration`;
USE `db_060708_migration`;
CREATE TABLE `UserQuiz` (
`id` VARCHAR(64),
`userId` VARCHAR(64),
`quizId` VARCHAR(64),
`timeStart` DATETIME,
`timeFinish` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `UserQuizQuestion` (
`id` VARCHAR(64),
`userQuizId` VARCHAR(64),
`quizQuestionId` VARCHAR(64),
`grade` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `UserQuestionAnswer` (
`id` VARCHAR(64),
`userQuizQuestionId` VARCHAR(64),
`questionAnswerId` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
