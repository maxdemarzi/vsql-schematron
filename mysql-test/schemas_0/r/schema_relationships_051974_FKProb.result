CREATE DATABASE `db_051974_FKProb`;
USE `db_051974_FKProb`;
CREATE TABLE `ot` (
`ot_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ot_id`)
) CHARACTER SET latin1;
CREATE TABLE `vtp` (
`vtp_id` INT,
`vt_ot_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`vtp_id`)
) CHARACTER SET latin1;
CREATE TABLE `vtp_restriction` (
`vt_ot_id` INT,
`vtp_id` INT,
PRIMARY KEY (`vt_ot_id`, `vtp_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_051974_FKProb') AS relationships;
