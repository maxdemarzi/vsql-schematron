INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 083556_insert
#
CREATE DATABASE `db_083556_insert`;
USE `db_083556_insert`;
CREATE TABLE `homes` (
`ID` INT NOT NULL,
`street` VARCHAR(50),
`city` VARCHAR(50),
`houseNumber` INT,
`zipCode` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `persons` (
`ID` INT NOT NULL,
`firstName` VARCHAR(50),
`surName` VARCHAR(50),
`description` TEXT,
`homeID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_083556_insert') AS relationships;
