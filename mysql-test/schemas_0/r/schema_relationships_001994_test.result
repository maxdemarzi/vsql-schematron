INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 001994_test
#
CREATE DATABASE `db_001994_test`;
USE `db_001994_test`;
CREATE TABLE `DEMO_COMPANY` (
`ID` DECIMAL(10,2),
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEMO_USER` (
`DTYPE` VARCHAR(64),
`ID` DECIMAL(10,2),
`USERNAME` VARCHAR(64),
`FIRST_NAME` VARCHAR(64),
`LAST_NAME` VARCHAR(64),
`WORKS_AT` DECIMAL(10,2),
`DAY` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_001994_test') AS relationships;
