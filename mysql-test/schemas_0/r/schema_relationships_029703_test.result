INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 029703_test
#
CREATE DATABASE `db_029703_test`;
USE `db_029703_test`;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`country_code` INT,
`default_language` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `languages` (
`id` INT,
`code` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `countries` (
`id` INT,
`code` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `path_owners` (
`user_id` INT,
`path_id` INT,
`type` INT
) CHARACTER SET latin1;
CREATE TABLE `paths` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `path_steps` (
`step_id` INT,
`path_id` INT
) CHARACTER SET latin1;
CREATE TABLE `steps` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `step_materials` (
`path_id` INT,
`step_id` INT
) CHARACTER SET latin1;
CREATE TABLE `materials` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`link` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `material_attachments` (
`material_id` INT,
`attachment_id` INT
) CHARACTER SET latin1;
CREATE TABLE `attachments` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
