CREATE DATABASE `db_062197_migration`;
USE `db_062197_migration`;
CREATE TABLE `User` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`email` TEXT,
`password` TEXT,
`firstname` TEXT,
`lastname` TEXT,
`role` VARCHAR(50),
`storeId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Store` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`address` TEXT,
`updatedAt` TIMESTAMP NULL,
`createdAt` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`description` TEXT,
`price` DOUBLE,
`discount` DOUBLE,
`mediaUrl` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`storeId` TEXT,
`category` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`id` VARCHAR(50) NOT NULL,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`userId` TEXT,
`productId` TEXT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
