INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 088668_1_Library
#
CREATE DATABASE `db_088668_1_Library`;
USE `db_088668_1_Library`;
CREATE TABLE `publisher` (
`Name` VARCHAR(255),
`Address` VARCHAR(255),
`Phone` DECIMAL(10,2),
PRIMARY KEY (`Name`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`Book_id` DECIMAL(10,2),
`Title` VARCHAR(255),
`Publisher_Name` VARCHAR(255),
`Pub_year` DECIMAL(10,2),
PRIMARY KEY (`Book_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_authors` (
`Book_id` DECIMAL(10,2),
`Author_Name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `library_branch` (
`Branch_id` DECIMAL(10,2),
`Branch_Name` VARCHAR(255),
`Address` VARCHAR(255),
PRIMARY KEY (`Branch_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_copies` (
`Book_id` DECIMAL(10,2),
`Branch_id` DECIMAL(10,2),
`No_of_copies` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `book_lending` (
`Book_id` DECIMAL(10,2),
`Branch_id` DECIMAL(10,2),
`Card_No` DECIMAL(10,2),
`Date_out` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_088668_1_Library') AS relationships;
relationships
Database: db_088668_1_Library

Table Connections:
------------------
[Implied]  book.Publisher_Name -> publisher.Name
[Implied]  book_authors.Book_id -> book.Book_id
[Implied]  book_copies.Book_id -> book.Book_id
[Implied]  book_copies.Branch_id -> library_branch.Branch_id
[Implied]  book_lending.Book_id -> book.Book_id
[Implied]  book_lending.Branch_id -> library_branch.Branch_id

DROP DATABASE `db_088668_1_Library`;
UNINSTALL EXTENSION vsql_schematron;
