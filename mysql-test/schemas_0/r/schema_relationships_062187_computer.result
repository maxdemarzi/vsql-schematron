INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 062187_computer
#
CREATE DATABASE `db_062187_computer`;
USE `db_062187_computer`;
CREATE TABLE `PC` (
`code` INT NOT NULL,
`model` VARCHAR(50),
`speed` INT,
`ram` INT,
`hd` DOUBLE,
`cd` VARCHAR(50),
`price` DOUBLE,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`maker` VARCHAR(50),
`model` VARCHAR(50) NOT NULL,
`type` VARCHAR(50),
PRIMARY KEY (`model`)
) CHARACTER SET latin1;
CREATE TABLE `Printer` (
`code` INT NOT NULL,
`model` VARCHAR(50),
`color` CHAR(50),
`type` VARCHAR(50),
`price` DOUBLE,
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_062187_computer') AS relationships;
