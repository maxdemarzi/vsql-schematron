INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 097732_music_schema
#
CREATE DATABASE `db_097732_music_schema`;
USE `db_097732_music_schema`;
CREATE TABLE `Artist` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Album` (
`id` INT,
`name` VARCHAR(64),
`release_date` DATETIME,
`artist` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Membership` (
`artist` INT,
`band` INT
) CHARACTER SET latin1;
CREATE TABLE `Track` (
`id` INT,
`name` VARCHAR(64),
`album` INT,
`length` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Songwriter` (
`song` INT,
`writer` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_097732_music_schema') AS relationships;
relationships
Database: db_097732_music_schema

Table Connections:
------------------
[Implied]  Album.artist -> Artist.id
[Implied]  Membership.artist -> Artist.id
[Implied]  Track.album -> Album.id

DROP DATABASE `db_097732_music_schema`;
UNINSTALL EXTENSION vsql_schematron;
