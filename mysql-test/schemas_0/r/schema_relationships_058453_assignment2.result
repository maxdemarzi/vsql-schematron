INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 058453_assignment2
#
CREATE DATABASE `db_058453_assignment2`;
USE `db_058453_assignment2`;
CREATE TABLE `hotel` (
`hno` DECIMAL(10,2) NOT NULL,
`name` VARCHAR(50),
`address` VARCHAR(50),
PRIMARY KEY (`hno`)
) CHARACTER SET latin1;
CREATE TABLE `room` (
`rno` DECIMAL(10,2) NOT NULL,
`rtype` VARCHAR(50),
`hno` DECIMAL(10,2),
`price` DECIMAL(10,2),
PRIMARY KEY (`rno`)
) CHARACTER SET latin1;
CREATE TABLE `guest` (
`gno` DECIMAL(10,2) NOT NULL,
`gname` VARCHAR(50),
`gaddress` VARCHAR(50),
PRIMARY KEY (`gno`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`hno` DECIMAL(10,2),
`gno` DECIMAL(10,2),
`rno` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_058453_assignment2') AS relationships;
