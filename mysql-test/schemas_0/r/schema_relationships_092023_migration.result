INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 092023_migration
#
CREATE DATABASE `db_092023_migration`;
USE `db_092023_migration`;
CREATE TABLE `Country` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`iso2` CHAR(50),
`iso3` CHAR(50),
`numeric_code` CHAR(50),
`phonecode` VARCHAR(50),
`capital` VARCHAR(50),
`currency` VARCHAR(50),
`current_symbol` VARCHAR(50),
`tld` CHAR(50),
`native` VARCHAR(50),
`region` VARCHAR(50),
`subregion` VARCHAR(50),
`translations` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
`emoji` VARCHAR(50),
`emojiU` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Timezone` (
`id` INT NOT NULL,
`zoneName` VARCHAR(50),
`gmtOffset` INT,
`gmtOffSetName` VARCHAR(50),
`abbreviation` VARCHAR(50),
`tzName` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
`countryId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_092023_migration') AS relationships;
