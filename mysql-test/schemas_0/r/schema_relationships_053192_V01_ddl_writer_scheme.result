`READER_ID` DECIMAL(10,2),
`WRITER_NAME` VARCHAR(50),
`WRITER_ADDRESS` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `WRITER.BOOK` (
`ID` DECIMAL(10,2) NOT NULL,
`BOOK_NAME` VARCHAR(50),
`BOOK_TYPE` VARCHAR(50),
`CNT` DECIMAL(10,2),
`INFO_ID` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
