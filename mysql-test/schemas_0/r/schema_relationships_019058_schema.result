[Implied]  msg_messages.thread_id -> msg_threads.thread_id
[Implied]  msg_thread_keys.thread_id -> msg_messages.thread_id
[Implied]  msg_thread_keys.thread_id -> msg_threads.thread_id

DROP DATABASE `db_019058_schema`;
UNINSTALL EXTENSION vsql_schematron;
