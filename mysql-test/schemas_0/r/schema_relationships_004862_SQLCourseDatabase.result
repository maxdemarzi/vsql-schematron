[Implied]  Student_grade.student_id -> Student.student_id
[Implied]  Teacher.curator_id -> Student.student_id
[Implied]  Teacher.curator_id -> Teacher.teacher_id
[Implied]  Teacher_Course_Faculty.course_id -> Course.course_id
[Implied]  Teacher_Course_Faculty.faculty_id -> Faculty.faculty_id
[Implied]  Teacher_Course_Faculty.teacher_id -> Teacher.teacher_id
[Implied]  Unit.faculty_id -> Faculty.faculty_id

DROP DATABASE `db_004862_SQLCourseDatabase`;
UNINSTALL EXTENSION vsql_schematron;
