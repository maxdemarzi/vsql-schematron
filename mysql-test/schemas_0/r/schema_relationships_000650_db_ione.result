INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 000650_db_ione
#
CREATE DATABASE `db_000650_db_ione`;
USE `db_000650_db_ione`;
CREATE TABLE `brand` (
`id` INT,
`name` VARCHAR(64),
`slug` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
`id` INT,
`brand_id` INT,
`model_id` INT,
`engine_type_id` INT,
`drive_unit_id` INT,
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `migration` (
`version` VARCHAR(64),
`apply_time` INT,
PRIMARY KEY (`version`)
) CHARACTER SET latin1;
CREATE TABLE `model` (
`id` INT,
`brand_id` INT,
`name` VARCHAR(64),
`slug` VARCHAR(64),
`created_at` INT,
`updated_at` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`auth_key` VARCHAR(64),
`password_hash` VARCHAR(64),
`password_reset_token` VARCHAR(64),
`email` VARCHAR(64),
`status` INT,
`created_at` INT,
`updated_at` INT,
`verification_token` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_000650_db_ione') AS relationships;
relationships
