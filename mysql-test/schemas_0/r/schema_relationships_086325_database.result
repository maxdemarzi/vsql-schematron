INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 086325_database
#
CREATE DATABASE `db_086325_database`;
USE `db_086325_database`;
CREATE TABLE `permissions` (
`perm_id` INT,
`perm_module` VARCHAR(64),
`perm_description` VARCHAR(64),
PRIMARY KEY (`perm_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT,
`role_name` VARCHAR(64),
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles_permissions` (
`role_id` INT,
`perm_id` INT,
PRIMARY KEY (`role_id`, `perm_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_uuid` VARCHAR(64),
`user_name` VARCHAR(64),
`user_email` VARCHAR(64),
`user_password` VARCHAR(64),
`role_id` INT,
PRIMARY KEY (`user_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `classes` (
`class_uuid` VARCHAR(64),
`class_name` VARCHAR(64),
`class_description` VARCHAR(64),
`slug` VARCHAR(64),
`teacher_uuid` VARCHAR(64),
PRIMARY KEY (`class_uuid`)
) CHARACTER SET latin1;
CREATE TABLE `student_registrations` (
`reg_uuid` VARCHAR(64),
`class_uuid` VARCHAR(64),
`student_uuid` VARCHAR(64),
`grade` VARCHAR(64),
`remarks` VARCHAR(64),
PRIMARY KEY (`reg_uuid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_086325_database') AS relationships;
relationships
Database: db_086325_database

Table Connections:
------------------
[Implied]  classes.teacher_uuid -> users.user_uuid
[Implied]  roles_permissions.perm_id -> permissions.perm_id
[Implied]  roles_permissions.role_id -> roles.role_id
[Implied]  student_registrations.class_uuid -> classes.class_uuid
[Implied]  student_registrations.student_uuid -> users.user_uuid
[Implied]  users.role_id -> roles.role_id

DROP DATABASE `db_086325_database`;
UNINSTALL EXTENSION vsql_schematron;
