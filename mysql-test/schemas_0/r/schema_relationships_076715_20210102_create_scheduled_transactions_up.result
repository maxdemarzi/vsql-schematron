CREATE TABLE `scheduled_transactions` (
`id` INT NOT NULL,
`start_date` DATE,
`end_date` DATE,
`enabled` BOOLEAN,
`last_occurrence` DATE,
`date_spec` VARCHAR(50),
`interval_type` VARCHAR(50),
`interval_count` INT,
`entity_id` INT,
`description` CHAR(50),
`memo` CHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scheduled_transaction_items` (
`id` INT NOT NULL,
`scheduled_transaction_id` INT,
`account_id` INT,
`action` CHAR(50),
`quantity` DECIMAL(10,2),
`memo` CHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
