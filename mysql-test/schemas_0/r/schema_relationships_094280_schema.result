INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 094280_schema
#
CREATE DATABASE `db_094280_schema`;
USE `db_094280_schema`;
CREATE TABLE `departments` (
`id` INT,
`dept_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_094280_schema') AS relationships;
relationships
Database: db_094280_schema

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_094280_schema`;
UNINSTALL EXTENSION vsql_schematron;
