CREATE DATABASE `db_033616_tugasakhir_yusron`;
USE `db_033616_tugasakhir_yusron`;
CREATE TABLE `departement` (
`id_departement` INT,
`namadepartement` VARCHAR(64),
`deskripsidepartement` VARCHAR(64),
PRIMARY KEY (`id_departement`)
) CHARACTER SET latin1;
CREATE TABLE `kategori` (
`id_kategori` INT,
`namakategori` VARCHAR(64),
`deskripsikategori` VARCHAR(64),
PRIMARY KEY (`id_kategori`)
) CHARACTER SET latin1;
CREATE TABLE `kriteria` (
`kriteria_id` INT,
`kriteria_nama` VARCHAR(64),
`kriteria_bobot` DECIMAL(10,2),
`kriteria_sifat` VARCHAR(64),
`kategori_id` INT,
PRIMARY KEY (`kriteria_id`)
) CHARACTER SET latin1;
CREATE TABLE `pegawai` (
`id_pegawai` INT,
`nip` VARCHAR(64),
`nama` VARCHAR(64),
`departement_id` INT,
`kontak` VARCHAR(64),
PRIMARY KEY (`id_pegawai`)
) CHARACTER SET latin1;
CREATE TABLE `penilaian` (
`id_penilaian` INT,
`pegawai_id` INT,
`kriteria_id` INT,
`jawaban` INT,
`periode_bulan` INT,
`periode_tahun` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT,
`nip` VARCHAR(64),
`nama` VARCHAR(64),
`kontak` VARCHAR(64),
`level` VARCHAR(64),
`password` VARCHAR(64),
`last_login` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_033616_tugasakhir_yusron') AS relationships;
