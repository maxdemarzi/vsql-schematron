INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 062779_mysql
#
CREATE DATABASE `db_062779_mysql`;
USE `db_062779_mysql`;
CREATE TABLE `people` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
`authentication_method` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resources` (
`id` INT,
`code` VARCHAR(64),
`type` VARCHAR(64),
`name` VARCHAR(64),
`class` VARCHAR(64),
`order` INT,
`api_key` VARCHAR(64),
`api_secret` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `resource_managers` (
`resource_code` VARCHAR(64),
`manager_id` INT
) CHARACTER SET latin1;
CREATE TABLE `account_requests` (
`id` INT,
`requester_id` INT,
`employee_number` INT,
`type` VARCHAR(64),
`status` VARCHAR(64),
`created` DATETIME,
`modified` DATETIME,
`completed` DATETIME,
`employee` VARCHAR(64),
`resources` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profiles` (
`id` INT,
`name` VARCHAR(64),
`questions` VARCHAR(64),
`resources` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_062779_mysql') AS relationships;
