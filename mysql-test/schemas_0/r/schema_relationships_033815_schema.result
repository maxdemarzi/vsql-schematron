INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 033815_schema
#
CREATE DATABASE `db_033815_schema`;
USE `db_033815_schema`;
CREATE TABLE `lesson_types` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teacher_positions` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups_table` (
`id` INT,
`name` VARCHAR(64),
`students_number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
`id` INT,
`name` VARCHAR(64),
`hours_number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`id` INT,
`name` VARCHAR(64),
`course` INT,
`phone_number` VARCHAR(64),
`email` VARCHAR(64),
`group_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teachers` (
`id` INT,
`name` VARCHAR(64),
`phone_number` VARCHAR(64),
`position` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lessons` (
`uuid` INT,
`subject_id` INT,
`teacher_id` INT,
`lesson_type` INT,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `progress` (
`uuid` INT,
`student_id` INT,
`subject_id` INT,
`grade` INT,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_033815_schema') AS relationships;
relationships
