INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 068160_MySQL
#
CREATE DATABASE `db_068160_MySQL`;
USE `db_068160_MySQL`;
CREATE TABLE `User` (
`idUser` INT,
`login` VARCHAR(64),
`password` VARCHAR(64),
`role` BOOL,
PRIMARY KEY (`idUser`)
) CHARACTER SET latin1;
CREATE TABLE `Client` (
`idClient` INT,
`firstName` VARCHAR(64),
`secondName` VARCHAR(64),
`Patronimic` VARCHAR(64),
`address` VARCHAR(64),
`phoneNumber` VARCHAR(64),
`idUser` INT,
PRIMARY KEY (`idClient`)
) CHARACTER SET latin1;
CREATE TABLE `Car` (
`idCar` INT,
`modelYear` DATETIME,
`idModel` INT,
`info` VARCHAR(64),
`image` INT,
`cost` DECIMAL(10,2),
PRIMARY KEY (`idCar`)
) CHARACTER SET latin1;
CREATE TABLE `Model` (
`idModel` INT,
`modelName` VARCHAR(64),
`idMark` INT,
`idBodyType` INT,
PRIMARY KEY (`idModel`)
) CHARACTER SET latin1;
CREATE TABLE `Mark` (
`idMark` INT,
`markName` VARCHAR(64),
`idCountry` INT,
PRIMARY KEY (`idMark`)
) CHARACTER SET latin1;
CREATE TABLE `BodyType` (
`idBodyType` INT,
`bodyTypeName` VARCHAR(64),
PRIMARY KEY (`idBodyType`)
) CHARACTER SET latin1;
CREATE TABLE `Country` (
`idCountry` INT,
`nameCountry` VARCHAR(64),
PRIMARY KEY (`idCountry`)
) CHARACTER SET latin1;
CREATE TABLE `Renta` (
`idRenta` INT,
`idClient` INT,
`idCar` INT,
`dataStart` DATETIME,
`dataPlan` DATETIME,
`dataEnd` DATETIME,
PRIMARY KEY (`idRenta`)
) CHARACTER SET latin1;
CREATE TABLE `Injury` (
`idInjury` INT,
`injuryName` VARCHAR(64),
PRIMARY KEY (`idInjury`)
) CHARACTER SET latin1;
CREATE TABLE `ResultingInjury` (
`idResultinInjury` INT,
`idRenta` INT,
`idInjury` INT,
PRIMARY KEY (`idResultinInjury`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_068160_MySQL') AS relationships;
