[Implied]  SupplierItemCustomer.I_ID -> Item.I_ID
[Implied]  SupplierItemCustomer.S_ID -> Supplier.S_ID

DROP DATABASE `db_084546_1_CREATE_TABLES`;
UNINSTALL EXTENSION vsql_schematron;
