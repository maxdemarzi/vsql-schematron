`height` INT,
`weight` INT,
`hair_color` VARCHAR(64),
`eye_color` VARCHAR(64),
PRIMARY KEY (`guid`)
) CHARACTER SET latin1;
CREATE TABLE `hunt` (
`guid` VARCHAR(64),
`client_guid` VARCHAR(64),
`season` VARCHAR(64),
`year` INT,
`animal` VARCHAR(64),
`hunt_type` VARCHAR(64),
