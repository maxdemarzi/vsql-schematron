CREATE DATABASE `db_079737_Online_Donations`;
USE `db_079737_Online_Donations`;
CREATE TABLE `online_donations.country` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `online_donations.institution` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`id_country` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `online_donations.user` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`surname` VARCHAR(50),
`id_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
