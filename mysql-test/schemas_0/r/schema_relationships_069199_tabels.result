CREATE DATABASE `db_069199_tabels`;
USE `db_069199_tabels`;
CREATE TABLE `SESSIONS` (
`SESSION_ID` INT,
`SESSION_USER_ID` INT,
`SESSION_TOKEN` VARCHAR(64),
`SESSION_USER_TYPE` VARCHAR(64),
PRIMARY KEY (`SESSION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RESET_PASSWORDS` (
`RESET_PASSWORD_ID` INT,
`RESET_PASSWORD_EMAIL` VARCHAR(64),
`RESET_PASSWORD_SELECTOR` VARCHAR(64),
`RESET_PASSWORD_TOKEN` VARCHAR(64),
`RESET_PASSWORD_EXPIRE` VARCHAR(64),
PRIMARY KEY (`RESET_PASSWORD_ID`)
) CHARACTER SET latin1;
CREATE TABLE `USERS` (
`USER_ID` INT,
`USER_FIRSTNAME` VARCHAR(64),
`USER_LASTNAME` VARCHAR(64),
`USER_EMAIL` VARCHAR(64),
`USER_PASSWORD` VARCHAR(64),
`USER_PROFILE` VARCHAR(64),
PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `STUDENTS` (
`STUDENT_ID` INT,
`STUDENT_PRN` INT,
`STUDENT_FIRSTNAME` VARCHAR(64),
`STUDENT_LASTNAME` VARCHAR(64),
`STUDENT_EMAIL` VARCHAR(64),
`STUDENT_CONTACT` VARCHAR(64),
`STUDENT_PASSWORD` VARCHAR(64),
`STUDENT_PROFILE` VARCHAR(64),
`COURSE_ID` INT,
`STUDENT_ACADEMIC_YEAR_START` VARCHAR(64),
`STUDENT_ACADEMIC_YEAR_END` VARCHAR(64),
PRIMARY KEY (`STUDENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `DEPARTMENTS` (
`DEPARTMENT_ID` INT,
`DEPARTMENT_NAME` VARCHAR(64),
PRIMARY KEY (`DEPARTMENT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `COURSES` (
`COURSE_ID` INT,
`DEPARTMENT_ID` INT,
`COURSE_NAME` VARCHAR(64),
PRIMARY KEY (`COURSE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `POSITIONS` (
`POSITION_ID` INT,
`POSITION_NAME` VARCHAR(64),
PRIMARY KEY (`POSITION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CANDIDATES` (
`CANDIDATE_ID` INT,
`STUDENT_ID` INT,
`ELECTION_ID` INT,
PRIMARY KEY (`CANDIDATE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ELECTIONS` (
`ELECTION_ID` INT,
`POSITION_ID` INT,
`COURSE_ID` INT,
`ELECTION_DATE` VARCHAR(64),
`ELECTION_START_TIME` VARCHAR(64),
`ELECTION_END_TIME` VARCHAR(64),
PRIMARY KEY (`ELECTION_ID`)
) CHARACTER SET latin1;
CREATE TABLE `VOTES` (
`VOTE_ID` INT,
`ELECTION_ID` INT,
`CANDIDATE_ID` INT,
`NO_OF_VOTES` INT,
`STUDENT_ID` INT,
PRIMARY KEY (`VOTE_ID`)
) CHARACTER SET latin1;
