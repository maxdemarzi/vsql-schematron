INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 054743_data
#
CREATE DATABASE `db_054743_data`;
USE `db_054743_data`;
CREATE TABLE `usuario` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
`id` INT NOT NULL,
`id_usuario` INT,
`number` INT,
`citycode` INT,
`countrycode` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_054743_data') AS relationships;
