INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 039026_000-init-schema
#
CREATE DATABASE `db_039026_000_init_schema`;
USE `db_039026_000_init_schema`;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`pwd_hash` VARCHAR(64),
`is_admin` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `marks` (
`id` INT,
`date` DATETIME,
`student_id` INT,
`course_id` INT,
`points` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course_reviews` (
`id` INT,
`date` DATETIME,
`course_id` INT,
`review_text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_039026_000_init_schema') AS relationships;
relationships
Database: db_039026_000_init_schema

Table Connections:
------------------
[Implied]  course_reviews.course_id -> courses.id
[Implied]  marks.course_id -> courses.id
[Implied]  marks.student_id -> students.id

DROP DATABASE `db_039026_000_init_schema`;
UNINSTALL EXTENSION vsql_schematron;
