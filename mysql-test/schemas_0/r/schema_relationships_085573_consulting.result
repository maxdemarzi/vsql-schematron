INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 085573_consulting
#
CREATE DATABASE `db_085573_consulting`;
USE `db_085573_consulting`;
CREATE TABLE `consultant` (
`id` INT NOT NULL,
`lastname` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT NOT NULL,
`lastname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `consulting` (
`id` INT NOT NULL,
`consultant_k` INT,
`client_k` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_085573_consulting') AS relationships;
