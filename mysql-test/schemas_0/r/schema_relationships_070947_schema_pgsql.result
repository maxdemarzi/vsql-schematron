INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 070947_schema.pgsql
#
CREATE DATABASE `db_070947_schema_pgsql`;
USE `db_070947_schema_pgsql`;
CREATE TABLE `pictures` (
`id` INT NOT NULL,
`digest` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sentpictures` (
`id` INT NOT NULL,
`url` CHAR(50),
`sender` CHAR(50),
`picture_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `signatures` (
`id` INT NOT NULL,
`compressed_signature` VARCHAR(50),
`picture_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `words` (
`pos_and_word` VARCHAR(50),
`signature_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_070947_schema_pgsql') AS relationships;
relationships
Database: db_070947_schema_pgsql

Table Connections:
------------------
[Implied]  sentpictures.picture_id -> pictures.id
[Implied]  signatures.picture_id -> pictures.id
[Implied]  words.signature_id -> signatures.id

DROP DATABASE `db_070947_schema_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
