CREATE TABLE `tweet` (
`id` INT,
`message` VARCHAR(255),
`lang` VARCHAR(255),
`created_at` DATETIME,
`aggregate_sentiment` VARCHAR(255),
`aggregate_score` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sentiment` (
`id` VARCHAR(255),
`tweet_id` INT,
`sentiment` VARCHAR(255),
`topic` VARCHAR(255),
`score` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
