USE `db_025551_8`;
CREATE TABLE `USERS` (
`ID` VARCHAR(64),
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`FIRSTNAME` VARCHAR(64),
`LASTNAME` VARCHAR(64),
`ROLE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EVENTS` (
`ID` VARCHAR(64),
`REPORT_ID` VARCHAR(64),
`USER_ID` VARCHAR(64),
`CREATION_DATE` DATETIME,
`EVENT_TYPE` VARCHAR(64),
`ACTION` VARCHAR(64),
`RESULT_ACTION` VARCHAR(64),
`DETAIL` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
