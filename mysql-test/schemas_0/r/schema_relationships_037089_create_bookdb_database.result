CREATE DATABASE `db_037089_create_bookdb_database`;
USE `db_037089_create_bookdb_database`;
CREATE TABLE `books` (
`book_id` INT NOT NULL,
`book_name` VARCHAR(50),
PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;
CREATE TABLE `authors` (
`author_id` INT NOT NULL,
`author_name` VARCHAR(50),
PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;
CREATE TABLE `book_author` (
`book_id` INT NOT NULL,
`author_id` INT NOT NULL,
PRIMARY KEY (`book_id`, `author_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_037089_create_bookdb_database') AS relationships;
