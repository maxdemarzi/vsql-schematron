`user_id` VARCHAR(64),
`follower_id` VARCHAR(64),
PRIMARY KEY (`user_id`, `follower_id`)
) CHARACTER SET latin1;
CREATE TABLE `woofs` (
`id` INT,
`author_id` VARCHAR(64),
`datetime` DATETIME,
`message` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
