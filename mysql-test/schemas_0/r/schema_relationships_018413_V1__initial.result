INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 018413_V1__initial
#
CREATE DATABASE `db_018413_V1__initial`;
USE `db_018413_V1__initial`;
CREATE TABLE `users.users` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`active` INT,
`time_created` TIMESTAMP NULL,
`last_updated` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users.datasets` (
`id` INT NOT NULL,
`owner_id` INT,
`name` TEXT,
`time_created` TIMESTAMP NULL,
`last_updated` TIMESTAMP NULL,
`metadata` VARCHAR(50),
`loid` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users.demo_files` (
`id` INT NOT NULL,
`name` TEXT,
`time_created` TIMESTAMP NULL,
`last_updated` TIMESTAMP NULL,
`size` INT,
`metadata` VARCHAR(50),
`loid` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users.jobs` (
`id` INT NOT NULL,
`owner_id` INT,
`job_class` TEXT,
`jobdata` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_018413_V1__initial') AS relationships;
