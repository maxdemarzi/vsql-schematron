INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 060159_photos
#
CREATE DATABASE `db_060159_photos`;
USE `db_060159_photos`;
CREATE TABLE `User` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Photo` (
`id` INT,
`caption` VARCHAR(64),
`creationDate` DATETIME,
`uploadDate` DATETIME,
`user` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Likes` (
`user` INT,
`photo` INT,
PRIMARY KEY (`user`, `photo`)
) CHARACTER SET latin1;
CREATE TABLE `AppearsIn` (
`user` INT,
`photo` INT,
PRIMARY KEY (`user`, `photo`)
) CHARACTER SET latin1;
CREATE TABLE `Friend` (
`user1` INT,
`user2` INT,
PRIMARY KEY (`user1`, `user2`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_060159_photos') AS relationships;
relationships
Database: db_060159_photos

Table Connections:
------------------
[Implied]  AppearsIn.photo -> Photo.id
[Implied]  AppearsIn.user -> User.id
[Implied]  Friend.user1 -> User.id
[Implied]  Friend.user2 -> User.id
[Implied]  Likes.photo -> Photo.id
[Implied]  Likes.user -> User.id
[Implied]  Photo.user -> User.id

DROP DATABASE `db_060159_photos`;
UNINSTALL EXTENSION vsql_schematron;
