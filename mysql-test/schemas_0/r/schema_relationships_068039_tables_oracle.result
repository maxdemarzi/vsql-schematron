INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 068039_tables_oracle
#
CREATE DATABASE `db_068039_tables_oracle`;
USE `db_068039_tables_oracle`;
CREATE TABLE `PUBLISHER` (
`ID` INT,
`VERSION` INT,
`NAME` VARCHAR(64),
`ADDRESS` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`ID` INT,
`VERSION` INT,
`NAME` VARCHAR(64),
`PUBLISHED` DATETIME,
`PRICE` DECIMAL(10,2),
`PUBLISHER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK_I18N` (
`ID` INT,
`VERSION` INT,
`BOOK_ID` INT,
`LANG` VARCHAR(64),
`TITLE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK_BIN` (
`ID` INT,
`VERSION` INT,
`HARDCOVER` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR` (
`ID` INT,
`VERSION` INT,
`NAME` VARCHAR(64),
`SECRET` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR_BOOK` (
`AUTHOR_ID` INT,
`BOOK_ID` INT,
PRIMARY KEY (`AUTHOR_ID`, `BOOK_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PROJECT` (
`ID` INT,
`VERSION` INT,
`NAME` VARCHAR(64),
`MANAGER_ID` INT,
`MANAGER_TYPE` VARCHAR(64),
`STATUS_COD` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CONSULTANT` (
`ID` INT,
`VERSION` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMPLOYEE` (
`ID` INT,
`VERSION` INT,
`FIRST_NAME` VARCHAR(64),
`LAST_NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `CATALOG` (
`ID` INT,
`VERSION` INT,
`DOMAIN` VARCHAR(64),
`KEY` VARCHAR(64),
`VALUE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
