INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 073784_web-app
#
CREATE DATABASE `db_073784_web_app`;
USE `db_073784_web_app`;
CREATE TABLE `scores` (
`student-id` VARCHAR(50),
`points` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`section` VARCHAR(50),
`student-id` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`student-id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_073784_web_app') AS relationships;
