CREATE DATABASE `db_069866_SCRIPT_TABLES`;
USE `db_069866_SCRIPT_TABLES`;
CREATE TABLE `AGENT` (
`EMP_ID` VARCHAR(64),
`A_NAME` VARCHAR(64),
`EMAIL` VARCHAR(64),
`A_LOC_ADD` VARCHAR(64),
PRIMARY KEY (`EMP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `A_REGION` (
`A_LOC_ADD` VARCHAR(64),
`A_REG` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`C_SSN` VARCHAR(64),
`C_NAME` VARCHAR(64),
`EMAIL` VARCHAR(64),
`C_LOC_ADD` VARCHAR(64),
`EMP_ID` VARCHAR(64),
PRIMARY KEY (`C_SSN`)
) CHARACTER SET latin1;
CREATE TABLE `C_REGION` (
`C_LOC_ADD` VARCHAR(64),
`C_REG` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `NOMINEE` (
`N_SSN` VARCHAR(64),
`N_NAME` VARCHAR(64),
`EMAIL` VARCHAR(64),
`N_LOC_ADD` VARCHAR(64),
`C_SSN` VARCHAR(64),
PRIMARY KEY (`N_SSN`)
) CHARACTER SET latin1;
CREATE TABLE `N_REGION` (
`N_LOC_ADD` VARCHAR(64),
`N_REG` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `INSURANCE` (
`I_ID` VARCHAR(64),
`PREMIUM` DECIMAL(10,2),
`ISSUE_DT` DATETIME,
`EXPIRY_DT` DATETIME,
`C_SSN` VARCHAR(64),
`EMP_ID` VARCHAR(64),
PRIMARY KEY (`I_ID`)
) CHARACTER SET latin1;
CREATE TABLE `HEALTH` (
`I_ID` VARCHAR(64),
`BMI` DECIMAL(10,2),
`GENETIC_DIS` VARCHAR(64),
`GEN_PHYS` VARCHAR(64),
PRIMARY KEY (`I_ID`)
) CHARACTER SET latin1;
CREATE TABLE `TRAVEL` (
`I_ID` VARCHAR(64),
`MODE_T` VARCHAR(64),
`REGION` VARCHAR(64),
`DURATION` VARCHAR(64),
PRIMARY KEY (`I_ID`)
) CHARACTER SET latin1;
