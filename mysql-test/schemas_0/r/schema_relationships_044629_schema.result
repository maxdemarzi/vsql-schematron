INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 044629_schema
#
CREATE DATABASE `db_044629_schema`;
USE `db_044629_schema`;
CREATE TABLE `authors` (
`id` INT,
`full_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`id` INT,
`title` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT,
`title` VARCHAR(64),
`publication_year` INT,
`author_id` INT,
`genre_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_comments` (
`id` INT,
`author` VARCHAR(64),
`text` VARCHAR(64),
`book_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`user_name` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_044629_schema') AS relationships;
relationships
Database: db_044629_schema

