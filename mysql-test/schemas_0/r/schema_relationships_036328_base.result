INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 036328_base
#
CREATE DATABASE `db_036328_base`;
USE `db_036328_base`;
CREATE TABLE `probs` (
`id` INT,
`question` VARCHAR(64),
`answer` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `learning` (
`probid` INT,
`next` DECIMAL(10,2),
`interval` DECIMAL(10,2),
PRIMARY KEY (`probid`)
) CHARACTER SET latin1;
CREATE TABLE `schema_version` (
`version` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `config` (
`key` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`key`)
) CHARACTER SET latin1;
CREATE TABLE `log` (
`stamp` DECIMAL(10,2),
`score` INT,
`probid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_036328_base') AS relationships;
