[Implied]  Rent.user_email -> App_User.user_email
[Implied]  Travel_Path.id_place_end -> Place.id_place
[Implied]  Travel_Path.id_place_start -> Place.id_place

DROP DATABASE `db_032850_LAPR3_criacao_base_dados`;
UNINSTALL EXTENSION vsql_schematron;
