CREATE DATABASE `db_088557_users`;
USE `db_088557_users`;
CREATE TABLE `messages` (
`id` INT,
`sender` INT,
`receiver` INT,
`message` VARCHAR(255),
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `register` (
`user_id` INT,
`user` VARCHAR(255),
`password` VARCHAR(255),
`information` VARCHAR(255),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_data` (
`user_id` INT,
`new_messages` VARCHAR(255),
`score` INT,
`sgc_points` INT
) CHARACTER SET latin1;
CREATE TABLE `wk_ud` (
`user_id` INT,
`categories` VARCHAR(255),
`write_test` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_088557_users') AS relationships;
