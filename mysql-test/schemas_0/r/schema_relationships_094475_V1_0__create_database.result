CREATE TABLE `city` (
`id` BIGINT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
`time_zone` VARCHAR(50),
`country_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `continent` (
`id` BIGINT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
`id` BIGINT NOT NULL,
`code` VARCHAR(50),
`name` VARCHAR(50),
`continent_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
