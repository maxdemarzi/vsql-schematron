INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 044115_ros_database
#
CREATE DATABASE `db_044115_ros_database`;
USE `db_044115_ros_database`;
CREATE TABLE `mes_types` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`x_par` VARCHAR(64),
`y_par` VARCHAR(64),
`t_par` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `robots` (
`id` INT,
`user_id` INT,
`ip_address` VARCHAR(64),
`port` VARCHAR(64),
`topic_id` INT
) CHARACTER SET latin1;
CREATE TABLE `topics` (
`id` INT,
`user_id` INT,
`name` VARCHAR(64),
`mes_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`activation_code` VARCHAR(64),
`activated` INT,
`forgotten_password_code` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`created` DATETIME,
`modified` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_044115_ros_database') AS relationships;
relationships
Database: db_044115_ros_database

Table Connections:
------------------
[Implied]  mes_types.user_id -> users.id
[Implied]  robots.topic_id -> topics.id
[Implied]  robots.user_id -> users.id
[Implied]  topics.mes_id -> mes_types.id
[Implied]  topics.user_id -> users.id

DROP DATABASE `db_044115_ros_database`;
UNINSTALL EXTENSION vsql_schematron;
