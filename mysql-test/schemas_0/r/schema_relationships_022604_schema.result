INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 022604_schema
#
CREATE DATABASE `db_022604_schema`;
USE `db_022604_schema`;
CREATE TABLE `Author` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`family_name` VARCHAR(50),
`date_of_birth` DATE,
`date_of_death` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Genre` (
`id` INT NOT NULL,
`genre_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Book` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`author` INT,
`summary` VARCHAR(50),
`isbn` VARCHAR(50),
`genre` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `BookInstance` (
`id` INT NOT NULL,
`book` INT,
`imprint` VARCHAR(50),
`instance_status` VARCHAR(50),
`due_back` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_022604_schema') AS relationships;
relationships
Database: db_022604_schema

Table Connections:
------------------
[Implied]  Book.author -> Author.id
[Implied]  Book.genre -> Genre.id
[Implied]  BookInstance.book -> Book.id

DROP DATABASE `db_022604_schema`;
UNINSTALL EXTENSION vsql_schematron;
