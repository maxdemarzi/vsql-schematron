CREATE DATABASE `db_092818_criarDB`;
USE `db_092818_criarDB`;
CREATE TABLE `tb_usuario` (
`cd_usuario` INT NOT NULL,
`nm_usuario` VARCHAR(50),
`pw_usuario` VARCHAR(50),
PRIMARY KEY (`cd_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `tb_contato` (
`cd_contato` INT NOT NULL,
`nm_contato` VARCHAR(50),
`nm_email` VARCHAR(50),
`fk_cd_usuario` INT,
PRIMARY KEY (`cd_contato`)
) CHARACTER SET latin1;
CREATE TABLE `tb_tel` (
`cd_tel` INT NOT NULL,
`nr_tel` CHAR(50),
`ddd_tel` CHAR(50),
`tp_tel` VARCHAR(50),
`fk_cd_contato` INT,
PRIMARY KEY (`cd_tel`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_092818_criarDB') AS relationships;
