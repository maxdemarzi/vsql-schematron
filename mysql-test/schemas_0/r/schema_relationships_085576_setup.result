INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 085576_setup
#
CREATE DATABASE `db_085576_setup`;
USE `db_085576_setup`;
CREATE TABLE `users` (
`id` INT,
`likes` INT
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT,
`type` INT,
`owner` INT,
`material` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `material_types` (
`id` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `materials` (
`id` INT,
`owner` INT,
`type` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_085576_setup') AS relationships;
relationships
