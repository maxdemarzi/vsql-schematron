INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 032054_hotel
#
CREATE DATABASE `db_032054_hotel`;
USE `db_032054_hotel`;
CREATE TABLE `administrateur` (
`id` INT NOT NULL,
`nom` VARCHAR(50),
`prenom` VARCHAR(50),
`fonction` VARCHAR(50),
`sexe` VARCHAR(50),
`service` VARCHAR(50),
`tel` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `commentaire` (
`id` INT NOT NULL,
`hotel_id` INT,
`texte` VARCHAR(50),
`email` VARCHAR(50),
`date` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hotel` (
`id` INT NOT NULL,
`nom` VARCHAR(50),
`region` VARCHAR(50),
`adresse` VARCHAR(50),
`ville` VARCHAR(50),
`code_postal` VARCHAR(50),
`pays` VARCHAR(50),
`tel` VARCHAR(50),
`commentaires` VARCHAR(50),
`nbre_etoiles` VARCHAR(50),
`etat` VARCHAR(50),
`hoteliers` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hotelier` (
`id` INT NOT NULL,
`hotel_id` INT,
`nom` VARCHAR(50),
`prenom` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `symfony_user` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_032054_hotel') AS relationships;
