INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 073065_schema
#
CREATE DATABASE `db_073065_schema`;
USE `db_073065_schema`;
CREATE TABLE `city` (
`id` INT,
`city` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `locationdata` (
`id` INT,
`city_id` INT,
`map_url` VARCHAR(64),
`city_url` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hoteldata` (
`id` INT,
`city_id` INT,
`hotel_image` VARCHAR(64),
`hotel_name` VARCHAR(64),
`hotel_price` VARCHAR(64),
`hotel_rate` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transportdata` (
`id` INT,
`city_id` INT,
`station_name` VARCHAR(64),
`station_type` VARCHAR(64),
`transport_price` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `booking` (
`id` INT,
`city` VARCHAR(64),
`map_url` VARCHAR(64),
`city_url` VARCHAR(64),
`time` VARCHAR(64),
`hotel_name` VARCHAR(64),
`hotel_price` VARCHAR(64),
`hotel_rate` VARCHAR(64),
`hotel_img` VARCHAR(64),
`station_name` VARCHAR(64),
`station_type` VARCHAR(64),
`transport_price` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_073065_schema') AS relationships;
relationships
Database: db_073065_schema

Table Connections:
------------------
[Implied]  hoteldata.city_id -> city.id
[Implied]  locationdata.city_id -> city.id
[Implied]  transportdata.city_id -> city.id

DROP DATABASE `db_073065_schema`;
UNINSTALL EXTENSION vsql_schematron;
