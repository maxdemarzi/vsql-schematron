INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 046821_schema
#
CREATE DATABASE `db_046821_schema`;
USE `db_046821_schema`;
CREATE TABLE `Person` (
`id` VARCHAR(50) NOT NULL,
`lastName` VARCHAR(50),
`firstName` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Contract` (
`id` VARCHAR(50) NOT NULL,
`number` VARCHAR(50),
`premium` DECIMAL(10,2),
`inceptionDate` DATE,
`signingTime` TIMESTAMP NULL,
`comments` VARCHAR(50),
`insuredPerson` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_046821_schema') AS relationships;
