CREATE DATABASE `db_021946_20140721_151024`;
USE `db_021946_20140721_151024`;
CREATE TABLE `organizations` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`notification_url` VARCHAR(64),
`cluster` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`id` INT,
`organization_id` INT,
`name` VARCHAR(64),
`cluster` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tokens` (
`id` INT,
`organization_id` INT,
`team_id` INT,
`description` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alerts` (
`id` INT,
`organization_id` INT,
`team_id` INT,
`description` VARCHAR(64),
`status` BOOL,
`handbook_url` VARCHAR(64),
`condition` VARCHAR(64),
`period` VARCHAR(64),
`routing` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `queries` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `alert_queries` (
`id` INT,
`alert_id` INT,
`query_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedulers` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`salt` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session_tokens` (
`id` INT,
`user_id` INT,
`token` VARCHAR(64),
`creation_time` DATETIME,
`expiration_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `confirmation_tokens` (
`id` INT,
`uuid` VARCHAR(64),
`email` VARCHAR(64),
`creation_time` DATETIME,
`expiration_time` DATETIME,
`is_sign_up` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `organization_users` (
`id` INT,
`organization_id` INT,
`user_id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `team_users` (
`id` INT,
`team_id` INT,
`user_id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
`id` INT,
`description` VARCHAR(64),
`since` DATETIME,
`until` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
