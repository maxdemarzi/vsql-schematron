) CHARACTER SET latin1;
CREATE TABLE `Courses` (
`CourseID` INT,
`Title` VARCHAR(64),
`MaxSize` INT,
PRIMARY KEY (`CourseID`)
) CHARACTER SET latin1;
CREATE TABLE `CurrentlyEnrolled` (
`CourseID` INT,
`StudentID` INT,
`Grade` DECIMAL(10,2),
PRIMARY KEY (`CourseID`, `StudentID`)
) CHARACTER SET latin1;
CREATE TABLE `CurrentlyTeaching` (
`CourseID` INT,
`ProfID` INT,
`Section` INT,
PRIMARY KEY (`CourseID`, `ProfID`)
) CHARACTER SET latin1;
