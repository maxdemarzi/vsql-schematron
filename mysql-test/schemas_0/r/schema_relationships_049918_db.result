INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 049918_db
#
CREATE DATABASE `db_049918_db`;
USE `db_049918_db`;
CREATE TABLE `users` (
`user_id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
`gender` VARCHAR(255),
`birthday` DATETIME,
`reg_date` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_files` (
`file_id` INT,
`user_id` INT,
`add_date` DATETIME,
`file_ext` VARCHAR(255),
`real_name` VARCHAR(255),
PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_049918_db') AS relationships;
