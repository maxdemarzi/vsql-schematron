CREATE DATABASE `db_042269_H1__Init`;
USE `db_042269_H1__Init`;
CREATE TABLE `subjects` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `time` (
`id` BIGINT NOT NULL,
`starttime` TIME,
`endtime` TIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `classrooms` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedule` (
`id` BIGINT,
`group_id` BIGINT,
`subject_id` BIGINT,
`day` INT,
`time_id` BIGINT,
`classroom_id` BIGINT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_042269_H1__Init') AS relationships;
