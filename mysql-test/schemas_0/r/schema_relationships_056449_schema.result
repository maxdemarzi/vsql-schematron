CREATE DATABASE `db_056449_schema`;
USE `db_056449_schema`;
CREATE TABLE `product` (
`product_id` INT NOT NULL,
`title` VARCHAR(50),
`description` VARCHAR(50),
`price` VARCHAR(50),
`quantity` VARCHAR(50),
`image` VARCHAR(50),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `cart` (
`id` INT NOT NULL,
`product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_056449_schema') AS relationships;
