CREATE DATABASE `db_000486_v1`;
USE `db_000486_v1`;
CREATE TABLE `pings` (
`id` VARCHAR(50) NOT NULL,
`date` INT,
`userId` TEXT,
`isFirstPing` INT,
`ip` TEXT,
`beakerVersion` TEXT,
`os` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
`id` VARCHAR(50) NOT NULL,
`computeDate` INT,
`activeUserCount` INT,
`totalUserCount` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `report_data` (
`reportId` TEXT,
`data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `report_active_user_cohorts` (
`reportId` TEXT,
`startWeek` TEXT,
`totalCount` INT,
`stillActiveCount` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_000486_v1') AS relationships;
