INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 056225_postgresql
#
CREATE DATABASE `db_056225_postgresql`;
USE `db_056225_postgresql`;
CREATE TABLE `logging_event` (
`sequence_number` INT,
`timestamp` INT,
`rendered_message` VARCHAR(64),
`logger_name` VARCHAR(64),
`level_string` VARCHAR(64),
`ndc` VARCHAR(64),
`thread_name` VARCHAR(64),
`reference_flag` INT,
`caller_filename` VARCHAR(64),
`caller_class` VARCHAR(64),
`caller_method` VARCHAR(64),
`caller_line` VARCHAR(64),
`event_id` INT,
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `logging_event_property` (
`event_id` INT,
`mapped_key` VARCHAR(64),
`mapped_value` VARCHAR(64),
PRIMARY KEY (`event_id`, `mapped_key`)
) CHARACTER SET latin1;
CREATE TABLE `logging_event_exception` (
`event_id` INT,
`i` INT,
`trace_line` VARCHAR(64),
PRIMARY KEY (`event_id`, `i`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_056225_postgresql') AS relationships;
relationships
