`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`department_name` TEXT,
`role_salary` INT,
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_020932_schema') AS relationships;
