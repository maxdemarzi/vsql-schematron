INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 072441_geek-text-def
#
CREATE DATABASE `db_072441_geek_text_def`;
USE `db_072441_geek_text_def`;
CREATE TABLE `Author` (
`authorID` INT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`bio` VARCHAR(50),
PRIMARY KEY (`authorID`)
) CHARACTER SET latin1;
CREATE TABLE `Book` (
`bookID` INT NOT NULL,
`title` VARCHAR(50),
`genre` VARCHAR(50),
`authorID` INT,
PRIMARY KEY (`bookID`)
) CHARACTER SET latin1;
CREATE TABLE `BookInfo` (
`bookID` INT,
`totalSold` INT,
`rating` INT,
`price` DECIMAL(10,2),
`releaseDate` DATE
) CHARACTER SET latin1;
CREATE TABLE `Feedback` (
`userID` INT,
`bookID` INT,
`rating` INT,
`comment` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Credentials` (
`userID` INT,
`pw` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `PaymentInfo` (
`userID` INT,
`ccNum` INT NOT NULL,
`cvc` INT,
`expDate` DATE,
`city` VARCHAR(50),
`state` VARCHAR(50),
`zip` INT,
`street` VARCHAR(50),
PRIMARY KEY (`ccNum`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_072441_geek_text_def') AS relationships;
relationships
Database: db_072441_geek_text_def

Table Connections:
------------------
[Implied]  Book.authorID -> Author.authorID
[Implied]  BookInfo.bookID -> Book.bookID
[Implied]  Feedback.bookID -> Book.bookID

DROP DATABASE `db_072441_geek_text_def`;
UNINSTALL EXTENSION vsql_schematron;
