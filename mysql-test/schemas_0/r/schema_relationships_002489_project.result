INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002489_project
#
CREATE DATABASE `db_002489_project`;
USE `db_002489_project`;
CREATE TABLE `projects` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`process` VARCHAR(50),
`current_iteration` INT,
`start_date` DATE,
`end_date` DATE,
`version` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_members` (
`project` INT,
`member` INT,
`role` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `iterations` (
`id` INT NOT NULL,
`project` INT,
`iteration` VARCHAR(50),
`number` INT,
`start_date` DATE,
`end_date` DATE,
`current_activity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `activities` (
`id` INT NOT NULL,
`iteration` INT,
`current_task` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT NOT NULL,
`task` VARCHAR(50),
`member` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artifacts` (
`id` INT NOT NULL,
`artifact` VARCHAR(50),
`filename` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task_artifacts` (
`task` INT,
`artifact` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002489_project') AS relationships;
relationships
