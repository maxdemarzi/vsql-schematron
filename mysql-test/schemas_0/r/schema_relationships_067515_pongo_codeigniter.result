) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`product_name` VARCHAR(64),
`price` INT,
`stock` INT,
`images` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `settings` (
`id` INT,
`meta_key` VARCHAR(64),
`meta_value` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` INT,
