INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 009958_init_tables
#
CREATE DATABASE `db_009958_init_tables`;
USE `db_009958_init_tables`;
CREATE TABLE `bm_book` (
`id` INT,
`book_name` VARCHAR(255),
`author` VARCHAR(255),
`price` DECIMAL(10,2),
`stock` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bm_admin` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`phone` VARCHAR(255),
`email` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bm_user` (
`id` INT,
`username` VARCHAR(255),
`password` VARCHAR(255),
`phone` VARCHAR(255),
`email` VARCHAR(255),
`status` INT,
`level` INT,
`available_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bm_order_rent` (
`id` INT,
`user_id` INT,
`rent_date` DATETIME,
`planned_return_date` DATETIME,
`return_date` DATETIME,
`is_returned` INT,
`book_count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bm_order_rent_detail` (
`id` INT,
`order_id` INT,
`book_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_009958_init_tables') AS relationships;
relationships
Database: db_009958_init_tables

Table Connections:
------------------
[Implied]  bm_order_rent.user_id -> bm_user.id
[Implied]  bm_order_rent_detail.book_id -> bm_book.id
[Implied]  bm_order_rent_detail.order_id -> bm_order_rent.id

DROP DATABASE `db_009958_init_tables`;
UNINSTALL EXTENSION vsql_schematron;
