CREATE DATABASE `db_041563_mysql_3`;
USE `db_041563_mysql_3`;
CREATE TABLE `user` (
`id` INT,
`name` VARCHAR(64),
`passwd` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pyq` (
`id` INT,
`image` VARCHAR(64),
`content` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mylike` (
`id` INT,
`uid` INT,
`pid` INT,
`comment` VARCHAR(64),
`lk` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_041563_mysql_3') AS relationships;
