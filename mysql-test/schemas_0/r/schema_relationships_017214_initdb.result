INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 017214_initdb
#
CREATE DATABASE `db_017214_initdb`;
USE `db_017214_initdb`;
CREATE TABLE `portfolio` (
`portfolioId` INT,
`clientId` VARCHAR(255),
`total` DECIMAL(10,2),
`loyalty` VARCHAR(255),
`balance` DECIMAL(10,2),
`commissions` DECIMAL(10,2),
`freeTrades` INT,
PRIMARY KEY (`portfolioId`)
) CHARACTER SET latin1;
CREATE TABLE `stock` (
`portfolioId` INT,
`symbol` VARCHAR(255),
`shares` INT,
`price` DECIMAL(10,2),
`total` DECIMAL(10,2),
`lastQuoted` DATETIME,
`commission` DECIMAL(10,2),
PRIMARY KEY (`portfolioId`, `symbol`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`clientId` VARCHAR(255),
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`email` VARCHAR(255),
`phone` VARCHAR(255),
`preferredContactMethod` VARCHAR(255),
`salesforceContactId` VARCHAR(255),
PRIMARY KEY (`clientId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_017214_initdb') AS relationships;
relationships
Database: db_017214_initdb

Table Connections:
------------------
[Implied]  portfolio.clientId -> client.clientId
[Implied]  stock.portfolioId -> portfolio.portfolioId

DROP DATABASE `db_017214_initdb`;
UNINSTALL EXTENSION vsql_schematron;
