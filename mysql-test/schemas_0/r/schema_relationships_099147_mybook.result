CREATE DATABASE `db_099147_mybook`;
USE `db_099147_mybook`;
CREATE TABLE `customer` (
`id` VARCHAR(50) NOT NULL,
`lastname` VARCHAR(50),
`firstname` VARCHAR(50),
`street_number` VARCHAR(50),
`street_address` VARCHAR(50),
`area_code` VARCHAR(50),
`city` VARCHAR(50),
`personnal_code` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`author` VARCHAR(50),
`release_date` DATE,
`category` VARCHAR(50),
`status` VARCHAR(50),
`summary` TEXT,
`customer_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_099147_mybook') AS relationships;
