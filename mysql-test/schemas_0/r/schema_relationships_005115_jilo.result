INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005115_jilo
#
CREATE DATABASE `db_005115_jilo`;
USE `db_005115_jilo`;
CREATE TABLE `article` (
`id` INT,
`title` VARCHAR(255),
`text` VARCHAR(255),
`activated` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authority` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`article_id` INT,
`text` VARCHAR(255),
`activated` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`login` VARCHAR(255),
`password` VARCHAR(255),
`activated` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_authority` (
`user_id` INT,
`authorithy_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005115_jilo') AS relationships;
