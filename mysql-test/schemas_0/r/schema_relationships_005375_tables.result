INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005375_tables
#
CREATE DATABASE `db_005375_tables`;
USE `db_005375_tables`;
CREATE TABLE `cameras` (
`id` INT NOT NULL,
`location` TEXT,
`resolution_x` INT,
`resolution_y` INT,
`fps` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spots` (
`id` VARCHAR(50) NOT NULL,
`camera_id` INT,
`location` VARCHAR(50),
`is_occupied` BOOLEAN,
`occupied_time` TIME,
`is_overtime` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005375_tables') AS relationships;
