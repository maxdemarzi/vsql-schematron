CREATE DATABASE `db_045867_10_base_tables`;
USE `db_045867_10_base_tables`;
CREATE TABLE `permissions` (
`id` INT NOT NULL,
`permission` VARCHAR(50),
`restricted` BOOLEAN,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `grouptypes` (
`id` INT NOT NULL,
`grouptype` VARCHAR(50),
`description` VARCHAR(50),
`who_may_join` VARCHAR(50),
`private_list` BOOLEAN,
`public_list` BOOLEAN,
`folder_type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission_to_grouptype` (
`permission_id` INT NOT NULL,
`grouptype_id` INT NOT NULL,
PRIMARY KEY (`permission_id`, `grouptype_id`)
) CHARACTER SET latin1;
