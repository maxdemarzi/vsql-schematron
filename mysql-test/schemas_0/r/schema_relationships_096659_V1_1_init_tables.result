INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 096659_V1_1_init_tables
#
CREATE DATABASE `db_096659_V1_1_init_tables`;
USE `db_096659_V1_1_init_tables`;
CREATE TABLE `judicial_user_profile` (
`per_Id` VARCHAR(64),
`personal_code` VARCHAR(64),
`appointment` VARCHAR(64),
`known_as` VARCHAR(64),
`surname` VARCHAR(64),
`full_name` VARCHAR(64),
`post_nominals` VARCHAR(64),
`appointment_type` VARCHAR(64),
`work_pattern` VARCHAR(64),
`ejudiciary_email` VARCHAR(64),
`joining_date` DATETIME,
`last_working_date` DATETIME,
`active_flag` VARCHAR(64),
`extracted_date` DATETIME,
`created_date` DATETIME,
`last_loaded_date` DATETIME,
PRIMARY KEY (`per_Id`)
) CHARACTER SET latin1;
CREATE TABLE `judicial_office_appointment` (
`judicial_office_appointment_id` INT,
`per_Id` VARCHAR(64),
`personal_code` VARCHAR(64),
`base_location_id` VARCHAR(64),
`region_id` VARCHAR(64),
`is_prinicple_appointment` VARCHAR(64),
`start_date` DATETIME,
`end_date` DATETIME,
`active_flag` VARCHAR(64),
`extracted_date` DATETIME,
`created_date` DATETIME,
`last_loaded_date` DATETIME,
PRIMARY KEY (`judicial_office_appointment_id`)
) CHARACTER SET latin1;
CREATE TABLE `judicial_office_authorisation` (
`judicial_office_auth_id` INT,
`per_id` VARCHAR(64),
`personal_code` VARCHAR(64),
`jurisdiction` VARCHAR(64),
`ticket_id` INT,
`start_date` DATETIME,
`end_date` DATETIME,
`created_date` DATETIME,
`last_updated` DATETIME,
`lower_level` VARCHAR(64),
PRIMARY KEY (`judicial_office_auth_id`)
) CHARACTER SET latin1;
CREATE TABLE `base_location_type` (
`base_location_id` VARCHAR(64),
`court_name` VARCHAR(64),
`court_type` VARCHAR(64),
`circuit` VARCHAR(64),
`area_of_expertise` VARCHAR(64),
PRIMARY KEY (`base_location_id`)
) CHARACTER SET latin1;
CREATE TABLE `region_type` (
`region_id` VARCHAR(64),
`region_desc_en` VARCHAR(64),
`region_desc_cy` VARCHAR(64),
PRIMARY KEY (`region_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_096659_V1_1_init_tables') AS relationships;
