[Implied]  employee_table.manager_id -> employee_table.employee_id
[Implied]  employee_table.role_id -> role_table.role_id
[Implied]  role_table.dept_id -> dept_table.dept_id

DROP DATABASE `db_055803_schema`;
UNINSTALL EXTENSION vsql_schematron;
