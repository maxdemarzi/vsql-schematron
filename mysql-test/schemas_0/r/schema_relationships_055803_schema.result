INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 055803_schema
#
CREATE DATABASE `db_055803_schema`;
USE `db_055803_schema`;
CREATE TABLE `dept_table` (
`dept_id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `role_table` (
`role_id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee_table` (
`employee_id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_055803_schema') AS relationships;
relationships
Database: db_055803_schema

Table Connections:
