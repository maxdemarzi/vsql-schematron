`name` VARCHAR(64),
`type` VARCHAR(64),
`data` VARCHAR(64),
`created_time` DATETIME,
`updated_time` DATETIME,
`etag` VARCHAR(64),
PRIMARY KEY (`parent`, `result_id`, `id`)
) CHARACTER SET latin1;
