INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 068125_MAPA
#
CREATE DATABASE `db_068125_MAPA`;
USE `db_068125_MAPA`;
CREATE TABLE `TIPO_PRODUTO` (
`ID` INT NOT NULL,
`DESCRICAO` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TIPO_PAGAMENTO` (
`ID` INT NOT NULL,
`DESCRICAO` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PRODUTOS` (
`ID` INT NOT NULL,
`DESCRICAO` VARCHAR(50),
`VALOR` DECIMAL(10,2),
`ID_TIPO_PRODUTO` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOS` (
`ID` INT NOT NULL,
`DATAB` DATE,
`ID_TIPO_PAGAMENTO` INT,
`VALOR_TOTAL` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PEDIDOS_PRODUTOS` (
`ID` INT NOT NULL,
`ID_PEDIDO` INT,
`ID_PRODUTO` INT,
`QTDE` INT,
`VALOR_UNIT` DECIMAL(10,2),
`VALOR_TOTAL` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_068125_MAPA') AS relationships;
relationships
Database: db_068125_MAPA

Table Connections:
------------------
[Implied]  PEDIDOS.ID_TIPO_PAGAMENTO -> TIPO_PAGAMENTO.ID
[Implied]  PEDIDOS_PRODUTOS.ID_PEDIDO -> PEDIDOS.ID
