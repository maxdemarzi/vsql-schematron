CREATE TABLE `language` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`label` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `collection` (
`id` INT NOT NULL,
`language_id` INT,
`name` VARCHAR(50),
`label` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `field` (
`id` INT NOT NULL,
`collection_id` INT,
`language_id` INT,
`name` VARCHAR(50),
`type` VARCHAR(50),
`value` TEXT,
`label` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `options` (
`id` INT NOT NULL,
`text` TEXT,
`field_id` INT,
`language_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
