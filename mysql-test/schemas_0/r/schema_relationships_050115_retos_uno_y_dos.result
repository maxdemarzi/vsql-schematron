INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 050115_retos_uno_y_dos
#
CREATE DATABASE `db_050115_retos_uno_y_dos`;
USE `db_050115_retos_uno_y_dos`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`genero` VARCHAR(50),
`edad` INT,
`ocup` INT,
`cp` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`id_movie` INT NOT NULL,
`title` VARCHAR(50),
`geners` VARCHAR(50),
PRIMARY KEY (`id_movie`)
) CHARACTER SET latin1;
CREATE TABLE `rating` (
`id_users` INT,
`id_movie` INT,
`ratings` INT,
`time_stamp` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_050115_retos_uno_y_dos') AS relationships;
