PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `URLS` (
`id` INT,
`url_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USERS_URLS` (
`id` INT,
`user_id` INT,
`url_id` INT,
`is_owner` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `DIRS` (
`id` INT,
`dir_name` VARCHAR(64),
`url_id` INT,
`parent_dir` INT,
`is_root` BOOL,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PAGES` (
`id` INT,
`page_name` VARCHAR(64),
`page_code` VARCHAR(64),
`url_id` INT,
`sub_url` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CONTENT_STRINGS` (
`id` INT,
