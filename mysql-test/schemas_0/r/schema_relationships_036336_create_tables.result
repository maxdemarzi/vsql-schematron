CREATE TABLE `USERS` (
`id` INT,
`email` VARCHAR(64),
`nick_name` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`password_hash` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ROLES` (
`id` INT,
`role_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `USER_ROLES` (
`id` INT,
