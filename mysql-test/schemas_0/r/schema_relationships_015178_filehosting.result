INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 015178_filehosting
#
CREATE DATABASE `db_015178_filehosting`;
USE `db_015178_filehosting`;
CREATE TABLE `files` (
`id` INT NOT NULL,
`name` CHAR(50),
`original_name` CHAR(50),
`path` CHAR(50),
`thumbnail_path` CHAR(50),
`description` CHAR(50),
`size` INT,
`mime_type` CHAR(50),
`date` TIMESTAMP NULL,
`downloads` INT,
`user_id` INT,
`user_token` CHAR(50),
`media_info` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` CHAR(50),
`avatar` CHAR(50),
`email` CHAR(50),
`password` CHAR(50),
`auth_token` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`file_id` INT,
`parent_id` INT,
`user_id` INT,
`date` TIMESTAMP NULL,
`text` CHAR(50),
`matpath` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_015178_filehosting') AS relationships;
relationships
Database: db_015178_filehosting

Table Connections:
------------------
[Implied]  comments.file_id -> files.id
[Implied]  comments.parent_id -> comments.id
[Implied]  comments.user_id -> users.id
[Implied]  files.user_id -> users.id

DROP DATABASE `db_015178_filehosting`;
UNINSTALL EXTENSION vsql_schematron;
