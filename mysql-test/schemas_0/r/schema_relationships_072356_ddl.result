CREATE TABLE `users` (
`id` INT,
`Email` VARCHAR(64),
`firstname` VARCHAR(64),
`surname` VARCHAR(64),
`avatar` VARCHAR(64),
`active` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
