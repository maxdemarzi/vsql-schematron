INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 004543_db
#
CREATE DATABASE `db_004543_db`;
USE `db_004543_db`;
CREATE TABLE `produtos` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
`estoque_minimo` INT,
`estoque_maximo` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `compras` (
`id` INT NOT NULL,
`produto_id` INT,
`quantidade` INT,
`valor_unitario` DECIMAL(10,2),
`data` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `estoques` (
`id` INT NOT NULL,
`produto_id` INT,
`quantidade` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vendas` (
`id` INT NOT NULL,
`produto_id` INT,
`quantidade` INT,
`data` DATE,
`valor_unitario` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_004543_db') AS relationships;
relationships
Database: db_004543_db

