`address_line2` VARCHAR(255),
`town` VARCHAR(255),
`county` VARCHAR(255),
`postcode` VARCHAR(255),
`is_mapped` VARCHAR(255),
`manual_mapping` VARCHAR(255),
`last_updated` DATETIME,
PRIMARY KEY (`ods_code`)
) CHARACTER SET latin1;
