CREATE DATABASE `db_002810_migration`;
USE `db_002810_migration`;
CREATE TABLE `account` (
`user_id` INT NOT NULL,
`username` TEXT,
`password` TEXT,
`is_admin` BOOLEAN,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `event` (
`event_id` INT NOT NULL,
`website_id` INT,
`session_id` INT,
`created_at` DATETIME,
`url` TEXT,
`event_type` TEXT,
`event_value` TEXT,
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `pageview` (
`view_id` INT NOT NULL,
`website_id` INT,
`session_id` INT,
`created_at` DATETIME,
`url` TEXT,
`referrer` TEXT,
PRIMARY KEY (`view_id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
`session_id` INT NOT NULL,
`session_uuid` TEXT,
`website_id` INT,
`created_at` DATETIME,
`hostname` TEXT,
`browser` TEXT,
`os` TEXT,
`device` TEXT,
`screen` TEXT,
`language` TEXT,
`country` TEXT,
PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `website` (
`website_id` INT NOT NULL,
`website_uuid` TEXT,
`user_id` INT,
`name` TEXT,
`domain` TEXT,
`share_id` TEXT,
`created_at` DATETIME,
PRIMARY KEY (`website_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002810_migration') AS relationships;
