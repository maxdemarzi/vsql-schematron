`service_number` VARCHAR(64),
`reg_date` DATETIME,
`bar_number` VARCHAR(64),
`prosecutor_team` INT,
`law_firm` INT,
`phone` VARCHAR(64),
`complaint` INT,
`prison` INT,
`court` INT,
`bail` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hearing` (
`id` INT,
