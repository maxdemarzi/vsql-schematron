PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `complaint` (
`id` INT,
`complainant` INT,
`police` INT,
`police_station` INT,
`statement` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `case` (
`id` INT,
