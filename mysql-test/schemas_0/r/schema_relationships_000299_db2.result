`prosecutor_team` INT,
`complainant` INT,
`offender` INT,
`defense_att` INT,
`court` INT,
`judge` INT,
`prison` INT,
`case_type` INT,
`case_status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bail` (
`id` INT,
`hearing` INT,
`amount` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
