INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 080451_students
#
CREATE DATABASE `db_080451_students`;
USE `db_080451_students`;
CREATE TABLE `Modules` (
`code` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Programmes` (
`id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Programme_Modules` (
`programme` VARCHAR(64),
`module` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
`id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Student_Programme` (
`id` VARCHAR(64),
`programme` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_080451_students') AS relationships;
relationships
Database: db_080451_students

Table Connections:
------------------
[Implied]  Programme_Modules.module -> Modules.code
[Implied]  Programme_Modules.programme -> Programmes.id
[Implied]  Student_Programme.id -> Students.id
[Implied]  Student_Programme.programme -> Programmes.id

DROP DATABASE `db_080451_students`;
UNINSTALL EXTENSION vsql_schematron;
