CREATE DATABASE `db_030300_hospital`;
USE `db_030300_hospital`;
CREATE TABLE `admin` (
`ID` VARCHAR(64),
`title` VARCHAR(64),
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`gender` VARCHAR(64),
`dob` DATETIME,
`tel` VARCHAR(64),
`nic` VARCHAR(64),
`address` VARCHAR(64),
`email` VARCHAR(64),
`pwd` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `diagnosis` (
`UPIN` VARCHAR(64),
`date` DATETIME,
`bmi` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `doctor` (
`ID` VARCHAR(64),
`title` VARCHAR(64),
`fname` VARCHAR(64),
`lname` VARCHAR(64),
`gender` VARCHAR(64),
`dob` DATETIME,
`tel` VARCHAR(64),
