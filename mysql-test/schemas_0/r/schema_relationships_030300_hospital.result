`address` VARCHAR(64),
`mlicense` VARCHAR(64),
`speciality` VARCHAR(64),
`email` VARCHAR(64),
`pwd` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
`UPIN` VARCHAR(64),
`title` VARCHAR(64),
`fName` VARCHAR(64),
`lName` VARCHAR(64),
`Gender` VARCHAR(64),
`DOB` DATETIME,
`Address` VARCHAR(64),
`tele` INT,
`email` VARCHAR(64),
PRIMARY KEY (`UPIN`)
) CHARACTER SET latin1;
CREATE TABLE `pharmacist` (
`ID` VARCHAR(64),
