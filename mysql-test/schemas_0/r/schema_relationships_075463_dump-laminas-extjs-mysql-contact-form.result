CREATE DATABASE `db_075463_dump_laminas_extjs_mysql_contact_form`;
USE `db_075463_dump_laminas_extjs_mysql_contact_form`;
CREATE TABLE `images` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`image` VARCHAR(50),
`deleted_at` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `priorities` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `forms` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`priority_id` VARCHAR(50),
`email` VARCHAR(50),
`birthdate` DATE,
`company` VARCHAR(50),
`profession` VARCHAR(50),
`notes` TEXT,
`phone_home` VARCHAR(50),
`phone_business` VARCHAR(50),
`phone_mobile` VARCHAR(50),
`fax` VARCHAR(50),
`biography` TEXT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_075463_dump_laminas_extjs_mysql_contact_form') AS relationships;
