INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 003219_load
#
CREATE DATABASE `db_003219_load`;
USE `db_003219_load`;
CREATE TABLE `wishlist_types` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mtu_list` (
`id` VARCHAR(50) NOT NULL,
`city` VARCHAR(50),
`mtu_name` VARCHAR(50),
`mtu_code` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mtu_analysis` (
`id` VARCHAR(50) NOT NULL,
`analysis_option` VARCHAR(50),
`mtu` VARCHAR(50),
`result` DECIMAL(10,2),
`year` INT,
`notes` TEXT,
`url` TEXT,
`source_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `data` (
`id` VARCHAR(50) NOT NULL,
`case_study` VARCHAR(50),
`result` DECIMAL(10,2),
`year` INT,
`notes` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_003219_load') AS relationships;
relationships
