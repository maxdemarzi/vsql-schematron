INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002270_schema
#
CREATE DATABASE `db_002270_schema`;
USE `db_002270_schema`;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`access_token` VARCHAR(50),
`mastodon_id` BIGINT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `snapshots` (
`id` BIGINT NOT NULL,
`owner` BIGINT,
`snap_type` VARCHAR(50),
`status` VARCHAR(50),
`bucket` VARCHAR(50),
`key` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002270_schema') AS relationships;
