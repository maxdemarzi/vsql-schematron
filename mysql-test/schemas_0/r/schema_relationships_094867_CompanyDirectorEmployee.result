CREATE DATABASE `db_094867_CompanyDirectorEmployee`;
USE `db_094867_CompanyDirectorEmployee`;
CREATE TABLE `attendance` (
`attendee_person_id` INT,
`meeting_id` INT,
PRIMARY KEY (`attendee_person_id`, `meeting_id`)
) CHARACTER SET latin1;
CREATE TABLE `company` (
`company_id` INT,
`company_name` VARCHAR(64),
`is_listed` BOOL,
PRIMARY KEY (`company_id`)
) CHARACTER SET latin1;
CREATE TABLE `directorship` (
`directorship_id` INT,
`director_person_id` INT,
`company_id` INT,
`appointment_date` DATETIME,
PRIMARY KEY (`directorship_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_id` INT,
`employee_nr` INT,
`company_id` INT,
`manager_employee_id` INT,
`manager_is_ceo` BOOL,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `employment` (
`person_id` INT,
`employee_id` INT,
PRIMARY KEY (`person_id`, `employee_id`)
) CHARACTER SET latin1;
CREATE TABLE `meeting` (
`meeting_id` INT,
`company_id` INT,
`date` DATETIME,
`is_board_meeting` BOOL,
PRIMARY KEY (`meeting_id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`person_id` INT,
`given_name` VARCHAR(64),
`family_name` VARCHAR(64),
`birth_date` DATETIME,
PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
