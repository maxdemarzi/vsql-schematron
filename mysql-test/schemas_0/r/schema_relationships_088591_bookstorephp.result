INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 088591_bookstorephp
#
CREATE DATABASE `db_088591_bookstorephp`;
USE `db_088591_bookstorephp`;
CREATE TABLE `account` (
`id` INT,
`full_name` VARCHAR(64),
`user_name` VARCHAR(64),
`pwd` VARCHAR(64),
`image` VARCHAR(64),
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `author` (
`id` INT,
`full_name` VARCHAR(64),
`date_of_brith` DATETIME,
`country` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT,
`author_id` INT,
`title` VARCHAR(64),
`image` VARCHAR(64),
`price` DECIMAL(10,2),
`publish_year` INT,
`category_id` INT,
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cartitem` (
`id` INT,
`account_id` INT,
`quantity` INT,
`book_id` INT,
`order_date` DATETIME,
`status` INT,
`shipping_id` INT
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `shipping` (
`id` INT,
`account_id` INT,
`card_owner` VARCHAR(64),
`card_number` INT,
`address` VARCHAR(64),
`city` VARCHAR(64),
`number_phone` INT,
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_088591_bookstorephp') AS relationships;
relationships
Database: db_088591_bookstorephp

Table Connections:
