INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 021251_schema
#
CREATE DATABASE `db_021251_schema`;
USE `db_021251_schema`;
CREATE TABLE `department` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`role_id` INT,
`title` VARCHAR(64),
`salary` INT,
`department_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_021251_schema') AS relationships;
relationships
Database: db_021251_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.employee_id
[Implied]  employee.role_id -> role.role_id
[Implied]  role.department_id -> department.id

DROP DATABASE `db_021251_schema`;
UNINSTALL EXTENSION vsql_schematron;
