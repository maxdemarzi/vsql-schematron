INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 009284_geek-text-def
#
CREATE DATABASE `db_009284_geek_text_def`;
USE `db_009284_geek_text_def`;
CREATE TABLE `book` (
`bookid` INT NOT NULL,
`title` VARCHAR(50),
`genre` VARCHAR(50),
`author` VARCHAR(50),
`rating` INT,
`price` DOUBLE,
`date` DATE,
`sales` INT,
`imagelink` VARCHAR(50),
`topseller` BOOLEAN,
PRIMARY KEY (`bookid`)
) CHARACTER SET latin1;
CREATE TABLE `credentials` (
`userid` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `userinfo` (
`userid` VARCHAR(50),
`email` VARCHAR(50),
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`homestate` VARCHAR(50),
`homecity` VARCHAR(50),
`homeaddress` VARCHAR(50),
`nickname` VARCHAR(50),
`password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `paymentinfo` (
`userid` VARCHAR(50),
`ccnum` INT,
`cvv` INT,
`name` VARCHAR(50),
`zip` INT,
`expdate` DATE
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
`userid` VARCHAR(50),
`state` VARCHAR(50),
`city` VARCHAR(50),
`address` VARCHAR(50),
`zip` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_009284_geek_text_def') AS relationships;
relationships
Database: db_009284_geek_text_def

Table Connections:
