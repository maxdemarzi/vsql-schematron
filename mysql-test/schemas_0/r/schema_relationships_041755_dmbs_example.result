[Implied]  rate.customer_id -> customer.id
[Implied]  rate.movie_id -> movie.id
[Implied]  room.theater_id -> theater.id
[Implied]  seat.room_id -> room.id
[Implied]  seat.session_id -> sessions.id
[Implied]  seat.theater_id -> theater.id
[Implied]  sessions.movie_id -> movie.id
[Implied]  sessions.room_id -> room.id
[Implied]  sessions.theater_id -> theater.id
[Implied]  ticket.customer_id -> customer.id
[Implied]  ticket.movie_id -> movie.id
[Implied]  ticket.room_id -> room.id
[Implied]  ticket.seat_id -> seat.id
[Implied]  ticket.session_id -> sessions.id
[Implied]  ticket.theater_id -> theater.id

DROP DATABASE `db_041755_dmbs_example`;
UNINSTALL EXTENSION vsql_schematron;
