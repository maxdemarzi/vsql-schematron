CREATE TABLE `application` (
`id` INT,
`uid` VARCHAR(64),
`name` VARCHAR(64),
`version` VARCHAR(64),
`require_promo_code_for_registration` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
`id` INT,
