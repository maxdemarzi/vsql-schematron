`name` VARCHAR(64),
`geo_json` VARCHAR(64),
`geom` VARCHAR(64),
`address_1` VARCHAR(64),
`address_2` VARCHAR(64),
`city` VARCHAR(64),
`county` VARCHAR(64),
`state` VARCHAR(64),
`country` VARCHAR(64),
`postal_code` VARCHAR(64),
`attributes_json` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `license_type` (
`id` INT,
`application_id` INT,
`name` VARCHAR(64),
`license_type_key` VARCHAR(64),
`active` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `promo_code` (
`id` INT,
