CREATE DATABASE `db_008664_Invite`;
USE `db_008664_Invite`;
CREATE TABLE `Invite` (
`token` VARCHAR(64),
`email` VARCHAR(64),
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`text` VARCHAR(64),
`sentTime` DATETIME,
`sentBy` INT,
PRIMARY KEY (`token`)
) CHARACTER SET latin1;
CREATE TABLE `InviteAcceptAction` (
`invite` VARCHAR(64),
`memberAction` INT,
PRIMARY KEY (`invite`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_008664_Invite') AS relationships;
