CREATE DATABASE `db_020797_football`;
USE `db_020797_football`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`active` BOOL,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stat` (
`id` INT,
`speed` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `players` (
`id` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`img` VARCHAR(64),
`team_id` INT,
`stat_id` INT,
`pos` VARCHAR(64),
`num` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
