INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 030464_000001_init_schema_up
#
CREATE DATABASE `db_030464_000001_init_schema_up`;
USE `db_030464_000001_init_schema_up`;
CREATE TABLE `accounts` (
`id` INT,
`owner` VARCHAR(255),
`citizenship` VARCHAR(255),
`balance` INT,
`currency` VARCHAR(255),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entries` (
`id` INT,
`account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transfers` (
`id` INT,
`from_account_id` INT,
`to_account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transfers_bank` (
`id` INT,
`account_id` INT,
`bank_account_id` INT,
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_030464_000001_init_schema_up') AS relationships;
relationships
Database: db_030464_000001_init_schema_up

