CREATE DATABASE `db_053914_db`;
USE `db_053914_db`;
CREATE TABLE `roles` (
`id` INT,
`name` VARCHAR(64),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment_methods` (
`id` INT,
`name` VARCHAR(64),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_category` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_stock` (
`id` INT,
`quantity` INT,
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `discount` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`percentage` DECIMAL(10,2),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`SKU` VARCHAR(64),
`name` VARCHAR(64),
`description` VARCHAR(64),
`unit_price` INT,
`discount_id` INT,
`size` VARCHAR(64),
`color` VARCHAR(64),
`weight` VARCHAR(64),
`category_id` INT,
`stock_id` INT,
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_rating` (
`id` INT,
`product_id` INT,
`rating` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
`role_id` INT,
`status` BOOL,
`email_verified_at` DATETIME,
`password` VARCHAR(64),
`remember_token` VARCHAR(64),
`created_by` INT,
`updated_by` INT,
`deleted_by` INT,
`restored_by` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
`restored_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_payment` (
`id` INT,
`user_id` INT,
`payment_id` INT,
`provider` VARCHAR(64),
`account_no` VARCHAR(64),
`status` BOOL,
`expiry` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_address` (
`id` INT,
`user_id` INT,
`latitude` INT,
`longitude` INT,
`name` VARCHAR(64),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shopping_session` (
`id` INT,
`user_id` INT,
`total` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cart_item` (
`id` INT,
`session_id` INT,
`product_id` INT,
`quantity` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`user_id` INT,
`payment_id` INT,
`total` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payment_details` (
`id` INT,
`order_id` INT,
`amount` INT,
`provider` VARCHAR(64),
`status` BOOL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`id` INT,
`product_id` INT,
`order_id` INT,
`quantity` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `suppliers` (
`id` INT,
`name` VARCHAR(64),
`contact_person` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
`address` VARCHAR(64),
`status` BOOL,
`created_by` INT,
`updated_by` INT,
`deleted_by` INT,
`restored_by` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
`restored_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
