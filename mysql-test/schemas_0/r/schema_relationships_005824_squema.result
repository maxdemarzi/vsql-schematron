[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  salaries.emp_no -> employees.emp_no
[Implied]  titles.emp_no -> employees.emp_no

DROP DATABASE `db_005824_squema`;
UNINSTALL EXTENSION vsql_schematron;
