INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005824_squema
#
CREATE DATABASE `db_005824_squema`;
USE `db_005824_squema`;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`emp_no` INT,
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`gender` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(64),
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` DECIMAL(10,2),
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `from_date`, `to_date`)
) CHARACTER SET latin1;
CREATE TABLE `titles` (
`emp_no` INT,
`title` VARCHAR(64),
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `from_date`, `to_date`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005824_squema') AS relationships;
relationships
Database: db_005824_squema

