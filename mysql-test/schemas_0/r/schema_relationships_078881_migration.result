`content` TEXT,
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL,
`deletedAt` TIMESTAMP NULL,
`channelId` TEXT,
`userId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Setting` (
`name` TEXT,
`value` VARCHAR(50),
`createdAt` TIMESTAMP NULL,
`updatedAt` TIMESTAMP NULL
) CHARACTER SET latin1;
CREATE TABLE `Log` (
`url` TEXT,
`createdAt` TIMESTAMP NULL,
`channelId` TEXT,
`userId` TEXT
) CHARACTER SET latin1;
