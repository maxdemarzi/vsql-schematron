INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 014025_blog
#
CREATE DATABASE `db_014025_blog`;
USE `db_014025_blog`;
CREATE TABLE `UserRole` (
`IDRole` INT NOT NULL,
`RoleName` VARCHAR(50),
PRIMARY KEY (`IDRole`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`IDCategory` INT NOT NULL,
`CategoryName` VARCHAR(50),
PRIMARY KEY (`IDCategory`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`IDUser` INT NOT NULL,
`Username` VARCHAR(50),
`FullName` VARCHAR(50),
`Birthday` DATETIME,
`Country` VARCHAR(50),
`JOINDate` DATETIME,
`IDRole` INT,
PRIMARY KEY (`IDUser`)
) CHARACTER SET latin1;
CREATE TABLE `Blog` (
`IDBlog` INT NOT NULL,
`BlogText` VARCHAR(50),
`DateBlog` DATETIME,
`IDUser` INT,
`IDCategory` INT,
PRIMARY KEY (`IDBlog`)
) CHARACTER SET latin1;
CREATE TABLE `Comment` (
`IDComment` INT NOT NULL,
`CommentText` VARCHAR(50),
`DateComment` DATETIME,
`IDUser` INT,
`IDBlog` INT,
PRIMARY KEY (`IDComment`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_014025_blog') AS relationships;
relationships
Database: db_014025_blog

Table Connections:
