`presenterId` INT,
`building` VARCHAR(64),
`distance` VARCHAR(64),
`content` VARCHAR(64),
`impresentationsageUrl` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
