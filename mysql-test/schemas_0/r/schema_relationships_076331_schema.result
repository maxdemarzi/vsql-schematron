INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 076331_schema
#
CREATE DATABASE `db_076331_schema`;
USE `db_076331_schema`;
CREATE TABLE `consumidor` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`telefone` INT,
`senha` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `restaurante` (
`id` INT NOT NULL,
`usuario_id` INT,
`nome` VARCHAR(50),
`descricao` TEXT,
`categoria_id` INT,
`taxa_entrega` INT,
`tempo_entrega_minutos` INT,
`valor_minimo_pedido` INT,
`imagem` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produto` (
`id` INT NOT NULL,
`restaurante_id` INT,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`preco` INT,
`ativo` BOOLEAN,
`permite_observacoes` BOOLEAN,
`imagem` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_076331_schema') AS relationships;
relationships
