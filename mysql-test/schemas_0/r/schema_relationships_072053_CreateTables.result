CREATE DATABASE `db_072053_CreateTables`;
USE `db_072053_CreateTables`;
CREATE TABLE `customer` (
`custid` INT,
`custname` VARCHAR(64),
`custusername` VARCHAR(64),
`custpassword` VARCHAR(64),
PRIMARY KEY (`custid`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`empid` INT,
`empname` VARCHAR(64),
`empusername` VARCHAR(64),
`emppassword` VARCHAR(64),
`isanadmin` VARCHAR(64),
PRIMARY KEY (`empid`)
) CHARACTER SET latin1;
CREATE TABLE `account` (
`accid` INT,
`name` VARCHAR(64),
`status` VARCHAR(64),
`balance` INT,
`ownerid` INT,
`coownerid` INT,
PRIMARY KEY (`accid`)
) CHARACTER SET latin1;
