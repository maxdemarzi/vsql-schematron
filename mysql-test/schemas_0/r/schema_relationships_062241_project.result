INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 062241_project
#
CREATE DATABASE `db_062241_project`;
USE `db_062241_project`;
CREATE TABLE `user` (
`userId` VARCHAR(255),
`email` VARCHAR(255),
`name` VARCHAR(255),
`phone` VARCHAR(255),
`username` VARCHAR(255),
`website` VARCHAR(255),
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`postId` VARCHAR(255),
`postUserId` VARCHAR(255),
`body` VARCHAR(255),
`title` VARCHAR(255),
PRIMARY KEY (`postId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_062241_project') AS relationships;
