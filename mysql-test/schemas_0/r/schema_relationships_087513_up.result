CREATE DATABASE `db_087513_up`;
USE `db_087513_up`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`last_name` TEXT,
`email` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tables` (
`id` VARCHAR(50) NOT NULL,
`name` TEXT,
`alias` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `confirmed_users` (
`user_id` VARCHAR(50) NOT NULL,
`will_attend` VARCHAR(50),
`table_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_087513_up') AS relationships;
