INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 090691_tables
#
CREATE DATABASE `db_090691_tables`;
USE `db_090691_tables`;
CREATE TABLE `recipes` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`prep_time` INT,
`cook_time` INT,
`cuisine` VARCHAR(50),
`complex` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `instructions` (
`id` INT NOT NULL,
`recipe_id` INT,
`step_number` INT,
`instructions` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_ingredients` (
`recipe_id` INT,
`ingredient_id` INT,
`ingredient_amount` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_090691_tables') AS relationships;
relationships
Database: db_090691_tables

Table Connections:
------------------
[Implied]  instructions.recipe_id -> recipes.id
[Implied]  recipe_ingredients.ingredient_id -> ingredients.id
[Implied]  recipe_ingredients.recipe_id -> recipes.id

DROP DATABASE `db_090691_tables`;
UNINSTALL EXTENSION vsql_schematron;
