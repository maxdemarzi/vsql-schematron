CREATE DATABASE `db_024287_db_uas_absensi`;
USE `db_024287_db_uas_absensi`;
CREATE TABLE `absen_keluar` (
`id_absen` INT,
`NIK` INT,
`kode_absen` VARCHAR(50),
`tanggal` DATE,
`jam` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `absen_masuk` (
`id_absen` INT,
`NIK` INT,
`kode_absen` VARCHAR(50),
`tanggal` DATE,
`jam` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `karyawan` (
`NIK` INT NOT NULL,
`nama` VARCHAR(50),
`password` VARCHAR(50),
`jk` VARCHAR(50),
`tgl_lahir` VARCHAR(50),
`telpon` VARCHAR(50),
`tahun_masuk` VARCHAR(50),
PRIMARY KEY (`NIK`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT,
`username` VARCHAR(50),
`password` VARCHAR(50),
`NIK` INT,
`level` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_024287_db_uas_absensi') AS relationships;
