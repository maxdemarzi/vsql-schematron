[Implied]  deliveries.cust_id -> customers.cust_id
[Implied]  deliveries.vendor_id -> vendors.vendor_id
[Implied]  listings.vendor_id -> vendors.vendor_id
[Implied]  orders.delivery_id -> deliveries.delivery_id
[Implied]  orders.list_id -> listings.list_id

DROP DATABASE `db_073351_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
