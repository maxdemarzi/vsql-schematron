CREATE DATABASE `db_033854_schema`;
USE `db_033854_schema`;
CREATE TABLE `RG_MODELS` (
`RMD_ID` DECIMAL(10,2),
`RMD_NAME` VARCHAR(255),
`RMD_START` DATETIME,
`RMD_END` DATETIME,
`RMD_FORMAT` VARCHAR(255),
PRIMARY KEY (`RMD_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RG_IMAGE_TYPES` (
`RIT_ID` DECIMAL(10,2),
`RIT_RMD_ID` DECIMAL(10,2),
`RIT_NAME` VARCHAR(255),
`RIT_DESC` VARCHAR(255),
PRIMARY KEY (`RIT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RG_TEXT_TYPES` (
`RTT_ID` DECIMAL(10,2),
`RTT_RMD_ID` DECIMAL(10,2),
`RTT_NAME` VARCHAR(255),
`RTT_DESC` VARCHAR(255),
PRIMARY KEY (`RTT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RG_TABLE_TYPES` (
`RTP_ID` DECIMAL(10,2),
`RTP_RMD_ID` DECIMAL(10,2),
`RTP_NAME` VARCHAR(255),
`RTP_DESC` VARCHAR(255),
PRIMARY KEY (`RTP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `RG_REPORTS` (
`RRE_ID` DECIMAL(10,2),
`RRE_RMD_ID` DECIMAL(10,2),
`RRE_REF_ID` VARCHAR(255),
`RRE_START` DATETIME,
`RRE_END` DATETIME,
