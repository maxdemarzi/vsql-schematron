INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 067505_peers
#
CREATE DATABASE `db_067505_peers`;
USE `db_067505_peers`;
CREATE TABLE `peers` (
`id` INT,
`name` VARCHAR(64),
`port` INT,
`lastSentVersion` INT,
`lastPokeSucceededAt` INT,
`active` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peer_pubkeys` (
`id` INT,
`peername` VARCHAR(64),
`alg` VARCHAR(64),
`key` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_067505_peers') AS relationships;
