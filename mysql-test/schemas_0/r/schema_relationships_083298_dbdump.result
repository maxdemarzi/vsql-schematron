INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 083298_dbdump
#
CREATE DATABASE `db_083298_dbdump`;
USE `db_083298_dbdump`;
CREATE TABLE `breach` (
`id` BIGINT NOT NULL,
`contract_uuid` VARCHAR(50),
`datetime` DATETIME,
`metric_name` VARCHAR(50),
`value` VARCHAR(50),
`violation_id` BIGINT,
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `enforcement_job` (
`id` BIGINT NOT NULL,
`enabled` VARCHAR(50),
`first_executed` DATETIME,
`last_executed` DATETIME,
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `guarantee_term` (
`id` BIGINT NOT NULL,
`kpi_name` VARCHAR(50),
`name` VARCHAR(50),
`service_level` VARCHAR(50),
`service_name` VARCHAR(50),
`service_scope` VARCHAR(50),
`status` INT,
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `policy` (
`id` BIGINT NOT NULL,
`number` INT,
`time_interval` DATETIME,
`variable` VARCHAR(50),
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `service_properties` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`service_name` VARCHAR(50),
`agreement_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `variable` (
`id` BIGINT NOT NULL,
`location` VARCHAR(50),
`metric` VARCHAR(50),
`name` VARCHAR(50),
`service_properties_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `violation` (
`id` BIGINT NOT NULL,
`actual_value` VARCHAR(50),
`contract_uuid` VARCHAR(50),
`datetime` DATETIME,
`expected_value` VARCHAR(50),
`metric_name` VARCHAR(50),
`service_name` VARCHAR(50),
`service_scope` VARCHAR(50),
`uuid` VARCHAR(50),
`guarantee_term_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_083298_dbdump') AS relationships;
