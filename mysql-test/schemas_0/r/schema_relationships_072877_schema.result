INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 072877_schema
#
CREATE DATABASE `db_072877_schema`;
USE `db_072877_schema`;
CREATE TABLE `organization` (
`id` INT,
`name` VARCHAR(64),
`full_name` VARCHAR(64),
`inn` VARCHAR(64),
`kpp` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`is_active` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `office` (
`id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
`phone` VARCHAR(64),
`org_id` INT,
`is_active` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `document` (
`doc_code` VARCHAR(64),
`doc_number` VARCHAR(64),
`doc_date` DATETIME,
PRIMARY KEY (`doc_code`, `doc_number`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`office_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`position` VARCHAR(64),
`phone` VARCHAR(64),
`doc_code` VARCHAR(64),
`doc_number` VARCHAR(64),
`citizenship_code` INT,
`is_identified` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_072877_schema') AS relationships;
relationships
Database: db_072877_schema

Table Connections:
