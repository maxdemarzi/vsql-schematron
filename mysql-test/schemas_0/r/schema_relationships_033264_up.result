INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 033264_up
#
CREATE DATABASE `db_033264_up`;
USE `db_033264_up`;
CREATE TABLE `users` (
`id` VARCHAR(255),
`username` VARCHAR(255),
`host` VARCHAR(255),
`nickname` VARCHAR(255),
`uri` VARCHAR(255),
`inbox` VARCHAR(255),
`public_key` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_auth` (
`username` VARCHAR(255),
`encrypted_password` VARCHAR(255),
`users_id` VARCHAR(255),
`private_key` VARCHAR(255),
`public_key` VARCHAR(255),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_033264_up') AS relationships;
