INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 011206_invent.mysql.db
#
CREATE DATABASE `db_011206_invent_mysql_db`;
USE `db_011206_invent_mysql_db`;
CREATE TABLE `unidades` (
`id` VARCHAR(50) NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categorias` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `productos` (
`id` INT NOT NULL,
`codigo` VARCHAR(50),
`nombre` VARCHAR(50),
`marca` VARCHAR(50),
`unidad_id` VARCHAR(50),
`categoria_id` INT,
`precio` DECIMAL(10,2),
`fecha_registro` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_011206_invent_mysql_db') AS relationships;
relationships
Database: db_011206_invent_mysql_db

Table Connections:
------------------
[Implied]  productos.categoria_id -> categorias.id
[Implied]  productos.unidad_id -> unidades.id

DROP DATABASE `db_011206_invent_mysql_db`;
UNINSTALL EXTENSION vsql_schematron;
