[Implied]  message.assigned_user_id -> user.id
[Implied]  message.priority_id -> priority.id
[Implied]  message.topic_id -> topic.id
[Implied]  response.message_id -> message.id
[Implied]  response.user_id -> user.id

DROP DATABASE `db_072197_default`;
UNINSTALL EXTENSION vsql_schematron;
