`Otro_software` INT,
`Estado_s_FK` INT,
`Equipo_FK` INT,
PRIMARY KEY (`Id_software`)
) CHARACTER SET latin1;
CREATE TABLE `Hardware` (
`Id_hardware` INT,
`Marca_board` VARCHAR(64),
`Referencias` VARCHAR(64),
`Marca_procesador` VARCHAR(64),
