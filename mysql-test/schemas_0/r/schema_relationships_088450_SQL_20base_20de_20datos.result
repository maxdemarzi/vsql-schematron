`Teclado` VARCHAR(64),
`Mouse_o_touchpad` VARCHAR(64),
`Alimentación` VARCHAR(64),
`Camara` VARCHAR(64),
`Cables` VARCHAR(64),
`Equipo_FK` INT,
PRIMARY KEY (`Id_hardware`)
) CHARACTER SET latin1;
CREATE TABLE `Estado_software` (
`Tipo_software` INT,
`Nombre_software` VARCHAR(64),
`Version` VARCHAR(64),
`Caracteristicas` VARCHAR(64),
`Licencias` VARCHAR(64),
