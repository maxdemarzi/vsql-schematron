CREATE DATABASE `db_088450_SQL_20base_20de_20datos`;
USE `db_088450_SQL_20base_20de_20datos`;
CREATE TABLE `Usuarios` (
`Id_usuarios` INT,
`Nombre_usuario` VARCHAR(64),
`Correo_usuario` VARCHAR(64),
`Nickname` VARCHAR(64),
`Contraseña` VARCHAR(64),
`Diagnostico_FK` INT,
`Bitacora_FK` INT,
`Hoja_vida_FK` INT,
PRIMARY KEY (`Id_usuarios`)
) CHARACTER SET latin1;
CREATE TABLE `Bitacora_sucesos_incidencias` (
`Contactos` INT,
`Inicio` DATETIME,
`Soporte` VARCHAR(64),
