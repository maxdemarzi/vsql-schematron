`Contacto` VARCHAR(64),
`Tipo_pago` DECIMAL(10,2),
PRIMARY KEY (`Id_diagnostico`)
) CHARACTER SET latin1;
CREATE TABLE `Hoja_vida_cliente` (
`Hoja_vida` INT,
`Telefono_cliente` VARCHAR(64),
