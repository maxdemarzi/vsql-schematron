`Fecha_quiebre` DATETIME,
`Observaciones` VARCHAR(64),
PRIMARY KEY (`Tipo_software`)
) CHARACTER SET latin1;
CREATE TABLE `Equipo` (
`Id_equipo` INT,
`Tipo_e` VARCHAR(64),
`Marca` VARCHAR(64),
`Referencia_e` VARCHAR(64),
PRIMARY KEY (`Id_equipo`)
) CHARACTER SET latin1;
