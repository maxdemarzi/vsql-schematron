[Implied]  juegos_venta.dni -> usuarios.dni
[Implied]  juegos_venta.id_ejemplar -> ejemplares.id_ejemplar
[Implied]  usuarios.id_tienda -> tienda.id_tienda

DROP DATABASE `db_013382_script`;
UNINSTALL EXTENSION vsql_schematron;
