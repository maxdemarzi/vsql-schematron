INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 056104_inventory
#
CREATE DATABASE `db_056104_inventory`;
USE `db_056104_inventory`;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`weight` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products_on_hand` (
`product_id` INT,
`quantity` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`order_date` DATETIME,
`purchaser` INT,
`quantity` INT,
`product_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `geom` (
`id` INT,
`g` VARCHAR(64),
`h` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_056104_inventory') AS relationships;
relationships
Database: db_056104_inventory

Table Connections:
