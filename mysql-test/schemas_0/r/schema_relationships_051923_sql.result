INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 051923_sql
#
CREATE DATABASE `db_051923_sql`;
USE `db_051923_sql`;
CREATE TABLE `companies` (
`id` INT NOT NULL,
`name_company` VARCHAR(50),
`type_services` VARCHAR(50),
`show_type_services` VARCHAR(50),
`descriptionServices` VARCHAR(50),
`email` VARCHAR(50),
`phone` VARCHAR(50),
`longitude` VARCHAR(50),
`latitude` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `address` (
`id` INT NOT NULL,
`zip_code` VARCHAR(50),
`road` VARCHAR(50),
`district` VARCHAR(50),
`city` VARCHAR(50),
`number_place` VARCHAR(50),
`fk_id_companies` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_051923_sql') AS relationships;
relationships
