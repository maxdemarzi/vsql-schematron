CREATE DATABASE `db_088834_db_inventory_medis`;
USE `db_088834_db_inventory_medis`;
CREATE TABLE `barang` (
`kode` VARCHAR(64),
`category_id` VARCHAR(64),
`idsup` VARCHAR(64),
`namabarang` VARCHAR(64),
`stok` INT,
`hrgjual` INT,
`hrgbeli` INT
) CHARACTER SET latin1;
CREATE TABLE `barangkeluar` (
`kodekeluar` VARCHAR(64),
`nik` VARCHAR(64),
`tglkeluar` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `barangmasuk` (
`kodemasuk` VARCHAR(64),
`nik` VARCHAR(64),
`tglmasuk` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`category_id` VARCHAR(64),
`explanation` VARCHAR(64),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `detbarangkeluar` (
`kodebk` INT,
`kodekeluar` VARCHAR(64),
`kode` VARCHAR(64),
`qtykeluar` INT
) CHARACTER SET latin1;
CREATE TABLE `detbarangmasuk` (
`kodebm` INT,
`kodemasuk` VARCHAR(64),
`kode` VARCHAR(64),
`qtymasuk` INT
) CHARACTER SET latin1;
CREATE TABLE `supplier` (
`idsup` VARCHAR(64),
`namasup` VARCHAR(64),
`notelp` VARCHAR(64),
`alamat` VARCHAR(64),
`category_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`nik` VARCHAR(64),
`username` VARCHAR(64),
`nama` VARCHAR(64),
`password` VARCHAR(64),
`job` VARCHAR(64),
PRIMARY KEY (`nik`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_088834_db_inventory_medis') AS relationships;
relationships
