CREATE DATABASE `db_049361_1427399956`;
USE `db_049361_1427399956`;
CREATE TABLE `session_info` (
`session_id` INT,
`description` VARCHAR(64),
`start_time` INT,
PRIMARY KEY (`session_id`)
) CHARACTER SET latin1;
CREATE TABLE `proc_info` (
`session_id` INT,
`rec_time` INT,
`proc_id` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `event_type` (
`type_id` INT,
`description` VARCHAR(64),
PRIMARY KEY (`type_id`)
) CHARACTER SET latin1;
CREATE TABLE `event_log` (
`session_id` INT,
`event_id` INT,
`event_time` DATETIME,
`event_type` INT,
`description` VARCHAR(64),
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
CREATE TABLE `cpu_sys` (
`session_id` INT,
`rec_time` INT,
`user_mode` DECIMAL(10,2),
`kernel_mode` DECIMAL(10,2),
`idle_mode` DECIMAL(10,2),
`percent` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `cpu_proc` (
`session_id` INT,
`rec_time` INT,
`proc_id` INT,
`priority` INT,
`ctx_switches` INT,
`threads` INT,
`user_mode` DECIMAL(10,2),
`kernel_mode` DECIMAL(10,2),
`percent` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `mem_sys` (
`session_id` INT,
`rec_time` INT,
`available` INT,
`percent` DECIMAL(10,2),
`used` INT,
`free` INT,
`swap_total` INT,
`swap_used` INT,
`swap_free` INT,
`swap_in` INT,
`swap_out` INT,
`swap_percent` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `mem_proc` (
`session_id` INT,
`rec_time` INT,
`proc_id` INT,
`used` INT,
`virtual` INT,
`percent` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `io_sys` (
`session_id` INT,
`rec_time` INT,
`bytes_sent` INT,
`bytes_received` INT,
`packets_sent` INT,
`packets_received` INT,
`errors_in` INT,
`errors_out` INT,
`dropped_in` INT,
`dropped_out` INT
) CHARACTER SET latin1;
