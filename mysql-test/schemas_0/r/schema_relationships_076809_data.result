INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 076809_data
#
CREATE DATABASE `db_076809_data`;
USE `db_076809_data`;
CREATE TABLE `RESTAURANT` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`ADDRESS` VARCHAR(50),
`CITY` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REVIEW` (
`ID` INT NOT NULL,
`MESSAGE` VARCHAR(50),
`RATING` INT,
`RESTAURANT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REPLY` (
`ID` INT NOT NULL,
`MESSAGE` VARCHAR(50),
`REVIEW_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_076809_data') AS relationships;
relationships
