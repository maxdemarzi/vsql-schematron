INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 046586_schema
#
CREATE DATABASE `db_046586_schema`;
USE `db_046586_schema`;
CREATE TABLE `customers` (
`customer_Id` INT NOT NULL,
`customer_name` VARCHAR(50),
`phone` VARCHAR(50),
`email` VARCHAR(50),
`address1` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`zipCode` VARCHAR(50),
PRIMARY KEY (`customer_Id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_Id` INT NOT NULL,
`customer_Id` INT,
`order_date` DATE,
`order_status` VARCHAR(50),
`delivery_date` DATE,
PRIMARY KEY (`order_Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_046586_schema') AS relationships;
relationships
