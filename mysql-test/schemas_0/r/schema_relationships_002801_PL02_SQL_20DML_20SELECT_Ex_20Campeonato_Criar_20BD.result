INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002801_PL02-SQL%20DML%20SELECT-Ex%20Campeonato-Criar%20BD
#
CREATE DATABASE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;
USE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;
CREATE TABLE `equipas` (
`id_equipa` INT,
`nome` VARCHAR(64),
`cidade` VARCHAR(64),
`diretor` VARCHAR(64),
PRIMARY KEY (`id_equipa`)
) CHARACTER SET latin1;
CREATE TABLE `treinadores` (
`id_treinador` INT,
`nome` VARCHAR(64),
`idade` INT,
`telefone` VARCHAR(64),
PRIMARY KEY (`id_treinador`)
) CHARACTER SET latin1;
CREATE TABLE `bolas` (
`referencia` VARCHAR(64),
`id_equipa` INT,
`fabricante` VARCHAR(64),
PRIMARY KEY (`id_equipa`, `referencia`)
) CHARACTER SET latin1;
CREATE TABLE `experiencias` (
`id_equipa` INT,
`id_treinador` INT,
`escalao` VARCHAR(64),
`anos` DECIMAL(10,2),
PRIMARY KEY (`id_equipa`, `id_treinador`, `escalao`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD') AS relationships;
relationships
Database: db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD

Table Connections:
------------------
[Implied]  bolas.id_equipa -> equipas.id_equipa
[Implied]  experiencias.id_equipa -> equipas.id_equipa
[Implied]  experiencias.id_treinador -> treinadores.id_treinador

DROP DATABASE `db_002801_PL02_SQL_20DML_20SELECT_Ex_20Campeonato_Criar_20BD`;
UNINSTALL EXTENSION vsql_schematron;
