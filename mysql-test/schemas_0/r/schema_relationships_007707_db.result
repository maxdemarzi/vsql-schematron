INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 007707_db
#
CREATE DATABASE `db_007707_db`;
USE `db_007707_db`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`image_path` VARCHAR(50),
`password` VARCHAR(50),
`birth_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT NOT NULL,
`user_id` INT,
`post_title` VARCHAR(50),
`post_text` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`comment_id` INT NOT NULL,
`user_id` INT,
`post_id` INT,
`comment_text` VARCHAR(50),
PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_007707_db') AS relationships;
relationships
Database: db_007707_db

Table Connections:
------------------
[Implied]  comments.post_id -> posts.id
[Implied]  comments.user_id -> users.id
[Implied]  posts.user_id -> users.id

DROP DATABASE `db_007707_db`;
UNINSTALL EXTENSION vsql_schematron;
