CREATE TABLE `behavior_group` (
`id` VARCHAR(64),
`account_id` VARCHAR(64),
`name` VARCHAR(64),
`display_name` VARCHAR(64),
`bundle_id` VARCHAR(64),
`default_behavior` VARCHAR(64),
`created` DATETIME,
`updated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event_type_behavior` (
`event_type_id` VARCHAR(64),
`behavior_group_id` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`event_type_id`, `behavior_group_id`)
) CHARACTER SET latin1;
CREATE TABLE `behavior_group_action` (
`behavior_group_id` VARCHAR(64),
`endpoint_id` VARCHAR(64),
`created` DATETIME,
PRIMARY KEY (`behavior_group_id`, `endpoint_id`)
) CHARACTER SET latin1;
