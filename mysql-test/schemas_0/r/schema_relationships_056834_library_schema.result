INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 056834_library_schema
#
CREATE DATABASE `db_056834_library_schema`;
USE `db_056834_library_schema`;
CREATE TABLE `authors` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`bio` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `author_books` (
`isbn` VARCHAR(64),
`title` VARCHAR(64),
`author_id` VARCHAR(64),
`genre` VARCHAR(64),
`description` VARCHAR(64),
`date_published` DATETIME,
PRIMARY KEY (`isbn`)
) CHARACTER SET latin1;
CREATE TABLE `library_books` (
`id` VARCHAR(64),
`isbn` VARCHAR(64),
`book_condition` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `members` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member_books` (
`member_id` VARCHAR(64),
`book_id` VARCHAR(64),
`date_checked_out` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_056834_library_schema') AS relationships;
relationships
Database: db_056834_library_schema

Table Connections:
------------------
[Implied]  author_books.author_id -> authors.id
[Implied]  library_books.isbn -> author_books.isbn
[Implied]  member_books.member_id -> members.id

DROP DATABASE `db_056834_library_schema`;
UNINSTALL EXTENSION vsql_schematron;
