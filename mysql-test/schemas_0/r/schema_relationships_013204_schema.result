INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 013204_schema
#
CREATE DATABASE `db_013204_schema`;
USE `db_013204_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `position` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`position_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_013204_schema') AS relationships;
relationships
Database: db_013204_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.position_id -> position.id
[Implied]  position.department_id -> department.id

DROP DATABASE `db_013204_schema`;
UNINSTALL EXTENSION vsql_schematron;
