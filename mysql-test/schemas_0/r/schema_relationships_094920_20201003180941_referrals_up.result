`name` VARCHAR(64),
`dateAdded` DATETIME,
`dateModified` DATETIME,
`addedBy` INT,
`modifiedBy` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `partnerServices` (
`id` INT,
`partnerId` INT,
`name` VARCHAR(64),
`isActive` VARCHAR(64),
`dateAdded` DATETIME,
`dateModified` DATETIME,
`addedBy` INT,
`modifiedBy` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `leadReferrals` (
`id` INT,
`leadId` INT,
`partnerServiceId` INT,
`addedBy` INT,
`dateAdded` DATETIME,
`isDeleted` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clientReferrals` (
`id` INT,
`clientId` INT,
`partnerServiceId` INT,
`isDeleted` VARCHAR(64),
`addedBy` INT,
`dateAdded` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
