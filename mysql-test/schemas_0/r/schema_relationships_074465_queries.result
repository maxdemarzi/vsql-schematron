INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 074465_queries
#
CREATE DATABASE `db_074465_queries`;
USE `db_074465_queries`;
CREATE TABLE `users` (
`user_id` VARCHAR(50) NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`address` VARCHAR(50),
`email` VARCHAR(50),
`phone_number` VARCHAR(50),
`is_admin` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` VARCHAR(50) NOT NULL,
`order_status` VARCHAR(50),
`order_time` TIME,
`order_description` VARCHAR(50),
`order_amount` VARCHAR(50),
`payment_method` VARCHAR(50),
`user_id` VARCHAR(50),
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`product_id` VARCHAR(50) NOT NULL,
`product_name` VARCHAR(50),
`product_price` VARCHAR(50),
`product_photo` VARCHAR(50),
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_products` (
`relationship_id` VARCHAR(50) NOT NULL,
`order_id` VARCHAR(50),
`product_id` VARCHAR(50),
`product_quantity` VARCHAR(50),
PRIMARY KEY (`relationship_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_074465_queries') AS relationships;
relationships
Database: db_074465_queries

Table Connections:
------------------
[Implied]  orders.user_id -> users.user_id
[Implied]  orders_products.order_id -> orders.order_id
[Implied]  orders_products.product_id -> products.product_id

DROP DATABASE `db_074465_queries`;
UNINSTALL EXTENSION vsql_schematron;
