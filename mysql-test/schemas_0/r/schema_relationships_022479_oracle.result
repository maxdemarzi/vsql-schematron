CREATE DATABASE `db_022479_oracle`;
USE `db_022479_oracle`;
CREATE TABLE `t_gtr_departamento` (
`id_departamento` DECIMAL(10,2),
`nm_departamento` VARCHAR(64),
`dt_criacao` DATETIME,
`dt_atualizacao` DATETIME,
`dt_exclusao` DATETIME,
PRIMARY KEY (`id_departamento`)
) CHARACTER SET latin1;
CREATE TABLE `t_gtr_funcionario` (
`id_funcionario` DECIMAL(10,2),
`id_departamento` DECIMAL(10,2),
`id_acesso` VARCHAR(64),
`nr_cpf_cnpj` VARCHAR(64),
`nm_funcionario` VARCHAR(64),
`ds_email` VARCHAR(64),
`ds_senha` VARCHAR(64),
`in_ativo` DECIMAL(10,2),
`st_primeiro_acesso` DECIMAL(10,2),
`dt_criacao` DATETIME,
`dt_atualizacao` DATETIME,
`dt_exclusao` DATETIME,
PRIMARY KEY (`id_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `t_gtr_reuniao` (
`id_reuniao` DECIMAL(10,2),
`id_gestor` DECIMAL(10,2),
`ds_reuniao` VARCHAR(64),
`in_status` VARCHAR(64),
`dt_criacao` DATETIME,
`dt_atualizacao` DATETIME,
`dt_exclusao` DATETIME,
PRIMARY KEY (`id_reuniao`)
) CHARACTER SET latin1;
CREATE TABLE `t_gtr_tarefa` (
`id_tarefa` DECIMAL(10,2),
`id_funcionario` DECIMAL(10,2),
`id_reuniao` DECIMAL(10,2),
`ds_tarefa` VARCHAR(64),
`ob_tarefa` VARCHAR(64),
`in_status` VARCHAR(64),
`dt_criacao` DATETIME,
`dt_atualizacao` DATETIME,
`dt_exclusao` DATETIME,
PRIMARY KEY (`id_tarefa`, `id_funcionario`)
) CHARACTER SET latin1;
