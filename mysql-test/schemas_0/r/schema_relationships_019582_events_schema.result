INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 019582_events-schema
#
CREATE DATABASE `db_019582_events_schema`;
USE `db_019582_events_schema`;
CREATE TABLE `appUsers` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`event_date` DATETIME,
`summary` VARCHAR(64),
`description` VARCHAR(64),
`owner` INT,
`attendee` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_019582_events_schema') AS relationships;
