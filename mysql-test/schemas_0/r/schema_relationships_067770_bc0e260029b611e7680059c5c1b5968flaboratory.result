CREATE DATABASE `db_067770_bc0e260029b611e7680059c5c1b5968flaboratory`;
USE `db_067770_bc0e260029b611e7680059c5c1b5968flaboratory`;
CREATE TABLE `t_brand` (
`id` INT,
`isDelete` INT,
`name` VARCHAR(64),
`Category_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_category` (
`id` INT,
`isDelete` INT,
`name` VARCHAR(64),
`photo` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_introduction` (
`id` INT,
`gg` VARCHAR(64),
`isDelete` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_message` (
`id` INT,
`count` VARCHAR(64),
`isDelete` INT,
`msg` VARCHAR(64),
`time` DATETIME,
`User_Fsr` INT,
`User_Jsr` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_photo` (
`id` INT,
`count` INT,
`fileName1` VARCHAR(64),
`fileName2` VARCHAR(64),
`fileName3` VARCHAR(64),
`fileName4` VARCHAR(64),
`isDelete` INT,
`jg` DECIMAL(10,2),
`js` VARCHAR(64),
`name` VARCHAR(64),
`brand_id` INT,
`category_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_purchase` (
`id` INT,
`count` INT,
`isDelete` INT,
`money` DECIMAL(10,2),
`price` DECIMAL(10,2),
`time` DATETIME,
`photo_id` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
