INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 089412_online_store
#
CREATE DATABASE `db_089412_online_store`;
USE `db_089412_online_store`;
CREATE TABLE `cities` (
`city_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`name` VARCHAR(50),
`birthday` DATE,
`city_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT NOT NULL,
`customer_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `item_types` (
`item_type_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`item_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT NOT NULL,
`name` VARCHAR(50),
`item_type_id` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_id` INT NOT NULL,
`item_id` INT NOT NULL,
PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_089412_online_store') AS relationships;
relationships
Database: db_089412_online_store

Table Connections:
------------------
[Implied]  customers.city_id -> cities.city_id
[Implied]  items.item_type_id -> item_types.item_type_id
[Implied]  order_items.item_id -> items.item_id
[Implied]  order_items.order_id -> orders.order_id
[Implied]  orders.customer_id -> customers.customer_id

DROP DATABASE `db_089412_online_store`;
UNINSTALL EXTENSION vsql_schematron;
