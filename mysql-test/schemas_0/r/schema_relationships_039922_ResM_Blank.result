CREATE TABLE `resources` (
`id` INT,
`name` VARCHAR(64),
`link` VARCHAR(64),
`cont` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT,
