) CHARACTER SET latin1;
CREATE TABLE `model` (
`model` INT,
`m_id` INT,
`name` VARCHAR(64),
`year` VARCHAR(64),
`basic_spec` VARCHAR(64),
PRIMARY KEY (`model`)
) CHARACTER SET latin1;
