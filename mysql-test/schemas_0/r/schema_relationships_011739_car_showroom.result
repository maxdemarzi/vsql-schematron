CREATE DATABASE `db_011739_car_showroom`;
USE `db_011739_car_showroom`;
CREATE TABLE `dealership` (
`d_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`d_id`)
) CHARACTER SET latin1;
CREATE TABLE `manufacturer` (
`m_id` INT,
`name` VARCHAR(64),
