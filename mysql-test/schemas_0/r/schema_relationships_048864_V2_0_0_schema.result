`lastOpDate` DATETIME,
`createDate` DATETIME,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `BaremetalChassisVO` (
`uuid` VARCHAR(64),
`ipmiAddress` VARCHAR(64),
`ipmiUsername` VARCHAR(64),
`ipmiPassword` VARCHAR(64),
`provisioned` INT,
`lastOpDate` DATETIME,
`createDate` DATETIME,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `BaremetalHostCfgVO` (
`uuid` VARCHAR(64),
`chassisUuid` VARCHAR(64),
`password` VARCHAR(64),
`vnc` INT,
`unattended` INT,
`lastOpDate` DATETIME,
`createDate` DATETIME,
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `BaremetalHostNicCfgVO` (
`uuid` VARCHAR(64),
`hostCfgUuid` VARCHAR(64),
`mac` VARCHAR(64),
`ip` VARCHAR(64),
`netmask` VARCHAR(64),
`gateway` VARCHAR(64),
`dns` VARCHAR(64),
`pxe` INT,
`lastOpDate` DATETIME,
