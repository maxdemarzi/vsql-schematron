CREATE DATABASE `db_076207_estrutura_20banco`;
USE `db_076207_estrutura_20banco`;
CREATE TABLE `TB_UF` (
`UF` VARCHAR(50) NOT NULL,
`DESCRICAO` VARCHAR(50),
PRIMARY KEY (`UF`)
) CHARACTER SET latin1;
CREATE TABLE `TB_PESSOA` (
`ID` INT NOT NULL,
`NOME` VARCHAR(50),
`ENDERECO` VARCHAR(50),
`NUMERO` VARCHAR(50),
`BAIRRO` VARCHAR(50),
`CIDADE` VARCHAR(50),
`UF` CHAR(50),
`CEP` CHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `TB_PESSOA_TELEFONE` (
`ID_PESSOA` INT NOT NULL,
`ID_TELEFONE` INT NOT NULL,
`TELEFONE` VARCHAR(50),
`CONTATO` VARCHAR(50),
PRIMARY KEY (`ID_PESSOA`, `ID_TELEFONE`)
) CHARACTER SET latin1;
