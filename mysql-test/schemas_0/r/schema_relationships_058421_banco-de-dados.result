INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 058421_banco-de-dados
#
CREATE DATABASE `db_058421_banco_de_dados`;
USE `db_058421_banco_de_dados`;
CREATE TABLE `MEDICO` (
`IDMEDICO` INT NOT NULL,
`NOME` VARCHAR(50),
`EMAIL` VARCHAR(50),
PRIMARY KEY (`IDMEDICO`)
) CHARACTER SET latin1;
CREATE TABLE `PACIENTE` (
`IDPACIENTE` INT NOT NULL,
`NOME` VARCHAR(50),
`CPF` VARCHAR(50),
`EMAIL` VARCHAR(50),
`SEXO` VARCHAR(50),
PRIMARY KEY (`IDPACIENTE`)
) CHARACTER SET latin1;
CREATE TABLE `EXAME` (
`IDEXAME` INT NOT NULL,
`NOME` VARCHAR(50),
`OBSERVACAO` VARCHAR(50),
`RESULTADO` VARCHAR(50),
`ID_PACIENTE` INT,
PRIMARY KEY (`IDEXAME`)
) CHARACTER SET latin1;
CREATE TABLE `TELEFONE` (
`IDTELEFONE` INT NOT NULL,
`NUMERO` VARCHAR(50),
`TIPO` VARCHAR(50),
`ID_PACIENTE` INT,
`ID_MEDICO` INT,
PRIMARY KEY (`IDTELEFONE`)
) CHARACTER SET latin1;
CREATE TABLE `MEDICAMENTO` (
`IDMEDICAMENTO` INT NOT NULL,
`NOME` VARCHAR(50),
`TIPO` VARCHAR(50),
`DOSAGEM` VARCHAR(50),
`ID_PACIENTE` INT,
PRIMARY KEY (`IDMEDICAMENTO`)
) CHARACTER SET latin1;
CREATE TABLE `ENDERECO` (
`IDENDERECO` INT NOT NULL,
`RUA` VARCHAR(50),
`CIDADE` VARCHAR(50),
`ESTADO` CHAR(50),
`BAIRRO` VARCHAR(50),
`ID_PACIENTE` INT,
PRIMARY KEY (`IDENDERECO`)
) CHARACTER SET latin1;
CREATE TABLE `PLANO` (
`IDPLANO` INT NOT NULL,
`TIPO` VARCHAR(50),
`ID_PACIENTE` INT,
PRIMARY KEY (`IDPLANO`)
) CHARACTER SET latin1;
CREATE TABLE `CONSULTA` (
`IDCONSULTA` INT NOT NULL,
`NOME` VARCHAR(50),
`TIPO` VARCHAR(50),
`ID_PACIENTE` INT,
`ID_MEDICO` INT,
PRIMARY KEY (`IDCONSULTA`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_058421_banco_de_dados') AS relationships;
