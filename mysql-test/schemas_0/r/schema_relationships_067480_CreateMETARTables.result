CREATE DATABASE `db_067480_CreateMETARTables`;
USE `db_067480_CreateMETARTables`;
CREATE TABLE `METAR` (
`METARID` INT,
`Type` VARCHAR(64),
`Mode` VARCHAR(64),
`StationID` VARCHAR(64),
`Time` DATETIME,
`Cycle` INT,
`WindDirection` DECIMAL(10,2),
`WindSpeed` DECIMAL(10,2),
`WindGust` DECIMAL(10,2),
`WindDirectionFrom` DECIMAL(10,2),
`WindDirectionTo` DECIMAL(10,2),
`Visibility` DECIMAL(10,2),
`VisibilityDirection` DECIMAL(10,2),
`MaxVisibility` DECIMAL(10,2),
`MaxVisibilityDirection` DECIMAL(10,2),
`Temperature` DECIMAL(10,2),
`DewPoint` DECIMAL(10,2),
`Pressure` DECIMAL(10,2),
`SeaLevelPressure` DECIMAL(10,2),
`PeakWindSpeed` DECIMAL(10,2),
`PeakWindDirection` DECIMAL(10,2),
`MaxTemperature6Hr` DECIMAL(10,2),
`MinTemperature6Hr` DECIMAL(10,2),
`MaxTemperature24Hr` DECIMAL(10,2),
`MinTemperature24Hr` DECIMAL(10,2),
`Precipitation1Hr` DECIMAL(10,2),
`Precipitation3Hr` DECIMAL(10,2),
`Precipitation6Hr` DECIMAL(10,2),
`Precipitation24Hr` DECIMAL(10,2),
`Code` VARCHAR(64),
PRIMARY KEY (`METARID`)
) CHARACTER SET latin1;
CREATE TABLE `RunwayVisibility` (
`RunwayVisibilityID` INT,
`METARID` INT,
`Name` VARCHAR(64),
`Low` DECIMAL(10,2),
`High` DECIMAL(10,2),
PRIMARY KEY (`RunwayVisibilityID`)
) CHARACTER SET latin1;
CREATE TABLE `PresentWeather` (
`PresentWeatherID` INT,
`METARID` INT,
`Intensity` VARCHAR(64),
`Descriptor` VARCHAR(64),
`Precipitation` VARCHAR(64),
`Obscuration` VARCHAR(64),
`Other` VARCHAR(64),
PRIMARY KEY (`PresentWeatherID`)
) CHARACTER SET latin1;
CREATE TABLE `RecentWeather` (
`RecentWeatherID` INT,
`METARID` INT,
`Intensity` VARCHAR(64),
`Descriptor` VARCHAR(64),
`Precipitation` VARCHAR(64),
`Obscuration` VARCHAR(64),
`Other` VARCHAR(64),
PRIMARY KEY (`RecentWeatherID`)
) CHARACTER SET latin1;
CREATE TABLE `SkyCondition` (
`SkyConditionID` INT,
`METARID` INT,
`Cover` VARCHAR(64),
`Height` DECIMAL(10,2),
`Cloud` VARCHAR(64),
PRIMARY KEY (`SkyConditionID`)
) CHARACTER SET latin1;
CREATE TABLE `WindShearRunway` (
`WindShearRunwayID` INT,
`METARID` INT,
`Runway` VARCHAR(64),
PRIMARY KEY (`WindShearRunwayID`)
) CHARACTER SET latin1;
CREATE TABLE `Remark` (
`RemarkID` INT,
`METARID` INT,
`Remark` VARCHAR(64),
PRIMARY KEY (`RemarkID`)
) CHARACTER SET latin1;
