INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 003307_create_tables_nutrition
#
CREATE DATABASE `db_003307_create_tables_nutrition`;
USE `db_003307_create_tables_nutrition`;
CREATE TABLE `macronutrients` (
`ID` INT,
`carbohydrates` VARCHAR(64),
`proteins` VARCHAR(64),
`fats` VARCHAR(64),
`saturated_fats` VARCHAR(64),
`fibers` VARCHAR(64),
`sugars` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `nutrients` (
`ID` INT,
`calories` DECIMAL(10,2),
`ID_macronutrients` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `time_total` (
`ID` INT,
`prep_time` VARCHAR(64),
`cook_time` VARCHAR(64),
`total_time` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`ID` INT,
`ID_nutrients` INT,
`ID_time_total` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`keywords` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `images` (
`ID` INT,
`image_path` VARCHAR(64),
`ID_recipe` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ingredients` (
`ID` INT,
`name` VARCHAR(64),
`ID_recipe` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`ID` INT,
`category` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_to_category` (
`ID_category` INT,
`ID_recipe` INT
) CHARACTER SET latin1;
CREATE TABLE `instructions` (
`ID` INT,
`instruction` VARCHAR(64),
`ID_recipe` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `activity_types` (
`ID` INT,
`name` VARCHAR(64),
`calories` DECIMAL(10,2),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `diet_types` (
`ID` INT,
`name` VARCHAR(64),
`calories` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `genders` (
`ID` INT,
`name` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `user_details` (
`ID` INT,
`age` INT,
`height` INT,
`weight` INT,
`ideal_weight` INT,
`calories` INT,
`bmi` DECIMAL(10,2),
`wnd` INT,
`ID_activity_type` INT,
`ID_diet_type` INT,
`ID_gender` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_003307_create_tables_nutrition') AS relationships;
