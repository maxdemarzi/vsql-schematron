CREATE DATABASE `db_094369_RxChart`;
USE `db_094369_RxChart`;
CREATE TABLE `MedHistory` (
`Id` INT,
`ResidentId` INT,
`MedicineId` INT,
`UserId` INT,
`Notes` VARCHAR(64),
`In` INT,
`Out` INT,
`Created` DATETIME,
`Updated` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Medicine` (
`Id` INT,
`ResidentId` INT,
`UserId` INT,
`MedicineId` INT,
`Drug` VARCHAR(64),
`OtherNames` VARCHAR(64),
`Strength` VARCHAR(64),
`Barcode` VARCHAR(64),
`Directions` VARCHAR(64),
`FillDateMonth` INT,
`FillDateDay` INT,
`FillDateYear` INT,
`Notes` VARCHAR(64),
`Active` INT,
`OTC` INT,
`Pillbox` INT,
`Quantity` INT,
`Created` DATETIME,
`Updated` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_094369_RxChart') AS relationships;
