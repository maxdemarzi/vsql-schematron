) CHARACTER SET latin1;
CREATE TABLE `CONFIG_BEAN_REF` (
`UUID` VARCHAR(64),
`FK_SOURCE_BEAN_SCHEMA_NAME` VARCHAR(64),
`FK_SOURCE_BEAN_ID` VARCHAR(64),
`PROP_NAME` VARCHAR(64),
`FK_TARGET_BEAN_ID` VARCHAR(64),
`FK_TARGET_BEAN_SCHEMA_NAME` VARCHAR(64),
PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;
CREATE TABLE `CONFIG_PROPERTY` (
`UUID` VARCHAR(64),
`FK_BEAN_ID` VARCHAR(64),
`PROP_NAME` VARCHAR(64),
`FK_BEAN_SCHEMA_NAME` VARCHAR(64),
`PROP_VALUE` VARCHAR(64),
PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;
