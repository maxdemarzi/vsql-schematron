[Implied]  ALBUM.GENRE_ID -> GENRE.GENRE_ID
[Implied]  ALBUM.KOALIBEE_ID -> KOALIBEE.KOALIBEE_ID
[Implied]  KOALIBEE.CREDENTIALS_ID -> CREDENTIALS.CREDENTIALS_ID
[Implied]  KOALIBEE_ALBUM.ALBUM_ID -> ALBUM.ALBUM_ID
[Implied]  KOALIBEE_ALBUM.KOALIBEE_ID -> KOALIBEE.KOALIBEE_ID
[Implied]  MOMENT.KOALIBEE_ID -> KOALIBEE.KOALIBEE_ID
[Implied]  REVIEW.ALBUM_ID -> ALBUM.ALBUM_ID
[Implied]  REVIEW.KOALIBEE_ID -> KOALIBEE.KOALIBEE_ID
[Implied]  TRACK.ALBUM_ID -> ALBUM.ALBUM_ID

DROP DATABASE `db_096152_kh_schema`;
UNINSTALL EXTENSION vsql_schematron;
