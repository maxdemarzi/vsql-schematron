[Implied]  material.lesson -> lesson.id
[Implied]  question.course -> course.id
[Implied]  question.student -> student.username
[Implied]  user_course.username -> user.username

DROP DATABASE `db_095597_schema`;
UNINSTALL EXTENSION vsql_schematron;
