INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 030950_netflix-schema
#
CREATE DATABASE `db_030950_netflix_schema`;
USE `db_030950_netflix_schema`;
CREATE TABLE `msmpoint` (
`skunitid` VARCHAR(64),
`msmid` VARCHAR(64),
`name` VARCHAR(64),
`hardware` VARCHAR(64),
PRIMARY KEY (`skunitid`)
) CHARACTER SET latin1;
CREATE TABLE `netflix` (
`unit_id` INT,
`dtime` VARCHAR(64),
`target` VARCHAR(64),
`address` VARCHAR(64),
`connect_time` INT,
`download_duration` INT,
`bytes_sec` INT,
`error` VARCHAR(64),
`error_msg` VARCHAR(64),
`successes` INT,
`failures` INT,
`location_id` INT
) CHARACTER SET latin1;
CREATE TABLE `traceroute` (
`unit_id` INT,
`dtime` VARCHAR(64),
`version` VARCHAR(64),
`destination` VARCHAR(64),
`method` VARCHAR(64),
`status` VARCHAR(64),
`ttl` INT,
`endpoint` VARCHAR(64),
`rtt` VARCHAR(64),
`location_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_030950_netflix_schema') AS relationships;
