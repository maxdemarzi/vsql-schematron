`createdAt` DATETIME,
`updatedAt` DATETIME,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Member` (
`id` INT,
`isOwner` BOOL,
`createdAt` DATETIME,
`updatedAt` DATETIME,
`userId` INT,
`guildId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
