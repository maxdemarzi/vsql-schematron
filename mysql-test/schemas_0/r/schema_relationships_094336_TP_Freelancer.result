INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 094336_TP_Freelancer
#
CREATE DATABASE `db_094336_TP_Freelancer`;
USE `db_094336_TP_Freelancer`;
CREATE TABLE `customers_cats` (
`cat_id` INT NOT NULL,
`cat_name` VARCHAR(50),
`cat_description` TEXT,
PRIMARY KEY (`cat_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`customer_name` VARCHAR(50),
`customer_email` VARCHAR(50),
`cat_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `jobs` (
`job_id` INT NOT NULL,
`job_state` CHAR(50),
`job_title` VARCHAR(50),
`job_start` DATETIME,
`job_end` DATETIME,
`job_description` TEXT,
`customer_id` INT,
PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `quotes` (
`quote_id` INT NOT NULL,
`quote_state` CHAR(50),
`quote_date` DATE,
`quote_amount` INT,
`quote_final_date` DATE,
`quote_final_amount` INT,
`job_id` INT,
PRIMARY KEY (`quote_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_094336_TP_Freelancer') AS relationships;
relationships
Database: db_094336_TP_Freelancer

Table Connections:
------------------
[Implied]  customers.cat_id -> customers_cats.cat_id
[Implied]  jobs.customer_id -> customers.customer_id
