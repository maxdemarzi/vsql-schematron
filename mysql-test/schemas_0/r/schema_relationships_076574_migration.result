CREATE DATABASE `db_076574_migration`;
USE `db_076574_migration`;
CREATE TABLE `User` (
`id` VARCHAR(64),
`email` VARCHAR(64),
`username` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Byte` (
`id` VARCHAR(64),
`userId` VARCHAR(64),
`css` VARCHAR(64),
`xml` VARCHAR(64),
`js` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Stylesheet` (
`id` VARCHAR(64),
`userId` VARCHAR(64),
`locked` BOOL,
`css` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`id` VARCHAR(64),
`slug` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `_ByteToStylesheet` (
`A` VARCHAR(64),
`B` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `_ByteToTag` (
`A` VARCHAR(64),
`B` VARCHAR(64)
) CHARACTER SET latin1;
