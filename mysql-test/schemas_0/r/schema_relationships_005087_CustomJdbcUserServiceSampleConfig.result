CREATE DATABASE `db_005087_CustomJdbcUserServiceSampleConfig`;
USE `db_005087_CustomJdbcUserServiceSampleConfig`;
CREATE TABLE `users` (
`principal` VARCHAR(50) NOT NULL,
`credentials` VARCHAR(50),
PRIMARY KEY (`principal`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`principal` VARCHAR(50),
`role` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`id` BIGINT NOT NULL,
`group_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_authorities` (
`group_id` BIGINT,
`authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`group_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005087_CustomJdbcUserServiceSampleConfig') AS relationships;
