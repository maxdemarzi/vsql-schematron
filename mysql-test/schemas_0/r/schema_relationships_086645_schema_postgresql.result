INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 086645_schema_postgresql
#
CREATE DATABASE `db_086645_schema_postgresql`;
USE `db_086645_schema_postgresql`;
CREATE TABLE `login` (
`login_id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`login_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey` (
`survey_id` INT,
`survey_name` VARCHAR(64),
PRIMARY KEY (`survey_id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
`question_id` INT,
`survey_id` INT,
`question_type` VARCHAR(64),
`question_text` VARCHAR(64),
`is_required` INT,
`question_order` INT,
PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
CREATE TABLE `choice` (
`choice_id` INT,
`question_id` INT,
`choice_text` VARCHAR(64),
`choice_order` INT,
PRIMARY KEY (`choice_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_response` (
`survey_response_id` INT,
`survey_id` INT,
`time_taken` VARCHAR(64),
PRIMARY KEY (`survey_response_id`)
) CHARACTER SET latin1;
CREATE TABLE `survey_answer` (
`survey_answer_id` INT,
`survey_response_id` INT,
`question_id` INT,
`answer_value` VARCHAR(64),
PRIMARY KEY (`survey_answer_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_086645_schema_postgresql') AS relationships;
relationships
Database: db_086645_schema_postgresql

Table Connections:
------------------
[Implied]  choice.question_id -> question.question_id
[Implied]  question.survey_id -> survey.survey_id
[Implied]  survey_answer.question_id -> question.question_id
[Implied]  survey_answer.survey_response_id -> survey_response.survey_response_id
[Implied]  survey_response.survey_id -> survey.survey_id

DROP DATABASE `db_086645_schema_postgresql`;
UNINSTALL EXTENSION vsql_schematron;
