INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 079393_schema-mysql
#
CREATE DATABASE `db_079393_schema_mysql`;
USE `db_079393_schema_mysql`;
CREATE TABLE `dept` (
`DEPTNO` INT,
`DNAME` VARCHAR(64),
`LOC` VARCHAR(64),
PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `emp` (
`EMPNO` INT,
`ENAME` VARCHAR(64),
`JOB` VARCHAR(64),
`MGR` INT,
`HIREDATE` DATETIME,
`SAL` DECIMAL(10,2),
`COMM` DECIMAL(10,2),
`DEPTNO` INT,
PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_079393_schema_mysql') AS relationships;
relationships
