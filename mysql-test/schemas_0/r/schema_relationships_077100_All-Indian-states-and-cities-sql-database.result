INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 077100_All-Indian-states-and-cities-sql-database
#
CREATE DATABASE `db_077100_All_Indian_states_and_cities_sql_database`;
USE `db_077100_All_Indian_states_and_cities_sql_database`;
CREATE TABLE `city` (
`city_id` INT,
`city_name` VARCHAR(50),
`city_state_id` INT
) CHARACTER SET latin1;
CREATE TABLE `country` (
`country_id` INT,
`country_code` VARCHAR(50),
`country_name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `state` (
`state_id` INT,
`state_name` VARCHAR(50),
`state_country_id` INT,
`state_type` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_077100_All_Indian_states_and_cities_sql_database') AS relationships;
relationships
Database: db_077100_All_Indian_states_and_cities_sql_database

Table Connections:
------------------
[Implied]  city.city_state_id -> state.state_id
[Implied]  state.state_country_id -> country.country_id

DROP DATABASE `db_077100_All_Indian_states_and_cities_sql_database`;
UNINSTALL EXTENSION vsql_schematron;
