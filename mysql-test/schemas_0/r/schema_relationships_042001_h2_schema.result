INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 042001_h2-schema
#
CREATE DATABASE `db_042001_h2_schema`;
USE `db_042001_h2_schema`;
CREATE TABLE `SAMPLE` (
`id` INT,
`val` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ORGANIZATION` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `PERSON` (
`id` INT,
`org_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`salary` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `VALUE8` (
`val1` INT,
`val2` INT,
`val3` INT,
`val4` INT,
`val5` INT,
`val6` INT,
`val7` INT,
`val8` INT,
PRIMARY KEY (`val1`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_042001_h2_schema') AS relationships;
