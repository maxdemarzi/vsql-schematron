`userId` INT,
`timeout` DATETIME,
`notify` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Tag` (
`id` INT,
`tag` VARCHAR(64),
`notify` BOOL,
`userId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
`id` INT,
`email` VARCHAR(64),
`name` VARCHAR(64),
`createdAt` DATETIME,
`notify` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `EmailLog` (
`id` INT,
`mailId` VARCHAR(64),
`createdAt` DATETIME,
`userId` INT,
`text` VARCHAR(64),
`html` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `_LinkToTag` (
`A` INT,
`B` INT
) CHARACTER SET latin1;
