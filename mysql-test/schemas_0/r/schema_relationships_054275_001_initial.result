INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 054275_001-initial
#
CREATE DATABASE `db_054275_001_initial`;
USE `db_054275_001_initial`;
CREATE TABLE `sncf_disruption_days` (
`id` INT,
`day` VARCHAR(64),
`total_trips` INT,
`created_at` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sncf_disruptions` (
`id` INT,
`sncf_disruption_day_id` INT,
`disruption_uuid` VARCHAR(64),
`trip_id` VARCHAR(64),
`trip_name` VARCHAR(64),
`application_period_begin` VARCHAR(64),
`application_period_end` VARCHAR(64),
`severity_name` VARCHAR(64),
`severity_effect` VARCHAR(64),
`message_text` VARCHAR(64),
`cause` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sncf_disruption_impacted_stops` (
`id` INT,
`sncf_disruption_id` INT,
`sncf_disruption_day_id` INT,
`name` VARCHAR(64),
`base_arrival_time` VARCHAR(64),
`amended_arrival_time` VARCHAR(64),
`arrival_status` VARCHAR(64),
`arrival_delta` INT,
`arrival_delay` INT,
`base_departure_time` VARCHAR(64),
`amended_departure_time` VARCHAR(64),
`departure_status` VARCHAR(64),
`departure_delta` INT,
`departure_delay` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_054275_001_initial') AS relationships;
