CREATE TABLE `ptcore.in_program` (
`id` BIGINT NOT NULL,
`in_user_id` BIGINT,
`created` TIMESTAMP NULL,
`name` VARCHAR(50),
`d_program_type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptcore.in_workout` (
`id` BIGINT NOT NULL,
`in_program_id` BIGINT,
`created` TIMESTAMP NULL,
`d_workout_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ptcore.in_workout_item` (
`id` BIGINT NOT NULL,
`in_workout_id` BIGINT,
`created` TIMESTAMP NULL,
`d_exercise_id` VARCHAR(50),
`d_exercise_name` VARCHAR(50),
`sets` INT,
`repetitions` INT,
`weight` INT,
`bodyweight` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
