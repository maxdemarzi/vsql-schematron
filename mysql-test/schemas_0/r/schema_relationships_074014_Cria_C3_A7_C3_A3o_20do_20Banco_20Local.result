CREATE TABLE `EVENTO` (
`CODIGO` INT,
`DATA` VARCHAR(64),
`HORARIO` VARCHAR(64),
`LOCAL` VARCHAR(64),
`NOME` VARCHAR(64),
PRIMARY KEY (`CODIGO`)
) CHARACTER SET latin1;
CREATE TABLE `CONVIDADO` (
`RG` VARCHAR(64),
`NOME_CONVIDADO` VARCHAR(64),
`EVENTO_CODIGO` INT,
PRIMARY KEY (`RG`)
) CHARACTER SET latin1;
CREATE TABLE `EVENTO_CONVIDADO` (
`EVENTO_CODIGO` INT,
`CONVIDADO_RG` VARCHAR(64),
PRIMARY KEY (`EVENTO_CODIGO`)
) CHARACTER SET latin1;
