INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 095101_init
#
CREATE DATABASE `db_095101_init`;
USE `db_095101_init`;
CREATE TABLE `user.users` (
`user_id` INT,
`username` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `community.communities` (
`community_id` INT,
`community_name` VARCHAR(64),
`owner_id` INT,
PRIMARY KEY (`community_id`)
) CHARACTER SET latin1;
CREATE TABLE `event.events` (
`event_id` INT,
`owner_id` INT,
`community_id` INT,
PRIMARY KEY (`event_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_095101_init') AS relationships;
