CREATE DATABASE `db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9`;
USE `db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9`;
CREATE TABLE `dept` (
`id` INT,
`dname` VARCHAR(64),
`loc` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job` (
`id` INT,
`jname` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emp` (
`id` INT,
`ename` VARCHAR(64),
`job_id` INT,
`mgr` INT,
`joindate` DATETIME,
`salary` DECIMAL(10,2),
`bonus` DECIMAL(10,2),
`dept_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `salarygrads` (
`grade` INT,
`losalary` INT,
`hisalary` INT,
PRIMARY KEY (`grade`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_011220_E5_A4_9A_E8_A1_A8_E6_9F_A5_E8_AF_A2_E7_BB_83_E4_B9') AS relationships;
