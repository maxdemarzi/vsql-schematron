CREATE DATABASE `db_010923_apt_complex_db_04_create_tables`;
USE `db_010923_apt_complex_db_04_create_tables`;
CREATE TABLE `entity_statement_group` (
`id` INT,
`type` VARCHAR(64),
`monthly_statement_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `entity_balance_group` (
`id` INT,
`type` VARCHAR(64),
`monthly_balance_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `balance_divergence` (
`id` INT,
`type` VARCHAR(64),
`value` DECIMAL(10,2),
`description` VARCHAR(64),
`entity_balance_group_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apartment_balance_group` (
`id` INT,
`description` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apartment_statement_group` (
`id` INT,
`total_fee` DECIMAL(10,2),
`total_surcharge` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bill` (
`id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bill_with_due_date` (
`id` INT,
`due_date` DATETIME,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apartment_fee` (
`apartment_balance_id` INT,
`bill_id` INT,
PRIMARY KEY (`apartment_balance_id`, `bill_id`)
) CHARACTER SET latin1;
CREATE TABLE `bill_item` (
`id` INT,
`type` VARCHAR(64),
`value` DECIMAL(10,2),
`description` VARCHAR(64),
`bill_id` INT,
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT,
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`document` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `residence` (
`apartment_id` INT,
`person_id` INT,
PRIMARY KEY (`apartment_id`, `person_id`)
) CHARACTER SET latin1;
CREATE TABLE `payment` (
`id` INT,
`value` DECIMAL(10,2),
`type` VARCHAR(64),
`payment_date` DATETIME,
`note` VARCHAR(64),
`version` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bill_payment` (
`bill_id` INT,
`payment_id` INT,
PRIMARY KEY (`bill_id`, `payment_id`)
) CHARACTER SET latin1;
