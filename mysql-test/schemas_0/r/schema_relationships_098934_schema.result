INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 098934_schema
#
CREATE DATABASE `db_098934_schema`;
USE `db_098934_schema`;
CREATE TABLE `status` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task_type` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT NOT NULL,
`profile_email` VARCHAR(50),
`profile_name` VARCHAR(50),
`profile_location` VARCHAR(50),
`positive_points` INT,
`negative_points` INT,
`first_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `task` (
`id` INT NOT NULL,
`task_text` VARCHAR(50),
`task_type_id` INT,
`person_1_id` INT,
`person_2_id` INT,
`location_start` VARCHAR(50),
`location_end` VARCHAR(50),
`status_id` INT,
`date_created` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_098934_schema') AS relationships;
relationships
Database: db_098934_schema

Table Connections:
