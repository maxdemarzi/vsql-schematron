INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 002832_db
#
CREATE DATABASE `db_002832_db`;
USE `db_002832_db`;
CREATE TABLE `seeds` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`content` TEXT,
`thought` VARCHAR(50),
`daily_reading` VARCHAR(50),
`prayer` VARCHAR(50),
`assignment` VARCHAR(50),
`quote` VARCHAR(50),
`resource` VARCHAR(50),
`date` DATETIME,
`day` INT,
`month` INT,
`year` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `artist` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`artist_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_002832_db') AS relationships;
