INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 005248_schema-h2
#
CREATE DATABASE `db_005248_schema_h2`;
USE `db_005248_schema_h2`;
CREATE TABLE `PRODUCT` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`MANUFACTURER` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SUPPLY_CHAIN` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REGION` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `SUPPLY_CHAIN_REF` (
`ID` INT NOT NULL,
`SUPPLY_CHAIN_ID` INT,
`PRODUCT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `REGION_REF` (
`ID` INT NOT NULL,
`REGION_ID` INT,
`PRODUCT_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_005248_schema_h2') AS relationships;
relationships
