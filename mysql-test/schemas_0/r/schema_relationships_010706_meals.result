CREATE DATABASE `db_010706_meals`;
USE `db_010706_meals`;
CREATE TABLE `kitchen` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`date_created` DATE,
`date_deleted` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `meal_type` (
`id` INT,
`name` VARCHAR(50),
`kitchen_id` INT,
`date_created` DATE,
`date_deleted` DATE,
`description` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_010706_meals') AS relationships;
