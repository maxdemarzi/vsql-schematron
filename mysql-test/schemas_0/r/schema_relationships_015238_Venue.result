CREATE DATABASE `db_015238_Venue`;
USE `db_015238_Venue`;
CREATE TABLE `Venue` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`postalAddress` VARCHAR(50),
`latitude` DOUBLE,
`longitude` DOUBLE,
`locationHint` VARCHAR(50),
`createdBy` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `VenueRoom` (
`venue` BIGINT NOT NULL,
`id` SMALLINT NOT NULL,
`name` VARCHAR(50),
`capacity` INT,
`locationHint` VARCHAR(50),
PRIMARY KEY (`venue`, `id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_015238_Venue') AS relationships;
