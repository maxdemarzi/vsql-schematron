CREATE DATABASE `db_089760_clean`;
USE `db_089760_clean`;
CREATE TABLE `zv_accounts` (
`id` INT,
`organization_id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zv_credentials` (
`id` INT,
`account_id` INT,
`section_id` INT,
`name` VARCHAR(64),
`username` VARCHAR(64),
`value` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zv_organizations` (
`id` INT,
`name` VARCHAR(64),
`display_name` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zv_sections` (
`id` INT,
`account_id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `zv_tags` (
`id` INT,
`name` VARCHAR(64),
`encrypted` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
`deleted_at` DATETIME,
