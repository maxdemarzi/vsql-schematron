CREATE DATABASE `db_010809_test_ddl`;
USE `db_010809_test_ddl`;
CREATE TABLE `address` (
`id` VARCHAR(50) NOT NULL,
`address` VARCHAR(50),
`city_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `city` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`country_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`address_id` VARCHAR(50),
`create_time` TIMESTAMP NULL,
`last_update` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_010809_test_ddl') AS relationships;
