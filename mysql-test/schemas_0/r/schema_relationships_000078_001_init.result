INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 000078_001_init
#
CREATE DATABASE `db_000078_001_init`;
USE `db_000078_001_init`;
CREATE TABLE `user` (
`username` VARCHAR(255),
`password` VARCHAR(255),
`email` VARCHAR(255),
`year` INT,
`major` VARCHAR(255),
`is_admin` VARCHAR(255),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `year_name` (
`year` INT,
`name` VARCHAR(255),
PRIMARY KEY (`year`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`name` VARCHAR(255),
`description` VARCHAR(255),
`advisor_email` VARCHAR(255),
`advisor_name` VARCHAR(255),
`est_num_students` INT,
`designation_name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `project_requirement` (
`name` VARCHAR(255),
`requirement` VARCHAR(255),
PRIMARY KEY (`name`, `requirement`)
) CHARACTER SET latin1;
CREATE TABLE `designation` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `category` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `major` (
`name` VARCHAR(255),
`department_name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
`name` VARCHAR(255),
`course_number` VARCHAR(255),
`instructor` VARCHAR(255),
`est_num_students` INT,
`designation_name` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `application` (
`project_name` VARCHAR(255),
`student_name` VARCHAR(255),
`application_date` DATETIME,
`status` VARCHAR(255),
PRIMARY KEY (`project_name`, `student_name`)
) CHARACTER SET latin1;
CREATE TABLE `project_category` (
`project_name` VARCHAR(255),
`category_name` VARCHAR(255),
PRIMARY KEY (`project_name`, `category_name`)
) CHARACTER SET latin1;
CREATE TABLE `course_category` (
`course_name` VARCHAR(255),
`category_name` VARCHAR(255),
PRIMARY KEY (`course_name`, `category_name`)
) CHARACTER SET latin1;
