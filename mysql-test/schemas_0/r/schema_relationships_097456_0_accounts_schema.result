CREATE DATABASE `db_097456_0_accounts_schema`;
USE `db_097456_0_accounts_schema`;
CREATE TABLE `users` (
`accountid` VARCHAR(64),
`username` VARCHAR(64),
`passhash` VARCHAR(64),
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`birthday` DATETIME,
`timezone` VARCHAR(64),
`address` VARCHAR(64),
`state` VARCHAR(64),
`zip` VARCHAR(64),
`ssn` VARCHAR(64),
PRIMARY KEY (`accountid`)
) CHARACTER SET latin1;
CREATE TABLE `contacts` (
`username` VARCHAR(64),
`label` VARCHAR(64),
`account_num` VARCHAR(64),
`routing_num` VARCHAR(64),
`is_external` BOOL
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_097456_0_accounts_schema') AS relationships;
