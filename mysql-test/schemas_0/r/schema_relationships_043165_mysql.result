CREATE DATABASE `db_043165_mysql`;
USE `db_043165_mysql`;
CREATE TABLE `accounting_transactions` (
`id` INT,
`user_id` INT,
`invoice_id` INT,
`order_id` INT,
`increase` INT,
`decrease` INT,
`description` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`product_id` INT,
`reply_to_id` INT,
`author_id` INT,
`author_name` VARCHAR(64),
`body` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`published_at` DATETIME,
`deleted_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `failed_jobs` (
`id` INT,
`connection` VARCHAR(64),
`queue` VARCHAR(64),
`payload` VARCHAR(64),
`exception` VARCHAR(64),
`failed_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`id` INT,
`order_id` INT,
`product_id` INT,
`count` INT,
`price` INT,
`total_price` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_status` (
`id` INT,
`order_id` INT,
`user_id` INT,
`state` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`mobile` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `payment_transactiobs` (
`id` INT,
`user_id` INT,
`invoice_id` INT,
`payment_method` VARCHAR(64),
`bank_name` VARCHAR(64),
`account` VARCHAR(64),
`card_number` VARCHAR(64),
`iban` VARCHAR(64),
`amount` INT,
`status` VARCHAR(64),
`reference_number` VARCHAR(64),
`details` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
