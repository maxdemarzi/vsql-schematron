CREATE DATABASE `db_002864_031_HIVE_17566_mssql`;
USE `db_002864_031_HIVE_17566_mssql`;
CREATE TABLE `WM_RESOURCEPLAN` (
`RP_ID` INT,
`NAME` VARCHAR(64),
`QUERY_PARALLELISM` INT,
`STATUS` VARCHAR(64),
`DEFAULT_POOL_ID` INT,
PRIMARY KEY (`RP_ID`)
) CHARACTER SET latin1;
CREATE TABLE `WM_POOL` (
`POOL_ID` INT,
`RP_ID` INT,
`PATH` VARCHAR(64),
`ALLOC_FRACTION` DECIMAL(10,2),
`QUERY_PARALLELISM` INT,
`SCHEDULING_POLICY` VARCHAR(64),
PRIMARY KEY (`POOL_ID`)
) CHARACTER SET latin1;
CREATE TABLE `WM_TRIGGER` (
`TRIGGER_ID` INT,
`RP_ID` INT,
`NAME` VARCHAR(64),
`TRIGGER_EXPRESSION` VARCHAR(64),
`ACTION_EXPRESSION` VARCHAR(64),
`IS_IN_UNMANAGED` VARCHAR(64),
PRIMARY KEY (`TRIGGER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `WM_POOL_TO_TRIGGER` (
`POOL_ID` INT,
`TRIGGER_ID` INT,
PRIMARY KEY (`POOL_ID`, `TRIGGER_ID`)
) CHARACTER SET latin1;
CREATE TABLE `WM_MAPPING` (
`MAPPING_ID` INT,
`RP_ID` INT,
`ENTITY_TYPE` VARCHAR(64),
`ENTITY_NAME` VARCHAR(64),
`POOL_ID` INT,
`ORDERING` INT,
PRIMARY KEY (`MAPPING_ID`)
) CHARACTER SET latin1;
