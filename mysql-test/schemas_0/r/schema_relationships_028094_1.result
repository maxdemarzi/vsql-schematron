INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 028094_1
#
CREATE DATABASE `db_028094_1`;
USE `db_028094_1`;
CREATE TABLE `countries` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `coaches` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`salary` DECIMAL(10,2),
`coach_level` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skills_data` (
`id` INT NOT NULL,
`dribbling` INT,
`pace` INT,
`passing` INT,
`shooting` INT,
`speed` INT,
`strength` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `towns` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`country_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stadiums` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`capacity` INT,
`town_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teams` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`established` DATE,
`fan_base` BIGINT,
`stadium_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `players` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`age` INT,
`position` CHAR(50),
`salary` DECIMAL(10,2),
`hire_date` DATETIME,
`skills_data_id` INT,
`team_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `players_coaches` (
`player_id` INT NOT NULL,
`coach_id` INT NOT NULL,
PRIMARY KEY (`player_id`, `coach_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_028094_1') AS relationships;
relationships
Database: db_028094_1

Table Connections:
------------------
[Implied]  players.skills_data_id -> skills_data.id
[Implied]  players.team_id -> teams.id
[Implied]  players_coaches.coach_id -> coaches.id
[Implied]  players_coaches.player_id -> players.id
[Implied]  stadiums.town_id -> towns.id
[Implied]  teams.stadium_id -> stadiums.id
[Implied]  towns.country_id -> countries.id

DROP DATABASE `db_028094_1`;
UNINSTALL EXTENSION vsql_schematron;
