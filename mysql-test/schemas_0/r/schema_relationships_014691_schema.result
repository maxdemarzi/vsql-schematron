INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 014691_schema
#
CREATE DATABASE `db_014691_schema`;
USE `db_014691_schema`;
CREATE TABLE `category` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT NOT NULL,
`product_name` VARCHAR(50),
`price` DECIMAL(10,2),
`stock` INT,
`category_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`id` INT NOT NULL,
`tag_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `producttag` (
`id` INT NOT NULL,
`product_id` INT,
`tag_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_014691_schema') AS relationships;
relationships
Database: db_014691_schema

Table Connections:
