CREATE DATABASE `db_052281_migration`;
USE `db_052281_migration`;
CREATE TABLE `User` (
`id` VARCHAR(64),
`username` VARCHAR(64),
`email` VARCHAR(64),
`name` VARCHAR(64),
`password` VARCHAR(64),
`location` VARCHAR(64),
`avatarUrl` VARCHAR(64),
`githubUsername` VARCHAR(64),
`createAt` DATETIME,
`updateAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CoffeeShop` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`latitude` VARCHAR(64),
`longitude` VARCHAR(64),
`userId` VARCHAR(64),
`createAt` DATETIME,
`updateAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CoffeeShopPhoto` (
`id` VARCHAR(64),
`url` VARCHAR(64),
`shopId` VARCHAR(64),
`createAt` DATETIME,
`updateAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`slug` VARCHAR(64),
`createAt` DATETIME,
`updateAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `CoffeeShopToCategory` (
`shopId` VARCHAR(64),
`categoryId` VARCHAR(64),
`createAt` DATETIME,
`updateAt` DATETIME,
PRIMARY KEY (`shopId`, `categoryId`)
) CHARACTER SET latin1;
CREATE TABLE `_followRelation` (
`A` VARCHAR(64),
`B` VARCHAR(64)
) CHARACTER SET latin1;
