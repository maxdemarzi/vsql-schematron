[Implied]  letter.club_id -> club.club_id
[Implied]  letter.user_id -> user.user_id
[Implied]  letter_agree.letter_id -> letter.letter_id
[Implied]  letter_agree.user_id -> user.user_id
[Implied]  target.letter_id -> letter.letter_id
[Implied]  user_has_authority.authority_name -> authority.authority_name
[Implied]  user_has_authority.user_id -> user.user_id

DROP DATABASE `db_065200_timeletter_user`;
UNINSTALL EXTENSION vsql_schematron;
