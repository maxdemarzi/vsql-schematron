INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 084848_database
#
CREATE DATABASE `db_084848_database`;
USE `db_084848_database`;
CREATE TABLE `marks` (
`id` VARCHAR(255),
`title` VARCHAR(255),
`mark` VARCHAR(255),
`date` VARCHAR(255),
`username` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `planning` (
`id` VARCHAR(255),
`room` VARCHAR(255),
`teacher` VARCHAR(255),
`date` VARCHAR(255),
`start` VARCHAR(255),
`end` VARCHAR(255),
`subject` VARCHAR(255),
`username` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`username` VARCHAR(255),
`password` VARCHAR(255),
`email` VARCHAR(255)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_084848_database') AS relationships;
