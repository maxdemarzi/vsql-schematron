CREATE TABLE `posts` (
`id` INT,
`content` VARCHAR(255),
`title` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`text` VARCHAR(255),
`post_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts_tags` (
`posts_id` INT,
`tags_id` INT
) CHARACTER SET latin1;
