) CHARACTER SET latin1;
CREATE TABLE `persons` (
`person_id` INT NOT NULL,
`first_name` VARCHAR(50),
`salary` DECIMAL(10,2),
`passport_id` INT,
PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_060230_persons') AS relationships;
