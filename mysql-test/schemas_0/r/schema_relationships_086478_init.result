CREATE DATABASE `db_086478_init`;
USE `db_086478_init`;
CREATE TABLE `product` (
`id` VARCHAR(50) NOT NULL,
`title` TEXT,
`description` TEXT,
`price` INT,
`img` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stocks` (
`id` VARCHAR(50) NOT NULL,
`product_id` VARCHAR(50),
`count` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_086478_init') AS relationships;
