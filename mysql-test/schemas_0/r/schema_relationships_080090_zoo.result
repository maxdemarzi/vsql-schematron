INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 080090_zoo
#
CREATE DATABASE `db_080090_zoo`;
USE `db_080090_zoo`;
CREATE TABLE `zookeeper` (
`id` INT NOT NULL,
`fname` VARCHAR(50),
`lname` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `species` (
`id` INT NOT NULL,
`subphylum` VARCHAR(50),
`class` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `diet` (
`id` INT NOT NULL,
`type` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `habitat` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `animaldetails` (
`id` INT NOT NULL,
`info` VARCHAR(50),
`age` VARCHAR(50),
`weight` VARCHAR(50),
`food` VARCHAR(50),
`diet_id` INT,
`habitat_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `animal` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`photo` VARCHAR(50),
`zookeeper_id` INT,
`species_id` INT,
`details_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_080090_zoo') AS relationships;
relationships
Database: db_080090_zoo

Table Connections:
------------------
[Implied]  animal.details_id -> animaldetails.id
[Implied]  animal.species_id -> species.id
[Implied]  animal.zookeeper_id -> zookeeper.id
[Implied]  animaldetails.diet_id -> diet.id
[Implied]  animaldetails.habitat_id -> habitat.id

DROP DATABASE `db_080090_zoo`;
UNINSTALL EXTENSION vsql_schematron;
