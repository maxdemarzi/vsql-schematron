INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 041024_db
#
CREATE DATABASE `db_041024_db`;
USE `db_041024_db`;
CREATE TABLE `people` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `event_status` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `events` (
`id` INT,
`name` VARCHAR(64),
`time` DATETIME,
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scores` (
`id` INT,
`eid` INT,
`pid` INT,
`score` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_041024_db') AS relationships;
