INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 027406_schema
#
CREATE DATABASE `db_027406_schema`;
USE `db_027406_schema`;
CREATE TABLE `departments` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `managers` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_027406_schema') AS relationships;
relationships
Database: db_027406_schema

Table Connections:
------------------
[Implied]  employees.manager_id -> managers.id
[Implied]  employees.role_id -> roles.id
[Implied]  managers.department_id -> departments.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_027406_schema`;
UNINSTALL EXTENSION vsql_schematron;
