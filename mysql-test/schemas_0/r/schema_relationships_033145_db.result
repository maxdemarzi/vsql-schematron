[Implied]  account_history.account_id -> account.id
[Implied]  account_history.event_type_id -> event_type.id
[Implied]  address.account_id -> account.id
[Implied]  payment_info.account_id -> account.id

DROP DATABASE `db_033145_db`;
UNINSTALL EXTENSION vsql_schematron;
