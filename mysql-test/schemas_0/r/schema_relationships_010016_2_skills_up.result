INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 010016_2_skills_up
#
CREATE DATABASE `db_010016_2_skills_up`;
USE `db_010016_2_skills_up`;
CREATE TABLE `skills` (
`id` INT,
`name` VARCHAR(64),
`type` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job_skill` (
`id` INT,
`job_id` INT,
`skill_id` INT,
`level` INT,
`complexity` INT,
`cost` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pc_skill_proficiency` (
`id` INT,
`player_character_id` INT,
`skill_id` INT,
`proficiency` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_010016_2_skills_up') AS relationships;
relationships
