CREATE DATABASE `db_066314_Books_mysql`;
USE `db_066314_Books_mysql`;
CREATE TABLE `AUTHOR` (
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`biography` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
PRIMARY KEY (`firstname`)
) CHARACTER SET latin1;
CREATE TABLE `REVIEW` (
`title` VARCHAR(64),
`body` VARCHAR(64),
`rating` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
`username` VARCHAR(64),
`title_1` VARCHAR(64),
PRIMARY KEY (`title`)
) CHARACTER SET latin1;
CREATE TABLE `WRITE_IN` (
`name` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`title` VARCHAR(64),
`image` VARCHAR(64),
`summary` VARCHAR(64),
`nbr_page` VARCHAR(64),
`price` VARCHAR(64),
`publishedat` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
`firstname` VARCHAR(64),
PRIMARY KEY (`title`)
) CHARACTER SET latin1;
CREATE TABLE `RELEASED_IN` (
`name` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;
CREATE TABLE `FORMAT` (
`name` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
`username` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `LANGUAGE` (
`name` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `HAVE` (
`name` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`name`, `title`)
) CHARACTER SET latin1;
CREATE TABLE `GENRE` (
`name` VARCHAR(64),
`createdat` VARCHAR(64),
`updatedat` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
