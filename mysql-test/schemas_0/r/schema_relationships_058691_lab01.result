INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 058691_lab01
#
CREATE DATABASE `db_058691_lab01`;
USE `db_058691_lab01`;
CREATE TABLE `Log` (
`id` INT,
`_datetime` DATETIME,
`statusCode` VARCHAR(64),
`newRowId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Drivers` (
`driverId` INT,
`driverName` VARCHAR(64),
`driverSurname` VARCHAR(64),
`driverCode` INT,
`driverDOB` DATETIME,
PRIMARY KEY (`driverId`)
) CHARACTER SET latin1;
CREATE TABLE `Models` (
`modelId` INT,
`modelName` VARCHAR(64),
`payloadCapacity` INT,
PRIMARY KEY (`modelId`)
) CHARACTER SET latin1;
CREATE TABLE `Cars` (
`carId` INT,
`modelCode` INT,
`releaseYear` INT,
`markCode` INT,
`carNum` INT,
PRIMARY KEY (`carId`)
) CHARACTER SET latin1;
CREATE TABLE `Report` (
`travelId` INT,
`carId` INT,
`driverId` INT,
`dateOfExport` DATETIME,
`timeOfExport` DATETIME,
`cargoWeight` INT,
`returnDate` DATETIME,
`distanse` INT,
PRIMARY KEY (`travelId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_058691_lab01') AS relationships;
