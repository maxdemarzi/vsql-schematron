`vni` INT,
`vpc_id` VARCHAR(255),
`expired_at` DATETIME,
`expire_after` INT,
PRIMARY KEY (`facility_id`, `vni`)
) CHARACTER SET latin1;
CREATE TABLE `account_mac` (
`id` VARCHAR(255),
`account_id` VARCHAR(255),
`mac` VARCHAR(255),
`vpc_id` VARCHAR(255),
`subnet_id` VARCHAR(255),
`expired_at` DATETIME,
`expire_after` INT,
PRIMARY KEY (`account_id`, `mac`)
) CHARACTER SET latin1;
CREATE TABLE `router` (
`id` VARCHAR(255),
