PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `region` (
`id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `facility_network_transit` (
`src_facility_id` VARCHAR(255),
`dst_facility_id` VARCHAR(255),
