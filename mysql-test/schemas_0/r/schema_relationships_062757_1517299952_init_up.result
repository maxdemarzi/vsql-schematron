) CHARACTER SET latin1;
CREATE TABLE `security_group` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`description` VARCHAR(255),
`account_id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cn` (
`id` VARCHAR(255),
`facility_id` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
