`sample_type` VARCHAR(50),
`sample_volume` VARCHAR(50),
`volume_unit` VARCHAR(50),
`filter_min` VARCHAR(50),
`filter_max` VARCHAR(50),
`sample_description` VARCHAR(50),
`sample_name` VARCHAR(50),
`comments` VARCHAR(50),
`taxon_id` VARCHAR(50),
`collection_start_time` VARCHAR(50),
`collection_stop_time` VARCHAR(50),
`biomaterial_name` VARCHAR(50),
`description` VARCHAR(50),
`material_acc` VARCHAR(50),
`site_name` VARCHAR(50),
`latitude` VARCHAR(50),
`longitude` VARCHAR(50),
`altitude` VARCHAR(50),
`site_depth` VARCHAR(50),
`site_description` VARCHAR(50),
`country_name` VARCHAR(50),
`region` VARCHAR(50),
`habitat_name` VARCHAR(50),
`host_taxon_id` VARCHAR(50),
`host_description` VARCHAR(50),
`host_organism` VARCHAR(50),
`library_acc` VARCHAR(50),
`sequencing_method` VARCHAR(50),
`dna_type` VARCHAR(50),
`num_of_reads` VARCHAR(50),
`material_id` VARCHAR(50),
`other` VARCHAR(50),
PRIMARY KEY (`sample_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_008611_mysql') AS relationships;
