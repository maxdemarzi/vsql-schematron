CREATE DATABASE `db_041291_create_table_model`;
USE `db_041291_create_table_model`;
CREATE TABLE `org.Contact` (
`ContactId` VARCHAR(64),
`DateOfBirth` DATETIME,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`HeightFt` INT,
`HeightInch` INT,
`Picture` VARCHAR(64),
`PreferredHeight` VARCHAR(64),
PRIMARY KEY (`ContactId`)
) CHARACTER SET latin1;
CREATE TABLE `org.Organization` (
`OrganizationId` VARCHAR(64),
`Name` VARCHAR(64),
PRIMARY KEY (`OrganizationId`)
) CHARACTER SET latin1;
CREATE TABLE `org.WorkHistory` (
`WorkHistoryId` VARCHAR(64),
`ContactId` VARCHAR(64),
`OrganizationId` VARCHAR(64),
`StartMonth` VARCHAR(64),
`StartYear` VARCHAR(64),
`EndMonth` VARCHAR(64),
`EndYear` VARCHAR(64),
`JobDescription` VARCHAR(64),
`JobTitle` VARCHAR(64),
PRIMARY KEY (`WorkHistoryId`)
) CHARACTER SET latin1;
CREATE TABLE `org.ContactLink` (
`SourceContactId` VARCHAR(64),
`TargetContactId` VARCHAR(64),
`WorkHistoryId` VARCHAR(64),
PRIMARY KEY (`SourceContactId`, `TargetContactId`, `WorkHistoryId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_041291_create_table_model') AS relationships;
