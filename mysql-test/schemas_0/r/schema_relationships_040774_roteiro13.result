CREATE DATABASE `db_040774_roteiro13`;
USE `db_040774_roteiro13`;
CREATE TABLE `tbTipo` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbMorador` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`cpf` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbRepublica` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbConta` (
`id` INT NOT NULL,
`mes` VARCHAR(50),
`valor` DECIMAL(10,2),
`idTipo` INT,
`idRepublica` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbRateio` (
`id` INT NOT NULL,
`valor` DECIMAL(10,2),
`situacao` INT,
`idMorador` INT,
`idConta` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tbProduto` (
`id` INT NOT NULL,
`descricao` VARCHAR(50),
`valor` DECIMAL(10,2),
`quantidade` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_040774_roteiro13') AS relationships;
