[Implied]  USER_HELP_CONF.ID_USER -> USER.ID
[Implied]  USER_LOCATION.ID_USER -> USER.ID

DROP DATABASE `db_003470_ALL`;
UNINSTALL EXTENSION vsql_schematron;
