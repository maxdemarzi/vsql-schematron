INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 069462_database
#
CREATE DATABASE `db_069462_database`;
USE `db_069462_database`;
CREATE TABLE `userAccount` (
`idUserAccount` VARCHAR(50) NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`userName` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`idUserAccount`)
) CHARACTER SET latin1;
CREATE TABLE `addBook` (
`id` VARCHAR(50) NOT NULL,
`title` VARCHAR(50),
`author` VARCHAR(50),
`publisher` VARCHAR(50),
`quantity` INT,
`isAvail` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addMember` (
`memberID` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`phone` VARCHAR(50),
`gender` VARCHAR(50),
PRIMARY KEY (`memberID`)
) CHARACTER SET latin1;
CREATE TABLE `issuedBooks` (
`bookID` VARCHAR(50) NOT NULL,
`memberID` VARCHAR(50) NOT NULL,
`issueTime` TIMESTAMP NULL,
`renew_count` INT,
PRIMARY KEY (`bookID`, `memberID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_069462_database') AS relationships;
relationships
Database: db_069462_database

Table Connections:
------------------
[Implied]  issuedBooks.bookID -> addBook.id
[Implied]  issuedBooks.memberID -> addMember.memberID

DROP DATABASE `db_069462_database`;
UNINSTALL EXTENSION vsql_schematron;
