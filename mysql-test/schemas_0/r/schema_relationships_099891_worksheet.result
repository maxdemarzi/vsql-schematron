INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 099891_worksheet
#
CREATE DATABASE `db_099891_worksheet`;
USE `db_099891_worksheet`;
CREATE TABLE `persons` (
`person_id` INT,
`first_name` VARCHAR(64),
`salary` DECIMAL(10,2),
`passport_id` INT,
PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
CREATE TABLE `manufacturers` (
`manufacturer_id` INT,
`name` VARCHAR(64),
`established_on` DATETIME,
PRIMARY KEY (`manufacturer_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`student_id` INT,
`student_number` VARCHAR(64),
`student_name` VARCHAR(64),
`major_id` INT,
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `students_exams` (
`student_id` INT,
`exam_id` INT,
PRIMARY KEY (`student_id`, `exam_id`)
) CHARACTER SET latin1;
CREATE TABLE `cities` (
`city_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `item_types` (
`item_type_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`item_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT,
`name` VARCHAR(64),
`birthday` DATETIME,
`city_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`customer_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT,
`name` VARCHAR(64),
`item_type_id` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_id` INT,
`item_id` INT
) CHARACTER SET latin1;
CREATE TABLE `subjects` (
`subject_id` INT,
`subject_name` VARCHAR(64),
PRIMARY KEY (`subject_id`)
) CHARACTER SET latin1;
CREATE TABLE `majors` (
`major_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`major_id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`payment_id` INT,
`payment_date` DATETIME,
`payment_amount` DECIMAL(10,2),
`student_id` INT,
PRIMARY KEY (`payment_id`)
) CHARACTER SET latin1;
CREATE TABLE `agenda` (
`student_id` INT,
`subject_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_099891_worksheet') AS relationships;
relationships
