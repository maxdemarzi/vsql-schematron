INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 031277_db
#
CREATE DATABASE `db_031277_db`;
USE `db_031277_db`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`info` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `periods` (
`period_id` VARCHAR(50) NOT NULL,
`user` VARCHAR(50),
`start` TIMESTAMP NULL,
`length` INT,
`info` TEXT,
PRIMARY KEY (`period_id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`task_id` VARCHAR(50) NOT NULL,
`user` VARCHAR(50),
`name` VARCHAR(50),
`status` BOOLEAN,
`date` TIMESTAMP NULL,
PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_031277_db') AS relationships;
