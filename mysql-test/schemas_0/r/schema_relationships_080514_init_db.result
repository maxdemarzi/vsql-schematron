CREATE DATABASE `db_080514_init_db`;
USE `db_080514_init_db`;
CREATE TABLE `dwh.dim_calendar` (
`date_id` INT,
`date_value` DATETIME,
`day_num` INT,
`month_num` INT,
`year_num` INT,
`month_name` VARCHAR(64),
`eff_dttm` DATETIME,
`exp_dttm` DATETIME,
`load_dttm` DATETIME,
PRIMARY KEY (`date_id`)
) CHARACTER SET latin1;
CREATE TABLE `dwh.dim_citizenship` (
`citizenship_id` INT,
