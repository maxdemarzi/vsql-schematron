INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 038252_schema
#
CREATE DATABASE `db_038252_schema`;
USE `db_038252_schema`;
CREATE TABLE `customer` (
`customer_id` BIGINT NOT NULL,
`id` BLOB,
`name` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`product_id` BIGINT NOT NULL,
`id` BLOB,
`customer_id` BIGINT,
`price` DOUBLE,
`image` VARCHAR(50),
`brand` VARCHAR(50),
`title` VARCHAR(50),
`review_score` DOUBLE,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `user_role` (
`username` VARCHAR(50) NOT NULL,
`role` VARCHAR(50) NOT NULL,
PRIMARY KEY (`username`, `role`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_038252_schema') AS relationships;
relationships
Database: db_038252_schema

