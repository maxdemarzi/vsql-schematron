PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `files` (
`id` VARCHAR(64),
`type_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `versions` (
`id` VARCHAR(64),
`file_id` VARCHAR(64),
`contents_sha` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
`id` VARCHAR(64),
`external_id` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documents_files` (
`document_id` VARCHAR(64),
`file_id` VARCHAR(64),
PRIMARY KEY (`document_id`, `file_id`)
) CHARACTER SET latin1;
CREATE TABLE `documents_metadata` (
`document_id` VARCHAR(64),
`key` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`document_id`, `key`)
) CHARACTER SET latin1;
CREATE TABLE `files_metadata` (
`file_id` VARCHAR(64),
`key` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`file_id`, `key`)
) CHARACTER SET latin1;
