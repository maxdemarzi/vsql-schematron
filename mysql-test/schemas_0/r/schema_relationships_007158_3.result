INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 007158_3
#
CREATE DATABASE `db_007158_3`;
USE `db_007158_3`;
CREATE TABLE `BOAT` (
`BID` VARCHAR(50) NOT NULL,
`BNAME` VARCHAR(50),
`COLOUR` VARCHAR(50),
PRIMARY KEY (`BID`)
) CHARACTER SET latin1;
CREATE TABLE `SAILOR` (
`SID` VARCHAR(50) NOT NULL,
`SNAME` VARCHAR(50),
`AGE` VARCHAR(50),
`RATING` VARCHAR(50),
PRIMARY KEY (`SID`)
) CHARACTER SET latin1;
CREATE TABLE `RESERVES` (
`BID` VARCHAR(50) NOT NULL,
`SID` VARCHAR(50) NOT NULL,
`DAY` VARCHAR(50),
PRIMARY KEY (`BID`, `SID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_007158_3') AS relationships;
