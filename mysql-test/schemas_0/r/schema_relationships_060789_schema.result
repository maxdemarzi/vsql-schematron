INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 060789_schema
#
CREATE DATABASE `db_060789_schema`;
USE `db_060789_schema`;
CREATE TABLE `tickets` (
`id` VARCHAR(50) NOT NULL,
`price` DECIMAL(10,2),
`location_from` VARCHAR(50),
`location_destination` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ticket_customer` (
`ticket_id` VARCHAR(50) NOT NULL,
`customer_id` VARCHAR(50) NOT NULL,
PRIMARY KEY (`ticket_id`, `customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
`id` VARCHAR(50) NOT NULL,
`status` VARCHAR(50),
`output_field` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_060789_schema') AS relationships;
