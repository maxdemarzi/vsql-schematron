INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 054823_banco
#
CREATE DATABASE `db_054823_banco`;
USE `db_054823_banco`;
CREATE TABLE `BOMBA` (
`COD_BOMBA` INT NOT NULL,
`DES_BOM` VARCHAR(50),
PRIMARY KEY (`COD_BOMBA`)
) CHARACTER SET latin1;
CREATE TABLE `COMBUSTIVEL` (
`COD_COMBUSTIVEL` INT NOT NULL,
`DES_COMBUSTIVEL` VARCHAR(50),
`PRC_COMBUSTIVEL` DOUBLE,
`IMPOSTO` DOUBLE,
PRIMARY KEY (`COD_COMBUSTIVEL`)
) CHARACTER SET latin1;
CREATE TABLE `FRENTISTA` (
`COD_FRENTISTA` INT NOT NULL,
`DES_FRENTISTA` VARCHAR(50),
PRIMARY KEY (`COD_FRENTISTA`)
) CHARACTER SET latin1;
CREATE TABLE `TANQUE` (
`COD_TANQUE` INT NOT NULL,
`DES_TANQUE` VARCHAR(50),
`QTD_VOLUME` DOUBLE,
PRIMARY KEY (`COD_TANQUE`)
) CHARACTER SET latin1;
CREATE TABLE `VENDA` (
`COD_MOVIMENTO` INT NOT NULL,
`DAT_MOVIMENTO` DATE,
`COD_TANQUE` INT,
`COD_BOMBA` INT,
`COD_COMBUSTIVEL` INT,
`COD_FRENTISTA` INT,
`QTD_LITRO` DOUBLE,
`PRC_LITRO` DOUBLE,
`IMPOSTO` DOUBLE,
`VAL_IMPOSTO` DOUBLE,
`VAL_VENDA` DOUBLE,
PRIMARY KEY (`COD_MOVIMENTO`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_054823_banco') AS relationships;
relationships
Database: db_054823_banco

Table Connections:
------------------
[Implied]  VENDA.COD_BOMBA -> BOMBA.COD_BOMBA
[Implied]  VENDA.COD_COMBUSTIVEL -> COMBUSTIVEL.COD_COMBUSTIVEL
[Implied]  VENDA.COD_FRENTISTA -> FRENTISTA.COD_FRENTISTA
[Implied]  VENDA.COD_TANQUE -> TANQUE.COD_TANQUE

DROP DATABASE `db_054823_banco`;
UNINSTALL EXTENSION vsql_schematron;
