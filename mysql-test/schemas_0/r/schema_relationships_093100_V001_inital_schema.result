INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 093100_V001_inital_schema
#
CREATE DATABASE `db_093100_V001_inital_schema`;
USE `db_093100_V001_inital_schema`;
CREATE TABLE `benchmark_run_measurements` (
`benchmark_run_id` INT,
`measurement_id` INT,
PRIMARY KEY (`benchmark_run_id`, `measurement_id`)
) CHARACTER SET latin1;
CREATE TABLE `benchmark_runs` (
`id` INT,
`name` VARCHAR(64),
`unique_name` VARCHAR(64),
`sequence_id` VARCHAR(64),
`started` DATETIME,
`ended` DATETIME,
`version` INT,
`environment_id` INT,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `benchmark_runs_attributes` (
`benchmark_run_id` INT,
`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`benchmark_run_id`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `benchmark_runs_variables` (
`benchmark_run_id` INT,
`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`benchmark_run_id`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `environment_attributes` (
`environment_id` INT,
`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`environment_id`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `environments` (
`id` INT,
`name` VARCHAR(64),
`version` INT,
`started` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `execution_attributes` (
`execution_id` INT,
`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`execution_id`, `name`)
) CHARACTER SET latin1;
CREATE TABLE `execution_measurements` (
`execution_id` INT,
`measurement_id` INT,
PRIMARY KEY (`execution_id`, `measurement_id`)
) CHARACTER SET latin1;
CREATE TABLE `executions` (
`id` INT,
`sequence_id` VARCHAR(64),
`benchmark_run_id` INT,
`started` DATETIME,
`ended` DATETIME,
`version` INT,
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurements` (
`id` INT,
`name` VARCHAR(64),
`unit` VARCHAR(64),
`value` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_093100_V001_inital_schema') AS relationships;
