CREATE DATABASE `db_099922_261`;
USE `db_099922_261`;
CREATE TABLE `cities` (
`city_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`city_id`)
) CHARACTER SET latin1;
CREATE TABLE `customers` (
`customer_id` INT NOT NULL,
`name` VARCHAR(50),
`birthday` DATE,
`city_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT NOT NULL,
`customer_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `item_types` (
`item_type_id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`item_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`item_id` INT NOT NULL,
`name` VARCHAR(50),
`item_type_id` INT,
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_items` (
`order_id` INT NOT NULL,
`item_id` INT NOT NULL,
PRIMARY KEY (`order_id`, `item_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_099922_261') AS relationships;
