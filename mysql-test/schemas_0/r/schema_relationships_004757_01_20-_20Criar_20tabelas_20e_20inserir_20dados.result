CREATE TABLE `Depto` (
`NrDepto` SMALLINT NOT NULL,
`NmDepto` CHAR(50),
`DsLocal` VARCHAR(50),
`VlOrcamento` DECIMAL(10,2),
PRIMARY KEY (`NrDepto`)
) CHARACTER SET latin1;
CREATE TABLE `Empregado` (
`NrEmpregado` INT NOT NULL,
`NmEmpregado` CHAR(50),
`NrGerente` INT,
`DsCargo` VARCHAR(50),
`NrDepto` SMALLINT,
`DtAdmissao` DATE,
`VlSalario` DECIMAL(10,2),
`VlComissao` DECIMAL(10,2),
PRIMARY KEY (`NrEmpregado`)
) CHARACTER SET latin1;
