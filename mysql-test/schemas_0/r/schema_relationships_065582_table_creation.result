CREATE DATABASE `db_065582_table_creation`;
USE `db_065582_table_creation`;
CREATE TABLE `Accommodation` (
`id` VARCHAR(64),
`title` VARCHAR(64),
`location` VARCHAR(64),
`price` INT,
`rooms` INT,
`rating` DECIMAL(10,2),
`type` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rating` (
`userId` VARCHAR(64),
`accoId` VARCHAR(64),
`rating` INT,
PRIMARY KEY (`accoId`, `userId`)
) CHARACTER SET latin1;
CREATE TABLE `Recommendation` (
`userId` VARCHAR(64),
`accoId` VARCHAR(64),
`prediction` DECIMAL(10,2),
PRIMARY KEY (`userId`, `accoId`)
) CHARACTER SET latin1;
