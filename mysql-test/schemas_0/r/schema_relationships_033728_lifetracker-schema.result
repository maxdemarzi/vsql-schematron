INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 033728_lifetracker-schema
#
CREATE DATABASE `db_033728_lifetracker_schema`;
USE `db_033728_lifetracker_schema`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`first_name` TEXT,
`last_name` TEXT,
`username` TEXT,
`email` TEXT,
`password` TEXT,
`is_admin` BOOLEAN,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercise_items` (
`id` INT NOT NULL,
`user_id` INT,
`name` TEXT,
`duration` INT,
`intensity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sleep_items` (
`id` INT NOT NULL,
`user_id` INT,
`start_date` DATE,
`end_date` DATE,
`start_time` TIME,
`end_time` TIME,
`hours` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `nutritional_items` (
`id` INT NOT NULL,
`user_id` INT,
`name` TEXT,
`calories` INT,
`quantity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_033728_lifetracker_schema') AS relationships;
relationships
Database: db_033728_lifetracker_schema

