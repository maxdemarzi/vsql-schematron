CREATE DATABASE `db_032235_create_tables`;
USE `db_032235_create_tables`;
CREATE TABLE `Conversations` (
`ID` INT NOT NULL,
`Title` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`Name` VARCHAR(50) NOT NULL,
PRIMARY KEY (`Name`)
) CHARACTER SET latin1;
CREATE TABLE `Participants` (
`ID` INT NOT NULL,
`Conversation_ID` INT,
`User_Name` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `Messages` (
`ID` INT NOT NULL,
`Conversation_ID` INT,
`User_Name` VARCHAR(50),
`Timestamp` INT,
`Content` TEXT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_032235_create_tables') AS relationships;
