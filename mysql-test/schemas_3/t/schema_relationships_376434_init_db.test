INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376434_init_db
--echo #
CREATE DATABASE `db_376434_init_db`;
USE `db_376434_init_db`;
CREATE TABLE `usuario` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `senha` VARCHAR(50),
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `papel` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `status` TINYINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario_papel` (
  `id` INT NOT NULL,
  `usuario_id` INT,
  `papel_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376434_init_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376434_init_db') AS relationships;
DROP DATABASE `db_376434_init_db`;
UNINSTALL EXTENSION vsql_schematron;
