INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 385246_V2_update_organization
--echo #
CREATE DATABASE `db_385246_V2_update_organization`;
USE `db_385246_V2_update_organization`;

CREATE TABLE `sec.org_category` (
  `id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `is_deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sec.assigned_org_category` (
  `org_code` VARCHAR(64),
  `org_category_code` VARCHAR(64),
  PRIMARY KEY (`org_code`, `org_category_code`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_385246_V2_update_organization') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_385246_V2_update_organization') AS relationships;
DROP DATABASE `db_385246_V2_update_organization`;
UNINSTALL EXTENSION vsql_schematron;
