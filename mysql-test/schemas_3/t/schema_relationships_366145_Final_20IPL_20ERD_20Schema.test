INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366145_Final%20IPL%20ERD%20Schema
--echo #
CREATE DATABASE `db_366145_Final_20IPL_20ERD_20Schema`;
USE `db_366145_Final_20IPL_20ERD_20Schema`;

CREATE TABLE `Players` (
  `Player_Id` VARCHAR(64),
  `Player_Name` VARCHAR(64),
  `DOB` VARCHAR(64),
  `Batting_Hand` VARCHAR(64),
  `Bowling_Skill` VARCHAR(64),
  `Country` VARCHAR(64),
  `Is_Umpire` INT,
  `age` DECIMAL(10,2),
  `Cntry_code` VARCHAR(64),
  `Series_BestBatsman` DECIMAL(10,2),
  `Series_BestBowler` DECIMAL(10,2),
  `Manoftheseries` DECIMAL(10,2),
  PRIMARY KEY (`Player_Id`)
) CHARACTER SET latin1;

CREATE TABLE `Matches` (
  `Match_Id` VARCHAR(64),
  `Match_Date` VARCHAR(64),
  `Team_Name_Id` VARCHAR(64),
  `Opponent_Team_Id` VARCHAR(64),
  `Season_Id` VARCHAR(64),
  `Venue_Name` VARCHAR(64),
  `Toss_Winner_Id` INT,
  `Toss_Decision` VARCHAR(64),
  `IS_Superover` INT,
  `IS_Result` INT,
  `Is_DuckWorthLewis` INT,
  `Win_Type` VARCHAR(64),
  `Won_By` VARCHAR(64),
  `Match_Winner_Id` VARCHAR(64),
  `Man_Of_The_Match_Id` VARCHAR(64),
  `First_Umpire_Id` VARCHAR(64),
  `Second_Umpire_Id` VARCHAR(64),
  `City_Name` VARCHAR(64),
  `Host_Country` VARCHAR(64),
  `Team1_Name` VARCHAR(64),
  `Team1_Short_Code` VARCHAR(64),
  `Opponent_Team_Name` VARCHAR(64),
  `OpponentTeam_Short_Code` VARCHAR(64),
  `Season_Year` VARCHAR(64),
  `Orange_Cap_Id` VARCHAR(64),
  `Purple_Cap_Id` VARCHAR(64),
  `Man_of_the_Series_Id` VARCHAR(64),
  PRIMARY KEY (`Match_Id`)
) CHARACTER SET latin1;

CREATE TABLE `Player_Match` (
  `Match_Id` VARCHAR(64),
  `Player_Id` VARCHAR(64),
  `Team_Id` VARCHAR(64),
  `Is_Keeper` INT,
  `Is_Captain` INT,
  PRIMARY KEY (`Match_Id`, `Player_Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366145_Final_20IPL_20ERD_20Schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366145_Final_20IPL_20ERD_20Schema') AS relationships;
DROP DATABASE `db_366145_Final_20IPL_20ERD_20Schema`;
UNINSTALL EXTENSION vsql_schematron;
