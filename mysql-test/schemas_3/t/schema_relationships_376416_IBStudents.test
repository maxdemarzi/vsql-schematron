INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376416_IBStudents
--echo #
CREATE DATABASE `db_376416_IBStudents`;
USE `db_376416_IBStudents`;

CREATE TABLE `STUDENTS_TBL` (
  `ID` INT,
  `FAKNO` VARCHAR(64),
  `NAME` VARCHAR(64),
  `FAM` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `SUBJECTS_TBL` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `NOTES_TBL` (
  `ID` INT,
  `STID` INT,
  `SBID` INT,
  `NOTE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376416_IBStudents') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376416_IBStudents') AS relationships;
DROP DATABASE `db_376416_IBStudents`;
UNINSTALL EXTENSION vsql_schematron;
