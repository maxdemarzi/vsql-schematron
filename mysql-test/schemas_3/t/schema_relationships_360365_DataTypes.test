INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360365_DataTypes
--echo #
CREATE DATABASE `db_360365_DataTypes`;
USE `db_360365_DataTypes`;

CREATE TABLE `aac_et` (
  `alternate_auto_counter` INT,
  PRIMARY KEY (`alternate_auto_counter`)
) CHARACTER SET latin1;

CREATE TABLE `aac_sub` (
  `aac_et_alternate_auto_counter` INT,
  PRIMARY KEY (`aac_et_alternate_auto_counter`)
) CHARACTER SET latin1;

CREATE TABLE `ag_et` (
  `alternate_guid` VARCHAR(64),
  PRIMARY KEY (`alternate_guid`)
) CHARACTER SET latin1;

CREATE TABLE `ag_sub` (
  `ag_et_alternate_guid` VARCHAR(64),
  PRIMARY KEY (`ag_et_alternate_guid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360365_DataTypes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360365_DataTypes') AS relationships;
DROP DATABASE `db_360365_DataTypes`;
UNINSTALL EXTENSION vsql_schematron;
