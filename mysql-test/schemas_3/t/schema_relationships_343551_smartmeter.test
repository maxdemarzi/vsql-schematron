INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343551_smartmeter
--echo #
CREATE DATABASE `db_343551_smartmeter`;
USE `db_343551_smartmeter`;
CREATE TABLE `sensors` (
  `id` INT NOT NULL,
  `serial` VARCHAR(50),
  `custom_id` VARCHAR(50),
  `device_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `plan` (
  `id` INT NOT NULL,
  `price` DOUBLE,
  `rate` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `live` (
  `time` TIMESTAMP NULL,
  `sensor_id` INT,
  `plan_id` INT,
  `energy` DOUBLE,
  `power` DOUBLE,
  `power_l1` DOUBLE,
  `power_l2` DOUBLE,
  `power_l3` DOUBLE,
  `voltage_l1` DOUBLE,
  `voltage_l2` DOUBLE,
  `voltage_l3` DOUBLE,
  `lifetime` BIGINT,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343551_smartmeter') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343551_smartmeter') AS relationships;
DROP DATABASE `db_343551_smartmeter`;
UNINSTALL EXTENSION vsql_schematron;
