INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 388817_beer_aniket
--echo #
CREATE DATABASE `db_388817_beer_aniket`;
USE `db_388817_beer_aniket`;

CREATE TABLE `Brewers` (
  `id` INT,
  `name` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Beers` (
  `id` INT,
  `name` VARCHAR(64),
  `brewer` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Bars` (
  `id` INT,
  `name` VARCHAR(64),
  `addr` VARCHAR(64),
  `license` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Drinkers` (
  `id` INT,
  `name` VARCHAR(64),
  `addr` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Sells` (
  `bar` INT,
  `beer` INT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`bar`, `beer`)
) CHARACTER SET latin1;

CREATE TABLE `Likes` (
  `drinker` INT,
  `beer` INT,
  PRIMARY KEY (`drinker`, `beer`)
) CHARACTER SET latin1;

CREATE TABLE `Frequents` (
  `drinker` INT,
  `bar` INT,
  PRIMARY KEY (`drinker`, `bar`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_388817_beer_aniket') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_388817_beer_aniket') AS relationships;
DROP DATABASE `db_388817_beer_aniket`;
UNINSTALL EXTENSION vsql_schematron;
