INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381480_init
--echo #
CREATE DATABASE `db_381480_init`;
USE `db_381480_init`;
CREATE TABLE `stock` (
  `id` INT NOT NULL,
  `symbol` TEXT,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ohlc_data` (
  `id` INT NOT NULL,
  `dt` TIMESTAMP NULL,
  `stock_id` INT,
  `open` DECIMAL(10,2),
  `high` DECIMAL(10,2),
  `low` DECIMAL(10,2),
  `close` DECIMAL(10,2),
  `volume` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tick_data` (
  `id` INT NOT NULL,
  `dt` TIMESTAMP NULL,
  `stock_id` INT,
  `bid` DECIMAL(10,2),
  `ask` DECIMAL(10,2),
  `ltp` DECIMAL(10,2),
  `ltv` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381480_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381480_init') AS relationships;
DROP DATABASE `db_381480_init`;
UNINSTALL EXTENSION vsql_schematron;
