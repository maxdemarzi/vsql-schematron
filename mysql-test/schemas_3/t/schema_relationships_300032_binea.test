INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 300032_binea
--echo #
CREATE DATABASE `db_300032_binea`;
USE `db_300032_binea`;

CREATE TABLE `cms_comment` (
  `comment_id` INT,
  `pid` INT,
  `article_id` INT,
  `user_id` INT,
  `content` VARCHAR(64),
  `status` INT,
  `ip` VARCHAR(64),
  `agent` VARCHAR(64),
  `ctime` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_300032_binea') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_300032_binea') AS relationships;
DROP DATABASE `db_300032_binea`;
UNINSTALL EXTENSION vsql_schematron;
