INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 315560_000001_init.up
--echo #
CREATE DATABASE `db_315560_000001_init_up`;
USE `db_315560_000001_init_up`;

CREATE TABLE `Users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `company` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserInterest` (
  `id` INT,
  `userId` INT,
  `topic` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Instructors` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `company` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `InstructorExpertise` (
  `id` INT,
  `instructorId` INT,
  `topic` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Courses` (
  `id` INT,
  `instructorId` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CourseTopic` (
  `id` INT,
  `courseId` INT,
  `topic` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CourseAttendee` (
  `id` INT,
  `courseId` INT,
  `attendeeId` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_315560_000001_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_315560_000001_init_up') AS relationships;
DROP DATABASE `db_315560_000001_init_up`;
UNINSTALL EXTENSION vsql_schematron;
