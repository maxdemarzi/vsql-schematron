INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303153_MenswearDB
--echo #
CREATE DATABASE `db_303153_MenswearDB`;
USE `db_303153_MenswearDB`;

CREATE TABLE `Sellers` (
  `seller_id` INT,
  `seller_name` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_pass` VARCHAR(64),
  PRIMARY KEY (`seller_id`)
) CHARACTER SET latin1;

CREATE TABLE `Categories` (
  `category_id` INT,
  `category_name` VARCHAR(64),
  PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;

CREATE TABLE `Sizes` (
  `size_id` INT,
  `size_name` VARCHAR(64),
  PRIMARY KEY (`size_id`)
) CHARACTER SET latin1;

CREATE TABLE `Colors` (
  `color_id` INT,
  `color_name` VARCHAR(64),
  PRIMARY KEY (`color_id`)
) CHARACTER SET latin1;

CREATE TABLE `Customers` (
  `customer_id` INT,
  `customer_name` VARCHAR(64),
  `customer_phone` VARCHAR(64),
  PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;

CREATE TABLE `Menswears` (
  `menswear_id` INT,
  `menswear_name` VARCHAR(64),
  `menswear_description` VARCHAR(64),
  `menswear_brand` VARCHAR(64),
  `menswear_material` VARCHAR(64),
  `menswear_price` DECIMAL(10,2),
  `amount` INT,
  `category_id` INT,
  PRIMARY KEY (`menswear_id`)
) CHARACTER SET latin1;

CREATE TABLE `MenswearTables` (
  `menswear_id` INT,
  `size_id` INT,
  `color_id` INT,
  `quantity` INT,
  PRIMARY KEY (`menswear_id`, `size_id`, `color_id`)
) CHARACTER SET latin1;

CREATE TABLE `Invoices` (
  `invoice_no` INT,
  `invoice_date` DATETIME,
  `invoice_status` INT,
  `customer_id` INT,
  `seller_id` INT,
  PRIMARY KEY (`invoice_no`)
) CHARACTER SET latin1;

CREATE TABLE `InvoiceDetails` (
  `invoice_no` INT,
  `menswear_id` INT,
  `total_due` DECIMAL(10,2),
  `quantity` INT,
  PRIMARY KEY (`invoice_no`, `menswear_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303153_MenswearDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303153_MenswearDB') AS relationships;
DROP DATABASE `db_303153_MenswearDB`;
UNINSTALL EXTENSION vsql_schematron;
