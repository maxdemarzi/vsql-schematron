INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307718_data_design
--echo #
CREATE DATABASE `db_307718_data_design`;
USE `db_307718_data_design`;

CREATE TABLE `profile` (
  `profileId` INT,
  `profileActivationToken` VARCHAR(255),
  `profileEmail` VARCHAR(255),
  `profileHash` VARCHAR(255),
  `profilePhone` VARCHAR(255),
  `profileSalt` VARCHAR(255),
  PRIMARY KEY (`profileId`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `productId` INT,
  `productName` VARCHAR(255),
  `productPrice` DECIMAL(10,2),
  PRIMARY KEY (`productId`)
) CHARACTER SET latin1;

CREATE TABLE `favorite` (
  `favoriteProfileId` INT,
  `favoriteProductId` INT,
  `favoriteDate` DATETIME,
  PRIMARY KEY (`favoriteProfileId`, `favoriteProductId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307718_data_design') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307718_data_design') AS relationships;
DROP DATABASE `db_307718_data_design`;
UNINSTALL EXTENSION vsql_schematron;
