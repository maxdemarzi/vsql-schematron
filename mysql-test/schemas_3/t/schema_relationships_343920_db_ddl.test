INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343920_db-ddl
--echo #
CREATE DATABASE `db_343920_db_ddl`;
USE `db_343920_db_ddl`;

CREATE TABLE `Community` (
  `uuid` VARCHAR(64),
  `name` VARCHAR(64),
  `short_name` VARCHAR(64),
  `handle` VARCHAR(64),
  `notes` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Collection` (
  `uuid` VARCHAR(64),
  `comm_uuid` VARCHAR(64),
  `name` VARCHAR(64),
  `short_name` VARCHAR(64),
  `reportable` DECIMAL(10,2),
  `owner` VARCHAR(64),
  `handle` VARCHAR(64),
  `notes` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `Monthly_Item_Count` (
  `coll_uuid` INT,
  `year` INT,
  `month` INT,
  `item_count` INT
) CHARACTER SET latin1;

CREATE TABLE `FilesProcessed` (
  `name` VARCHAR(64),
  `timestamp` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `Email_Distribution` (
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `formats` VARCHAR(64),
  `active` DECIMAL(10,2),
  `notes` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343920_db_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343920_db_ddl') AS relationships;
DROP DATABASE `db_343920_db_ddl`;
UNINSTALL EXTENSION vsql_schematron;
