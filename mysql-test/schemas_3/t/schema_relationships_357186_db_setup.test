INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 357186_db_setup
--echo #
CREATE DATABASE `db_357186_db_setup`;
USE `db_357186_db_setup`;
CREATE TABLE `User` (
  `user_id` INT NOT NULL,
  `nome` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATE,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `Categoria` (
  `categoria_id` INT NOT NULL,
  `user_id` INT,
  `titulo` VARCHAR(50),
  `descricao` VARCHAR(50),
  `cor` VARCHAR(50),
  PRIMARY KEY (`categoria_id`)
) CHARACTER SET latin1;
CREATE TABLE `Paciente` (
  `paciente_id` INT NOT NULL,
  `user_id` INT,
  `categoria_id` INT,
  `nome` VARCHAR(50),
  `descricao` VARCHAR(50),
  `created_at` DATE,
  PRIMARY KEY (`paciente_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_357186_db_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_357186_db_setup') AS relationships;
DROP DATABASE `db_357186_db_setup`;
UNINSTALL EXTENSION vsql_schematron;
