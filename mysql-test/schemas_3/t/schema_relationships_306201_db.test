INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 306201_db
--echo #
CREATE DATABASE `db_306201_db`;
USE `db_306201_db`;

CREATE TABLE `device` (
  `device_id` VARCHAR(255),
  `device_state` INT,
  `device_name` VARCHAR(255),
  `account_id` INT,
  PRIMARY KEY (`device_id`)
) CHARACTER SET latin1;

CREATE TABLE `grouping` (
  `grouping_name` VARCHAR(255),
  `grouping_id` INT,
  `account_id` INT,
  PRIMARY KEY (`grouping_id`)
) CHARACTER SET latin1;

CREATE TABLE `traffic` (
  `traffic_ip` VARCHAR(255),
  `traffic_block` INT,
  PRIMARY KEY (`traffic_ip`)
) CHARACTER SET latin1;

CREATE TABLE `traffic_detail` (
  `traffic_ip` VARCHAR(255),
  `traffic_time` DATETIME,
  `traffic_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_306201_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_306201_db') AS relationships;
DROP DATABASE `db_306201_db`;
UNINSTALL EXTENSION vsql_schematron;
