INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 308649_db
--echo #
CREATE DATABASE `db_308649_db`;
USE `db_308649_db`;

CREATE TABLE `locations` (
  `id` INT,
  `locale_code` VARCHAR(64),
  `continent_code` VARCHAR(64),
  `continent_name` VARCHAR(64),
  `country_iso_code` VARCHAR(64),
  `country_name` VARCHAR(64),
  `is_in_european_union` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `networks` (
  `network` VARCHAR(64),
  `geoname_id` INT,
  `registered_country_geoname_id` INT,
  `represented_country_geoname_id` INT,
  `is_anonymous_proxy` BOOL,
  `is_satellite_provider` BOOL,
  PRIMARY KEY (`network`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_308649_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_308649_db') AS relationships;
DROP DATABASE `db_308649_db`;
UNINSTALL EXTENSION vsql_schematron;
