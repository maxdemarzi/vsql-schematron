INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 350601_schema
--echo #
CREATE DATABASE `db_350601_schema`;
USE `db_350601_schema`;

CREATE TABLE `USERS` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `QUESTIONS` (
  `ID` INT,
  `Q_TEXT` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HISTORY` (
  `TIME` DATETIME,
  `ANSWER` VARCHAR(64),
  `EXPECTED_ANSWER` VARCHAR(64),
  `TIME_TO_ANSWER` INT,
  `TARGET_TIME_TO_ANSWER` INT,
  `NUMBER_ATTEMPTS` INT,
  `Q_ID` INT,
  `U_ID` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_350601_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_350601_schema') AS relationships;
DROP DATABASE `db_350601_schema`;
UNINSTALL EXTENSION vsql_schematron;
