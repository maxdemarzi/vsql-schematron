INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 338742_V1__init
--echo #
CREATE DATABASE `db_338742_V1__init`;
USE `db_338742_V1__init`;
CREATE TABLE `articles` (
  `id` INT NOT NULL,
  `title` TEXT,
  `body` TEXT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
  `id` INT NOT NULL,
  `name` TEXT,
  `created_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_tags` (
  `id` INT NOT NULL,
  `article_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_338742_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_338742_V1__init') AS relationships;
DROP DATABASE `db_338742_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
