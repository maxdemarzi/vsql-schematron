INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333829_mysql-schema
--echo #
CREATE DATABASE `db_333829_mysql_schema`;
USE `db_333829_mysql_schema`;
CREATE TABLE `user` (
  `username` VARCHAR(50) NOT NULL,
  `created_date` DATETIME,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `receiver` (
  `receiver_id` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `dash_payment_address` VARCHAR(50),
  `amount_fiat` DECIMAL(10,2),
  `type_fiat` VARCHAR(50),
  `base_fiat` DECIMAL(10,2),
  `amount_duffs` BIGINT,
  `payment_received_amount_duffs` BIGINT,
  `created_date` DATETIME,
  `payment_date` DATETIME,
  `description` VARCHAR(50),
  `callback_url` VARCHAR(50),
  PRIMARY KEY (`receiver_id`)
) CHARACTER SET latin1;
CREATE TABLE `data_cache` (
  `cache_key` VARCHAR(50) NOT NULL,
  `cache_data` VARCHAR(50),
  PRIMARY KEY (`cache_key`)
) CHARACTER SET latin1;
CREATE TABLE `counter` (
  `counter_key` VARCHAR(50) NOT NULL,
  `counter_value` BIGINT,
  PRIMARY KEY (`counter_key`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333829_mysql_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333829_mysql_schema') AS relationships;
DROP DATABASE `db_333829_mysql_schema`;
UNINSTALL EXTENSION vsql_schematron;
