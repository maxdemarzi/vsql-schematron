INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 323503_user_access
--echo #
CREATE DATABASE `db_323503_user_access`;
USE `db_323503_user_access`;
CREATE TABLE `user_type` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `akses` (
  `id` INT NOT NULL,
  `pid` INT,
  `nama` VARCHAR(50),
  `icon` VARCHAR(50),
  `link` VARCHAR(50),
  `urutan` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user_type_akses` (
  `id` INT NOT NULL,
  `user_type_id` INT,
  `akses_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_323503_user_access') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_323503_user_access') AS relationships;
DROP DATABASE `db_323503_user_access`;
UNINSTALL EXTENSION vsql_schematron;
