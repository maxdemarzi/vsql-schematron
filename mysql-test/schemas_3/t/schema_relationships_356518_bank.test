INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 356518_bank
--echo #
CREATE DATABASE `db_356518_bank`;
USE `db_356518_bank`;

CREATE TABLE `borrower` (
  `cust_name` VARCHAR(64),
  `loan_no` INT
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `branch_name` VARCHAR(64),
  `branch_city` VARCHAR(64),
  `assets` INT,
  PRIMARY KEY (`branch_name`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `cust_name` VARCHAR(64),
  `cust_street` VARCHAR(64),
  `cust_city` VARCHAR(64),
  PRIMARY KEY (`cust_name`)
) CHARACTER SET latin1;

CREATE TABLE `depositor` (
  `cust_name` VARCHAR(64),
  `acc_no` INT
) CHARACTER SET latin1;

CREATE TABLE `employee` (
  `employee_name` VARCHAR(64),
  `branch_name` VARCHAR(64),
  `salary` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_356518_bank') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_356518_bank') AS relationships;
DROP DATABASE `db_356518_bank`;
UNINSTALL EXTENSION vsql_schematron;
