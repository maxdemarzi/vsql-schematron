INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348642_assignment3
--echo #
CREATE DATABASE `db_348642_assignment3`;
USE `db_348642_assignment3`;
CREATE TABLE `team` (
  `jersy_no` DECIMAL(10,2),
  `player_name` VARCHAR(50) NOT NULL,
  `team` VARCHAR(50),
  PRIMARY KEY (`player_name`)
) CHARACTER SET latin1;
CREATE TABLE `run` (
  `player_name` VARCHAR(50),
  `against` VARCHAR(50),
  `run` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348642_assignment3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348642_assignment3') AS relationships;
DROP DATABASE `db_348642_assignment3`;
UNINSTALL EXTENSION vsql_schematron;
