INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 388680_lffOJ
--echo #
CREATE DATABASE `db_388680_lffOJ`;
USE `db_388680_lffOJ`;

CREATE TABLE `Users` (
  `Id` INT,
  `Email` VARCHAR(64),
  `IsAdmin` INT,
  `Password` VARCHAR(64),
  `Nickname` VARCHAR(64),
  `RegisterDate` DATETIME,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Trainings` (
  `Id` INT,
  `Title` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Submission` (
  `Id` INT,
  `UserId` VARCHAR(64),
  `TrainingId` INT,
  `Status` VARCHAR(64),
  `ExcuteTime` INT,
  `MemoryUsed` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_388680_lffOJ') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_388680_lffOJ') AS relationships;
DROP DATABASE `db_388680_lffOJ`;
UNINSTALL EXTENSION vsql_schematron;
