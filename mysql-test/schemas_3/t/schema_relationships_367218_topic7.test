INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 367218_topic7
--echo #
CREATE DATABASE `db_367218_topic7`;
USE `db_367218_topic7`;
CREATE TABLE `order_statuses` (
  `id` VARCHAR(50) NOT NULL,
  `status_id` INT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `status_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_367218_topic7') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_367218_topic7') AS relationships;
DROP DATABASE `db_367218_topic7`;
UNINSTALL EXTENSION vsql_schematron;
