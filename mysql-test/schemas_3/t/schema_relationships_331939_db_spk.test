INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331939_db_spk
--echo #
CREATE DATABASE `db_331939_db_spk`;
USE `db_331939_db_spk`;
CREATE TABLE `tb_klasifikasi` (
  `id_klasifikasi` INT,
  `id_uji` INT,
  `no_kk` VARCHAR(50),
  `nik` VARCHAR(50),
  `nama` VARCHAR(50),
  `alamat` TEXT,
  `jenis_pkj` VARCHAR(50),
  `jml_phsl` INT,
  `jml_art` INT,
  `pengeluaran` VARCHAR(50),
  `status_tmpt` VARCHAR(50),
  `kelas_asli` VARCHAR(50),
  `layak` VARCHAR(50),
  `tidak` VARCHAR(50),
  `label_prediksi` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tb_penduduk` (
  `id_penduduk` INT NOT NULL,
  `no_kk` VARCHAR(50),
  `nik` VARCHAR(50),
  `nama` VARCHAR(50),
  `alamat` TEXT,
  `jenis_pkj` VARCHAR(50),
  `jml_phsl` INT,
  `jml_art` INT,
  `pengeluaran` VARCHAR(50),
  `status_tmpt` VARCHAR(50),
  `klasifikasi` VARCHAR(50),
  PRIMARY KEY (`id_penduduk`)
) CHARACTER SET latin1;
CREATE TABLE `tb_uji` (
  `id_uji` INT NOT NULL,
  `no_kk` VARCHAR(50),
  `nik` VARCHAR(50),
  `nama` VARCHAR(50),
  `alamat` TEXT,
  `jenis_pkj` VARCHAR(50),
  `jml_phsl` INT,
  `jml_art` INT,
  `pengeluaran` VARCHAR(50),
  `status_tmpt` VARCHAR(50),
  `kelas_asli` VARCHAR(50),
  PRIMARY KEY (`id_uji`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id_user` INT NOT NULL,
  `nama` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `akses` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331939_db_spk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331939_db_spk') AS relationships;
DROP DATABASE `db_331939_db_spk`;
UNINSTALL EXTENSION vsql_schematron;
