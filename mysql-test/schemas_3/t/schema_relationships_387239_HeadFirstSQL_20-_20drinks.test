INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 387239_HeadFirstSQL%20-%20drinks
--echo #
CREATE DATABASE `db_387239_HeadFirstSQL_20__20drinks`;
USE `db_387239_HeadFirstSQL_20__20drinks`;
CREATE TABLE `easy_drinks` (
  `drink_name` VARCHAR(50),
  `main` VARCHAR(50),
  `amount1` DOUBLE,
  `second` VARCHAR(50),
  `amount2` DOUBLE,
  `directions` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `info_main` (
  `id` INT,
  `main_id` INT,
  `amount` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `main` (
  `main_id` INT NOT NULL,
  `main` VARCHAR(50),
  PRIMARY KEY (`main_id`)
) CHARACTER SET latin1;
CREATE TABLE `info_second` (
  `id` INT,
  `second_id` INT,
  `amount` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `_second` (
  `second_id` INT NOT NULL,
  `_second` VARCHAR(50),
  PRIMARY KEY (`second_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_387239_HeadFirstSQL_20__20drinks') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_387239_HeadFirstSQL_20__20drinks') AS relationships;
DROP DATABASE `db_387239_HeadFirstSQL_20__20drinks`;
UNINSTALL EXTENSION vsql_schematron;
