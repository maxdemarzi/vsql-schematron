INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383898_schema
--echo #
CREATE DATABASE `db_383898_schema`;
USE `db_383898_schema`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `article` (
  `id` INT,
  `uploader_id` INT,
  `uploaded` DATETIME,
  `published` VARCHAR(64),
  `author` VARCHAR(64),
  `title` VARCHAR(64),
  `body` VARCHAR(64),
  `sentiment` VARCHAR(64),
  `article_url` VARCHAR(64),
  `keyword` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383898_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383898_schema') AS relationships;
DROP DATABASE `db_383898_schema`;
UNINSTALL EXTENSION vsql_schematron;
