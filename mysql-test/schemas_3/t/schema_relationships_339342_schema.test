INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 339342_schema
--echo #
CREATE DATABASE `db_339342_schema`;
USE `db_339342_schema`;
CREATE TABLE `CUSTOMER` (
  `CUSTOMERID` INT NOT NULL,
  `CUSTOMERNAME` VARCHAR(50),
  PRIMARY KEY (`CUSTOMERID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
  `ITEMID` INT NOT NULL,
  `ITEMDESC` VARCHAR(50),
  `PRICE` DOUBLE,
  PRIMARY KEY (`ITEMID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERDETAIL` (
  `ORDERID` INT NOT NULL,
  `CUSTOMERID` INT,
  `ITEMID` INT,
  `QUANTITY` INT,
  PRIMARY KEY (`ORDERID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_339342_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_339342_schema') AS relationships;
DROP DATABASE `db_339342_schema`;
UNINSTALL EXTENSION vsql_schematron;
