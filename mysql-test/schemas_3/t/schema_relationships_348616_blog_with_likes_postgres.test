INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348616_blog_with_likes.postgres
--echo #
CREATE DATABASE `db_348616_blog_with_likes_postgres`;
USE `db_348616_blog_with_likes_postgres`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `password_digest` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `id` INT NOT NULL,
  `author_id` INT,
  `title` TEXT,
  `body` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `likes` (
  `id` INT NOT NULL,
  `article_id` INT,
  `user_id` INT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348616_blog_with_likes_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348616_blog_with_likes_postgres') AS relationships;
DROP DATABASE `db_348616_blog_with_likes_postgres`;
UNINSTALL EXTENSION vsql_schematron;
