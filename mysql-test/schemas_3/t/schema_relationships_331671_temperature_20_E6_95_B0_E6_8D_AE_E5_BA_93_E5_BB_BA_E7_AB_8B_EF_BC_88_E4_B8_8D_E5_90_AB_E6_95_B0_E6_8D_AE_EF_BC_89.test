CREATE DATABASE `db_331671_temperature_20_E6_95_B0_E6_8D_AE_E5_BA_93_E5_BB_BA`;
USE `db_331671_temperature_20_E6_95_B0_E6_8D_AE_E5_BA_93_E5_BB_BA`;

CREATE TABLE `USER` (
  `USER_ID` INT,
  `STATE` VARCHAR(64),
  `NICK_NAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `AVATR` VARCHAR(64),
  `GENDER` VARCHAR(64),
  `LOCATION` VARCHAR(64),
  `DOB` DATETIME,
  `EMAIL` VARCHAR(64),
  `TEL` VARCHAR(64),
  `WECHAT` VARCHAR(64),
  `ARTICLE_NUM` INT,
  `FOLLOW_NUM` INT,
  PRIMARY KEY (`USER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ZONE` (
  `ZONE_ID` INT,
  `ZONE_NAME` VARCHAR(64),
  `ZONE_ARTICLE_NUM` INT,
  `ZONE_TOPIC_NUM` INT,
  PRIMARY KEY (`ZONE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ARTICLE` (
  `ARTICLE_ID` INT,
  `TITLE` VARCHAR(64),
  `USER_ID` INT,
  `ARTICLE_CONTENT` VARCHAR(64),
  `ARTICLE_LIKES` INT,
  `COLLECT_NUM` INT,
  `READ_NUM` INT,
  `ARTICLE_UPLOAD_TIME` DATETIME,
  `ZONE_ID` INT,
  PRIMARY KEY (`ARTICLE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ARTICLE_COMMENT_REPLY` (
  `ARTICLE_CR_ID` INT,
