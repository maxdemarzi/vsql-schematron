CREATE TABLE `PHOTO_COMMENT` (
  `PHOTO_COMMENT_ID` INT,
  `PHOTO_COMMENT_CONTENT` VARCHAR(64),
  `PHOTO_ID` INT,
  `USER_ID` INT,
  `PHOTO_COMMENT_TIME` DATETIME,
  PRIMARY KEY (`PHOTO_COMMENT_ID`)
) CHARACTER SET latin1;

CREATE TABLE `TOPIC` (
  `TOPIC_ID` INT,
  `TOPIC_TITLE` VARCHAR(64),
  `TOPIC_CONTENT` VARCHAR(64),
