  `PASSIVE_USER_ID` INT,
  PRIMARY KEY (`ACTIVE_USER_ID`, `PASSIVE_USER_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331671_temperature_20_E6_95_B0_E6_8D_AE_E5_BA_93_E5_BB_BA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331671_temperature_20_E6_95_B0_E6_8D_AE_E5_BA_93_E5_BB_BA') AS relationships;
DROP DATABASE `db_331671_temperature_20_E6_95_B0_E6_8D_AE_E5_BA_93_E5_BB_BA`;
UNINSTALL EXTENSION vsql_schematron;
