  `ARTICLE_ID` INT,
  `USER_ID` INT,
  `ARTICLE_CR_TIME` DATETIME,
  `PARENT_CR_ID` INT,
  PRIMARY KEY (`ARTICLE_CR_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ARTICLE_RANK` (
  `ARTICLE_RANK_DATE` DATETIME,
  `ARTICLE_RANK_TIME` DATETIME,
  `ARTICLE_RANK_TYPE` VARCHAR(64),
  `ARTICLE_RANK` VARCHAR(64),
  `ARTICLE_ID` INT,
  PRIMARY KEY (`ARTICLE_RANK_DATE`, `ARTICLE_RANK_TIME`, `ARTICLE_RANK_TYPE`, `ARTICLE_RANK`)
) CHARACTER SET latin1;

CREATE TABLE `ARTICLE_VISIT` (
  `USER_ID` INT,
  `ARTICLE_ID` INT,
  `ARTICLE_VISIT_TIME` DATETIME,
  PRIMARY KEY (`USER_ID`, `ARTICLE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FAVOURITE` (
  `FAVOURITE_ID` INT,
  `FAVOURITE_NAME` VARCHAR(64),
