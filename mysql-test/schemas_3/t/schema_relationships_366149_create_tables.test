INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366149_create_tables
--echo #
CREATE DATABASE `db_366149_create_tables`;
USE `db_366149_create_tables`;
CREATE TABLE `Author` (
  `authorid` INT NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `country` VARCHAR(50),
  PRIMARY KEY (`authorid`)
) CHARACTER SET latin1;
CREATE TABLE `Publisher` (
  `publisherid` INT NOT NULL,
  `name` VARCHAR(50),
  `city` VARCHAR(50),
  `country` VARCHAR(50),
  PRIMARY KEY (`publisherid`)
) CHARACTER SET latin1;
CREATE TABLE `Book_Category` (
  `categoryid` INT NOT NULL,
  `description` VARCHAR(50),
  PRIMARY KEY (`categoryid`)
) CHARACTER SET latin1;
CREATE TABLE `Book_Catalog` (
  `bookid` INT NOT NULL,
  `title` VARCHAR(50),
  `authorid` INT,
  `publisherid` INT,
  `categoryid` INT,
  `yearofpublish` INT,
  `price` INT,
  PRIMARY KEY (`bookid`)
) CHARACTER SET latin1;
CREATE TABLE `Order_Details` (
  `orderno` INT NOT NULL,
  `bookid` INT NOT NULL,
  `quantity` INT,
  PRIMARY KEY (`orderno`, `bookid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366149_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366149_create_tables') AS relationships;
DROP DATABASE `db_366149_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
