INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 382193_V1__init
--echo #
CREATE DATABASE `db_382193_V1_init`;
USE `db_382193_V1_init`;

CREATE TABLE `conversion_category` (
  `id` INT,
  `category` VARCHAR(64),
  `base_unit` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `conversion_factor` (
  `id` INT,
  `conversion_category_id` INT,
  `target_unit` VARCHAR(64),
  `factor` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_382193_V1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_382193_V1_init') AS relationships;
DROP DATABASE `db_382193_V1_init`;
UNINSTALL EXTENSION vsql_schematron;
