INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 380817_postgres
--echo #
CREATE DATABASE `db_380817_postgres`;
USE `db_380817_postgres`;
CREATE TABLE `project` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `environment` (
  `id` INT NOT NULL,
  `project_id` INT,
  `name` VARCHAR(50),
  `key` VARCHAR(50),
  `description` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature` (
  `id` INT NOT NULL,
  `project_id` INT,
  `environment_id` INT,
  `name` VARCHAR(50),
  `key` VARCHAR(50),
  `description` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `version_type` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `description` VARCHAR(50),
  `is_enabled` INT,
  `created_by` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `version` (
  `id` INT NOT NULL,
  `key` VARCHAR(50),
  `version_type_id` INT,
  `feature_id` INT,
  `description` VARCHAR(50),
  `created_by` VARCHAR(50),
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `feature_version` (
  `id` INT NOT NULL,
  `created_by` VARCHAR(50),
  `version_id` INT,
  `feature_id` INT,
  `created` TIMESTAMP NULL,
  `last_modified` TIMESTAMP NULL,
  `last_modified_by` VARCHAR(50),
  `deleted` TIMESTAMP NULL,
  `deleted_by` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_380817_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_380817_postgres') AS relationships;
DROP DATABASE `db_380817_postgres`;
UNINSTALL EXTENSION vsql_schematron;
