INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352257_schema
--echo #
CREATE DATABASE `db_352257_schema`;
USE `db_352257_schema`;
CREATE TABLE `USERS` (
  `id` INT NOT NULL,
  `login` VARCHAR(50),
  `salt` VARCHAR(50),
  `config` VARCHAR(50),
  `name` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `HASHES` (
  `hash` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `REFRESH_SESSIONS` (
  `user_id` BIGINT,
  `refresh_token` VARCHAR(50) NOT NULL,
  `expires_in` TIMESTAMP NULL,
  `fingerprint` VARCHAR(50),
  PRIMARY KEY (`refresh_token`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352257_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352257_schema') AS relationships;
DROP DATABASE `db_352257_schema`;
UNINSTALL EXTENSION vsql_schematron;
