INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 384673_lab3
--echo #
CREATE DATABASE `db_384673_lab3`;
USE `db_384673_lab3`;

CREATE TABLE `CLIENTES` (
  `IDCLIENTE` DECIMAL(10,2),
  `NOMBRE` VARCHAR(64),
  `APELLIDO` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `DIRECCION` VARCHAR(64),
  `CIUDAD` VARCHAR(64),
  `TELEFONO` DECIMAL(10,2),
  PRIMARY KEY (`IDCLIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `CURSOS` (
  `idcurso` DECIMAL(10,2),
  `titulo` VARCHAR(64),
  `descripcion` VARCHAR(64),
  `max_num` DECIMAL(10,2),
  `precio` DECIMAL(10,2),
  `tipoanimal` DECIMAL(10,2),
  `fechahora` DATETIME,
  `lugar` VARCHAR(64),
  `instructor` DECIMAL(10,2),
  PRIMARY KEY (`idcurso`)
) CHARACTER SET latin1;

CREATE TABLE `MASCOTAS` (
  `IDMASCOTA` DECIMAL(10,2),
  `IDCLIENTE` DECIMAL(10,2),
  `NOMBREMASCOTA` VARCHAR(64),
  `TIPOANIMAL` DECIMAL(10,2),
  `FECHANAC` DATETIME,
  PRIMARY KEY (`IDMASCOTA`)
) CHARACTER SET latin1;

CREATE TABLE `CURSOS_CLIENTES` (
  `IDCURSO` DECIMAL(10,2),
  `IDCLIENTE` DECIMAL(10,2),
  PRIMARY KEY (`IDCLIENTE`, `IDCURSO`)
) CHARACTER SET latin1;

CREATE TABLE `PEDIDOS` (
  `IDPEDIDO` DECIMAL(10,2),
  `IDCLIENTE` DECIMAL(10,2),
  `FECHAPEDIDO` DATETIME,
  `FECHAENTREGA` DATETIME,
  `DIRECCIONENTREGA` VARCHAR(64),
  `EMPLEADOVENTA` DECIMAL(10,2),
  PRIMARY KEY (`IDPEDIDO`)
) CHARACTER SET latin1;

CREATE TABLE `PEDIDOS_PRODUCTOS` (
  `IDPEDIDO` DECIMAL(10,2),
  `IDPRODUCTO` DECIMAL(10,2),
  `CANTIDAD` DECIMAL(10,2),
  `PRECIOREAL` DECIMAL(10,2),
  PRIMARY KEY (`IDPEDIDO`, `IDPRODUCTO`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_384673_lab3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_384673_lab3') AS relationships;
DROP DATABASE `db_384673_lab3`;
UNINSTALL EXTENSION vsql_schematron;
