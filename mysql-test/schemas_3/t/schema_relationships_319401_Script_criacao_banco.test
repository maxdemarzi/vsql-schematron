INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319401_Script_criacao_banco
--echo #
CREATE DATABASE `db_319401_Script_criacao_banco`;
USE `db_319401_Script_criacao_banco`;

CREATE TABLE `responsavel` (
  `id` INT,
  `nome` VARCHAR(64),
  `cpf` VARCHAR(64),
  `email` VARCHAR(64),
  `foto` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `processo` (
  `id` INT,
  `numeroprocesso` VARCHAR(64),
  `datadistribuicao` DATETIME,
  `processosegredo` BOOL,
  `pastafisica` VARCHAR(64),
  `descricao` VARCHAR(64),
  `situacao` INT,
  `idprocessopai` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `processoresponsavel` (
  `id` INT,
  `idprocesso` INT,
  `idresponsavel` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319401_Script_criacao_banco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319401_Script_criacao_banco') AS relationships;
DROP DATABASE `db_319401_Script_criacao_banco`;
UNINSTALL EXTENSION vsql_schematron;
