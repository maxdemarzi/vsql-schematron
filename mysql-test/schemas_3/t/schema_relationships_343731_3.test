INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343731_3
--echo #
CREATE DATABASE `db_343731_3`;
USE `db_343731_3`;

CREATE TABLE `labcontrol.assay_type` (
  `assay_type_id` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`assay_type_id`)
) CHARACTER SET latin1;

CREATE TABLE `labcontrol.comp_to_assay_type_map` (
  `composition_type_id` INT,
  `assay_type_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343731_3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343731_3') AS relationships;
DROP DATABASE `db_343731_3`;
UNINSTALL EXTENSION vsql_schematron;
