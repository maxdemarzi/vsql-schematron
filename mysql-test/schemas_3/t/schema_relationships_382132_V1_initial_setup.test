INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 382132_V1__initial_setup
--echo #
CREATE DATABASE `db_382132_V1_initial_setup`;
USE `db_382132_V1_initial_setup`;

CREATE TABLE `user` (
  `uuid` VARCHAR(64),
  `username` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `passwordhash` VARCHAR(64),
  `email` VARCHAR(64),
  `enabled` BOOL,
  `meta` VARCHAR(64),
  `created` DATETIME,
  `creator_uuid` VARCHAR(64),
  `edited` DATETIME,
  `editor_uuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `group` (
  `uuid` VARCHAR(64),
  `name` VARCHAR(64),
  `meta` VARCHAR(64),
  `created` DATETIME,
  `creator_uuid` VARCHAR(64),
  `edited` DATETIME,
  `editor_uuid` VARCHAR(64),
  PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;

CREATE TABLE `user_group` (
  `user_uuid` VARCHAR(64),
  `group_uuid` VARCHAR(64),
  PRIMARY KEY (`user_uuid`, `group_uuid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_382132_V1_initial_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_382132_V1_initial_setup') AS relationships;
DROP DATABASE `db_382132_V1_initial_setup`;
UNINSTALL EXTENSION vsql_schematron;
