  `sme_id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`sme_id`)
) CHARACTER SET latin1;
CREATE TABLE `sme_project` (
  `sme_id` BIGINT NOT NULL,
  `project_id` BIGINT NOT NULL,
  PRIMARY KEY (`sme_id`, `project_id`)
) CHARACTER SET latin1;
--disable_query_log
