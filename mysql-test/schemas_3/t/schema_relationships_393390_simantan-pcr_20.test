INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 393390_simantan-pcr%20
--echo #
CREATE DATABASE `db_393390_simantan_pcr_20`;
USE `db_393390_simantan_pcr_20`;
CREATE TABLE `kegiatan` (
  `id` INT NOT NULL,
  `pengaju` VARCHAR(50),
  `kegiatan` VARCHAR(50),
  `kegiatan_unit` VARCHAR(50),
  `kegiatan_peserta` VARCHAR(50),
  `kegiatan_jmlpeserta` VARCHAR(50),
  `prioritas` VARCHAR(50),
  `prioritas_alasan` VARCHAR(50),
  `penanggung_jawab` VARCHAR(50),
  `waktu` DATETIME,
  `tempat` VARCHAR(50),
  `lokasi` VARCHAR(50),
  `pelaksana` VARCHAR(50),
  `skema_proses_masuk_keluar` TEXT,
  `skema_penerapan_prokes` TEXT,
  `skema_kegiatan_berlangsung` TEXT,
  `skema_kegiatan_selesai` TEXT,
  `satgas` VARCHAR(50),
  `kasatgas` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `komentar` (
  `id` INT,
  `user` VARCHAR(50),
  `kegiatan` INT,
  `komentar` TEXT,
  `tanggal` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `role` (
  `id` INT NOT NULL,
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT,
  `nama` VARCHAR(50),
  `role` INT,
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `institut` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_393390_simantan_pcr_20') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_393390_simantan_pcr_20') AS relationships;
DROP DATABASE `db_393390_simantan_pcr_20`;
UNINSTALL EXTENSION vsql_schematron;
