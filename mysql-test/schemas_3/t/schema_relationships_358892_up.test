INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358892_up
--echo #
CREATE DATABASE `db_358892_up`;
USE `db_358892_up`;
CREATE TABLE `Role` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Account` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `display_name` VARCHAR(50),
  `verified` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `AccountRole` (
  `id` INT NOT NULL,
  `account_id` INT,
  `role_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358892_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358892_up') AS relationships;
DROP DATABASE `db_358892_up`;
UNINSTALL EXTENSION vsql_schematron;
