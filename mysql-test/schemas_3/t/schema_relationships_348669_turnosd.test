INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348669_turnosd
--echo #
CREATE DATABASE `db_348669_turnosd`;
USE `db_348669_turnosd`;

CREATE TABLE `edificios` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  `Direccion` VARCHAR(64),
  `Lat` VARCHAR(64),
  `Long` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `gerencias` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `pisos` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  `Numero` INT,
  `IdEdificio` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `pisosxgerencias` (
  `Id` INT,
  `IdPiso` INT,
  `IdGerencia` INT,
  `Cupo` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `usuarios` (
  `DNI` INT,
  `Password` VARCHAR(64),
  `Nombre` VARCHAR(64),
  `Email` VARCHAR(64),
  `IdTipoDeUsuario` INT,
  `IdGerencia` INT,
  `IdJefeDirecto` INT,
  PRIMARY KEY (`DNI`)
) CHARACTER SET latin1;

CREATE TABLE `turnosd.reportes` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  `Query` VARCHAR(64),
  `SelGerencia` BOOL,
  `SelUsuario` BOOL,
  `SelFecha` BOOL,
  `SelEdificio` BOOL,
  `SelPiso` BOOL,
  `SelHorario` BOOL,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `turnosd.configuraciones` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  `Valor` VARCHAR(64),
  `Descripcion` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348669_turnosd') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348669_turnosd') AS relationships;
DROP DATABASE `db_348669_turnosd`;
UNINSTALL EXTENSION vsql_schematron;
