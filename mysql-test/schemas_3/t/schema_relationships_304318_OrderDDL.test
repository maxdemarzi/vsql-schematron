INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 304318_OrderDDL
--echo #
CREATE DATABASE `db_304318_OrderDDL`;
USE `db_304318_OrderDDL`;
CREATE TABLE `ORDERS` (
  `ID` INT NOT NULL,
  `CUSTOMER_ID` INT,
  `COST` INT,
  `STATUS` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORDER_DETAILS` (
  `ID` INT NOT NULL,
  `ORDER_ID` INT,
  `PRODUCT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_304318_OrderDDL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_304318_OrderDDL') AS relationships;
DROP DATABASE `db_304318_OrderDDL`;
UNINSTALL EXTENSION vsql_schematron;
