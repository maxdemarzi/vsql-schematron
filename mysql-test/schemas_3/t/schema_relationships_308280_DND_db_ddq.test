INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 308280_DND_db_ddq
--echo #
CREATE DATABASE `db_308280_DND_db_ddq`;
USE `db_308280_DND_db_ddq`;
CREATE TABLE `statistic` (
  `stat_id` INT NOT NULL,
  `strength` INT,
  `dexterity` INT,
  `constitution` INT,
  `intelligence` INT,
  `wisdom` INT,
  `charisma` INT,
  PRIMARY KEY (`stat_id`)
) CHARACTER SET latin1;
CREATE TABLE `inventory` (
  `inventory_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `damage` INT,
  `effects` VARCHAR(50),
  `weight` INT,
  PRIMARY KEY (`inventory_id`)
) CHARACTER SET latin1;
CREATE TABLE `class` (
  `class_id` INT NOT NULL,
  `name` VARCHAR(50),
  `hit_points` INT,
  PRIMARY KEY (`class_id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
  `action_id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`action_id`)
) CHARACTER SET latin1;
CREATE TABLE `character` (
  `character_id` INT NOT NULL,
  `name` VARCHAR(50),
  `chosen_class_id` INT,
  `stat_id` INT,
  `chosen_demographic_info` VARCHAR(50),
  `total_hit_points` INT,
  `current_hit_points` INT,
  PRIMARY KEY (`character_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_308280_DND_db_ddq') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_308280_DND_db_ddq') AS relationships;
DROP DATABASE `db_308280_DND_db_ddq`;
UNINSTALL EXTENSION vsql_schematron;
