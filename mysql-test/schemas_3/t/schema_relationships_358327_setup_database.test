INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358327_setup_database
--echo #
CREATE DATABASE `db_358327_setup_database`;
USE `db_358327_setup_database`;

CREATE TABLE `movies` (
  `id` INT,
  `release` INT,
  `title` VARCHAR(64),
  `winner` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `producers` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `studios` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_producers` (
  `id_movie` INT,
  `id_producer` INT,
  PRIMARY KEY (`id_movie`, `id_producer`)
) CHARACTER SET latin1;

CREATE TABLE `movie_studios` (
  `id_movie` INT,
  `id_studio` INT,
  PRIMARY KEY (`id_movie`, `id_studio`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358327_setup_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358327_setup_database') AS relationships;
DROP DATABASE `db_358327_setup_database`;
UNINSTALL EXTENSION vsql_schematron;
