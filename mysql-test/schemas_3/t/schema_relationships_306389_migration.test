INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 306389_migration
--echo #
CREATE DATABASE `db_306389_migration`;
USE `db_306389_migration`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `isadmin` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `year` VARCHAR(64),
  `description` VARCHAR(64),
  `imageUrl` VARCHAR(64),
  `videoUrl` VARCHAR(64),
  `genres` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tvshows` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `year` VARCHAR(64),
  `description` VARCHAR(64),
  `imageUrl` VARCHAR(64),
  `videoUrl` VARCHAR(64),
  `genres` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `folders` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `creatorId` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `watchlist` (
  `id` VARCHAR(64),
  `li_id` VARCHAR(64),
  `li_title` VARCHAR(64),
  `li_desc` VARCHAR(64),
  `li_year` VARCHAR(64),
  `li_imageUrl` VARCHAR(64),
  `li_type` VARCHAR(64),
  `belongsId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `moviecomments` (
  `id` VARCHAR(64),
  `text` VARCHAR(64),
  `authorId` VARCHAR(64),
  `mcId` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tvcomments` (
  `id` VARCHAR(64),
  `text` VARCHAR(64),
  `authorId` VARCHAR(64),
  `tcId` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movieratings` (
  `id` VARCHAR(64),
  `rate` INT,
  `authorId` VARCHAR(64),
  `ratedMvId` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tvratings` (
  `id` VARCHAR(64),
  `rate` INT,
  `authorId` VARCHAR(64),
  `ratedTvId` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_306389_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_306389_migration') AS relationships;
DROP DATABASE `db_306389_migration`;
UNINSTALL EXTENSION vsql_schematron;
