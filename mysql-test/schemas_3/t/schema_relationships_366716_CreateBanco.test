INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366716_CreateBanco
--echo #
CREATE DATABASE `db_366716_CreateBanco`;
USE `db_366716_CreateBanco`;

CREATE TABLE `MEIODETRANSPORTE` (
  `ID` INT,
  `DESCRICAO` VARCHAR(64),
  `TIPO` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EVENTO` (
  `ID` INT,
  `MEIODETRANSPORTE_ID` INT,
  `DATA` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `VIAGEM` (
  `EVENTO_ID` INT,
  `INICIO` DATETIME,
  `FIM` DATETIME,
  `DISTANCIA` DECIMAL(10,2),
  PRIMARY KEY (`EVENTO_ID`)
) CHARACTER SET latin1;

CREATE TABLE `GASTO` (
  `EVENTO_ID` INT,
  `TIPO` INT,
  `VALOR` DECIMAL(10,2),
  `OBSERVACAO` VARCHAR(64),
  PRIMARY KEY (`EVENTO_ID`)
) CHARACTER SET latin1;

CREATE TABLE `ALUGADO` (
  `MEIODETRANSPORTE_ID` INT,
  `LOCADORA` VARCHAR(64),
  `MARCA` VARCHAR(64),
  `MODELO` VARCHAR(64),
  `COR` VARCHAR(64),
  PRIMARY KEY (`MEIODETRANSPORTE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `COMPARTILHADO` (
  `MEIODETRANSPORTE_ID` INT,
  `EMPRESA` VARCHAR(64),
  PRIMARY KEY (`MEIODETRANSPORTE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PUBLICO` (
  `MEIODETRANSPORTE_ID` INT,
  `EMPRESA` VARCHAR(64),
  PRIMARY KEY (`MEIODETRANSPORTE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PARTICULAR` (
  `MEIODETRANSPORTE_ID` INT,
  `MARCA` VARCHAR(64),
  `MODELO` VARCHAR(64),
  `COR` VARCHAR(64),
  PRIMARY KEY (`MEIODETRANSPORTE_ID`)
) CHARACTER SET latin1;

CREATE TABLE `USUARIO` (
  `ID` INT,
  `NOME` VARCHAR(64),
  `SOBRENOME` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `SENHA` VARCHAR(64),
  `FACEBOOK` VARCHAR(64),
  `SINCRONIZAR` BOOL,
  `LASTLOGIN` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USUARIO_HAS_MEIODETRANSPORTE` (
  `USUARIO_ID` INT,
  `MEIODETRANSPORTE_ID` INT,
  PRIMARY KEY (`USUARIO_ID`, `MEIODETRANSPORTE_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366716_CreateBanco') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366716_CreateBanco') AS relationships;
DROP DATABASE `db_366716_CreateBanco`;
UNINSTALL EXTENSION vsql_schematron;
