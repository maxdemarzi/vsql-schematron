INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 372649_liquibase-changeLog.mysql
--echo #
CREATE DATABASE `db_372649_liquibase_changeLog_mysql`;
USE `db_372649_liquibase_changeLog_mysql`;

CREATE TABLE `available-pharmacies` (
  `id` INT,
  `date` DATETIME,
  `pulled-version` INT,
  `pharmacy-id` INT,
  `working-hour-id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `pharmacies` (
  `id` INT,
  `address` VARCHAR(64),
  `name` VARCHAR(64),
  `phone-number` VARCHAR(64),
  `region` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `working-hours` (
  `id` INT,
  `working-hour-text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_372649_liquibase_changeLog_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_372649_liquibase_changeLog_mysql') AS relationships;
DROP DATABASE `db_372649_liquibase_changeLog_mysql`;
UNINSTALL EXTENSION vsql_schematron;
