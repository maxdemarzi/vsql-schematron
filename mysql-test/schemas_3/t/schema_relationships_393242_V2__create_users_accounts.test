INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 393242_V2__create_users_accounts
--echo #
CREATE DATABASE `db_393242_V2__create_users_accounts`;
USE `db_393242_V2__create_users_accounts`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `password` VARCHAR(50),
  `email` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
  `id` INT NOT NULL,
  `account_number` VARCHAR(50),
  `account_type` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_accounts` (
  `id` INT NOT NULL,
  `account_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_393242_V2__create_users_accounts') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_393242_V2__create_users_accounts') AS relationships;
DROP DATABASE `db_393242_V2__create_users_accounts`;
UNINSTALL EXTENSION vsql_schematron;
