INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 362688_20201110184350_init_db.up
--echo #
CREATE DATABASE `db_362688_20201110184350_init_db_up`;
USE `db_362688_20201110184350_init_db_up`;

CREATE TABLE `users` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `articles` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `thumbnail_url` VARCHAR(64),
  `author` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `mime` VARCHAR(64),
  `img` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_362688_20201110184350_init_db_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_362688_20201110184350_init_db_up') AS relationships;
DROP DATABASE `db_362688_20201110184350_init_db_up`;
UNINSTALL EXTENSION vsql_schematron;
