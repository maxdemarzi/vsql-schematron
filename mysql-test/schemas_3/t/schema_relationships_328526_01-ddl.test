INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328526_01-ddl
--echo #
CREATE DATABASE `db_328526_01_ddl`;
USE `db_328526_01_ddl`;
CREATE TABLE `Manufacturers` (
  `Code` INT NOT NULL,
  `Name` TEXT,
  PRIMARY KEY (`Code`)
) CHARACTER SET latin1;
CREATE TABLE `Products` (
  `Code` INT NOT NULL,
  `Name` TEXT,
  `Price` DOUBLE,
  `Manufacturer` INT,
  PRIMARY KEY (`Code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328526_01_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328526_01_ddl') AS relationships;
DROP DATABASE `db_328526_01_ddl`;
UNINSTALL EXTENSION vsql_schematron;
