INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363514_utcshop
--echo #
CREATE DATABASE `db_363514_utcshop`;
USE `db_363514_utcshop`;

CREATE TABLE `account` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `date_of_birth` DATETIME,
  `gender` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `address` VARCHAR(64),
  `registered_date` DATETIME,
  `role` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bill` (
  `id` INT,
  `account_id` INT,
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `method` VARCHAR(64),
  `time` DATETIME,
  `last_update_date` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bill_detail` (
  `id` INT,
  `bill_id` INT,
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `cart` (
  `id` INT,
  `account_id` INT,
  `product_id` INT,
  `quantity` INT
) CHARACTER SET latin1;

CREATE TABLE `category` (
  `id` INT,
  `name` VARCHAR(64),
  `image` VARCHAR(64),
  `level` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `account_id` INT,
  `product_id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `time` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `news` (
  `id` INT,
  `title` VARCHAR(64),
  `short_content` VARCHAR(64),
  `content` VARCHAR(64),
  `image` VARCHAR(64),
  `time` DATETIME,
  `author` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product` (
  `id` INT,
  `name` VARCHAR(64),
  `image` VARCHAR(64),
  `description` VARCHAR(64),
  `quantity` INT,
  `sold` INT,
  `price` INT,
  `discount` INT,
  `promotion` VARCHAR(64),
  `category_id` INT,
  `updated_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `support` (
  `id` INT,
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `name` VARCHAR(64),
  `phone` VARCHAR(64),
  `email` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363514_utcshop') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363514_utcshop') AS relationships;
DROP DATABASE `db_363514_utcshop`;
UNINSTALL EXTENSION vsql_schematron;
