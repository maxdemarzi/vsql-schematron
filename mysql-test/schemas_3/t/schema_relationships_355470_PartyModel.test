INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 355470_PartyModel
--echo #
CREATE DATABASE `db_355470_PartyModel`;
USE `db_355470_PartyModel`;

CREATE TABLE `Company` (
  `PartyID` INT,
  PRIMARY KEY (`PartyID`)
) CHARACTER SET latin1;

CREATE TABLE `Party` (
  `PartyID` INT,
  `PartyTypeCode` VARCHAR(64),
  PRIMARY KEY (`PartyID`)
) CHARACTER SET latin1;

CREATE TABLE `Person` (
  `PartyID` INT,
  PRIMARY KEY (`PartyID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_355470_PartyModel') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_355470_PartyModel') AS relationships;
DROP DATABASE `db_355470_PartyModel`;
UNINSTALL EXTENSION vsql_schematron;
