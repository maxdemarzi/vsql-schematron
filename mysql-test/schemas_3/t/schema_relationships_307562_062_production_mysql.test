INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307562_062_production.mysql
--echo #
CREATE DATABASE `db_307562_062_production_mysql`;
USE `db_307562_062_production_mysql`;
CREATE TABLE `prod_header` (
  `prod_id` INT NOT NULL,
  `entity_id` VARCHAR(50),
  `division_id` INT,
  `department_id` INT,
  `prod_start` DATETIME,
  `prod_due` DATETIME,
  `prod_finished` DATETIME,
  `resulting_product_id` INT,
  `maximum_quantity` DECIMAL(10,2),
  `bom_id` INT,
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`prod_id`)
) CHARACTER SET latin1;
CREATE TABLE `prod_detail` (
  `prod_detail_id` INT NOT NULL,
  `prod_id` INT,
  `prod_step_number` INT,
  `bom_detail_id` INT,
  `item_consumed_id` INT,
  `item_generated_id` INT,
  `step_started` DATETIME,
  `step_due` DATETIME,
  `step_finished` DATETIME,
  `step_cost` DECIMAL(10,2),
  `currency_code` CHAR(50),
  `planned_consumed` DECIMAL(10,2),
  `planned_generated` DECIMAL(10,2),
  `quantity_consumed` DECIMAL(10,2),
  `quantity_generated` DECIMAL(10,2),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`prod_detail_id`)
) CHARACTER SET latin1;
CREATE TABLE `prod_header_notes` (
  `note_id` INT NOT NULL,
  `prod_id` INT,
  `note_type_id` INT,
  `seq` INT,
  `note_text` VARCHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`note_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307562_062_production_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307562_062_production_mysql') AS relationships;
DROP DATABASE `db_307562_062_production_mysql`;
UNINSTALL EXTENSION vsql_schematron;
