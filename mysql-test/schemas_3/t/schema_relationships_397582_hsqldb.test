INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 397582_hsqldb
--echo #
CREATE DATABASE `db_397582_hsqldb`;
USE `db_397582_hsqldb`;

CREATE TABLE `tagservice_collection` (
  `tagcollectionid` VARCHAR(64),
  `description` VARCHAR(64),
  `externalsourcename` VARCHAR(64),
  `externalsourcedescription` VARCHAR(64),
  `name` VARCHAR(64),
  `createdby` VARCHAR(64),
  `creationdate` INT,
  `lastmodifiedby` VARCHAR(64),
  `lastmodificationdate` INT,
  `lastsynchronizationdate` INT,
  `externalupdate` BOOL,
  `externalcreation` BOOL,
  `lastupdatedateinexternalsystem` INT,
  PRIMARY KEY (`tagcollectionid`)
) CHARACTER SET latin1;

CREATE TABLE `tagservice_tag` (
  `tagid` VARCHAR(64),
  `tagcollectionid` VARCHAR(64),
  `externalid` VARCHAR(64),
  `taglabel` VARCHAR(64),
  `description` VARCHAR(64),
  `alternativelabels` VARCHAR(64),
  `createdby` VARCHAR(64),
  `creationdate` INT,
  `externalcreation` BOOL,
  `externalcreationDate` INT,
  `externalupdate` BOOL,
  `lastmodifiedby` VARCHAR(64),
  `lastmodificationdate` INT,
  `lastupdatedateinexternalsystem` INT,
  `parentid` VARCHAR(64),
  `externalhierarchycode` VARCHAR(64),
  `externaltype` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`tagid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_397582_hsqldb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_397582_hsqldb') AS relationships;
DROP DATABASE `db_397582_hsqldb`;
UNINSTALL EXTENSION vsql_schematron;
