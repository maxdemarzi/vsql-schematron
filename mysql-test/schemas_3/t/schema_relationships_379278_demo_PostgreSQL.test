INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379278_demo-PostgreSQL
--echo #
CREATE DATABASE `db_379278_demo_PostgreSQL`;
USE `db_379278_demo_PostgreSQL`;

CREATE TABLE `gui_acl_privileges` (
  `id` INT,
  `key_name` VARCHAR(64),
  `name` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gui_acl_resources` (
  `id` INT,
  `parent_id` INT,
  `key_name` VARCHAR(64),
  `name` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gui_acl_roles` (
  `id` INT,
  `parent_id` INT,
  `key_name` VARCHAR(64),
  `name` VARCHAR(64),
  `comment` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gui_users` (
  `id` INT,
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gui_users_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `gui_acl` (
  `id` INT,
  `role_id` INT,
  `privilege_id` INT,
  `resource_id` INT,
  `access` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379278_demo_PostgreSQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379278_demo_PostgreSQL') AS relationships;
DROP DATABASE `db_379278_demo_PostgreSQL`;
UNINSTALL EXTENSION vsql_schematron;
