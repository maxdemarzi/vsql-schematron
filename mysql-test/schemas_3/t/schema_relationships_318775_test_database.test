INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318775_test_database
--echo #
CREATE DATABASE `db_318775_test_database`;
USE `db_318775_test_database`;
CREATE TABLE `roles_master` (
  `role_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `role_name` VARCHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `logins_master` (
  `id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  `role_id` VARCHAR(50),
  `login_time` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318775_test_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318775_test_database') AS relationships;
DROP DATABASE `db_318775_test_database`;
UNINSTALL EXTENSION vsql_schematron;
