INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325042_schema
--echo #
CREATE DATABASE `db_325042_schema`;
USE `db_325042_schema`;

CREATE TABLE `spec` (
  `id` INT,
  `version` VARCHAR(64),
  `language` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `section` (
  `id` INT,
  `name` VARCHAR(64),
  `title` VARCHAR(64),
  `spec_version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `question` (
  `id` INT,
  `number` VARCHAR(64),
  `question` VARCHAR(64),
  `type` VARCHAR(64),
  `correct_answer` VARCHAR(64),
  `evidence_prompt` VARCHAR(64),
  `evidence_validation` VARCHAR(64),
  `section_id` INT,
  `subquestion_of` INT,
  `spec_reference` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `openchain_user` (
  `id` INT,
  `username` VARCHAR(64),
  `password_token` VARCHAR(64),
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `email` VARCHAR(64),
  `verified` BOOL,
  `passwordReset` BOOL,
  `admin` BOOL,
  `verificationExpirationDate` DATETIME,
  `uuid` VARCHAR(64),
  `organization` VARCHAR(64),
  `name_permission` BOOL,
  `email_permission` BOOL,
  `language` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `survey_response` (
  `id` INT,
  `user_id` INT,
  `spec_version` INT,
  `submitted` BOOL,
  `approved` BOOL,
  `rejected` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `answer` (
  `id` INT,
  `response_id` INT,
  `question_id` INT,
  `answer` VARCHAR(64),
  `evidence` VARCHAR(64),
  `subanswer_of` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325042_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325042_schema') AS relationships;
DROP DATABASE `db_325042_schema`;
UNINSTALL EXTENSION vsql_schematron;
