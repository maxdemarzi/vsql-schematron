INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373109_migration
--echo #
CREATE DATABASE `db_373109_migration`;
USE `db_373109_migration`;

CREATE TABLE `GuildTrelloIntegration` (
  `id` INT,
  `key` VARCHAR(64),
  `token` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ArchiveSettings` (
  `id` INT,
  `enabled` BOOL
) CHARACTER SET latin1;

CREATE TABLE `ArchivedChannel` (
  `id` INT,
  `guild_id` INT,
  `name` VARCHAR(64),
  `topic` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ArchivedMessage` (
  `id` INT,
  `guild_id` INT,
  `channel_id` INT,
  `author_id` INT,
  `content` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373109_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373109_migration') AS relationships;
DROP DATABASE `db_373109_migration`;
UNINSTALL EXTENSION vsql_schematron;
