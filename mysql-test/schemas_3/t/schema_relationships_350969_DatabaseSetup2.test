INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 350969_DatabaseSetup2
--echo #
CREATE DATABASE `db_350969_DatabaseSetup2`;
USE `db_350969_DatabaseSetup2`;
CREATE TABLE `donor` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `donation` (
  `id` INT NOT NULL,
  `donor_id` INT NOT NULL,
  `donation_amount` DECIMAL(10,2),
  PRIMARY KEY (`donor_id`, `id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_350969_DatabaseSetup2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_350969_DatabaseSetup2') AS relationships;
DROP DATABASE `db_350969_DatabaseSetup2`;
UNINSTALL EXTENSION vsql_schematron;
