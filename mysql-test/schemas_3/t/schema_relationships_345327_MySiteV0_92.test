INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 345327_MySiteV0_92
--echo #
CREATE DATABASE `db_345327_MySiteV0_92`;
USE `db_345327_MySiteV0_92`;

CREATE TABLE `accountbal` (
  `UUID` VARCHAR(255),
  `Name` VARCHAR(255),
  `Action` VARCHAR(255),
  `TransDate` DATETIME,
  `Amount` DECIMAL(10,2),
  `Actual` DECIMAL(10,2),
  `TransFee` DECIMAL(10,2),
  `ExchangeRate` INT,
  `txnID` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `contactus` (
  `ContactID` INT,
  `SendEmail` VARCHAR(255),
  `Title` VARCHAR(255),
  `Subject` VARCHAR(255),
  `AutoResponse` VARCHAR(255),
  `SortOrder` DECIMAL(10,2),
  `Active` VARCHAR(255),
  PRIMARY KEY (`ContactID`)
) CHARACTER SET latin1;

CREATE TABLE `control` (
  `Control` VARCHAR(255),
  `Name` VARCHAR(255),
  `Parm1` VARCHAR(255),
  `Parm2` VARCHAR(255),
  `Nbr1` INT,
  `Nbr2` INT,
  PRIMARY KEY (`Control`, `Name`)
) CHARACTER SET latin1;

CREATE TABLE `pagemaster` (
  `PageID` INT,
  `Name` VARCHAR(255),
  `Path` VARCHAR(255),
  PRIMARY KEY (`PageID`)
) CHARACTER SET latin1;

CREATE TABLE `pagedetail` (
  `EntryID` INT,
  `PageID` INT,
  `SortOrder` DECIMAL(10,2),
  `Name` VARCHAR(255),
  `Title` VARCHAR(255),
  `Content` VARCHAR(255),
  `Active` VARCHAR(255),
  `AutoStart` DATETIME,
  `AutoExpire` DATETIME,
  PRIMARY KEY (`EntryID`)
) CHARACTER SET latin1;

CREATE TABLE `regionxml` (
  `UUID` VARCHAR(255),
  `regionName` VARCHAR(255),
  `status` INT,
  `locationX` INT,
  `locationY` INT,
  `internalIP` VARCHAR(255),
  `port` INT,
  `externalIP` VARCHAR(255),
  `ownerUUID` VARCHAR(255),
  `lastmapUUID` VARCHAR(255),
  `lastmapRefresh` VARCHAR(255),
  `primMax` INT,
  `physicalMax` INT,
  `productType` INT,
  `CreateDate` DATETIME,
  `MachineName` VARCHAR(255),
  `ProcessHandle` INT,
  PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;

CREATE TABLE `usereconomy` (
  `UUID` VARCHAR(255),
  `MaxBuy` INT,
  `MaxSell` INT,
  `Hours` INT,
  PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_345327_MySiteV0_92') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_345327_MySiteV0_92') AS relationships;
DROP DATABASE `db_345327_MySiteV0_92`;
UNINSTALL EXTENSION vsql_schematron;
