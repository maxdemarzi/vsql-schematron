INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302070_up
--echo #
CREATE DATABASE `db_302070_up`;
USE `db_302070_up`;
CREATE TABLE `catalogs` (
  `id` INT NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `kind` INT,
  `status` INT,
  `uuid` BLOB,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `catalog` INT,
  `name` TEXT,
  `description` TEXT,
  `price_int` INT,
  `price_frac` INT,
  `currency` TEXT,
  `status` INT,
  `uuid` BLOB,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
  `id` INT NOT NULL,
  `product` INT,
  `txn_code` TEXT,
  `name` TEXT,
  `address` TEXT,
  `city` TEXT,
  `region` TEXT,
  `country` TEXT,
  `postal` TEXT,
  `email` TEXT,
  `phone` TEXT,
  `last4` TEXT,
  `payment_method` TEXT,
  `amount_int` INT,
  `amount_frac` INT,
  `currency` TEXT,
  `uuid` BLOB,
  `created` DATETIME,
  `updated` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302070_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302070_up') AS relationships;
DROP DATABASE `db_302070_up`;
UNINSTALL EXTENSION vsql_schematron;
