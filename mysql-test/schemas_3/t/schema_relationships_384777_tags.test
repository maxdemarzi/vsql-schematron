INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 384777_tags
--echo #
CREATE DATABASE `db_384777_tags`;
USE `db_384777_tags`;
CREATE TABLE `relations` (
  `id` INT NOT NULL,
  `category` CHAR(50),
  `parent` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_384777_tags') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_384777_tags') AS relationships;
DROP DATABASE `db_384777_tags`;
UNINSTALL EXTENSION vsql_schematron;
