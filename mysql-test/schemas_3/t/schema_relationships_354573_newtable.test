INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354573_newtable
--echo #
CREATE DATABASE `db_354573_newtable`;
USE `db_354573_newtable`;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `pwd` VARCHAR(64),
  `auth` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `word` (
  `id` INT,
  `kana` VARCHAR(64),
  `kanji` VARCHAR(64),
  `type` VARCHAR(64),
  `trans` VARCHAR(64),
  `lid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `record` (
  `id` INT,
  `wid` INT,
  `uid` INT,
  `total_record` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354573_newtable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354573_newtable') AS relationships;
DROP DATABASE `db_354573_newtable`;
UNINSTALL EXTENSION vsql_schematron;
