INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312811_000001_create_movie_table.up
--echo #
CREATE DATABASE `db_312811_000001_create_movie_table_up`;
USE `db_312811_000001_create_movie_table_up`;

CREATE TABLE `directors` (
  `director_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`director_id`)
) CHARACTER SET latin1;

CREATE TABLE `movies` (
  `movie_id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `director_id` VARCHAR(64),
  `rank` VARCHAR(64),
  `year` VARCHAR(64),
  `run_time` VARCHAR(64),
  `vote` VARCHAR(64),
  `rating` VARCHAR(64),
  `revenue` VARCHAR(64),
  `meta_score` VARCHAR(64),
  PRIMARY KEY (`movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `actors` (
  `actor_id` VARCHAR(64),
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  PRIMARY KEY (`actor_id`)
) CHARACTER SET latin1;

CREATE TABLE `generes` (
  `genere_id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`genere_id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_actors` (
  `actor_actor_id` VARCHAR(64),
  `movie_movie_id` VARCHAR(64),
  PRIMARY KEY (`actor_actor_id`, `movie_movie_id`)
) CHARACTER SET latin1;

CREATE TABLE `movie_generes` (
  `genere_genere_id` VARCHAR(64),
  `movie_movie_id` VARCHAR(64),
  PRIMARY KEY (`genere_genere_id`, `movie_movie_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312811_000001_create_movie_table_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312811_000001_create_movie_table_up') AS relationships;
DROP DATABASE `db_312811_000001_create_movie_table_up`;
UNINSTALL EXTENSION vsql_schematron;
