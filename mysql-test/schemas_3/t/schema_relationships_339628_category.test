INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 339628_category
--echo #
CREATE DATABASE `db_339628_category`;
USE `db_339628_category`;

CREATE TABLE `category` (
  `category_no` INT,
  `category_manage_no` INT,
  `category_name` VARCHAR(255),
  `category_no_parent` INT,
  `category_order` INT,
  PRIMARY KEY (`category_no`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_339628_category') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_339628_category') AS relationships;
DROP DATABASE `db_339628_category`;
UNINSTALL EXTENSION vsql_schematron;
