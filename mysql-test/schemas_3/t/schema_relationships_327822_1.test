INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 327822_1
--echo #
CREATE DATABASE `db_327822_1`;
USE `db_327822_1`;
CREATE TABLE `roles` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `obj` VARCHAR(50),
  `action` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rolePermissions` (
  `id` BIGINT NOT NULL,
  `permissionId` BIGINT,
  `roleId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  `displayName` VARCHAR(50),
  `email` VARCHAR(50),
  `dateOfBirth` VARCHAR(50),
  `gender` VARCHAR(50),
  `phone` VARCHAR(50),
  `address` VARCHAR(50),
  `picture` VARCHAR(50),
  `login` VARCHAR(50),
  `password` VARCHAR(50),
  `roleId` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_327822_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_327822_1') AS relationships;
DROP DATABASE `db_327822_1`;
UNINSTALL EXTENSION vsql_schematron;
