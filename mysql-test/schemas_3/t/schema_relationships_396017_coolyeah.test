INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 396017_coolyeah
--echo #
CREATE DATABASE `db_396017_coolyeah`;
USE `db_396017_coolyeah`;

CREATE TABLE `admin` (
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;

CREATE TABLE `matakuliah` (
  `kode_matakuliah` VARCHAR(64),
  `kode_pengajar` VARCHAR(64),
  `nama_matakuliah` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `materi` (
  `kode_materi` VARCHAR(64),
  `kode_matakuliah` VARCHAR(64),
  `nama_materi` VARCHAR(64),
  `file_materi` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `pelajar` (
  `nim` VARCHAR(64),
  `nama` VARCHAR(64),
  `jurusan` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`nim`)
) CHARACTER SET latin1;

CREATE TABLE `pengajar` (
  `kode_pengajar` VARCHAR(64),
  `nama` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`kode_pengajar`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_396017_coolyeah') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_396017_coolyeah') AS relationships;
DROP DATABASE `db_396017_coolyeah`;
UNINSTALL EXTENSION vsql_schematron;
