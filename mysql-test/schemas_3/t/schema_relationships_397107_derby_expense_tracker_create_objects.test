INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 397107_derby-expense-tracker-create-objects
--echo #
CREATE DATABASE `db_397107_derby_expense_tracker_create_objects`;
USE `db_397107_derby_expense_tracker_create_objects`;

CREATE TABLE `et_audit` (
  `id` INT,
  `createdby` VARCHAR(64),
  `createddate` DATETIME,
  `recorddata` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `et_groups` (
  `id` INT,
  `groupname` VARCHAR(64),
  `groupdescription` VARCHAR(64),
  `active` INT,
  `creationdate` DATETIME,
  `lastupdateddate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `middleinit` VARCHAR(64),
  `emailid` VARCHAR(64),
  `createddate` DATETIME,
  `lastupdateddate` DATETIME,
  `lastmodifiedby` VARCHAR(64),
  `createdby` VARCHAR(64),
  `pwdchangeneeded` INT,
  `creditcardnumber` VARCHAR(64),
  `phonenumber` VARCHAR(64),
  `enabled` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `et_group_user` (
  `group_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authorities` (
  `id` INT,
  `username` VARCHAR(64),
  `authority` VARCHAR(64),
  `grantedby` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `et_expense` (
  `id` INT,
  `paidby` VARCHAR(64),
  `settlement_id` INT,
  `amount` DECIMAL(10,2),
  `date` DATETIME,
  `createdby` VARCHAR(64),
  `lastmodifiedby` VARCHAR(64),
  `createddate` DATETIME,
  `lastmodifieddate` DATETIME,
  `description` VARCHAR(64),
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `et_user_expense` (
  `id` INT,
  `username` VARCHAR(64),
  `discountpercent` DECIMAL(10,2),
  `amount` DECIMAL(10,2),
  `expense_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `et_payments` (
  `id` INT,
  `paymentdate` DATETIME,
  `amount` DECIMAL(10,2),
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_397107_derby_expense_tracker_create_objects') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_397107_derby_expense_tracker_create_objects') AS relationships;
DROP DATABASE `db_397107_derby_expense_tracker_create_objects`;
UNINSTALL EXTENSION vsql_schematron;
