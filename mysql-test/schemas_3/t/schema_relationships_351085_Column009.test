INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351085_Column009
--echo #
CREATE DATABASE `db_351085_Column009`;
USE `db_351085_Column009`;

CREATE TABLE `가댁체힐你好` (
  `가댁` INT,
  `힐你好` VARCHAR(64),
  PRIMARY KEY (`가댁`)
) CHARACTER SET latin1;

CREATE TABLE `가댁체힐` (
  `가댁체힐你好` INT,
  `댁체힐` VARCHAR(64),
  PRIMARY KEY (`가댁체힐你好`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351085_Column009') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351085_Column009') AS relationships;
DROP DATABASE `db_351085_Column009`;
UNINSTALL EXTENSION vsql_schematron;
