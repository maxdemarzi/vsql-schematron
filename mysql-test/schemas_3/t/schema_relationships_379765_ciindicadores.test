INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379765_ciindicadores
--echo #
CREATE DATABASE `db_379765_ciindicadores`;
USE `db_379765_ciindicadores`;
CREATE TABLE `indicadores` (
  `id` INT,
  `codigo` VARCHAR(50),
  `nombre` VARCHAR(50),
  `id_unidad_medida` INT,
  `fecha` DATETIME,
  `valor` INT
) CHARACTER SET latin1;
CREATE TABLE `unidad_medida` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379765_ciindicadores') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379765_ciindicadores') AS relationships;
DROP DATABASE `db_379765_ciindicadores`;
UNINSTALL EXTENSION vsql_schematron;
