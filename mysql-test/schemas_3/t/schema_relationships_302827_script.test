INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302827_script
--echo #
CREATE DATABASE `db_302827_script`;
USE `db_302827_script`;
CREATE TABLE `categorias` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `personal` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `apellidos` VARCHAR(50),
  `telefono` CHAR(50),
  `direccion` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
  `id` INT NOT NULL,
  `nombre` VARCHAR(50),
  `descripcion` VARCHAR(50),
  `prioridad` CHAR(50),
  `persona_id` INT,
  `categoria_id` INT,
  `estatus` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302827_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302827_script') AS relationships;
DROP DATABASE `db_302827_script`;
UNINSTALL EXTENSION vsql_schematron;
