INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302835_20210406191606_dbinit
--echo #
CREATE DATABASE `db_302835_20210406191606_dbinit`;
USE `db_302835_20210406191606_dbinit`;
CREATE TABLE `domains` (
  `id` INT NOT NULL,
  `domain` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `key` VARCHAR(50),
  `dkim_private_key` VARCHAR(50),
  `dkim_public_key` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
  `id` INT NOT NULL,
  `message_id` VARCHAR(50),
  `subject` VARCHAR(50),
  `sender_email` VARCHAR(50),
  `sender_alias` VARCHAR(50),
  `template_id` VARCHAR(50),
  `domain` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sending_pool_emails` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  `scheduled_time` TIMESTAMP NULL,
  `original_scheduled_time` TIMESTAMP NULL,
  `trial` SMALLINT,
  `email` VARCHAR(50),
  `message_id` INT,
  `error_msg` VARCHAR(50),
  `error_code` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `templates` (
  `id` INT NOT NULL,
  `template_id` VARCHAR(50),
  `html` VARCHAR(50),
  `domain` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302835_20210406191606_dbinit') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302835_20210406191606_dbinit') AS relationships;
DROP DATABASE `db_302835_20210406191606_dbinit`;
UNINSTALL EXTENSION vsql_schematron;
