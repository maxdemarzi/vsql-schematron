INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341448_E5_BB_BA_E8_A1_A8
--echo #
CREATE DATABASE `db_341448_E5_BB_BA_E8_A1_A8`;
USE `db_341448_E5_BB_BA_E8_A1_A8`;

CREATE TABLE `data_yys.store` (
  `code` VARCHAR(64),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `data_yys.client` (
  `code` VARCHAR(64),
  `cli_name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `email` VARCHAR(64),
  `cli_age` INT,
  `sex` INT,
  `reg_time` DATETIME,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `data_yys.commodity` (
  `code` VARCHAR(64),
  `cate` VARCHAR(64),
  `price` INT,
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `data_yys.sale` (
  `sale_code` VARCHAR(64),
  `sale_city` VARCHAR(64),
  `com_code` VARCHAR(64),
  `par_time` DATETIME,
  `sale_sex` INT,
  `sale_price` INT,
  PRIMARY KEY (`sale_code`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341448_E5_BB_BA_E8_A1_A8') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341448_E5_BB_BA_E8_A1_A8') AS relationships;
DROP DATABASE `db_341448_E5_BB_BA_E8_A1_A8`;
UNINSTALL EXTENSION vsql_schematron;
