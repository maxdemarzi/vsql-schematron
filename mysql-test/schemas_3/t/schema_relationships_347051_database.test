INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347051_database
--echo #
CREATE DATABASE `db_347051_database`;
USE `db_347051_database`;
CREATE TABLE `VideoType` (
  `videoTypeId` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`videoTypeId`)
) CHARACTER SET latin1;
CREATE TABLE `Video` (
  `videoId` BIGINT NOT NULL,
  `stringId` VARCHAR(50),
  `videoTypeId` BIGINT,
  `title` VARCHAR(50),
  `description` VARCHAR(50),
  `host` VARCHAR(50),
  `source` VARCHAR(50),
  `thumbnail` VARCHAR(50),
  `updatedAt` VARCHAR(50),
  `remoteUpdatedAt` VARCHAR(50),
  PRIMARY KEY (`videoId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347051_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347051_database') AS relationships;
DROP DATABASE `db_347051_database`;
UNINSTALL EXTENSION vsql_schematron;
