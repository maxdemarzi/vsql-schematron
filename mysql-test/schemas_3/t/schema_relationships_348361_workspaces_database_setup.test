INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348361_workspaces_database_setup
--echo #
CREATE DATABASE `db_348361_workspaces_database_setup`;
USE `db_348361_workspaces_database_setup`;

CREATE TABLE `workspaces` (
  `workspace_id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`workspace_id`)
) CHARACTER SET latin1;

CREATE TABLE `items_in_workspaces` (
  `item_id` VARCHAR(64),
  `workspace_id` INT,
  PRIMARY KEY (`item_id`, `workspace_id`)
) CHARACTER SET latin1;

CREATE TABLE `collections_in_workspaces` (
  `collection_id` VARCHAR(64),
  `workspace_id` INT,
  PRIMARY KEY (`collection_id`, `workspace_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348361_workspaces_database_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348361_workspaces_database_setup') AS relationships;
DROP DATABASE `db_348361_workspaces_database_setup`;
UNINSTALL EXTENSION vsql_schematron;
