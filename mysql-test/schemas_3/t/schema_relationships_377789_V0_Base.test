INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377789_V0__Base
--echo #
CREATE DATABASE `db_377789_V0_Base`;
USE `db_377789_V0_Base`;

CREATE TABLE `chats` (
  `id` INT,
  `chat_id` INT,
  `is_rude` BOOL,
  PRIMARY KEY (`chat_id`)
) CHARACTER SET latin1;

CREATE TABLE `parties` (
  `id` INT,
  `name` VARCHAR(64),
  `chat_id` INT,
  `users` VARCHAR(64),
  `last_use` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377789_V0_Base') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377789_V0_Base') AS relationships;
DROP DATABASE `db_377789_V0_Base`;
UNINSTALL EXTENSION vsql_schematron;
