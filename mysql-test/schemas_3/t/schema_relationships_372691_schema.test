INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 372691_schema
--echo #
CREATE DATABASE `db_372691_schema`;
USE `db_372691_schema`;
CREATE TABLE `users` (
  `userid` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `admin_access` BOOLEAN,
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `admin_users` (
  `adminid` INT NOT NULL,
  `admin_password` VARCHAR(50),
  `userid` INT,
  PRIMARY KEY (`adminid`)
) CHARACTER SET latin1;
CREATE TABLE `auction_items` (
  `id` INT NOT NULL,
  `item` VARCHAR(50),
  `value` DECIMAL(10,2),
  `category` VARCHAR(50),
  `bid` DECIMAL(10,2),
  `topBidder` VARCHAR(50),
  `closed` BOOLEAN,
  `userid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_372691_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_372691_schema') AS relationships;
DROP DATABASE `db_372691_schema`;
UNINSTALL EXTENSION vsql_schematron;
