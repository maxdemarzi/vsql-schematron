INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366792_job
--echo #
CREATE DATABASE `db_366792_job`;
USE `db_366792_job`;

CREATE TABLE `application` (
  `app_id` INT,
  `user_id` INT,
  `job_id` INT,
  `app_status` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `job` (
  `job_id` INT,
  `job_title` VARCHAR(255),
  `job_company` VARCHAR(255),
  `job_experience` VARCHAR(255),
  `job_create_date` DATETIME,
  `job_kind` VARCHAR(255),
  `job_category` VARCHAR(255),
  `job_city` VARCHAR(255),
  `job_detail` VARCHAR(255),
  `user_id` INT,
  PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `user_id` INT,
  `user_name` VARCHAR(255),
  `user_email` VARCHAR(255),
  `user_password` VARCHAR(255),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366792_job') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366792_job') AS relationships;
DROP DATABASE `db_366792_job`;
UNINSTALL EXTENSION vsql_schematron;
