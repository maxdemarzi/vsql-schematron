INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328572_initialize_mysql
--echo #
CREATE DATABASE `db_328572_initialize_mysql`;
USE `db_328572_initialize_mysql`;
CREATE TABLE `properties` (
  `id` VARCHAR(50) NOT NULL,
  `value` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vulnerability` (
  `id` INT NOT NULL,
  `cve` VARCHAR(50),
  `description` VARCHAR(50),
  `cwe` VARCHAR(50),
  `cvssScore` DECIMAL(10,2),
  `cvssAccessVector` VARCHAR(50),
  `cvssAccessComplexity` VARCHAR(50),
  `cvssAuthentication` VARCHAR(50),
  `cvssConfidentialityImpact` VARCHAR(50),
  `cvssIntegrityImpact` VARCHAR(50),
  `cvssAvailabilityImpact` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reference` (
  `cveid` INT,
  `name` VARCHAR(50),
  `url` VARCHAR(50),
  `source` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `cpeEntry` (
  `id` INT NOT NULL,
  `cpe` VARCHAR(50),
  `vendor` VARCHAR(50),
  `product` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `software` (
  `cveid` INT,
  `cpeEntryId` INT,
  `previousVersion` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328572_initialize_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328572_initialize_mysql') AS relationships;
DROP DATABASE `db_328572_initialize_mysql`;
UNINSTALL EXTENSION vsql_schematron;
