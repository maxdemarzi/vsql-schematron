INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 311705_migration
--echo #
CREATE DATABASE `db_311705_migration`;
USE `db_311705_migration`;

CREATE TABLE `Coach` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `handle` VARCHAR(64),
  `name` VARCHAR(64),
  `teamId` INT,
  `type` VARCHAR(64),
  `isAssistant` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Player` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `handle` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `teamId` INT,
  `height` VARCHAR(64),
  `weight` VARCHAR(64),
  `number` VARCHAR(64),
  `position` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ColorScheme` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `primary` VARCHAR(64),
  `secondary` VARCHAR(64),
  `teamId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Team` (
  `id` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `handle` VARCHAR(64),
  `name` VARCHAR(64),
  `slug` VARCHAR(64),
  `city` VARCHAR(64),
  `abbreviation` VARCHAR(64),
  `logo` VARCHAR(64),
  `logoSlug` VARCHAR(64),
  `wins` INT,
  `losses` INT,
  `winPercentage` DECIMAL(10,2),
  `conference` VARCHAR(64),
  `division` VARCHAR(64),
  `established` VARCHAR(64),
  `primaryColor` VARCHAR(64),
  `secondaryColor` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `accounts` (
  `id` INT,
  `compound_id` VARCHAR(64),
  `user_id` INT,
  `provider_type` VARCHAR(64),
  `provider_id` VARCHAR(64),
  `provider_account_id` VARCHAR(64),
  `refresh_token` VARCHAR(64),
  `access_token` VARCHAR(64),
  `access_token_expires` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` INT,
  `user_id` INT,
  `expires` DATETIME,
  `session_token` VARCHAR(64),
  `access_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified` DATETIME,
  `image` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `verification_requests` (
  `id` INT,
  `identifier` VARCHAR(64),
  `token` VARCHAR(64),
  `expires` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_311705_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_311705_migration') AS relationships;
DROP DATABASE `db_311705_migration`;
UNINSTALL EXTENSION vsql_schematron;
