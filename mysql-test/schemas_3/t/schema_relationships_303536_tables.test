INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303536_tables
--echo #
CREATE DATABASE `db_303536_tables`;
USE `db_303536_tables`;
CREATE TABLE `t_users` (
  `user_id` INT NOT NULL,
  `user_name_first` TEXT,
  `user_name_last` TEXT,
  `user_phone` TEXT,
  `user_dni` TEXT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_users_locations` (
  `location_id` INT NOT NULL,
  `user_id` INT,
  `location_address` TEXT,
  `location_city` TEXT,
  `location_country` TEXT,
  `location_zip` TEXT,
  PRIMARY KEY (`location_id`)
) CHARACTER SET latin1;
CREATE TABLE `t_users_records` (
  `record_id` INT NOT NULL,
  `user_id` INT,
  `record_title` TEXT,
  `record_year` TEXT,
  PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303536_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303536_tables') AS relationships;
DROP DATABASE `db_303536_tables`;
UNINSTALL EXTENSION vsql_schematron;
