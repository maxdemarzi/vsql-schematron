INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 362481_create-db
--echo #
CREATE DATABASE `db_362481_create_db`;
USE `db_362481_create_db`;

CREATE TABLE `report` (
  `report_id` INT,
  `test_id` INT,
  `test_number` INT,
  `test_name` VARCHAR(64),
  `test_script` VARCHAR(64),
  `test_host` VARCHAR(64),
  `test_host_role` VARCHAR(64),
  `test_result` VARCHAR(64),
  `test_result_message` VARCHAR(64),
  `location` VARCHAR(64),
  `aggregated` VARCHAR(64),
  `test_date` DATETIME,
  `test_description` VARCHAR(64),
  `test_comments` VARCHAR(64),
  `valid` VARCHAR(64),
  `retired` VARCHAR(64),
  `retired_date` DATETIME,
  PRIMARY KEY (`report_id`)
) CHARACTER SET latin1;

CREATE TABLE `sut_node_info` (
  `sut_node_id` INT,
  `sut_node_name` VARCHAR(64),
  `sut_node_os_name` VARCHAR(64),
  `sut_node_os_arch` VARCHAR(64),
  `sut_node_os_version` VARCHAR(64),
  `sut_node_os_other` VARCHAR(64),
  `sut_node_hw_name` VARCHAR(64),
  `sut_node_hw_model` VARCHAR(64),
  `sut_node_hw_cpu` VARCHAR(64),
  `sut_node_hw_cpu_count` INT,
  `sut_node_hw_ram` INT,
  `sut_node_hw_disk_type` VARCHAR(64),
  `sut_node_hw_other` VARCHAR(64),
  PRIMARY KEY (`sut_node_id`)
) CHARACTER SET latin1;

CREATE TABLE `test_sut_node_link` (
  `test_id` INT,
  `sut_node_id` INT,
  PRIMARY KEY (`test_id`, `sut_node_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_362481_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_362481_create_db') AS relationships;
DROP DATABASE `db_362481_create_db`;
UNINSTALL EXTENSION vsql_schematron;
