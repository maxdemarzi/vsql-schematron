INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331203_schema
--echo #
CREATE DATABASE `db_331203_schema`;
USE `db_331203_schema`;

CREATE TABLE `form` (
  `id` INT,
  `author` VARCHAR(64),
  `projectName` VARCHAR(64),
  `contactInfo` VARCHAR(64),
  `projectDescription` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `PTRelation` (
  `iden` VARCHAR(64),
  `projectID` INT,
  `tagName` VARCHAR(64),
  PRIMARY KEY (`iden`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331203_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331203_schema') AS relationships;
DROP DATABASE `db_331203_schema`;
UNINSTALL EXTENSION vsql_schematron;
