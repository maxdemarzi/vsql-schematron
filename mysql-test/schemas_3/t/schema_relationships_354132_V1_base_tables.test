INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354132_V1__base_tables
--echo #
CREATE DATABASE `db_354132_V1_base_tables`;
USE `db_354132_V1_base_tables`;

CREATE TABLE `executions` (
  `id` INT,
  `timestamp` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `methods` (
  `id` INT,
  `executionId` INT,
  `identifier` VARCHAR(64),
  `checksum` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `classes` (
  `id` INT,
  `executionId` INT,
  `identifier` VARCHAR(64),
  `checksum` VARCHAR(64),
  `superclassIdentifier` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `class_constructors` (
  `id` INT,
  `identifier` VARCHAR(64),
  `checksum` VARCHAR(64),
  `classId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `class_static_blocks` (
  `id` INT,
  `identifier` VARCHAR(64),
  `checksum` VARCHAR(64),
  `classId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tests` (
  `id` INT,
  `executionId` INT,
  `identifier` VARCHAR(64),
  `runStatus` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `test_classes` (
  `testId` INT,
  `classId` INT,
  PRIMARY KEY (`testId`, `classId`)
) CHARACTER SET latin1;

CREATE TABLE `test_methods` (
  `testId` INT,
  `methodId` INT,
  PRIMARY KEY (`testId`, `methodId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354132_V1_base_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354132_V1_base_tables') AS relationships;
DROP DATABASE `db_354132_V1_base_tables`;
UNINSTALL EXTENSION vsql_schematron;
