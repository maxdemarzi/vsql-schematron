INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 362615_V1__schema
--echo #
CREATE DATABASE `db_362615_V1_schema`;
USE `db_362615_V1_schema`;

CREATE TABLE `user_roles` (
  `user_id` INT,
  `role_id` INT,
  PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;

CREATE TABLE `polls` (
  `id` INT,
  `question` VARCHAR(64),
  `expiration_date_time` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `created_by` INT,
  `updated_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `choices` (
  `id` INT,
  `text` VARCHAR(64),
  `poll_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `votes` (
  `id` INT,
  `user_id` INT,
  `poll_id` INT,
  `choice_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transactions` (
  `user_id` INT,
  `station_id` INT,
  `vehicle_id` INT,
  `trans_id` INT,
  `startTime` VARCHAR(64),
  `endTime` VARCHAR(64),
  `totalTime` VARCHAR(64),
  PRIMARY KEY (`trans_id`)
) CHARACTER SET latin1;

CREATE TABLE `documents` (
  `id` INT,
  `user_id` INT,
  `file_ref` VARCHAR(64),
  `country_name` VARCHAR(64),
  `file_name` VARCHAR(64),
  `document_type` VARCHAR(64),
  `upload_dir` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_362615_V1_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_362615_V1_schema') AS relationships;
DROP DATABASE `db_362615_V1_schema`;
UNINSTALL EXTENSION vsql_schematron;
