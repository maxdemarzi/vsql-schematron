INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 389496_create-database
--echo #
CREATE DATABASE `db_389496_create_database`;
USE `db_389496_create_database`;
CREATE TABLE `settings` (
  `themeName` VARCHAR(50),
  `timezone` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` VARCHAR(50) NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `firstName` VARCHAR(50),
  `lastName` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `poststatus` (
  `id` VARCHAR(50) NOT NULL,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `authorId` VARCHAR(50),
  `slug` VARCHAR(50),
  `content` TEXT,
  `createdDateTime` DATETIME,
  `publishedDateTime` DATETIME,
  `publishedYear` INT,
  `publishedMonth` INT,
  `postStatusId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_389496_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_389496_create_database') AS relationships;
DROP DATABASE `db_389496_create_database`;
UNINSTALL EXTENSION vsql_schematron;
