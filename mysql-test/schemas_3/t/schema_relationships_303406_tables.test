INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303406_tables
--echo #
CREATE DATABASE `db_303406_tables`;
USE `db_303406_tables`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `email` VARCHAR(64),
  `user_name` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `hashes` (
  `user_id` VARCHAR(64),
  `hash` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `salts` (
  `user_id` VARCHAR(64),
  `salt` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `user_id` VARCHAR(64),
  `token` VARCHAR(64),
  `expires` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303406_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303406_tables') AS relationships;
DROP DATABASE `db_303406_tables`;
UNINSTALL EXTENSION vsql_schematron;
