INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 353933_schema
--echo #
CREATE DATABASE `db_353933_schema`;
USE `db_353933_schema`;
CREATE TABLE `accountNumberDim` (
  `id` INT NOT NULL,
  `account_number` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `dimDate` (
  `date_key` INT NOT NULL,
  `date` DATE,
  `year` SMALLINT,
  `quarter` TINYINT,
  `month` TINYINT,
  `day` TINYINT,
  `week` TINYINT,
  `is_weekend` TINYINT,
  `is_holiday` TINYINT,
  PRIMARY KEY (`date_key`)
) CHARACTER SET latin1;
CREATE TABLE `trxAmountFact` (
  `date` INT,
  `account_number_id` INT,
  `withdrawal_amount` DECIMAL(10,2),
  `deposit_amount` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_353933_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_353933_schema') AS relationships;
DROP DATABASE `db_353933_schema`;
UNINSTALL EXTENSION vsql_schematron;
