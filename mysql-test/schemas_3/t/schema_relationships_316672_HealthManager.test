INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 316672_HealthManager
--echo #
CREATE DATABASE `db_316672_HealthManager`;
USE `db_316672_HealthManager`;
CREATE TABLE `comment` (
  `comment_id` INT NOT NULL,
  `content` VARCHAR(50),
  `time` VARCHAR(50),
  `user_num` VARCHAR(50),
  `post_id` INT,
  PRIMARY KEY (`comment_id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
  `course_id` INT NOT NULL,
  `course_data` VARCHAR(50),
  `course_name` VARCHAR(50),
  `course_time` VARCHAR(50),
  `information` VARCHAR(50),
  `tea_id` INT,
  PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `course_students` (
  `course_course_id` INT,
  `students_stu_id` INT
) CHARACTER SET latin1;
CREATE TABLE `homework` (
  `homework_id` INT NOT NULL,
  `grade` DOUBLE,
  `path` VARCHAR(50),
  `status` VARCHAR(50),
  `time` VARCHAR(50),
  `homework_title_id` INT,
  PRIMARY KEY (`homework_id`)
) CHARACTER SET latin1;
CREATE TABLE `homework_title` (
  `homework_title_id` INT NOT NULL,
  `content` VARCHAR(50),
  `num` INT,
  `course_id` INT,
  PRIMARY KEY (`homework_title_id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `post_id` INT NOT NULL,
  `content` VARCHAR(50),
  `time` VARCHAR(50),
  `title` VARCHAR(50),
  `type` INT,
  `user_num` VARCHAR(50),
  `tea_id` INT,
  `course_id` INT,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
CREATE TABLE `student_courses` (
  `student_stu_id` INT,
  `courses_course_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_316672_HealthManager') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_316672_HealthManager') AS relationships;
DROP DATABASE `db_316672_HealthManager`;
UNINSTALL EXTENSION vsql_schematron;
