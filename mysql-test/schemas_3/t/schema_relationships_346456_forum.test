INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 346456_forum
--echo #
CREATE DATABASE `db_346456_forum`;
USE `db_346456_forum`;

CREATE TABLE `forum_discussions` (
  `id` INT,
  `threadid` INT,
  `title` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forum_replies` (
  `id` INT,
  `postid` INT,
  `discussion` INT,
  `posted` INT,
  `user` INT,
  `name` VARCHAR(64),
  `contacturl` VARCHAR(64),
  `html` VARCHAR(64),
  `markdown` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forum_tags` (
  `id` INT,
  `name` VARCHAR(64),
  `count` INT,
  `lastused` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `forum_discussion_tags` (
  `tag` INT,
  `discussion` INT,
  PRIMARY KEY (`tag`, `discussion`)
) CHARACTER SET latin1;

CREATE TABLE `forum_edits` (
  `id` INT,
  `reply` INT,
  `editor` INT,
  `posted` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_346456_forum') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_346456_forum') AS relationships;
DROP DATABASE `db_346456_forum`;
UNINSTALL EXTENSION vsql_schematron;
