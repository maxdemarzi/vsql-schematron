INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351309_bibliotheque2
--echo #
CREATE DATABASE `db_351309_bibliotheque2`;
USE `db_351309_bibliotheque2`;
CREATE TABLE `Lecteur` (
  `id` VARCHAR(50) NOT NULL,
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `carte_numero` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Livre` (
  `id` VARCHAR(50) NOT NULL,
  `titre` VARCHAR(50),
  `auteur` VARCHAR(50),
  `categorie` VARCHAR(50),
  `synopsis` TEXT,
  `statut` BOOLEAN,
  `lecteur_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Emprunt` (
  `id` VARCHAR(50) NOT NULL,
  `date_emprunt` DATE,
  `date_rendu` DATE,
  `livre_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351309_bibliotheque2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351309_bibliotheque2') AS relationships;
DROP DATABASE `db_351309_bibliotheque2`;
UNINSTALL EXTENSION vsql_schematron;
