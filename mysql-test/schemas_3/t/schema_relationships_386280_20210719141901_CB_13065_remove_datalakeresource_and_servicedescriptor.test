CREATE TABLE `datalakeresources` (
  `id` INT,
  `datalakestack_id` INT,
  `name` VARCHAR(64),
  `datalakeambariip` VARCHAR(64),
  `datalakeambarifqdn` VARCHAR(64),
  `workspace_id` INT,
  `datalakecomponents` VARCHAR(64),
  `datalakeclustermanagerip` VARCHAR(64),
  `datalakeclustermanagerfqdn` VARCHAR(64),
  `datalakeclustermanagerurl` VARCHAR(64),
  `environmentcrn` VARCHAR(64),
  `datalakeambariurl` VARCHAR(64),
  `kerberosconfig_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `servicedescriptor` (
  `id` INT,
  `datalakeresources_id` INT,
  `workspace_id` INT,
  `servicename` VARCHAR(64),
  `blueprintparams` VARCHAR(64),
  `blueprintsecretparams` VARCHAR(64),
  `componentshosts` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `datalakeresources_rdsconfig` (
  `datalakeresources_id` INT,
  `rdsconfigs_id` INT,
  PRIMARY KEY (`datalakeresources_id`, `rdsconfigs_id`)
) CHARACTER SET latin1;

