INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318712_create
--echo #
CREATE DATABASE `db_318712_create`;
USE `db_318712_create`;

CREATE TABLE `DARWIN` (
  `component` VARCHAR(64),
  `modified` DATETIME,
  `version` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `DARWIN_LOCK` (
  `processName` VARCHAR(64),
  `leaseUntil` DATETIME,
  `unlockKey` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `DARWIN_PATCH` (
  `id` INT,
  `componentName` VARCHAR(64),
  `patchName` VARCHAR(64),
  `processTime` INT,
  `detectedOn` DATETIME,
  `finishedOn` DATETIME,
  `platform` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `DARWIN_SQL` (
  `id` INT,
  `patchId` INT,
  `statementHash` VARCHAR(64),
  `statement` VARCHAR(64),
  `processTime` INT,
  `finishedOn` DATETIME,
  `exception` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318712_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318712_create') AS relationships;
DROP DATABASE `db_318712_create`;
UNINSTALL EXTENSION vsql_schematron;
