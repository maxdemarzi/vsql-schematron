INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 308094_db_creation
--echo #
CREATE DATABASE `db_308094_db_creation`;
USE `db_308094_db_creation`;

CREATE TABLE `person` (
  `IDUser` INT,
  `Name` VARCHAR(64),
  `Surname` VARCHAR(64),
  `Gender` VARCHAR(64),
  `DoB` DATETIME,
  `Email` VARCHAR(64),
  `Passwd` VARCHAR(64),
  `Phone` VARCHAR(64),
  `City` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`IDUser`)
) CHARACTER SET latin1;

CREATE TABLE `feedback` (
  `TeacherID` INT,
  `StudentID` INT,
  `Score` INT,
  `Description` VARCHAR(64),
  `ReviewDate` DATETIME,
  PRIMARY KEY (`TeacherID`, `StudentID`)
) CHARACTER SET latin1;

CREATE TABLE `lesson` (
  `IDLesson` INT,
  `TeacherID` INT,
  `StudentID` INT,
  `LessonDate` DATETIME,
  `LessonTime` DATETIME,
  `LessonDuration` DATETIME,
  `LessonTariff` INT,
  `Payment` DATETIME,
  PRIMARY KEY (`IDLesson`)
) CHARACTER SET latin1;

CREATE TABLE `chat` (
  `TeacherID` INT,
  `StudentID` INT,
  `Confirmed` BOOL,
  `Messages` VARCHAR(64),
  `LastMessage` DATETIME,
  PRIMARY KEY (`TeacherID`, `StudentID`)
) CHARACTER SET latin1;

CREATE TABLE `topic` (
  `IDTopic` INT,
  `Label` VARCHAR(64),
  PRIMARY KEY (`IDTopic`)
) CHARACTER SET latin1;

CREATE TABLE `teacher_topic` (
  `TeacherID` INT,
  `TopicID` INT,
  `Tariff` INT,
  PRIMARY KEY (`TeacherID`, `TopicID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_308094_db_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_308094_db_creation') AS relationships;
DROP DATABASE `db_308094_db_creation`;
UNINSTALL EXTENSION vsql_schematron;
