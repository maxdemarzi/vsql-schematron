INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302160_Problem14-21
--echo #
CREATE DATABASE `db_302160_Problem14_21`;
USE `db_302160_Problem14_21`;
CREATE TABLE `towns` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `addresses` (
  `id` INT NOT NULL,
  `address_text` TEXT,
  `town_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `middle_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `job_title` VARCHAR(50),
  `department_id` INT,
  `hire_date` DATE,
  `salary` INT,
  `address_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302160_Problem14_21') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302160_Problem14_21') AS relationships;
DROP DATABASE `db_302160_Problem14_21`;
UNINSTALL EXTENSION vsql_schematron;
