INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 355986_db_beasiswa
--echo #
CREATE DATABASE `db_355986_db_beasiswa`;
USE `db_355986_db_beasiswa`;

CREATE TABLE `program` (
  `id_program` VARCHAR(64),
  `program_name` VARCHAR(64),
  `program_degree` VARCHAR(64),
  PRIMARY KEY (`id_program`)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `id_student` INT,
  `id_program` VARCHAR(64),
  `name` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `tb_user` (
  `id_user` INT,
  `firts_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_355986_db_beasiswa') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_355986_db_beasiswa') AS relationships;
DROP DATABASE `db_355986_db_beasiswa`;
UNINSTALL EXTENSION vsql_schematron;
