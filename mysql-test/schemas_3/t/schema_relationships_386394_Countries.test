INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 386394_Countries
--echo #
CREATE DATABASE `db_386394_Countries`;
USE `db_386394_Countries`;

CREATE TABLE `Country` (
  `CountryCode` VARCHAR(64),
  PRIMARY KEY (`CountryCode`)
) CHARACTER SET latin1;

CREATE TABLE `CountryCode` (
  `CountryCodeValue` VARCHAR(64),
  PRIMARY KEY (`CountryCodeValue`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_386394_Countries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_386394_Countries') AS relationships;
DROP DATABASE `db_386394_Countries`;
UNINSTALL EXTENSION vsql_schematron;
