INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 344250_AllTable
--echo #
CREATE DATABASE `db_344250_AllTable`;
USE `db_344250_AllTable`;

CREATE TABLE `USERS` (
  `id` DECIMAL(10,2),
  `uname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `LOCATION` (
  `lid` DECIMAL(10,2),
  `area` VARCHAR(64),
  PRIMARY KEY (`lid`)
) CHARACTER SET latin1;

CREATE TABLE `OWNER` (
  `oid` DECIMAL(10,2),
  `lid` DECIMAL(10,2),
  `oname` VARCHAR(64),
  `phoneno` VARCHAR(64),
  PRIMARY KEY (`oid`)
) CHARACTER SET latin1;

CREATE TABLE `PARKINGSLOAT` (
  `psid` DECIMAL(10,2),
  `price` DECIMAL(10,2),
  `booked` DECIMAL(10,2),
  `lid` DECIMAL(10,2),
  `oid` DECIMAL(10,2),
  PRIMARY KEY (`psid`)
) CHARACTER SET latin1;

CREATE TABLE `USES` (
  `id` DECIMAL(10,2),
  `PSid` DECIMAL(10,2),
  `oid` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_344250_AllTable') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_344250_AllTable') AS relationships;
DROP DATABASE `db_344250_AllTable`;
UNINSTALL EXTENSION vsql_schematron;
