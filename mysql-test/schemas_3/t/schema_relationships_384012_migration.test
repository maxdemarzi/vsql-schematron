INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 384012_migration
--echo #
CREATE DATABASE `db_384012_migration`;
USE `db_384012_migration`;

CREATE TABLE `Article` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `published` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `authorId` VARCHAR(64),
  `issueId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Issue` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `published` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `authorId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Archive` (
  `id` VARCHAR(64),
  `userId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ArchiveToArticle` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `_ArchiveToIssue` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_384012_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_384012_migration') AS relationships;
DROP DATABASE `db_384012_migration`;
UNINSTALL EXTENSION vsql_schematron;
