INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 309072_init
--echo #
CREATE DATABASE `db_309072_init`;
USE `db_309072_init`;

CREATE TABLE `user` (
  `user_id` INT,
  `name` VARCHAR(64),
  `app_name` VARCHAR(64),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `info` (
  `file_id` VARCHAR(64),
  `name` VARCHAR(64),
  `address` VARCHAR(64),
  `file_size` VARCHAR(64),
  `file_mime` VARCHAR(64),
  `created_at` DATETIME,
  `deleted_at` DATETIME,
  `owner` INT,
  PRIMARY KEY (`file_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_309072_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_309072_init') AS relationships;
DROP DATABASE `db_309072_init`;
UNINSTALL EXTENSION vsql_schematron;
