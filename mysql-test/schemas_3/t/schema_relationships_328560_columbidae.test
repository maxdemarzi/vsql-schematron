INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328560_columbidae
--echo #
CREATE DATABASE `db_328560_columbidae`;
USE `db_328560_columbidae`;

CREATE TABLE `auditory_signal` (
  `Name` VARCHAR(64),
  `Audio` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `behavior` (
  `Name` VARCHAR(64),
  `Video` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`Name`)
) CHARACTER SET latin1;

CREATE TABLE `common_names` (
  `SLatinName` VARCHAR(64),
  `VernacularName` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `conservation` (
  `SLatinName` VARCHAR(64),
  `Category` VARCHAR(64),
  `PrevCategory` VARCHAR(64),
  `PopTrend` VARCHAR(64),
  `LastAssesed` DATETIME,
  PRIMARY KEY (`SLatinName`)
) CHARACTER SET latin1;

CREATE TABLE `exhibits_auditory_signal` (
  `Name` VARCHAR(64),
  `SLatinName` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `exhibits_behavior` (
  `Name` VARCHAR(64),
  `SLatinName` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `family` (
  `FamilyName` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`FamilyName`)
) CHARACTER SET latin1;

CREATE TABLE `genus` (
  `GenusName` VARCHAR(64),
  `SubFamilyName` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`GenusName`)
) CHARACTER SET latin1;

CREATE TABLE `habitat` (
  `SLatinName` VARCHAR(64),
  `System` VARCHAR(64),
  `Biomes` VARCHAR(64),
  `Countries` VARCHAR(64),
  PRIMARY KEY (`SLatinName`)
) CHARACTER SET latin1;

CREATE TABLE `nat_predator` (
  `SLatinName` VARCHAR(64),
  `VernacularName` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `pigeons` (
  `SerialNumber` VARCHAR(64),
  `EyeColor` VARCHAR(64),
  `Weight` INT,
  `Breed` VARCHAR(64),
  `DateOfBirth` DATETIME,
  PRIMARY KEY (`SerialNumber`)
) CHARACTER SET latin1;

CREATE TABLE `species` (
  `LatinName` VARCHAR(64),
  `GenusName` VARCHAR(64),
  `Diet` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`LatinName`)
) CHARACTER SET latin1;

CREATE TABLE `subfamily` (
  `SubFamilyName` VARCHAR(64),
  `FamilyName` VARCHAR(64),
  `Description` VARCHAR(64),
  PRIMARY KEY (`SubFamilyName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328560_columbidae') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328560_columbidae') AS relationships;
DROP DATABASE `db_328560_columbidae`;
UNINSTALL EXTENSION vsql_schematron;
