INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318497_create_schema_cdret2gen.v.1.0
--echo #
CREATE DATABASE `db_318497_create_schema_cdret2gen_v_1_0`;
USE `db_318497_create_schema_cdret2gen_v_1_0`;

CREATE TABLE `cdret2gen.doctype` (
  `doctype_id` INT,
  `doctype` VARCHAR(64),
  `parent_id` INT,
  PRIMARY KEY (`doctype_id`)
) CHARACTER SET latin1;

CREATE TABLE `cdret2gen.doc` (
  `doc_id` INT,
  `doctype` INT,
  `reference` INT,
  `parent` INT,
  `reference2` INT,
  PRIMARY KEY (`doc_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318497_create_schema_cdret2gen_v_1_0') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318497_create_schema_cdret2gen_v_1_0') AS relationships;
DROP DATABASE `db_318497_create_schema_cdret2gen_v_1_0`;
UNINSTALL EXTENSION vsql_schematron;
