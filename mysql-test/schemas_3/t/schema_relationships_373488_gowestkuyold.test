INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373488_gowestkuyold
--echo #
CREATE DATABASE `db_373488_gowestkuyold`;
USE `db_373488_gowestkuyold`;
CREATE TABLE `sepeda` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  `qty` INT,
  `harga` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `sewa` (
  `id` INT,
  `trxno` VARCHAR(50),
  `tgl_sewa` TIMESTAMP NULL,
  `duedays` INT,
  `pelanggan` VARCHAR(50),
  `nohp` VARCHAR(50),
  `alamat` VARCHAR(50),
  `sepeda_id` INT,
  `total` INT,
  `tgl_kembali` TIMESTAMP NULL,
  `denda` INT,
  `isback` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `user` (
  `id` INT NOT NULL,
  `nama` VARCHAR(50),
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  `alamat` VARCHAR(50),
  `nohp` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373488_gowestkuyold') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373488_gowestkuyold') AS relationships;
DROP DATABASE `db_373488_gowestkuyold`;
UNINSTALL EXTENSION vsql_schematron;
