INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 382210_EMPRESA
--echo #
CREATE DATABASE `db_382210_EMPRESA`;
USE `db_382210_EMPRESA`;
CREATE TABLE `DEPTO` (
  `DEPTNO` INT NOT NULL,
  `DNOME` VARCHAR(50),
  PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
  `EMPNO` INT NOT NULL,
  `ENOME` VARCHAR(50),
  `ESAL` DECIMAL(10,2),
  `EDATADM` DATE,
  `EFUNCAO` CHAR(50),
  `DEPTNO` INT,
  PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `FONES_EMP` (
  `EMPNO` INT NOT NULL,
  `EFONE` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`EMPNO`, `EFONE`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_382210_EMPRESA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_382210_EMPRESA') AS relationships;
DROP DATABASE `db_382210_EMPRESA`;
UNINSTALL EXTENSION vsql_schematron;
