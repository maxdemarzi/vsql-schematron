INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302342_DATABASE_SQL
--echo #
CREATE DATABASE `db_302342_DATABASE_SQL`;
USE `db_302342_DATABASE_SQL`;

CREATE TABLE `mydb.language` (
  `ISO` VARCHAR(64),
  `language` VARCHAR(64),
  PRIMARY KEY (`ISO`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.newsletter` (
  `id` INT,
  `newsletteremail` VARCHAR(64),
  `subscribed_on` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.course` (
  `id` INT,
  `language` VARCHAR(64),
  `courseName` VARCHAR(64),
  `courseCategory` INT,
  `courseDescription` VARCHAR(64),
  `imageURL` VARCHAR(64),
  `addDate` INT,
  `author` INT,
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.lesson` (
  `id` INT,
  `lessonTitle` VARCHAR(64),
  `lessonDescription` VARCHAR(64),
  `courseID` INT,
  `order` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.review` (
  `id` INT,
  `reviewtext` VARCHAR(64),
  `rating` INT,
  `FK_userID` INT,
  `FK_courseID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.unit` (
  `id` INT,
  `unitTitle` VARCHAR(64),
  `unitText` VARCHAR(64),
  `imageURL` VARCHAR(64),
  `lessonID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.user_course` (
  `user_id` INT,
  `course_id` INT,
  `subscribed_at` INT,
  PRIMARY KEY (`user_id`, `course_id`)
) CHARACTER SET latin1;

CREATE TABLE `mydb.video` (
  `id` INT,
  `videoTitle` VARCHAR(64),
  `videoDescription` VARCHAR(64),
  `videoURL` VARCHAR(64),
  `lessonID` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302342_DATABASE_SQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302342_DATABASE_SQL') AS relationships;
DROP DATABASE `db_302342_DATABASE_SQL`;
UNINSTALL EXTENSION vsql_schematron;
