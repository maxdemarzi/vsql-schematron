INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334038_V1__init
--echo #
CREATE DATABASE `db_334038_V1__init`;
USE `db_334038_V1__init`;
CREATE TABLE `level` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member` (
  `id` BIGINT NOT NULL,
  `username` VARCHAR(50),
  `nickname` VARCHAR(50),
  `role` VARCHAR(50),
  `github_id` BIGINT,
  `image_url` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mission` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `level_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
  `id` BIGINT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `member_id` BIGINT,
  `mission_id` BIGINT,
  `title` VARCHAR(50),
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
  `id` BIGINT NOT NULL,
  `tag_id` BIGINT,
  `post_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334038_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334038_V1__init') AS relationships;
DROP DATABASE `db_334038_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
