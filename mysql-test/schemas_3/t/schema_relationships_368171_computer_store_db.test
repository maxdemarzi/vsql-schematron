INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 368171_computer_store_db
--echo #
CREATE DATABASE `db_368171_computer_store_db`;
USE `db_368171_computer_store_db`;
CREATE TABLE `country` (
  `id` VARCHAR(50) NOT NULL,
  `version` INT,
  `name` VARCHAR(50),
  `longitude` DOUBLE,
  `country_code` VARCHAR(50),
  `latitude` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
  `id` VARCHAR(50) NOT NULL,
  `version` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `favorite_color` VARCHAR(50),
  `birth_date` DATETIME,
  `email_address` VARCHAR(50),
  `male` VARCHAR(50),
  `phone_number` VARCHAR(50),
  `country_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` VARCHAR(50) NOT NULL,
  `version` INT,
  `name` VARCHAR(50),
  `price` DOUBLE,
  `quantity_in_stock` INT,
  `product_category_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_category` (
  `id` VARCHAR(50) NOT NULL,
  `version` INT,
  `name` VARCHAR(50),
  `parent_category_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_368171_computer_store_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_368171_computer_store_db') AS relationships;
DROP DATABASE `db_368171_computer_store_db`;
UNINSTALL EXTENSION vsql_schematron;
