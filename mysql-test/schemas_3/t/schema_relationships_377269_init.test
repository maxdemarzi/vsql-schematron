INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377269_init
--echo #
CREATE DATABASE `db_377269_init`;
USE `db_377269_init`;

CREATE TABLE `sensor` (
  `id` INT,
  `name` VARCHAR(64),
  `manufacturer` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `location` (
  `id` INT,
  `sensor_id` INT,
  `altitude` DECIMAL(10,2),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `indoor` VARCHAR(64),
  `country` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sensordatavalues` (
  `id` INT,
  `sensor_id` INT,
  `value` DECIMAL(10,2),
  `value_type` VARCHAR(64),
  `date` DATETIME,
  `time` DATETIME,
  PRIMARY KEY (`id`, `sensor_id`, `value`, `value_type`, `date`, `time`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377269_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377269_init') AS relationships;
DROP DATABASE `db_377269_init`;
UNINSTALL EXTENSION vsql_schematron;
