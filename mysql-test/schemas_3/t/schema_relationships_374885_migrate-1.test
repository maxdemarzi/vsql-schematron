INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 374885_migrate-1
--echo #
CREATE DATABASE `db_374885_migrate_1`;
USE `db_374885_migrate_1`;
CREATE TABLE `doer` (
  `doer_id` VARCHAR(50) NOT NULL,
  `current_timing` VARCHAR(50),
  PRIMARY KEY (`doer_id`)
) CHARACTER SET latin1;
CREATE TABLE `todo` (
  `doer_id` VARCHAR(50),
  `timing` VARCHAR(50),
  `plan` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_374885_migrate_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_374885_migrate_1') AS relationships;
DROP DATABASE `db_374885_migrate_1`;
UNINSTALL EXTENSION vsql_schematron;
