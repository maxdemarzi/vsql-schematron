INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 304040_schema
--echo #
CREATE DATABASE `db_304040_schema`;
USE `db_304040_schema`;
CREATE TABLE `customer` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `profile` (
  `customer_id` BIGINT,
  `street_number` VARCHAR(50),
  `street_name` VARCHAR(50),
  `district` VARCHAR(50),
  `city` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `product` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `price` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product_tag` (
  `tag_id` BIGINT NOT NULL,
  `product_id` BIGINT NOT NULL,
  PRIMARY KEY (`tag_id`, `product_id`)
) CHARACTER SET latin1;
CREATE TABLE `customer_order` (
  `id` BIGINT NOT NULL,
  `customer_id` BIGINT,
  `discount` DECIMAL(10,2),
  `created_date` DATETIME,
  `last_modified` DATETIME,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_304040_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_304040_schema') AS relationships;
DROP DATABASE `db_304040_schema`;
UNINSTALL EXTENSION vsql_schematron;
