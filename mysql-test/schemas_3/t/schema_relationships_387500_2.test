INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 387500_2
--echo #
CREATE DATABASE `db_387500_2`;
USE `db_387500_2`;
CREATE TABLE `departamento` (
  `did` VARCHAR(50) NOT NULL,
  `nomedepto` VARCHAR(50),
  PRIMARY KEY (`did`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
  `fid` VARCHAR(50) NOT NULL,
  `nome` VARCHAR(50),
  `did` VARCHAR(50),
  `salario` DECIMAL(10,2),
  PRIMARY KEY (`fid`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_387500_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_387500_2') AS relationships;
DROP DATABASE `db_387500_2`;
UNINSTALL EXTENSION vsql_schematron;
