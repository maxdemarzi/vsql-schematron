INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 385534_import
--echo #
CREATE DATABASE `db_385534_import`;
USE `db_385534_import`;

CREATE TABLE `faculty` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `id` INT,
  `faculty` INT,
  `name` VARCHAR(64),
  `study_years` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `course_code` VARCHAR(64),
  `department` INT,
  `course_title` VARCHAR(64),
  `year` INT,
  PRIMARY KEY (`course_code`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer` (
  `lec_no` VARCHAR(64),
  `name` VARCHAR(64),
  `department` INT,
  `password` VARCHAR(64),
  PRIMARY KEY (`lec_no`)
) CHARACTER SET latin1;

CREATE TABLE `lecturer-course` (
  `lecturer` VARCHAR(64),
  `course` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `student` (
  `mat_no` VARCHAR(64),
  `name` VARCHAR(64),
  `department` INT,
  `year` INT,
  `password` VARCHAR(64),
  PRIMARY KEY (`mat_no`)
) CHARACTER SET latin1;

CREATE TABLE `student-course` (
  `student` VARCHAR(64),
  `course` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `complaint` (
  `id` VARCHAR(64),
  `author` VARCHAR(64),
  `category` VARCHAR(64),
  `status` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `dateadded` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag` (
  `id` INT,
  `name` VARCHAR(64),
  `category` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tag-complaint` (
  `tag` INT,
  `complaint` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `student-complaint` (
  `student` VARCHAR(64),
  `complaint` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `comment` (
  `id` INT,
  `author-s` VARCHAR(64),
  `author-r` VARCHAR(64),
  `complaint` VARCHAR(64),
  `text` VARCHAR(64),
  `dateadded` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_385534_import') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_385534_import') AS relationships;
DROP DATABASE `db_385534_import`;
UNINSTALL EXTENSION vsql_schematron;
