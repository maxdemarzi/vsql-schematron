INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 342786_V2__add_tags
--echo #
CREATE DATABASE `db_342786_V2__add_tags`;
USE `db_342786_V2__add_tags`;
CREATE TABLE `tags` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documents_tags` (
  `document_id` VARCHAR(50),
  `tag_id` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_342786_V2__add_tags') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_342786_V2__add_tags') AS relationships;
DROP DATABASE `db_342786_V2__add_tags`;
UNINSTALL EXTENSION vsql_schematron;
