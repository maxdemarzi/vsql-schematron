INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 346785_V_1__create_len
--echo #
CREATE DATABASE `db_346785_V_1_create_len`;
USE `db_346785_V_1_create_len`;

CREATE TABLE `len_schema_version` (
  `version_key` VARCHAR(64),
  `version_value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `len_document` (
  `id` DECIMAL(10,2),
  `oid` DECIMAL(10,2),
  `ver_from_instant` DATETIME,
  `ver_to_instant` DATETIME,
  `corr_from_instant` DATETIME,
  `corr_to_instant` DATETIME,
  `name` VARCHAR(64),
  `main_type` VARCHAR(64),
  `sub_type` VARCHAR(64),
  `actual_type` VARCHAR(64),
  `packed_data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `len_idkey` (
  `id` DECIMAL(10,2),
  `key_scheme` VARCHAR(64),
  `key_value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `len_doc2idkey` (
  `doc_id` DECIMAL(10,2),
  `idkey_id` DECIMAL(10,2),
  PRIMARY KEY (`doc_id`, `idkey_id`)
) CHARACTER SET latin1;

CREATE TABLE `len_attr` (
  `id` DECIMAL(10,2),
  `attr_key` VARCHAR(64),
  `attr_value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `len_doc2attr` (
  `doc_id` DECIMAL(10,2),
  `attr_id` DECIMAL(10,2),
  PRIMARY KEY (`doc_id`, `attr_id`)
) CHARACTER SET latin1;

CREATE TABLE `len_prop` (
  `id` DECIMAL(10,2),
  `prop_key` VARCHAR(64),
  `prop_value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `len_doc2prop` (
  `doc_id` DECIMAL(10,2),
  `prop_id` DECIMAL(10,2),
  PRIMARY KEY (`doc_id`, `prop_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_346785_V_1_create_len') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_346785_V_1_create_len') AS relationships;
DROP DATABASE `db_346785_V_1_create_len`;
UNINSTALL EXTENSION vsql_schematron;
