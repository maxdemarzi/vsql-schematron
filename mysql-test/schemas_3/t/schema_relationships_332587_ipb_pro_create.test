INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 332587_ipb_pro_create
--echo #
CREATE DATABASE `db_332587_ipb_pro_create`;
USE `db_332587_ipb_pro_create`;
CREATE TABLE `Dokumentacja` (
  `id` INT NOT NULL,
  `dataUtworzenia` DATE,
  `nakład` INT,
  `formaNadruku` VARCHAR(50),
  `rodzajMateriału` VARCHAR(50),
  `tematPrzewodni` VARCHAR(50),
  `stanProjektu` VARCHAR(50),
  `DziałProjektowy_id` INT,
  `Projektant_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `DziałProjektowy` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `KolekcjaGrafik` (
  `id` INT NOT NULL,
  `dataUtworzenia` DATE,
  `odnośnik` VARCHAR(50),
  `Projektant_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Projektant` (
  `id` INT NOT NULL,
  `imię` VARCHAR(50),
  `nazwisko` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Zlecenie` (
  `id` INT NOT NULL,
  `treść` VARCHAR(50),
  `DziałProjektowy_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_332587_ipb_pro_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_332587_ipb_pro_create') AS relationships;
DROP DATABASE `db_332587_ipb_pro_create`;
UNINSTALL EXTENSION vsql_schematron;
