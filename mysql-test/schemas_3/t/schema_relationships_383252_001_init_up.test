INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383252_001_init.up
--echo #
CREATE DATABASE `db_383252_001_init_up`;
USE `db_383252_001_init_up`;
CREATE TABLE `bake` (
  `id` VARCHAR(50) NOT NULL,
  `create_time` TIMESTAMP NULL,
  `name` TEXT,
  `bake_status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `toppings` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bake_toppings` (
  `bake_id` VARCHAR(50) NOT NULL,
  `topping_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`bake_id`, `topping_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383252_001_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383252_001_init_up') AS relationships;
DROP DATABASE `db_383252_001_init_up`;
UNINSTALL EXTENSION vsql_schematron;
