INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354821_V12__ContainedItem
--echo #
CREATE DATABASE `db_354821_V12__ContainedItem`;
USE `db_354821_V12__ContainedItem`;
CREATE TABLE `collection_containeditem` (
  `id` INT NOT NULL,
  `item_container_id` INT,
  `relative_probability` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `collection_containeditem_required_tags` (
  `contained_item_id` INT NOT NULL,
  `required_tags_tag` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`contained_item_id`, `required_tags_tag`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354821_V12__ContainedItem') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354821_V12__ContainedItem') AS relationships;
DROP DATABASE `db_354821_V12__ContainedItem`;
UNINSTALL EXTENSION vsql_schematron;
