INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366565_bug_442
--echo #
CREATE DATABASE `db_366565_bug_442`;
USE `db_366565_bug_442`;

CREATE TABLE `tbl_A` (
  `a` INT,
  `b` INT,
  PRIMARY KEY (`a`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_B` (
  `ba` INT,
  `a` INT,
  PRIMARY KEY (`ba`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_C` (
  `ba` INT,
  `a` INT,
  PRIMARY KEY (`ba`)
) CHARACTER SET latin1;

CREATE TABLE `tbl_D` (
  `ba` INT,
  `a` INT,
  PRIMARY KEY (`ba`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366565_bug_442') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366565_bug_442') AS relationships;
DROP DATABASE `db_366565_bug_442`;
UNINSTALL EXTENSION vsql_schematron;
