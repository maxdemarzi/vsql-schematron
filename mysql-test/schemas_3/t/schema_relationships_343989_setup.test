INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343989_setup
--echo #
CREATE DATABASE `db_343989_setup`;
USE `db_343989_setup`;
CREATE TABLE `Categories` (
  `CategoryID` INT NOT NULL,
  `CategoryName` VARCHAR(50),
  `CategoryDescription` VARCHAR(50),
  PRIMARY KEY (`CategoryID`)
) CHARACTER SET latin1;
CREATE TABLE `Products` (
  `ProductNumber` INT NOT NULL,
  `ProductName` VARCHAR(50),
  `ProductDescription` VARCHAR(50),
  `Price` DECIMAL(10,2),
  `CategoryID` INT,
  PRIMARY KEY (`ProductNumber`)
) CHARACTER SET latin1;
CREATE TABLE `SalesRecords` (
  `SalesRecordNumber` INT NOT NULL,
  `SalesDate` DATETIME,
  `Comment` VARCHAR(50),
  PRIMARY KEY (`SalesRecordNumber`)
) CHARACTER SET latin1;
CREATE TABLE `SaleRecordDetails` (
  `SalesRecordNumber` INT NOT NULL,
  `ProductNumber` INT NOT NULL,
  `QuotedPrice` DECIMAL(10,2),
  `QuantityOrdered` INT,
  PRIMARY KEY (`SalesRecordNumber`, `ProductNumber`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343989_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343989_setup') AS relationships;
DROP DATABASE `db_343989_setup`;
UNINSTALL EXTENSION vsql_schematron;
