INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317591_schema
--echo #
CREATE DATABASE `db_317591_schema`;
USE `db_317591_schema`;

CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(64),
  `ProductVersion` VARCHAR(64),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;

CREATE TABLE `evidence_requests` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `resident_id` VARCHAR(64),
  `delivery_methods` VARCHAR(64),
  `document_types` VARCHAR(64),
  `service_requested_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `residents` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `communications` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `delivery_method` VARCHAR(64),
  `notify_id` VARCHAR(64),
  `template_id` VARCHAR(64),
  `reason` VARCHAR(64),
  `evidence_request_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `document_submissions` (
  `id` VARCHAR(64),
  `created_at` DATETIME,
  `claim_id` VARCHAR(64),
  `rejection_reason` VARCHAR(64),
  `state` INT,
  `evidence_request_id` VARCHAR(64),
  `document_type_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317591_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317591_schema') AS relationships;
DROP DATABASE `db_317591_schema`;
UNINSTALL EXTENSION vsql_schematron;
