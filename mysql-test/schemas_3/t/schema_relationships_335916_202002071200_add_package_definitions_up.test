CREATE TABLE `packages` (
  `id` VARCHAR(255),
  `tenant_id` VARCHAR(255),
  `app_id` VARCHAR(255),
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `instance_auth_request_json_schema` VARCHAR(255),
  `default_instance_auth` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `package_instance_auths` (
  `id` VARCHAR(255),
  `package_id` VARCHAR(255),
  `tenant_id` VARCHAR(255),
  `context` VARCHAR(255),
  `input_params` VARCHAR(255),
  `auth_value` VARCHAR(255),
  `status_condition` VARCHAR(255),
  `status_timestamp` DATETIME,
  `status_message` VARCHAR(255),
  `status_reason` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

