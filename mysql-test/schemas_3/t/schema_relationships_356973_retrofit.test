INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 356973_retrofit
--echo #
CREATE DATABASE `db_356973_retrofit`;
USE `db_356973_retrofit`;

CREATE TABLE `~heads` (
  `ID` INT,
  `name` VARCHAR(64),
  `desc` VARCHAR(64),
  `order` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `~cats` (
  `ID` INT,
  `head` INT,
  `name` VARCHAR(64),
  `desc` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `~threads` (
  `ID` INT,
  `cat` INT,
  `name` VARCHAR(64),
  `time` INT,
  `creator` INT,
  `last_post` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `~posts` (
  `ID` INT,
  `thread` INT,
  `time` INT,
  `content` VARCHAR(64),
  `poster` INT,
  `last_edited` INT,
  `edited_by` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_356973_retrofit') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_356973_retrofit') AS relationships;
DROP DATABASE `db_356973_retrofit`;
UNINSTALL EXTENSION vsql_schematron;
