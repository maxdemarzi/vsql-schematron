INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318897_setup
--echo #
CREATE DATABASE `db_318897_setup`;
USE `db_318897_setup`;

CREATE TABLE `users` (
  `userID` INT,
  `vms_email` VARCHAR(64),
  `vms_apiPassword` VARCHAR(64),
  `userPassword` VARCHAR(64),
  `userType` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `dids` (
  `didID` INT,
  `ownerID` INT,
  `did` VARCHAR(64),
  PRIMARY KEY (`didID`)
) CHARACTER SET latin1;

CREATE TABLE `contacts` (
  `contactID` INT,
  `ownerID` INT,
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `did` VARCHAR(64),
  `notes` VARCHAR(64),
  PRIMARY KEY (`contactID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318897_setup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318897_setup') AS relationships;
DROP DATABASE `db_318897_setup`;
UNINSTALL EXTENSION vsql_schematron;
