INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 368196_edges
--echo #
CREATE DATABASE `db_368196_edges`;
USE `db_368196_edges`;

CREATE TABLE `Edges` (
  `EdgeID` INT,
  `ProgramID` INT,
  `EnvironmentID` INT,
  `ParentNodeID` INT,
  `ChildNodeID` INT,
  `BirthPhaseID` INT,
  `BirthTime` DATETIME,
  `DeathPhaseID` INT,
  `DeathTime` DATETIME,
  `ClonedFromEdgeID` INT,
  `ClonedRootNodeID` INT,
  PRIMARY KEY (`EdgeID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_368196_edges') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_368196_edges') AS relationships;
DROP DATABASE `db_368196_edges`;
UNINSTALL EXTENSION vsql_schematron;
