INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352397_4-Classroom
--echo #
CREATE DATABASE `db_352397_4_Classroom`;
USE `db_352397_4_Classroom`;

CREATE TABLE `student` (
  `USN` VARCHAR(64),
  `sname` VARCHAR(64),
  `Address` VARCHAR(64),
  `Phone` DECIMAL(10,2),
  `Gender` VARCHAR(64),
  PRIMARY KEY (`USN`)
) CHARACTER SET latin1;

CREATE TABLE `semsec` (
  `ssid` VARCHAR(64),
  `sem` DECIMAL(10,2),
  `sec` VARCHAR(64),
  PRIMARY KEY (`ssid`)
) CHARACTER SET latin1;

CREATE TABLE `class` (
  `usn` VARCHAR(64),
  `ssid` VARCHAR(64),
  PRIMARY KEY (`usn`, `ssid`)
) CHARACTER SET latin1;

CREATE TABLE `subject` (
  `subcode` VARCHAR(64),
  `Title` VARCHAR(64),
  `sem` DECIMAL(10,2),
  `credits` DECIMAL(10,2),
  PRIMARY KEY (`subcode`)
) CHARACTER SET latin1;

CREATE TABLE `iamarks` (
  `usn` VARCHAR(64),
  `subcode` VARCHAR(64),
  `ssid` VARCHAR(64),
  `test1` DECIMAL(10,2),
  `test2` DECIMAL(10,2),
  `test3` DECIMAL(10,2),
  `finalia` DECIMAL(10,2),
  PRIMARY KEY (`usn`, `subcode`, `ssid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352397_4_Classroom') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352397_4_Classroom') AS relationships;
DROP DATABASE `db_352397_4_Classroom`;
UNINSTALL EXTENSION vsql_schematron;
