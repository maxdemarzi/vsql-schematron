INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 305137_schema
--echo #
CREATE DATABASE `db_305137_schema`;
USE `db_305137_schema`;
CREATE TABLE `Users` (
  `username` VARCHAR(50) NOT NULL,
  `hashedPassword` VARCHAR(50),
  `salt` VARCHAR(50),
  `iterations` INT,
  PRIMARY KEY (`username`)
) CHARACTER SET latin1;
CREATE TABLE `AccessTokens` (
  `token` VARCHAR(50) NOT NULL,
  `username` VARCHAR(50),
  `expiration` DATETIME,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_305137_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_305137_schema') AS relationships;
DROP DATABASE `db_305137_schema`;
UNINSTALL EXTENSION vsql_schematron;
