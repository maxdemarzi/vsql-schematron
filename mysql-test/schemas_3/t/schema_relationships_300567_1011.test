INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 300567_1011
--echo #
CREATE DATABASE `db_300567_1011`;
USE `db_300567_1011`;
CREATE TABLE `album` (
  `id` VARCHAR(50) NOT NULL,
  `title` VARCHAR(50),
  `artist` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `track` (
  `album` CHAR(50),
  `dsk` INT,
  `posn` INT,
  `song` VARCHAR(50)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_300567_1011') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_300567_1011') AS relationships;
DROP DATABASE `db_300567_1011`;
UNINSTALL EXTENSION vsql_schematron;
