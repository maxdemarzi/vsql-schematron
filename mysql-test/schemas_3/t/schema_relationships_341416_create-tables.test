INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341416_create-tables
--echo #
CREATE DATABASE `db_341416_create_tables`;
USE `db_341416_create_tables`;
CREATE TABLE `Person` (
  `id` INT NOT NULL,
  `forename` VARCHAR(50),
  `surname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Project` (
  `id` INT NOT NULL,
  `person` INT,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Task` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `priority` INT,
  `schedule` DATE,
  `completed` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ProjectTask` (
  `project` INT NOT NULL,
  `task` INT NOT NULL,
  PRIMARY KEY (`project`, `task`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341416_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341416_create_tables') AS relationships;
DROP DATABASE `db_341416_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
