INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364740_migration
--echo #
CREATE DATABASE `db_364740_migration`;
USE `db_364740_migration`;
CREATE TABLE `Reason` (
  `id` INT NOT NULL,
  `text` VARCHAR(50),
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Transaction` (
  `id` INT NOT NULL,
  `amount` DECIMAL(10,2),
  `date` TIMESTAMP NULL,
  `description` VARCHAR(50),
  `updatedAt` TIMESTAMP NULL,
  `reasonId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364740_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364740_migration') AS relationships;
DROP DATABASE `db_364740_migration`;
UNINSTALL EXTENSION vsql_schematron;
