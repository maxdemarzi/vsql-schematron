INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376965_uni2
--echo #
CREATE DATABASE `db_376965_uni2`;
USE `db_376965_uni2`;

CREATE TABLE `course` (
  `cid` INT,
  `lecturer` INT,
  `lab_teacher` INT,
  `topic` VARCHAR(64),
  PRIMARY KEY (`cid`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `pid` INT,
  `fname` VARCHAR(64),
  `lname` VARCHAR(64),
  `status` INT,
  PRIMARY KEY (`pid`)
) CHARACTER SET latin1;

CREATE TABLE `registration` (
  `pid` INT,
  `cid` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376965_uni2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376965_uni2') AS relationships;
DROP DATABASE `db_376965_uni2`;
UNINSTALL EXTENSION vsql_schematron;
