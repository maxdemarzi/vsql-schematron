INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335331_databases
--echo #
CREATE DATABASE `db_335331_databases`;
USE `db_335331_databases`;

CREATE TABLE `autores` (
  `autor_id` INT,
  `nombre` VARCHAR(255),
  `apellido` VARCHAR(255),
  `genero` VARCHAR(255),
  `fecha_nacimiento` DATETIME,
  `pais_origen` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `usuarios` (
  `usuario_id` INT,
  `nombre` VARCHAR(255),
  `apellidos` VARCHAR(255),
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `fecha_creacion` DATETIME,
  PRIMARY KEY (`usuario_id`)
) CHARACTER SET latin1;

CREATE TABLE `libros` (
  `libro_id` INT,
  `autor_id` INT,
  `titulo` VARCHAR(255),
  `descripcion` VARCHAR(255),
  `paginas` INT,
  `fecha_publicacion` DATETIME,
  `fecha_creacion` DATETIME,
  PRIMARY KEY (`libro_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335331_databases') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335331_databases') AS relationships;
DROP DATABASE `db_335331_databases`;
UNINSTALL EXTENSION vsql_schematron;
