INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303083_schema_objects
--echo #
CREATE DATABASE `db_303083_schema_objects`;
USE `db_303083_schema_objects`;

CREATE TABLE `test_suite` (
  `test_suite_id` DECIMAL(10,2),
  `parent_id` DECIMAL(10,2),
  `owner` VARCHAR(64),
  `package_name` VARCHAR(64),
  `procedure_name` VARCHAR(64),
  `include_in_package` DECIMAL(10,2),
  `test_suite_description` VARCHAR(64),
  PRIMARY KEY (`test_suite_id`)
) CHARACTER SET latin1;

CREATE TABLE `test_case` (
  `test_case_id` DECIMAL(10,2),
  `test_suite_id` DECIMAL(10,2),
  `test_case_description` VARCHAR(64),
  PRIMARY KEY (`test_case_id`)
) CHARACTER SET latin1;

CREATE TABLE `test_param` (
  `test_param_id` DECIMAL(10,2),
  `test_case_id` DECIMAL(10,2),
  `parameter_type` VARCHAR(64),
  `parameter_name` VARCHAR(64),
  `num_value` DECIMAL(10,2),
  `str_value` VARCHAR(64),
  `dat_value` DATETIME,
  `lob_value` VARCHAR(64),
  PRIMARY KEY (`test_param_id`)
) CHARACTER SET latin1;

CREATE TABLE `test_execution` (
  `test_execution_id` DECIMAL(10,2),
  `test_suite_id` DECIMAL(10,2),
  `execution_date` DATETIME,
  `execution_user` VARCHAR(64),
  PRIMARY KEY (`test_execution_id`)
) CHARACTER SET latin1;

CREATE TABLE `execution_param` (
  `execution_param_id` DECIMAL(10,2),
  `test_execution_id` DECIMAL(10,2),
  `test_case_id` DECIMAL(10,2),
  `parameter_type` VARCHAR(64),
  `parameter_name` VARCHAR(64),
  `num_value` DECIMAL(10,2),
  `str_value` VARCHAR(64),
  `dat_value` DATETIME,
  `lob_value` VARCHAR(64),
  PRIMARY KEY (`execution_param_id`)
) CHARACTER SET latin1;

CREATE TABLE `script` (
  `script_id` DECIMAL(10,2),
  `script_body` VARCHAR(64),
  `script_description` VARCHAR(64),
  `run_seq` DECIMAL(10,2),
  `script_type` VARCHAR(64),
  `test_suite_id` DECIMAL(10,2),
  `script_owner` VARCHAR(64),
  `script_package` VARCHAR(64),
  `script_proc` VARCHAR(64),
  PRIMARY KEY (`script_id`)
) CHARACTER SET latin1;

CREATE TABLE `testing_log` (
  `log_id` DECIMAL(10,2),
  `place` VARCHAR(64),
  `message` VARCHAR(64),
  `testsuite_id` DECIMAL(10,2),
  `execution_id` DECIMAL(10,2),
  `sql_code` DECIMAL(10,2),
  `sql_message` VARCHAR(64),
  `executed_by` VARCHAR(64),
  `executed_on` DATETIME,
  PRIMARY KEY (`log_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303083_schema_objects') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303083_schema_objects') AS relationships;
DROP DATABASE `db_303083_schema_objects`;
UNINSTALL EXTENSION vsql_schematron;
