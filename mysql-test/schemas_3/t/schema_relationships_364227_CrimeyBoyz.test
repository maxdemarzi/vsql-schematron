INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364227_CrimeyBoyz
--echo #
CREATE DATABASE `db_364227_CrimeyBoyz`;
USE `db_364227_CrimeyBoyz`;

CREATE TABLE `interactions` (
  `interactionID` INT,
  `metricName` VARCHAR(64),
  `roundID` INT,
  `initiatingPlayerNum` INT,
  `actionTime` DECIMAL(10,2),
  `actionXPos` DECIMAL(10,2),
  `actionYPos` DECIMAL(10,2),
  `actionSpecificData` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `metrics` (
  `metricName` VARCHAR(64),
  `metricDescription` VARCHAR(64),
  `dataDescription` VARCHAR(64),
  `behaviourType` VARCHAR(64),
  PRIMARY KEY (`metricName`)
) CHARACTER SET latin1;

CREATE TABLE `rounds` (
  `roundID` INT,
  `sessionID` INT,
  `sceneName` VARCHAR(64),
  `roundStartTime` DECIMAL(10,2),
  `player1StartingScore` INT,
  `player2StartingScore` INT,
  `player3StartingScore` INT,
  `player4StartingScore` INT,
  `player5StartingScore` INT,
  `tabletPlayer` INT,
  PRIMARY KEY (`roundID`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `sessionID` INT,
  `sessionStartTime` DATETIME,
  `player1` INT,
  `player2` INT,
  `player3` INT,
  `player4` INT,
  `player5` INT
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `username` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `researcher` INT,
  `institution` VARCHAR(64),
  `field` VARCHAR(64),
  `AllowsDataCollection` INT,
  `Notes` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364227_CrimeyBoyz') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364227_CrimeyBoyz') AS relationships;
DROP DATABASE `db_364227_CrimeyBoyz`;
UNINSTALL EXTENSION vsql_schematron;
