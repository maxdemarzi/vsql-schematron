INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 309365_createdb.template
--echo #
CREATE DATABASE `db_309365_createdb_template`;
USE `db_309365_createdb_template`;

CREATE TABLE `musichub.account` (
  `id` INT,
  `email` VARCHAR(64),
  `passwordhash` VARCHAR(64),
  `nickname` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.work` (
  `id` INT,
  `title` VARCHAR(64),
  `year` VARCHAR(64),
  `version` VARCHAR(64),
  `composer` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.performance` (
  `id` INT,
  `workid` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `performer_title` VARCHAR(64),
  `performer_bio` VARCHAR(64),
  `venue_title` VARCHAR(64),
  `location` VARCHAR(64),
  `date` DATETIME,
  `time` DATETIME,
  `timezone` VARCHAR(64),
  `public` INT,
  `status` VARCHAR(64),
  `linked_performanceid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.role` (
  `id` INT,
  `accountid` INT,
  `role` VARCHAR(64),
  `workid` INT,
  `performanceid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.log` (
  `id` INT,
  `accountid` INT,
  `timestamp` DATETIME,
  `onaccountid` INT,
  `workid` INT,
  `performanceid` INT,
  `action` VARCHAR(64),
  `extrainfo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.plugin` (
  `id` INT,
  `title` VARCHAR(64),
  `code` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.plugin_setting` (
  `id` INT,
  `pluginid` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.performance_integration` (
  `id` INT,
  `performanceid` INT,
  `pluginid` INT,
  `enabled` INT,
  `guid` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `musichub.performance_integration_setting` (
  `id` INT,
  `perfintid` INT,
  `performanceid` INT,
  `pluginid` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_309365_createdb_template') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_309365_createdb_template') AS relationships;
DROP DATABASE `db_309365_createdb_template`;
UNINSTALL EXTENSION vsql_schematron;
