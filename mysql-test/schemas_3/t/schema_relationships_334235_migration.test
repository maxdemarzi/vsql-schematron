INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334235_migration
--echo #
CREATE DATABASE `db_334235_migration`;
USE `db_334235_migration`;
CREATE TABLE `comic_imgs` (
  `id` INT NOT NULL,
  `height` INT,
  `width` INT,
  `ratio` DOUBLE,
  `sourceUrl` VARCHAR(50),
  `size` VARCHAR(50),
  `comic_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comics` (
  `id` INT NOT NULL,
  `publishedAt` TIMESTAMP NULL,
  `news` TEXT,
  `safeTitle` TEXT,
  `title` TEXT,
  `transcript` TEXT,
  `alt` TEXT,
  `sourceUrl` VARCHAR(50),
  `explainUrl` VARCHAR(50),
  `interactiveUrl` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `device_tokens` (
  `token` VARCHAR(50) NOT NULL,
  `version` VARCHAR(50),
  `lastComicIdSent` INT,
  `createdAt` TIMESTAMP NULL,
  `updatedAt` TIMESTAMP NULL,
  PRIMARY KEY (`token`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334235_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334235_migration') AS relationships;
DROP DATABASE `db_334235_migration`;
UNINSTALL EXTENSION vsql_schematron;
