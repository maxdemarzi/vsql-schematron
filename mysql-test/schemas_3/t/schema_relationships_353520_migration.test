INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 353520_migration
--echo #
CREATE DATABASE `db_353520_migration`;
USE `db_353520_migration`;

CREATE TABLE `Term` (
  `id` INT,
  `name` VARCHAR(64),
  `months` INT,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_CategoryToTerm` (
  `A` INT,
  `B` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_353520_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_353520_migration') AS relationships;
DROP DATABASE `db_353520_migration`;
UNINSTALL EXTENSION vsql_schematron;
