INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 343789_schema
--echo #
CREATE DATABASE `db_343789_schema`;
USE `db_343789_schema`;
CREATE TABLE `account` (
  `id` INT NOT NULL,
  `usr` VARCHAR(50),
  `pwd` VARCHAR(50),
  `email` VARCHAR(50),
  `created_on` TIMESTAMP NULL,
  `last_login` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permission` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `account_permission` (
  `account_id` INT NOT NULL,
  `permission_id` INT NOT NULL,
  `grant_date` TIMESTAMP NULL,
  PRIMARY KEY (`account_id`, `permission_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_343789_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_343789_schema') AS relationships;
DROP DATABASE `db_343789_schema`;
UNINSTALL EXTENSION vsql_schematron;
