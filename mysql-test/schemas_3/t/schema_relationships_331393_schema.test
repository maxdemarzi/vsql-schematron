INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331393_schema
--echo #
CREATE DATABASE `db_331393_schema`;
USE `db_331393_schema`;
CREATE TABLE `COMMENT` (
  `ID` BIGINT NOT NULL,
  `DESCRIPTION` VARCHAR(50),
  `BOOK_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GENRE` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR` (
  `ID` BIGINT NOT NULL,
  `FULLNAME` VARCHAR(50),
  `ALIAS` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
  `ID` BIGINT NOT NULL,
  `NAME` VARCHAR(50),
  `AUTHOR_ID` BIGINT,
  `GENRE_ID` BIGINT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331393_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331393_schema') AS relationships;
DROP DATABASE `db_331393_schema`;
UNINSTALL EXTENSION vsql_schematron;
