INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 368620_script
--echo #
CREATE DATABASE `db_368620_script`;
USE `db_368620_script`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `icons` VARCHAR(64),
  `color_hex` VARCHAR(64),
  `user_created` INT,
  `created_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tasks` (
  `id` INT,
  `title` VARCHAR(64),
  `due_date` DATETIME,
  `location` VARCHAR(64),
  `attachments` VARCHAR(64),
  `status` BOOL,
  `created_date` DATETIME,
  `cat_id` INT,
  `user_created` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_368620_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_368620_script') AS relationships;
DROP DATABASE `db_368620_script`;
UNINSTALL EXTENSION vsql_schematron;
