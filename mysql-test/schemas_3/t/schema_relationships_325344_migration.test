INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325344_migration
--echo #
CREATE DATABASE `db_325344_migration`;
USE `db_325344_migration`;

CREATE TABLE `User` (
  `id` INT,
  `updatedAt` DATETIME,
  `createdAt` DATETIME,
  `email` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `social` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Course` (
  `id` INT,
  `name` VARCHAR(64),
  `courseDetails` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `CourseEnrollment` (
  `createdAt` DATETIME,
  `role` VARCHAR(64),
  `userId` INT,
  `courseId` INT,
  PRIMARY KEY (`userId`, `courseId`, `role`)
) CHARACTER SET latin1;

CREATE TABLE `Test` (
  `id` INT,
  `updatedAt` DATETIME,
  `name` VARCHAR(64),
  `date` DATETIME,
  `courseId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `TestResult` (
  `id` INT,
  `createdAt` DATETIME,
  `result` INT,
  `graderId` INT,
  `studentId` INT,
  `testId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325344_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325344_migration') AS relationships;
DROP DATABASE `db_325344_migration`;
UNINSTALL EXTENSION vsql_schematron;
