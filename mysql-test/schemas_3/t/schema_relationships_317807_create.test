INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317807_create
--echo #
CREATE DATABASE `db_317807_create`;
USE `db_317807_create`;

CREATE TABLE `component` (
  `name` VARCHAR(255),
  `source_url` VARCHAR(255),
  `source_type` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `stand` (
  `reference` VARCHAR(255),
  `version` VARCHAR(255),
  `component_name` VARCHAR(255),
  PRIMARY KEY (`reference`)
) CHARACTER SET latin1;

CREATE TABLE `build` (
  `id` VARCHAR(255),
  `time_stamp` VARCHAR(255),
  `build_number` INT,
  `job_name` VARCHAR(255),
  `job_url` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `dependency` (
  `reference` VARCHAR(255),
  `build_id` VARCHAR(255),
  `type` VARCHAR(255),
  PRIMARY KEY (`reference`, `build_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317807_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317807_create') AS relationships;
DROP DATABASE `db_317807_create`;
UNINSTALL EXTENSION vsql_schematron;
