INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 353223_V1__init
--echo #
CREATE DATABASE `db_353223_V1__init`;
USE `db_353223_V1__init`;
CREATE TABLE `EMPRESA` (
  `id` BIGINT NOT NULL,
  `cnpj` VARCHAR(50),
  `data_atualizacao` DATETIME,
  `data_criacao` DATETIME,
  `razao_social` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `FUNCIONARIO` (
  `id` BIGINT NOT NULL,
  `cpf` VARCHAR(50),
  `data_atualizacao` DATETIME,
  `data_criacao` DATETIME,
  `email` VARCHAR(50),
  `nome` VARCHAR(50),
  `perfil` VARCHAR(50),
  `qtd_horas_almoco` DOUBLE,
  `qtd_horas_trabalho_dia` DOUBLE,
  `senha` VARCHAR(50),
  `valor_hora` DECIMAL(10,2),
  `empresa_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lancamento` (
  `id` BIGINT NOT NULL,
  `data` DATETIME,
  `data_atualizacao` DATETIME,
  `data_criacao` DATETIME,
  `descricao` VARCHAR(50),
  `localizacao` VARCHAR(50),
  `tipo` VARCHAR(50),
  `funcionario_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_353223_V1__init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_353223_V1__init') AS relationships;
DROP DATABASE `db_353223_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
