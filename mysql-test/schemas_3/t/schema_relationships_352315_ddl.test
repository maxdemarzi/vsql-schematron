INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352315_ddl
--echo #
CREATE DATABASE `db_352315_ddl`;
USE `db_352315_ddl`;
CREATE TABLE `book` (
  `id` BIGINT NOT NULL,
  `author` VARCHAR(50),
  `title` VARCHAR(50),
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `review` (
  `id` BIGINT NOT NULL,
  `fk_book` BIGINT,
  `comment_body` VARCHAR(50),
  `comment_date` DATE,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352315_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352315_ddl') AS relationships;
DROP DATABASE `db_352315_ddl`;
UNINSTALL EXTENSION vsql_schematron;
