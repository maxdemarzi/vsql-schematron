INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 392241_db
--echo #
CREATE DATABASE `db_392241_db`;
USE `db_392241_db`;
CREATE TABLE `categories` (
  `id` INT NOT NULL,
  `category` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tips` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `content` TEXT,
  `category_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_392241_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_392241_db') AS relationships;
DROP DATABASE `db_392241_db`;
UNINSTALL EXTENSION vsql_schematron;
