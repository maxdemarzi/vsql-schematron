INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366706_V14__create_spm_svar_tables
--echo #
CREATE DATABASE `db_366706_V14__create_spm_svar_tables`;
USE `db_366706_V14__create_spm_svar_tables`;
CREATE TABLE `sporsmal` (
  `id` INT NOT NULL,
  `shortName` VARCHAR(50),
  `tekst` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `svar` (
  `id` INT NOT NULL,
  `sykmelding_id` VARCHAR(50),
  `sporsmal_id` INT,
  `svartype` VARCHAR(50),
  `svar` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366706_V14__create_spm_svar_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366706_V14__create_spm_svar_tables') AS relationships;
DROP DATABASE `db_366706_V14__create_spm_svar_tables`;
UNINSTALL EXTENSION vsql_schematron;
