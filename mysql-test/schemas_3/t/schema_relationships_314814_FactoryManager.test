INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 314814_FactoryManager
--echo #
CREATE DATABASE `db_314814_FactoryManager`;
USE `db_314814_FactoryManager`;
CREATE TABLE `Registration` (
  `RegistrationID` INT NOT NULL,
  `Username` VARCHAR(50),
  `Email` VARCHAR(50),
  `Password` VARCHAR(50),
  `FirstName` VARCHAR(50),
  `LastName` VARCHAR(50),
  `CompanyName` VARCHAR(50),
  `Address` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `ZipCode` INT,
  PRIMARY KEY (`RegistrationID`)
) CHARACTER SET latin1;
CREATE TABLE `Importation` (
  `ImportationID` INT NOT NULL,
  `RegistrationID` INT,
  `CompanyName` VARCHAR(50),
  `PointOfContact` VARCHAR(50),
  `CountryCode` INT,
  `PhoneNumber` INT,
  `Email` VARCHAR(50),
  `Address` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `ZipCode` INT,
  `CurrentDate` DATE,
  `Product` VARCHAR(50),
  `PricePerUnit` DOUBLE,
  `Quantity` INT,
  PRIMARY KEY (`ImportationID`)
) CHARACTER SET latin1;
CREATE TABLE `Exportation` (
  `ExportationID` INT NOT NULL,
  `RegistrationID` INT,
  `CompanyName` VARCHAR(50),
  `PointOfContact` VARCHAR(50),
  `CountryCode` INT,
  `PhoneNumber` INT,
  `Email` VARCHAR(50),
  `Address` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `ZipCode` INT,
  `CurrentDate` DATE,
  `Product` VARCHAR(50),
  `PricePerUnit` DOUBLE,
  `Quantity` INT,
  PRIMARY KEY (`ExportationID`)
) CHARACTER SET latin1;
CREATE TABLE `Delivery` (
  `DeliveryID` INT NOT NULL,
  `RegistrationID` INT,
  `ExportationID` INT,
  `CompanyName` VARCHAR(50),
  `PointOfContact` VARCHAR(50),
  `CountryCode` INT,
  `PhoneNumber` INT,
  `Email` VARCHAR(50),
  `Address` VARCHAR(50),
  `City` VARCHAR(50),
  `State` VARCHAR(50),
  `ZipCode` INT,
  `CurrentDate` DATE,
  `ContainerPricePerUnit` DOUBLE,
  `ContainerQuantity` INT,
  `ShipmentPrice` DOUBLE,
  PRIMARY KEY (`DeliveryID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_314814_FactoryManager') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_314814_FactoryManager') AS relationships;
DROP DATABASE `db_314814_FactoryManager`;
UNINSTALL EXTENSION vsql_schematron;
