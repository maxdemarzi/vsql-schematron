INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377762_databaseSchema
--echo #
CREATE DATABASE `db_377762_databaseSchema`;
USE `db_377762_databaseSchema`;
CREATE TABLE `devices` (
  `id` INT NOT NULL,
  `serialNumber` VARCHAR(50),
  `name` VARCHAR(50),
  `latitude` DECIMAL(10,2),
  `longitude` DECIMAL(10,2),
  `functional_status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurments` (
  `measurment_id` INT NOT NULL,
  `device_id` INT,
  `measure_time` TIMESTAMP NULL,
  `co` SMALLINT,
  `pm25` SMALLINT,
  `pm10` SMALLINT,
  `no2` SMALLINT,
  `so2` SMALLINT,
  `temperature` SMALLINT,
  `humidity` SMALLINT,
  PRIMARY KEY (`measurment_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377762_databaseSchema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377762_databaseSchema') AS relationships;
DROP DATABASE `db_377762_databaseSchema`;
UNINSTALL EXTENSION vsql_schematron;
