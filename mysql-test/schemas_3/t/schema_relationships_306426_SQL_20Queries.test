INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 306426_SQL%20Queries
--echo #
CREATE DATABASE `db_306426_SQL_20Queries`;
USE `db_306426_SQL_20Queries`;
CREATE TABLE `etu` (
  `pknumsecu` VARCHAR(50) NOT NULL,
  `knumetu` CHAR(50),
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  PRIMARY KEY (`pknumsecu`)
) CHARACTER SET latin1;
CREATE TABLE `uv` (
  `pkcode` VARCHAR(50) NOT NULL,
  `fketu` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`pkcode`, `fketu`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_306426_SQL_20Queries') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_306426_SQL_20Queries') AS relationships;
DROP DATABASE `db_306426_SQL_20Queries`;
UNINSTALL EXTENSION vsql_schematron;
