INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 326353_market
--echo #
CREATE DATABASE `db_326353_market`;
USE `db_326353_market`;

CREATE TABLE `usuarios` (
  `id` INT,
  `nombre` VARCHAR(64),
  `email` VARCHAR(64),
  `clave` VARCHAR(64),
  `fecha_registro` DATETIME,
  `activo` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `entradas` (
  `id` INT,
  `autor_id` INT,
  `url` VARCHAR(64),
  `titulo` VARCHAR(64),
  `valor` INT,
  `texto` VARCHAR(64),
  `fecha` DATETIME,
  `activa` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comentarios` (
  `id` INT,
  `autor_id` INT,
  `entrada_id` INT,
  `titulo` VARCHAR(64),
  `texto` VARCHAR(64),
  `fecha` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `recuperacion_clave` (
  `id` INT,
  `usuario_id` INT,
  `url_secreta` VARCHAR(64),
  `fecha` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `perfil` (
  `id` INT,
  `usuario_id` INT,
  `celular` VARCHAR(64),
  `facebook` VARCHAR(64),
  `twitter` VARCHAR(64),
  `instagram` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_326353_market') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_326353_market') AS relationships;
DROP DATABASE `db_326353_market`;
UNINSTALL EXTENSION vsql_schematron;
