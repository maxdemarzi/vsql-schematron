INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341053_235%20Major%20Concentrations
--echo #
CREATE DATABASE `db_341053_235_20Major_20Concentrations`;
USE `db_341053_235_20Major_20Concentrations`;

CREATE TABLE `pos_major_conc` (
  `uniqueid` DECIMAL(10,2),
  `major_id` DECIMAL(10,2),
  `external_uid` VARCHAR(64),
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`uniqueid`)
) CHARACTER SET latin1;

CREATE TABLE `reservation_major_conc` (
  `reservation_id` DECIMAL(10,2),
  `concentration_id` DECIMAL(10,2),
  PRIMARY KEY (`reservation_id`, `concentration_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341053_235_20Major_20Concentrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341053_235_20Major_20Concentrations') AS relationships;
DROP DATABASE `db_341053_235_20Major_20Concentrations`;
UNINSTALL EXTENSION vsql_schematron;
