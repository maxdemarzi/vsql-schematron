INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358274_TableCreationQueries-H2
--echo #
CREATE DATABASE `db_358274_TableCreationQueries_H2`;
USE `db_358274_TableCreationQueries_H2`;

CREATE TABLE `User` (
  `userID` VARCHAR(64),
  `name` VARCHAR(64),
  `password` VARCHAR(64),
  `regDate` DATETIME,
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `TestPlan` (
  `testID` INT,
  `userID` VARCHAR(64),
  `testConfig` VARCHAR(64),
  `creationTime` DATETIME,
  PRIMARY KEY (`testID`)
) CHARACTER SET latin1;

CREATE TABLE `Report` (
  `reportID` INT,
  `testID` VARCHAR(64),
  `userID` VARCHAR(64),
  `report` VARCHAR(64),
  `passed` INT,
  `failed` INT,
  `passRate` INT,
  `runTime` DATETIME,
  PRIMARY KEY (`reportID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358274_TableCreationQueries_H2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358274_TableCreationQueries_H2') AS relationships;
DROP DATABASE `db_358274_TableCreationQueries_H2`;
UNINSTALL EXTENSION vsql_schematron;
