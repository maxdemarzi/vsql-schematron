INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 362575_problems
--echo #
CREATE DATABASE `db_362575_problems`;
USE `db_362575_problems`;
CREATE TABLE `apartaments` (
  `id` INT NOT NULL,
  `unit` VARCHAR(50),
  `building_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `buildings` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `complex_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `complexes` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tenants` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `requests` (
  `id` INT NOT NULL,
  `status` VARCHAR(50),
  `apartament_id` INT,
  `description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_362575_problems') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_362575_problems') AS relationships;
DROP DATABASE `db_362575_problems`;
UNINSTALL EXTENSION vsql_schematron;
