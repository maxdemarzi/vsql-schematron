INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 375810_6
--echo #
CREATE DATABASE `db_375810_6`;
USE `db_375810_6`;

CREATE TABLE `TILE` (
  `ID` VARCHAR(64),
  `DEFAULT_SIZE` VARCHAR(64),
  `FETCH_URL` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_TILE` (
  `USERCODE` VARCHAR(64),
  `TILE_ID` VARCHAR(64),
  `TILE_POSITION` INT,
  `TILE_SIZE` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`USERCODE`, `TILE_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_375810_6') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_375810_6') AS relationships;
DROP DATABASE `db_375810_6`;
UNINSTALL EXTENSION vsql_schematron;
