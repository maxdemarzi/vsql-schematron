INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 313069_tables
--echo #
CREATE DATABASE `db_313069_tables`;
USE `db_313069_tables`;
CREATE TABLE `book_genre` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `author` VARCHAR(50),
  `page_count` INT,
  `book_genre` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member` (
  `id` INT NOT NULL,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `email` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `borrowed_books` (
  `id` INT NOT NULL,
  `book_id` INT,
  `member_id` INT,
  `withdraw_date` DATETIME,
  `due_date` DATETIME,
  `is_overdue` TINYINT,
  `is_returned` TINYINT,
  `returned_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_313069_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_313069_tables') AS relationships;
DROP DATABASE `db_313069_tables`;
UNINSTALL EXTENSION vsql_schematron;
