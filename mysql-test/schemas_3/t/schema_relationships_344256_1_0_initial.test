INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 344256_1.0__initial
--echo #
CREATE DATABASE `db_344256_1_0_initial`;
USE `db_344256_1_0_initial`;

CREATE TABLE `error_env` (
  `id` INT,
  `error_id` INT,
  `app` VARCHAR(64),
  `env` VARCHAR(64),
  `line` VARCHAR(64),
  `when_created` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `error_instance` (
  `id` INT,
  `error_id` INT,
  `app` VARCHAR(64),
  `env` VARCHAR(64),
  `line` VARCHAR(64),
  `when_created` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `error_stack` (
  `id` INT,
  `hash` VARCHAR(64),
  `match_line` VARCHAR(64),
  `stack_lines` VARCHAR(64),
  `when_created` DATETIME,
  `version` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_344256_1_0_initial') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_344256_1_0_initial') AS relationships;
DROP DATABASE `db_344256_1_0_initial`;
UNINSTALL EXTENSION vsql_schematron;
