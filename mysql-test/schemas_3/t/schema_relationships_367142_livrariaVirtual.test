INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 367142_livrariaVirtual
--echo #
CREATE DATABASE `db_367142_livrariaVirtual`;
USE `db_367142_livrariaVirtual`;
CREATE TABLE `cliente` (
  `id` INT NOT NULL,
  `cpf` VARCHAR(50),
  `nome` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `livro` (
  `id` INT NOT NULL,
  `isbn` VARCHAR(50),
  `titulo` VARCHAR(50),
  `autor` VARCHAR(50),
  `anoPublicacao` INT,
  `quantidadeEstoque` INT,
  `preco` DOUBLE,
  `ativo` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedido` (
  `id` INT NOT NULL,
  `idCliente` INT,
  `dataPedido` DATETIME,
  `confirmacaoPagamento` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pedidoLivro` (
  `idPedido` INT NOT NULL,
  `idLivro` INT NOT NULL,
  `quantidade` INT,
  `preco` DOUBLE,
  PRIMARY KEY (`idPedido`, `idLivro`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_367142_livrariaVirtual') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_367142_livrariaVirtual') AS relationships;
DROP DATABASE `db_367142_livrariaVirtual`;
UNINSTALL EXTENSION vsql_schematron;
