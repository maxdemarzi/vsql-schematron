INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 316268_JFY_DB_v3
--echo #
CREATE DATABASE `db_316268_JFY_DB_v3`;
USE `db_316268_JFY_DB_v3`;

CREATE TABLE `categories` (
  `CAID` INT,
  `category` VARCHAR(64),
  PRIMARY KEY (`CAID`)
) CHARACTER SET latin1;

CREATE TABLE `moderator` (
  `MODID` INT,
  `REQID` INT,
  `POSTID` INT
) CHARACTER SET latin1;

CREATE TABLE `requestslog` (
  `REQID` INT,
  `Time` DATETIME,
  `Method` VARCHAR(64),
  `Path` VARCHAR(64),
  `Error` VARCHAR(64),
  PRIMARY KEY (`REQID`)
) CHARACTER SET latin1;

CREATE TABLE `responses` (
  `REID` INT,
  `UID` INT,
  `AID` INT,
  `UserChoice` INT
) CHARACTER SET latin1;

CREATE TABLE `userposts` (
  `POSTID` INT,
  `UID` INT,
  `CID` INT,
  `title` VARCHAR(64),
  `author` VARCHAR(64),
  `likes` INT,
  `image` VARCHAR(64),
  `body` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `usertable` (
  `UID` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `Password` VARCHAR(64),
  `NewUser` INT,
  `last_login` DATETIME,
  `last_logout` DATETIME,
  PRIMARY KEY (`UID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_316268_JFY_DB_v3') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_316268_JFY_DB_v3') AS relationships;
DROP DATABASE `db_316268_JFY_DB_v3`;
UNINSTALL EXTENSION vsql_schematron;
