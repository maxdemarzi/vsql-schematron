INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 313910_menu
--echo #
CREATE DATABASE `db_313910_menu`;
USE `db_313910_menu`;
CREATE TABLE `menu` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `url` VARCHAR(50),
  `parent` INT,
  `status` BOOLEAN,
  `icon` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_313910_menu') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_313910_menu') AS relationships;
DROP DATABASE `db_313910_menu`;
UNINSTALL EXTENSION vsql_schematron;
