INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379760_000001_init_schema.up
--echo #
CREATE DATABASE `db_379760_000001_init_schema_up`;
USE `db_379760_000001_init_schema_up`;

CREATE TABLE `members` (
  `id` INT,
  `name` VARCHAR(64),
  `age` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `discographies` (
  `id` INT,
  `title` VARCHAR(64),
  `type` VARCHAR(64),
  `center_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379760_000001_init_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379760_000001_init_schema_up') AS relationships;
DROP DATABASE `db_379760_000001_init_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
