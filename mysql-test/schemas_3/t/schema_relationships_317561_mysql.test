INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317561_mysql
--echo #
CREATE DATABASE `db_317561_mysql`;
USE `db_317561_mysql`;

CREATE TABLE `cpa` (
  `cpa_id` VARCHAR(255),
  `cpa` VARCHAR(255),
  PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;

CREATE TABLE `ebms_message` (
  `id` INT,
  `time_stamp` DATETIME,
  `cpa_id` VARCHAR(255),
  `conversation_id` VARCHAR(255),
  `sequence_nr` INT,
  `message_id` VARCHAR(255),
  `ref_to_message_id` VARCHAR(255),
  `from_role` VARCHAR(255),
  `to_role` VARCHAR(255),
  `service_type` VARCHAR(255),
  `service` VARCHAR(255),
  `action` VARCHAR(255),
  `original` VARCHAR(255),
  `signature` VARCHAR(255),
  `message_header` VARCHAR(255),
  `sync_reply` VARCHAR(255),
  `message_order` VARCHAR(255),
  `ack_requested` VARCHAR(255),
  `content` VARCHAR(255),
  `status` INT,
  `status_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `ebms_attachment` (
  `ebms_message_id` INT,
  `name` VARCHAR(255),
  `content_type` VARCHAR(255),
  `content` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `ebms_send_event` (
  `ebms_message_id` INT,
  `time` DATETIME,
  `status` INT,
  `status_time` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317561_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317561_mysql') AS relationships;
DROP DATABASE `db_317561_mysql`;
UNINSTALL EXTENSION vsql_schematron;
