INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 375997_deathstar_power_nodes
--echo #
CREATE DATABASE `db_375997_deathstar_power_nodes`;
USE `db_375997_deathstar_power_nodes`;

CREATE TABLE `deathstar_power_nodes` (
  `id` INT,
  `label` VARCHAR(64),
  `primary_node_fk` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_375997_deathstar_power_nodes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_375997_deathstar_power_nodes') AS relationships;
DROP DATABASE `db_375997_deathstar_power_nodes`;
UNINSTALL EXTENSION vsql_schematron;
