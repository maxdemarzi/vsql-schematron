INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 313409_month_schema
--echo #
CREATE DATABASE `db_313409_month_schema`;
USE `db_313409_month_schema`;
CREATE TABLE `mydb.periods` (
  `id` INT NOT NULL,
  `period` VARCHAR(50),
  `order` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.month_names` (
  `id` INT NOT NULL,
  `composite_month_name` VARCHAR(50),
  `type` VARCHAR(50),
  `order` INT,
  `month_number` VARCHAR(50),
  `ruler_id` INT,
  `year_name_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.dates` (
  `id` INT NOT NULL,
  `date` VARCHAR(50),
  `type` VARCHAR(50),
  `order` INT,
  `month_name_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_313409_month_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_313409_month_schema') AS relationships;
DROP DATABASE `db_313409_month_schema`;
UNINSTALL EXTENSION vsql_schematron;
