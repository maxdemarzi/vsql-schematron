INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352647_upgrade_3_1_3000_to_4_0_0_postgres
--echo #
CREATE DATABASE `db_352647_upgrade_3_1_3000_to_4_0_0_postgres`;
USE `db_352647_upgrade_3_1_3000_to_4_0_0_postgres`;

CREATE TABLE `REPLICATION_METRICS` (
  `RM_SCHEDULED_EXECUTION_ID` INT,
  `RM_POLICY` VARCHAR(255),
  `RM_DUMP_EXECUTION_ID` INT,
  `RM_METADATA` VARCHAR(255),
  `RM_PROGRESS` VARCHAR(255),
  PRIMARY KEY (`RM_SCHEDULED_EXECUTION_ID`)
) CHARACTER SET latin1;

CREATE TABLE `STORED_PROCS` (
  `SP_ID` INT,
  `CREATE_TIME` INT,
  `DB_ID` INT,
  `NAME` VARCHAR(255),
  `OWNER_NAME` VARCHAR(255),
  `SOURCE` VARCHAR(255),
  PRIMARY KEY (`SP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `DATACONNECTORS` (
  `NAME` VARCHAR(255),
  `TYPE` VARCHAR(255),
  `URL` VARCHAR(255),
  `COMMENT` VARCHAR(255),
  `OWNER_NAME` VARCHAR(255),
  `OWNER_TYPE` VARCHAR(255),
  `CREATE_TIME` INT,
  PRIMARY KEY (`NAME`)
) CHARACTER SET latin1;

CREATE TABLE `DATACONNECTOR_PARAMS` (
  `NAME` VARCHAR(255),
  `PARAM_KEY` VARCHAR(255),
  `PARAM_VALUE` VARCHAR(255),
  PRIMARY KEY (`NAME`, `PARAM_KEY`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352647_upgrade_3_1_3000_to_4_0_0_postgres') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352647_upgrade_3_1_3000_to_4_0_0_postgres') AS relationships;
DROP DATABASE `db_352647_upgrade_3_1_3000_to_4_0_0_postgres`;
UNINSTALL EXTENSION vsql_schematron;
