INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 386581_livro_cap1_exemplo15_1
--echo #
CREATE DATABASE `db_386581_livro_cap1_exemplo15_1`;
USE `db_386581_livro_cap1_exemplo15_1`;

CREATE TABLE `empregado` (
  `codemp` INT,
  `nomeemp` VARCHAR(64),
  `salario` DECIMAL(10,2),
  `codresp` INT,
  PRIMARY KEY (`codemp`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_386581_livro_cap1_exemplo15_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_386581_livro_cap1_exemplo15_1') AS relationships;
DROP DATABASE `db_386581_livro_cap1_exemplo15_1`;
UNINSTALL EXTENSION vsql_schematron;
