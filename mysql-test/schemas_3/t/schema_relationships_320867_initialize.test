INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 320867_initialize
--echo #
CREATE DATABASE `db_320867_initialize`;
USE `db_320867_initialize`;
CREATE TABLE `foodCategory` (
  `id` INT NOT NULL,
  `food_cat_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `course` (
  `id` INT NOT NULL,
  `course_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ingredient` (
  `id` INT NOT NULL,
  `ingredient_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `measurement` (
  `id` INT NOT NULL,
  `measurement_name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
  `id` INT NOT NULL,
  `course_id` INT,
  `food_cat_id` INT,
  `recipe_name` VARCHAR(50),
  `recipe_desc` VARCHAR(50),
  `prep_time` TIME,
  `cook_time` TIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `quantity` (
  `id` INT NOT NULL,
  `recipe_id` INT,
  `ingredient_id` INT,
  `measurement_id` INT,
  `ingredient_quantity` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `steps` (
  `id` INT NOT NULL,
  `recipe_id` INT,
  `step_number` INT,
  `step_description` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_320867_initialize') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_320867_initialize') AS relationships;
DROP DATABASE `db_320867_initialize`;
UNINSTALL EXTENSION vsql_schematron;
