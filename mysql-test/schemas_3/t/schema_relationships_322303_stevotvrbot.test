INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 322303_stevotvrbot
--echo #
CREATE DATABASE `db_322303_stevotvrbot`;
USE `db_322303_stevotvrbot`;
CREATE TABLE `commands` (
  `id` INT,
  `command` VARCHAR(50),
  `arguments` TEXT,
  `description` TEXT,
  `level` INT
) CHARACTER SET latin1;
CREATE TABLE `platforms` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `url` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `schedule` (
  `id` INT,
  `day` INT,
  `hour` INT,
  `minute` INT,
  `length` INT,
  `game` TEXT,
  `platform` INT,
  `active` TINYINT
) CHARACTER SET latin1;
CREATE TABLE `settings` (
  `setting` VARCHAR(50) NOT NULL,
  `value` TEXT,
  PRIMARY KEY (`setting`)
) CHARACTER SET latin1;
CREATE TABLE `tips` (
  `id` INT,
  `time` TIMESTAMP NULL,
  `user` VARCHAR(50),
  `message` TEXT,
  `status` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(50),
  `accessToken` VARCHAR(50),
  `refreshToken` VARCHAR(50),
  `isAdmin` TINYINT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_322303_stevotvrbot') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_322303_stevotvrbot') AS relationships;
DROP DATABASE `db_322303_stevotvrbot`;
UNINSTALL EXTENSION vsql_schematron;
