CREATE TABLE `Hawks` (
  `name` VARCHAR(64),
  `gender` VARCHAR(64),
  `yearHatched` INT,
  `bandNumber` VARCHAR(64),
  `cdwc` VARCHAR(64),
  `bandFather` VARCHAR(64),
  `bandMother` VARCHAR(64),
  `owner` VARCHAR(64),
  `breeder` VARCHAR(64),
  `originCountry` VARCHAR(64),
  `originState` VARCHAR(64),
  `originLocality` VARCHAR(64),
  `disposition` VARCHAR(64),
  `yod` INT,
  `cod` VARCHAR(64),
  `comments` VARCHAR(64),
  `lastUpdate` DATETIME,
  `weight` INT,
  `seasons` INT,
  `rabbits` INT,
  `hares` INT,
  `squirrels` INT,
  `uplandFowl` INT,
  `waterfowl` INT,
  `miscCritters` INT,
  `bestSeason` INT,
  `overall` INT,
  `groupHunting` INT,
  `dogs` INT,
  `followPosition` INT,
  `speed` INT,
  `footing` INT,
  `persistence` INT,
  `huntingComments` VARCHAR(64),
  PRIMARY KEY (`bandNumber`)
) CHARACTER SET latin1;

