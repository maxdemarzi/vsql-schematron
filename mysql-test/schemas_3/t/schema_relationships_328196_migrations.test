INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328196_migrations
--echo #
CREATE DATABASE `db_328196_migrations`;
USE `db_328196_migrations`;

CREATE TABLE `__EFMigrationsHistory` (
  `MigrationId` VARCHAR(64),
  `ProductVersion` VARCHAR(64),
  PRIMARY KEY (`MigrationId`)
) CHARACTER SET latin1;

CREATE TABLE `Bodegas` (
  `Id` INT,
  `Ciudad` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Empleados` (
  `Id` INT,
  `Rut` VARCHAR(64),
  `Nombre` VARCHAR(64),
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `Productos` (
  `Id` INT,
  `Nombre` VARCHAR(64),
  `Umbral` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

CREATE TABLE `ProductosBodegas` (
  `ProductoId` INT,
  `BodegaId` INT,
  `Cantidad` INT,
  PRIMARY KEY (`ProductoId`, `BodegaId`)
) CHARACTER SET latin1;

CREATE TABLE `ProductosBodegasEmpleados` (
  `Id` INT,
  `ProductoId` INT,
  `BodegaId` INT,
  `EmpleadoId` INT,
  `Fecha` DATETIME,
  `Cantidad` INT,
  PRIMARY KEY (`Id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328196_migrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328196_migrations') AS relationships;
DROP DATABASE `db_328196_migrations`;
UNINSTALL EXTENSION vsql_schematron;
