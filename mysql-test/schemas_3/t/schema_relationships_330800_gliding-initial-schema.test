INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 330800_gliding-initial-schema
--echo #
CREATE DATABASE `db_330800_gliding_initial_schema`;
USE `db_330800_gliding_initial_schema`;
CREATE TABLE `address` (
  `id` INT NOT NULL,
  `type` INT NOT NULL,
  `addr1` VARCHAR(50),
  `addr2` VARCHAR(50),
  `addr3` VARCHAR(50),
  `addr4` VARCHAR(50),
  `city` VARCHAR(50),
  `postcode` VARCHAR(50),
  `country` VARCHAR(50),
  PRIMARY KEY (`id`, `type`)
) CHARACTER SET latin1;
CREATE TABLE `address_type` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `diag` (
  `id` INT NOT NULL,
  `create_time` TIMESTAMP NULL,
  `data` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_member` (
  `gm_group_id` INT,
  `gm_member_id` INT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_330800_gliding_initial_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_330800_gliding_initial_schema') AS relationships;
DROP DATABASE `db_330800_gliding_initial_schema`;
UNINSTALL EXTENSION vsql_schematron;
