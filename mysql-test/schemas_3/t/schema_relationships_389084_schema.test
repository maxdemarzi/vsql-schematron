INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 389084_schema
--echo #
CREATE DATABASE `db_389084_schema`;
USE `db_389084_schema`;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `movie` (
  `id` INT,
  `title` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `genre` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bridge_movie_genre` (
  `movie_id` INT,
  `genre_id` INT
) CHARACTER SET latin1;

CREATE TABLE `bridge_movie_user_rating` (
  `movie_id` INT,
  `user_id` INT,
  `rating` INT
) CHARACTER SET latin1;

CREATE TABLE `movie_list` (
  `id` INT,
  `movie_id` INT,
  `user_id` INT,
  `avg_rating` DECIMAL(10,2),
  `date_added` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_389084_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_389084_schema') AS relationships;
DROP DATABASE `db_389084_schema`;
UNINSTALL EXTENSION vsql_schematron;
