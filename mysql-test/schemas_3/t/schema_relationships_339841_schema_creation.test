INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 339841_schema_creation
--echo #
CREATE DATABASE `db_339841_schema_creation`;
USE `db_339841_schema_creation`;

CREATE TABLE `movie_basic` (
  `title` VARCHAR(64),
  `genre` VARCHAR(64),
  `release_year` INT,
  `director` VARCHAR(64),
  `studio` VARCHAR(64),
  `critic_rating` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `Genre` (
  `id` INT,
  `genre` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Director` (
  `id` INT,
  `dir_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Studio` (
  `id` INT,
  `studio_name` VARCHAR(64),
  `city` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Titles` (
  `id` INT,
  `title` VARCHAR(64),
  `genre_id` INT,
  `release_year` INT,
  `director_id` INT,
  `studio_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Critic_Rating` (
  `id` INT,
  `titles_id` INT,
  `critics_rating` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posters` (
  `titles_id` INT,
  `filename` VARCHAR(64),
  `resolution` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_339841_schema_creation') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_339841_schema_creation') AS relationships;
DROP DATABASE `db_339841_schema_creation`;
UNINSTALL EXTENSION vsql_schematron;
