INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 371018_6
--echo #
CREATE DATABASE `db_371018_6`;
USE `db_371018_6`;
CREATE TABLE `play` (
  `id` VARCHAR(50) NOT NULL,
  `theater` VARCHAR(50),
  `date` TIMESTAMP NULL,
  `reservationEndDate` TIMESTAMP NULL,
  `show` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `play_price` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `value` DECIMAL(10,2),
  `condition` TEXT,
  `play` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_371018_6') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_371018_6') AS relationships;
DROP DATABASE `db_371018_6`;
UNINSTALL EXTENSION vsql_schematron;
