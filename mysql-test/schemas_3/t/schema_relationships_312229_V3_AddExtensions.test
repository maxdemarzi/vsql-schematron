INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312229_V3__AddExtensions
--echo #
CREATE DATABASE `db_312229_V3_AddExtensions`;
USE `db_312229_V3_AddExtensions`;

CREATE TABLE `BUNDLE` (
  `ID` VARCHAR(64),
  `BUCKET_ID` VARCHAR(64),
  `BUNDLE_TYPE` VARCHAR(64),
  `GROUP_ID` VARCHAR(64),
  `ARTIFACT_ID` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `BUNDLE_VERSION` (
  `ID` VARCHAR(64),
  `BUNDLE_ID` VARCHAR(64),
  `VERSION` VARCHAR(64),
  `CREATED` DATETIME,
  `CREATED_BY` VARCHAR(64),
  `DESCRIPTION` VARCHAR(64),
  `SHA_256_HEX` VARCHAR(64),
  `SHA_256_SUPPLIED` INT,
  `CONTENT_SIZE` INT,
  `SYSTEM_API_VERSION` VARCHAR(64),
  `BUILD_TOOL` VARCHAR(64),
  `BUILD_FLAGS` VARCHAR(64),
  `BUILD_BRANCH` VARCHAR(64),
  `BUILD_TAG` VARCHAR(64),
  `BUILD_REVISION` VARCHAR(64),
  `BUILT` DATETIME,
  `BUILT_BY` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `BUNDLE_VERSION_DEPENDENCY` (
  `ID` VARCHAR(64),
  `BUNDLE_VERSION_ID` VARCHAR(64),
  `GROUP_ID` VARCHAR(64),
  `ARTIFACT_ID` VARCHAR(64),
  `VERSION` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EXTENSION` (
  `ID` VARCHAR(64),
  `BUNDLE_VERSION_ID` VARCHAR(64),
  `NAME` VARCHAR(64),
  `DISPLAY_NAME` VARCHAR(64),
  `TYPE` VARCHAR(64),
  `CONTENT` VARCHAR(64),
  `ADDITIONAL_DETAILS` VARCHAR(64),
  `HAS_ADDITIONAL_DETAILS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EXTENSION_PROVIDED_SERVICE_API` (
  `ID` VARCHAR(64),
  `EXTENSION_ID` VARCHAR(64),
  `CLASS_NAME` VARCHAR(64),
  `GROUP_ID` VARCHAR(64),
  `ARTIFACT_ID` VARCHAR(64),
  `VERSION` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EXTENSION_RESTRICTION` (
  `ID` VARCHAR(64),
  `EXTENSION_ID` VARCHAR(64),
  `REQUIRED_PERMISSION` VARCHAR(64),
  `EXPLANATION` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EXTENSION_TAG` (
  `EXTENSION_ID` VARCHAR(64),
  `TAG` VARCHAR(64),
  PRIMARY KEY (`EXTENSION_ID`, `TAG`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312229_V3_AddExtensions') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312229_V3_AddExtensions') AS relationships;
DROP DATABASE `db_312229_V3_AddExtensions`;
UNINSTALL EXTENSION vsql_schematron;
