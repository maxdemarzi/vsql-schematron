INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 374175_2018-12-28T173536-tables
--echo #
CREATE DATABASE `db_374175_2018_12_28T173536_tables`;
USE `db_374175_2018_12_28T173536_tables`;

CREATE TABLE `model` (
  `id` INT,
  `type` VARCHAR(64),
  `status` VARCHAR(64),
  `dateCreated` DATETIME,
  `dateModified` DATETIME,
  `createdBy` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `modelLink` (
  `id` INT,
  `link` INT
) CHARACTER SET latin1;

CREATE TABLE `action` (
  `id` INT,
  `action` VARCHAR(64),
  `result` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `question` (
  `id` INT,
  `question` VARCHAR(64),
  `answer` INT,
  `numComments` INT,
  `score` INT
) CHARACTER SET latin1;

CREATE TABLE `pool` (
  `id` INT,
  `name` VARCHAR(64),
  `numberOfQuestions` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `sessionId` VARCHAR(64),
  `role` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_374175_2018_12_28T173536_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_374175_2018_12_28T173536_tables') AS relationships;
DROP DATABASE `db_374175_2018_12_28T173536_tables`;
UNINSTALL EXTENSION vsql_schematron;
