INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328144_init
--echo #
CREATE DATABASE `db_328144_init`;
USE `db_328144_init`;

CREATE TABLE `app_settings` (
  `id` INT,
  `key` VARCHAR(64),
  `value` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `carts` (
  `id` INT,
  `product_id` INT,
  `user_id` INT,
  `quantity` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `cart_extras` (
  `extra_id` INT,
  `cart_id` INT
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `currencies` (
  `id` INT,
  `name` VARCHAR(64),
  `symbol` VARCHAR(64),
  `code` VARCHAR(64),
  `decimal_digits` INT,
  `rounding` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `custom_fields` (
  `id` INT,
  `name` VARCHAR(64),
  `type` VARCHAR(64),
  `values` VARCHAR(64),
  `disabled` INT,
  `required` INT,
  `in_table` INT,
  `bootstrap_column` INT,
  `order` INT,
  `custom_field_model` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `custom_field_values` (
  `id` INT,
  `value` VARCHAR(64),
  `view` VARCHAR(64),
  `custom_field_id` INT,
  `customizable_type` VARCHAR(64),
  `customizable_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `degradable` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `active` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `delivery_addresses` (
  `id` INT,
  `description` VARCHAR(64),
  `address` VARCHAR(64),
  `latitude` VARCHAR(64),
  `longitude` VARCHAR(64),
  `is_default` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `discountables` (
  `id` INT,
  `coupon_id` INT,
  `discountable_type` VARCHAR(64),
  `discountable_id` INT
) CHARACTER SET latin1;

CREATE TABLE `driver_stores` (
  `user_id` INT,
  `store_id` INT
) CHARACTER SET latin1;

CREATE TABLE `extra_groups` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `faqs` (
  `id` INT,
  `question` VARCHAR(64),
  `answer` VARCHAR(64),
  `faq_category_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `faq_categories` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `favorites` (
  `id` INT,
  `product_id` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `favorite_extras` (
  `extra_id` INT,
  `favorite_id` INT
) CHARACTER SET latin1;

CREATE TABLE `franchises` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `galleries` (
  `id` INT,
  `description` VARCHAR(64),
  `store_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `media` (
  `id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT,
  `collection_name` VARCHAR(64),
  `name` VARCHAR(64),
  `file_name` VARCHAR(64),
  `mime_type` VARCHAR(64),
  `disk` VARCHAR(64),
  `size` INT,
  `manipulations` VARCHAR(64),
  `custom_properties` VARCHAR(64),
  `responsive_images` VARCHAR(64),
  `order_column` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `model_has_permissions` (
  `permission_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `model_has_roles` (
  `role_id` INT,
  `model_type` VARCHAR(64),
  `model_id` INT
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `id` VARCHAR(64),
  `type` VARCHAR(64),
  `notifiable_type` VARCHAR(64),
  `notifiable_id` INT,
  `data` VARCHAR(64),
  `read_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `nutrition` (
  `id` INT,
  `name` VARCHAR(64),
  `quantity` INT,
  `product_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `order_statuses` (
  `id` INT,
  `status` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_degradale` (
  `id` INT,
  `degradable_id` INT,
  `product_id` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_reviews` (
  `id` INT,
  `review` VARCHAR(64),
  `rate` INT,
  `user_id` INT,
  `product_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `guard_name` VARCHAR(64),
  `default` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_has_permissions` (
  `permission_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `slides` (
  `id` INT,
  `order` INT,
  `text` VARCHAR(64),
  `button` VARCHAR(64),
  `text_position` VARCHAR(64),
  `text_color` VARCHAR(64),
  `button_color` VARCHAR(64),
  `background_color` VARCHAR(64),
  `indicator_color` VARCHAR(64),
  `image_fit` VARCHAR(64),
  `product_id` INT,
  `store_id` INT,
  `enabled` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `stores_categories` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `stores_image` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `stores_subcategories` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `subcategory_icon` VARCHAR(64),
  `category_id` INT,
  `position` VARCHAR(64),
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `store_franchises` (
  `franchise_id` INT,
  `store_id` INT
) CHARACTER SET latin1;

CREATE TABLE `store_reviews` (
  `id` INT,
  `review` VARCHAR(64),
  `rate` INT,
  `user_id` INT,
  `store_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `uploads` (
  `id` INT,
  `uuid` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `password` VARCHAR(64),
  `api_token` VARCHAR(64),
  `device_token` VARCHAR(64),
  `dateofbirth` DATETIME,
  `gender` VARCHAR(64),
  `agreement` VARCHAR(64),
  `latitude` VARCHAR(64),
  `longitude` VARCHAR(64),
  `stripe_id` VARCHAR(64),
  `card_brand` VARCHAR(64),
  `card_last_four` VARCHAR(64),
  `trial_ends_at` DATETIME,
  `braintree_id` VARCHAR(64),
  `paypal_email` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user_friends` (
  `id` INT,
  `user_id` INT,
  `friend_id` INT,
  `is_user_accept` INT,
  `is_friend_accept` INT,
  `created_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_stores` (
  `user_id` INT,
  `store_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328144_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328144_init') AS relationships;
DROP DATABASE `db_328144_init`;
UNINSTALL EXTENSION vsql_schematron;
