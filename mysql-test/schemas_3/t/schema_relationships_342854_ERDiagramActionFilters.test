INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 342854_ERDiagramActionFilters
--echo #
CREATE DATABASE `db_342854_ERDiagramActionFilters`;
USE `db_342854_ERDiagramActionFilters`;

CREATE TABLE `ACTIONLISTS` (
  `LIST_ID` INT,
  `LISTNAME` VARCHAR(64),
  `WEIGHT` INT,
  PRIMARY KEY (`LIST_ID`)
) CHARACTER SET latin1;

CREATE TABLE `FILTER_CONTEXT` (
  `LIST_ID` INT,
  `CONTEXT_NAME` VARCHAR(64),
  `CONTEXT_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `FILTER_STATUS` (
  `LIST_ID` INT,
  `STATUS_NAME` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `FILTER_TOPIC` (
  `LIST_ID` INT,
  `TOPIC_NAME` VARCHAR(64),
  `TOPIC_ID` INT
) CHARACTER SET latin1;

CREATE TABLE `SORT` (
  `LIST_ID` INT,
  `CRITERIA` INT,
  `DIRECTION` INT,
  `WEIGHT` INT,
  PRIMARY KEY (`LIST_ID`, `CRITERIA`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_342854_ERDiagramActionFilters') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_342854_ERDiagramActionFilters') AS relationships;
DROP DATABASE `db_342854_ERDiagramActionFilters`;
UNINSTALL EXTENSION vsql_schematron;
