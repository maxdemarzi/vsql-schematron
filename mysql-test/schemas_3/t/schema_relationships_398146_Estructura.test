INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 398146_Estructura
--echo #
CREATE DATABASE `db_398146_Estructura`;
USE `db_398146_Estructura`;

CREATE TABLE `person` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `ci` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `account` INT,
  `balance` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `account` (
  `person_id` INT,
  `account` INT,
  `description` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `moves` (
  `origin_id` INT,
  `destiny_id` INT,
  `amount` DECIMAL(10,2),
  `description` VARCHAR(64),
  `type` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_398146_Estructura') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_398146_Estructura') AS relationships;
DROP DATABASE `db_398146_Estructura`;
UNINSTALL EXTENSION vsql_schematron;
