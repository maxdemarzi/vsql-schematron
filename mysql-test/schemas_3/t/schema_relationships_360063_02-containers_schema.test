INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360063_02-containers.schema
--echo #
CREATE DATABASE `db_360063_02_containers_schema`;
USE `db_360063_02_containers_schema`;
CREATE TABLE `containers` (
  `id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `container_members` (
  `container_id` VARCHAR(50) NOT NULL,
  `member` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`container_id`, `member`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360063_02_containers_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360063_02_containers_schema') AS relationships;
DROP DATABASE `db_360063_02_containers_schema`;
UNINSTALL EXTENSION vsql_schematron;
