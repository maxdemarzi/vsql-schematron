INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 314226_schema
--echo #
CREATE DATABASE `db_314226_schema`;
USE `db_314226_schema`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` TEXT,
  `password` TEXT,
  `role` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `questions` (
  `id` INT NOT NULL,
  `question` TEXT,
  `content` TEXT,
  `authorName` TEXT,
  `categories` TEXT,
  `datePosted` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answers` (
  `id` INT NOT NULL,
  `questionId` INT,
  `content` TEXT,
  `role` TEXT,
  `authorName` TEXT,
  `datePosted` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_314226_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_314226_schema') AS relationships;
DROP DATABASE `db_314226_schema`;
UNINSTALL EXTENSION vsql_schematron;
