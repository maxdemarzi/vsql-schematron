INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395140_database_schema_sqlite
--echo #
CREATE DATABASE `db_395140_database_schema_sqlite`;
USE `db_395140_database_schema_sqlite`;
CREATE TABLE `experiments` (
  `id` INT NOT NULL,
  `experiment_date` DATE,
  `experiment_time` TIME,
  `sampling_rate` DOUBLE,
  `input_file` VARCHAR(50),
  `configurations` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `metrics` (
  `id` INT NOT NULL,
  `experiment_id` INT,
  `model` VARCHAR(50),
  `sampler` VARCHAR(50),
  `mean_square_error` DOUBLE,
  `mean_average_error` DOUBLE,
  `deviation` DOUBLE,
  `coefficient_of_determination` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `samples` (
  `id` INT NOT NULL,
  `experiment_id` INT,
  `sampler` VARCHAR(50),
  `list` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `model_predictions` (
  `id` INT NOT NULL,
  `experiment_id` INT,
  `sampler` VARCHAR(50),
  `model` VARCHAR(50),
  `list` BLOB,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395140_database_schema_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395140_database_schema_sqlite') AS relationships;
DROP DATABASE `db_395140_database_schema_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
