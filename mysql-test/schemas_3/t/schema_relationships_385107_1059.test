INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 385107_1059
--echo #
CREATE DATABASE `db_385107_1059`;
USE `db_385107_1059`;

CREATE TABLE `p2` (
  `b` INT,
  `a` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_385107_1059') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_385107_1059') AS relationships;
DROP DATABASE `db_385107_1059`;
UNINSTALL EXTENSION vsql_schematron;
