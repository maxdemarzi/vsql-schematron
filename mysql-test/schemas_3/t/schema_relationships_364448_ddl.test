INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364448_ddl
--echo #
CREATE DATABASE `db_364448_ddl`;
USE `db_364448_ddl`;

CREATE TABLE `author` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `date_of_birth` DATETIME,
  `year_of_birth` INT,
  `distinguished` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book_store` (
  `name` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `language` (
  `id` INT,
  `cd` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book` (
  `id` INT,
  `author_id` INT,
  `title` VARCHAR(255),
  `published_in` INT,
  `language_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `book_to_book_store` (
  `name` VARCHAR(255),
  `book_id` INT,
  `stock` INT,
  PRIMARY KEY (`name`, `book_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364448_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364448_ddl') AS relationships;
DROP DATABASE `db_364448_ddl`;
UNINSTALL EXTENSION vsql_schematron;
