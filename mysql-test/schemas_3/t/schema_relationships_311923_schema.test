INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 311923_schema
--echo #
CREATE DATABASE `db_311923_schema`;
USE `db_311923_schema`;

CREATE TABLE `attendance` (
  `id` INT,
  `student_id` INT,
  `subject_id` INT,
  `visit` INT,
  `lateness` INT,
  `truancy` INT,
  `disease` INT,
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `classrooms` (
  `id` INT,
  `begin_year` DATETIME,
  `letter` VARCHAR(64),
  `is_graduated` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `homeworks` (
  `id` INT,
  `classroom_id` INT,
  `subject_id` INT,
  `text` VARCHAR(64),
  `until_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `marks` (
  `id` INT,
  `student_id` INT,
  `teacher_id` INT,
  `subject_id` INT,
  `mark` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `user_id` INT,
  `classroom_id` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `subjects` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `teachers` (
  `teacher_id` INT,
  PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_311923_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_311923_schema') AS relationships;
DROP DATABASE `db_311923_schema`;
UNINSTALL EXTENSION vsql_schematron;
