INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 392615_binapile_bpqc-data_and_str_from_local
--echo #
CREATE DATABASE `db_392615_binapile_bpqc_data_and_str_from_local`;
USE `db_392615_binapile_bpqc_data_and_str_from_local`;

CREATE TABLE `cementintake` (
  `id` INT,
  `display_date` DATETIME,
  `date_created` DATETIME,
  `silo1` DECIMAL(10,2),
  `silo2` DECIMAL(10,2),
  `silo3` DECIMAL(10,2),
  `summary_status` VARCHAR(64),
  `plant_id` INT,
  `is_holiday` INT
) CHARACTER SET latin1;

CREATE TABLE `driver` (
  `id` INT,
  `name` VARCHAR(64),
  `remark` VARCHAR(64),
  `employee_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `grade` (
  `id` INT,
  `name` VARCHAR(64),
  `charac_strength28` VARCHAR(64),
  `cement_type` VARCHAR(64),
  `specified_slump` VARCHAR(64),
  `coarse_agg_type` VARCHAR(64),
  `fine_agg_type` VARCHAR(64),
  `admixture` VARCHAR(64),
  `mix_design_for_cal` DECIMAL(10,2),
  `deleted` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `location` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `rate_prefix` VARCHAR(64),
  `rate_number` DECIMAL(10,2),
  `deleted` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `materialaudit` (
  `id` INT,
  `plant_id` INT,
  `volume` DECIMAL(10,2),
  `material_need` DECIMAL(10,2),
  `actual_use` DECIMAL(10,2),
  `difference_kg` DECIMAL(10,2),
  `difference_percent` DECIMAL(10,2),
  `date_calculated` DATETIME,
  `display_date` DATETIME,
  `is_holiday` INT
) CHARACTER SET latin1;

CREATE TABLE `materialending` (
  `id` INT,
  `display_date` DATETIME,
  `date_created` DATETIME,
  `silo1` DECIMAL(10,2),
  `silo2` DECIMAL(10,2),
  `silo3` DECIMAL(10,2),
  `summary_status` VARCHAR(64),
  `plant_id` INT,
  `is_holiday` INT
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `date_created` DATETIME,
  `deleted` INT,
  `location_id` INT
) CHARACTER SET latin1;

CREATE TABLE `truck` (
  `id` INT,
  `truck_no` VARCHAR(64),
  `remark` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `truckexpense` (
  `id` INT,
  `date_reported` DATETIME,
  `expenditure` DECIMAL(10,2),
  `reason` VARCHAR(64),
  `truck_id` INT
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(64),
  `auth_key` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `password_reset_token` VARCHAR(64),
  `email` VARCHAR(64),
  `status` INT,
  `role` INT,
  `created_at` INT,
  `updated_at` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_392615_binapile_bpqc_data_and_str_from_local') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_392615_binapile_bpqc_data_and_str_from_local') AS relationships;
DROP DATABASE `db_392615_binapile_bpqc_data_and_str_from_local`;
UNINSTALL EXTENSION vsql_schematron;
