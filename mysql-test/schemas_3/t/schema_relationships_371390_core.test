INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 371390_core
--echo #
CREATE DATABASE `db_371390_core`;
USE `db_371390_core`;

CREATE TABLE `activity` (
  `id` VARCHAR(64),
  `started_at_time` DATETIME,
  `ended_at_time` DATETIME,
  `was_informed_by` VARCHAR(64),
  `was_associated_with` VARCHAR(64),
  `used` VARCHAR(64),
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `agent` (
  `id` VARCHAR(64),
  `acted_on_behalf_of` VARCHAR(64),
  `was_informed_by` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_371390_core') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_371390_core') AS relationships;
DROP DATABASE `db_371390_core`;
UNINSTALL EXTENSION vsql_schematron;
