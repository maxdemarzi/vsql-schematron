INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 337430_tournament
--echo #
CREATE DATABASE `db_337430_tournament`;
USE `db_337430_tournament`;

CREATE TABLE `players` (
  `id` INT,
  `full_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `matches` (
  `id` INT,
  `winner_id` INT,
  `loser_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_337430_tournament') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_337430_tournament') AS relationships;
DROP DATABASE `db_337430_tournament`;
UNINSTALL EXTENSION vsql_schematron;
