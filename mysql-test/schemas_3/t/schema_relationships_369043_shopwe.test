INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 369043_shopwe
--echo #
CREATE DATABASE `db_369043_shopwe`;
USE `db_369043_shopwe`;

CREATE TABLE `brands` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `categories` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `colors` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `detail_order` (
  `id` INT,
  `order_id` INT,
  `product_id` INT,
  `size` VARCHAR(255),
  `color` VARCHAR(255),
  `price` INT,
  `quantity` INT,
  `sub_total` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `orders` (
  `id` INT,
  `user_id` INT,
  `tracking_number` VARCHAR(255),
  `address` VARCHAR(255),
  `payment_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `payments` (
  `id` INT,
  `name` VARCHAR(255),
  `image` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `brand_id` INT,
  `name` VARCHAR(255),
  `category_id` INT,
  `categories` VARCHAR(255),
  `colors` VARCHAR(255),
  `sizes` VARCHAR(255),
  `price` INT,
  `image` VARCHAR(255),
  `quantity` INT,
  `description` VARCHAR(255),
  `rating` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `sizes` (
  `id` INT,
  `name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(255),
  `full_name` VARCHAR(255),
  `birth` DATETIME,
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  `phone` VARCHAR(255),
  `image` VARCHAR(255),
  `address` VARCHAR(255),
  `address_active` INT,
  `role` INT,
  `access_key` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_369043_shopwe') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_369043_shopwe') AS relationships;
DROP DATABASE `db_369043_shopwe`;
UNINSTALL EXTENSION vsql_schematron;
