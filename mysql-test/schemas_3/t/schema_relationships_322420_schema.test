INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 322420_schema
--echo #
CREATE DATABASE `db_322420_schema`;
USE `db_322420_schema`;

CREATE TABLE `offers` (
  `id` INT,
  `owner_id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `creation_timestamp` DATETIME,
  `is_archived` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `offers_tags` (
  `offer_id` INT,
  `tag_name` VARCHAR(64),
  PRIMARY KEY (`offer_id`, `tag_name`)
) CHARACTER SET latin1;

CREATE TABLE `tiers` (
  `id` INT,
  `offer_id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `price` DECIMAL(10,2),
  `delivery_time` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `thumbnails` (
  `id` INT,
  `offer_id` INT,
  `url` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_322420_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_322420_schema') AS relationships;
DROP DATABASE `db_322420_schema`;
UNINSTALL EXTENSION vsql_schematron;
