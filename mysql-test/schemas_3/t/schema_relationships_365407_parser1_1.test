INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 365407_parser1-1
--echo #
CREATE DATABASE `db_365407_parser1_1`;
USE `db_365407_parser1_1`;

CREATE TABLE `t1` (
  `a` VARCHAR(64),
  `b` VARCHAR(64),
  PRIMARY KEY (`a`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_365407_parser1_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_365407_parser1_1') AS relationships;
DROP DATABASE `db_365407_parser1_1`;
UNINSTALL EXTENSION vsql_schematron;
