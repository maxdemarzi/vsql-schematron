INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 324231_sql
--echo #
CREATE DATABASE `db_324231_sql`;
USE `db_324231_sql`;

CREATE TABLE `kandidat` (
  `kandidat_id` INT,
  `fornavn` VARCHAR(64),
  `etternavn` VARCHAR(64),
  `telefon` INT,
  `epost` VARCHAR(64),
  PRIMARY KEY (`kandidat_id`)
) CHARACTER SET latin1;

CREATE TABLE `bedrift` (
  `bedrift_id` INT,
  `navn` VARCHAR(64),
  `telefon` INT,
  `epost` VARCHAR(64),
  PRIMARY KEY (`bedrift_id`)
) CHARACTER SET latin1;

CREATE TABLE `kvalifikasjon` (
  `kvalifikasjon_id` INT,
  `beskrivelse` VARCHAR(64),
  PRIMARY KEY (`kvalifikasjon_id`)
) CHARACTER SET latin1;

CREATE TABLE `kvalkand` (
  `kandidat_id` INT,
  `kvalifikasjon_id` INT,
  PRIMARY KEY (`kandidat_id`, `kvalifikasjon_id`)
) CHARACTER SET latin1;

CREATE TABLE `oppdrag` (
  `oppdrag_id` INT,
  `bedrift_id` INT,
  `kandidat_id` INT,
  `kvalifikasjon_id` INT,
  `bedriftnavn` VARCHAR(64),
  `datostart` DATETIME,
  `datoslutt` DATETIME,
  PRIMARY KEY (`oppdrag_id`)
) CHARACTER SET latin1;

CREATE TABLE `jobbhistorikk` (
  `oppdrag_id` INT,
  `kandidat_id` INT,
  `datostart` DATETIME,
  `datoslutt` DATETIME,
  PRIMARY KEY (`oppdrag_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_324231_sql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_324231_sql') AS relationships;
DROP DATABASE `db_324231_sql`;
UNINSTALL EXTENSION vsql_schematron;
