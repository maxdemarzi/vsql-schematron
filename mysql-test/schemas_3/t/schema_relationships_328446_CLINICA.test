INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328446_CLINICA
--echo #
CREATE DATABASE `db_328446_CLINICA`;
USE `db_328446_CLINICA`;

CREATE TABLE `TB_ENDERECO` (
  `ID_ENDERECO` INT,
  `RUA_ENDERECO` VARCHAR(64),
  `NUMERO_ENDERECO` VARCHAR(64),
  `ESTADO_ENDERECO` VARCHAR(64),
  `PAIS_ENDERECO` VARCHAR(64),
  PRIMARY KEY (`ID_ENDERECO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_FUNCIONARIO` (
  `ID_FUNCIONARIO` INT,
  `NOME_FUNCIONARIO` VARCHAR(64),
  `GENERO_FUNCIONARIO` VARCHAR(64),
  `TIPO_SANGUINEO_FUNCIONARIO` VARCHAR(64),
  `DATA_NASCIMENTO_FUNCIONARIO` DATETIME,
  `ID_ENDERECO` INT,
  PRIMARY KEY (`ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_AFASTADO` (
  `ID_FUNCIONARIO` INT,
  `DATA_AFASTADO` DATETIME,
  PRIMARY KEY (`ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MEDICO` (
  `ID_FUNCIONARIO` INT,
  `QUALIFICACAO_MEDICO` VARCHAR(64),
  PRIMARY KEY (`ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_ENFERMEIRO` (
  `ID_FUNCIONARIO` INT,
  `NUMERO_PACIENTES_ENFERMEIRO` INT,
  PRIMARY KEY (`ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_DEPARTAMENTO` (
  `ID_DEPARTAMENTO` INT,
  `NOME_DEPARTAMENTO` VARCHAR(64),
  `CHEFE_DEPARTAMENTO` VARCHAR(64),
  `ID_ENDERECO` INT,
  PRIMARY KEY (`ID_DEPARTAMENTO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_TRABALHOU` (
  `ID_DEPARTAMENTO` INT,
  `ID_FUNCIONARIO` INT,
  PRIMARY KEY (`ID_DEPARTAMENTO`, `ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_ATIVO` (
  `ID_FUNCIONARIO` INT,
  `DESDE_ATIVO` DATETIME,
  `ID_DEPARTAMENTO` INT,
  PRIMARY KEY (`ID_FUNCIONARIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_QUARTO` (
  `ID_QUARTO` INT,
  `CUSTO_QUARTO` DECIMAL(10,2),
  `TIPO_QUARTO` VARCHAR(64),
  `ID_ENDERECO` INT,
  PRIMARY KEY (`ID_QUARTO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_LABORATORIO` (
  `ID_LABORATORIO` INT,
  `NOME_LABORATORIO` VARCHAR(64),
  `TELEFONE_LABORATORIO` VARCHAR(64),
  `EMAIL_LABORATORIO` VARCHAR(64),
  `SITE_LABORATORIO` VARCHAR(64),
  PRIMARY KEY (`ID_LABORATORIO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_TESTE` (
  `ID_TESTE` INT,
  `NOME_TESTE` VARCHAR(64),
  `CUSTO_TESTE` DECIMAL(10,2),
  `ID_LABORATORIO` INT,
  PRIMARY KEY (`ID_TESTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_MEDICAMENTO` (
  `ID_MEDICAMENTO` INT,
  `NOME_MEDICAMENTO` VARCHAR(64),
  `CUSTO_MEDICAMENTO` DECIMAL(10,2),
  `ID_LABORATORIO` INT,
  PRIMARY KEY (`ID_MEDICAMENTO`)
) CHARACTER SET latin1;

CREATE TABLE `TB_PACIENTE` (
  `ID_PACIENTE` INT,
  `NOME_PACIENTE` VARCHAR(64),
  `GENERO_PACIENTE` VARCHAR(64),
  `TIPO_SANGUINEO_PACIENTE` VARCHAR(64),
  `DATA_NASCIMENTO_PACIENTE` DATETIME,
  `ID_FUNCIONARIO` INT,
  PRIMARY KEY (`ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_INTERNADO` (
  `ID_PACIENTE` INT,
  `CHEGADA_INTERNADO` DATETIME,
  `LIBERACAO_INTERNADO` DATETIME,
  `DOENCA_INTERNADO` VARCHAR(64),
  `ID_FUNCIONARIO` INT,
  PRIMARY KEY (`ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_RELACAO` (
  `ID_QUARTO` INT,
  `ID_PACIENTE` INT,
  `CHEGADA` DATETIME,
  PRIMARY KEY (`ID_QUARTO`, `ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_CONTATO` (
  `NOME_CONTATO` VARCHAR(64),
  `ID_PACIENTE` INT,
  `RELACAO_CONTATO` VARCHAR(64),
  `TELEFONE_CONTATO` VARCHAR(64),
  PRIMARY KEY (`NOME_CONTATO`, `ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_AMBULATORIO` (
  `ID_PACIENTE` INT,
  `CHEGADA_AMBULATORIO` DATETIME,
  `DOENCA` VARCHAR(64),
  PRIMARY KEY (`ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_USA` (
  `ID_MEDICAMENTO` INT,
  `ID_PACIENTE` INT,
  `QUANTIDADE_USA` INT,
  `DESDE_USA` DATETIME,
  PRIMARY KEY (`ID_MEDICAMENTO`, `ID_PACIENTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_FEZ` (
  `ID_PACIENTE` INT,
  `ID_TESTE` INT,
  `TESTE_DATA` DATETIME,
  PRIMARY KEY (`ID_PACIENTE`, `ID_TESTE`)
) CHARACTER SET latin1;

CREATE TABLE `TB_CONTA` (
  `DATA_CONTA` DATETIME,
  `ID_PACIENTE` INT,
  `CUSTO_TESTE_CONTA` DECIMAL(10,2),
  `CUSTO_QUARTO_CONTA` DECIMAL(10,2),
  `CUSTO_MEDICAMENTO_CONTA` DECIMAL(10,2),
  `CUSTO_OUTROS_CONTA` DECIMAL(10,2),
  PRIMARY KEY (`DATA_CONTA`, `ID_PACIENTE`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328446_CLINICA') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328446_CLINICA') AS relationships;
DROP DATABASE `db_328446_CLINICA`;
UNINSTALL EXTENSION vsql_schematron;
