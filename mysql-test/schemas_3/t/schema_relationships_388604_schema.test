INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 388604_schema
--echo #
CREATE DATABASE `db_388604_schema`;
USE `db_388604_schema`;

CREATE TABLE `Games` (
  `gameID` INT,
  `gameName` VARCHAR(64),
  `gameType` VARCHAR(64),
  `maxPlayers` INT,
  PRIMARY KEY (`gameID`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `userID` INT,
  `isOnline` BOOL,
  `userName` VARCHAR(64),
  `avatarURL` VARCHAR(64),
  PRIMARY KEY (`userID`)
) CHARACTER SET latin1;

CREATE TABLE `Friends` (
  `userID` INT,
  `friendID` INT,
  PRIMARY KEY (`userID`, `friendID`)
) CHARACTER SET latin1;

CREATE TABLE `Matches` (
  `instanceID` INT,
  `userID` INT,
  `gameID` INT,
  PRIMARY KEY (`instanceID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_388604_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_388604_schema') AS relationships;
DROP DATABASE `db_388604_schema`;
UNINSTALL EXTENSION vsql_schematron;
