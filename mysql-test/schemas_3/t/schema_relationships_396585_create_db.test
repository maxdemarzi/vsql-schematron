INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 396585_create_db
--echo #
CREATE DATABASE `db_396585_create_db`;
USE `db_396585_create_db`;

CREATE TABLE `danceTable` (
  `uid` INT,
  `name` VARCHAR(255),
  `danceTime` DATETIME,
  `venue` VARCHAR(255),
  `attendanceCount` INT,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `friendlyStatuses` (
  `uid` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `uid` INT,
  `firstName` VARCHAR(255),
  `lastName` VARCHAR(255),
  `email` VARCHAR(255),
  `isAdmin` INT,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `superAdmins` (
  `uid` INT,
  `firstName` VARCHAR(255),
  `lastName` VARCHAR(255),
  `email` VARCHAR(255),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `studentStatuses` (
  `uid` INT,
  `danceUID` INT,
  `userUID` INT,
  `status` INT,
  `lastUpdate` DATETIME,
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_396585_create_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_396585_create_db') AS relationships;
DROP DATABASE `db_396585_create_db`;
UNINSTALL EXTENSION vsql_schematron;
