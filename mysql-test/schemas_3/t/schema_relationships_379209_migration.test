INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379209_migration
--echo #
CREATE DATABASE `db_379209_migration`;
USE `db_379209_migration`;
CREATE TABLE `ProductType` (
  `id` INT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `productTypeId` INT,
  `placeId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `productId` INT,
  `quantity` DECIMAL(10,2),
  `unit` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Place` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379209_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379209_migration') AS relationships;
DROP DATABASE `db_379209_migration`;
UNINSTALL EXTENSION vsql_schematron;
