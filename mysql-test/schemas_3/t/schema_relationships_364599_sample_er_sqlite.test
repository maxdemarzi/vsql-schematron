INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364599_sample-er-sqlite
--echo #
CREATE DATABASE `db_364599_sample_er_sqlite`;
USE `db_364599_sample_er_sqlite`;

CREATE TABLE `tree` (
  `tree_id` INT,
  `head_node_id` INT,
  PRIMARY KEY (`tree_id`)
) CHARACTER SET latin1;

CREATE TABLE `tree_node` (
  `tree_node_id` INT,
  `value` INT,
  `parent_id` INT,
  PRIMARY KEY (`tree_node_id`)
) CHARACTER SET latin1;

CREATE TABLE `user_permission` (
  `user_permission_id` INT,
  `user_id` INT,
  `permission_id` INT,
  PRIMARY KEY (`user_permission_id`)
) CHARACTER SET latin1;

CREATE TABLE `follows` (
  `follows_id` INT,
  `follower_id` INT,
  `follow_id` INT,
  PRIMARY KEY (`follows_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364599_sample_er_sqlite') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364599_sample_er_sqlite') AS relationships;
DROP DATABASE `db_364599_sample_er_sqlite`;
UNINSTALL EXTENSION vsql_schematron;
