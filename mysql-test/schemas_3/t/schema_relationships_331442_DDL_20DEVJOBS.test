INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331442_DDL%20DEVJOBS
--echo #
CREATE DATABASE `db_331442_DDL_20DEVJOBS`;
USE `db_331442_DDL_20DEVJOBS`;

CREATE TABLE `DESENVOLVEDORES` (
  `ID` INT,
  `NOME_COMPLETO` VARCHAR(64),
  `CPF` VARCHAR(64),
  `DATA_NASCTO` DATETIME,
  `GENERO` VARCHAR(64),
  `ESTADO_CIVIL` VARCHAR(64),
  `NRO_FILHOS` INT,
  `NACIONALIDADE` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `HABILIDADES` (
  `ID` INT,
  `ID_DEV` INT,
  `TITULO` VARCHAR(64),
  `DESCRICAO` VARCHAR(64),
  `TEMPO_EXPERIENCIA` INT,
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMPRESAS` (
  `ID` INT,
  `NOME_EMP` VARCHAR(64),
  `SEDE` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ENDERECOS` (
  `ID` INT,
  `ID_ENDERECO` INT,
  `LOGRADOURO` VARCHAR(64),
  `ESTADO` VARCHAR(64),
  `CIDADE` VARCHAR(64),
  `CEP` VARCHAR(64),
  `CIDADE_NASCIMENTO` VARCHAR(64),
  `ESTADO_NASCIMENTO` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTAS` (
  `ID` INT,
  `ID_ACC` INT,
  `EMAIL` VARCHAR(64),
  `PASSWRD` VARCHAR(64),
  `ACC_STATUS` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `RECUPERAR_CONTAS` (
  `ID` INT,
  `CODIGO` INT,
  `ID_ACC` INT,
  `STATUS_RECUPERACAO` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `VAGAS` (
  `ID` INT,
  `ID_EMPRESA` INT,
  `TITULO` VARCHAR(64),
  `DESCRICAO` VARCHAR(64),
  `MEDIA_LINK` VARCHAR(64),
  `MIN_SALARIO` DECIMAL(10,2),
  `MAX_SALARIO` DECIMAL(10,2),
  `DATA_INICIO` DATETIME,
  `DATA_FIM` DATETIME,
  `STATUS_VAGA` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CANDIDATURAS` (
  `ID` INT,
  `ID_VAGA` INT,
  `ID_DESENVOLVEDOR` INT,
  `DATA_CANDIDATURA` DATETIME,
  `STATUS_CANDIDATURA` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CONTATO_CANDIDATURAS` (
  `ID` INT,
  `ID_CANDIDATURA` INT,
  `ID_EMPRESA` INT,
  `ID_DESENVOLVEDOR` INT,
  `TITULO_MENSAGEM` VARCHAR(64),
  `MENSAGEM` VARCHAR(64),
  `CREATED_AT` DATETIME,
  `UPDATED_AT` DATETIME,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331442_DDL_20DEVJOBS') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331442_DDL_20DEVJOBS') AS relationships;
DROP DATABASE `db_331442_DDL_20DEVJOBS`;
UNINSTALL EXTENSION vsql_schematron;
