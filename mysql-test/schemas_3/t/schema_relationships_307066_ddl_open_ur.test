INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307066_ddl_open_ur
--echo #
CREATE DATABASE `db_307066_ddl_open_ur`;
USE `db_307066_ddl_open_ur`;

CREATE TABLE `hibernate_sequences` (
  `sequence_name` VARCHAR(64),
  `sequence_next_hi_value` INT
) CHARACTER SET latin1;

CREATE TABLE `APPLICATION` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `APPLICATION_NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ADDRESS` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `CARE_OF` VARCHAR(64),
  `CITY` VARCHAR(64),
  `COUNTRY_CODE` VARCHAR(64),
  `PO_BOX` VARCHAR(64),
  `POST_CODE` VARCHAR(64),
  `STREET` VARCHAR(64),
  `STREET_NO` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_STRUCTURE_BASE` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `NUMBER` VARCHAR(64),
  `STATUS` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSON` (
  `ID` INT,
  `EMAIL` VARCHAR(64),
  `FAX_NO` VARCHAR(64),
  `FIRSTNAME` VARCHAR(64),
  `GENDER` VARCHAR(64),
  `HOME_EMAIL` VARCHAR(64),
  `HOME_PHONE_NO` VARCHAR(64),
  `LASTNAME` VARCHAR(64),
  `MOBILE_NO` VARCHAR(64),
  `PHONE_NO` VARCHAR(64),
  `TITLE` VARCHAR(64),
  `HOME_ADDRESS_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERSONS_APPS` (
  `ID_PERSON` INT,
  `ID_APPLICATION` INT,
  PRIMARY KEY (`ID_PERSON`, `ID_APPLICATION`)
) CHARACTER SET latin1;

CREATE TABLE `TECHNICAL_USER` (
  `ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `USER_ACCOUNT` (
  `ID` INT,
  `USER_ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `USERNAME` VARCHAR(64),
  `PASSWORD` VARCHAR(64),
  `SALT` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ORGANIZATIONAL_UNIT` (
  `ID` INT,
  `DESCRIPTION` VARCHAR(64),
  `EMAIL` VARCHAR(64),
  `NAME` VARCHAR(64),
  `SHORT_NAME` VARCHAR(64),
  `ADDRESS_ID` INT,
  `ROOT_OU_ID` INT,
  `SUPER_OU_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ORG_UNIT_MEMBER` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `ORG_UNIT_ID` INT,
  `PERSON_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PERMISSION` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `PERMISSION_TEXT` VARCHAR(64),
  `PERMISSION_SCOPE` VARCHAR(64),
  `APPLICATION_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `TECH_USERS_PERMISSIONS` (
  `ID_TECH_USER` INT,
  `ID_PERMISSION` INT,
  PRIMARY KEY (`ID_TECH_USER`, `ID_PERMISSION`)
) CHARACTER SET latin1;

CREATE TABLE `ROLE` (
  `ID` INT,
  `CREATED` DATETIME,
  `MODIFIED` DATETIME,
  `DESCRIPTION` VARCHAR(64),
  `ROLE_NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `ROLES_PERMISSIONS` (
  `ID_ROLE` INT,
  `ID_PERMISSION` INT,
  PRIMARY KEY (`ID_ROLE`, `ID_PERMISSION`)
) CHARACTER SET latin1;

CREATE TABLE `ROLES_MEMBERS` (
  `ID_MEMBER` INT,
  `ID_ROLE` INT,
  PRIMARY KEY (`ID_MEMBER`, `ID_ROLE`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307066_ddl_open_ur') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307066_ddl_open_ur') AS relationships;
DROP DATABASE `db_307066_ddl_open_ur`;
UNINSTALL EXTENSION vsql_schematron;
