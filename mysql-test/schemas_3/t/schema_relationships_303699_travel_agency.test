INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 303699_travel_agency
--echo #
CREATE DATABASE `db_303699_travel_agency`;
USE `db_303699_travel_agency`;

CREATE TABLE `company` (
  `mail` VARCHAR(64),
  `pass` VARCHAR(64),
  `comp_name` VARCHAR(64),
  `representative_fame` VARCHAR(64),
  `representative_lname` VARCHAR(64),
  `Tele_number` INT,
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `street` VARCHAR(64),
  `address` VARCHAR(64),
  PRIMARY KEY (`mail`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `pass` VARCHAR(64),
  `user_fname` VARCHAR(64),
  `user_lname` VARCHAR(64),
  `mail` VARCHAR(64),
  `tele_number` INT,
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `boy` BOOL,
  `BD` DATETIME,
  PRIMARY KEY (`mail`)
) CHARACTER SET latin1;

CREATE TABLE `Trips` (
  `trip_id` INT,
  `mail` VARCHAR(64),
  `price` INT,
  `days` INT,
  `hours` INT,
  `descri` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `visited_place` VARCHAR(64),
  PRIMARY KEY (`trip_id`)
) CHARACTER SET latin1;

CREATE TABLE `Trips_photos` (
  `trip_id` INT,
  `photo` VARCHAR(64),
  `photo_id` INT,
  PRIMARY KEY (`trip_id`, `photo_id`)
) CHARACTER SET latin1;

CREATE TABLE `Reservation` (
  `mail` VARCHAR(64),
  `trip_id` INT,
  `D` DATETIME,
  `done` BOOL,
  `cancelled` BOOL,
  PRIMARY KEY (`mail`, `trip_id`)
) CHARACTER SET latin1;

CREATE TABLE `rates` (
  `user_mail` VARCHAR(64),
  `comp_mail` VARCHAR(64),
  `stars` INT,
  `descri` VARCHAR(64),
  PRIMARY KEY (`user_mail`, `comp_mail`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_303699_travel_agency') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_303699_travel_agency') AS relationships;
DROP DATABASE `db_303699_travel_agency`;
UNINSTALL EXTENSION vsql_schematron;
