INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 356092_create_table_mysql
--echo #
CREATE DATABASE `db_356092_create_table_mysql`;
USE `db_356092_create_table_mysql`;

CREATE TABLE `PARENTS` (
  `ID` INT,
  `NAME` VARCHAR(255),
  `AGE` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `CHILDREN` (
  `PARENT_ID` INT,
  `NAME` VARCHAR(255),
  `AGE` INT,
  PRIMARY KEY (`PARENT_ID`, `NAME`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_356092_create_table_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_356092_create_table_mysql') AS relationships;
DROP DATABASE `db_356092_create_table_mysql`;
UNINSTALL EXTENSION vsql_schematron;
