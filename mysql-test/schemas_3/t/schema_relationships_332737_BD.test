INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 332737_BD
--echo #
CREATE DATABASE `db_332737_BD`;
USE `db_332737_BD`;

CREATE TABLE `t_usuario` (
  `id_i` INT,
  `ci` VARCHAR(64),
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `nombre` VARCHAR(64),
  `email_1` VARCHAR(64),
  `email_2` VARCHAR(64),
  `bloqueo` VARCHAR(64),
  `intentos_c` INT,
  `intentos_d` INT,
  `creacion` DATETIME,
  PRIMARY KEY (`id_i`)
) CHARACTER SET latin1;

CREATE TABLE `t_tipo` (
  `tipo` INT,
  `descripcion` VARCHAR(64),
  PRIMARY KEY (`tipo`)
) CHARACTER SET latin1;

CREATE TABLE `t_registro` (
  `id_log` INT,
  `id_i` INT,
  `tipo` INT,
  `datos` VARCHAR(64),
  `ip` VARCHAR(64),
  `fecha` DATETIME,
  PRIMARY KEY (`id_log`)
) CHARACTER SET latin1;

CREATE TABLE `t_adm` (
  `llave` VARCHAR(64),
  `llave_log` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `t_eliminados` (
  `id_i` INT,
  `ci` VARCHAR(64),
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  `nombre` VARCHAR(64),
  `email_1` VARCHAR(64),
  `email_2` VARCHAR(64),
  `bloqueo` VARCHAR(64),
  `intentos_c` INT,
  `intentos_d` INT,
  `creacion` DATETIME,
  PRIMARY KEY (`id_i`)
) CHARACTER SET latin1;

CREATE TABLE `t_dpf` (
  `dpf` INT,
  `apertura` VARCHAR(64),
  `plazo` INT,
  `vcto` VARCHAR(64),
  `capital` DECIMAL(10,2),
  `tasa` DECIMAL(10,2),
  `periodo` VARCHAR(64),
  `moneda` VARCHAR(64),
  `caja_a` INT,
  PRIMARY KEY (`dpf`)
) CHARACTER SET latin1;

CREATE TABLE `t_dpfr` (
  `dpf` INT,
  `ci` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `t_dpfq` (
  `dpf` INT,
  `fecha` VARCHAR(64),
  `operacion` VARCHAR(64),
  `d_h` VARCHAR(64),
  `monto` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `t_dpfa` (
  `dpf` INT,
  `fecha` VARCHAR(64),
  `monto_int` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `t_cred` (
  `cred` INT,
  `monto` DECIMAL(10,2),
  `tasa` DECIMAL(10,2),
  `plazo` INT,
  `tipocuota` VARCHAR(64),
  `tipoamort` VARCHAR(64),
  `diasamort` INT,
  `f_desemb` VARCHAR(64),
  `saldo` DECIMAL(10,2),
  `caja_a` INT,
  PRIMARY KEY (`cred`)
) CHARACTER SET latin1;

CREATE TABLE `t_credr` (
  `cred` INT,
  `ci` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `t_credq` (
  `cred` INT,
  `fecha` VARCHAR(64),
  `operacion` VARCHAR(64),
  `d_h` VARCHAR(64),
  `monto` DECIMAL(10,2),
  `amort` DECIMAL(10,2),
  `interes` DECIMAL(10,2),
  `otros` DECIMAL(10,2),
  `monto_pag` DECIMAL(10,2),
  `saldo_cap` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `t_creda` (
  `cred` INT,
  `fecha` VARCHAR(64),
  `capital` DECIMAL(10,2),
  `interes` DECIMAL(10,2),
  `formularios` DECIMAL(10,2),
  `total_pag` DECIMAL(10,2),
  `saldo_cap` DECIMAL(10,2)
) CHARACTER SET latin1;

CREATE TABLE `t_cda` (
  `cda` INT,
  `moneda` VARCHAR(64),
  `interes` DECIMAL(10,2),
  `periodo` VARCHAR(64),
  `saldo` DECIMAL(10,2),
  `inpp` DECIMAL(10,2),
  `fecha` VARCHAR(64),
  PRIMARY KEY (`cda`)
) CHARACTER SET latin1;

CREATE TABLE `t_cdar` (
  `cda` INT,
  `ci` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `t_cdaq` (
  `cda` INT,
  `fecha` VARCHAR(64),
  `operacion` VARCHAR(64),
  `d_h` VARCHAR(64),
  `monto` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_332737_BD') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_332737_BD') AS relationships;
DROP DATABASE `db_332737_BD`;
UNINSTALL EXTENSION vsql_schematron;
