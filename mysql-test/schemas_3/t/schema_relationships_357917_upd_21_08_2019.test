INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 357917_upd_21_08_2019
--echo #
CREATE DATABASE `db_357917_upd_21_08_2019`;
USE `db_357917_upd_21_08_2019`;

CREATE TABLE `CL_BRAND` (
  `CL_BRAND_ID` INT,
  `CL_BRAND_NAME` VARCHAR(64),
  `CL_BRAND_IMG_SMALL` VARCHAR(64),
  `CL_BRAND_IMG_BIG` VARCHAR(64),
  `CL_BRAND_URL` VARCHAR(64),
  `CL_BRAND_PRIORITY` DECIMAL(10,2),
  PRIMARY KEY (`CL_BRAND_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PARTNER` (
  `PARTNER_ID` INT,
  `PARTNER_GROUP_ID` INT,
  `PARTNER_NAME` VARCHAR(64),
  `PARTNER_URL` VARCHAR(64),
  `PARTNER_PRIORITY` DECIMAL(10,2),
  PRIMARY KEY (`PARTNER_ID`)
) CHARACTER SET latin1;

CREATE TABLE `PARTNER_GROUP` (
  `PARTNER_GROUP_ID` INT,
  `PARTNER_GROUP_NAME` VARCHAR(64),
  `PARTNER_GROUP_PRIORITY` DECIMAL(10,2),
  PRIMARY KEY (`PARTNER_GROUP_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_357917_upd_21_08_2019') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_357917_upd_21_08_2019') AS relationships;
DROP DATABASE `db_357917_upd_21_08_2019`;
UNINSTALL EXTENSION vsql_schematron;
