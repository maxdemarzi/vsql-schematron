INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377596_umkm
--echo #
CREATE DATABASE `db_377596_umkm`;
USE `db_377596_umkm`;

CREATE TABLE `categories` (
  `id` INT,
  `category_name` VARCHAR(64),
  `slug` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `images` (
  `id` INT,
  `name` VARCHAR(64),
  `imageable_id` VARCHAR(64),
  `imageable_type` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `category_id` INT,
  `user_id` INT,
  `slug` VARCHAR(64),
  `product_name` VARCHAR(64),
  `product_detail` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `address` VARCHAR(64),
  `maps` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_user` (
  `id` INT,
  `role_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `surname` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user_details` (
  `id` INT,
  `user_id` INT,
  `address` VARCHAR(64),
  `phone` VARCHAR(64),
  `m_phone` VARCHAR(64),
  `city` VARCHAR(64),
  `country` VARCHAR(64),
  `zipcode` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377596_umkm') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377596_umkm') AS relationships;
DROP DATABASE `db_377596_umkm`;
UNINSTALL EXTENSION vsql_schematron;
