INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 356663_init
--echo #
CREATE DATABASE `db_356663_init`;
USE `db_356663_init`;
CREATE TABLE `articles_categories` (
  `categoryId` INT NOT NULL,
  `category` VARCHAR(50),
  PRIMARY KEY (`categoryId`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `title` VARCHAR(50),
  `shortDescription` TEXT,
  `description` TEXT,
  `eventDate` TEXT,
  `categoryId` INT,
  `imageURL` VARCHAR(50),
  `imageDescription` TEXT,
  `isMemberOnly` BOOLEAN,
  `isStared` BOOLEAN,
  `tags` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `documents_types` (
  `typeId` INT NOT NULL,
  `type` VARCHAR(50),
  PRIMARY KEY (`typeId`)
) CHARACTER SET latin1;
CREATE TABLE `documents` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `typeId` INT,
  `title` VARCHAR(50),
  `shortDescription` TEXT,
  `url` VARCHAR(50),
  `isMemberOnly` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `isAdmin` BOOLEAN,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `statics` (
  `id` INT NOT NULL,
  `slug` TEXT,
  `content` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_356663_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_356663_init') AS relationships;
DROP DATABASE `db_356663_init`;
UNINSTALL EXTENSION vsql_schematron;
