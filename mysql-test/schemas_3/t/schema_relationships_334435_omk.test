INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 334435_omk
--echo #
CREATE DATABASE `db_334435_omk`;
USE `db_334435_omk`;

CREATE TABLE `item` (
  `id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_item_set` (
  `item_id` INT,
  `item_set_id` INT,
  PRIMARY KEY (`item_id`, `item_set_id`)
) CHARACTER SET latin1;

CREATE TABLE `item_set` (
  `id` INT,
  `is_open` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_334435_omk') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_334435_omk') AS relationships;
DROP DATABASE `db_334435_omk`;
UNINSTALL EXTENSION vsql_schematron;
