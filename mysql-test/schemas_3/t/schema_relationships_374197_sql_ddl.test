INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 374197_sql.ddl
--echo #
CREATE DATABASE `db_374197_sql_ddl`;
USE `db_374197_sql_ddl`;

CREATE TABLE `accesstable` (
  `startdate` DATETIME,
  `enddate` DATETIME,
  `usertable_userid` DECIMAL(10,2),
  `doortable_doorid` DECIMAL(10,2),
  PRIMARY KEY (`usertable_userid`, `doortable_doorid`)
) CHARACTER SET latin1;

CREATE TABLE `doortable` (
  `doorid` DECIMAL(10,2),
  `name` VARCHAR(64),
  `ip` VARCHAR(64),
  PRIMARY KEY (`doorid`)
) CHARACTER SET latin1;

CREATE TABLE `finger` (
  `finger` VARCHAR(64),
  `user_id` DECIMAL(10,2),
  `binfile` VARCHAR(64),
  PRIMARY KEY (`finger`)
) CHARACTER SET latin1;

CREATE TABLE `logaccesstable` (
  `time` DATETIME,
  `usertable_userid` DECIMAL(10,2),
  `doortable_doorid` DECIMAL(10,2),
  PRIMARY KEY (`usertable_userid`, `doortable_doorid`)
) CHARACTER SET latin1;

CREATE TABLE `usertable` (
  `userid` DECIMAL(10,2),
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`userid`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_374197_sql_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_374197_sql_ddl') AS relationships;
DROP DATABASE `db_374197_sql_ddl`;
UNINSTALL EXTENSION vsql_schematron;
