INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331014_create_database
--echo #
CREATE DATABASE `db_331014_create_database`;
USE `db_331014_create_database`;

CREATE TABLE `players` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `matches` (
  `id` INT,
  `date` VARCHAR(64),
  `winner` INT,
  `loser` INT,
  `winner_score` INT,
  `loser_score` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331014_create_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331014_create_database') AS relationships;
DROP DATABASE `db_331014_create_database`;
UNINSTALL EXTENSION vsql_schematron;
