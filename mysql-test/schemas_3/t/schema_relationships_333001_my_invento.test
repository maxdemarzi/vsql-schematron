INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333001_my_invento
--echo #
CREATE DATABASE `db_333001_my_invento`;
USE `db_333001_my_invento`;

CREATE TABLE `grn_masters` (
  `id` INT,
  `user_id` INT,
  `supplier_id` INT,
  `purchase_order_id` INT,
  `dn_code` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `issuance_masters` (
  `id` INT,
  `user_id` INT,
  `requisition_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `item_categories` (
  `id` INT,
  `item_cat_name` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item_types` (
  `id` INT,
  `item_type_name` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menus` (
  `id` INT,
  `menu_name` VARCHAR(64),
  `menu_slug` VARCHAR(64),
  `parent_menu_id` INT,
  `order` INT,
  `icon` VARCHAR(64),
  `menu_route` VARCHAR(64),
  `active` INT,
  `hidden` INT,
  `sort_order` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `my_departments` (
  `id` INT,
  `department_name` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `id` INT,
  `menu_id` INT,
  `user_id` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `purchase_order_masters` (
  `id` INT,
  `requisition_id` INT,
  `user_id` INT,
  `supplier_id` INT,
  `purchase_code` VARCHAR(64),
  `quatation_nmbr` VARCHAR(64),
  `approval_by` INT,
  `approved` INT,
  `rejected` INT,
  `printed` INT,
  `approval_date` DATETIME,
  `created_date` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `requisitions` (
  `id` INT,
  `user_id` INT,
  `department_id` INT,
  `reason` VARCHAR(64),
  `req_code` INT,
  `approval_by` INT,
  `approved` INT,
  `issued` INT,
  `rejected` INT,
  `approval_date` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `requisition_details` (
  `id` INT,
  `requisition_id` INT,
  `item_id` INT,
  `required_qnt` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `role_name` VARCHAR(64),
  `superadmin` INT,
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `suppliers` (
  `id` INT,
  `sup_name` VARCHAR(64),
  `sup_email` VARCHAR(64),
  `sup_phone` INT,
  `sup_account` INT,
  `sup_address` VARCHAR(64),
  `sup_image` VARCHAR(64),
  `status` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `first_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `username` VARCHAR(64),
  `role_id` INT,
  `department_id` INT,
  `password` VARCHAR(64),
  `profile_image` VARCHAR(64),
  `status` INT,
  `gender` INT,
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333001_my_invento') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333001_my_invento') AS relationships;
DROP DATABASE `db_333001_my_invento`;
UNINSTALL EXTENSION vsql_schematron;
