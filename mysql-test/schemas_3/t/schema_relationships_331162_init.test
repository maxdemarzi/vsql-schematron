INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 331162_init
--echo #
CREATE DATABASE `db_331162_init`;
USE `db_331162_init`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `question` (
  `id` INT NOT NULL,
  `category_id` INT,
  `text` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `answer` (
  `id` INT NOT NULL,
  `question_id` INT,
  `text` VARCHAR(50),
  `is_correct` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_331162_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_331162_init') AS relationships;
DROP DATABASE `db_331162_init`;
UNINSTALL EXTENSION vsql_schematron;
