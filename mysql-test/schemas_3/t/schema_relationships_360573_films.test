INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360573_films
--echo #
CREATE DATABASE `db_360573_films`;
USE `db_360573_films`;

CREATE TABLE `cinemas` (
  `id` INT,
  `cinema_name` VARCHAR(64),
  `places` INT,
  `country_id` INT,
  `date_deleted` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `countries` (
  `country_id` INT,
  `country_name` VARCHAR(64),
  `date_deleted` DATETIME,
  PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;

CREATE TABLE `directors` (
  `director_id` INT,
  `director_name` VARCHAR(64),
  `diirector_bio` VARCHAR(64),
  `date_deleted` DATETIME,
  PRIMARY KEY (`director_id`)
) CHARACTER SET latin1;

CREATE TABLE `films` (
  `film_id` INT,
  `film_name` VARCHAR(64),
  `imdb_index` DECIMAL(10,2),
  `plot` VARCHAR(64),
  `year_of_production` INT,
  `producer_id` INT,
  `director_id` INT,
  `screenwriter_id` INT,
  `tickets_sold` INT,
  `country_id` INT,
  `date_deleted` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `genres` (
  `genre_id` INT,
  `genre_name` VARCHAR(64),
  `date_deleted` DATETIME,
  PRIMARY KEY (`genre_id`)
) CHARACTER SET latin1;

CREATE TABLE `producers` (
  `producer_id` INT,
  `producer_name` VARCHAR(64),
  `birth_year` INT,
  `producer_bio` VARCHAR(64),
  `date_deleted` DATETIME,
  PRIMARY KEY (`producer_id`)
) CHARACTER SET latin1;

CREATE TABLE `screenwriters` (
  `screenwriter_id` INT,
  `sceenwriter_name` VARCHAR(64),
  `screenwriter_bio` VARCHAR(64),
  `number_of_screenwritigs` INT,
  `date_deleted` DATETIME,
  PRIMARY KEY (`screenwriter_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360573_films') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360573_films') AS relationships;
DROP DATABASE `db_360573_films`;
UNINSTALL EXTENSION vsql_schematron;
