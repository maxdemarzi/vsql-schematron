INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 398876_V1__create_table
--echo #
CREATE DATABASE `db_398876_V1__create_table`;
USE `db_398876_V1__create_table`;
CREATE TABLE `DEPT` (
  `DEPT_ID` INT NOT NULL,
  `DEPT_NAME` VARCHAR(50),
  `VERSION_NO` INT,
  PRIMARY KEY (`DEPT_ID`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
  `EMP_ID` INT NOT NULL,
  `DEPT_ID` INT,
  `EMP_NAME` VARCHAR(50),
  `HIREDATE` DATE,
  `SALARY` DECIMAL(10,2),
  `VERSION_NO` INT,
  PRIMARY KEY (`EMP_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_398876_V1__create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_398876_V1__create_table') AS relationships;
DROP DATABASE `db_398876_V1__create_table`;
UNINSTALL EXTENSION vsql_schematron;
