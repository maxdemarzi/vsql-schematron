INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307866_scriptdatabase
--echo #
CREATE DATABASE `db_307866_scriptdatabase`;
USE `db_307866_scriptdatabase`;
CREATE TABLE `users` (
  `id_user` INT NOT NULL,
  `email` VARCHAR(50),
  `user_password` VARCHAR(50),
  PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
CREATE TABLE `codes` (
  `id_code` INT NOT NULL,
  `title` VARCHAR(50),
  `content` VARCHAR(50),
  `id_user` INT,
  `code_date` DATETIME,
  PRIMARY KEY (`id_code`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307866_scriptdatabase') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307866_scriptdatabase') AS relationships;
DROP DATABASE `db_307866_scriptdatabase`;
UNINSTALL EXTENSION vsql_schematron;
