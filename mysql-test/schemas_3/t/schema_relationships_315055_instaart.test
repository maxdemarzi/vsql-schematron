INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 315055_instaart
--echo #
CREATE DATABASE `db_315055_instaart`;
USE `db_315055_instaart`;

CREATE TABLE `comments` (
  `id` INT,
  `post_id` INT,
  `user_id` INT,
  `body` VARCHAR(64),
  `date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `follows` (
  `id` INT,
  `following_id` INT,
  `follower_id` INT
) CHARACTER SET latin1;

CREATE TABLE `likes` (
  `id` INT,
  `post_id` INT,
  `user_id` INT
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `user_id` INT,
  `title` VARCHAR(64),
  `caption` VARCHAR(64),
  `image` VARCHAR(64),
  `date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `display_name` VARCHAR(64),
  `biodata` VARCHAR(64),
  `image` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_315055_instaart') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_315055_instaart') AS relationships;
DROP DATABASE `db_315055_instaart`;
UNINSTALL EXTENSION vsql_schematron;
