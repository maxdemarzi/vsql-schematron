INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376523_create_table
--echo #
CREATE DATABASE `db_376523_create_table`;
USE `db_376523_create_table`;
CREATE TABLE `employee` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `office` VARCHAR(50),
  `age` SMALLINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `author` VARCHAR(50),
  `publisher` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `record` (
  `book_id` CHAR(50),
  `employee_id` CHAR(50),
  `time` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376523_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376523_create_table') AS relationships;
DROP DATABASE `db_376523_create_table`;
UNINSTALL EXTENSION vsql_schematron;
