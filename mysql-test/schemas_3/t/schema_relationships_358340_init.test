INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 358340_init
--echo #
CREATE DATABASE `db_358340_init`;
USE `db_358340_init`;

CREATE TABLE `th__challenge` (
  `id` VARCHAR(64),
  `code` VARCHAR(64),
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `key_type` VARCHAR(64),
  `key_type_options` VARCHAR(64),
  `on_submit` VARCHAR(64),
  `correct_answer` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__narrative` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `following_challenge_id` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__treasure_map` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `filename` VARCHAR(64),
  `tiling_x` INT,
  `tiling_y` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__notebook` (
  `id` VARCHAR(64),
  `user_id` VARCHAR(64),
  `active_page` INT,
  `first_opened_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__notebook_page` (
  `id` VARCHAR(64),
  `notebook_id` VARCHAR(64),
  `page_number` INT,
  `type` VARCHAR(64),
  `params` VARCHAR(64),
  `discovered_on` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__clue_revelation` (
  `id` INT,
  `notebook_page_id` VARCHAR(64),
  `expires_on` DATETIME,
  `clue_type` VARCHAR(64),
  `clue_args` VARCHAR(64),
  `date_created` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `th__input_ban` (
  `id` INT,
  `notebook_page_id` VARCHAR(64),
  `active_until` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_358340_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_358340_init') AS relationships;
DROP DATABASE `db_358340_init`;
UNINSTALL EXTENSION vsql_schematron;
