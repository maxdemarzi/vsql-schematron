INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351451_create_schema_with_constraints
--echo #
CREATE DATABASE `db_351451_create_schema_with_constraints`;
USE `db_351451_create_schema_with_constraints`;

CREATE TABLE `date_` (
  `d_datekey` INT,
  `d_date` VARCHAR(64),
  `d_dayofweek` VARCHAR(64),
  `d_month` VARCHAR(64),
  `d_year` INT,
  `d_yearmonthnum` INT,
  `d_yearmonth` VARCHAR(64),
  `d_daynuminweek` INT,
  `d_daynuminmonth` INT,
  `d_daynuminyear` INT,
  `d_monthnuminyear` INT,
  `d_weeknuminyear` INT,
  `d_sellingseason` VARCHAR(64),
  `d_lastdayinweekfl` INT,
  `d_lastdayinmonthfl` INT,
  `d_holidayfl` INT,
  `d_weekdayfl` INT,
  PRIMARY KEY (`d_datekey`)
) CHARACTER SET latin1;

CREATE TABLE `supplier` (
  `s_suppkey` INT,
  `s_name` VARCHAR(64),
  `s_address` VARCHAR(64),
  `s_city` VARCHAR(64),
  `s_nation` VARCHAR(64),
  `s_region` VARCHAR(64),
  `s_phone` VARCHAR(64),
  PRIMARY KEY (`s_suppkey`)
) CHARACTER SET latin1;

CREATE TABLE `customer` (
  `c_custkey` INT,
  `c_name` VARCHAR(64),
  `c_address` VARCHAR(64),
  `c_city` VARCHAR(64),
  `c_nation` VARCHAR(64),
  `c_region` VARCHAR(64),
  `c_phone` VARCHAR(64),
  `c_mktsegment` VARCHAR(64),
  PRIMARY KEY (`c_custkey`)
) CHARACTER SET latin1;

CREATE TABLE `part` (
  `p_partkey` INT,
  `p_name` VARCHAR(64),
  `p_mfgr` VARCHAR(64),
  `p_category` VARCHAR(64),
  `p_brand1` VARCHAR(64),
  `p_color` VARCHAR(64),
  `p_type` VARCHAR(64),
  `p_size` INT,
  `p_container` VARCHAR(64),
  PRIMARY KEY (`p_partkey`)
) CHARACTER SET latin1;

CREATE TABLE `lineorder` (
  `lo_orderkey` INT,
  `lo_linenumber` INT,
  `lo_custkey` INT,
  `lo_partkey` INT,
  `lo_suppkey` INT,
  `lo_orderdate` INT,
  `lo_orderpriority` VARCHAR(64),
  `lo_shippriority` VARCHAR(64),
  `lo_quantity` INT,
  `lo_extendedprice` INT,
  `lo_ordtotalprice` INT,
  `lo_discount` INT,
  `lo_revenue` INT,
  `lo_supplycost` INT,
  `lo_tax` INT,
  `lo_commitdate` INT,
  `lo_shipmode` VARCHAR(64),
  PRIMARY KEY (`lo_orderkey`, `lo_linenumber`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351451_create_schema_with_constraints') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351451_create_schema_with_constraints') AS relationships;
DROP DATABASE `db_351451_create_schema_with_constraints`;
UNINSTALL EXTENSION vsql_schematron;
