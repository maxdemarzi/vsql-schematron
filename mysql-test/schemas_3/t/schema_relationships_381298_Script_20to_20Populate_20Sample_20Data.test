INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381298_Script%20to%20Populate%20Sample%20Data
--echo #
CREATE DATABASE `db_381298_Script_20to_20Populate_20Sample_20Data`;
USE `db_381298_Script_20to_20Populate_20Sample_20Data`;
CREATE TABLE `department_master` (
  `dept_id` DECIMAL(10,2) NOT NULL,
  `dept_code` VARCHAR(50),
  `dept_name` VARCHAR(50),
  `updated_by` VARCHAR(50),
  `updated_on` TIMESTAMP NULL,
  PRIMARY KEY (`dept_id`)
) CHARACTER SET latin1;
CREATE TABLE `dept_tasks` (
  `task_id` DECIMAL(10,2) NOT NULL,
  `task_name` VARCHAR(50),
  `dept_id` DECIMAL(10,2),
  `updated_by` VARCHAR(50),
  `updated_on` TIMESTAMP NULL,
  PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381298_Script_20to_20Populate_20Sample_20Data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381298_Script_20to_20Populate_20Sample_20Data') AS relationships;
DROP DATABASE `db_381298_Script_20to_20Populate_20Sample_20Data`;
UNINSTALL EXTENSION vsql_schematron;
