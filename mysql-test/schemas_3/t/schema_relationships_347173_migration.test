INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347173_migration
--echo #
CREATE DATABASE `db_347173_migration`;
USE `db_347173_migration`;
CREATE TABLE `Campaign` (
  `id` VARCHAR(50) NOT NULL,
  `createdAt` TIMESTAMP NULL,
  `name` TEXT,
  `platinum` INT,
  `gold` INT,
  `electrum` INT,
  `silver` INT,
  `copper` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Item` (
  `id` VARCHAR(50) NOT NULL,
  `name` TEXT,
  `description` TEXT,
  `notes` TEXT,
  `tags` VARCHAR(50),
  `quantity` INT,
  `updatedAt` TIMESTAMP NULL,
  `createdAt` TIMESTAMP NULL,
  `campaignId` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347173_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347173_migration') AS relationships;
DROP DATABASE `db_347173_migration`;
UNINSTALL EXTENSION vsql_schematron;
