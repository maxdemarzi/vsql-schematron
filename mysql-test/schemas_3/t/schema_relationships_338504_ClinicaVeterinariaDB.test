INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 338504_ClinicaVeterinariaDB
--echo #
CREATE DATABASE `db_338504_ClinicaVeterinariaDB`;
USE `db_338504_ClinicaVeterinariaDB`;
CREATE TABLE `ClinicaVeterinariaDB.animal` (
  `id` INT NOT NULL,
  `nome` VARCHAR(50),
  `especie` VARCHAR(50),
  `raca` VARCHAR(50),
  `idade` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ClinicaVeterinariaDB.cliente_animal` (
  `fk_cliente` INT NOT NULL,
  `fk_animal` INT NOT NULL,
  PRIMARY KEY (`fk_cliente`, `fk_animal`)
) CHARACTER SET latin1;
CREATE TABLE `ClinicaVeterinariaDB.veterinario_consulta` (
  `fk_veterinario` INT NOT NULL,
  `fk_consulta` INT NOT NULL,
  PRIMARY KEY (`fk_veterinario`, `fk_consulta`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_338504_ClinicaVeterinariaDB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_338504_ClinicaVeterinariaDB') AS relationships;
DROP DATABASE `db_338504_ClinicaVeterinariaDB`;
UNINSTALL EXTENSION vsql_schematron;
