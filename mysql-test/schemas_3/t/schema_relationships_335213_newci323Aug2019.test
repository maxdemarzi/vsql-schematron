INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335213_newci323Aug2019
--echo #
CREATE DATABASE `db_335213_newci323Aug2019`;
USE `db_335213_newci323Aug2019`;
CREATE TABLE `blogs` (
  `bId` INT,
  `bTitle` VARCHAR(50),
  `bBody` TEXT,
  `bDate` DATETIME,
  `bStatus` INT,
  `userId` INT
) CHARACTER SET latin1;
CREATE TABLE `classes` (
  `cId` INT,
  `cName` VARCHAR(50),
  `date` DATETIME,
  `userId` INT
) CHARACTER SET latin1;
CREATE TABLE `students` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `date` DATETIME,
  `fullName` VARCHAR(50),
  `age` INT,
  `eLink` VARCHAR(50),
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335213_newci323Aug2019') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335213_newci323Aug2019') AS relationships;
DROP DATABASE `db_335213_newci323Aug2019`;
UNINSTALL EXTENSION vsql_schematron;
