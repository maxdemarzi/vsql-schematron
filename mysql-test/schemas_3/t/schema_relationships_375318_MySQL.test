INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 375318_MySQL
--echo #
CREATE DATABASE `db_375318_MySQL`;
USE `db_375318_MySQL`;

CREATE TABLE `bet_type` (
  `id` INT,
  `bet_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `horse` (
  `id` INT,
  `horse_name` VARCHAR(64),
  `description` VARCHAR(64),
  `avatar` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `race_status` (
  `id` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `race` (
  `id` INT,
  `start_date` DATETIME,
  `race_name` VARCHAR(64),
  `description` VARCHAR(64),
  `race_status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `race_runner` (
  `id` INT,
  `runner_id` INT,
  `runner_place` INT,
  `race_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role` (
  `id` INT,
  `role_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_status` (
  `id` INT,
  `user_status` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_table` (
  `id` INT,
  `login` VARCHAR(64),
  `pass` VARCHAR(64),
  `username` VARCHAR(64),
  `role_id` INT,
  `money` DECIMAL(10,2),
  `avatar` VARCHAR(64),
  `status_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bet` (
  `id` INT,
  `user_id` INT,
  `price` DECIMAL(10,2),
  `bet_type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bet_pick` (
  `id` INT,
  `bet_id` INT,
  `pick_place` INT,
  `pick_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_375318_MySQL') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_375318_MySQL') AS relationships;
DROP DATABASE `db_375318_MySQL`;
UNINSTALL EXTENSION vsql_schematron;
