INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 321556_database
--echo #
CREATE DATABASE `db_321556_database`;
USE `db_321556_database`;

CREATE TABLE `Heathpath.doctors` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Heathpath.patients` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `phone` VARCHAR(64),
  `birthday` DATETIME,
  `insurance` VARCHAR(64),
  `risk` DECIMAL(10,2),
  `zip` VARCHAR(64),
  `house` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Heathpath.patientRelatives` (
  `id` INT,
  `patientId` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Heathpath.appointments` (
  `id` INT,
  `doctorId` INT,
  `patientId` INT,
  `subject` VARCHAR(64),
  `symptoms` VARCHAR(64),
  `appointmentDate` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Heathpath.appointmentResults` (
  `id` INT,
  `appointmentId` INT,
  `prescription` VARCHAR(64),
  `nextAppointment` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Heathpath.appointmentResultQuestions` (
  `id` INT,
  `appointmentId` INT,
  `question` VARCHAR(64),
  `answer` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_321556_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_321556_database') AS relationships;
DROP DATABASE `db_321556_database`;
UNINSTALL EXTENSION vsql_schematron;
