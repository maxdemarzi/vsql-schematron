INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373571_parking_lot_platform_db
--echo #
CREATE DATABASE `db_373571_parking_lot_platform_db`;
USE `db_373571_parking_lot_platform_db`;

CREATE TABLE `config` (
  `config_sno` INT,
  `config_para_name` VARCHAR(64),
  `config_para_data` VARCHAR(64),
  PRIMARY KEY (`config_sno`)
) CHARACTER SET latin1;

CREATE TABLE `control_box_info` (
  `control_box_info_name` VARCHAR(64),
  `control_box_info_ip` VARCHAR(64),
  `control_box_info_port` VARCHAR(64),
  `control_box_info_para` VARCHAR(64),
  `control_box_info_uuid` VARCHAR(64),
  PRIMARY KEY (`control_box_info_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `display_info` (
  `display_info_name` VARCHAR(64),
  `display_info_ip` VARCHAR(64),
  `display_info_port` VARCHAR(64),
  `display_info_para` VARCHAR(64),
  `display_info_uuid` VARCHAR(64),
  PRIMARY KEY (`display_info_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `gate_info` (
  `gate_info_name` VARCHAR(64),
  `control_box_info_uuid` VARCHAR(64),
  `gate_info_no` VARCHAR(64),
  `gate_info_uuid` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `group_info` (
  `group_info_name` VARCHAR(64),
  `group_info_space_amount` INT,
  `group_info_space_remaning` INT,
  `group_info_uuid` VARCHAR(64),
  PRIMARY KEY (`group_info_uuid`)
) CHARACTER SET latin1;

CREATE TABLE `history_info` (
  `vehicle_info_uuid` VARCHAR(64),
  `history_info_current_time` DATETIME,
  `history_info_direct` INT,
  `history_info_image_filename` VARCHAR(64),
  `history_info_uuid` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `vehicle_info` (
  `vehicle_info_owner` VARCHAR(64),
  `vehicle_info_plate` VARCHAR(64),
  `vehicle_info_phone` VARCHAR(64),
  `group_info_uuid` VARCHAR(64),
  `vehicle_info_other` VARCHAR(64),
  `vehicle_info_is_inside` INT,
  `vehicle_info_is_deleted` INT,
  `vehicle_info_uuid` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373571_parking_lot_platform_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373571_parking_lot_platform_db') AS relationships;
DROP DATABASE `db_373571_parking_lot_platform_db`;
UNINSTALL EXTENSION vsql_schematron;
