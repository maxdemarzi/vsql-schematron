INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360422_2
--echo #
CREATE DATABASE `db_360422_2`;
USE `db_360422_2`;
CREATE TABLE `answer_user` (
  `answer_id` VARCHAR(50) NOT NULL,
  `user_id` VARCHAR(50),
  PRIMARY KEY (`answer_id`)
) CHARACTER SET latin1;
CREATE TABLE `question_answer` (
  `question_id` VARCHAR(50) NOT NULL,
  `answer_id` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`question_id`, `answer_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360422_2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360422_2') AS relationships;
DROP DATABASE `db_360422_2`;
UNINSTALL EXTENSION vsql_schematron;
