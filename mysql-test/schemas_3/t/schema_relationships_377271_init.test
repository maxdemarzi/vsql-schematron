INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 377271_init
--echo #
CREATE DATABASE `db_377271_init`;
USE `db_377271_init`;
CREATE TABLE `account` (
  `id` BIGINT NOT NULL,
  `name` VARCHAR(50),
  `password_hash` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
  `id` VARCHAR(50) NOT NULL,
  `account_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `expires_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_377271_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_377271_init') AS relationships;
DROP DATABASE `db_377271_init`;
UNINSTALL EXTENSION vsql_schematron;
