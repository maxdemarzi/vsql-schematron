INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 352586_data
--echo #
CREATE DATABASE `db_352586_data`;
USE `db_352586_data`;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `shop_user` (
  `id` INT,
  `role_id` INT,
  `name` VARCHAR(255),
  `username` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `transaction` (
  `id` INT,
  `shop_user_id` INT,
  `status_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `item` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `category` VARCHAR(255),
  `stock_number` INT,
  `price` DECIMAL(10,2),
  `image` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cart` (
  `id` INT,
  `transaction_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `r_cart_item` (
  `id` INT,
  `cart_id` INT,
  `item_id` INT,
  `quantity` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_352586_data') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_352586_data') AS relationships;
DROP DATABASE `db_352586_data`;
UNINSTALL EXTENSION vsql_schematron;
