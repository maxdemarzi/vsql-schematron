INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 378379_043_containers_and_shipments.mysql
--echo #
CREATE DATABASE `db_378379_043_containers_and_shipments_mysql`;
USE `db_378379_043_containers_and_shipments_mysql`;
CREATE TABLE `fv_shipments` (
  `fv_shipment_id` INT NOT NULL,
  `fv_ship_mode` INT,
  `fv_vendor_id` INT,
  `voyage` VARCHAR(50),
  `vessel` VARCHAR(50),
  `bol` VARCHAR(50),
  `commercial_invoice` VARCHAR(50),
  `fv_forwarder` INT,
  `from_port` INT,
  `to_port` INT,
  `country_of_origin` CHAR(50),
  `customs_entry_number` VARCHAR(50),
  `document_send_date` DATETIME,
  `invoice_paid_date` DATETIME,
  `begin_loading_date` DATETIME,
  `finish_loading_date` DATETIME,
  `departure_date` DATETIME,
  `arrival_date` DATETIME,
  `begin_unloading_date` DATETIME,
  `finish_unloading_date` DATETIME,
  `begin_inspection_date` DATETIME,
  `finish_inspection_date` DATETIME,
  `must_arrive_by` DATETIME,
  `status` CHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`fv_shipment_id`)
) CHARACTER SET latin1;
CREATE TABLE `fv_containers` (
  `fv_container_id` INT NOT NULL,
  `registration_code` VARCHAR(50),
  `bol` VARCHAR(50),
  `seal` VARCHAR(50),
  `customs_release` VARCHAR(50),
  `container_cost` DECIMAL(10,2),
  `currency_code` CHAR(50),
  `fv_shipment_id` INT,
  `length` DECIMAL(10,2),
  `width` DECIMAL(10,2),
  `height` DECIMAL(10,2),
  `lwh_uom` CHAR(50),
  `weight` DECIMAL(10,2),
  `weight_uom` CHAR(50),
  `fill_rate` DECIMAL(10,2),
  `final_destination` VARCHAR(50),
  `purchase_date` DATETIME,
  `sealed_date` DATETIME,
  `loaded_date` DATETIME,
  `departure_date` DATETIME,
  `arrival_date` DATETIME,
  `unloaded_date` DATETIME,
  `inspection_date` DATETIME,
  `destination_date` DATETIME,
  `unsealed_date` DATETIME,
  `emptied_date` DATETIME,
  `returned_date` DATETIME,
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`fv_container_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_378379_043_containers_and_shipments_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_378379_043_containers_and_shipments_mysql') AS relationships;
DROP DATABASE `db_378379_043_containers_and_shipments_mysql`;
UNINSTALL EXTENSION vsql_schematron;
