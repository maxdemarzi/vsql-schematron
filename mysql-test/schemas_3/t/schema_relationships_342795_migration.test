INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 342795_migration
--echo #
CREATE DATABASE `db_342795_migration`;
USE `db_342795_migration`;

CREATE TABLE `Account` (
  `id` VARCHAR(64),
  `email` VARCHAR(64),
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `verified` BOOL,
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Tag` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Stage` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `color` VARCHAR(64),
  `description` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `deletedAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Item` (
  `id` VARCHAR(64),
  `title` VARCHAR(64),
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `stageId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Note` (
  `id` INT,
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  `updatedAt` DATETIME,
  `itemId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_ItemToTag` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_342795_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_342795_migration') AS relationships;
DROP DATABASE `db_342795_migration`;
UNINSTALL EXTENSION vsql_schematron;
