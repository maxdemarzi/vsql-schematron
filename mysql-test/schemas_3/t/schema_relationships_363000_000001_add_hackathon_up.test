INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363000_000001_add_hackathon_up
--echo #
CREATE DATABASE `db_363000_000001_add_hackathon_up`;
USE `db_363000_000001_add_hackathon_up`;

CREATE TABLE `hackathon` (
  `hackathon_id` VARCHAR(255),
  `name` VARCHAR(255),
  `type` VARCHAR(255),
  `created_at` DATETIME,
  `closed_at` DATETIME,
  PRIMARY KEY (`hackathon_id`)
) CHARACTER SET latin1;

CREATE TABLE `hackathon_participant` (
  `participant_id` VARCHAR(255),
  `hackathon_id` VARCHAR(255),
  `name` VARCHAR(255),
  `endpoint` VARCHAR(255),
  `score` INT,
  `created_at` DATETIME,
  `scored_at` DATETIME,
  PRIMARY KEY (`participant_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363000_000001_add_hackathon_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363000_000001_add_hackathon_up') AS relationships;
DROP DATABASE `db_363000_000001_add_hackathon_up`;
UNINSTALL EXTENSION vsql_schematron;
