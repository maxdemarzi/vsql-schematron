INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 338854_Create%20DB
--echo #
CREATE DATABASE `db_338854_Create_20DB`;
USE `db_338854_Create_20DB`;
CREATE TABLE `Dates` (
  `DateId` INT NOT NULL,
  `FullDate` DATE,
  `Year` INT,
  `Month` INT,
  `Day` INT,
  PRIMARY KEY (`DateId`)
) CHARACTER SET latin1;
CREATE TABLE `Timeslots` (
  `TimeslotId` INT NOT NULL,
  `Display` VARCHAR(50),
  `StartTime` TIME,
  PRIMARY KEY (`TimeslotId`)
) CHARACTER SET latin1;
CREATE TABLE `Specialties` (
  `SpecialtyId` INT NOT NULL,
  `Name` VARCHAR(50),
  `Description` VARCHAR(50),
  PRIMARY KEY (`SpecialtyId`)
) CHARACTER SET latin1;
CREATE TABLE `Doctors` (
  `DoctorId` INT NOT NULL,
  `Name` VARCHAR(50),
  `SpecialtyId` INT,
  PRIMARY KEY (`DoctorId`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_338854_Create_20DB') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_338854_Create_20DB') AS relationships;
DROP DATABASE `db_338854_Create_20DB`;
UNINSTALL EXTENSION vsql_schematron;
