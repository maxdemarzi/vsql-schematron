INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319887_db
--echo #
CREATE DATABASE `db_319887_db`;
USE `db_319887_db`;

CREATE TABLE `companies` (
  `id` INT,
  `company_name` VARCHAR(255),
  `country` VARCHAR(255),
  `company_vat` VARCHAR(255),
  `company_type` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `company_type` (
  `id` INT,
  `type` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `invoices` (
  `id` INT,
  `invoice_number` INT,
  `invoice_date` DATETIME,
  `user_id` INT,
  `company_id` INT
) CHARACTER SET latin1;

CREATE TABLE `registration` (
  `id` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `email` VARCHAR(255),
  `company_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319887_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319887_db') AS relationships;
DROP DATABASE `db_319887_db`;
UNINSTALL EXTENSION vsql_schematron;
