INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333437_e-commerce
--echo #
CREATE DATABASE `db_333437_e_commerce`;
USE `db_333437_e_commerce`;
CREATE TABLE `order_statuses` (
  `id` TINYINT NOT NULL,
  `order_statusescol` VARCHAR(50),
  `order_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ordered_products` (
  `id` BIGINT NOT NULL,
  `product_id` INT,
  `quantity` TINYINT,
  `order_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shipping_details` (
  `id` INT NOT NULL,
  `order_id` INT,
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `address` TEXT,
  `address_2` TEXT,
  `city` VARCHAR(50),
  `state` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333437_e_commerce') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333437_e_commerce') AS relationships;
DROP DATABASE `db_333437_e_commerce`;
UNINSTALL EXTENSION vsql_schematron;
