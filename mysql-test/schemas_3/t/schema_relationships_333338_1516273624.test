INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333338_1516273624
--echo #
CREATE DATABASE `db_333338_1516273624`;
USE `db_333338_1516273624`;
CREATE TABLE `permissions` (
  `id` VARCHAR(50) NOT NULL,
  `roleId` VARCHAR(50),
  `resourceId` VARCHAR(50),
  `privilegeId` VARCHAR(50),
  `allowed` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
  `userId` VARCHAR(50) NOT NULL,
  `realname` VARCHAR(50),
  `email` VARCHAR(50),
  `password` CHAR(50),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `acl` (
  `id` VARCHAR(50) NOT NULL,
  `roleId` VARCHAR(50),
  `userId` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333338_1516273624') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333338_1516273624') AS relationships;
DROP DATABASE `db_333338_1516273624`;
UNINSTALL EXTENSION vsql_schematron;
