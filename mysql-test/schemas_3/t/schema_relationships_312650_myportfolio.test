INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312650_myportfolio
--echo #
CREATE DATABASE `db_312650_myportfolio`;
USE `db_312650_myportfolio`;
CREATE TABLE `projet` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` TEXT,
  `date` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skill` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projetSkill` (
  `id` INT NOT NULL,
  `skill_id` INT,
  `projet_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312650_myportfolio') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312650_myportfolio') AS relationships;
DROP DATABASE `db_312650_myportfolio`;
UNINSTALL EXTENSION vsql_schematron;
