INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 359880_script
--echo #
CREATE DATABASE `db_359880_script`;
USE `db_359880_script`;
CREATE TABLE `s` (
  `snum` INT NOT NULL,
  `sname` VARCHAR(50),
  `status` INT,
  `city` VARCHAR(50),
  PRIMARY KEY (`snum`)
) CHARACTER SET latin1;
CREATE TABLE `p` (
  `pnum` INT NOT NULL,
  `pname` VARCHAR(50),
  `color` VARCHAR(50),
  `weight` INT,
  PRIMARY KEY (`pnum`)
) CHARACTER SET latin1;
CREATE TABLE `sp` (
  `snum` INT NOT NULL,
  `pnum` INT NOT NULL,
  `qty` INT,
  PRIMARY KEY (`snum`, `pnum`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_359880_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_359880_script') AS relationships;
DROP DATABASE `db_359880_script`;
UNINSTALL EXTENSION vsql_schematron;
