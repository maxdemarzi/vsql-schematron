INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 382100_schema
--echo #
CREATE DATABASE `db_382100_schema`;
USE `db_382100_schema`;

CREATE TABLE `polls` (
  `uid` VARCHAR(64),
  `title` VARCHAR(64),
  `message` VARCHAR(64),
  `end_date` DATETIME,
  `owner` VARCHAR(64),
  PRIMARY KEY (`uid`)
) CHARACTER SET latin1;

CREATE TABLE `choices` (
  `id` INT,
  `poll` VARCHAR(64),
  `text` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `ballots` (
  `voter` VARCHAR(64),
  `poll` VARCHAR(64),
  `choice` INT,
  `grade` INT,
  PRIMARY KEY (`voter`, `poll`, `choice`)
) CHARACTER SET latin1;

CREATE TABLE `results` (
  `poll` VARCHAR(64),
  `choice` INT,
  `rank` VARCHAR(64),
  `grade` VARCHAR(64),
  `percentages` VARCHAR(64),
  `ballots` INT,
  PRIMARY KEY (`poll`, `choice`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_382100_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_382100_schema') AS relationships;
DROP DATABASE `db_382100_schema`;
UNINSTALL EXTENSION vsql_schematron;
