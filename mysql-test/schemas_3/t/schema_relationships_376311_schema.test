INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376311_schema
--echo #
CREATE DATABASE `db_376311_schema`;
USE `db_376311_schema`;
CREATE TABLE `TOUR` (
  `TOUR_ID` INT NOT NULL,
  `DIRECTION` VARCHAR(50),
  `DATE_TOUR` DATE,
  PRIMARY KEY (`TOUR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `CLIENT` (
  `CLIENT_ID` INT NOT NULL,
  `FIRSTNAME` VARCHAR(50),
  `LASTNAME` VARCHAR(50),
  `TOUR_ID` INT,
  PRIMARY KEY (`CLIENT_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376311_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376311_schema') AS relationships;
DROP DATABASE `db_376311_schema`;
UNINSTALL EXTENSION vsql_schematron;
