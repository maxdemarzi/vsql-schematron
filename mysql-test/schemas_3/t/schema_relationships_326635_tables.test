INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 326635_tables
--echo #
CREATE DATABASE `db_326635_tables`;
USE `db_326635_tables`;

CREATE TABLE `nk2_venues` (
  `id` INT,
  `title` VARCHAR(255),
  `ticket_type` VARCHAR(255),
  `description` VARCHAR(255),
  `layout_src` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_sections` (
  `id` INT,
  `venue_id` INT,
  `title` VARCHAR(255),
  `row_name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_seats` (
  `id` INT,
  `section_id` INT,
  `row` INT,
  `number` INT,
  `x_coord` INT,
  `y_coord` INT,
  `inactive` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_discount_codes` (
  `code` VARCHAR(255),
  `eur` DECIMAL(10,2),
  `use_max` INT,
  `email` VARCHAR(255),
  `code_group` VARCHAR(255),
  PRIMARY KEY (`code`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_productions` (
  `id` INT,
  `title` VARCHAR(255),
  `performer` VARCHAR(255),
  `opens` DATETIME,
  `active` VARCHAR(255),
  `description` VARCHAR(255),
  `ticket_image_src` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_shows` (
  `id` INT,
  `title` VARCHAR(255),
  `production_id` INT,
  `venue_id` INT,
  `time` DATETIME,
  `active` VARCHAR(255),
  `inactivate_time` DATETIME,
  `description` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_discount_groups` (
  `id` INT,
  `show_id` INT,
  `title` VARCHAR(255),
  `eur` DECIMAL(10,2),
  `admin_only` VARCHAR(255),
  `active` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `nk2_orders` (
  `id` INT,
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `discount_code` VARCHAR(255),
  `wants_email` VARCHAR(255),
  `time` DATETIME,
  `price` DECIMAL(10,2),
  `payment_url` VARCHAR(255),
  `payment_id` VARCHAR(255),
  `reserved_until` DATETIME,
  `reserved_session_id` VARCHAR(255),
  `status` VARCHAR(255),
  `hash` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_326635_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_326635_tables') AS relationships;
DROP DATABASE `db_326635_tables`;
UNINSTALL EXTENSION vsql_schematron;
