INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 328647_ruleinfo_migrate
--echo #
CREATE DATABASE `db_328647_ruleinfo_migrate`;
USE `db_328647_ruleinfo_migrate`;
CREATE TABLE `ruleinfo` (
  `ID` INT NOT NULL,
  `head` TEXT,
  `lid` INT,
  `rid` INT,
  `flag` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `rulepred` (
  `ruleid` INT,
  `predid` INT,
  `carg` TEXT
) CHARACTER SET latin1;
CREATE TABLE `predinfo` (
  `ID` INT NOT NULL,
  `pred` TEXT,
  `predtype` INT,
  `lemma` TEXT,
  `pos` TEXT,
  `sense` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_328647_ruleinfo_migrate') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_328647_ruleinfo_migrate') AS relationships;
DROP DATABASE `db_328647_ruleinfo_migrate`;
UNINSTALL EXTENSION vsql_schematron;
