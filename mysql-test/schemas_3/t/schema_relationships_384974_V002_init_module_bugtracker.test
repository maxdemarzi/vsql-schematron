INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 384974_V002__init_module_bugtracker
--echo #
CREATE DATABASE `db_384974_V002_init_module_bugtracker`;
USE `db_384974_V002_init_module_bugtracker`;

CREATE TABLE `project` (
  `id` INT,
  `name` VARCHAR(64),
  `deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project_members` (
  `project_id` INT,
  `members_id` INT,
  PRIMARY KEY (`project_id`, `members_id`)
) CHARACTER SET latin1;

CREATE TABLE `issuestatus` (
  `id` INT,
  `order_nr` INT,
  `name` VARCHAR(64),
  `deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `issue` (
  `id` INT,
  `description` VARCHAR(64),
  `title` VARCHAR(64),
  `date` DATETIME,
  `status_id` INT,
  `reporter_id` INT,
  `owner_id` INT,
  `project_id` INT,
  `deleted` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_384974_V002_init_module_bugtracker') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_384974_V002_init_module_bugtracker') AS relationships;
DROP DATABASE `db_384974_V002_init_module_bugtracker`;
UNINSTALL EXTENSION vsql_schematron;
