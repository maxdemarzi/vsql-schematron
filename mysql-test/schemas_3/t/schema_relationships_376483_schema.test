INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376483_schema
--echo #
CREATE DATABASE `db_376483_schema`;
USE `db_376483_schema`;

CREATE TABLE `user` (
  `id` INT,
  `login` VARCHAR(64),
  `pass` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `person` (
  `id` INT,
  `lastname` VARCHAR(64),
  `firstname` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `note` (
  `id` INT,
  `title` VARCHAR(64),
  `note` VARCHAR(64),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sub_note` (
  `id` INT,
  `note_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376483_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376483_schema') AS relationships;
DROP DATABASE `db_376483_schema`;
UNINSTALL EXTENSION vsql_schematron;
