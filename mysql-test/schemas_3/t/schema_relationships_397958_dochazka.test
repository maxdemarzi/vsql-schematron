INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 397958_dochazka
--echo #
CREATE DATABASE `db_397958_dochazka`;
USE `db_397958_dochazka`;
CREATE TABLE `dochazka` (
  `prichodDoPrace` DATETIME,
  `odchodZPrace` DATETIME,
  `prichodKLekari` DATETIME,
  `odchodOdLekare` DATETIME,
  `prichodNaObed` DATETIME,
  `odchodZObedu` DATETIME,
  `idOsoba` INT,
  `idDochazka` INT
) CHARACTER SET latin1;
CREATE TABLE `osoba` (
  `idOsoba` INT,
  `jmeno` VARCHAR(50),
  `prijmeni` VARCHAR(50),
  `idPozice` INT
) CHARACTER SET latin1;
CREATE TABLE `pozice` (
  `idPozice` INT NOT NULL,
  `Nazev` VARCHAR(50),
  PRIMARY KEY (`idPozice`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_397958_dochazka') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_397958_dochazka') AS relationships;
DROP DATABASE `db_397958_dochazka`;
UNINSTALL EXTENSION vsql_schematron;
