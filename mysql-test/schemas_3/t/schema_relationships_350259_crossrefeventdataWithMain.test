--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_350259_crossrefeventdataWithMain') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_350259_crossrefeventdataWithMain') AS relationships;
DROP DATABASE `db_350259_crossrefeventdataWithMain`;
UNINSTALL EXTENSION vsql_schematron;
