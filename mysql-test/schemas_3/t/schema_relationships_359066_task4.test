INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 359066_task4
--echo #
CREATE DATABASE `db_359066_task4`;
USE `db_359066_task4`;
CREATE TABLE `category` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `request` (
  `id` INT,
  `name` VARCHAR(50),
  `description` TEXT,
  `category_id` INT,
  `status` VARCHAR(50),
  `reject_reason` TEXT
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_359066_task4') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_359066_task4') AS relationships;
DROP DATABASE `db_359066_task4`;
UNINSTALL EXTENSION vsql_schematron;
