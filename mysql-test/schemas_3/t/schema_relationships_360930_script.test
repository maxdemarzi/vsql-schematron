INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360930_script
--echo #
CREATE DATABASE `db_360930_script`;
USE `db_360930_script`;
CREATE TABLE `client` (
  `id_client` INT NOT NULL,
  `nom` VARCHAR(50),
  `prenom` VARCHAR(50),
  `adresse` VARCHAR(50),
  `tel` CHAR(50),
  PRIMARY KEY (`id_client`)
) CHARACTER SET latin1;
CREATE TABLE `facture` (
  `id_facture` INT NOT NULL,
  `numfact` VARCHAR(50),
  `datefact` DATE,
  `id_clientFacture` INT,
  PRIMARY KEY (`id_facture`)
) CHARACTER SET latin1;
CREATE TABLE `payement` (
  `id_payement` INT NOT NULL,
  `datepayement` DATE,
  `montantpaye` DECIMAL(10,2),
  `id_facturePayment` INT,
  PRIMARY KEY (`id_payement`)
) CHARACTER SET latin1;
CREATE TABLE `produit` (
  `id_produit` INT NOT NULL,
  `reference` VARCHAR(50),
  `designation` VARCHAR(50),
  `prixunit` DECIMAL(10,2),
  PRIMARY KEY (`id_produit`)
) CHARACTER SET latin1;
CREATE TABLE `commander` (
  `id_commande` INT NOT NULL,
  `qtecde` INT,
  `id_factureCmd` INT,
  `id_produitCmd` INT,
  PRIMARY KEY (`id_commande`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360930_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360930_script') AS relationships;
DROP DATABASE `db_360930_script`;
UNINSTALL EXTENSION vsql_schematron;
