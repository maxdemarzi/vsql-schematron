INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 321738_db
--echo #
CREATE DATABASE `db_321738_db`;
USE `db_321738_db`;

CREATE TABLE `public.roles` (
  `id` INT,
  `name` VARCHAR(64),
  `status` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.skills` (
  `id` INT,
  `name` VARCHAR(64),
  `status` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.users` (
  `id` INT,
  `first_name` VARCHAR(64),
  `middle_name` VARCHAR(64),
  `last_name` VARCHAR(64),
  `email` VARCHAR(64),
  `phone_number` VARCHAR(64),
  `role_id` INT,
  `status` BOOL,
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_by` INT,
  `updated_by` INT,
  `deleted_by` INT,
  `restored_by` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `restored_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.clients` (
  `id` INT,
  `username` VARCHAR(64),
  `gender` VARCHAR(64),
  `dob` DATETIME,
  `user_id` INT,
  `status` BOOL,
  `address` VARCHAR(64),
  `citizenship` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `restored_at` DATETIME,
  `created_by` INT,
  `updated_by` INT,
  `deleted_by` INT,
  `restored_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.workers` (
  `id` INT,
  `username` VARCHAR(64),
  `gender` VARCHAR(64),
  `dob` DATETIME,
  `user_id` INT,
  `profile_photo` VARCHAR(64),
  `status` BOOL,
  `address` VARCHAR(64),
  `citizenship` VARCHAR(64),
  `skills` VARCHAR(64),
  `rate` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `restored_at` DATETIME,
  `created_by` INT,
  `updated_by` INT,
  `deleted_by` INT,
  `restored_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.jobs` (
  `id` INT,
  `title` VARCHAR(64),
  `description` VARCHAR(64),
  `date_added` DATETIME,
  `validity` DATETIME,
  `client_id` INT,
  `worker_id` INT,
  `preferance` VARCHAR(64),
  `status` BOOL,
  `rating` INT,
  `location` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `restored_at` DATETIME,
  `created_by` INT,
  `updated_by` INT,
  `deleted_by` INT,
  `restored_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `public.job_ratings` (
  `id` INT,
  `user_id` INT,
  `job_id` INT,
  `rating` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `restored_at` DATETIME,
  `created_by` INT,
  `updated_by` INT,
  `deleted_by` INT,
  `restored_by` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_321738_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_321738_db') AS relationships;
DROP DATABASE `db_321738_db`;
UNINSTALL EXTENSION vsql_schematron;
