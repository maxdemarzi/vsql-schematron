INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 350287_schema_table
--echo #
CREATE DATABASE `db_350287_schema_table`;
USE `db_350287_schema_table`;
CREATE TABLE `user` (
  `id` INT,
  `pseudo` TEXT,
  `email` TEXT,
  `tel` TEXT,
  `nom` TEXT,
  `prenom` TEXT,
  `paypal` TEXT,
  `password` TEXT,
  `disabled` INT
) CHARACTER SET latin1;
CREATE TABLE `artwork` (
  `id` INT,
  `filename` TEXT,
  `price` DECIMAL(10,2),
  `available` INT
) CHARACTER SET latin1;
CREATE TABLE `block` (
  `id` INT,
  `index` INT,
  `previous_hash` TEXT,
  `data` TEXT,
  `timestamp` DECIMAL(10,2),
  `hash` TEXT,
  `nonce` DECIMAL(10,2),
  `id_artwork` DECIMAL(10,2),
  `id_user_creator` DECIMAL(10,2),
  `id_user_owner` DECIMAL(10,2)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_350287_schema_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_350287_schema_table') AS relationships;
DROP DATABASE `db_350287_schema_table`;
UNINSTALL EXTENSION vsql_schematron;
