INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 308012_create_tables
--echo #
CREATE DATABASE `db_308012_create_tables`;
USE `db_308012_create_tables`;

CREATE TABLE `carts` (
  `cart_id` INT,
  `cart_subtotal` DECIMAL(10,2),
  `cart_discount` DECIMAL(10,2),
  `cart_taxes` DECIMAL(10,2),
  `cart_total` DECIMAL(10,2),
  PRIMARY KEY (`cart_id`)
) CHARACTER SET latin1;

CREATE TABLE `items` (
  `item_id` INT,
  `cart_id` INT,
  `item_label` VARCHAR(64),
  `item_price` DECIMAL(10,2),
  PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;

CREATE TABLE `tax` (
  `tax_id` INT,
  `tax_label` VARCHAR(64),
  `tax_percent` DECIMAL(10,2),
  PRIMARY KEY (`tax_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_308012_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_308012_create_tables') AS relationships;
DROP DATABASE `db_308012_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
