INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354823_V002__create_poll_user
--echo #
CREATE DATABASE `db_354823_V002_create_poll_user`;
USE `db_354823_V002_create_poll_user`;

CREATE TABLE `poll_user` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `user_token` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tg_user` (
  `user_id` VARCHAR(64),
  `username` VARCHAR(64),
  `poll_user` INT,
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354823_V002_create_poll_user') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354823_V002_create_poll_user') AS relationships;
DROP DATABASE `db_354823_V002_create_poll_user`;
UNINSTALL EXTENSION vsql_schematron;
