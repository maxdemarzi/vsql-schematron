INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 342830__000_dev2
--echo #
CREATE DATABASE `db_342830_000_dev2`;
USE `db_342830_000_dev2`;

CREATE TABLE `a_parent` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `b_child` (
  `id` INT,
  `parent_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_342830_000_dev2') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_342830_000_dev2') AS relationships;
DROP DATABASE `db_342830_000_dev2`;
UNINSTALL EXTENSION vsql_schematron;
