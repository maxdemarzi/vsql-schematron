INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 344834_script
--echo #
CREATE DATABASE `db_344834_script`;
USE `db_344834_script`;
CREATE TABLE `CHAT_ROOM` (
  `CHAT_ROOM_JID` VARCHAR(50) NOT NULL,
  PRIMARY KEY (`CHAT_ROOM_JID`)
) CHARACTER SET latin1;
CREATE TABLE `CHAT_PRESENCE` (
  `CHAT_ID` INT NOT NULL,
  `CHAT_ROOM_JID` VARCHAR(50),
  `USER_JID` VARCHAR(50),
  `STATE` VARCHAR(50),
  PRIMARY KEY (`CHAT_ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_344834_script') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_344834_script') AS relationships;
DROP DATABASE `db_344834_script`;
UNINSTALL EXTENSION vsql_schematron;
