INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 351989_la_petite_syrienne
--echo #
CREATE DATABASE `db_351989_la_petite_syrienne`;
USE `db_351989_la_petite_syrienne`;

CREATE TABLE `t_compte_cpt` (
  `cpt_mail` VARCHAR(64),
  `cpt_mdp` VARCHAR(64),
  PRIMARY KEY (`cpt_mail`)
) CHARACTER SET latin1;

CREATE TABLE `t_profil_pfl` (
  `pfl_nom` VARCHAR(64),
  `pfl_prenom` VARCHAR(64),
  `pfl_civilite` VARCHAR(64),
  `pfl_adresse` VARCHAR(64),
  `pfl_telephone` VARCHAR(64),
  `cpt_mail` VARCHAR(64),
  `pfl_etat` VARCHAR(64),
  `pfl_statut` VARCHAR(64),
  PRIMARY KEY (`cpt_mail`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_351989_la_petite_syrienne') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_351989_la_petite_syrienne') AS relationships;
DROP DATABASE `db_351989_la_petite_syrienne`;
UNINSTALL EXTENSION vsql_schematron;
