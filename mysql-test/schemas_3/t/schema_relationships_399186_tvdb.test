INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 399186_tvdb
--echo #
CREATE DATABASE `db_399186_tvdb`;
USE `db_399186_tvdb`;

CREATE TABLE `role` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `title` (
  `id` INT,
  `name` VARCHAR(255),
  `description` VARCHAR(255),
  `owner` VARCHAR(255),
  `title_type_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `title_type` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `login` VARCHAR(255),
  `password_hash` VARCHAR(255),
  `role_id` INT,
  `last_name` VARCHAR(255),
  `first_name` VARCHAR(255),
  `middle_name` VARCHAR(255),
  `position` VARCHAR(255),
  `image` VARCHAR(255),
  `auth_token` VARCHAR(255),
  `status` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_399186_tvdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_399186_tvdb') AS relationships;
DROP DATABASE `db_399186_tvdb`;
UNINSTALL EXTENSION vsql_schematron;
