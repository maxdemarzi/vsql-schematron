INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 371392_fly
--echo #
CREATE DATABASE `db_371392_fly`;
USE `db_371392_fly`;

CREATE TABLE `admin` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `flight` (
  `id` INT,
  `type` VARCHAR(64),
  `origin` VARCHAR(64),
  `destination` VARCHAR(64),
  `departing` VARCHAR(64),
  `returning` VARCHAR(64),
  `seats` INT,
  `price` DECIMAL(10,2),
  `iat` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `reservation` (
  `id` INT,
  `uid` INT,
  `fid` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `passenger` (
  `id` INT,
  `rid` INT,
  `name` VARCHAR(64),
  `birth` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_371392_fly') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_371392_fly') AS relationships;
DROP DATABASE `db_371392_fly`;
UNINSTALL EXTENSION vsql_schematron;
