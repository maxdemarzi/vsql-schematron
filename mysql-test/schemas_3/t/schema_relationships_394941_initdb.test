INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 394941_initdb
--echo #
CREATE DATABASE `db_394941_initdb`;
USE `db_394941_initdb`;
CREATE TABLE `products` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `description` VARCHAR(50),
  `weight` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products_on_hand` (
  `product_id` INT NOT NULL,
  `quantity` INT,
  PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `geom` (
  `id` INT NOT NULL,
  `g` VARCHAR(50),
  `h` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
  `id` INT NOT NULL,
  `created` VARCHAR(50),
  `product` VARCHAR(50),
  `qty` INT,
  `price` DOUBLE,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_394941_initdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_394941_initdb') AS relationships;
DROP DATABASE `db_394941_initdb`;
UNINSTALL EXTENSION vsql_schematron;
