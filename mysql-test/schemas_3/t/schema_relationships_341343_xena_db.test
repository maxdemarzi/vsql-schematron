CREATE DATABASE `db_341343_xena_db`;
USE `db_341343_xena_db`;

CREATE TABLE `staff_area` (
  `id` INT,
  `user_id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `staff_division` (
  `id` INT,
  `user_id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `cost_centers` (
  `id` INT,
  `user_id` INT,
  `code` VARCHAR(64),
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `companies` (
  `id` INT,
  `user_id` INT,
  `name` VARCHAR(64),
  `business_name` VARCHAR(64),
  `ruc` VARCHAR(64),
  `square_icon` VARCHAR(64),
  `rectangle_icon` VARCHAR(64),
  `is_default` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `employees` (
  `id` INT,
  `company_id` INT,
  `person_id` INT,
  `code` VARCHAR(64),
  `date_entry` DATETIME,
  `email` VARCHAR(64),
  `company_position_id` INT,
  `staff_area_id` INT,
  `cost_center_id` INT,
  `staff_division_id` INT,
  `organizational_unit_id` INT,
  `eps_affiliate` BOOL,
  `eps_plan` VARCHAR(64),
  `eps_option` VARCHAR(64),
  `affiliated` BOOL,
  `sctr_affiliate` BOOL,
  `ev_affiliate` BOOL,
  `boss` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `salt` VARCHAR(64),
  `is_admin` BOOL,
  `recovery_token` VARCHAR(64),
  `enabled` BOOL,
  `name` VARCHAR(64),
  `lastname` VARCHAR(64),
  `gender` VARCHAR(64),
  `email` VARCHAR(64),
  `avatar_url` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users_sessions` (
  `id` INT,
  `user_id` INT,
  `token` VARCHAR(64),
  `expire` DATETIME,
  `ip` VARCHAR(64),
  `browser` VARCHAR(64),
  `version` VARCHAR(64),
  `platform` VARCHAR(64),
  `created_at` DATETIME,
  `closed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `document_types` (
  `id` INT,
  `name` VARCHAR(64),
  `abbr` VARCHAR(64),
  `length` DECIMAL(10,2),
  `exact_length` BOOL,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `organizational_units` (
  `id` INT,
