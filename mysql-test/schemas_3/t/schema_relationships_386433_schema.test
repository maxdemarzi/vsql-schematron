INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 386433_schema
--echo #
CREATE DATABASE `db_386433_schema`;
USE `db_386433_schema`;

CREATE TABLE `guilds` (
  `GuildID` INT,
  `Prefix` VARCHAR(255),
  `StarChannel` INT,
  PRIMARY KEY (`GuildID`)
) CHARACTER SET latin1;

CREATE TABLE `tags` (
  `GuildID` INT,
  `TagOwner` INT,
  `TagName` VARCHAR(255),
  `TagContent` VARCHAR(255),
  `Uses` INT,
  PRIMARY KEY (`GuildID`, `TagName`)
) CHARACTER SET latin1;

CREATE TABLE `starboard` (
  `BaseMessageID` INT,
  `GuildID` INT,
  `StarMessageID` INT,
  `Stars` INT,
  PRIMARY KEY (`BaseMessageID`, `GuildID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_386433_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_386433_schema') AS relationships;
DROP DATABASE `db_386433_schema`;
UNINSTALL EXTENSION vsql_schematron;
