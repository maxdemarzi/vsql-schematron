INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 356467_schema
--echo #
CREATE DATABASE `db_356467_schema`;
USE `db_356467_schema`;

CREATE TABLE `user` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course` (
  `id` INT,
  `identifier` VARCHAR(64),
  `user_id` INT,
  `program_id` INT,
  `course_type_id` INT,
  `focus_id` INT,
  `traditional_id` INT,
  `equipment_id` INT,
  `experience_id` INT,
  `university_type_id` INT,
  `university_id` INT,
  `notes_id` INT,
  `number_students` INT,
  `students_per_instructor` DECIMAL(10,2),
  `lab_per_lecture` DECIMAL(10,2),
  `hours_per_lab` DECIMAL(10,2),
  `number_labs` INT,
  `number_experiments` INT,
  `number_projects` INT,
  `week_guided` DECIMAL(10,2),
  `start_date_pre` VARCHAR(64),
  `start_date_post` VARCHAR(64),
  `name` VARCHAR(64),
  `frequency_phys_principle` INT,
  `frequency_known_principle` INT,
  `frequency_unknown_principle` INT,
  `students_questions` INT,
  `students_plan` INT,
  `students_design` INT,
  `students_apparatus` INT,
  `students_analysis` INT,
  `students_troubleshoot` INT,
  `students_groups` INT,
  `modeling_mathematics` INT,
  `modeling_model` INT,
  `modeling_tools` INT,
  `modeling_measurement` INT,
  `modeling_predictions` INT,
  `modeling_uncertainty` INT,
  `modeling_calibrate` INT,
  `analysis_uncertainty` INT,
  `analysis_calculate` INT,
  `analysis_computer` INT,
  `analysis_control` INT,
  `communication_oral` INT,
  `communication_written` INT,
  `communication_lab` INT,
  `communication_journal` INT,
  `communication_test` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `program` (
  `id` INT,
  `program_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `course_type` (
  `id` INT,
  `course_type_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `focus` (
  `id` INT,
  `focus_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `traditional` (
  `id` INT,
  `traditional_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `equipment` (
  `id` INT,
  `equipment_type` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `experience` (
  `id` INT,
  `experience_level` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `university` (
  `id` INT,
  `university_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notes` (
  `id` INT,
  `notes_text` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `university_type` (
  `id` INT,
  `university_type_name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_356467_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_356467_schema') AS relationships;
DROP DATABASE `db_356467_schema`;
UNINSTALL EXTENSION vsql_schematron;
