INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 360296_tableSetup
--echo #
CREATE DATABASE `db_360296_tableSetup`;
USE `db_360296_tableSetup`;

CREATE TABLE `sync` (
  `folderIn` VARCHAR(64),
  `folderOut` VARCHAR(64),
  PRIMARY KEY (`folderIn`, `folderOut`)
) CHARACTER SET latin1;

CREATE TABLE `location` (
  `folderIn` VARCHAR(64),
  `folderOut` VARCHAR(64),
  `folderInLocation` VARCHAR(64),
  `folderInId` VARCHAR(64),
  PRIMARY KEY (`folderIn`, `folderOut`, `folderInLocation`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_360296_tableSetup') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_360296_tableSetup') AS relationships;
DROP DATABASE `db_360296_tableSetup`;
UNINSTALL EXTENSION vsql_schematron;
