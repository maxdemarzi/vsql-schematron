INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379761_db
--echo #
CREATE DATABASE `db_379761_db`;
USE `db_379761_db`;

CREATE TABLE `member` (
  `id` VARCHAR(64),
  `pw` VARCHAR(64),
  `email` VARCHAR(64),
  `date` DATETIME,
  `phone` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `address` (
  `id` VARCHAR(64),
  `adrs` VARCHAR(64),
  `dadrs` VARCHAR(64),
  `phone` VARCHAR(64),
  `etc` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `paymentcard` (
  `cardnumber` VARCHAR(64),
  `cardmm` VARCHAR(64),
  `cardyy` VARCHAR(64),
  `cardcvc` VARCHAR(64),
  `cardpw` VARCHAR(64),
  PRIMARY KEY (`cardnumber`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379761_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379761_db') AS relationships;
DROP DATABASE `db_379761_db`;
UNINSTALL EXTENSION vsql_schematron;
