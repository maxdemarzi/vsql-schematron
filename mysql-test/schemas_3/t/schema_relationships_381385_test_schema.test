INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 381385_test_schema
--echo #
CREATE DATABASE `db_381385_test_schema`;
USE `db_381385_test_schema`;
CREATE TABLE `artist` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `album` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `artist_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_381385_test_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_381385_test_schema') AS relationships;
DROP DATABASE `db_381385_test_schema`;
UNINSTALL EXTENSION vsql_schematron;
