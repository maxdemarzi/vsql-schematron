INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 322968_SQLDump
--echo #
CREATE DATABASE `db_322968_SQLDump`;
USE `db_322968_SQLDump`;

CREATE TABLE `PHONE` (
  `ID` INT,
  `TYPE` VARCHAR(64),
  `NUM` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `PARKING_SPACE` (
  `ID` INT,
  `LOT` INT,
  `LOCATION` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `DEPARTMENT` (
  `ID` INT,
  `NAME` VARCHAR(64),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMPLOYEE` (
  `ID` INT,
  `NAME` VARCHAR(64),
  `SALARY` INT,
  `PSPACE_ID` INT,
  `DEPARTMENT_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMP_PHONE` (
  `PHONE_ID` INT,
  `EMP_ID` INT,
  PRIMARY KEY (`PHONE_ID`, `EMP_ID`)
) CHARACTER SET latin1;

CREATE TABLE `EMP_PROJ` (
  `PROJ_ID` INT,
  `EMP_ID` INT,
  PRIMARY KEY (`PROJ_ID`, `EMP_ID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_322968_SQLDump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_322968_SQLDump') AS relationships;
DROP DATABASE `db_322968_SQLDump`;
UNINSTALL EXTENSION vsql_schematron;
