INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 392244_createdb
--echo #
CREATE DATABASE `db_392244_createdb`;
USE `db_392244_createdb`;

CREATE TABLE `userbase` (
  `id` INT,
  `username` VARCHAR(64),
  `password` VARCHAR(64),
  `fullname` VARCHAR(64),
  `emailaddress` VARCHAR(64),
  `enabled` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `lft` INT,
  `rgt` INT,
  `description` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_role_map` (
  `user_id` INT,
  `role_id` INT
) CHARACTER SET latin1;

CREATE TABLE `authorities` (
  `id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `role_authority_map` (
  `role_id` INT,
  `authority_id` INT
) CHARACTER SET latin1;

CREATE TABLE `settings` (
  `id` INT,
  `name` VARCHAR(64),
  `value` VARCHAR(64),
  `sortindex` INT,
  `enabled` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_setting_map` (
  `user_id` INT,
  `setting_id` INT
) CHARACTER SET latin1;

CREATE TABLE `tokens` (
  `id` INT,
  `value` VARCHAR(64),
  `type` VARCHAR(64),
  `expiration` DATETIME,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_392244_createdb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_392244_createdb') AS relationships;
DROP DATABASE `db_392244_createdb`;
UNINSTALL EXTENSION vsql_schematron;
