INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 365527_skuldb
--echo #
CREATE DATABASE `db_365527_skuldb`;
USE `db_365527_skuldb`;

CREATE TABLE `USUARIOS` (
  `id_usuario` INT,
  `nickname` VARCHAR(64),
  `password` VARCHAR(64),
  `email` VARCHAR(64),
  `nombre` VARCHAR(64),
  `apellidos` VARCHAR(64),
  PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;

CREATE TABLE `TEMAS` (
  `id_tema` INT,
  `titulo` VARCHAR(64),
  `texto` VARCHAR(64),
  `fecha` DATETIME,
  `etiqueta` VARCHAR(64),
  `id_usuario` INT,
  PRIMARY KEY (`id_tema`)
) CHARACTER SET latin1;

CREATE TABLE `RESPUESTAS` (
  `id_respuesta` INT,
  `texto` VARCHAR(64),
  `fecha` DATETIME,
  `id_usuario` INT,
  `id_tema` INT,
  PRIMARY KEY (`id_respuesta`)
) CHARACTER SET latin1;

CREATE TABLE `VALORACIONES` (
  `id_valoracion` INT,
  `id_usuario` INT,
  `id_tema` INT,
  `id_respuesta` INT,
  PRIMARY KEY (`id_valoracion`)
) CHARACTER SET latin1;

CREATE TABLE `ARCHIVOSADJUNTOS` (
  `id_archivo` INT,
  `nombre` VARCHAR(64),
  `src` VARCHAR(64),
  `id_tema` INT,
  `id_respuesta` INT,
  PRIMARY KEY (`id_archivo`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_365527_skuldb') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_365527_skuldb') AS relationships;
DROP DATABASE `db_365527_skuldb`;
UNINSTALL EXTENSION vsql_schematron;
