INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354751_000003_blogs_and_posts.up
--echo #
CREATE DATABASE `db_354751_000003_blogs_and_posts_up`;
USE `db_354751_000003_blogs_and_posts_up`;
CREATE TABLE `blogs` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `userplant_id` BIGINT,
  `name_blog` VARCHAR(50),
  `description` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `posts` (
  `id` BIGINT NOT NULL,
  `blog_id` BIGINT,
  `text_post` TEXT,
  `created_at` TIMESTAMP NULL,
  `modified_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354751_000003_blogs_and_posts_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354751_000003_blogs_and_posts_up') AS relationships;
DROP DATABASE `db_354751_000003_blogs_and_posts_up`;
UNINSTALL EXTENSION vsql_schematron;
