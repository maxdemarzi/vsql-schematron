INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 340408_migration
--echo #
CREATE DATABASE `db_340408_migration`;
USE `db_340408_migration`;

CREATE TABLE `accounts` (
  `id` VARCHAR(255),
  `authentication_id` VARCHAR(255),
  `name` VARCHAR(255),
  `email` VARCHAR(255),
  `last_name` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authentications` (
  `id` VARCHAR(255),
  `account_id` VARCHAR(255),
  `sessions_number` INT,
  `password` VARCHAR(255),
  `failed_attempts` INT,
  `locked` VARCHAR(255),
  `status` VARCHAR(255),
  `active` VARCHAR(255),
  `auth_groups_id` VARCHAR(255),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `authentication__sessions` (
  `authentication_id` VARCHAR(255),
  `session_id` VARCHAR(255),
  PRIMARY KEY (`authentication_id`, `session_id`)
) CHARACTER SET latin1;

CREATE TABLE `sessions` (
  `id` VARCHAR(255),
  `ip` VARCHAR(255),
  `device` VARCHAR(255),
  `active` VARCHAR(255),
  `created_at` DATETIME,
  `expires_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups` (
  `id` VARCHAR(255),
  `title` VARCHAR(255),
  `created_at` DATETIME,
  `active` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_groups__permissions` (
  `auth_group_id` VARCHAR(255),
  `permission_id` VARCHAR(255),
  PRIMARY KEY (`auth_group_id`, `permission_id`)
) CHARACTER SET latin1;

CREATE TABLE `permissions` (
  `name` VARCHAR(255),
  `action` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_340408_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_340408_migration') AS relationships;
DROP DATABASE `db_340408_migration`;
UNINSTALL EXTENSION vsql_schematron;
