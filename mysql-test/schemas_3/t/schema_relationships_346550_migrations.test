INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 346550_migrations
--echo #
CREATE DATABASE `db_346550_migrations`;
USE `db_346550_migrations`;

CREATE TABLE `users` (
  `id` INT,
  `email` VARCHAR(64),
  `password` VARCHAR(64),
  `slug` VARCHAR(64),
  `bio` VARCHAR(64),
  `username` VARCHAR(64),
  `profilePic` VARCHAR(64),
  `isActive` INT,
  `resetToken` VARCHAR(64),
  `createdAt` DATETIME,
  `lastActive` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `followers` (
  `id` INT,
  `subjectId` INT,
  `userId` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `id` INT,
  `userId` INT,
  `content` VARCHAR(64),
  `tags` VARCHAR(64),
  `img` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `postId` INT,
  `userId` INT,
  `content` VARCHAR(64),
  `createdAt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_346550_migrations') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_346550_migrations') AS relationships;
DROP DATABASE `db_346550_migrations`;
UNINSTALL EXTENSION vsql_schematron;
