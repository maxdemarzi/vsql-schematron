INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 323197_1622692685_initial_schema.up
--echo #
CREATE DATABASE `db_323197_1622692685_initial_schema_up`;
USE `db_323197_1622692685_initial_schema_up`;
CREATE TABLE `users` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `email` TEXT,
  `hashed_password` VARCHAR(50),
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lists` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `user_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `source` TEXT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `list_items` (
  `id` BIGINT NOT NULL,
  `quantity` BIGINT,
  `collected` BOOLEAN,
  `list_id` BIGINT,
  `item_id` BIGINT,
  `created_at` TIMESTAMP NULL,
  `updated_at` TIMESTAMP NULL,
  `deleted_at` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_323197_1622692685_initial_schema_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_323197_1622692685_initial_schema_up') AS relationships;
DROP DATABASE `db_323197_1622692685_initial_schema_up`;
UNINSTALL EXTENSION vsql_schematron;
