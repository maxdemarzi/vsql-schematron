INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 317427_up
--echo #
CREATE DATABASE `db_317427_up`;
USE `db_317427_up`;

CREATE TABLE `splinter_nodes` (
  `identity` VARCHAR(64),
  `display_name` VARCHAR(64),
  PRIMARY KEY (`identity`)
) CHARACTER SET latin1;

CREATE TABLE `splinter_nodes_endpoints` (
  `identity` VARCHAR(64),
  `endpoint` VARCHAR(64),
  PRIMARY KEY (`identity`, `endpoint`)
) CHARACTER SET latin1;

CREATE TABLE `splinter_nodes_keys` (
  `identity` VARCHAR(64),
  `key` VARCHAR(64),
  PRIMARY KEY (`identity`, `key`)
) CHARACTER SET latin1;

CREATE TABLE `splinter_nodes_metadata` (
  `identity` VARCHAR(64),
  `key` VARCHAR(64),
  `value` VARCHAR(64),
  PRIMARY KEY (`identity`, `key`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_317427_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_317427_up') AS relationships;
DROP DATABASE `db_317427_up`;
UNINSTALL EXTENSION vsql_schematron;
