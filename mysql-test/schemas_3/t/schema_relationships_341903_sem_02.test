INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 341903_sem_02
--echo #
CREATE DATABASE `db_341903_sem_02`;
USE `db_341903_sem_02`;

CREATE TABLE `planes` (
  `id` DECIMAL(10,2),
  `first_class` DECIMAL(10,2),
  `business_class` DECIMAL(10,2),
  `economy_class` DECIMAL(10,2),
  `model` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `flight` (
  `num` VARCHAR(64),
  `date_out` DATETIME,
  `date_in` DATETIME,
  `airport_out` VARCHAR(64),
  `airport_in` VARCHAR(64),
  `plane_id` DECIMAL(10,2),
  PRIMARY KEY (`num`, `date_out`)
) CHARACTER SET latin1;

CREATE TABLE `passengers` (
  `full_name` VARCHAR(64),
  `doc_type` VARCHAR(64),
  `series_number` VARCHAR(64),
  `born` DATETIME,
  `id` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `tickets` (
  `num` DECIMAL(10,2),
  `position` VARCHAR(64),
  `class_type` VARCHAR(64),
  `price` DECIMAL(10,2),
  `bagage` VARCHAR(64),
  `flight_num` VARCHAR(64),
  `date_out` DATETIME,
  `passenger_id` DECIMAL(10,2)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_341903_sem_02') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_341903_sem_02') AS relationships;
DROP DATABASE `db_341903_sem_02`;
UNINSTALL EXTENSION vsql_schematron;
