INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 376680_dump
--echo #
CREATE DATABASE `db_376680_dump`;
USE `db_376680_dump`;

CREATE TABLE `auth_assignment` (
  `item_name` VARCHAR(64),
  `user_id` VARCHAR(64),
  `created_at` INT,
  PRIMARY KEY (`item_name`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item` (
  `name` VARCHAR(64),
  `type` INT,
  `description` VARCHAR(64),
  `rule_name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `auth_item_child` (
  `parent` VARCHAR(64),
  `child` VARCHAR(64),
  PRIMARY KEY (`parent`, `child`)
) CHARACTER SET latin1;

CREATE TABLE `auth_rule` (
  `name` VARCHAR(64),
  `data` VARCHAR(64),
  `created_at` INT,
  `updated_at` INT,
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `menu` (
  `id` INT,
  `name` VARCHAR(64),
  `parent` INT,
  `route` VARCHAR(64),
  `order` INT,
  `data` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migration` (
  `version` VARCHAR(64),
  `apply_time` INT,
  PRIMARY KEY (`version`)
) CHARACTER SET latin1;

CREATE TABLE `profile` (
  `user_id` INT,
  `name` VARCHAR(64),
  `public_email` VARCHAR(64),
  `gravatar_email` VARCHAR(64),
  `gravatar_id` VARCHAR(64),
  `location` VARCHAR(64),
  `website` VARCHAR(64),
  `bio` VARCHAR(64),
  `timezone` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_376680_dump') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_376680_dump') AS relationships;
DROP DATABASE `db_376680_dump`;
UNINSTALL EXTENSION vsql_schematron;
