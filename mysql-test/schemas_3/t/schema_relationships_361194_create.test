INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 361194_create
--echo #
CREATE DATABASE `db_361194_create`;
USE `db_361194_create`;

CREATE TABLE `Keys` (
  `entity` VARCHAR(64),
  `maxId` INT,
  PRIMARY KEY (`entity`)
) CHARACTER SET latin1;

CREATE TABLE `Users` (
  `userId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`userId`)
) CHARACTER SET latin1;

CREATE TABLE `TurnstileEvents` (
  `userId` INT,
  `eventId` INT,
  `eventType` VARCHAR(64),
  `eventTime` DATETIME,
  PRIMARY KEY (`userId`, `eventId`)
) CHARACTER SET latin1;

CREATE TABLE `SubscriptionEvents` (
  `userId` INT,
  `eventId` INT,
  `endTime` DATETIME,
  PRIMARY KEY (`userId`, `eventId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_361194_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_361194_create') AS relationships;
DROP DATABASE `db_361194_create`;
UNINSTALL EXTENSION vsql_schematron;
