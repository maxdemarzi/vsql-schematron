INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 389218_schema
--echo #
CREATE DATABASE `db_389218_schema`;
USE `db_389218_schema`;

CREATE TABLE `project` (
  `project_id` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`project_id`)
) CHARACTER SET latin1;

CREATE TABLE `environment` (
  `project_id` VARCHAR(255),
  `environment_id` VARCHAR(255),
  `description` VARCHAR(255),
  `policy_arn` VARCHAR(255),
  `roles` VARCHAR(255),
  `groups` VARCHAR(255),
  PRIMARY KEY (`project_id`, `environment_id`)
) CHARACTER SET latin1;

CREATE TABLE `secret` (
  `project_id` VARCHAR(255),
  `environment_id` VARCHAR(255),
  `secret_id` VARCHAR(255),
  `description` VARCHAR(255),
  PRIMARY KEY (`project_id`, `environment_id`, `secret_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_389218_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_389218_schema') AS relationships;
DROP DATABASE `db_389218_schema`;
UNINSTALL EXTENSION vsql_schematron;
