INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 318290_schema
--echo #
CREATE DATABASE `db_318290_schema`;
USE `db_318290_schema`;

CREATE TABLE `manufacturers` (
  `id` INT,
  `name` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `types` (
  `name` VARCHAR(255),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `models` (
  `id` INT,
  `name` VARCHAR(255),
  `manufacturer_id` INT,
  `type_name` VARCHAR(255),
  `year` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bikes` (
  `id` INT,
  `model_id` INT,
  `size` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `bike_colors` (
  `bike_id` INT,
  `color` VARCHAR(255),
  PRIMARY KEY (`bike_id`, `color`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_318290_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_318290_schema') AS relationships;
DROP DATABASE `db_318290_schema`;
UNINSTALL EXTENSION vsql_schematron;
