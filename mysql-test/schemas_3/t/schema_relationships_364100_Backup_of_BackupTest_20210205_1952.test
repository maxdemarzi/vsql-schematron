INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 364100_Backup_of_BackupTest_20210205_1952
--echo #
CREATE DATABASE `db_364100_Backup_of_BackupTest_20210205_1952`;
USE `db_364100_Backup_of_BackupTest_20210205_1952`;

CREATE TABLE `account` (
  `AccountNumber` VARCHAR(255),
  `AccountType` VARCHAR(255),
  `CustomerID` VARCHAR(255),
  PRIMARY KEY (`AccountNumber`)
) CHARACTER SET latin1;

CREATE TABLE `accounttype` (
  `AccountType` VARCHAR(255),
  `AccountName` VARCHAR(255),
  `Description` VARCHAR(255),
  PRIMARY KEY (`AccountType`)
) CHARACTER SET latin1;

CREATE TABLE `branch` (
  `BranchCode` VARCHAR(255),
  `BranchName` VARCHAR(255),
  `IFSC_Code` VARCHAR(255),
  `state` VARCHAR(255),
  PRIMARY KEY (`BranchCode`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_364100_Backup_of_BackupTest_20210205_1952') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_364100_Backup_of_BackupTest_20210205_1952') AS relationships;
DROP DATABASE `db_364100_Backup_of_BackupTest_20210205_1952`;
UNINSTALL EXTENSION vsql_schematron;
