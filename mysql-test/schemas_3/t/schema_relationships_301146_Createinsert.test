INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 301146_Createinsert
--echo #
CREATE DATABASE `db_301146_Createinsert`;
USE `db_301146_Createinsert`;
CREATE TABLE `Customer` (
  `custID` DECIMAL(10,2) NOT NULL,
  `custName` VARCHAR(50),
  `custPhone` VARCHAR(50),
  `custEmail` VARCHAR(50),
  PRIMARY KEY (`custID`)
) CHARACTER SET latin1;
CREATE TABLE `Species` (
  `speciesCode` DECIMAL(10,2) NOT NULL,
  `speciesName` VARCHAR(50),
  `speciesPrice` DECIMAL(10,2),
  PRIMARY KEY (`speciesCode`)
) CHARACTER SET latin1;
CREATE TABLE `Animal` (
  `animalID` DECIMAL(10,2) NOT NULL,
  `animalName` VARCHAR(50),
  `dateShopPurchased` DATE,
  `speciesCode` DECIMAL(10,2),
  PRIMARY KEY (`animalID`)
) CHARACTER SET latin1;
CREATE TABLE `AnimalSale` (
  `custID` DECIMAL(10,2) NOT NULL,
  `animalID` DECIMAL(10,2) NOT NULL,
  `saleDate` DATE,
  PRIMARY KEY (`custID`, `animalID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_301146_Createinsert') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_301146_Createinsert') AS relationships;
DROP DATABASE `db_301146_Createinsert`;
UNINSTALL EXTENSION vsql_schematron;
