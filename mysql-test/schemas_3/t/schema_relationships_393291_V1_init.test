INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 393291_V1__init
--echo #
CREATE DATABASE `db_393291_V1_init`;
USE `db_393291_V1_init`;

CREATE TABLE `first` (
  `id` INT,
  `first_field` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `second` (
  `id` INT,
  `second_field` VARCHAR(64),
  `fk_first` INT,
  `fk_second` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `third` (
  `id` INT,
  `third_field` VARCHAR(64),
  `fk_second` INT,
  `fk_first` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_393291_V1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_393291_V1_init') AS relationships;
DROP DATABASE `db_393291_V1_init`;
UNINSTALL EXTENSION vsql_schematron;
