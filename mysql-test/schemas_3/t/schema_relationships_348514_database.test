INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348514_database
--echo #
CREATE DATABASE `db_348514_database`;
USE `db_348514_database`;

CREATE TABLE `users` (
  `user_id` INT,
  `username` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `section` (
  `section_id` INT,
  `section_name` VARCHAR(64),
  `sorting_order` INT,
  PRIMARY KEY (`section_id`)
) CHARACTER SET latin1;

CREATE TABLE `grocery` (
  `grocery_id` INT,
  `grocery_name` VARCHAR(64),
  `section_id` INT,
  PRIMARY KEY (`grocery_id`)
) CHARACTER SET latin1;

CREATE TABLE `recipe` (
  `recipe_id` INT,
  `recipe_name` VARCHAR(64),
  `instructions` VARCHAR(64),
  PRIMARY KEY (`recipe_id`)
) CHARACTER SET latin1;

CREATE TABLE `ingredient` (
  `ingredient_id` INT,
  `grocery_id` INT,
  `ingredient_amount` INT,
  `ingredient_unit` VARCHAR(64),
  PRIMARY KEY (`ingredient_id`)
) CHARACTER SET latin1;

CREATE TABLE `shoplist` (
  `user_id` INT,
  `grocery_id` INT,
  PRIMARY KEY (`user_id`, `grocery_id`)
) CHARACTER SET latin1;

CREATE TABLE `ingredients` (
  `recipe_id` INT,
  `ingredient_id` INT,
  PRIMARY KEY (`recipe_id`, `ingredient_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348514_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348514_database') AS relationships;
DROP DATABASE `db_348514_database`;
UNINSTALL EXTENSION vsql_schematron;
