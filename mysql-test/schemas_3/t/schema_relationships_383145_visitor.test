INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383145_visitor
--echo #
CREATE DATABASE `db_383145_visitor`;
USE `db_383145_visitor`;

CREATE TABLE `canton` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `id_provincia` INT,
  `activo` INT
) CHARACTER SET latin1;

CREATE TABLE `entidad` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `id_parroquia` INT,
  `activo` INT,
  `fecha_ingreso` DATETIME,
  `fecha_edicion` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `pais` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `activo` INT,
  `fecha_ingreso` DATETIME,
  `fecha_edicion` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `parroquia` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `id_canton` INT,
  `activo` INT,
  `fecha_ingreso` DATETIME,
  `fecha_edicion` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `provincia` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `id_pais` INT,
  `activo` INT,
  `fecha_ingreso` DATETIME,
  `fecha_edicion` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `unidad` (
  `id` INT,
  `nombre` VARCHAR(64),
  `siglas` VARCHAR(64),
  `activo` INT,
  `fecha_ingreso` DATETIME,
  `fecha_edicion` DATETIME,
  `id_entidad` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383145_visitor') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383145_visitor') AS relationships;
DROP DATABASE `db_383145_visitor`;
UNINSTALL EXTENSION vsql_schematron;
