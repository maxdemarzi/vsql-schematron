INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 322370_inventory
--echo #
CREATE DATABASE `db_322370_inventory`;
USE `db_322370_inventory`;

CREATE TABLE `devis` (
  `id` INT,
  `user_id` INT,
  `client_id` INT,
  `total_amount` INT,
  `finalized_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `validate` INT,
  `reference` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `failed_jobs` (
  `id` INT,
  `connection` VARCHAR(64),
  `queue` VARCHAR(64),
  `payload` VARCHAR(64),
  `exception` VARCHAR(64),
  `failed_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `migrations` (
  `id` INT,
  `migration` VARCHAR(64),
  `batch` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `password_resets` (
  `email` VARCHAR(64),
  `token` VARCHAR(64),
  `created_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `payment_methods` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `products` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `product_category_id` INT,
  `price` INT,
  `stock` INT,
  `stock_defective` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `product_unite_id` INT,
  `reference` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `product_categories` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `product_devis` (
  `id` INT,
  `devis_id` INT,
  `product_id` INT,
  `qty` INT,
  `price` INT,
  `total_amount` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `providers` (
  `id` INT,
  `name` VARCHAR(64),
  `description` VARCHAR(64),
  `paymentinfo` VARCHAR(64),
  `email` VARCHAR(64),
  `phone` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `receipts` (
  `id` INT,
  `title` VARCHAR(64),
  `provider_id` INT,
  `user_id` INT,
  `paid` INT,
  `finalized_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `received_products` (
  `id` INT,
  `receipt_id` INT,
  `product_id` INT,
  `stock` INT,
  `stock_defective` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `roles` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `id` INT,
  `user_id` INT,
  `client_id` INT,
  `total_amount` INT,
  `paid` INT,
  `finalized_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `reference` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `sold_products` (
  `id` INT,
  `sale_id` INT,
  `product_id` INT,
  `qty` INT,
  `price` INT,
  `total_amount` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `transactions` (
  `id` INT,
  `type` VARCHAR(64),
  `title` VARCHAR(64),
  `reference` VARCHAR(64),
  `client_id` INT,
  `sale_id` INT,
  `provider_id` INT,
  `transfer_id` INT,
  `payment_method_id` INT,
  `amount` INT,
  `user_id` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `transfers` (
  `id` INT,
  `title` VARCHAR(64),
  `sender_method_id` INT,
  `receiver_method_id` INT,
  `sended_amount` INT,
  `received_amount` INT,
  `reference` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `unites` (
  `id` INT,
  `name` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `users` (
  `id` INT,
  `name` VARCHAR(64),
  `email` VARCHAR(64),
  `email_verified_at` DATETIME,
  `password` VARCHAR(64),
  `remember_token` VARCHAR(64),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  `deleted_at` DATETIME,
  `users_role_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_322370_inventory') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_322370_inventory') AS relationships;
DROP DATABASE `db_322370_inventory`;
UNINSTALL EXTENSION vsql_schematron;
