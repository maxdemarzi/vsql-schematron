INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 333715_structure
--echo #
CREATE DATABASE `db_333715_structure`;
USE `db_333715_structure`;

CREATE TABLE `Role` (
  `roleId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`roleId`)
) CHARACTER SET latin1;

CREATE TABLE `Account` (
  `accountId` INT,
  `login` VARCHAR(64),
  `password` VARCHAR(64),
  PRIMARY KEY (`accountId`)
) CHARACTER SET latin1;

CREATE TABLE `AccountRole` (
  `accountId` INT,
  `roleId` INT,
  PRIMARY KEY (`accountId`, `roleId`)
) CHARACTER SET latin1;

CREATE TABLE `Country` (
  `countryId` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`countryId`)
) CHARACTER SET latin1;

CREATE TABLE `City` (
  `cityId` INT,
  `name` VARCHAR(64),
  `countryId` INT,
  PRIMARY KEY (`cityId`)
) CHARACTER SET latin1;

CREATE TABLE `Session` (
  `sessionId` INT,
  `accountId` INT,
  `token` VARCHAR(64),
  `ip` VARCHAR(64),
  `data` VARCHAR(64),
  PRIMARY KEY (`sessionId`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_333715_structure') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_333715_structure') AS relationships;
DROP DATABASE `db_333715_structure`;
UNINSTALL EXTENSION vsql_schematron;
