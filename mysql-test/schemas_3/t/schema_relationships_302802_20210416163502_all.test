INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 302802_20210416163502_all
--echo #
CREATE DATABASE `db_302802_20210416163502_all`;
USE `db_302802_20210416163502_all`;

CREATE TABLE `symptoms` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `diseases` (
  `id` INT,
  `name` VARCHAR(64),
  `symptoms` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `departments` (
  `id` INT,
  `name` VARCHAR(64),
  `diseases` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `doctors` (
  `id` INT,
  `name` VARCHAR(64),
  `occupied` BOOL,
  `department` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `chances` (
  `disease` INT,
  `chance` INT,
  PRIMARY KEY (`disease`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_302802_20210416163502_all') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_302802_20210416163502_all') AS relationships;
DROP DATABASE `db_302802_20210416163502_all`;
UNINSTALL EXTENSION vsql_schematron;
