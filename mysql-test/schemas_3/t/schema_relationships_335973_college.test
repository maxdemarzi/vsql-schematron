INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335973_college
--echo #
CREATE DATABASE `db_335973_college`;
USE `db_335973_college`;

CREATE TABLE `professors` (
  `prof_id` INT,
  `name` VARCHAR(64),
  `rank` INT,
  `age` INT,
  `specialization` VARCHAR(64),
  PRIMARY KEY (`prof_id`)
) CHARACTER SET latin1;

CREATE TABLE `projects` (
  `project_num` VARCHAR(64),
  `sponsor` VARCHAR(64),
  `start_date` DATETIME,
  `end_date` DATETIME,
  `budget` DECIMAL(10,2),
  PRIMARY KEY (`project_num`)
) CHARACTER SET latin1;

CREATE TABLE `students` (
  `usn` VARCHAR(64),
  `name` VARCHAR(64),
  `age` INT,
  `degree` VARCHAR(64),
  `prof_id` INT,
  PRIMARY KEY (`usn`, `prof_id`)
) CHARACTER SET latin1;

CREATE TABLE `prof_works` (
  `prof_work_id` INT,
  `prof_id` INT,
  `project_num` VARCHAR(64),
  PRIMARY KEY (`prof_work_id`, `prof_id`, `project_num`)
) CHARACTER SET latin1;

CREATE TABLE `student_works` (
  `student_work_id` INT,
  `usn` VARCHAR(64),
  `project_num` VARCHAR(64),
  PRIMARY KEY (`student_work_id`, `usn`, `project_num`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335973_college') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335973_college') AS relationships;
DROP DATABASE `db_335973_college`;
UNINSTALL EXTENSION vsql_schematron;
