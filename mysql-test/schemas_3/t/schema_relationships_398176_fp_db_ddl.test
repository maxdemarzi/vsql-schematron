INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 398176_fp_db.ddl
--echo #
CREATE DATABASE `db_398176_fp_db_ddl`;
USE `db_398176_fp_db_ddl`;
CREATE TABLE `user` (
  `id` BIGINT NOT NULL,
  `user_reference` VARCHAR(50),
  `email` VARCHAR(50),
  `first_name` VARCHAR(50),
  `last_name` VARCHAR(50),
  `username` VARCHAR(50),
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallet_account` (
  `id` BIGINT NOT NULL,
  `user_id` BIGINT,
  `created_at` DATETIME,
  `enabled` BOOLEAN,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallet_credit_transaction` (
  `id` BIGINT NOT NULL,
  `transaction_reference` VARCHAR(50),
  `wallet_account_id` BIGINT,
  `amount` BIGINT,
  `currency` VARCHAR(50),
  `transaction_type` VARCHAR(50),
  `method` VARCHAR(50),
  `account_type` VARCHAR(50),
  `description` VARCHAR(50),
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_398176_fp_db_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_398176_fp_db_ddl') AS relationships;
DROP DATABASE `db_398176_fp_db_ddl`;
UNINSTALL EXTENSION vsql_schematron;
