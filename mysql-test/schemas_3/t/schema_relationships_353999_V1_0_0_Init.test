INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 353999_V1.0.0__Init
--echo #
CREATE DATABASE `db_353999_V1_0_0_Init`;
USE `db_353999_V1_0_0_Init`;

CREATE TABLE `posts` (
  `id` INT,
  `is_active` VARCHAR(64),
  `moderation_status` VARCHAR(64),
  `text` VARCHAR(64),
  `time` DATETIME,
  `title` VARCHAR(64),
  `view_count` INT,
  `user_id` INT,
  `moderator_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `id` INT,
  `text` VARCHAR(64),
  `time` DATETIME,
  `parent_id` INT,
  `post_id` INT,
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `posts_tags` (
  `post_id` INT,
  `tag_id` INT,
  PRIMARY KEY (`post_id`, `tag_id`)
) CHARACTER SET latin1;

CREATE TABLE `captcha_codes` (
  `id` INT,
  `code` VARCHAR(64),
  `secret_code` VARCHAR(64),
  `time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_353999_V1_0_0_Init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_353999_V1_0_0_Init') AS relationships;
DROP DATABASE `db_353999_V1_0_0_Init`;
UNINSTALL EXTENSION vsql_schematron;
