INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 379961_create_tables
--echo #
CREATE DATABASE `db_379961_create_tables`;
USE `db_379961_create_tables`;

CREATE TABLE `reports` (
  `ReportID` INT,
  `when_created` DATETIME,
  `username` VARCHAR(64),
  `submit_lat` DECIMAL(10,2),
  `submit_long` DECIMAL(10,2),
  `location` VARCHAR(64),
  `when_occurred` VARCHAR(64),
  `room_number` INT,
  `media_available` VARCHAR(64),
  `reporter_details` VARCHAR(64),
  `police_details` VARCHAR(64),
  PRIMARY KEY (`ReportID`)
) CHARACTER SET latin1;

CREATE TABLE `people` (
  `PersonID` INT,
  `ReportID` INT,
  `person_type` VARCHAR(64),
  `name` VARCHAR(64),
  `sex` VARCHAR(64),
  `race` VARCHAR(64),
  `height_inches` INT,
  `age_low` INT,
  `age_high` INT,
  `build` VARCHAR(64),
  `hair_color` VARCHAR(64),
  `hair_length` VARCHAR(64),
  `eye_color` VARCHAR(64),
  `clothing` VARCHAR(64),
  `reporter_details` VARCHAR(64),
  `police_details` VARCHAR(64),
  PRIMARY KEY (`PersonID`)
) CHARACTER SET latin1;

CREATE TABLE `vehicles` (
  `VehicleID` INT,
  `ReportID` INT,
  `driven_by` VARCHAR(64),
  `color` VARCHAR(64),
  `make` VARCHAR(64),
  `model` VARCHAR(64),
  `plate` VARCHAR(64),
  `state` VARCHAR(64),
  `reporter_details` VARCHAR(64),
  `police_details` VARCHAR(64),
  PRIMARY KEY (`VehicleID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_379961_create_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_379961_create_tables') AS relationships;
DROP DATABASE `db_379961_create_tables`;
UNINSTALL EXTENSION vsql_schematron;
