INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 326768_db_resto
--echo #
CREATE DATABASE `db_326768_db_resto`;
USE `db_326768_db_resto`;

CREATE TABLE `food` (
  `id` INT,
  `name` VARCHAR(255),
  `detail` VARCHAR(255),
  `price` INT,
  `category` INT,
  `status` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `food_category` (
  `id` INT,
  `name` VARCHAR(255),
  `is_food` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `food_image` (
  `id` INT,
  `food_id` INT,
  `img` VARCHAR(255)
) CHARACTER SET latin1;

CREATE TABLE `order` (
  `id` INT,
  `user_id` INT,
  `order_time` DATETIME,
  `total_price` INT,
  `is_payed` INT,
  `step` INT,
  `table_number` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `order_item` (
  `id` INT,
  `food_id` INT,
  `qty` INT,
  `note` VARCHAR(255),
  `approved` INT,
  `order_id` INT
) CHARACTER SET latin1;

CREATE TABLE `topup_history` (
  `id` INT,
  `user_id` INT,
  `nominal` INT,
  `topup_date` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `user` (
  `id` INT,
  `username` VARCHAR(255),
  `email` VARCHAR(255),
  `password_hash` VARCHAR(255),
  `status` INT,
  `auth_key` VARCHAR(255),
  `password_reset_token` VARCHAR(255),
  `account_activation_token` VARCHAR(255),
  `role` INT,
  `current_saldo` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_326768_db_resto') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_326768_db_resto') AS relationships;
DROP DATABASE `db_326768_db_resto`;
UNINSTALL EXTENSION vsql_schematron;
