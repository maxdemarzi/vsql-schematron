INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312111_schema
--echo #
CREATE DATABASE `db_312111_schema`;
USE `db_312111_schema`;

CREATE TABLE `person` (
  `id` INT,
  `name` VARCHAR(255),
  `auth0_sub` VARCHAR(255),
  `email` VARCHAR(255),
  `is_admin` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `id` INT,
  `name` VARCHAR(255),
  `user_id` INT,
  `s3_bucket` VARCHAR(255),
  `s3_key` VARCHAR(255),
  `program_filename` VARCHAR(255),
  `spec_filename` VARCHAR(255),
  `creation_dt` DATETIME,
  `is_compilation_error` VARCHAR(255),
  `compilation_error_message` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `project_tag` (
  `id` INT,
  `project_id` INT,
  `tag` VARCHAR(255),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `job` (
  `id` INT,
  `project_id` INT,
  `benchmark_name` VARCHAR(255),
  `spec_name` VARCHAR(255),
  `kprove` VARCHAR(255),
  `semantics` VARCHAR(255),
  `request_dt` DATETIME,
  `s3_bucket` VARCHAR(255),
  `s3_key` VARCHAR(255),
  `spec_filename` VARCHAR(255),
  `timeout_sec` INT,
  `memlimit_mb` INT,
  `processing_dt` DATETIME,
  `output_log_s3_key` VARCHAR(255),
  `error_log_s3_key` VARCHAR(255),
  `status_code` INT,
  `timed_out` VARCHAR(255),
  `proved` VARCHAR(255),
  `completed_dt` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312111_schema') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312111_schema') AS relationships;
DROP DATABASE `db_312111_schema`;
UNINSTALL EXTENSION vsql_schematron;
