INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363866_db
--echo #
CREATE DATABASE `db_363866_db`;
USE `db_363866_db`;
CREATE TABLE `game` (
  `game_id` INT NOT NULL,
  `player_x_alias` VARCHAR(50),
  `player_y_alias` VARCHAR(50),
  `winner` VARCHAR(50),
  `game_over` TINYINT,
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`game_id`)
) CHARACTER SET latin1;
CREATE TABLE `game_move` (
  `move_id` BIGINT NOT NULL,
  `game_id` INT,
  `player_x_move` VARCHAR(50),
  `player_y_move` VARCHAR(50),
  `created` DATETIME,
  `modified` DATETIME,
  PRIMARY KEY (`move_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363866_db') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363866_db') AS relationships;
DROP DATABASE `db_363866_db`;
UNINSTALL EXTENSION vsql_schematron;
