INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 366183_init
--echo #
CREATE DATABASE `db_366183_init`;
USE `db_366183_init`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `login_pass` VARCHAR(50),
  `login_salt` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `passwords` (
  `id` INT NOT NULL,
  `pass` VARCHAR(50),
  `name` VARCHAR(50),
  `nonce` VARCHAR(50),
  `tag` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `devices` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `user_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_366183_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_366183_init') AS relationships;
DROP DATABASE `db_366183_init`;
UNINSTALL EXTENSION vsql_schematron;
