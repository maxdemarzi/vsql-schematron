INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 348407_custom_mysql
--echo #
CREATE DATABASE `db_348407_custom_mysql`;
USE `db_348407_custom_mysql`;
CREATE TABLE `cus_custom` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `address` VARCHAR(50),
  `phone` VARCHAR(50),
  `position` VARCHAR(50),
  `area` VARCHAR(50),
  `house_property` VARCHAR(50),
  `center` VARCHAR(50),
  `buchu` VARCHAR(50),
  `kezu` VARCHAR(50),
  `leixing` VARCHAR(50),
  `leaseholder` VARCHAR(50),
  `leaseholder_phone` VARCHAR(50),
  `create_by` VARCHAR(50),
  `create_date` DATETIME,
  `update_by` VARCHAR(50),
  `update_date` DATETIME,
  `remarks` VARCHAR(50),
  `del_flag` CHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cus_equipment` (
  `id` VARCHAR(50) NOT NULL,
  `nam` VARCHAR(50),
  `type` VARCHAR(50),
  `mac` VARCHAR(50),
  `number` VARCHAR(50),
  `create_by` VARCHAR(50),
  `create_date` DATETIME,
  `update_by` VARCHAR(50),
  `update_date` DATETIME,
  `remarks` VARCHAR(50),
  `del_flag` CHAR(50),
  `cus_id` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_348407_custom_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_348407_custom_mysql') AS relationships;
DROP DATABASE `db_348407_custom_mysql`;
UNINSTALL EXTENSION vsql_schematron;
