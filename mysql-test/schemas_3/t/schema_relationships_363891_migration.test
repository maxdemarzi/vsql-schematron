INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363891_migration
--echo #
CREATE DATABASE `db_363891_migration`;
USE `db_363891_migration`;

CREATE TABLE `University` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  `logo` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UniversityUser` (
  `universityId` VARCHAR(64),
  `userId` VARCHAR(64),
  `roleId` VARCHAR(64),
  PRIMARY KEY (`universityId`, `userId`)
) CHARACTER SET latin1;

CREATE TABLE `Role` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Scope` (
  `id` VARCHAR(64),
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `_RoleToScope` (
  `A` VARCHAR(64),
  `B` VARCHAR(64)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363891_migration') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363891_migration') AS relationships;
DROP DATABASE `db_363891_migration`;
UNINSTALL EXTENSION vsql_schematron;
