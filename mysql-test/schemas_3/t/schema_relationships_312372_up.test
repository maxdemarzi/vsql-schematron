INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 312372_up
--echo #
CREATE DATABASE `db_312372_up`;
USE `db_312372_up`;

CREATE TABLE `gameroom_user` (
  `email` VARCHAR(64),
  `public_key` VARCHAR(64),
  `encrypted_private_key` VARCHAR(64),
  `hashed_password` VARCHAR(64),
  PRIMARY KEY (`email`)
) CHARACTER SET latin1;

CREATE TABLE `gameroom` (
  `circuit_id` VARCHAR(64),
  `authorization_type` VARCHAR(64),
  `persistence` VARCHAR(64),
  `durability` VARCHAR(64),
  `routes` VARCHAR(64),
  `circuit_management_type` VARCHAR(64),
  `alias` VARCHAR(64),
  `status` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  PRIMARY KEY (`circuit_id`)
) CHARACTER SET latin1;

CREATE TABLE `gameroom_proposal` (
  `id` INT,
  `proposal_type` VARCHAR(64),
  `circuit_id` VARCHAR(64),
  `circuit_hash` VARCHAR(64),
  `requester` VARCHAR(64),
  `requester_node_id` VARCHAR(64),
  `status` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `proposal_vote_record` (
  `id` INT,
  `proposal_id` INT,
  `voter_public_key` VARCHAR(64),
  `voter_node_id` VARCHAR(64),
  `vote` VARCHAR(64),
  `created_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gameroom_member` (
  `id` INT,
  `circuit_id` VARCHAR(64),
  `node_id` VARCHAR(64),
  `endpoint` VARCHAR(64),
  `status` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gameroom_service` (
  `id` INT,
  `circuit_id` VARCHAR(64),
  `service_id` VARCHAR(64),
  `service_type` VARCHAR(64),
  `allowed_nodes` VARCHAR(64),
  `arguments` VARCHAR(64),
  `status` VARCHAR(64),
  `last_event` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `gameroom_notification` (
  `id` INT,
  `notification_type` VARCHAR(64),
  `requester` VARCHAR(64),
  `requester_node_id` VARCHAR(64),
  `target` VARCHAR(64),
  `created_time` DATETIME,
  `read` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `messages` (
  `id` INT,
  `circuit_id` VARCHAR(64),
  `message_name` VARCHAR(64),
  `message_content` VARCHAR(64),
  `message_type` VARCHAR(64),
  `previous_id` INT,
  `sender` VARCHAR(64),
  `participant_1` VARCHAR(64),
  `participant_2` VARCHAR(64),
  `created_time` DATETIME,
  `updated_time` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_312372_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_312372_up') AS relationships;
DROP DATABASE `db_312372_up`;
UNINSTALL EXTENSION vsql_schematron;
