INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 323329_ddl
--echo #
CREATE DATABASE `db_323329_ddl`;
USE `db_323329_ddl`;
CREATE TABLE `role_master` (
  `role_id` INT NOT NULL,
  `role_name` CHAR(50),
  PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
  `shain_id` VARCHAR(50) NOT NULL,
  `family_name` CHAR(50),
  `family_name_kana` CHAR(50),
  `given_name` CHAR(50),
  `given_name_kana` CHAR(50),
  `email` CHAR(50),
  `phone_number` CHAR(50),
  `cellphone_number` CHAR(50),
  `address` CHAR(50),
  `join_date` DATE,
  `quit_date` DATE,
  `password` CHAR(50),
  `role_id` INT,
  `delete_flag` INT,
  PRIMARY KEY (`shain_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_323329_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_323329_ddl') AS relationships;
DROP DATABASE `db_323329_ddl`;
UNINSTALL EXTENSION vsql_schematron;
