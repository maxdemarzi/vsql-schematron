INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307033_5-Company
--echo #
CREATE DATABASE `db_307033_5_Company`;
USE `db_307033_5_Company`;

CREATE TABLE `employee` (
  `ssn` VARCHAR(64),
  `name` VARCHAR(64),
  `salary` DECIMAL(10,2),
  `superssn` VARCHAR(64),
  `dno` DECIMAL(10,2),
  PRIMARY KEY (`ssn`)
) CHARACTER SET latin1;

CREATE TABLE `department` (
  `dno` DECIMAL(10,2),
  `dname` VARCHAR(64),
  `mgrssn` VARCHAR(64),
  PRIMARY KEY (`dno`)
) CHARACTER SET latin1;

CREATE TABLE `project` (
  `pno` DECIMAL(10,2),
  `pname` VARCHAR(64),
  `dno` DECIMAL(10,2),
  PRIMARY KEY (`pno`)
) CHARACTER SET latin1;

CREATE TABLE `works_on` (
  `ssn` VARCHAR(64),
  `pno` DECIMAL(10,2),
  PRIMARY KEY (`ssn`, `pno`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307033_5_Company') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307033_5_Company') AS relationships;
DROP DATABASE `db_307033_5_Company`;
UNINSTALL EXTENSION vsql_schematron;
