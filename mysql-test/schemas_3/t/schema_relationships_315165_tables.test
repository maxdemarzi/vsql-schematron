INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 315165_tables
--echo #
CREATE DATABASE `db_315165_tables`;
USE `db_315165_tables`;
CREATE TABLE `users` (
  `id` INT NOT NULL,
  `name` VARCHAR(50),
  `email` VARCHAR(50),
  `password` VARCHAR(50),
  `role` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibitions` (
  `id` INT NOT NULL,
  `title` VARCHAR(50),
  `ticket_price` DECIMAL(10,2),
  `opening_date` DATE,
  `closing_date` DATE,
  `status` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibitions_halls` (
  `hall_id` INT,
  `exhibition_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
  `id` INT NOT NULL,
  `user_id` INT,
  `exhibition_id` INT,
  `price` DECIMAL(10,2),
  `purchase_time` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_315165_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_315165_tables') AS relationships;
DROP DATABASE `db_315165_tables`;
UNINSTALL EXTENSION vsql_schematron;
