INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 319715_mysql
--echo #
CREATE DATABASE `db_319715_mysql`;
USE `db_319715_mysql`;

CREATE TABLE `aluno` (
  `aluno_id` INT,
  `telegram_code` VARCHAR(64),
  `nome` VARCHAR(64),
  `usuario_siga` VARCHAR(64),
  `senha_siga` VARCHAR(64),
  `ultima_atualizacao` DATETIME,
  `ativo` INT,
  PRIMARY KEY (`aluno_id`)
) CHARACTER SET latin1;

CREATE TABLE `materia` (
  `materia_id` INT,
  `nome` VARCHAR(64),
  PRIMARY KEY (`materia_id`)
) CHARACTER SET latin1;

CREATE TABLE `aula` (
  `aula_id` INT,
  `materia_id` INT,
  `dia_semana` INT,
  `quantidade` INT,
  PRIMARY KEY (`aula_id`, `materia_id`)
) CHARACTER SET latin1;

CREATE TABLE `matricula` (
  `matricula_id` INT,
  `aluno_id` INT,
  `materia_id` INT,
  PRIMARY KEY (`matricula_id`)
) CHARACTER SET latin1;

CREATE TABLE `falta` (
  `falta_id` INT,
  `matricula_id` INT,
  `data_falta` DATETIME,
  `quantidade` INT,
  PRIMARY KEY (`falta_id`, `matricula_id`)
) CHARACTER SET latin1;

CREATE TABLE `nota` (
  `nota_id` INT,
  `matricula_id` INT,
  `nota` DECIMAL(10,2),
  PRIMARY KEY (`nota_id`, `matricula_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_319715_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_319715_mysql') AS relationships;
DROP DATABASE `db_319715_mysql`;
UNINSTALL EXTENSION vsql_schematron;
