INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 394461_V1_init
--echo #
CREATE DATABASE `db_394461_V1_init`;
USE `db_394461_V1_init`;

CREATE TABLE `menu_service.week` (
  `id` INT,
  `week_number` VARCHAR(64),
  `start_date` VARCHAR(64),
  `end_date` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_service.unit_of_measure` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_service.ingredient` (
  `id` INT,
  `name` VARCHAR(64),
  `external_id` VARCHAR(64),
  `amount` VARCHAR(64),
  `unit_of_measure_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_service.menu` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_service.week_has_menu` (
  `week_id` INT,
  `menu_id` INT,
  PRIMARY KEY (`week_id`, `menu_id`)
) CHARACTER SET latin1;

CREATE TABLE `menu_service.menu_has_ingredient` (
  `menu_id` INT,
  `ingredient_id` INT,
  PRIMARY KEY (`menu_id`, `ingredient_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_394461_V1_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_394461_V1_init') AS relationships;
DROP DATABASE `db_394461_V1_init`;
UNINSTALL EXTENSION vsql_schematron;
