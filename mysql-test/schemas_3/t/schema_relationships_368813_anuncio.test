INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 368813_anuncio
--echo #
CREATE DATABASE `db_368813_anuncio`;
USE `db_368813_anuncio`;

CREATE TABLE `pagamentos` (
  `id` INT,
  `valor` DECIMAL(10,2),
  `forma_pagamento` VARCHAR(64),
  `credito` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `anuncios` (
  `id` INT,
  `quantidade_visualizacao` INT,
  `publico_alvO` VARCHAR(64),
  `regiao` VARCHAR(64),
  `cliques` INT,
  `data_inicio` DATETIME,
  `data_final` DATETIME,
  `postagem_anuncio` VARCHAR(64),
  `pagamentos_id` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `anunciantes` (
  `id` INT,
  `pagina` VARCHAR(64),
  `usuario` VARCHAR(64),
  `pagamentos_id` INT,
  `anuncios_id` INT,
  PRIMARY KEY (`id`, `pagamentos_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_368813_anuncio') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_368813_anuncio') AS relationships;
DROP DATABASE `db_368813_anuncio`;
UNINSTALL EXTENSION vsql_schematron;
