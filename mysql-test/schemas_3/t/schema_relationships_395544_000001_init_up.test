INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395544_000001_init.up
--echo #
CREATE DATABASE `db_395544_000001_init_up`;
USE `db_395544_000001_init_up`;

CREATE TABLE `users` (
  `id` INT,
  `created` DATETIME,
  `credentials` VARCHAR(64),
  `credential_key` VARCHAR(64),
  `last_login` VARCHAR(64),
  `is_connected` BOOL,
  `app_version` VARCHAR(64),
  `notification_cnt` INT,
  `UUID` VARCHAR(64),
  `public_key` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `notifications` (
  `UUID` VARCHAR(64),
  `time` DATETIME,
  `credentials` VARCHAR(64),
  `title` VARCHAR(64),
  `message` VARCHAR(64),
  `image` VARCHAR(64),
  `link` VARCHAR(64),
  PRIMARY KEY (`UUID`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395544_000001_init_up') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395544_000001_init_up') AS relationships;
DROP DATABASE `db_395544_000001_init_up`;
UNINSTALL EXTENSION vsql_schematron;
