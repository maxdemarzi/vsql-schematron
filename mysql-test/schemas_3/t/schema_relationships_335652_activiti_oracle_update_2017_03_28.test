INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 335652_activiti_oracle_update_2017_03_28
--echo #
CREATE DATABASE `db_335652_activiti_oracle_update_2017_03_28`;
USE `db_335652_activiti_oracle_update_2017_03_28`;

CREATE TABLE `ACT_RE_COMMON_MSG` (
  `id_` VARCHAR(64),
  `user_id_` VARCHAR(64),
  `common_msg_` VARCHAR(64),
  PRIMARY KEY (`id_`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_RE_BIZ` (
  `id_` VARCHAR(64),
  `name_` VARCHAR(64),
  `description_` VARCHAR(64),
  PRIMARY KEY (`id_`)
) CHARACTER SET latin1;

CREATE TABLE `ACT_RE_BIZFIELD` (
  `id_` VARCHAR(64),
  `name_` VARCHAR(64),
  `label_` VARCHAR(64),
  `type_` VARCHAR(64),
  `values_` VARCHAR(64),
  `required_` DECIMAL(10,2),
  `description_` VARCHAR(64),
  `biz_id_` VARCHAR(64),
  PRIMARY KEY (`id_`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_335652_activiti_oracle_update_2017_03_28') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_335652_activiti_oracle_update_2017_03_28') AS relationships;
DROP DATABASE `db_335652_activiti_oracle_update_2017_03_28`;
UNINSTALL EXTENSION vsql_schematron;
