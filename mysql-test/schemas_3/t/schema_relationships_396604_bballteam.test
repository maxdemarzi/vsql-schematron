INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 396604_bballteam
--echo #
CREATE DATABASE `db_396604_bballteam`;
USE `db_396604_bballteam`;

CREATE TABLE `UserAccounts` (
  `userName` VARCHAR(64),
  `password` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `email` VARCHAR(64),
  `currentYear` INT,
  PRIMARY KEY (`userName`)
) CHARACTER SET latin1;

CREATE TABLE `UserSession` (
  `userName` VARCHAR(64),
  `reAuth` BOOL,
  PRIMARY KEY (`userName`)
) CHARACTER SET latin1;

CREATE TABLE `PlayerInfo` (
  `userName` VARCHAR(64),
  `infoSplit` VARCHAR(64),
  `cellPhone` VARCHAR(64),
  `jerseySize` VARCHAR(64),
  `webSplit` VARCHAR(64),
  `firstName` VARCHAR(64),
  `lastName` VARCHAR(64),
  `teamType` VARCHAR(64),
  `team` VARCHAR(64),
  `schoolName` VARCHAR(64),
  `userImageUrl` VARCHAR(64),
  `role` VARCHAR(64),
  `playerNumber` VARCHAR(64),
  `printerSplit` VARCHAR(64),
  `favSportsTeams` VARCHAR(64),
  `favMovieTVShows` VARCHAR(64),
  `favFoods` VARCHAR(64),
  `famousPersonToMeet` VARCHAR(64),
  `BBallCareerHighlights` VARCHAR(64),
  `threeThingsUnknown` VARCHAR(64),
  PRIMARY KEY (`userName`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_396604_bballteam') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_396604_bballteam') AS relationships;
DROP DATABASE `db_396604_bballteam`;
UNINSTALL EXTENSION vsql_schematron;
