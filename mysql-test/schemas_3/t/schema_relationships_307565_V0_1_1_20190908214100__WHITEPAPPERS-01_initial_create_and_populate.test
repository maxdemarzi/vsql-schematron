INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 307565_V0.1.1_20190908214100__WHITEPAPPERS-01_initial_create_and_populate
--echo #
CREATE DATABASE `db_307565_V0_1_1_20190908214100__WHITEPAPPERS_01_initial_create_`;
USE `db_307565_V0_1_1_20190908214100__WHITEPAPPERS_01_initial_create_`;
CREATE TABLE `s_user` (
  `id` BIGINT NOT NULL,
  `last_name` TEXT,
  `first_name` TEXT,
  `middle_name` TEXT,
  `login` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `white_papper` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `created_user_id` BIGINT,
  `created_dt` TIMESTAMP NULL,
  `updated_user_id` BIGINT,
  `updated_dt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `white_papper_metadata` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  `type` TEXT,
  `registration_number` TEXT,
  `white_papper_id` BIGINT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `file_metadata` (
  `id` BIGINT NOT NULL,
  `file_name` TEXT,
  `storage` TEXT,
  `uuid` TEXT,
  `is_deleted` BOOLEAN,
  `white_papper_id` BIGINT,
  `created_user_id` BIGINT,
  `created_dt` TIMESTAMP NULL,
  `updated_user_id` BIGINT,
  `updated_dt` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `scope` (
  `id` BIGINT NOT NULL,
  `name` TEXT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_307565_V0_1_1_20190908214100__WHITEPAPPERS_01_initial_create_') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_307565_V0_1_1_20190908214100__WHITEPAPPERS_01_initial_create_') AS relationships;
DROP DATABASE `db_307565_V0_1_1_20190908214100__WHITEPAPPERS_01_initial_create_`;
UNINSTALL EXTENSION vsql_schematron;
