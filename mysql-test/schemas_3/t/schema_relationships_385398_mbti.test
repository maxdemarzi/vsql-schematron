INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 385398_mbti
--echo #
CREATE DATABASE `db_385398_mbti`;
USE `db_385398_mbti`;

CREATE TABLE `participant` (
  `id` INT,
  `email` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `participant_answer` (
  `id` INT,
  `participant_id` INT,
  `question_id` INT,
  `score` INT
) CHARACTER SET latin1;

CREATE TABLE `participant_perspective` (
  `id` INT,
  `participant_id` INT,
  `ei_i` INT,
  `ei_e` INT,
  `sn_s` INT,
  `sn_n` INT,
  `tf_t` INT,
  `tf_f` INT,
  `jp_j` INT,
  `jp_p` INT,
  `summary` VARCHAR(64)
) CHARACTER SET latin1;

CREATE TABLE `question` (
  `id` INT,
  `question` VARCHAR(64),
  `dimension` VARCHAR(64),
  `direction` INT,
  `meaning` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_385398_mbti') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_385398_mbti') AS relationships;
DROP DATABASE `db_385398_mbti`;
UNINSTALL EXTENSION vsql_schematron;
