INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 388899_create-tables-budget
--echo #
CREATE DATABASE `db_388899_create_tables_budget`;
USE `db_388899_create_tables_budget`;
CREATE TABLE `entries` (
  `id` INT NOT NULL,
  `summary` VARCHAR(50),
  `timeAdded` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
  `id` INT NOT NULL,
  `ruleType` VARCHAR(50),
  `amountModifier` DECIMAL(10,2),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conditions` (
  `id` INT NOT NULL,
  `sourceRule` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funds` (
  `id` INT NOT NULL,
  `fundName` VARCHAR(50),
  `ruleSet` INT,
  `startEntry` INT,
  `endEntry` INT,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_388899_create_tables_budget') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_388899_create_tables_budget') AS relationships;
DROP DATABASE `db_388899_create_tables_budget`;
UNINSTALL EXTENSION vsql_schematron;
