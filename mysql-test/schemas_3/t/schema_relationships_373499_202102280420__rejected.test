INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373499_202102280420__rejected
--echo #
CREATE DATABASE `db_373499_202102280420__rejected`;
USE `db_373499_202102280420__rejected`;
CREATE TABLE `rejected` (
  `id` BIGINT NOT NULL,
  `url` VARCHAR(50),
  `artist_id` BIGINT,
  `discord_id` BIGINT,
  `rejected_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `strike` (
  `id` BIGINT NOT NULL,
  `rejected_id` BIGINT,
  `discord_id` BIGINT,
  `rejected_date` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373499_202102280420__rejected') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373499_202102280420__rejected') AS relationships;
DROP DATABASE `db_373499_202102280420__rejected`;
UNINSTALL EXTENSION vsql_schematron;
