INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 395052_default
--echo #
CREATE DATABASE `db_395052_default`;
USE `db_395052_default`;

CREATE TABLE `client_tokens` (
  `id` INT,
  `group` VARCHAR(255),
  `somewords` VARCHAR(255),
  `revoked` INT,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `user_tokens` (
  `id` INT,
  `token` VARCHAR(255),
  `user_id` INT,
  `client_id` INT,
  `revoked` INT,
  `expire_at` DATETIME,
  `created_at` DATETIME,
  `updated_at` DATETIME,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_395052_default') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_395052_default') AS relationships;
DROP DATABASE `db_395052_default`;
UNINSTALL EXTENSION vsql_schematron;
