INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 325139_init
--echo #
CREATE DATABASE `db_325139_init`;
USE `db_325139_init`;

CREATE TABLE `Artist` (
  `artistId` INT,
  `lastfmUri` VARCHAR(64),
  `name` VARCHAR(64),
  `spotifyUri` VARCHAR(64),
  PRIMARY KEY (`artistId`)
) CHARACTER SET latin1;

CREATE TABLE `Releases` (
  `releaseId` INT,
  `name` VARCHAR(64),
  `releasedOn` DATETIME,
  `spotifyUri` VARCHAR(64),
  `type` VARCHAR(64),
  PRIMARY KEY (`releaseId`)
) CHARACTER SET latin1;

CREATE TABLE `ArtistRelease` (
  `release_id` INT,
  `artist_id` INT,
  PRIMARY KEY (`artist_id`, `release_id`)
) CHARACTER SET latin1;

CREATE TABLE `User` (
  `id` INT,
  `create_date` DATETIME,
  `email` VARCHAR(64),
  `lastLastFmScrape` DATETIME,
  `lastNotified` DATETIME,
  `lastSpotifyScrape` DATETIME,
  `lastfmUsername` VARCHAR(64),
  `modify_date` DATETIME,
  `spotifyEnabled` VARCHAR(64),
  `username` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `UserArtist` (
  `hasNewRelease` VARCHAR(64),
  `weight` DECIMAL(10,2),
  `user_id` INT,
  `artist_id` INT,
  PRIMARY KEY (`artist_id`, `user_id`)
) CHARACTER SET latin1;

CREATE TABLE `hibernate_sequence` (
  `next_val` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_325139_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_325139_init') AS relationships;
DROP DATABASE `db_325139_init`;
UNINSTALL EXTENSION vsql_schematron;
