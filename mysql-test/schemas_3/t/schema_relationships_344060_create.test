INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 344060_create
--echo #
CREATE DATABASE `db_344060_create`;
USE `db_344060_create`;

CREATE TABLE `task_list` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `task` (
  `id` INT,
  `list_id` INT,
  `name` VARCHAR(64),
  `completed` BOOL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_344060_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_344060_create') AS relationships;
DROP DATABASE `db_344060_create`;
UNINSTALL EXTENSION vsql_schematron;
