INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 359016_create_ddl
--echo #
CREATE DATABASE `db_359016_create_ddl`;
USE `db_359016_create_ddl`;

CREATE TABLE `chain` (
  `ID` INT,
  `NAME` VARCHAR(255),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `area` (
  `ID` INT,
  `NAME` VARCHAR(255),
  `CHAIN_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `region` (
  `ID` INT,
  `NAME` VARCHAR(255),
  `AREA_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `district` (
  `ID` INT,
  `NAME` VARCHAR(255),
  `REGION_ID` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `ID` INT,
  `SALES_DATE` DATETIME,
  `DISTRICT_ID` INT,
  `AMOUNT` INT,
  PRIMARY KEY (`ID`, `SALES_DATE`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_359016_create_ddl') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_359016_create_ddl') AS relationships;
DROP DATABASE `db_359016_create_ddl`;
UNINSTALL EXTENSION vsql_schematron;
