INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 305175_1
--echo #
CREATE DATABASE `db_305175_1`;
USE `db_305175_1`;
CREATE TABLE `business_rating` (
  `business_id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  `avg_rating` DOUBLE,
  `num_reviews` INT,
  `latitude` DOUBLE,
  `longitude` DOUBLE,
  `timestamp` DATETIME,
  PRIMARY KEY (`business_id`)
) CHARACTER SET latin1;
CREATE TABLE `tweets` (
  `tweets_id` INT NOT NULL,
  `business_id` VARCHAR(50),
  `num_tweets` INT,
  `follower_count` INT,
  `timestamp` DATETIME,
  PRIMARY KEY (`tweets_id`)
) CHARACTER SET latin1;
CREATE TABLE `yelp_review` (
  `review_id` INT NOT NULL,
  `business_id` VARCHAR(50),
  `rating` DOUBLE,
  `excerpt` VARCHAR(50),
  `user_name` VARCHAR(50),
  `user_id` VARCHAR(50),
  `time_created` DATETIME,
  PRIMARY KEY (`review_id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_305175_1') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_305175_1') AS relationships;
DROP DATABASE `db_305175_1`;
UNINSTALL EXTENSION vsql_schematron;
