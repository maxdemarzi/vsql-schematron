INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347697_create
--echo #
CREATE DATABASE `db_347697_create`;
USE `db_347697_create`;
CREATE TABLE `REFFERAL` (
  `RefferalID` INT NOT NULL,
  `Casehead` VARCHAR(50),
  `ServiceRecipient` VARCHAR(50),
  `ParentPhoneNumber` CHAR(50),
  `ParentAddress` VARCHAR(50),
  `VisitLocation` VARCHAR(50),
  `VisitSchedule` VARCHAR(50),
  `ConfirmationRequired` BOOLEAN,
  `CaregiverName` VARCHAR(50),
  `CaregiverPhoneNumber` CHAR(50),
  `CaregiverAddress` VARCHAR(50),
  `AdditionalInfo` VARCHAR(50),
  PRIMARY KEY (`RefferalID`)
) CHARACTER SET latin1;
CREATE TABLE `PARTICIPANT` (
  `RefferalID` INT,
  `ParticipantName` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `CHILD` (
  `RefferalID` INT,
  `ChildName` VARCHAR(50),
  `ChildDOB` DATE
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347697_create') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347697_create') AS relationships;
DROP DATABASE `db_347697_create`;
UNINSTALL EXTENSION vsql_schematron;
