INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 347710_probecap
--echo #
CREATE DATABASE `db_347710_probecap`;
USE `db_347710_probecap`;

CREATE TABLE `station` (
  `id` INT,
  `mac` VARCHAR(64),
  `firstSeen` DATETIME,
  `lastSeen` DATETIME,
  PRIMARY KEY (`mac`)
) CHARACTER SET latin1;

CREATE TABLE `ssid` (
  `id` INT,
  `name` VARCHAR(64),
  PRIMARY KEY (`name`)
) CHARACTER SET latin1;

CREATE TABLE `probe` (
  `station` INT,
  `ssid` INT,
  `seen` DATETIME
) CHARACTER SET latin1;

CREATE TABLE `beacon` (
  `station` INT,
  `ssid` INT,
  `seen` DATETIME
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_347710_probecap') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_347710_probecap') AS relationships;
DROP DATABASE `db_347710_probecap`;
UNINSTALL EXTENSION vsql_schematron;
