INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383343_create_table
--echo #
CREATE DATABASE `db_383343_create_table`;
USE `db_383343_create_table`;

CREATE TABLE `authors` (
  `author_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  `middle_name` VARCHAR(255),
  PRIMARY KEY (`author_id`)
) CHARACTER SET latin1;

CREATE TABLE `books` (
  `book_id` INT,
  `title` VARCHAR(255),
  `publisher_id` INT,
  `pub_date` DATETIME,
  `quantity` INT,
  PRIMARY KEY (`book_id`)
) CHARACTER SET latin1;

CREATE TABLE `publisher` (
  `publisher_id` INT,
  `title` VARCHAR(255),
  PRIMARY KEY (`publisher_id`)
) CHARACTER SET latin1;

CREATE TABLE `readers` (
  `reader_id` INT,
  `first_name` VARCHAR(255),
  `last_name` VARCHAR(255),
  PRIMARY KEY (`reader_id`)
) CHARACTER SET latin1;

CREATE TABLE `library_queue` (
  `queue_id` INT,
  `book_id` INT,
  `reader_id` INT,
  `given` DATETIME,
  `taken` DATETIME,
  PRIMARY KEY (`queue_id`)
) CHARACTER SET latin1;

CREATE TABLE `book_author` (
  `book_id` INT,
  `author_id` INT
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383343_create_table') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383343_create_table') AS relationships;
DROP DATABASE `db_383343_create_table`;
UNINSTALL EXTENSION vsql_schematron;
