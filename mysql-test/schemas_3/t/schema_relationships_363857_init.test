INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 363857_init
--echo #
CREATE DATABASE `db_363857_init`;
USE `db_363857_init`;

CREATE TABLE `users` (
  `user_id` VARCHAR(64),
  `user_name` VARCHAR(64),
  `user_email` VARCHAR(64),
  `user_passwd` VARCHAR(64),
  `user_in_date` DATETIME,
  `user_salt` VARCHAR(64),
  PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;

CREATE TABLE `vendings` (
  `serial_number` VARCHAR(64),
  `user_id` VARCHAR(64),
  `vending_name` VARCHAR(64),
  `vending_description` VARCHAR(64),
  `vending_full_size` INT,
  `vending_in_date` DATETIME,
  `vending_update_date` DATETIME,
  PRIMARY KEY (`serial_number`)
) CHARACTER SET latin1;

CREATE TABLE `drinks` (
  `serial_number` VARCHAR(64),
  `drink_position` INT,
  `drink_name` VARCHAR(64),
  `drink_price` INT,
  `drink_count` INT,
  `drink_max_count` INT,
  PRIMARY KEY (`serial_number`, `drink_position`)
) CHARACTER SET latin1;

CREATE TABLE `managers` (
  `manager_id` VARCHAR(64),
  `manager_name` VARCHAR(64),
  `manager_email` VARCHAR(64),
  `manager_passwd` VARCHAR(64),
  `manager_in_date` DATETIME,
  `manager_salt` VARCHAR(64),
  `manager_approbation_flag` INT,
  PRIMARY KEY (`manager_id`)
) CHARACTER SET latin1;

CREATE TABLE `sales` (
  `sale_seq` INT,
  `user_id` VARCHAR(64),
  `serial_number` VARCHAR(64),
  `drink_name` VARCHAR(64),
  `drink_price` INT,
  `sale_date` DATETIME,
  PRIMARY KEY (`sale_seq`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_363857_init') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_363857_init') AS relationships;
DROP DATABASE `db_363857_init`;
UNINSTALL EXTENSION vsql_schematron;
