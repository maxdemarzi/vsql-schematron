INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 383060_stully
--echo #
CREATE DATABASE `db_383060_stully`;
USE `db_383060_stully`;

CREATE TABLE `account` (
  `account_id` INT,
  `username` VARCHAR(64),
  `password_hash` VARCHAR(64),
  `email` VARCHAR(64),
  `punten` INT,
  `status` VARCHAR(64),
  PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;

CREATE TABLE `comments` (
  `comment_id` INT,
  `comment` VARCHAR(64),
  `punten` INT,
  `post_id` INT,
  `account_id` INT
) CHARACTER SET latin1;

CREATE TABLE `posts` (
  `post_id` INT,
  `account_id` INT,
  `title` VARCHAR(64),
  `code` VARCHAR(64),
  `subtext` VARCHAR(64),
  `timestamp` DATETIME,
  PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_383060_stully') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_383060_stully') AS relationships;
DROP DATABASE `db_383060_stully`;
UNINSTALL EXTENSION vsql_schematron;
