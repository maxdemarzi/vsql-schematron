INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 373199_modeloContribuyentes
--echo #
CREATE DATABASE `db_373199_modeloContribuyentes`;
USE `db_373199_modeloContribuyentes`;

CREATE TABLE `CONTRIBUYENTE` (
  `IDE_CONTRIBUYENTE` DECIMAL(10,2),
  `NOM_PRIMER_NOMBRE` VARCHAR(64),
  `NOM_OTROS_NOMBRES` VARCHAR(64),
  `NOM_PRIMER_APELLIDO` VARCHAR(64),
  `NOM_SEGUNDO_APELLIDO` VARCHAR(64),
  `NOM_RAZON_SOCIAL` VARCHAR(64),
  `IDE_TIPO_DOCUMENTO` DECIMAL(10,2),
  `NUM_IDENTIDAD` VARCHAR(64),
  `NUM_NIT` DECIMAL(10,2),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_LECTURA` DECIMAL(10,2),
  `NIV_ESCRITURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_CONTRIBUYENTE`)
) CHARACTER SET latin1;

CREATE TABLE `CONTRIBUYENTE_DIRECCION` (
  `IDE_CONTRIBUYENTE` DECIMAL(10,2),
  `IDE_DIRECCION` DECIMAL(10,2),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_ESCRITURA` DECIMAL(10,2),
  `NIV_LECTURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_CONTRIBUYENTE`, `IDE_DIRECCION`)
) CHARACTER SET latin1;

CREATE TABLE `DIRECCION` (
  `IDE_DIRECCION` DECIMAL(10,2),
  `IDE_PAIS` DECIMAL(10,2),
  `IDE_DEPARTAMENTO` DECIMAL(10,2),
  `IDE_MUNICIPIO` DECIMAL(10,2),
  `VAL_DIRECCION` VARCHAR(64),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_ESCRITURA` DECIMAL(10,2),
  `NIV_LECTURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_DIRECCION`)
) CHARACTER SET latin1;

CREATE TABLE `LUGAR` (
  `IDE_LUGAR` DECIMAL(10,2),
  `IDE_TIPO_LUGAR` DECIMAL(10,2),
  `IDE_LUGAR_PADRE` DECIMAL(10,2),
  `NOM_TIPO_LUGAR` VARCHAR(64),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_ESCRITURA` DECIMAL(10,2),
  `NIV_LECTURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_LUGAR`)
) CHARACTER SET latin1;

CREATE TABLE `TIPO_DOCUMENTO` (
  `IDE_TIPO_DOCUMENTO` DECIMAL(10,2),
  `NOM_TIPO_DOCUMENTO` VARCHAR(64),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_LECTURA` DECIMAL(10,2),
  `NIV_ESCRITURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_TIPO_DOCUMENTO`)
) CHARACTER SET latin1;

CREATE TABLE `TIPO_LUGAR` (
  `IDE_TIPO_LUGAR` DECIMAL(10,2),
  `NOM_TIPO_LUGAR` VARCHAR(64),
  `IDE_USUARIO_CAMBIO` DECIMAL(10,2),
  `FEC_CAMBIO` DATETIME,
  `NIV_ESCRITURA` DECIMAL(10,2),
  `NIV_LECTURA` DECIMAL(10,2),
  `IDE_UUID` VARCHAR(64),
  PRIMARY KEY (`IDE_TIPO_LUGAR`)
) CHARACTER SET latin1;

--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_373199_modeloContribuyentes') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_373199_modeloContribuyentes') AS relationships;
DROP DATABASE `db_373199_modeloContribuyentes`;
UNINSTALL EXTENSION vsql_schematron;
