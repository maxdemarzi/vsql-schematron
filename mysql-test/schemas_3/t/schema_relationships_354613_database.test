INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 354613_database
--echo #
CREATE DATABASE `db_354613_database`;
USE `db_354613_database`;
CREATE TABLE `session` (
  `id` INT NOT NULL,
  `email` VARCHAR(50),
  `ip` VARCHAR(50),
  `browser` VARCHAR(50),
  `viewport_width` CHAR(50),
  `orientation` VARCHAR(50),
  `updated` DATETIME,
  `created` TIMESTAMP NULL,
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
  `id` INT NOT NULL,
  `type` VARCHAR(50),
  `session_id` INT,
  `value` TEXT,
  `created` TIMESTAMP NULL,
  `referer` VARCHAR(50),
  `domain_origin` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `admin` (
  `id` INT NOT NULL,
  `username` VARCHAR(50),
  `password` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_354613_database') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_354613_database') AS relationships;
DROP DATABASE `db_354613_database`;
UNINSTALL EXTENSION vsql_schematron;
