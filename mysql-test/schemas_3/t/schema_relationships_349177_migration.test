CREATE DATABASE `db_349177_migration`;
USE `db_349177_migration`;

CREATE TABLE `User` (
  `id` INT,
  `email` VARCHAR(64),
  `hashedPassword` VARCHAR(64),
  `salt` VARCHAR(64),
  `role` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Vault` (
  `id` INT,
  `vaultname` VARCHAR(64),
  `vaultusername` VARCHAR(64),
  `vaultpassword` VARCHAR(64),
  `vaultpassword2` VARCHAR(64),
  `userEmailId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Contact` (
  `id` INT,
  `firstname` VARCHAR(64),
  `lastname` VARCHAR(64),
  `email` VARCHAR(64),
  `landline` VARCHAR(64),
  `mobile` VARCHAR(64),
  `website` VARCHAR(64),
  `street` VARCHAR(64),
  `suburb` VARCHAR(64),
  `notes` VARCHAR(64),
  `contactEmailId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

CREATE TABLE `Appointment` (
  `id` INT,
  `time` VARCHAR(64),
  `date` VARCHAR(64),
  `appointEmailId` VARCHAR(64),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;

