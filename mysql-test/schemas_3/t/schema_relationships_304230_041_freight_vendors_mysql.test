INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 304230_041_freight_vendors.mysql
--echo #
CREATE DATABASE `db_304230_041_freight_vendors_mysql`;
USE `db_304230_041_freight_vendors_mysql`;
CREATE TABLE `fv_types` (
  `fv_type_id` INT NOT NULL,
  `fv_type_name` VARCHAR(50),
  `fv_type_edi_code` VARCHAR(50),
  PRIMARY KEY (`fv_type_id`)
) CHARACTER SET latin1;
CREATE TABLE `fv_freight_vendors` (
  `fv_vendor_id` INT NOT NULL,
  `fv_vendor_abbreviation` VARCHAR(50),
  `fv_vendor_name` VARCHAR(50),
  `fv_vendor_scac` VARCHAR(50),
  `fv_type_id` INT,
  `gl_account_id` INT,
  `primary_address` VARCHAR(50),
  `fv_vendor_status` CHAR(50),
  `rev_enabled` CHAR(50),
  `rev_number` INT,
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME,
  PRIMARY KEY (`fv_vendor_id`)
) CHARACTER SET latin1;
CREATE TABLE `fv_contacts` (
  `fv_vendor_id` INT,
  `contact_id` VARCHAR(50),
  `role` VARCHAR(50),
  `created_by` VARCHAR(50),
  `creation_date` DATETIME,
  `last_update_by` VARCHAR(50),
  `last_update_date` DATETIME
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_304230_041_freight_vendors_mysql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_304230_041_freight_vendors_mysql') AS relationships;
DROP DATABASE `db_304230_041_freight_vendors_mysql`;
UNINSTALL EXTENSION vsql_schematron;
