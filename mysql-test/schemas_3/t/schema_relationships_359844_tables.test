INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 359844_tables
--echo #
CREATE DATABASE `db_359844_tables`;
USE `db_359844_tables`;
CREATE TABLE `GRANT_STATUSES` (
  `ID` BIGINT NOT NULL,
  `STATUS` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GRANT_TYPES` (
  `ID` BIGINT NOT NULL,
  `GRANT_TYPE` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ORGANIZATIONS` (
  `ID` BIGINT NOT NULL,
  `ORGANIZATION` TEXT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `LOCATIONS` (
  `ID` BIGINT NOT NULL,
  `LOCATION` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `STRATEGIC_PRIORITIES` (
  `ID` BIGINT NOT NULL,
  `STRATEGIC_PRIORITY` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `STRATEGIC_RESULTS` (
  `ID` BIGINT NOT NULL,
  `STRATEGIC_RESULT` VARCHAR(50),
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GRANTS` (
  `ID` BIGINT NOT NULL,
  `GRANT_STATUS_ID` BIGINT,
  `FISCAL_YEAR` INT,
  `GRANT_TYPE_ID` BIGINT,
  `ORGANIZATION_ID` BIGINT,
  `PROJECT` VARCHAR(50),
  `AMOUNT` BIGINT,
  `LOCATION_ID` BIGINT,
  `STRATEGIC_PRIORITY_ID` BIGINT,
  `STRATEGIC_RESULT_ID` BIGINT,
  `TOTAL_NUMBER_SERVED` INT,
  `NUMBER_NATIVE_HAWAIIANS_SERVED` INT,
  PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_359844_tables') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_359844_tables') AS relationships;
DROP DATABASE `db_359844_tables`;
UNINSTALL EXTENSION vsql_schematron;
