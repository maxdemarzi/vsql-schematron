INSTALL EXTENSION vsql_schematron;
--echo #
--echo # Test relationships for schema 359164_phonebook-pgsql
--echo #
CREATE DATABASE `db_359164_phonebook_pgsql`;
USE `db_359164_phonebook_pgsql`;
CREATE TABLE `contact` (
  `id` VARCHAR(50) NOT NULL,
  `name` VARCHAR(50),
  PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone` (
  `contact_id` VARCHAR(50) NOT NULL,
  `number` VARCHAR(50) NOT NULL,
  `carrier` VARCHAR(50),
  PRIMARY KEY (`contact_id`, `number`)
) CHARACTER SET latin1;
--disable_query_log
SET GLOBAL vsql_schematron.schema_cache_enabled = ON;
--enable_query_log
--let $wait_counter= 100
while ($wait_counter)
{
  --let $ready= query_get_value(SELECT vsql_schema_cache_ready('db_359164_phonebook_pgsql') AS r, r, 1)
  if ($ready)
  {
    --let $wait_counter= 0
  }
  if (!$ready)
  {
    sleep 0.1;
    --dec $wait_counter
  }
}
SELECT vsql_schema_relationships('db_359164_phonebook_pgsql') AS relationships;
DROP DATABASE `db_359164_phonebook_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
