INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 347058_schema
#
CREATE DATABASE `db_347058_schema`;
USE `db_347058_schema`;
CREATE TABLE `Customer` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Category` (
`identifier` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`identifier`)
) CHARACTER SET latin1;
CREATE TABLE `Ad` (
`id` VARCHAR(50) NOT NULL,
`short_description` VARCHAR(50),
`description` VARCHAR(50),
`customer_id` BIGINT,
`category_id` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`price` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_347058_schema') AS relationships;
relationships
Database: db_347058_schema

