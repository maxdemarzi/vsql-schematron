CREATE DATABASE `db_391290_db`;
USE `db_391290_db`;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`nombrecompleto` VARCHAR(50),
`email` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `links` (
`id` INT NOT NULL,
`titulo` VARCHAR(50),
`url` VARCHAR(50),
`descripcion` TEXT,
`usuario_id` INT,
`creado` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_391290_db') AS relationships;
