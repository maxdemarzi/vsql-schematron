INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 346435_schema
#
CREATE DATABASE `db_346435_schema`;
USE `db_346435_schema`;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_346435_schema') AS relationships;
relationships
