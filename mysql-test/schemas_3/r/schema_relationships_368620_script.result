) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` INT,
`title` VARCHAR(64),
`due_date` DATETIME,
`location` VARCHAR(64),
`attachments` VARCHAR(64),
`status` BOOL,
`created_date` DATETIME,
`cat_id` INT,
`user_created` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
