INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 327638_schema
#
CREATE DATABASE `db_327638_schema`;
USE `db_327638_schema`;
CREATE TABLE `ATTR` (
`ATTRID` INT NOT NULL,
`IDENTIFIER` VARCHAR(50),
`ATTRTYPEID` INT,
`FIELD1` VARCHAR(50),
`FIELD2` VARCHAR(50),
`CREATED_DATE` DATE,
`UPDATED_DATE` DATE,
PRIMARY KEY (`ATTRID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEM` (
`ITEMID` INT NOT NULL,
`IDENTIFIER` VARCHAR(50),
`DESCRIPTION` VARCHAR(50),
`ITEMTYPE` INT,
`FIELD1` VARCHAR(50),
`FIELD2` VARCHAR(50),
`CREATED_DATE` DATE,
`UPDATED_DATE` DATE,
PRIMARY KEY (`ITEMID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEMATTRMAPPING` (
`ITEMATTRMAPPINGID` INT NOT NULL,
`ITEMID` INT,
`ATTRID` INT,
`ATTRVALUE` VARCHAR(50),
`FIELD1` VARCHAR(50),
`FIELD2` VARCHAR(50),
`CREATED_DATE` DATE,
`UPDATED_DATE` DATE,
PRIMARY KEY (`ITEMATTRMAPPINGID`)
) CHARACTER SET latin1;
CREATE TABLE `ITEMREL` (
`ITEMRELID` INT NOT NULL,
`ITEMID_PARENT` INT,
`ITEMID_CHILD` INT,
`FIELD1` VARCHAR(50),
`FIELD2` VARCHAR(50),
PRIMARY KEY (`ITEMRELID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_327638_schema') AS relationships;
