INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 305185_maplestory
#
CREATE DATABASE `db_305185_maplestory`;
USE `db_305185_maplestory`;
CREATE TABLE `accounts` (
`accountID` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`isLogedIn` INT,
`adminLevel` INT,
`isBanned` INT,
`gender` INT,
`dob` INT,
PRIMARY KEY (`accountID`)
) CHARACTER SET latin1;
CREATE TABLE `buddy` (
`id` INT,
`characterID` INT,
`friendID` INT,
`accepted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `characters` (
`id` INT,
`accountID` INT,
`worldID` INT,
`channelID` INT,
`migrationID` INT,
`name` VARCHAR(64),
`gender` INT,
`skin` INT,
`hair` INT,
`face` INT,
`level` INT,
`job` INT,
`str` INT,
`dex` INT,
`intt` INT,
`luk` INT,
`hp` INT,
`maxHP` INT,
`mp` INT,
`maxMP` INT,
`ap` INT,
`sp` INT,
`exp` INT,
`fame` INT,
`mapID` INT,
`mapPos` INT,
`previousMapID` INT,
`mesos` INT,
`equipSlotSize` INT,
`useSlotSize` INT,
`setupSlotSize` INT,
`etcSlotSize` INT,
`cashSlotSize` INT,
`miniGameWins` INT,
`miniGameDraw` INT,
`miniGameLoss` INT,
`miniGamePoints` INT,
`buddyListSize` INT,
`inCashShop` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT,
`characterID` INT,
`itemID` INT,
`inventoryID` INT,
`slotNumber` INT,
`amount` INT,
`flag` INT,
`upgradeSlots` INT,
`level` INT,
`str` INT,
`dex` INT,
`intt` INT,
`luk` INT,
`hp` INT,
`mp` INT,
`watk` INT,
`matk` INT,
`wdef` INT,
`mdef` INT,
`accuracy` INT,
`avoid` INT,
`hands` INT,
`speed` INT,
`jump` INT,
`expireTime` INT,
`creatorName` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_305185_maplestory') AS relationships;
relationships
Database: db_305185_maplestory

Table Connections:
