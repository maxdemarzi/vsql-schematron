CREATE DATABASE `db_361583_wxapp_db`;
USE `db_361583_wxapp_db`;
CREATE TABLE `t_memo` (
`id` INT,
`user` VARCHAR(64),
`content` VARCHAR(64),
`flag` VARCHAR(64),
`type` VARCHAR(64),
`time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_price_history` (
`id` INT,
`custom` INT,
`price` DECIMAL(10,2),
`update_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_setting` (
`id` VARCHAR(64),
`list_size` INT,
`time` VARCHAR(64),
`free` INT,
`gift` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_store` (
`id` VARCHAR(64),
`now_num` INT,
`warn_num` INT,
`warn_text` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `t_user` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`memo` VARCHAR(64),
`state` VARCHAR(64),
`last_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_361583_wxapp_db') AS relationships;
