INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 321447_rpg_website
#
CREATE DATABASE `db_321447_rpg_website`;
USE `db_321447_rpg_website`;
CREATE TABLE `game_entries` (
`id` INT,
`userid` INT,
`message` VARCHAR(64),
`timestamp` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`role` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`gender` VARCHAR(64),
`age` INT,
`imagepath` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `user_permissions` (
`id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `website_contents` (
`id` INT,
`text` VARCHAR(64),
`website_navigation_name` INT
) CHARACTER SET latin1;
CREATE TABLE `website_navigation` (
`id` INT,
`menuname` VARCHAR(64),
`filename` VARCHAR(64),
`role` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_321447_rpg_website') AS relationships;
