INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 371022_schema
#
CREATE DATABASE `db_371022_schema`;
USE `db_371022_schema`;
CREATE TABLE `Questions` (
`question_id` INT,
`product_id` INT,
`body` VARCHAR(64),
`date_written` INT,
`asker_name` VARCHAR(64),
`asker_email` VARCHAR(64),
`reported` INT,
`helpful` INT,
PRIMARY KEY (`question_id`)
) CHARACTER SET latin1;
CREATE TABLE `Answers` (
`answer_id` INT,
`question_id` INT,
`body` VARCHAR(64),
`date` INT,
`answerer_name` VARCHAR(64),
`answerer_email` VARCHAR(64),
`reported` INT,
`helpfulness` INT,
PRIMARY KEY (`answer_id`)
) CHARACTER SET latin1;
CREATE TABLE `Photos` (
`photo_id` INT,
`answer_id` INT,
`url` VARCHAR(64),
PRIMARY KEY (`photo_id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`product_id` INT,
`name` VARCHAR(64),
`slogan` VARCHAR(64),
`description` VARCHAR(64),
`category` VARCHAR(64),
`default_price` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_371022_schema') AS relationships;
relationships
Database: db_371022_schema

Table Connections:
------------------
[Implied]  Answers.question_id -> Questions.question_id
[Implied]  Photos.answer_id -> Answers.answer_id
[Implied]  Questions.product_id -> Product.product_id

DROP DATABASE `db_371022_schema`;
UNINSTALL EXTENSION vsql_schematron;
