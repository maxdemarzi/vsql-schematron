CREATE DATABASE `db_347051_database`;
USE `db_347051_database`;
CREATE TABLE `VideoType` (
`videoTypeId` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`videoTypeId`)
) CHARACTER SET latin1;
CREATE TABLE `Video` (
`videoId` BIGINT NOT NULL,
`stringId` VARCHAR(50),
`videoTypeId` BIGINT,
`title` VARCHAR(50),
`description` VARCHAR(50),
`host` VARCHAR(50),
`source` VARCHAR(50),
`thumbnail` VARCHAR(50),
`updatedAt` VARCHAR(50),
`remoteUpdatedAt` VARCHAR(50),
PRIMARY KEY (`videoId`)
) CHARACTER SET latin1;
