CREATE DATABASE `db_348627_tables`;
USE `db_348627_tables`;
CREATE TABLE `Store` (
`storeID` INT,
`storeAddress` VARCHAR(64),
`Phone_No` VARCHAR(64),
PRIMARY KEY (`storeID`)
) CHARACTER SET latin1;
CREATE TABLE `Staff` (
`staffID` INT,
`storeID` INT,
`name` VARCHAR(64),
`Age` INT,
`Job_Title` VARCHAR(64),
`Address` VARCHAR(64),
`Email` VARCHAR(64),
`Phone_No` VARCHAR(64),
`TimeofEmployment` DATETIME,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `ClubMember` (
`customerID` INT,
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
`PhoneNumber` VARCHAR(64),
`Address` VARCHAR(64),
`Email` VARCHAR(64),
`ActiveStatus` BOOL,
`membershipLevel` VARCHAR(64),
PRIMARY KEY (`customerID`)
) CHARACTER SET latin1;
CREATE TABLE `SignsUp` (
`customerID` INT,
`staffID` INT,
`signUpDate` DATETIME,
`storeID` INT,
PRIMARY KEY (`customerID`)
) CHARACTER SET latin1;
CREATE TABLE `Transactions` (
`transactionID` INT,
`storeID` INT,
`customerID` INT,
`cashierID` INT,
`PurchaseDate` DATETIME,
`TotalPrice` INT,
PRIMARY KEY (`transactionID`)
) CHARACTER SET latin1;
CREATE TABLE `productTable` (
`productID` INT,
`productName` VARCHAR(64),
`buyPrice` INT,
`marketPrice` INT,
PRIMARY KEY (`productID`)
) CHARACTER SET latin1;
CREATE TABLE `InventoryInfo` (
`productID` INT,
`storeID` INT,
`productionDate` DATETIME,
`expirationDate` DATETIME,
`quantity` INT,
PRIMARY KEY (`productID`, `storeID`)
) CHARACTER SET latin1;
CREATE TABLE `ProductList` (
`transactionID` INT,
`productID` INT,
`quantity` INT,
`discountApplied` BOOL,
`finalPrice` INT,
PRIMARY KEY (`transactionID`, `productID`)
) CHARACTER SET latin1;
CREATE TABLE `Discount` (
`discountID` INT,
`productID` INT,
`storeID` INT,
`DiscountPercentage` INT,
`startDate` DATETIME,
`endDate` DATETIME,
PRIMARY KEY (`discountID`)
) CHARACTER SET latin1;
CREATE TABLE `Supplier` (
`supplierID` INT,
`supplierName` VARCHAR(64),
`PhoneNumber` VARCHAR(64),
`Email` VARCHAR(64),
`Location` VARCHAR(64),
PRIMARY KEY (`supplierID`)
) CHARACTER SET latin1;
CREATE TABLE `ProductInfo` (
`productID` INT,
`supplierID` INT,
PRIMARY KEY (`productID`)
) CHARACTER SET latin1;
CREATE TABLE `SuppliesInfo` (
`storeID` INT,
`productID` INT,
`billingDate` DATETIME,
`quantity` INT,
PRIMARY KEY (`storeID`, `productID`, `billingDate`)
) CHARACTER SET latin1;
CREATE TABLE `ordersInfo` (
`orderID` INT,
`supplierID` INT,
`staffID` INT,
PRIMARY KEY (`orderID`)
) CHARACTER SET latin1;
CREATE TABLE `orderProductInfo` (
`orderID` INT,
`productID` INT,
`quantity` INT,
PRIMARY KEY (`orderID`, `productID`)
) CHARACTER SET latin1;
CREATE TABLE `Bills` (
`staffID` INT,
`supplierID` INT,
`orderID` INT,
`billingDate` DATETIME,
`billingPrice` INT,
PRIMARY KEY (`orderID`)
) CHARACTER SET latin1;
CREATE TABLE `Manager` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `Cashier` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `WarehouseOperator` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `RegistrationOperator` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `BillingStaff` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
CREATE TABLE `Admin` (
`staffID` INT,
PRIMARY KEY (`staffID`)
) CHARACTER SET latin1;
