INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 312111_schema
#
CREATE DATABASE `db_312111_schema`;
USE `db_312111_schema`;
CREATE TABLE `person` (
`id` INT,
`name` VARCHAR(255),
`auth0_sub` VARCHAR(255),
`email` VARCHAR(255),
`is_admin` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT,
`name` VARCHAR(255),
`user_id` INT,
`s3_bucket` VARCHAR(255),
`s3_key` VARCHAR(255),
`program_filename` VARCHAR(255),
`spec_filename` VARCHAR(255),
`creation_dt` DATETIME,
`is_compilation_error` VARCHAR(255),
`compilation_error_message` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `project_tag` (
`id` INT,
`project_id` INT,
`tag` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `job` (
`id` INT,
`project_id` INT,
`benchmark_name` VARCHAR(255),
`spec_name` VARCHAR(255),
`kprove` VARCHAR(255),
`semantics` VARCHAR(255),
`request_dt` DATETIME,
`s3_bucket` VARCHAR(255),
`s3_key` VARCHAR(255),
`spec_filename` VARCHAR(255),
`timeout_sec` INT,
`memlimit_mb` INT,
`processing_dt` DATETIME,
`output_log_s3_key` VARCHAR(255),
`error_log_s3_key` VARCHAR(255),
`status_code` INT,
`timed_out` VARCHAR(255),
`proved` VARCHAR(255),
`completed_dt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_312111_schema') AS relationships;
relationships
Database: db_312111_schema

Table Connections:
------------------
[Implied]  job.project_id -> project.id
[Implied]  project.user_id -> person.id
[Implied]  project_tag.project_id -> project.id

DROP DATABASE `db_312111_schema`;
UNINSTALL EXTENSION vsql_schematron;
