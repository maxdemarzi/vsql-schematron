INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 352397_4-Classroom
#
CREATE DATABASE `db_352397_4_Classroom`;
USE `db_352397_4_Classroom`;
CREATE TABLE `student` (
`USN` VARCHAR(64),
`sname` VARCHAR(64),
`Address` VARCHAR(64),
`Phone` DECIMAL(10,2),
`Gender` VARCHAR(64),
PRIMARY KEY (`USN`)
) CHARACTER SET latin1;
CREATE TABLE `semsec` (
`ssid` VARCHAR(64),
`sem` DECIMAL(10,2),
`sec` VARCHAR(64),
PRIMARY KEY (`ssid`)
) CHARACTER SET latin1;
CREATE TABLE `class` (
`usn` VARCHAR(64),
`ssid` VARCHAR(64),
PRIMARY KEY (`usn`, `ssid`)
) CHARACTER SET latin1;
CREATE TABLE `subject` (
`subcode` VARCHAR(64),
`Title` VARCHAR(64),
`sem` DECIMAL(10,2),
`credits` DECIMAL(10,2),
PRIMARY KEY (`subcode`)
) CHARACTER SET latin1;
CREATE TABLE `iamarks` (
`usn` VARCHAR(64),
`subcode` VARCHAR(64),
`ssid` VARCHAR(64),
`test1` DECIMAL(10,2),
`test2` DECIMAL(10,2),
`test3` DECIMAL(10,2),
`finalia` DECIMAL(10,2),
PRIMARY KEY (`usn`, `subcode`, `ssid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_352397_4_Classroom') AS relationships;
relationships
Database: db_352397_4_Classroom

Table Connections:
------------------
[Implied]  class.ssid -> semsec.ssid
[Implied]  class.usn -> iamarks.usn
[Implied]  class.usn -> student.USN
[Implied]  iamarks.ssid -> semsec.ssid
[Implied]  iamarks.subcode -> subject.subcode
[Implied]  iamarks.usn -> class.usn
[Implied]  iamarks.usn -> student.USN

DROP DATABASE `db_352397_4_Classroom`;
UNINSTALL EXTENSION vsql_schematron;
