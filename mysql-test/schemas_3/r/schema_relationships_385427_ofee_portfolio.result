CREATE DATABASE `db_385427_ofee_portfolio`;
USE `db_385427_ofee_portfolio`;
CREATE TABLE `artcomments` (
`id` INT,
`pseudo` VARCHAR(64),
`content` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`article_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT,
`title` VARCHAR(64),
`description` VARCHAR(64),
`image` VARCHAR(64),
`resume` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`categorie_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_has_tags` (
`article_id` INT,
`tag_id` INT,
PRIMARY KEY (`article_id`, `tag_id`)
) CHARACTER SET latin1;
CREATE TABLE `works_has_categories` (
`work_id` INT,
`categorie_id` INT,
PRIMARY KEY (`work_id`, `categorie_id`)
) CHARACTER SET latin1;
CREATE TABLE `works_has_tags` (
`work_id` INT,
`tag_id` INT,
PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_385427_ofee_portfolio') AS relationships;
