CREATE TABLE `DARWIN` (
`component` VARCHAR(64),
`modified` DATETIME,
`version` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `DARWIN_LOCK` (
`processName` VARCHAR(64),
`leaseUntil` DATETIME,
`unlockKey` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `DARWIN_PATCH` (
`id` INT,
`componentName` VARCHAR(64),
`patchName` VARCHAR(64),
`processTime` INT,
`detectedOn` DATETIME,
`finishedOn` DATETIME,
`platform` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `DARWIN_SQL` (
`id` INT,
`patchId` INT,
`statementHash` VARCHAR(64),
`statement` VARCHAR(64),
`processTime` INT,
`finishedOn` DATETIME,
`exception` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
