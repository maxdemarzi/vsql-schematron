`userId` INT,
`courseId` INT,
PRIMARY KEY (`userId`, `courseId`, `role`)
) CHARACTER SET latin1;
CREATE TABLE `Test` (
`id` INT,
`updatedAt` DATETIME,
`name` VARCHAR(64),
`date` DATETIME,
`courseId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `TestResult` (
`id` INT,
`createdAt` DATETIME,
`result` INT,
`graderId` INT,
`studentId` INT,
`testId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
