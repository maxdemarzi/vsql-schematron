`createddate` DATETIME,
`lastmodifieddate` DATETIME,
`description` VARCHAR(64),
`category` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `et_user_expense` (
`id` INT,
`username` VARCHAR(64),
`discountpercent` DECIMAL(10,2),
`amount` DECIMAL(10,2),
`expense_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `et_payments` (
`id` INT,
`paymentdate` DATETIME,
`amount` DECIMAL(10,2),
`username` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
