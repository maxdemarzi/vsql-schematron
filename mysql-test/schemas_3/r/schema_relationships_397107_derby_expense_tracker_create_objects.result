`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`role` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `authorities` (
`id` INT,
`username` VARCHAR(64),
`authority` VARCHAR(64),
`grantedby` VARCHAR(64),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `et_expense` (
`id` INT,
