`description` TEXT,
`notes` TEXT,
`tags` VARCHAR(50),
`quantity` INT,
`updatedAt` TIMESTAMP NULL,
`createdAt` TIMESTAMP NULL,
`campaignId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
