CREATE DATABASE `db_394803_1`;
USE `db_394803_1`;
CREATE TABLE `abilities` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `natures` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ev_spreads` (
`id` INT,
`hp` INT,
`attack` INT,
`defence` INT,
`spa` INT,
`spd` INT,
`speed` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `moves` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `items` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pokemon` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `generations` (
`id` INT,
`number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tiers` (
`id` INT,
`name` VARCHAR(64),
`generation_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `years` (
`id` INT,
`number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `months` (
`id` INT,
`number` INT,
`year_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tier_months` (
`id` INT,
`month_id` INT,
`tier_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tier_ratings` (
`id` INT,
