PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stat_records` (
`id` INT,
`raw_usage` INT,
`pokemon_id` INT,
`tier_rating_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ability_records` (
`id` INT,
`number` DECIMAL(10,2),
`ability_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `check_records` (
`id` INT,
`matchup_occurences` INT,
`kos_or_switches_caused` DECIMAL(10,2),
`kos_or_switches_stddev` DECIMAL(10,2),
`pokemon_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `item_records` (
`id` INT,
`number` DECIMAL(10,2),
`item_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `lead_records` (
`id` INT,
`number` DECIMAL(10,2),
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `move_records` (
`id` INT,
`number` DECIMAL(10,2),
`move_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `spread_records` (
`id` INT,
`number` DECIMAL(10,2),
`ev_spread_id` INT,
`nature_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `teammate_records` (
`id` INT,
`number` DECIMAL(10,2),
`pokemon_id` INT,
`stat_record_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
