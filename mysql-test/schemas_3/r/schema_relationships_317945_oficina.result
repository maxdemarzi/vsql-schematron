CREATE DATABASE `db_317945_oficina`;
USE `db_317945_oficina`;
CREATE TABLE `clientes` (
`cpf` VARCHAR(50) NOT NULL,
`nome` VARCHAR(50),
`idade` INT,
`rg` VARCHAR(50),
`telefone` VARCHAR(50),
PRIMARY KEY (`cpf`)
) CHARACTER SET latin1;
CREATE TABLE `carros` (
`placa` VARCHAR(50) NOT NULL,
`anomodelo` INT,
`marca` VARCHAR(50),
`modelo` VARCHAR(50),
`anofabricacao` INT,
`cpf_cliente` VARCHAR(50),
PRIMARY KEY (`placa`)
) CHARACTER SET latin1;
