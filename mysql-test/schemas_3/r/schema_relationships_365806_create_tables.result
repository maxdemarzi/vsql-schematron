CREATE TABLE `users` (
`id` INT NOT NULL,
`nick` VARCHAR(50),
`premmision` CHAR(50),
`pas_hash` CHAR(50),
`registration` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `info` (
`user_id` INT,
`data` TEXT
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`user_id` INT,
`title` VARCHAR(50),
`text` TEXT,
`image` VARCHAR(50),
`time` DATE
) CHARACTER SET latin1;
