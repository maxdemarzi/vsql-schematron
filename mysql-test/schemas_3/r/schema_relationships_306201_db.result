CREATE DATABASE `db_306201_db`;
USE `db_306201_db`;
CREATE TABLE `device` (
`device_id` VARCHAR(255),
`device_state` INT,
`device_name` VARCHAR(255),
`account_id` INT,
PRIMARY KEY (`device_id`)
) CHARACTER SET latin1;
CREATE TABLE `grouping` (
`grouping_name` VARCHAR(255),
`grouping_id` INT,
`account_id` INT,
PRIMARY KEY (`grouping_id`)
) CHARACTER SET latin1;
CREATE TABLE `traffic` (
`traffic_ip` VARCHAR(255),
`traffic_block` INT,
PRIMARY KEY (`traffic_ip`)
) CHARACTER SET latin1;
CREATE TABLE `traffic_detail` (
`traffic_ip` VARCHAR(255),
`traffic_time` DATETIME,
`traffic_id` INT
) CHARACTER SET latin1;
