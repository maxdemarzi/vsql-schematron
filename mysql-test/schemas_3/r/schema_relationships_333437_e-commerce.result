INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 333437_e-commerce
#
CREATE DATABASE `db_333437_e_commerce`;
USE `db_333437_e_commerce`;
CREATE TABLE `order_statuses` (
`id` TINYINT NOT NULL,
`order_statusescol` VARCHAR(50),
`order_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ordered_products` (
`id` BIGINT NOT NULL,
`product_id` INT,
`quantity` TINYINT,
`order_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `shipping_details` (
`id` INT NOT NULL,
`order_id` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`address` TEXT,
`address_2` TEXT,
`city` VARCHAR(50),
`state` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_333437_e_commerce') AS relationships;
relationships
Database: db_333437_e_commerce

Table Connections:
------------------
[Implied]  order_statuses.order_id -> orders.id
[Implied]  ordered_products.order_id -> orders.id
[Implied]  shipping_details.order_id -> orders.id

DROP DATABASE `db_333437_e_commerce`;
