CREATE DATABASE `db_356616_V1_Create_initial_tables`;
USE `db_356616_V1_Create_initial_tables`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`bio` VARCHAR(64),
`image` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `followers` (
`user_id` INT,
`followee_id` INT,
`inserted_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT,
`slug` VARCHAR(64),
`title` VARCHAR(64),
`description` VARCHAR(64),
`body` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
`author_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_tags` (
`id` INT,
`article_id` INT,
`tag_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT,
`body` VARCHAR(64),
`article_id` INT,
`author_id` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `favorite` (
`id` INT,
`user_id` INT,
`favorited_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_356616_V1_Create_initial_tables') AS relationships;
