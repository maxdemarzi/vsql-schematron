INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 312650_myportfolio
#
CREATE DATABASE `db_312650_myportfolio`;
USE `db_312650_myportfolio`;
CREATE TABLE `projet` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` TEXT,
`date` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `skill` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projetSkill` (
`id` INT NOT NULL,
`skill_id` INT,
`projet_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_312650_myportfolio') AS relationships;
relationships
Database: db_312650_myportfolio

Table Connections:
