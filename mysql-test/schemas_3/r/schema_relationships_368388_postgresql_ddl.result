`description` VARCHAR(64),
`createdBy` VARCHAR(64),
`createdOn` DATETIME,
`labels` VARCHAR(64),
`properties` VARCHAR(64),
`contentId` INT,
PRIMARY KEY (`globalId`)
) CHARACTER SET latin1;
CREATE TABLE `properties` (
`globalId` INT,
`pkey` VARCHAR(64),
`pvalue` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `labels` (
`globalId` INT,
`label` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `logconfiguration` (
`logger` VARCHAR(64),
`loglevel` VARCHAR(64),
PRIMARY KEY (`logger`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`tenantId` VARCHAR(64),
`groupId` VARCHAR(64),
`description` VARCHAR(64),
`artifactsType` VARCHAR(64),
`createdBy` VARCHAR(64),
`createdOn` DATETIME,
`modifiedBy` VARCHAR(64),
`modifiedOn` DATETIME,
`properties` VARCHAR(64),
PRIMARY KEY (`tenantId`, `groupId`)
) CHARACTER SET latin1;
