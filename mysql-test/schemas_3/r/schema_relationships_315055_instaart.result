INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 315055_instaart
#
CREATE DATABASE `db_315055_instaart`;
USE `db_315055_instaart`;
CREATE TABLE `comments` (
`id` INT,
`post_id` INT,
`user_id` INT,
`body` VARCHAR(64),
`date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `follows` (
`id` INT,
`following_id` INT,
`follower_id` INT
) CHARACTER SET latin1;
CREATE TABLE `likes` (
`id` INT,
`post_id` INT,
`user_id` INT
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`id` INT,
`user_id` INT,
`title` VARCHAR(64),
`caption` VARCHAR(64),
`image` VARCHAR(64),
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`display_name` VARCHAR(64),
`biodata` VARCHAR(64),
`image` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_315055_instaart') AS relationships;
relationships
Database: db_315055_instaart

Table Connections:
