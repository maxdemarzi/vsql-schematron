[Implied]  comments.post_id -> posts.id
[Implied]  comments.user_id -> users.id
[Implied]  likes.post_id -> posts.id
[Implied]  likes.user_id -> users.id
[Implied]  posts.user_id -> users.id

DROP DATABASE `db_315055_instaart`;
UNINSTALL EXTENSION vsql_schematron;
