CREATE DATABASE `db_359831_pg_schema`;
USE `db_359831_pg_schema`;
CREATE TABLE `authors` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`country` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books` (
`id` INT NOT NULL,
`title` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `books_authors` (
`id` INT NOT NULL,
`author_id` INT,
`book_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_359831_pg_schema') AS relationships;
