INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 382492_aeropuerto_campanero_db
#
CREATE DATABASE `db_382492_aeropuerto_campanero_db`;
USE `db_382492_aeropuerto_campanero_db`;
CREATE TABLE `tb_airline` (
`id` INT,
`code_airline` VARCHAR(64),
`name` VARCHAR(64),
`address` VARCHAR(64),
`id_airport` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_airport` (
`id` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tb_arrival` (
`id` INT,
`code_arrival` VARCHAR(64),
`id_flight` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_departure` (
`id` INT,
`code_departure` VARCHAR(64),
`id_flight` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_flight` (
`id` INT,
`code_flight` VARCHAR(64),
`type_flight` VARCHAR(64),
`flight_selection` VARCHAR(64),
`crew_plane` VARCHAR(64),
`destination` VARCHAR(64),
`runway` VARCHAR(64),
`date_flight` DATETIME,
`time_flight` DATETIME,
`id_airline` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_flight_requeriment_airline` (
`id` INT,
`code_flight` VARCHAR(64),
`model_plane` VARCHAR(64),
`Type_flight` VARCHAR(64),
`flight_selection` VARCHAR(64),
`capacity_plane` VARCHAR(64),
`crew_plane` VARCHAR(64),
`date_flight` DATETIME,
`time_flight` DATETIME,
`id_airline` INT,
`destination` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tb_freight` (
`id` INT,
`code_freight` VARCHAR(64),
`supported_weight` DECIMAL(10,2),
`id_plane` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_passengers` (
`id` INT,
`code_passenger` VARCHAR(64),
`supported_passengers` INT,
`id_plane` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_pilots` (
`id` INT,
`id_pilot` VARCHAR(64),
`name` VARCHAR(64),
`last_name` VARCHAR(64),
`phone` VARCHAR(64),
`email` VARCHAR(64),
`experience` VARCHAR(64),
`medical_checkup` VARCHAR(64),
`id_flight` INT
) CHARACTER SET latin1;
CREATE TABLE `tb_plane` (
`id` INT,
`code_plane` VARCHAR(64),
`model` VARCHAR(64),
`capacity` VARCHAR(64),
`storage_type` VARCHAR(64),
`id_airport` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_382492_aeropuerto_campanero_db') AS relationships;
relationships
