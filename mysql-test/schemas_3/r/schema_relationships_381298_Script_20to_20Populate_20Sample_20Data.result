) CHARACTER SET latin1;
CREATE TABLE `dept_tasks` (
`task_id` DECIMAL(10,2) NOT NULL,
`task_name` VARCHAR(50),
`dept_id` DECIMAL(10,2),
`updated_by` VARCHAR(50),
`updated_on` TIMESTAMP NULL,
PRIMARY KEY (`task_id`)
) CHARACTER SET latin1;
