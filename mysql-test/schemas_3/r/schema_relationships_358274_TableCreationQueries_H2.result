CREATE DATABASE `db_358274_TableCreationQueries_H2`;
USE `db_358274_TableCreationQueries_H2`;
CREATE TABLE `User` (
`userID` VARCHAR(64),
`name` VARCHAR(64),
`password` VARCHAR(64),
`regDate` DATETIME,
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `TestPlan` (
`testID` INT,
`userID` VARCHAR(64),
`testConfig` VARCHAR(64),
`creationTime` DATETIME,
PRIMARY KEY (`testID`)
) CHARACTER SET latin1;
CREATE TABLE `Report` (
`reportID` INT,
`testID` VARCHAR(64),
`userID` VARCHAR(64),
`report` VARCHAR(64),
`passed` INT,
`failed` INT,
`passRate` INT,
`runTime` DATETIME,
PRIMARY KEY (`reportID`)
) CHARACTER SET latin1;
