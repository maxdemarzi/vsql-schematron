CREATE DATABASE `db_325819_database`;
USE `db_325819_database`;
CREATE TABLE `contracts` (
`id` INT NOT NULL,
`description` TEXT,
`amount` DOUBLE,
`start_date` DATE,
`end_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cashflows` (
`id` INT NOT NULL,
`reference_date` DATE,
`amount` DOUBLE,
`contract_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reports` (
`id` INT NOT NULL,
`contract_id` INT,
`reference_date` DATE,
`state` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_325819_database') AS relationships;
