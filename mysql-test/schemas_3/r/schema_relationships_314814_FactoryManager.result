INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 314814_FactoryManager
#
CREATE DATABASE `db_314814_FactoryManager`;
USE `db_314814_FactoryManager`;
CREATE TABLE `Registration` (
`RegistrationID` INT NOT NULL,
`Username` VARCHAR(50),
`Email` VARCHAR(50),
`Password` VARCHAR(50),
`FirstName` VARCHAR(50),
`LastName` VARCHAR(50),
`CompanyName` VARCHAR(50),
`Address` VARCHAR(50),
`City` VARCHAR(50),
`State` VARCHAR(50),
`ZipCode` INT,
PRIMARY KEY (`RegistrationID`)
) CHARACTER SET latin1;
CREATE TABLE `Importation` (
`ImportationID` INT NOT NULL,
`RegistrationID` INT,
`CompanyName` VARCHAR(50),
`PointOfContact` VARCHAR(50),
`CountryCode` INT,
`PhoneNumber` INT,
`Email` VARCHAR(50),
`Address` VARCHAR(50),
`City` VARCHAR(50),
`State` VARCHAR(50),
`ZipCode` INT,
`CurrentDate` DATE,
`Product` VARCHAR(50),
`PricePerUnit` DOUBLE,
`Quantity` INT,
PRIMARY KEY (`ImportationID`)
) CHARACTER SET latin1;
CREATE TABLE `Exportation` (
`ExportationID` INT NOT NULL,
`RegistrationID` INT,
`CompanyName` VARCHAR(50),
`PointOfContact` VARCHAR(50),
`CountryCode` INT,
`PhoneNumber` INT,
`Email` VARCHAR(50),
`Address` VARCHAR(50),
`City` VARCHAR(50),
`State` VARCHAR(50),
`ZipCode` INT,
`CurrentDate` DATE,
`Product` VARCHAR(50),
`PricePerUnit` DOUBLE,
`Quantity` INT,
PRIMARY KEY (`ExportationID`)
) CHARACTER SET latin1;
CREATE TABLE `Delivery` (
`DeliveryID` INT NOT NULL,
`RegistrationID` INT,
`ExportationID` INT,
`CompanyName` VARCHAR(50),
`PointOfContact` VARCHAR(50),
`CountryCode` INT,
`PhoneNumber` INT,
`Email` VARCHAR(50),
`Address` VARCHAR(50),
`City` VARCHAR(50),
`State` VARCHAR(50),
`ZipCode` INT,
`CurrentDate` DATE,
`ContainerPricePerUnit` DOUBLE,
`ContainerQuantity` INT,
`ShipmentPrice` DOUBLE,
PRIMARY KEY (`DeliveryID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_314814_FactoryManager') AS relationships;
relationships
Database: db_314814_FactoryManager

Table Connections:
