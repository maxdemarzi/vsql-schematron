CREATE DATABASE `db_383060_stully`;
USE `db_383060_stully`;
CREATE TABLE `account` (
`account_id` INT,
`username` VARCHAR(64),
`password_hash` VARCHAR(64),
`email` VARCHAR(64),
`punten` INT,
`status` VARCHAR(64),
PRIMARY KEY (`account_id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`comment_id` INT,
`comment` VARCHAR(64),
`punten` INT,
`post_id` INT,
`account_id` INT
) CHARACTER SET latin1;
CREATE TABLE `posts` (
`post_id` INT,
`account_id` INT,
`title` VARCHAR(64),
`code` VARCHAR(64),
`subtext` VARCHAR(64),
`timestamp` DATETIME,
PRIMARY KEY (`post_id`)
) CHARACTER SET latin1;
