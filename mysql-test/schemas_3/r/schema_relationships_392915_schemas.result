[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  salaries.emp_no -> employees.emp_no
[Implied]  title.emp_no -> employees.emp_no

DROP DATABASE `db_392915_schemas`;
UNINSTALL EXTENSION vsql_schematron;
