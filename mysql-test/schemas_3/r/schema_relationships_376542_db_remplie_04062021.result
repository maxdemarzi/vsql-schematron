) CHARACTER SET latin1;
CREATE TABLE `works_has_categories` (
`work_id` INT,
`categorie_id` INT,
PRIMARY KEY (`work_id`, `categorie_id`)
) CHARACTER SET latin1;
CREATE TABLE `works_has_tags` (
`work_id` INT,
`tag_id` INT,
PRIMARY KEY (`work_id`, `tag_id`)
) CHARACTER SET latin1;
