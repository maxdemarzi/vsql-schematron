`resume` VARCHAR(64),
`created_at` VARCHAR(64),
`updated_at` VARCHAR(64),
`categorie_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles_has_tags` (
