CREATE TABLE `KolekcjaGrafik` (
`id` INT NOT NULL,
`dataUtworzenia` DATE,
`odnośnik` VARCHAR(50),
`Projektant_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Projektant` (
`id` INT NOT NULL,
`imię` VARCHAR(50),
`nazwisko` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Zlecenie` (
`id` INT NOT NULL,
`treść` VARCHAR(50),
`DziałProjektowy_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
