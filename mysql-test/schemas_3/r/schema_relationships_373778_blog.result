CREATE DATABASE `db_373778_blog`;
USE `db_373778_blog`;
CREATE TABLE `blog` (
`blog_id` INT,
`title` VARCHAR(50),
`created` VARCHAR(50),
`description` VARCHAR(50),
`attachment` VARCHAR(50),
`user_id` INT,
`category` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT NOT NULL,
`email` VARCHAR(50),
`password` VARCHAR(50),
`name` VARCHAR(50),
`lastname` VARCHAR(50),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
