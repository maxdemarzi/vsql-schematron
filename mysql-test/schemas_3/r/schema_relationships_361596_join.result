INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 361596_join
#
CREATE DATABASE `db_361596_join`;
USE `db_361596_join`;
CREATE TABLE `engine` (
`id_e` INT NOT NULL,
`name_e` VARCHAR(50),
PRIMARY KEY (`id_e`)
) CHARACTER SET latin1;
CREATE TABLE `frame` (
`id_f` INT NOT NULL,
`name_f` VARCHAR(50),
PRIMARY KEY (`id_f`)
) CHARACTER SET latin1;
CREATE TABLE `transmission` (
`id_t` INT NOT NULL,
`name_t` VARCHAR(50),
PRIMARY KEY (`id_t`)
) CHARACTER SET latin1;
CREATE TABLE `car` (
`id_c` INT NOT NULL,
`name_c` VARCHAR(50),
`id_f` INT,
`id_e` INT,
`id_t` INT,
PRIMARY KEY (`id_c`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_361596_join') AS relationships;
