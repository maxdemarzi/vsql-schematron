INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 382514_matrix
#
CREATE DATABASE `db_382514_matrix`;
USE `db_382514_matrix`;
CREATE TABLE `address` (
`addr_id` INT NOT NULL,
`addr_street` VARCHAR(50),
`addr_number` VARCHAR(50),
`addr_zipcode` VARCHAR(50),
`addr_neighborhood` VARCHAR(50),
`addr_city` VARCHAR(50),
`addr_state` VARCHAR(50),
`addr_country` VARCHAR(50),
`addr_zone` VARCHAR(50),
`addr_latitude` VARCHAR(50),
`addr_longitude` VARCHAR(50),
PRIMARY KEY (`addr_id`)
) CHARACTER SET latin1;
CREATE TABLE `store` (
`stre_id` INT NOT NULL,
`stre_name` VARCHAR(50),
`stre_rsocial` VARCHAR(50),
`stre_type_rsocial` VARCHAR(50),
`stre_tplace` VARCHAR(50),
`addr_id` INT,
`stre_element` VARCHAR(50),
PRIMARY KEY (`stre_id`)
) CHARACTER SET latin1;
CREATE TABLE `record` (
`rcrd_id` INT NOT NULL,
`stre_id` INT,
`rcrd_type` VARCHAR(50),
`rcrd_family` VARCHAR(50),
`rcrd_name` VARCHAR(50),
`rcrd_size` VARCHAR(50),
`rcrd_modality` VARCHAR(50),
`rcrd_milk` VARCHAR(50),
`rcrd_sugar` VARCHAR(50),
`rcrd_tapioca` VARCHAR(50),
`rcrd_tapioca_extra` VARCHAR(50),
`rcrd_topping` VARCHAR(50),
`rcrd_jelly_coffee` VARCHAR(50),
`rcrd_jelly_samba` VARCHAR(50),
`rcrd_jelly_strawberry` VARCHAR(50),
`rcrd_jelly_lychee` VARCHAR(50),
`rcrd_pb_blueberry` VARCHAR(50),
`rcrd_pb_strawberry` VARCHAR(50),
`rcrd_pb_lychee` VARCHAR(50),
`rcrd_cheesefoam` VARCHAR(50),
`rcrd_pudding_taro` VARCHAR(50),
`rcrd_pudding_flan` VARCHAR(50),
`rcrd_chamoymiguelito` VARCHAR(50),
PRIMARY KEY (`rcrd_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_382514_matrix') AS relationships;
relationships
Database: db_382514_matrix

Table Connections:
------------------
[Implied]  record.stre_id -> store.stre_id
[Implied]  store.addr_id -> address.addr_id

DROP DATABASE `db_382514_matrix`;
UNINSTALL EXTENSION vsql_schematron;
