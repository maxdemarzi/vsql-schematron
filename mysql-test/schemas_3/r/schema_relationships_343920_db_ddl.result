CREATE DATABASE `db_343920_db_ddl`;
USE `db_343920_db_ddl`;
CREATE TABLE `Community` (
`uuid` VARCHAR(64),
`name` VARCHAR(64),
`short_name` VARCHAR(64),
`handle` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `Collection` (
`uuid` VARCHAR(64),
`comm_uuid` VARCHAR(64),
`name` VARCHAR(64),
`short_name` VARCHAR(64),
`reportable` DECIMAL(10,2),
`owner` VARCHAR(64),
`handle` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `Monthly_Item_Count` (
`coll_uuid` INT,
`year` INT,
`month` INT,
`item_count` INT
) CHARACTER SET latin1;
CREATE TABLE `FilesProcessed` (
`name` VARCHAR(64),
`timestamp` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Email_Distribution` (
`name` VARCHAR(64),
`email` VARCHAR(64),
`formats` VARCHAR(64),
`active` DECIMAL(10,2),
`notes` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_343920_db_ddl') AS relationships;
