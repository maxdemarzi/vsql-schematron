CREATE DATABASE `db_348116_schema_group_mysql`;
USE `db_348116_schema_group_mysql`;
CREATE TABLE `groups` (
`id` BIGINT NOT NULL,
`group_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_authorities` (
`group_id` BIGINT,
`authority` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `group_members` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`group_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_348116_schema_group_mysql') AS relationships;
