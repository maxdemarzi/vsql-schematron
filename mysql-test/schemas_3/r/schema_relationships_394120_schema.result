INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 394120_schema
#
CREATE DATABASE `db_394120_schema`;
USE `db_394120_schema`;
CREATE TABLE `employees` (
`emp_no` INT,
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`gender` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(64),
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `titles` (
`emp_no` INT,
`title` VARCHAR(64),
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `title`, `from_date`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_394120_schema') AS relationships;
relationships
Database: db_394120_schema

Table Connections:
------------------
[Implied]  dept_emp.dept_no -> departments.dept_no
[Implied]  dept_emp.emp_no -> employees.emp_no
[Implied]  dept_manager.dept_no -> departments.dept_no
[Implied]  dept_manager.emp_no -> employees.emp_no
[Implied]  titles.emp_no -> employees.emp_no

DROP DATABASE `db_394120_schema`;
UNINSTALL EXTENSION vsql_schematron;
