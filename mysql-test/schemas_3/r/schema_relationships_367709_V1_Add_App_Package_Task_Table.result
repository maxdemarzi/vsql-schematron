CREATE DATABASE `db_367709_V1_Add_App_Package_Task_Table`;
USE `db_367709_V1_Add_App_Package_Task_Table`;
CREATE TABLE `apppackage` (
`id` VARCHAR(64),
`app_pkg_id` VARCHAR(64),
`app_pkg_name` VARCHAR(64),
`app_pkg_version` VARCHAR(64),
`app_pkg_path` VARCHAR(64),
`app_provider` VARCHAR(64),
`app_pkg_desc` VARCHAR(64),
`app_pkg_affinity` VARCHAR(64),
`app_icon_url` VARCHAR(64),
`app_id` VARCHAR(64),
`tenant_id` VARCHAR(64),
`created_time` DATETIME,
`modified_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apppackagehost` (
`id` INT,
`pkg_host_key` VARCHAR(64),
`host_ip` VARCHAR(64),
`app_pkg_id` VARCHAR(64),
`distribution_status` VARCHAR(64),
`tenant_id` VARCHAR(64),
`error` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apmtenant` (
`tenant` VARCHAR(64),
PRIMARY KEY (`tenant`)
) CHARACTER SET latin1;
CREATE TABLE `apppackageinfo` (
`id` VARCHAR(64),
`app_id` VARCHAR(64),
`appstore_ip` VARCHAR(64),
`package_id` VARCHAR(64),
`name` VARCHAR(64),
`appstore_name` VARCHAR(64),
`appstore_endpoint` VARCHAR(64),
`pkg_size` VARCHAR(64),
`version` VARCHAR(64),
`type` VARCHAR(64),
`affinity` VARCHAR(64),
`industry` VARCHAR(64),
`contact` VARCHAR(64),
`user_id` VARCHAR(64),
`user_name` VARCHAR(64),
`status` VARCHAR(64),
`short_desc` VARCHAR(64),
`test_task_id` VARCHAR(64),
`provider` VARCHAR(64),
`sync_status` VARCHAR(64),
`created_time` DATETIME,
`updated_time` DATETIME,
`operational_info` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `apptemplate` (
`template_id` VARCHAR(64),
`app_name` VARCHAR(64),
`version` VARCHAR(64),
`app_package_id` VARCHAR(64),
`app_id` VARCHAR(64),
`tenant_id` VARCHAR(64),
`deploy_type` VARCHAR(64),
PRIMARY KEY (`template_id`)
) CHARACTER SET latin1;
CREATE TABLE `apptemplateinputattr` (
`attr_id` INT,
`template_id` VARCHAR(64),
`name` VARCHAR(64),
`type` VARCHAR(64),
`default_value` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`attr_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_367709_V1_Add_App_Package_Task_Table') AS relationships;
