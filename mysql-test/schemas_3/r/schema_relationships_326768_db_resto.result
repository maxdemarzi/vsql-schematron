INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 326768_db_resto
#
CREATE DATABASE `db_326768_db_resto`;
USE `db_326768_db_resto`;
CREATE TABLE `food` (
`id` INT,
`name` VARCHAR(64),
`detail` VARCHAR(64),
`price` INT,
`category` INT,
`status` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `food_category` (
`id` INT,
`name` VARCHAR(64),
`is_food` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `food_image` (
`id` INT,
`food_id` INT,
`img` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `order` (
`id` INT,
`user_id` INT,
`order_time` DATETIME,
`total_price` INT,
`is_payed` INT,
`step` INT,
`table_number` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `order_item` (
`id` INT,
`food_id` INT,
`qty` INT,
`note` VARCHAR(64),
`approved` INT,
`order_id` INT
) CHARACTER SET latin1;
CREATE TABLE `topup_history` (
`id` INT,
`user_id` INT,
`nominal` INT,
`topup_date` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`username` VARCHAR(64),
`email` VARCHAR(64),
`password_hash` VARCHAR(64),
`status` INT,
`auth_key` VARCHAR(64),
`password_reset_token` VARCHAR(64),
`account_activation_token` VARCHAR(64),
`role` INT,
`current_saldo` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_326768_db_resto') AS relationships;
