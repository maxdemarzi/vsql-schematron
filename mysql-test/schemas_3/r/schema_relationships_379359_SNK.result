`name` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Bans` (
`id` INT,
`userId` INT,
`channelId` INT,
`IP` VARCHAR(64),
`isGlobal` BOOL,
`reason` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
