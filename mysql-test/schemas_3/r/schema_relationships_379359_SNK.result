`owner` INT,
`isLocked` BOOL,
`isPublic` BOOL,
`password` VARCHAR(64),
`dateCreated` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ChannelConfigs` (
`id` INT,
`channelId` INT,
`name` VARCHAR(64),
`isActivated` BOOL,
`logFileUrl` VARCHAR(64),
