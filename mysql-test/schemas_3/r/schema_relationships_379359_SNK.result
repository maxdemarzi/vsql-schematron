`isAdmin` BOOL,
`lastSeen` DATETIME,
`avatarUrl` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` INT,
`expiresAt` INT,
`data` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Videos` (
`url` VARCHAR(64),
`playlistId` INT,
`addedBy` INT,
`positionInList` INT,
`dateAdded` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `Playlists` (
`id` INT,
