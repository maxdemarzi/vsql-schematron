CREATE DATABASE `db_396585_create_db`;
USE `db_396585_create_db`;
CREATE TABLE `danceTable` (
`uid` INT,
`name` VARCHAR(255),
`danceTime` DATETIME,
`venue` VARCHAR(255),
`attendanceCount` INT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `friendlyStatuses` (
`uid` INT,
`name` VARCHAR(255),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`uid` INT,
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`email` VARCHAR(255),
`isAdmin` INT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `superAdmins` (
`uid` INT,
`firstName` VARCHAR(255),
`lastName` VARCHAR(255),
`email` VARCHAR(255),
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
CREATE TABLE `studentStatuses` (
`uid` INT,
`danceUID` INT,
`userUID` INT,
`status` INT,
`lastUpdate` DATETIME,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
