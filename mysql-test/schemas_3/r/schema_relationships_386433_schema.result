INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 386433_schema
#
CREATE DATABASE `db_386433_schema`;
USE `db_386433_schema`;
CREATE TABLE `guilds` (
`GuildID` INT,
`Prefix` VARCHAR(64),
`StarChannel` INT,
PRIMARY KEY (`GuildID`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`GuildID` INT,
`TagOwner` INT,
`TagName` VARCHAR(64),
`TagContent` VARCHAR(64),
`Uses` INT,
PRIMARY KEY (`GuildID`, `TagName`)
) CHARACTER SET latin1;
CREATE TABLE `starboard` (
`BaseMessageID` INT,
`GuildID` INT,
`StarMessageID` INT,
`Stars` INT,
PRIMARY KEY (`BaseMessageID`, `GuildID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_386433_schema') AS relationships;
