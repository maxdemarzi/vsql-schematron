CREATE DATABASE `db_348616_blog_with_likes_postgres`;
USE `db_348616_blog_with_likes_postgres`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`password_digest` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `articles` (
`id` INT NOT NULL,
`author_id` INT,
`title` TEXT,
`body` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `likes` (
`id` INT NOT NULL,
`article_id` INT,
`user_id` INT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_348616_blog_with_likes_postgres') AS relationships;
