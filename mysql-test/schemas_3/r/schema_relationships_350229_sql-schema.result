INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 350229_sql-schema
#
CREATE DATABASE `db_350229_sql_schema`;
USE `db_350229_sql_schema`;
CREATE TABLE `ims.customers` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`surname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ims.items` (
`item_id` INT NOT NULL,
`name` VARCHAR(50),
`value` DECIMAL(10,2),
PRIMARY KEY (`item_id`)
) CHARACTER SET latin1;
CREATE TABLE `ims.orders` (
`orders_id` INT NOT NULL,
`customer_id` INT,
PRIMARY KEY (`orders_id`)
) CHARACTER SET latin1;
CREATE TABLE `ims.orders_items` (
`orders_items_id` INT NOT NULL,
`orders_id` INT,
`item_id` INT,
PRIMARY KEY (`orders_items_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_350229_sql_schema') AS relationships;
relationships
Database: db_350229_sql_schema

Table Connections:
------------------
[Implied]  ims.orders.customer_id -> ims.customers.id
[Implied]  ims.orders_items.item_id -> ims.items.item_id
[Implied]  ims.orders_items.orders_id -> ims.orders.orders_id

DROP DATABASE `db_350229_sql_schema`;
UNINSTALL EXTENSION vsql_schematron;
