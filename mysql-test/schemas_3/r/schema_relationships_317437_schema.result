CREATE DATABASE `db_317437_schema`;
USE `db_317437_schema`;
CREATE TABLE `users` (
`id` VARCHAR(64),
`name` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`document` VARCHAR(64),
`user_type` VARCHAR(64),
`balance` DECIMAL(10,2)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` VARCHAR(64),
`payer` VARCHAR(64),
`payee` VARCHAR(64),
`value` DECIMAL(10,2),
`status` VARCHAR(64)
) CHARACTER SET latin1;
