#
CREATE DATABASE `db_359880_script`;
USE `db_359880_script`;
CREATE TABLE `s` (
`snum` INT NOT NULL,
`sname` VARCHAR(50),
`status` INT,
`city` VARCHAR(50),
PRIMARY KEY (`snum`)
) CHARACTER SET latin1;
CREATE TABLE `p` (
`pnum` INT NOT NULL,
`pname` VARCHAR(50),
`color` VARCHAR(50),
`weight` INT,
PRIMARY KEY (`pnum`)
) CHARACTER SET latin1;
CREATE TABLE `sp` (
`snum` INT NOT NULL,
`pnum` INT NOT NULL,
`qty` INT,
PRIMARY KEY (`snum`, `pnum`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_359880_script') AS relationships;
