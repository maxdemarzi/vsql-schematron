CREATE DATABASE `db_331203_schema`;
USE `db_331203_schema`;
CREATE TABLE `form` (
`id` INT,
`author` VARCHAR(64),
`projectName` VARCHAR(64),
`contactInfo` VARCHAR(64),
`projectDescription` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`name` VARCHAR(64),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `PTRelation` (
`iden` VARCHAR(64),
`projectID` INT,
`tagName` VARCHAR(64),
PRIMARY KEY (`iden`)
) CHARACTER SET latin1;
