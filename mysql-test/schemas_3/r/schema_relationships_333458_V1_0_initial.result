CREATE DATABASE `db_333458_V1_0_initial`;
USE `db_333458_V1_0_initial`;
CREATE TABLE `Customer` (
`CustomerId` VARCHAR(64),
`name` VARCHAR(64),
`version` INT,
PRIMARY KEY (`CustomerId`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`order_id` INT,
`customer_id` VARCHAR(64),
`version` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderDetails` (
`OrderDetailsId` INT,
`order_id` INT,
`version` INT,
PRIMARY KEY (`OrderDetailsId`)
) CHARACTER SET latin1;
CREATE TABLE `row` (
`RowId` INT,
`Name` VARCHAR(64),
`version` INT,
PRIMARY KEY (`RowId`)
) CHARACTER SET latin1;
CREATE TABLE `column` (
`ColumnId` INT,
`Name` VARCHAR(64),
`version` INT,
PRIMARY KEY (`ColumnId`)
) CHARACTER SET latin1;
CREATE TABLE `cell` (
`RowId` INT,
`ColumnId` INT,
PRIMARY KEY (`RowId`, `ColumnId`)
) CHARACTER SET latin1;
CREATE TABLE `cell_data` (
`RowId` INT,
`ColumnId` INT,
`cell_text` VARCHAR(64),
PRIMARY KEY (`RowId`, `ColumnId`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_333458_V1_0_initial') AS relationships;
