INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 323186_database
#
CREATE DATABASE `db_323186_database`;
USE `db_323186_database`;
CREATE TABLE `Feature` (
`featureId` INT,
`name` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `Hospital` (
`hospitalId` INT,
`name` VARCHAR(64),
`login` VARCHAR(64),
`password` VARCHAR(64),
`location` INT,
`city` VARCHAR(64),
`street` VARCHAR(64),
`building` VARCHAR(64),
`phone` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `HospitalFeature` (
`hospitalId` INT,
`featureId` INT,
PRIMARY KEY (`hospitalId`, `featureId`)
) CHARACTER SET latin1;
CREATE TABLE `Message` (
`messageId` INT,
`address` VARCHAR(64),
`age` INT,
`weight` INT,
`gender` VARCHAR(64),
`registration` DATETIME,
`episode` DATETIME,
`gcScale` INT,
`arterialPressure` VARCHAR(64),
`symptoms` VARCHAR(64),
`patology` VARCHAR(64),
`solution` VARCHAR(64),
`hospitalId` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_323186_database') AS relationships;
relationships
Database: db_323186_database

Table Connections:
------------------
[Implied]  HospitalFeature.featureId -> Feature.featureId
[Implied]  HospitalFeature.hospitalId -> Hospital.hospitalId
[Implied]  Message.hospitalId -> Hospital.hospitalId

DROP DATABASE `db_323186_database`;
UNINSTALL EXTENSION vsql_schematron;
