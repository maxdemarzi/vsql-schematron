CREATE DATABASE `db_398286_db_sensus`;
USE `db_398286_db_sensus`;
CREATE TABLE `tbl_kelahiran` (
`id` VARCHAR(50),
`kk` VARCHAR(50),
`nama` VARCHAR(50),
`jenis_kelamin` VARCHAR(50),
`tempat_lahir` TEXT,
`tanggal_lahir` DATE
) CHARACTER SET latin1;
CREATE TABLE `tbl_kematian` (
`nik` VARCHAR(50),
`tanggal` DATE,
`tempat` TEXT,
`penyebab` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tbl_lokasi` (
`kk` VARCHAR(50),
`latitude` DOUBLE,
`longitude` DOUBLE
) CHARACTER SET latin1;
CREATE TABLE `tbl_pendatang` (
`nik` VARCHAR(50),
`tanggal` DATE,
`alamat` TEXT,
`alasan` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tbl_penduduk` (
`nik` VARCHAR(50) NOT NULL,
`nama` VARCHAR(50),
`alamat` TEXT,
`jenis_kelamin` VARCHAR(50),
`tempat_lahir` TEXT,
`tanggal_lahir` DATE,
`agama` VARCHAR(50),
`pendidikan` VARCHAR(50),
`pekerjaan` VARCHAR(50),
`status` VARCHAR(50),
PRIMARY KEY (`nik`)
) CHARACTER SET latin1;
CREATE TABLE `tbl_pindah` (
`nik` VARCHAR(50),
`tanggal` DATE,
`tujuan` TEXT,
`alasan` TEXT
) CHARACTER SET latin1;
CREATE TABLE `tbl_user` (
`username` VARCHAR(50) NOT NULL,
`password` VARCHAR(50),
`nama` VARCHAR(50),
`level` VARCHAR(50),
PRIMARY KEY (`username`)
) CHARACTER SET latin1;
