CREATE DATABASE `db_371582_eyalet_backend_project_chen`;
USE `db_371582_eyalet_backend_project_chen`;
CREATE TABLE `Customer` (
`id` VARCHAR(50) NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`phone_number` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Address` (
`id` INT NOT NULL,
`customer_id` VARCHAR(50),
`city` VARCHAR(50),
`street` VARCHAR(50),
`house_number` INT,
`zip_code` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Dog` (
`id` INT NOT NULL,
`customer_id` VARCHAR(50),
`dog_name` VARCHAR(50),
`weight` DOUBLE,
`age` INT,
`size` VARCHAR(50),
`gender` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`city` VARCHAR(50),
`latitude` DOUBLE,
`longitude` DOUBLE,
`radius` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Service` (
`id` INT NOT NULL,
`service_name` VARCHAR(50),
`price` INT,
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Employee_services` (
`employee_id` INT,
`service_id` INT
) CHARACTER SET latin1;
CREATE TABLE `Additional_services` (
`id` INT NOT NULL,
`service_name` VARCHAR(50),
`price` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Orders` (
`id` INT NOT NULL,
`employee_id` INT,
`service_id` INT,
`customer_id` VARCHAR(50),
`order_date` DATE,
`total_price` INT,
`dog_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Order_add` (
`additional_services_id` INT,
`Orders_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_371582_eyalet_backend_project_chen') AS relationships;
