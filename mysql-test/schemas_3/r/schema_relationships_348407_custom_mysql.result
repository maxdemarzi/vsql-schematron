CREATE TABLE `cus_custom` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`address` VARCHAR(50),
`phone` VARCHAR(50),
`position` VARCHAR(50),
`area` VARCHAR(50),
`house_property` VARCHAR(50),
`center` VARCHAR(50),
