`kezu` VARCHAR(50),
`leixing` VARCHAR(50),
`leaseholder` VARCHAR(50),
`leaseholder_phone` VARCHAR(50),
`create_by` VARCHAR(50),
`create_date` DATETIME,
`update_by` VARCHAR(50),
`update_date` DATETIME,
`remarks` VARCHAR(50),
`del_flag` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cus_equipment` (
`id` VARCHAR(50) NOT NULL,
`nam` VARCHAR(50),
`type` VARCHAR(50),
`mac` VARCHAR(50),
`number` VARCHAR(50),
`create_by` VARCHAR(50),
`create_date` DATETIME,
`update_by` VARCHAR(50),
`update_date` DATETIME,
`remarks` VARCHAR(50),
`del_flag` CHAR(50),
`cus_id` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
