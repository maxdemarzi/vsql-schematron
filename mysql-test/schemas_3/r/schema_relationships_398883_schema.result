INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 398883_schema
#
CREATE DATABASE `db_398883_schema`;
USE `db_398883_schema`;
CREATE TABLE `departments` (
`department_id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`department_id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`role_id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`role_id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`employee_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`employee_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_398883_schema') AS relationships;
relationships
Database: db_398883_schema

Table Connections:
