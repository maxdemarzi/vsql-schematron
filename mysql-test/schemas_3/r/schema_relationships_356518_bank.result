INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 356518_bank
#
CREATE DATABASE `db_356518_bank`;
USE `db_356518_bank`;
CREATE TABLE `borrower` (
`cust_name` VARCHAR(64),
`loan_no` INT
) CHARACTER SET latin1;
CREATE TABLE `branch` (
`branch_name` VARCHAR(64),
`branch_city` VARCHAR(64),
`assets` INT,
PRIMARY KEY (`branch_name`)
) CHARACTER SET latin1;
CREATE TABLE `customer` (
`cust_name` VARCHAR(64),
`cust_street` VARCHAR(64),
`cust_city` VARCHAR(64),
PRIMARY KEY (`cust_name`)
) CHARACTER SET latin1;
CREATE TABLE `depositor` (
`cust_name` VARCHAR(64),
`acc_no` INT
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`employee_name` VARCHAR(64),
`branch_name` VARCHAR(64),
`salary` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_356518_bank') AS relationships;
relationships
Database: db_356518_bank

Table Connections:
------------------
[Implied]  borrower.cust_name -> customer.cust_name
[Implied]  depositor.cust_name -> customer.cust_name
[Implied]  employee.branch_name -> branch.branch_name

DROP DATABASE `db_356518_bank`;
UNINSTALL EXTENSION vsql_schematron;
