INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 325705_db
#
CREATE DATABASE `db_325705_db`;
USE `db_325705_db`;
CREATE TABLE `owner` (
`photo` VARCHAR(50),
`first` VARCHAR(50),
`last` VARCHAR(50),
`building` VARCHAR(50),
`street` VARCHAR(50),
`city` VARCHAR(50),
`state` VARCHAR(50),
`zip` VARCHAR(50),
`phone` VARCHAR(50),
`alive` VARCHAR(50),
`notes` VARCHAR(50),
`link_to_pet` VARCHAR(50),
`hide` TINYINT,
`id` INT NOT NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pet` (
`id` INT NOT NULL,
`photo` VARCHAR(50),
`name` VARCHAR(50),
`breed` VARCHAR(50),
`species` VARCHAR(50),
`dob` DATE,
`shots` DATE,
`licensed` DATE,
`sex` VARCHAR(50),
`neutered` VARCHAR(50),
`alive` VARCHAR(50),
`notes` VARCHAR(50),
`hide` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `owner_pet` (
`id` INT NOT NULL,
`owner_id` INT,
`pet_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_325705_db') AS relationships;
relationships
Database: db_325705_db

Table Connections:
------------------
[Implied]  owner_pet.owner_id -> owner.id
[Implied]  owner_pet.pet_id -> pet.id

DROP DATABASE `db_325705_db`;
UNINSTALL EXTENSION vsql_schematron;
