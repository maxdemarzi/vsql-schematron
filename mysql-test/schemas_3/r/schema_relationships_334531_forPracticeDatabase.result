INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 334531_forPracticeDatabase
#
CREATE DATABASE `db_334531_forPracticeDatabase`;
USE `db_334531_forPracticeDatabase`;
CREATE TABLE `Products` (
`product_id` BIGINT NOT NULL,
`product_name` VARCHAR(50),
`value` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `Prefecture` (
`prefecture_id` INT NOT NULL,
`prefecture_name` VARCHAR(50),
PRIMARY KEY (`prefecture_id`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
`customer_id` BIGINT NOT NULL,
`customer_name` VARCHAR(50),
`prefecture_id` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `Sales` (
`sales_id` BIGINT NOT NULL,
`product_id` BIGINT,
`customer_id` BIGINT,
`created_at` DATETIME,
PRIMARY KEY (`sales_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_334531_forPracticeDatabase') AS relationships;
relationships
