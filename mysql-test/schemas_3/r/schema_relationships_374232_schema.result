INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 374232_schema
#
CREATE DATABASE `db_374232_schema`;
USE `db_374232_schema`;
CREATE TABLE `country` (
`country_id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`country_id`)
) CHARACTER SET latin1;
CREATE TABLE `language` (
`language_id` INT,
`abbr` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`language_id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`content` VARCHAR(64),
`email` VARCHAR(64),
`facebook_url` VARCHAR(64),
`image_url` VARCHAR(64),
`instagram_url` VARCHAR(64),
`name` VARCHAR(64),
`password` VARCHAR(64),
`reg_date` DATETIME,
`role` VARCHAR(64),
`school` VARCHAR(64),
`views` INT,
`web_email` VARCHAR(64),
`rep_country` VARCHAR(64),
`rep_language` VARCHAR(64),
`rep_hope_language` VARCHAR(64),
`refresh_token` VARCHAR(64),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `likes` (
`like_id` INT,
`reg_date` DATETIME,
`user_from` INT,
`user_to` INT,
PRIMARY KEY (`like_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_country` (
`user_country_id` INT,
`country_id` INT,
`user_id` INT,
PRIMARY KEY (`user_country_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_language` (
`user_language_id` INT,
`language_id` INT,
`user_id` INT,
PRIMARY KEY (`user_language_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_hope_language` (
`user_hope_language_id` INT,
`language_id` INT,
`user_id` INT,
PRIMARY KEY (`user_hope_language_id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_room` (
`id` INT,
`name` VARCHAR(64),
`reg_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chat_room_user` (
`id` INT,
`room_id` INT,
`user_id` INT,
`exit_date` DATETIME,
`is_exit` BOOL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `block` (
`block_id` INT,
`reg_date` DATETIME,
`user_from` INT,
`user_to` INT,
PRIMARY KEY (`block_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_374232_schema') AS relationships;
