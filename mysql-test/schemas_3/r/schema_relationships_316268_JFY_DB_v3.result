INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 316268_JFY_DB_v3
#
CREATE DATABASE `db_316268_JFY_DB_v3`;
USE `db_316268_JFY_DB_v3`;
CREATE TABLE `categories` (
`CAID` INT,
`category` VARCHAR(64),
PRIMARY KEY (`CAID`)
) CHARACTER SET latin1;
CREATE TABLE `moderator` (
`MODID` INT,
`REQID` INT,
`POSTID` INT
) CHARACTER SET latin1;
CREATE TABLE `requestslog` (
`REQID` INT,
`Time` DATETIME,
`Method` VARCHAR(64),
`Path` VARCHAR(64),
`Error` VARCHAR(64),
PRIMARY KEY (`REQID`)
) CHARACTER SET latin1;
CREATE TABLE `responses` (
`REID` INT,
`UID` INT,
`AID` INT,
`UserChoice` INT
) CHARACTER SET latin1;
CREATE TABLE `userposts` (
`POSTID` INT,
`UID` INT,
`CID` INT,
`title` VARCHAR(64),
`author` VARCHAR(64),
`likes` INT,
`image` VARCHAR(64),
`body` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `usertable` (
`UID` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`Password` VARCHAR(64),
`NewUser` INT,
`last_login` DATETIME,
`last_logout` DATETIME,
PRIMARY KEY (`UID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_316268_JFY_DB_v3') AS relationships;
relationships
Database: db_316268_JFY_DB_v3

