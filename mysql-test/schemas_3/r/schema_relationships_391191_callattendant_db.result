CREATE DATABASE `db_391191_callattendant_db`;
USE `db_391191_callattendant_db`;
CREATE TABLE `Whitelist` (
`PhoneNo` VARCHAR(50) NOT NULL,
`Name` TEXT,
`Reason` TEXT,
`SystemDateTime` TEXT,
PRIMARY KEY (`PhoneNo`)
) CHARACTER SET latin1;
CREATE TABLE `Message` (
`MessageID` INT NOT NULL,
`CallLogID` INT,
`Played` BOOLEAN,
`Filename` TEXT,
`DateTime` TEXT,
PRIMARY KEY (`MessageID`)
) CHARACTER SET latin1;
CREATE TABLE `CallLog` (
`CallLogID` INT NOT NULL,
`Name` TEXT,
`Number` TEXT,
`Date` TEXT,
`Time` TEXT,
`SystemDateTime` TEXT,
`Action` TEXT,
`Reason` TEXT,
PRIMARY KEY (`CallLogID`)
) CHARACTER SET latin1;
CREATE TABLE `Blacklist` (
`PhoneNo` VARCHAR(50) NOT NULL,
`Name` TEXT,
`Reason` TEXT,
`SystemDateTime` TEXT,
PRIMARY KEY (`PhoneNo`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_391191_callattendant_db') AS relationships;
