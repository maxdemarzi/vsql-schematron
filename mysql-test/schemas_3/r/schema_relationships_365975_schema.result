INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 365975_schema
#
CREATE DATABASE `db_365975_schema`;
USE `db_365975_schema`;
CREATE TABLE `department` (
`id` INT NOT NULL,
`dept_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `emprole` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_365975_schema') AS relationships;
relationships
