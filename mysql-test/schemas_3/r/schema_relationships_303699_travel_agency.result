[Implied]  Trips.mail -> users.mail
[Implied]  Trips_photos.trip_id -> Trips.trip_id
[Implied]  company.mail -> users.mail
[Implied]  rates.comp_mail -> company.mail
[Implied]  rates.user_mail -> users.mail

DROP DATABASE `db_303699_travel_agency`;
UNINSTALL EXTENSION vsql_schematron;
