INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 327822_1
#
CREATE DATABASE `db_327822_1`;
USE `db_327822_1`;
CREATE TABLE `roles` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `permissions` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`obj` VARCHAR(50),
`action` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rolePermissions` (
`id` BIGINT NOT NULL,
`permissionId` BIGINT,
`roleId` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` BIGINT NOT NULL,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`displayName` VARCHAR(50),
`email` VARCHAR(50),
`dateOfBirth` VARCHAR(50),
`gender` VARCHAR(50),
`phone` VARCHAR(50),
`address` VARCHAR(50),
`picture` VARCHAR(50),
`login` VARCHAR(50),
`password` VARCHAR(50),
`roleId` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_327822_1') AS relationships;
