[Implied]  usuario.concursoId -> concurso.idC
[Implied]  voto.pinchoIdPi -> pincho.idPi
[Implied]  voto.usuarioEmailU -> usuario.emailU

DROP DATABASE `db_369192_bdPinchos`;
UNINSTALL EXTENSION vsql_schematron;
