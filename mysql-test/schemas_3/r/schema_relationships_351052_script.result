INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 351052_script
#
CREATE DATABASE `db_351052_script`;
USE `db_351052_script`;
CREATE TABLE `HOST` (
`ID` INT,
`ADDRESS` VARCHAR(64),
`PORT` INT,
`COMMAND` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER` (
`ID` INT,
`NAME` VARCHAR(64),
`EMAIL` VARCHAR(64),
`PASSWORD` VARCHAR(64),
`ACTIVE` VARCHAR(64),
`TIMEZONE` INT,
`TOKEN` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTH_LINK` (
`USER_ID` INT,
`GENERATION_DATE` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `USER_HOST` (
`USER_ID` INT,
`HOST_ID` INT,
`TITLE` VARCHAR(64),
`PAID_UNTIL` DATETIME,
PRIMARY KEY (`USER_ID`, `HOST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `HOST_STATUS` (
`ID` VARCHAR(64),
`HOST_ID` INT,
`START` DATETIME,
`FINISH` DATETIME,
`ONLINE` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PING` (
`ID` VARCHAR(64),
`HOST_ID` INT,
`WHEN` DATETIME,
`MS` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_351052_script') AS relationships;
relationships
Database: db_351052_script

Table Connections:
------------------
[Implied]  AUTH_LINK.USER_ID -> USER.ID
[Implied]  HOST_STATUS.HOST_ID -> HOST.ID
[Implied]  PING.HOST_ID -> HOST.ID
[Implied]  USER_HOST.HOST_ID -> HOST.ID
[Implied]  USER_HOST.USER_ID -> USER.ID

DROP DATABASE `db_351052_script`;
UNINSTALL EXTENSION vsql_schematron;
