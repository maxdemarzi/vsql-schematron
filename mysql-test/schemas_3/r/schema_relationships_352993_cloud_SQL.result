CREATE DATABASE `db_352993_cloud_SQL`;
USE `db_352993_cloud_SQL`;
CREATE TABLE `User` (
`userId` VARCHAR(50) NOT NULL,
`moduleId` INT,
`roleId` INT,
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`gender` TINYINT,
PRIMARY KEY (`userId`)
) CHARACTER SET latin1;
CREATE TABLE `SensorHeartbeat` (
`sensorHeartbeatId` INT NOT NULL,
`userId` VARCHAR(50),
`timestamp` TIMESTAMP NULL,
`rate` TINYINT,
PRIMARY KEY (`sensorHeartbeatId`)
) CHARACTER SET latin1;
