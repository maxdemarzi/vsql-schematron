CREATE TABLE `responsavel` (
`id` INT,
`nome` VARCHAR(64),
`cpf` VARCHAR(64),
`email` VARCHAR(64),
`foto` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `processo` (
`id` INT,
`numeroprocesso` VARCHAR(64),
`datadistribuicao` DATETIME,
`processosegredo` BOOL,
`pastafisica` VARCHAR(64),
`descricao` VARCHAR(64),
`situacao` INT,
`idprocessopai` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `processoresponsavel` (
`id` INT,
`idprocesso` INT,
`idresponsavel` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_319401_Script_criacao_banco') AS relationships;
