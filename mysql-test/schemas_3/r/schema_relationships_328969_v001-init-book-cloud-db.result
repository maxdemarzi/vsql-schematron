CREATE TABLE `book` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`type` VARCHAR(50),
`description` VARCHAR(50),
`publish_at` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `author` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`birth_day` DATETIME,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_author` (
`id` INT NOT NULL,
`book_id` INT,
`author_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_328969_v001_init_book_cloud_db') AS relationships;
