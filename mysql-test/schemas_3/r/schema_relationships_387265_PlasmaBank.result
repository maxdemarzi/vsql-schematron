[Implied]  BLOOD_COST.plasma_bag_number -> BLOOD.plasma_bag_number
[Implied]  COMPANION.donor_id -> DONOR_INFO.donor_id
[Implied]  DONORS.donor_id -> DONOR_INFO.donor_id
[Implied]  PAYMENT_TRANSACTION.rec_id -> RECIPIENT.rec_id
[Implied]  RECIEVES.emp_id -> STAFF.emp_id
[Implied]  RECIEVES.rec_id -> RECIPIENT.rec_id
[Implied]  REGISTERS.donor_id -> DONOR_INFO.donor_id
[Implied]  REGISTERS.rec_id -> RECIPIENT.rec_id

DROP DATABASE `db_387265_PlasmaBank`;
UNINSTALL EXTENSION vsql_schematron;
