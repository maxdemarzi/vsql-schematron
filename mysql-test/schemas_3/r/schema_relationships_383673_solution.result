CREATE DATABASE `db_383673_solution`;
USE `db_383673_solution`;
CREATE TABLE `users` (
`userid` INT,
`name` VARCHAR(64),
PRIMARY KEY (`userid`)
) CHARACTER SET latin1;
CREATE TABLE `movies` (
`movieid` INT,
`title` VARCHAR(64),
PRIMARY KEY (`movieid`)
) CHARACTER SET latin1;
CREATE TABLE `taginfo` (
`tagid` INT,
`content` VARCHAR(64),
PRIMARY KEY (`tagid`)
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`genreid` INT,
`name` VARCHAR(64),
PRIMARY KEY (`genreid`)
) CHARACTER SET latin1;
CREATE TABLE `ratings` (
`userid` INT,
`movieid` INT,
`rating` DECIMAL(10,2),
`timestamp` INT,
PRIMARY KEY (`userid`, `movieid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`userid` INT,
`movieid` INT,
`tagid` INT,
`timestamp` INT
) CHARACTER SET latin1;
CREATE TABLE `hasagenre` (
`movieid` INT,
`genreid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_383673_solution') AS relationships;
