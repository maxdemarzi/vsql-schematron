INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 366792_job
#
CREATE DATABASE `db_366792_job`;
USE `db_366792_job`;
CREATE TABLE `application` (
`app_id` INT,
`user_id` INT,
`job_id` INT,
`app_status` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `job` (
`job_id` INT,
`job_title` VARCHAR(255),
`job_company` VARCHAR(255),
`job_experience` VARCHAR(255),
`job_create_date` DATETIME,
`job_kind` VARCHAR(255),
`job_category` VARCHAR(255),
`job_city` VARCHAR(255),
`job_detail` VARCHAR(255),
`user_id` INT,
PRIMARY KEY (`job_id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`user_id` INT,
`user_name` VARCHAR(255),
`user_email` VARCHAR(255),
`user_password` VARCHAR(255),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_366792_job') AS relationships;
relationships
