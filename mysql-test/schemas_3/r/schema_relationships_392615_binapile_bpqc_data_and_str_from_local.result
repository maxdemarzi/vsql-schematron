`display_date` DATETIME,
`is_holiday` INT
) CHARACTER SET latin1;
CREATE TABLE `materialending` (
`id` INT,
`display_date` DATETIME,
`date_created` DATETIME,
`silo1` DECIMAL(10,2),
`silo2` DECIMAL(10,2),
`silo3` DECIMAL(10,2),
`summary_status` VARCHAR(64),
`plant_id` INT,
`is_holiday` INT
) CHARACTER SET latin1;
CREATE TABLE `project` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`date_created` DATETIME,
`deleted` INT,
`location_id` INT
) CHARACTER SET latin1;
CREATE TABLE `truck` (
`id` INT,
