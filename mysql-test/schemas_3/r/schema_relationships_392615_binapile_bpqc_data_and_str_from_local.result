`silo3` DECIMAL(10,2),
`summary_status` VARCHAR(64),
`plant_id` INT,
`is_holiday` INT
) CHARACTER SET latin1;
CREATE TABLE `driver` (
`id` INT,
`name` VARCHAR(64),
`remark` VARCHAR(64),
`employee_id` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `grade` (
`id` INT,
`name` VARCHAR(64),
`charac_strength28` VARCHAR(64),
`cement_type` VARCHAR(64),
`specified_slump` VARCHAR(64),
`coarse_agg_type` VARCHAR(64),
`fine_agg_type` VARCHAR(64),
`admixture` VARCHAR(64),
`mix_design_for_cal` DECIMAL(10,2),
`deleted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `location` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`rate_prefix` VARCHAR(64),
`rate_number` DECIMAL(10,2),
`deleted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `materialaudit` (
`id` INT,
`plant_id` INT,
`volume` DECIMAL(10,2),
