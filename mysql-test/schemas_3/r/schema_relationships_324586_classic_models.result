CREATE DATABASE `db_324586_classic_models`;
USE `db_324586_classic_models`;
CREATE TABLE `categorias` (
`ID_categoria` VARCHAR(64),
`descricao_texto` VARCHAR(64),
`descricao_html` VARCHAR(64),
`imagem` VARCHAR(64),
PRIMARY KEY (`ID_categoria`)
) CHARACTER SET latin1;
CREATE TABLE `clientes` (
`ID_cliente` INT,
`razao_social` VARCHAR(64),
`sobrenome` VARCHAR(64),
`nome` VARCHAR(64),
`telefone` VARCHAR(64),
`endereco_linha1` VARCHAR(64),
`endereco_linha2` VARCHAR(64),
`cidade` VARCHAR(64),
`estado` VARCHAR(64),
`codigo_postal` VARCHAR(64),
`pais` VARCHAR(64),
`ID_representante_vendas` INT,
`limite_credito` DECIMAL(10,2),
PRIMARY KEY (`ID_cliente`)
) CHARACTER SET latin1;
CREATE TABLE `escritorios` (
`ID_escritorio` VARCHAR(64),
`cidade` VARCHAR(64),
`telefone` VARCHAR(64),
`endereco_linha1` VARCHAR(64),
`endereco_linha2` VARCHAR(64),
`estado` VARCHAR(64),
`pais` VARCHAR(64),
`codigo_postal` VARCHAR(64),
`territorio` VARCHAR(64),
PRIMARY KEY (`ID_escritorio`)
) CHARACTER SET latin1;
CREATE TABLE `funcionario` (
`ID_funcionario` INT,
`sobrenome` VARCHAR(64),
`nome` VARCHAR(64),
`extension` VARCHAR(64),
`email` VARCHAR(64),
`ID_escritorio` VARCHAR(64),
`ID_chefe` INT,
`cargo` VARCHAR(64),
PRIMARY KEY (`ID_funcionario`)
) CHARACTER SET latin1;
CREATE TABLE `item_venda` (
`ID_venda` INT,
`ID_produto` VARCHAR(64),
`qtd` INT,
`preco_individual` DECIMAL(10,2),
`orderLineNumber` INT,
PRIMARY KEY (`ID_venda`, `ID_produto`)
) CHARACTER SET latin1;
CREATE TABLE `pagamentos` (
`ID_cliente` INT,
`checkNumber` VARCHAR(64),
`data_pagameto` DATETIME,
`valor` DECIMAL(10,2),
PRIMARY KEY (`ID_cliente`, `checkNumber`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
`ID_produto` VARCHAR(64),
`nome_produto` VARCHAR(64),
`ID_categoria` VARCHAR(64),
`escala_produto` VARCHAR(64),
`productVendor` VARCHAR(64),
`descricao_produto` VARCHAR(64),
`qtd_em_estoque` INT,
`preco_compra` DECIMAL(10,2),
`preco_venda` DECIMAL(10,2),
PRIMARY KEY (`ID_produto`)
) CHARACTER SET latin1;
CREATE TABLE `venda` (
`ID_venda` INT,
`data_venda` DATETIME,
`data_entrega` DATETIME,
`data_envio` DATETIME,
`status` VARCHAR(64),
`comentarios` VARCHAR(64),
`ID_cliente` INT,
PRIMARY KEY (`ID_venda`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_324586_classic_models') AS relationships;
