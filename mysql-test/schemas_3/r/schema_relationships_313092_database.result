INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 313092_database
#
CREATE DATABASE `db_313092_database`;
USE `db_313092_database`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `results` (
`id` INT NOT NULL,
`user_id` INT,
`linguist` INT,
`logic` INT,
`musical` INT,
`bodily` INT,
`visual` INT,
`inter` INT,
`intra` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_313092_database') AS relationships;
