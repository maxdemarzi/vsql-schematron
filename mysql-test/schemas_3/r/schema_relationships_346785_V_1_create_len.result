CREATE DATABASE `db_346785_V_1_create_len`;
USE `db_346785_V_1_create_len`;
CREATE TABLE `len_schema_version` (
`version_key` VARCHAR(64),
`version_value` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `len_document` (
`id` DECIMAL(10,2),
`oid` DECIMAL(10,2),
`ver_from_instant` DATETIME,
`ver_to_instant` DATETIME,
`corr_from_instant` DATETIME,
`corr_to_instant` DATETIME,
`name` VARCHAR(64),
`main_type` VARCHAR(64),
`sub_type` VARCHAR(64),
`actual_type` VARCHAR(64),
`packed_data` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `len_idkey` (
`id` DECIMAL(10,2),
`key_scheme` VARCHAR(64),
`key_value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `len_doc2idkey` (
`doc_id` DECIMAL(10,2),
`idkey_id` DECIMAL(10,2),
PRIMARY KEY (`doc_id`, `idkey_id`)
) CHARACTER SET latin1;
CREATE TABLE `len_attr` (
`id` DECIMAL(10,2),
`attr_key` VARCHAR(64),
`attr_value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `len_doc2attr` (
`doc_id` DECIMAL(10,2),
`attr_id` DECIMAL(10,2),
PRIMARY KEY (`doc_id`, `attr_id`)
) CHARACTER SET latin1;
CREATE TABLE `len_prop` (
`id` DECIMAL(10,2),
`prop_key` VARCHAR(64),
`prop_value` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `len_doc2prop` (
`doc_id` DECIMAL(10,2),
`prop_id` DECIMAL(10,2),
PRIMARY KEY (`doc_id`, `prop_id`)
) CHARACTER SET latin1;
