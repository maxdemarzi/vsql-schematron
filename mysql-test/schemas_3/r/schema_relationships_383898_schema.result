PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `article` (
`id` INT,
`uploader_id` INT,
`uploaded` DATETIME,
`published` VARCHAR(64),
`author` VARCHAR(64),
`title` VARCHAR(64),
`body` VARCHAR(64),
`sentiment` VARCHAR(64),
`article_url` VARCHAR(64),
`keyword` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
