INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 354048_InitDatabase
#
CREATE DATABASE `db_354048_InitDatabase`;
USE `db_354048_InitDatabase`;
CREATE TABLE `testing.player` (
`Id` VARCHAR(50) NOT NULL,
`Name` VARCHAR(50),
`Age` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `testing.kingdom` (
`Id` VARCHAR(50) NOT NULL,
`Name` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `testing.general` (
`Id` VARCHAR(50) NOT NULL,
`Name` VARCHAR(50),
`Attack` VARCHAR(50),
`Defense` VARCHAR(50),
`PlayerId` VARCHAR(50),
`KingdomId` VARCHAR(50),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_354048_InitDatabase') AS relationships;
relationships
