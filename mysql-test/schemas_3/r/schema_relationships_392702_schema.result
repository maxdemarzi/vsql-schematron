INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 392702_schema
#
CREATE DATABASE `db_392702_schema`;
USE `db_392702_schema`;
CREATE TABLE `employees` (
`emp_no` INT,
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`gender` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` INT,
`from_date` DATETIME,
`to_date` DATETIME,
PRIMARY KEY (`emp_no`, `from_date`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_392702_schema') AS relationships;
relationships
Database: db_392702_schema

Table Connections:
