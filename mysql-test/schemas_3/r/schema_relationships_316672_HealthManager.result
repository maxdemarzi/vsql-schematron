[Implied]  homework_title.course_id -> course.course_id
[Implied]  post.course_id -> course.course_id
[Implied]  student_courses.courses_course_id -> course.course_id

DROP DATABASE `db_316672_HealthManager`;
UNINSTALL EXTENSION vsql_schematron;
