CREATE DATABASE `db_332067_create_market43`;
USE `db_332067_create_market43`;
CREATE TABLE `user` (
`UserId` INT,
`Email` VARCHAR(64),
`Nickname` VARCHAR(64),
`AccountType` INT,
PRIMARY KEY (`UserId`)
) CHARACTER SET latin1;
CREATE TABLE `item_type` (
`ItemTypeId` INT,
`Name` VARCHAR(64),
`IconPath` VARCHAR(64),
`Rarity` INT,
`Description` VARCHAR(64),
PRIMARY KEY (`ItemTypeId`)
) CHARACTER SET latin1;
CREATE TABLE `item` (
`ItemId` INT,
`ItemType` INT,
`OwnerUserId` INT,
PRIMARY KEY (`ItemId`)
) CHARACTER SET latin1;
CREATE TABLE `recipe` (
`RecipeId` INT,
PRIMARY KEY (`RecipeId`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_input` (
`Recipe` INT,
`InputItemType` INT,
`InputItemCount` INT,
PRIMARY KEY (`Recipe`, `InputItemType`, `InputItemCount`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_output` (
`Recipe` INT,
`OutputItemType` INT,
`OutputItemCount` INT,
PRIMARY KEY (`Recipe`, `OutputItemType`, `OutputItemCount`)
) CHARACTER SET latin1;
CREATE TABLE `listing` (
`ListingId` INT,
`MinimumBid` INT,
`PostedTimestamp` DATETIME,
`ExpiryTimestamp` DATETIME,
`ListedItemId` INT,
`ListingUserId` INT,
`Open` BOOL,
PRIMARY KEY (`ListingId`)
) CHARACTER SET latin1;
CREATE TABLE `transaction` (
`TransactionId` INT,
`NetBalanceChange` INT,
`TransactionType` INT,
`TransactionUser` INT,
`TransactionTimestamp` DATETIME,
PRIMARY KEY (`TransactionId`)
) CHARACTER SET latin1;
CREATE TABLE `bid` (
`Bidder` INT,
`Listing` INT,
`Value` INT,
PRIMARY KEY (`Bidder`, `Listing`)
) CHARACTER SET latin1;
CREATE TABLE `credential` (
`SaltedHash` VARCHAR(64),
`User` INT,
PRIMARY KEY (`User`)
) CHARACTER SET latin1;
