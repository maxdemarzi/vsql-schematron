`publico_alvO` VARCHAR(64),
`regiao` VARCHAR(64),
`cliques` INT,
`data_inicio` DATETIME,
`data_final` DATETIME,
`postagem_anuncio` VARCHAR(64),
`pagamentos_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `anunciantes` (
`id` INT,
`pagina` VARCHAR(64),
`usuario` VARCHAR(64),
`pagamentos_id` INT,
`anuncios_id` INT,
PRIMARY KEY (`id`, `pagamentos_id`)
) CHARACTER SET latin1;
