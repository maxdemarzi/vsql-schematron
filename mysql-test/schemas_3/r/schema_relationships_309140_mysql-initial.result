INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 309140_mysql-initial
#
CREATE DATABASE `db_309140_mysql_initial`;
USE `db_309140_mysql_initial`;
CREATE TABLE `mds-sm.StateMachineVersion` (
`id` VARCHAR(50) NOT NULL,
`definition` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.StateMachine` (
`id` VARCHAR(50) NOT NULL,
`account_id` VARCHAR(50),
`name` VARCHAR(50),
`active_version` CHAR(50),
`is_deleted` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.Execution` (
`id` VARCHAR(50) NOT NULL,
`created` CHAR(50),
`status` VARCHAR(50),
`version` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mds-sm.Operation` (
`id` VARCHAR(50) NOT NULL,
`execution` CHAR(50),
`created` CHAR(50),
`stateKey` VARCHAR(50),
`status` VARCHAR(50),
`input` TEXT,
`inputType` VARCHAR(50),
`output` TEXT,
`outputType` VARCHAR(50),
`waitUntilUtc` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_309140_mysql_initial') AS relationships;
relationships
Database: db_309140_mysql_initial

