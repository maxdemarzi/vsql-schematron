CREATE DATABASE `db_356066_schema`;
USE `db_356066_schema`;
CREATE TABLE `endereco` (
`id` INT,
`tipo_endereco_id` INT,
`endereco` VARCHAR(64),
`cidade` VARCHAR(64),
`uf` VARCHAR(64),
`cep` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pessoa` (
`id` INT,
`nome` VARCHAR(64),
`email` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pessoa_endereco` (
`id` INT,
`pessoa_id` INT,
`endereco_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `pessoa_telefone` (
`id` INT,
`pessoa_id` INT,
`telefone_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `telefone` (
`id` INT,
`tipo_telefone_id` INT,
`ddd` VARCHAR(64),
`numero` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_endereco` (
`id` INT,
`nome` VARCHAR(64),
`descricao` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_telefone` (
`id` INT,
`nome` VARCHAR(64),
`descricao` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_356066_schema') AS relationships;
