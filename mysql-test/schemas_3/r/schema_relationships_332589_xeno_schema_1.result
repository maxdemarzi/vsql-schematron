INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 332589_xeno_schema_1
#
CREATE DATABASE `db_332589_xeno_schema_1`;
USE `db_332589_xeno_schema_1`;
CREATE TABLE `prefix_config` (
`id` INT NOT NULL,
`default_country` TEXT,
`dialog_timeout` INT,
`dual_billing_prefix` TEXT,
`enabled` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `phone_number` (
`id` INT NOT NULL,
`action_type` TEXT,
`contact_id` TEXT,
`contact_name` TEXT,
`country_code` TEXT,
`number` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`id` INT NOT NULL,
`age` INT,
`name` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `country` (
`id` INT NOT NULL,
`area` INT,
`calling_code` TEXT,
`code` TEXT,
`name` TEXT,
`region` TEXT,
`translated_name` BLOB,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `person_phone_number` (
`id` INT NOT NULL,
`person_id` INT,
`phone_number_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_332589_xeno_schema_1') AS relationships;
