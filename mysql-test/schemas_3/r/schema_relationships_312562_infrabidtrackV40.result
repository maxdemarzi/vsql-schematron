CREATE DATABASE `db_312562_infrabidtrackV40`;
USE `db_312562_infrabidtrackV40`;
CREATE TABLE `disqualification_records` (
`record_id` INT,
`project_bid` INT,
`log_id` INT,
PRIMARY KEY (`record_id`)
) CHARACTER SET latin1;
CREATE TABLE `document_logs` (
`doc_log_id` INT,
`log_id` INT,
`project_document_id` INT,
PRIMARY KEY (`doc_log_id`)
) CHARACTER SET latin1;
CREATE TABLE `logs` (
`log_id` INT,
`remark` VARCHAR(64),
`log_type` VARCHAR(64),
`sender` INT,
`receiver` INT,
`log_date` DATETIME,
PRIMARY KEY (`log_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_document` (
`project_document_id` INT,
`plan_id` INT,
`doc_type_id` INT,
`contractor_id` INT,
`added_by` INT,
`previous_doc_loc` VARCHAR(64),
`current_doc_loc` VARCHAR(64),
`receiver` VARCHAR(64),
`status` VARCHAR(64),
`image_status` VARCHAR(64),
PRIMARY KEY (`project_document_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_document_images` (
`document_image_id` INT,
`project_document_id` INT,
`image_url` VARCHAR(64),
`upload_path` VARCHAR(64),
PRIMARY KEY (`document_image_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_logs` (
`project_log_id` INT,
`plan_id` INT,
`user_id` INT,
`log_date` DATETIME,
`remark` VARCHAR(64),
PRIMARY KEY (`project_log_id`)
) CHARACTER SET latin1;
CREATE TABLE `project_observers` (
`activity_observer` INT,
`plan_id` INT,
`observer_id` INT,
`name_of_observer` VARCHAR(64),
PRIMARY KEY (`activity_observer`)
) CHARACTER SET latin1;
