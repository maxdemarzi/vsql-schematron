CREATE DATABASE `db_311167_V1__init`;
USE `db_311167_V1__init`;
CREATE TABLE `salesman` (
`id` BIGINT NOT NULL,
`full_name` VARCHAR(50),
`cpf` VARCHAR(50),
`operation` BIGINT,
`account_type` BIGINT,
`agency` BIGINT,
`user_id` BIGINT,
`phone_number` VARCHAR(50),
`biography` VARCHAR(50),
`photo` VARCHAR(50),
`status` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` BIGINT,
`categories_id` BIGINT,
`salesman_id` BIGINT,
`name` VARCHAR(50),
`description` VARCHAR(50),
`value` BIGINT,
`status` BIGINT,
`stock` BIGINT,
`photo` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` BIGINT,
`name` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` BIGINT,
`senha` VARCHAR(50),
`perfil` VARCHAR(50),
`email` VARCHAR(50),
`user_Name` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_311167_V1__init') AS relationships;
