INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 380235_schema
#
CREATE DATABASE `db_380235_schema`;
USE `db_380235_schema`;
CREATE TABLE `departments` (
`id` INT NOT NULL,
`department_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT NOT NULL,
`role_title` VARCHAR(50),
`role_salary` DECIMAL(10,2),
`is_manager` BOOLEAN,
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_380235_schema') AS relationships;
relationships
Database: db_380235_schema

Table Connections:
------------------
[Implied]  employees.manager_id -> employees.id
[Implied]  employees.role_id -> roles.id
[Implied]  roles.department_id -> departments.id

DROP DATABASE `db_380235_schema`;
UNINSTALL EXTENSION vsql_schematron;
