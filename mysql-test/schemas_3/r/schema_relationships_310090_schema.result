CREATE DATABASE `db_310090_schema`;
USE `db_310090_schema`;
CREATE TABLE `paper` (
`id` INT NOT NULL,
`title` TEXT,
`authors` TEXT,
`abstract` TEXT,
`venue` TEXT,
`year` INT,
`doi` TEXT,
`source` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `remark` (
`id` INT NOT NULL,
`paper_id` INT,
`created` TIMESTAMP NULL,
`author` TEXT,
`acceptance` INT,
`inclusion_note` TEXT,
`exclusion_note` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_310090_schema') AS relationships;
