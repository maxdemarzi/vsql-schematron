CREATE TABLE `usuario` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`email` VARCHAR(50),
`senha` VARCHAR(50),
`status` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `papel` (
`id` INT NOT NULL,
`nome` VARCHAR(50),
`descricao` VARCHAR(50),
`status` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `usuario_papel` (
`id` INT NOT NULL,
`usuario_id` INT,
`papel_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_376434_init_db') AS relationships;
