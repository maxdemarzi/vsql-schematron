CREATE TABLE `item` (
`itemID` INT NOT NULL,
`itemName` VARCHAR(50),
`itemPrice` VARCHAR(50),
`itemDesc` VARCHAR(50),
PRIMARY KEY (`itemID`)
) CHARACTER SET latin1;
CREATE TABLE `itemColour` (
`itemColourID` INT NOT NULL,
`itemID` INT,
`itemColourName` VARCHAR(50),
`itemColourImage` VARCHAR(50),
PRIMARY KEY (`itemColourID`)
) CHARACTER SET latin1;
CREATE TABLE `size` (
`sizeID` INT NOT NULL,
`itemID` INT,
`sizeName` VARCHAR(50),
PRIMARY KEY (`sizeID`)
) CHARACTER SET latin1;
