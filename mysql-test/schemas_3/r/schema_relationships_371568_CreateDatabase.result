CREATE DATABASE `db_371568_CreateDatabase`;
USE `db_371568_CreateDatabase`;
CREATE TABLE `AdviseGroups` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `AdviseSets` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Folders` (
`Id` INT,
`ParentFolder_Id` INT,
`AdviseGroup_Id` INT,
`Name` VARCHAR(255),
`DeleteDate` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Discs` (
`Id` INT,
`Folder_Id` INT,
`AdviseGroup_Id` INT,
`AdviseSet_Id` INT,
`AdviseSetOrder` INT,
`Year` INT,
`Title` VARCHAR(255),
`TreeTitle` VARCHAR(255),
`AlbumTitle` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Artists` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Genres` (
`Id` INT,
`Name` VARCHAR(255),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Songs` (
`Id` INT,
`Artist_Id` INT,
`Disc_Id` INT,
`Genre_Id` INT,
`TrackNumber` INT,
`Title` VARCHAR(255),
`TreeTitle` VARCHAR(255),
`Duration` DECIMAL(10,2),
`Rating` INT,
`FileSize` INT,
`Checksum` INT,
`Bitrate` INT,
`LastPlaybackTime` DATETIME,
`PlaybacksCount` INT,
`DeleteDate` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Playbacks` (
`Id` INT,
`Song_Id` INT,
`PlaybackTime` DATETIME,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `DiscImages` (
`Id` INT,
`Disc_Id` INT,
`TreeTitle` VARCHAR(255),
`ImageType` INT,
`FileSize` INT,
`Checksum` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `SessionData` (
`Key` VARCHAR(255),
`Data` VARCHAR(255),
PRIMARY KEY (`Key`)
) CHARACTER SET latin1;
