) CHARACTER SET latin1;
CREATE TABLE `employee` (
`shain_id` VARCHAR(50) NOT NULL,
`family_name` CHAR(50),
`family_name_kana` CHAR(50),
`given_name` CHAR(50),
`given_name_kana` CHAR(50),
`email` CHAR(50),
`phone_number` CHAR(50),
`cellphone_number` CHAR(50),
`address` CHAR(50),
`join_date` DATE,
`quit_date` DATE,
`password` CHAR(50),
`role_id` INT,
`delete_flag` INT,
PRIMARY KEY (`shain_id`)
) CHARACTER SET latin1;
