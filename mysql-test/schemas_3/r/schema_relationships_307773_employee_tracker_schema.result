INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 307773_employee-tracker-schema
#
CREATE DATABASE `db_307773_employee_tracker_schema`;
USE `db_307773_employee_tracker_schema`;
CREATE TABLE `department` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_307773_employee_tracker_schema') AS relationships;
relationships
Database: db_307773_employee_tracker_schema

Table Connections:
