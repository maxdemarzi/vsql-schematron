INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 310494_init
#
CREATE DATABASE `db_310494_init`;
USE `db_310494_init`;
CREATE TABLE `auth` (
`user_id` VARCHAR(64),
`email` VARCHAR(64),
`password` VARCHAR(64),
`role` VARCHAR(64),
`registration_code` VARCHAR(64),
`is_active` BOOL,
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
CREATE TABLE `students` (
`student_id` VARCHAR(64),
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
`group_id` VARCHAR(64),
`enter_year` DATETIME,
`major` VARCHAR(64),
`education_form` VARCHAR(64),
`education_base` VARCHAR(64),
`user_id` VARCHAR(64),
PRIMARY KEY (`student_id`)
) CHARACTER SET latin1;
CREATE TABLE `user_profile` (
`profile_id` VARCHAR(64),
`user_id` VARCHAR(64),
`email` VARCHAR(64),
`phone_number` VARCHAR(64),
`city` VARCHAR(64),
`about` VARCHAR(64),
`vk_link` VARCHAR(64),
`facebook_link` VARCHAR(64),
`linkedin_link` VARCHAR(64),
`instagram_link` VARCHAR(64),
PRIMARY KEY (`profile_id`)
) CHARACTER SET latin1;
CREATE TABLE `teachers` (
`user_id` VARCHAR(64),
`teacher_id` VARCHAR(64),
`first_name` VARCHAR(64),
`middle_name` VARCHAR(64),
`last_name` VARCHAR(64),
PRIMARY KEY (`teacher_id`)
) CHARACTER SET latin1;
CREATE TABLE `groups` (
`group_id` VARCHAR(64),
`group_name` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`group_id`)
) CHARACTER SET latin1;
CREATE TABLE `courses` (
`course_id` VARCHAR(64),
`course_name` VARCHAR(64),
`description` VARCHAR(64),
`group_id` VARCHAR(64),
`teacher_id` VARCHAR(64),
`major_id` VARCHAR(64),
PRIMARY KEY (`course_id`)
) CHARACTER SET latin1;
CREATE TABLE `materials` (
`material_id` VARCHAR(64),
`material_name` VARCHAR(64),
`material_content` VARCHAR(64),
`add_date` VARCHAR(64),
`course_id` VARCHAR(64),
PRIMARY KEY (`material_id`)
) CHARACTER SET latin1;
CREATE TABLE `homeworks` (
`homework_id` VARCHAR(64),
`homeworks_name` VARCHAR(64),
`homework_start_date` VARCHAR(64),
`homework_end_date` VARCHAR(64),
`description` VARCHAR(64),
`course_id` VARCHAR(64),
PRIMARY KEY (`homework_id`)
) CHARACTER SET latin1;
CREATE TABLE `solutions` (
`solution_id` VARCHAR(64),
`homework_id` VARCHAR(64),
`student_id` VARCHAR(64),
`course_id` VARCHAR(64),
`description` VARCHAR(64),
PRIMARY KEY (`solution_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_310494_init') AS relationships;
relationships
