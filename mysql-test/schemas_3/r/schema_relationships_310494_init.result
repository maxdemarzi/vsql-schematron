[Implied]  solutions.homework_id -> homeworks.homework_id
[Implied]  solutions.student_id -> students.student_id
[Implied]  students.group_id -> groups.group_id
[Implied]  students.user_id -> user_profile.profile_id
[Implied]  teachers.user_id -> user_profile.profile_id
