INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 354613_database
#
CREATE DATABASE `db_354613_database`;
USE `db_354613_database`;
CREATE TABLE `session` (
`id` INT NOT NULL,
`email` VARCHAR(50),
`ip` VARCHAR(50),
`browser` VARCHAR(50),
`viewport_width` CHAR(50),
`orientation` VARCHAR(50),
`updated` DATETIME,
`created` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
`id` INT NOT NULL,
`type` VARCHAR(50),
`session_id` INT,
`value` TEXT,
`created` TIMESTAMP NULL,
`referer` VARCHAR(50),
`domain_origin` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `admin` (
`id` INT NOT NULL,
`username` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_354613_database') AS relationships;
