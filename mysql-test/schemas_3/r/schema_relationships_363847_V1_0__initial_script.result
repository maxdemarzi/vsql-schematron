CREATE DATABASE `db_363847_V1_0__initial_script`;
USE `db_363847_V1_0__initial_script`;
CREATE TABLE `visits` (
`id` BIGINT NOT NULL,
`dtype` VARCHAR(50),
`entry_time` DATETIME,
`ticket_code` BIGINT,
`exit_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `payments` (
`id` BIGINT NOT NULL,
`visit_id` BIGINT,
`made_at` DATETIME,
`amount` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `configuration` (
`id` BIGINT NOT NULL,
`dtype` VARCHAR(50),
`key` VARCHAR(50),
`value` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `parking_tariffs` (
`id` BIGINT NOT NULL,
`upper_limit` BIGINT,
`fee` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `hibernate_sequence` (
`next_val` BIGINT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_363847_V1_0__initial_script') AS relationships;
