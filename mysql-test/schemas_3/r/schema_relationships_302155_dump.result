INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 302155_dump
#
CREATE DATABASE `db_302155_dump`;
USE `db_302155_dump`;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`password` CHAR(50),
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tasks` (
`id` VARCHAR(50) NOT NULL,
`user_id` VARCHAR(50),
`name` VARCHAR(50),
`description` TEXT,
`created_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_302155_dump') AS relationships;
