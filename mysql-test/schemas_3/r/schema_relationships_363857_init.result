[Implied]  sales.serial_number -> vendings.serial_number
[Implied]  sales.user_id -> users.user_id
[Implied]  vendings.user_id -> users.user_id

DROP DATABASE `db_363857_init`;
UNINSTALL EXTENSION vsql_schematron;
