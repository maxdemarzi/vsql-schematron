CREATE TABLE `admin` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`email` VARCHAR(64),
`password` VARCHAR(64),
`firstName` VARCHAR(64),
`lastName` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `flight` (
`id` INT,
`type` VARCHAR(64),
`origin` VARCHAR(64),
`destination` VARCHAR(64),
`departing` VARCHAR(64),
`returning` VARCHAR(64),
`seats` INT,
`price` DECIMAL(10,2),
`iat` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reservation` (
`id` INT,
`uid` INT,
`fid` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `passenger` (
`id` INT,
`rid` INT,
`name` VARCHAR(64),
`birth` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
