CREATE DATABASE `db_394461_V1_init`;
USE `db_394461_V1_init`;
CREATE TABLE `menu_service.week` (
`id` INT,
`week_number` VARCHAR(64),
`start_date` VARCHAR(64),
`end_date` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_service.unit_of_measure` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_service.ingredient` (
`id` INT,
`name` VARCHAR(64),
`external_id` VARCHAR(64),
`amount` VARCHAR(64),
`unit_of_measure_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_service.menu` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_service.week_has_menu` (
`week_id` INT,
`menu_id` INT,
PRIMARY KEY (`week_id`, `menu_id`)
) CHARACTER SET latin1;
CREATE TABLE `menu_service.menu_has_ingredient` (
`menu_id` INT,
`ingredient_id` INT,
PRIMARY KEY (`menu_id`, `ingredient_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_394461_V1_init') AS relationships;
