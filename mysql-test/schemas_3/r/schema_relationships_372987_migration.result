`userId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ActivityLog` (
`id` VARCHAR(50) NOT NULL,
`startedAt` TIMESTAMP NULL,
`finishedAt` TIMESTAMP NULL,
`journalId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `MoodEntry` (
`id` VARCHAR(50) NOT NULL,
`on` DATE,
`mood` VARCHAR(50),
`userId` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Schedule` (
`id` VARCHAR(50) NOT NULL,
`userId` TEXT,
`label` TEXT,
`remindAt` TIME,
`repeatEach` VARCHAR(50),
`selectedDays` VARCHAR(50),
`remindEvery` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
