INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 335680_ats_basic
#
CREATE DATABASE `db_335680_ats_basic`;
USE `db_335680_ats_basic`;
CREATE TABLE `Job_Position` (
`id` INT NOT NULL,
`job_title` VARCHAR(50),
`status` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Job_post` (
`id` INT,
`Post_Title` VARCHAR(50),
`Post_Description` TEXT,
`status` TINYINT,
`Job_Pos` INT
) CHARACTER SET latin1;
CREATE TABLE `mac_users` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`Address` VARCHAR(50),
`phone_number` VARCHAR(50),
`Email` VARCHAR(50),
`status` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Resume_Candidate` (
`id` INT,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`Address` VARCHAR(50),
`Email` VARCHAR(50),
`Phone_Number` VARCHAR(50),
`Status` TINYINT,
`Job_Pos` INT,
`cv_file_name` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_335680_ats_basic') AS relationships;
