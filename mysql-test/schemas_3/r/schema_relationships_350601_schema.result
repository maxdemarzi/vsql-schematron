CREATE DATABASE `db_350601_schema`;
USE `db_350601_schema`;
CREATE TABLE `USERS` (
`ID` INT,
`NAME` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `QUESTIONS` (
`ID` INT,
`Q_TEXT` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `HISTORY` (
