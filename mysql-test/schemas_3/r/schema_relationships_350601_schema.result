`ANSWER` VARCHAR(64),
`EXPECTED_ANSWER` VARCHAR(64),
`TIME_TO_ANSWER` INT,
`TARGET_TIME_TO_ANSWER` INT,
`NUMBER_ATTEMPTS` INT,
`Q_ID` INT,
`U_ID` INT
) CHARACTER SET latin1;
