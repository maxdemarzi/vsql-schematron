INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 372734_schema
#
CREATE DATABASE `db_372734_schema`;
USE `db_372734_schema`;
CREATE TABLE `abstract_class` (
`id` INT,
`place_id` INT,
`class_type_id` INT,
`day_of_the_week` VARCHAR(64),
`start_hour` VARCHAR(64),
`end_hour` VARCHAR(64),
`start_min` VARCHAR(64),
`end_min` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `abstract_person` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birthday` DATETIME,
`email` VARCHAR(64),
`address` VARCHAR(64),
`phones` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `class_per_client` (
`client_id` INT,
`abstract_class_id` INT,
PRIMARY KEY (`client_id`, `abstract_class_id`)
) CHARACTER SET latin1;
CREATE TABLE `class_per_coach` (
`coach_id` INT,
`abstract_class_id` INT,
PRIMARY KEY (`coach_id`, `abstract_class_id`)
) CHARACTER SET latin1;
CREATE TABLE `class_type` (
`id` INT,
`type_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birthday` DATETIME,
`email` VARCHAR(64),
`address` VARCHAR(64),
`phones` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `coach` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`birthday` DATETIME,
`email` VARCHAR(64),
`address` VARCHAR(64),
`phones` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `medical_revision` (
`id` INT,
`client_id` INT,
`date` DATETIME,
`passed` INT,
`comments` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `place` (
`id` INT,
`place_name` VARCHAR(64),
`maximum_capacity` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
