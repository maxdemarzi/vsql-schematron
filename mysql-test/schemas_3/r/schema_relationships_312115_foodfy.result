INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 312115_foodfy
#
CREATE DATABASE `db_312115_foodfy`;
USE `db_312115_foodfy`;
CREATE TABLE `files` (
`id` INT,
`name` VARCHAR(255),
`path` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chefs` (
`id` INT,
`name` VARCHAR(255),
`file_id` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipe_files` (
`id` INT,
`recipe_id` INT,
`file_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `recipes` (
`id` INT,
`chef_id` INT,
`title` VARCHAR(255),
`ingredients` VARCHAR(255),
`preparation` VARCHAR(255),
`information` VARCHAR(255),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(255),
`email` VARCHAR(255),
`password` VARCHAR(255),
`reset_token` VARCHAR(255),
`reset_token_expires` VARCHAR(255),
`is_admin` VARCHAR(255),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_312115_foodfy') AS relationships;
relationships
Database: db_312115_foodfy

Table Connections:
------------------
[Implied]  chefs.file_id -> files.id
[Implied]  recipe_files.file_id -> files.id
[Implied]  recipe_files.recipe_id -> recipes.id
[Implied]  recipes.chef_id -> chefs.id

DROP DATABASE `db_312115_foodfy`;
UNINSTALL EXTENSION vsql_schematron;
