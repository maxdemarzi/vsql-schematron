[Implied]  aula.materia_id -> materia.materia_id
[Implied]  falta.matricula_id -> matricula.matricula_id
[Implied]  matricula.aluno_id -> aluno.aluno_id
[Implied]  matricula.materia_id -> materia.materia_id
[Implied]  nota.matricula_id -> matricula.matricula_id

DROP DATABASE `db_319715_mysql`;
UNINSTALL EXTENSION vsql_schematron;
