) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT NOT NULL,
`content` VARCHAR(50),
`who` VARCHAR(50),
`cat_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
