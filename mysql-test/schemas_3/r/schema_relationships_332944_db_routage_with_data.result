INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 332944_db_routage_with_data
#
CREATE DATABASE `db_332944_db_routage_with_data`;
USE `db_332944_db_routage_with_data`;
CREATE TABLE `instance` (
`id` INT,
`nom` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `point` (
`id` INT,
`pointtype` INT,
`x` DECIMAL(10,2),
`y` DECIMAL(10,2),
`ninstance` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `depot` (
`id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `planning` (
`id` INT,
`cout` DECIMAL(10,2),
`ninstance` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `vehicule` (
`id` INT,
`cout` DECIMAL(10,2),
`capaciteutilisee` INT,
`capacite` INT,
`ndepot` INT,
`nplanning` INT,
`ninstance` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `client` (
`demand` INT,
`position` INT,
`id` INT,
`nvehicule` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `route` (
`id` INT,
`ndepart` INT,
`narrivee` INT,
`distance` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_332944_db_routage_with_data') AS relationships;
relationships
