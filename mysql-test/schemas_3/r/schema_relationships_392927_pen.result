CREATE DATABASE `db_392927_pen`;
USE `db_392927_pen`;
CREATE TABLE `pensections` (
`id` VARCHAR(255),
`name` VARCHAR(255),
`description` VARCHAR(255),
`sort` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `penstories` (
`id` VARCHAR(255),
`section` VARCHAR(255),
`name` VARCHAR(255),
`title` VARCHAR(255),
`subtitle` VARCHAR(255),
`pretitle` VARCHAR(255),
`description` VARCHAR(255),
`posted` VARCHAR(255),
`sort` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bln` (
`name` VARCHAR(255),
`status` VARCHAR(255),
`instant` INT,
`tags` VARCHAR(255),
`title` VARCHAR(255),
`post` VARCHAR(255),
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_392927_pen') AS relationships;
