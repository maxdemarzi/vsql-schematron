INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 326630_db
#
CREATE DATABASE `db_326630_db`;
USE `db_326630_db`;
CREATE TABLE `alembic_version` (
`version_num` VARCHAR(50) NOT NULL,
PRIMARY KEY (`version_num`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auctions` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`first_cost` DOUBLE,
`step_cost` DOUBLE,
`start_auction` DATETIME,
`end_auction` DATETIME,
`is_active` TINYINT,
`owner_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bets` (
`id` INT NOT NULL,
`user_id` INT,
`auction_id` INT,
`cost` DOUBLE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_326630_db') AS relationships;
