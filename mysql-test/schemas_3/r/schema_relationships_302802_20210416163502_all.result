CREATE DATABASE `db_302802_20210416163502_all`;
USE `db_302802_20210416163502_all`;
CREATE TABLE `symptoms` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `diseases` (
`id` INT,
`name` VARCHAR(64),
`symptoms` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `departments` (
`id` INT,
`name` VARCHAR(64),
`diseases` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `doctors` (
`id` INT,
`name` VARCHAR(64),
`occupied` BOOL,
`department` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `chances` (
`disease` INT,
`chance` INT,
PRIMARY KEY (`disease`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_302802_20210416163502_all') AS relationships;
