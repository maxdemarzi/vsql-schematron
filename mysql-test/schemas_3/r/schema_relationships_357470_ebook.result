INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 357470_ebook
#
CREATE DATABASE `db_357470_ebook`;
USE `db_357470_ebook`;
CREATE TABLE `book_brief` (
`name` VARCHAR(50),
`ISBN` VARCHAR(50) NOT NULL,
`price` DECIMAL(10,2),
`author` VARCHAR(50),
`inventory` INT,
`cover_path` VARCHAR(50),
`intro` VARCHAR(50),
PRIMARY KEY (`ISBN`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`name` VARCHAR(50),
`ID` VARCHAR(50) NOT NULL,
`avatar_path` VARCHAR(50),
`password` VARCHAR(50),
`email` VARCHAR(50),
`state` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` VARCHAR(50) NOT NULL,
`ID` VARCHAR(50),
`ISBN` VARCHAR(50),
`time` VARCHAR(50),
`amount` INT,
`state` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_357470_ebook') AS relationships;
relationships
Database: db_357470_ebook

Table Connections:
