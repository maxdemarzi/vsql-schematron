INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 313557_worksheet
#
CREATE DATABASE `db_313557_worksheet`;
USE `db_313557_worksheet`;
CREATE TABLE `mountains` (
`id` INT,
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `peaks` (
`id` INT,
`name` VARCHAR(64),
`mountain_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT,
`client_id` INT,
`project_lead_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `clients` (
`id` INT,
`client_name` VARCHAR(64),
`project_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_313557_worksheet') AS relationships;
