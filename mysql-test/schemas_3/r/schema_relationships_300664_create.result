`mid` INT,
PRIMARY KEY (`materialid`)
) CHARACTER SET latin1;
CREATE TABLE `texture` (
`textureid` INT,
`filename` VARCHAR(64),
`mid` INT,
PRIMARY KEY (`textureid`)
) CHARACTER SET latin1;
CREATE TABLE `actiontype` (
`atid` INT,
`atdh` VARCHAR(64),
`atname` VARCHAR(64),
PRIMARY KEY (`atid`)
) CHARACTER SET latin1;
CREATE TABLE `action` (
`actionid` INT,
`atid` INT,
`mid` INT,
`actiondata` VARCHAR(64),
PRIMARY KEY (`actionid`)
) CHARACTER SET latin1;
