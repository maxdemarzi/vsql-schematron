CREATE TABLE `Message` (
`id` BIGINT NOT NULL,
`iv` BLOB,
`type` VARCHAR(50),
`sender` VARCHAR(50),
`recipient` VARCHAR(50),
`data` BLOB,
`sent` BIGINT,
`received` BIGINT,
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Label` (
`id` BIGINT NOT NULL,
`label` VARCHAR(50),
`type` VARCHAR(50),
`color` INT,
`ord` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Message_Label` (
`message_id` BIGINT NOT NULL,
`label_id` BIGINT NOT NULL,
PRIMARY KEY (`message_id`, `label_id`)
) CHARACTER SET latin1;
