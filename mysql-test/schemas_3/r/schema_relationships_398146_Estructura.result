) CHARACTER SET latin1;
CREATE TABLE `moves` (
`origin_id` INT,
`destiny_id` INT,
`amount` DECIMAL(10,2),
`description` VARCHAR(64),
`type` VARCHAR(64)
) CHARACTER SET latin1;
