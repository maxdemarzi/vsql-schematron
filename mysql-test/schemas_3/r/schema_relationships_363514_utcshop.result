INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 363514_utcshop
#
CREATE DATABASE `db_363514_utcshop`;
USE `db_363514_utcshop`;
CREATE TABLE `account` (
`id` INT,
`name` VARCHAR(255),
`username` VARCHAR(255),
`password` VARCHAR(255),
`date_of_birth` DATETIME,
`gender` VARCHAR(255),
`email` VARCHAR(255),
`phone_number` VARCHAR(255),
`address` VARCHAR(255),
`registered_date` DATETIME,
`role` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bill` (
`id` INT,
`account_id` INT,
`name` VARCHAR(255),
`address` VARCHAR(255),
`phone` VARCHAR(255),
`email` VARCHAR(255),
`method` VARCHAR(255),
`time` DATETIME,
`last_update_date` INT,
`status` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `bill_detail` (
`id` INT,
`bill_id` INT,
`product_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `cart` (
`id` INT,
`account_id` INT,
`product_id` INT,
`quantity` INT
) CHARACTER SET latin1;
CREATE TABLE `category` (
`id` INT,
`name` VARCHAR(255),
`image` VARCHAR(255),
`level` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comment` (
`id` INT,
`account_id` INT,
`product_id` INT,
`title` VARCHAR(255),
`content` VARCHAR(255),
`time` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `news` (
`id` INT,
`title` VARCHAR(255),
`short_content` VARCHAR(255),
`content` VARCHAR(255),
`image` VARCHAR(255),
`time` DATETIME,
`author` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`id` INT,
`name` VARCHAR(255),
`image` VARCHAR(255),
`description` VARCHAR(255),
`quantity` INT,
`sold` INT,
`price` INT,
`discount` INT,
`promotion` VARCHAR(255),
`category_id` INT,
`updated_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `support` (
`id` INT,
`title` VARCHAR(255),
`content` VARCHAR(255),
`name` VARCHAR(255),
`phone` VARCHAR(255),
`email` VARCHAR(255),
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_363514_utcshop') AS relationships;
relationships
Database: db_363514_utcshop

