INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 303153_MenswearDB
#
CREATE DATABASE `db_303153_MenswearDB`;
USE `db_303153_MenswearDB`;
CREATE TABLE `Sellers` (
`seller_id` INT,
`seller_name` VARCHAR(64),
`user_name` VARCHAR(64),
`user_pass` VARCHAR(64),
PRIMARY KEY (`seller_id`)
) CHARACTER SET latin1;
CREATE TABLE `Categories` (
`category_id` INT,
`category_name` VARCHAR(64),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `Sizes` (
`size_id` INT,
`size_name` VARCHAR(64),
PRIMARY KEY (`size_id`)
) CHARACTER SET latin1;
CREATE TABLE `Colors` (
`color_id` INT,
`color_name` VARCHAR(64),
PRIMARY KEY (`color_id`)
) CHARACTER SET latin1;
CREATE TABLE `Customers` (
`customer_id` INT,
`customer_name` VARCHAR(64),
`customer_phone` VARCHAR(64),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `Menswears` (
`menswear_id` INT,
`menswear_name` VARCHAR(64),
`menswear_description` VARCHAR(64),
`menswear_brand` VARCHAR(64),
`menswear_material` VARCHAR(64),
`menswear_price` DECIMAL(10,2),
`amount` INT,
`category_id` INT,
PRIMARY KEY (`menswear_id`)
) CHARACTER SET latin1;
CREATE TABLE `MenswearTables` (
`menswear_id` INT,
`size_id` INT,
`color_id` INT,
`quantity` INT,
PRIMARY KEY (`menswear_id`, `size_id`, `color_id`)
) CHARACTER SET latin1;
CREATE TABLE `Invoices` (
`invoice_no` INT,
`invoice_date` DATETIME,
`invoice_status` INT,
`customer_id` INT,
`seller_id` INT,
PRIMARY KEY (`invoice_no`)
) CHARACTER SET latin1;
CREATE TABLE `InvoiceDetails` (
`invoice_no` INT,
`menswear_id` INT,
`total_due` DECIMAL(10,2),
`quantity` INT,
PRIMARY KEY (`invoice_no`, `menswear_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_303153_MenswearDB') AS relationships;
relationships
Database: db_303153_MenswearDB

Table Connections:
------------------
[Implied]  InvoiceDetails.invoice_no -> Invoices.invoice_no
[Implied]  InvoiceDetails.menswear_id -> Menswears.menswear_id
[Implied]  Invoices.customer_id -> Customers.customer_id
[Implied]  Invoices.seller_id -> Sellers.seller_id
[Implied]  MenswearTables.color_id -> Colors.color_id
[Implied]  MenswearTables.menswear_id -> Menswears.menswear_id
[Implied]  MenswearTables.size_id -> Sizes.size_id
[Implied]  Menswears.category_id -> Categories.category_id

DROP DATABASE `db_303153_MenswearDB`;
UNINSTALL EXTENSION vsql_schematron;
