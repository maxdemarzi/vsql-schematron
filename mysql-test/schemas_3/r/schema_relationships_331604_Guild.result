`id` VARCHAR(64),
`k_guild_id` VARCHAR(64),
`k_user_id` VARCHAR(64),
`k_points` INT,
`k_ts` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `kbInsights` (
`id` INT,
`k_guild_id` VARCHAR(64),
`k_date` DATETIME,
`k_left` INT,
`k_joined` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
