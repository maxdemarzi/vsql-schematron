CREATE TABLE `kbGuild` (
`id` VARCHAR(64),
`guild_id` VARCHAR(64),
`prefix` VARCHAR(64),
`max_warning_points` INT,
`mod_log_channel` VARCHAR(64),
`welcome_channel` VARCHAR(64),
`reactRoleChannel` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
