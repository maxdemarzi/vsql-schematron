[Implied]  Friends.friendID -> Users.userID
[Implied]  Friends.userID -> Users.userID
[Implied]  Matches.gameID -> Games.gameID
[Implied]  Matches.userID -> Users.userID

DROP DATABASE `db_388604_schema`;
UNINSTALL EXTENSION vsql_schematron;
