INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 388604_schema
#
CREATE DATABASE `db_388604_schema`;
USE `db_388604_schema`;
CREATE TABLE `Games` (
`gameID` INT,
`gameName` VARCHAR(64),
`gameType` VARCHAR(64),
`maxPlayers` INT,
PRIMARY KEY (`gameID`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`userID` INT,
`isOnline` BOOL,
`userName` VARCHAR(64),
`avatarURL` VARCHAR(64),
PRIMARY KEY (`userID`)
) CHARACTER SET latin1;
CREATE TABLE `Friends` (
`userID` INT,
`friendID` INT,
PRIMARY KEY (`userID`, `friendID`)
) CHARACTER SET latin1;
CREATE TABLE `Matches` (
`instanceID` INT,
`userID` INT,
`gameID` INT,
PRIMARY KEY (`instanceID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_388604_schema') AS relationships;
relationships
Database: db_388604_schema

Table Connections:
