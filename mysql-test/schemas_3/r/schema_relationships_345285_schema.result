INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 345285_schema
#
CREATE DATABASE `db_345285_schema`;
USE `db_345285_schema`;
CREATE TABLE `usuarios` (
`id` INT NOT NULL,
`nome` TEXT,
`nome_loja` TEXT,
`email` TEXT,
`senha` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `produtos` (
`id` INT NOT NULL,
`usuario_id` INT,
`nome` TEXT,
`estoque` INT,
`preco` INT,
`categoria` TEXT,
`descricao` TEXT,
`imagem` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_345285_schema') AS relationships;
