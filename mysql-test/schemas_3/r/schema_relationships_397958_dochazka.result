`idPozice` INT
) CHARACTER SET latin1;
CREATE TABLE `pozice` (
`idPozice` INT NOT NULL,
`Nazev` VARCHAR(50),
PRIMARY KEY (`idPozice`)
) CHARACTER SET latin1;
