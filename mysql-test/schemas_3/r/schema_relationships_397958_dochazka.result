USE `db_397958_dochazka`;
CREATE TABLE `dochazka` (
`prichodDoPrace` DATETIME,
`odchodZPrace` DATETIME,
`prichodKLekari` DATETIME,
`odchodOdLekare` DATETIME,
`prichodNaObed` DATETIME,
