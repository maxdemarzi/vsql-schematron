CREATE TABLE `kabupaten` (
`id_kab` VARCHAR(64),
`id_prov` VARCHAR(64),
`nama` VARCHAR(64),
`id_jenis` INT,
PRIMARY KEY (`id_kab`)
) CHARACTER SET latin1;
CREATE TABLE `kecamatan` (
`id_kec` VARCHAR(64),
`id_kab` VARCHAR(64),
`nama` VARCHAR(64),
PRIMARY KEY (`id_kec`)
) CHARACTER SET latin1;
CREATE TABLE `provinsi` (
`id_prov` VARCHAR(64),
`nama` VARCHAR(64),
PRIMARY KEY (`id_prov`)
) CHARACTER SET latin1;
CREATE TABLE `tm_category` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`status` INT,
`deleted` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tm_cover` (
`id` INT,
`slide` VARCHAR(64),
`created_at` DATETIME,
`update_at` DATETIME,
`cover` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tm_forgot_pass` (
`id` INT,
`id_userLogin` INT,
`uniqueCode` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `tm_status_order` (
`id` INT,
`class` VARCHAR(64),
`status` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tr_stock` (
`id` INT,
`id_prod_size` INT,
`id_store` INT,
`invoice` VARCHAR(64),
`quantity` INT,
`update_stock` DATETIME
) CHARACTER SET latin1;
