`dataformat` VARCHAR(50),
`sourcekind` VARCHAR(50),
PRIMARY KEY (`enginetype`)
) CHARACTER SET latin1;
CREATE TABLE `sourcemanager` (
`sourceid` VARCHAR(50) NOT NULL,
`spaceid` VARCHAR(50),
`sourcetype` VARCHAR(50),
`name` VARCHAR(50),
`comment` VARCHAR(50),
`url` VARCHAR(50),
`createtime` VARCHAR(50),
`updatetime` VARCHAR(50),
`state` VARCHAR(50),
PRIMARY KEY (`sourceid`)
) CHARACTER SET latin1;
CREATE TABLE `sourcetables` (
`tableid` VARCHAR(50) NOT NULL,
`sourceid` VARCHAR(50),
`spaceid` VARCHAR(50),
`name` VARCHAR(50),
`comment` VARCHAR(50),
`url` VARCHAR(50),
`createtime` VARCHAR(50),
`updatetime` VARCHAR(50),
`direction` VARCHAR(50),
PRIMARY KEY (`tableid`)
) CHARACTER SET latin1;
