INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 331393_schema
#
CREATE DATABASE `db_331393_schema`;
USE `db_331393_schema`;
CREATE TABLE `COMMENT` (
`ID` BIGINT NOT NULL,
`DESCRIPTION` VARCHAR(50),
`BOOK_ID` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `GENRE` (
`ID` BIGINT NOT NULL,
`NAME` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `AUTHOR` (
`ID` BIGINT NOT NULL,
`FULLNAME` VARCHAR(50),
`ALIAS` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `BOOK` (
`ID` BIGINT NOT NULL,
`NAME` VARCHAR(50),
`AUTHOR_ID` BIGINT,
`GENRE_ID` BIGINT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_331393_schema') AS relationships;
