INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 379321_oracle.create.strict
#
CREATE DATABASE `db_379321_oracle_create_strict`;
USE `db_379321_oracle_create_strict`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(64),
`cpa` VARCHAR(64),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `url` (
`source` VARCHAR(64),
`destination` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`time_stamp` DATETIME,
`cpa_id` VARCHAR(64),
`conversation_id` VARCHAR(64),
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`ref_to_message_id` VARCHAR(64),
`time_to_live` DATETIME,
`persist_time` DATETIME,
`from_party_id` VARCHAR(64),
`from_role` VARCHAR(64),
`to_party_id` VARCHAR(64),
`to_role` VARCHAR(64),
`service` VARCHAR(64),
`action` VARCHAR(64),
`content` VARCHAR(64),
`status` DECIMAL(10,2),
`status_time` DATETIME,
PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`order_nr` DECIMAL(10,2),
`name` VARCHAR(64),
`content_id` VARCHAR(64),
`content_type` VARCHAR(64),
`content` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event` (
`cpa_id` VARCHAR(64),
`client_alias` VARCHAR(64),
`channel_id` VARCHAR(64),
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`is_confidential` DECIMAL(10,2),
`retries` DECIMAL(10,2),
`server_id` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_event_log` (
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`time_stamp` DATETIME,
`uri` VARCHAR(64),
`status` DECIMAL(10,2),
`error_message` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message_event` (
`message_id` VARCHAR(64),
`message_nr` DECIMAL(10,2),
`event_type` DECIMAL(10,2),
`time_stamp` DATETIME,
`processed` DECIMAL(10,2)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_379321_oracle_create_strict') AS relationships;
relationships
Database: db_379321_oracle_create_strict

