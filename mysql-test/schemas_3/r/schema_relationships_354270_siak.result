CREATE DATABASE `db_354270_siak`;
USE `db_354270_siak`;
CREATE TABLE `akun` (
`no_reff` INT,
`id_user` INT,
`nama_reff` VARCHAR(50),
`keterangan` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `transaksi` (
`id_transaksi` INT,
`id_user` INT,
`no_reff` INT,
`tgl_input` DATETIME,
`tgl_transaksi` DATE,
`jenis_saldo` VARCHAR(50),
`saldo` INT
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id_user` INT NOT NULL,
`nama` VARCHAR(50),
`jk` VARCHAR(50),
`alamat` VARCHAR(50),
`email` VARCHAR(50),
`username` VARCHAR(50),
`password` VARCHAR(50),
`last_login` DATETIME,
PRIMARY KEY (`id_user`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_354270_siak') AS relationships;
