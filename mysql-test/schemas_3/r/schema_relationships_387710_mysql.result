INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 387710_mysql
#
CREATE DATABASE `db_387710_mysql`;
USE `db_387710_mysql`;
CREATE TABLE `users` (
`id` INT,
`usertype` INT,
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`email` VARCHAR(64),
`mobile` VARCHAR(64),
`pwd` VARCHAR(64),
`abn` VARCHAR(64),
`userAddress` VARCHAR(64),
`active` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accommodation` (
`id` INT,
`accomLocation` VARCHAR(64),
`availFrom` DATETIME,
`availTo` DATETIME,
`guests` INT,
`price` DECIMAL(10,2),
`rooms` INT,
`bathrooms` INT,
`smoking` VARCHAR(64),
`garage` VARCHAR(64),
`pet` VARCHAR(64),
`internet` VARCHAR(64),
`accomAddress` VARCHAR(64),
`houseRating` DECIMAL(10,2),
`hostRating` DECIMAL(10,2),
`hostID` INT,
`accomName` VARCHAR(64),
`accomDesc` VARCHAR(64),
`city` VARCHAR(64),
`entireHouse` VARCHAR(64),
`active` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `inbox` (
`id` INT,
`fromID` INT,
`toID` INT,
`msg` VARCHAR(64),
`bookingID` INT,
`inputTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `reviews` (
`id` INT,
`bid` INT,
`hostID` INT,
`reviewerID` INT,
`accomID` INT,
`accomRating` INT,
`hostRating` INT,
`review` VARCHAR(64),
`inputTime` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_387710_mysql') AS relationships;
relationships
Database: db_387710_mysql

Table Connections:
