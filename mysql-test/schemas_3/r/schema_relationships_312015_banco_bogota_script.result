INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 312015_banco_bogota_script
#
CREATE DATABASE `db_312015_banco_bogota_script`;
USE `db_312015_banco_bogota_script`;
CREATE TABLE `ciudad` (
`id` INT,
`nombre` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `cuenta` (
`num` INT,
`cedula` VARCHAR(64),
`nombre` VARCHAR(64),
`telefono` VARCHAR(64),
`saldo` DECIMAL(10,2),
`ciudad_id` INT,
PRIMARY KEY (`num`)
) CHARACTER SET latin1;
CREATE TABLE `tipo_transaccion` (
`id` INT,
`nombre` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transaccion` (
`id` INT,
`valor` DECIMAL(10,2),
`fecha` DATETIME,
`tipo` INT,
`cuenta` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_312015_banco_bogota_script') AS relationships;
relationships
Database: db_312015_banco_bogota_script

Table Connections:
------------------
[Implied]  cuenta.ciudad_id -> ciudad.id
[Implied]  transaccion.cuenta -> cuenta.num
[Implied]  transaccion.tipo -> tipo_transaccion.id

DROP DATABASE `db_312015_banco_bogota_script`;
UNINSTALL EXTENSION vsql_schematron;
