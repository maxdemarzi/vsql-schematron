CREATE DATABASE `db_353115_db_knnig`;
USE `db_353115_db_knnig`;
CREATE TABLE `cyrotherapy` (
`patient_id` INT,
`sex` INT,
`age` INT,
`time` DECIMAL(10,2),
`number_of_warts` INT,
`type` INT,
`area` INT,
`result_of_treatment` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`patient_id`)
) CHARACTER SET latin1;
CREATE TABLE `dataset_type` (
`id` INT,
`type` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `experiments` (
`experiment_id` INT,
`dataset_id` INT,
`type` VARCHAR(64),
`created_at` DATETIME,
`number_of_folds` INT,
`number_of_neighbors` INT,
`thresholds` DECIMAL(10,2),
`updated_at` DATETIME,
PRIMARY KEY (`experiment_id`)
) CHARACTER SET latin1;
CREATE TABLE `experiment_details` (
`detail_id` INT,
`experiment_id` INT,
`fold_number` INT,
`tp` INT,
`tn` INT,
`fp` INT,
`fn` INT,
`accuracy` DECIMAL(10,2),
`sensitivity` DECIMAL(10,2),
`specificity` DECIMAL(10,2),
`execution_time` DECIMAL(10,2),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `immunotherapy` (
`patient_id` INT,
`sex` INT,
`age` INT,
`time` DECIMAL(10,2),
`number_of_warts` INT,
`type` INT,
`area` INT,
`induration_diameter` INT,
`result_of_treatment` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`patient_id`)
) CHARACTER SET latin1;
CREATE TABLE `information_gain` (
`id` INT,
`dataset_id` INT,
`feature` VARCHAR(64),
`gain` DECIMAL(10,2),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `patients` (
`patient_id` INT,
`sex` INT,
`age` INT,
`time` DECIMAL(10,2),
`number_of_warts` INT,
`type` INT,
`area` INT,
`result_of_treatment` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`patient_id`)
) CHARACTER SET latin1;
