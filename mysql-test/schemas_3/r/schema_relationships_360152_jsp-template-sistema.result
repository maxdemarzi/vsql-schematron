INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 360152_jsp-template-sistema
#
CREATE DATABASE `db_360152_jsp_template_sistema`;
USE `db_360152_jsp_template_sistema`;
CREATE TABLE `profiles` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`telephone` CHAR(50),
`email` VARCHAR(50),
`login` CHAR(50),
`password` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_profiles` (
`id_user` INT NOT NULL,
`id_profile` INT NOT NULL,
PRIMARY KEY (`id_user`, `id_profile`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_360152_jsp_template_sistema') AS relationships;
relationships
Database: db_360152_jsp_template_sistema

