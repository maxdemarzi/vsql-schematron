INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 394865_init
#
CREATE DATABASE `db_394865_init`;
USE `db_394865_init`;
CREATE TABLE `movies` (
`mid` INT NOT NULL,
`title` VARCHAR(50),
`year` INT,
`rating` DOUBLE,
`num_ratings` INT,
PRIMARY KEY (`mid`)
) CHARACTER SET latin1;
CREATE TABLE `actors` (
`mid` INT,
`name` VARCHAR(50),
`cast_position` INT
) CHARACTER SET latin1;
CREATE TABLE `genres` (
`mid` INT,
`genre` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `tag_names` (
`tid` INT NOT NULL,
`tag` VARCHAR(50),
PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
CREATE TABLE `tags` (
`mid` INT,
`tid` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_394865_init') AS relationships;
