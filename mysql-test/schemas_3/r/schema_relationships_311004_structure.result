INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 311004_structure
#
CREATE DATABASE `db_311004_structure`;
USE `db_311004_structure`;
CREATE TABLE `machine` (
`machine` VARCHAR(50) NOT NULL,
`key` TEXT,
PRIMARY KEY (`machine`)
) CHARACTER SET latin1;
CREATE TABLE `product` (
`pid` INT NOT NULL,
`product` TEXT,
`price` INT,
PRIMARY KEY (`pid`)
) CHARACTER SET latin1;
CREATE TABLE `slot_product` (
`spid` INT NOT NULL,
`slot` INT,
`machine` TEXT,
`product` INT,
PRIMARY KEY (`spid`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`tid` INT NOT NULL,
`uid` INT,
`value` INT,
`descr` TEXT,
`timestamp` TIMESTAMP NULL,
`machine` TEXT,
`product` INT,
`user` TEXT,
`username` TEXT,
PRIMARY KEY (`tid`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`uid` INT NOT NULL,
`username` TEXT,
`card_data` TEXT,
`enabled` INT,
`admin` INT,
`access_areas` TEXT,
`phone` TEXT,
`email` TEXT,
`address` TEXT,
`realname` TEXT,
`password` TEXT,
`sshkey` TEXT,
`stripe_id` TEXT,
PRIMARY KEY (`uid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_311004_structure') AS relationships;
relationships
Database: db_311004_structure

Table Connections:
------------------
[Implied]  slot_product.machine -> machine.machine
[Implied]  slot_product.product -> product.pid
[Implied]  transactions.machine -> machine.machine
[Implied]  transactions.product -> product.pid

DROP DATABASE `db_311004_structure`;
UNINSTALL EXTENSION vsql_schematron;
