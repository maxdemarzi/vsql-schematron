CREATE DATABASE `db_386794_Imagedb_DDL`;
USE `db_386794_Imagedb_DDL`;
CREATE TABLE `ALBUMS` (
`ALBUM_ID` INT,
`USER_ID` INT,
`TITLE` VARCHAR(64),
`CREATION_DATE` DATETIME,
PRIMARY KEY (`ALBUM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ALBUMS_IMAGES` (
`ALBUM_ID` INT,
`IMAGE_ID` INT,
`ORDER_NUMBER` INT,
PRIMARY KEY (`ALBUM_ID`, `IMAGE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `ARTISTS` (
`ARTIST_ID` INT,
`NAME` VARCHAR(64),
`NAME_2` VARCHAR(64),
`SURNAME` VARCHAR(64),
`BIRTH_YEAR` DATETIME,
`DEATH_YEAR` DATETIME,
`COMMENTS` VARCHAR(64),
`RATINGS` DECIMAL(10,2),
PRIMARY KEY (`ARTIST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `IMAGE_AUTHORS` (
`IMAGE_ID` INT,
`AUTHOR_ID` INT,
PRIMARY KEY (`IMAGE_ID`, `AUTHOR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `IMAGE_FILES` (
`IMAGE_FILE_ID` INT,
`FILE_NAME` VARCHAR(64),
`FILE_SIZE` INT,
`FILE_EXTENSION` VARCHAR(64),
`CREATION_DATE` DATETIME,
`IS_PUBLIC` BOOL,
`FILE` VARCHAR(64),
PRIMARY KEY (`IMAGE_FILE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `IMAGE_TYPES` (
`TYPE_ID` INT,
`NAME` VARCHAR(64),
`COMMENTS` VARCHAR(64),
PRIMARY KEY (`TYPE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `IMAGES` (
`IMAGE_ID` INT,
`TITLE` VARCHAR(64),
`IMAGE_FILE_ID` INT,
`NATIVE_WIDTH` INT,
`NATIVE_HEIGHT` INT,
`RESOLUTION` INT,
`DEPTH` INT,
`COMMENTS` VARCHAR(64),
`RATING` DECIMAL(10,2),
`RATING_TIMES` INT,
`TYPE_ID` INT,
`YEAR` INT,
`OWNER_ID` INT,
PRIMARY KEY (`IMAGE_ID`)
) CHARACTER SET latin1;
