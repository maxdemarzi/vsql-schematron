CREATE DATABASE `db_319854_V1__init`;
USE `db_319854_V1__init`;
CREATE TABLE `wkUser` (
`id` INT NOT NULL,
`nick_name` VARCHAR(50),
`role` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `workout` (
`id` INT NOT NULL,
`comment` TEXT,
`type` SMALLINT,
`user_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exercise` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`notes` TEXT,
`part` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `workout_exercise` (
`workout_id` INT NOT NULL,
`exercise_id` INT NOT NULL,
PRIMARY KEY (`workout_id`, `exercise_id`)
) CHARACTER SET latin1;
