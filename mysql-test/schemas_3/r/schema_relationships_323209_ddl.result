INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 323209_ddl
#
CREATE DATABASE `db_323209_ddl`;
USE `db_323209_ddl`;
CREATE TABLE `client` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email_address` VARCHAR(50),
`account_type` VARCHAR(50),
`extra` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `stock` (
`stock_id` INT NOT NULL,
`client_id` INT,
`ticker` CHAR(50),
`shares` INT,
`purchased_value` INT,
`purchased_date` VARCHAR(50),
PRIMARY KEY (`stock_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_323209_ddl') AS relationships;
