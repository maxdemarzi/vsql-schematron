CREATE DATABASE `db_377271_init`;
USE `db_377271_init`;
CREATE TABLE `account` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`password_hash` VARCHAR(50),
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
`id` VARCHAR(50) NOT NULL,
`account_id` BIGINT,
`created_at` TIMESTAMP NULL,
`expires_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_377271_init') AS relationships;
