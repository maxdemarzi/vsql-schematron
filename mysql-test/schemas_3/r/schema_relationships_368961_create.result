CREATE DATABASE `db_368961_create`;
USE `db_368961_create`;
CREATE TABLE `Card_state` (
`id_state` DECIMAL(10,2),
`state_title` VARCHAR(64),
PRIMARY KEY (`id_state`)
) CHARACTER SET latin1;
CREATE TABLE `Sex` (
`id_sex` DECIMAL(10,2),
`sex_title` VARCHAR(64),
PRIMARY KEY (`id_sex`)
) CHARACTER SET latin1;
CREATE TABLE `Patient` (
`id_patient` DECIMAL(10,2),
`last_name` VARCHAR(64),
`first_name` VARCHAR(64),
`patronymic` VARCHAR(64),
`id_sex` DECIMAL(10,2),
`date_birth` DATETIME,
`telephone` VARCHAR(64),
`passport` VARCHAR(64),
`insurance_number` VARCHAR(64),
PRIMARY KEY (`id_patient`)
) CHARACTER SET latin1;
CREATE TABLE `Medical_card` (
`id_medical_card` DECIMAL(10,2),
`id_patient` DECIMAL(10,2),
`id_state` DECIMAL(10,2),
PRIMARY KEY (`id_medical_card`)
) CHARACTER SET latin1;
CREATE TABLE `Group_info` (
`id_group_info` DECIMAL(10,2),
`group_title` VARCHAR(64),
PRIMARY KEY (`id_group_info`)
) CHARACTER SET latin1;
CREATE TABLE `Additional_info` (
`id_info` DECIMAL(10,2),
`id_medical_card` DECIMAL(10,2),
`id_group_info` DECIMAL(10,2),
`description` VARCHAR(64),
PRIMARY KEY (`id_info`)
) CHARACTER SET latin1;
CREATE TABLE `History_type` (
`id_history_type` DECIMAL(10,2),
`type_title` VARCHAR(64),
PRIMARY KEY (`id_history_type`)
) CHARACTER SET latin1;
CREATE TABLE `Medical_history` (
`id_medical_history` DECIMAL(10,2),
