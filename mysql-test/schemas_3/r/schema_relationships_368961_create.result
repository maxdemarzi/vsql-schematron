PRIMARY KEY (`id_laboratory`, `id_week_day`, `id_time`)
) CHARACTER SET latin1;
CREATE TABLE `Doctor_schedule` (
`id_doctor` DECIMAL(10,2),
`id_week_day` DECIMAL(10,2),
`id_time` DECIMAL(10,2),
PRIMARY KEY (`id_doctor`, `id_week_day`, `id_time`)
) CHARACTER SET latin1;
CREATE TABLE `Doctor_reception` (
`id_doctor_reception` DECIMAL(10,2),
`id_medical_history` DECIMAL(10,2),
`id_doctor` DECIMAL(10,2),
