PRIMARY KEY (`id_treatment`)
) CHARACTER SET latin1;
CREATE TABLE `Diagnosis` (
`id_diagnosis` DECIMAL(10,2),
`id_examination` DECIMAL(10,2),
`id_illness` DECIMAL(10,2),
PRIMARY KEY (`id_diagnosis`)
) CHARACTER SET latin1;
