`openning_date` DATETIME,
PRIMARY KEY (`id_medical_history`)
) CHARACTER SET latin1;
CREATE TABLE `Specialization` (
`id_specialization` DECIMAL(10,2),
`spec_title` VARCHAR(64),
PRIMARY KEY (`id_specialization`)
) CHARACTER SET latin1;
CREATE TABLE `Doctor` (
`id_doctor` DECIMAL(10,2),
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`patronymic` VARCHAR(64),
`id_specialization` DECIMAL(10,2),
PRIMARY KEY (`id_doctor`)
) CHARACTER SET latin1;
CREATE TABLE `Group_illnesses` (
`id_group_illnesses` DECIMAL(10,2),
`ilnesses_gr_title` VARCHAR(64),
PRIMARY KEY (`id_group_illnesses`)
) CHARACTER SET latin1;
CREATE TABLE `Illnesses` (
`id_illness` DECIMAL(10,2),
