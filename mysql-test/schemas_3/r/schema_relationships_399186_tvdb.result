CREATE DATABASE `db_399186_tvdb`;
USE `db_399186_tvdb`;
CREATE TABLE `role` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `title` (
`id` INT,
`name` VARCHAR(255),
`description` VARCHAR(255),
`owner` VARCHAR(255),
`title_type_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `title_type` (
`id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `user` (
`id` INT,
`login` VARCHAR(255),
`password_hash` VARCHAR(255),
`role_id` INT,
`last_name` VARCHAR(255),
`first_name` VARCHAR(255),
`middle_name` VARCHAR(255),
`position` VARCHAR(255),
`image` VARCHAR(255),
`auth_token` VARCHAR(255),
`status` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_399186_tvdb') AS relationships;
