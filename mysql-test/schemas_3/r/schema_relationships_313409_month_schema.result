INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 313409_month_schema
#
CREATE DATABASE `db_313409_month_schema`;
USE `db_313409_month_schema`;
CREATE TABLE `mydb.periods` (
`id` INT NOT NULL,
`period` VARCHAR(50),
`order` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.month_names` (
`id` INT NOT NULL,
`composite_month_name` VARCHAR(50),
`type` VARCHAR(50),
`order` INT,
`month_number` VARCHAR(50),
`ruler_id` INT,
`year_name_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mydb.dates` (
`id` INT NOT NULL,
`date` VARCHAR(50),
`type` VARCHAR(50),
`order` INT,
`month_name_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_313409_month_schema') AS relationships;
