CREATE TABLE `person` (
`ID` INT,
`name` VARCHAR(64),
`age` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `school` (
`ID` INT,
`name` VARCHAR(64),
`address` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `hobby` (
`pid` INT,
`hobby` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `diary` (
`ID` INT,
`pid` INT,
`text` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
