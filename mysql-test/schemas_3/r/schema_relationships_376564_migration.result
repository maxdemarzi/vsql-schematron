`refreshToken` VARCHAR(64),
`accessToken` VARCHAR(64),
`accessTokenExpires` DATETIME,
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Session` (
`id` VARCHAR(64),
`userId` VARCHAR(64),
`expires` DATETIME,
`sessionToken` VARCHAR(64),
`accessToken` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `User` (
