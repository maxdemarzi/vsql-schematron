) CHARACTER SET latin1;
CREATE TABLE `play_price` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
`value` DECIMAL(10,2),
`condition` TEXT,
`play` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
