INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 375111_data
#
CREATE DATABASE `db_375111_data`;
USE `db_375111_data`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`user_id` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`career` VARCHAR(50),
`manager` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `projects` (
`id` INT NOT NULL,
`project_id` VARCHAR(50),
`project_name` VARCHAR(50),
`project_description` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `timesheets` (
`id` INT NOT NULL,
`project_id` INT,
`user_id` INT,
`date_from` DATE,
`date_to` DATE,
`duration_min` INT,
`comments` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_375111_data') AS relationships;
relationships
