INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 351432_PremiereDB
#
CREATE DATABASE `db_351432_PremiereDB`;
USE `db_351432_PremiereDB`;
CREATE TABLE `SALES_REP` (
`SLSREP_NUMBER` VARCHAR(64),
`SLSREP_LAST_NAME` VARCHAR(64),
`SLSREP_FIRST_NAME` VARCHAR(64),
`SLSREP_GENDER` VARCHAR(64),
`SLSREP_STREET` VARCHAR(64),
`SLSREP_CITY` VARCHAR(64),
`SLSREP_US_STATE` VARCHAR(64),
`SLSREP_ZIP_CODE` VARCHAR(64),
`SLSREP_TOTAL_COMMISSION` DECIMAL(10,2),
`SLSREP_COMMISSION_RATE` DECIMAL(10,2),
PRIMARY KEY (`SLSREP_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `CUSTOMER` (
`CUSTOMER_NUMBER` VARCHAR(64),
`CUSTOMER_LAST_NAME` VARCHAR(64),
`CUSTOMER_FIRST_NAME` VARCHAR(64),
`CUSTOMER_STREET` VARCHAR(64),
`CUSTOMER_CITY` VARCHAR(64),
`CUSTOMER_US_STATE` VARCHAR(64),
`CUSTOMER_ZIP_CODE` VARCHAR(64),
`CUSTOMER_BALANCE` DECIMAL(10,2),
`CUSTOMER_CREDIT_LIMIT` DECIMAL(10,2),
`CUSTOMER_SLSREP_NUMBER` VARCHAR(64),
PRIMARY KEY (`CUSTOMER_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `ORDERS` (
`ORDER_NUMBER` VARCHAR(64),
`ORDER_DATE` DATETIME,
`ORDER_CUSTOMER_NUMBER` VARCHAR(64),
PRIMARY KEY (`ORDER_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `PART` (
`PART_NUMBER` VARCHAR(64),
`PART_DESCRIPTION` VARCHAR(64),
`PART_UNITS_ON_HAND` DECIMAL(10,2),
`PART_ITEM_CLASS` VARCHAR(64),
`PART_WAREHOUSE_NUMBER` VARCHAR(64),
`PART_UNIT_PRICE` DECIMAL(10,2),
PRIMARY KEY (`PART_NUMBER`)
) CHARACTER SET latin1;
CREATE TABLE `ORDER_LINE` (
`LINE_ORDER_NUMBER` VARCHAR(64),
`LINE_PART_NUMBER` VARCHAR(64),
`LINE_NUMBER_ORDERED` DECIMAL(10,2),
`LINE_QUOTED_PRICE` DECIMAL(10,2),
PRIMARY KEY (`LINE_ORDER_NUMBER`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_351432_PremiereDB') AS relationships;
