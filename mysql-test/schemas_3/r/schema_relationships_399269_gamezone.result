INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 399269_gamezone
#
CREATE DATABASE `db_399269_gamezone`;
USE `db_399269_gamezone`;
CREATE TABLE `failed_jobs` (
`id` INT,
`uuid` VARCHAR(64),
`connection` VARCHAR(64),
`queue` VARCHAR(64),
`payload` VARCHAR(64),
`exception` VARCHAR(64),
`failed_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `migrations` (
`id` INT,
`migration` VARCHAR(64),
`batch` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `oauth_providers` (
`id` INT,
`user_id` INT,
`provider` VARCHAR(64),
`provider_user_id` VARCHAR(64),
`access_token` VARCHAR(64),
`refresh_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `password_resets` (
`email` VARCHAR(64),
`token` VARCHAR(64),
`created_at` DATETIME
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`name` VARCHAR(64),
`slug` VARCHAR(64),
`description` VARCHAR(64),
`details` VARCHAR(64),
`specification` VARCHAR(64),
`image_name` VARCHAR(64),
`image_name1` VARCHAR(64),
`image_name2` VARCHAR(64),
`image_name3` VARCHAR(64),
`image_name4` VARCHAR(64),
`price` VARCHAR(64),
`sale_price` VARCHAR(64),
`cat` VARCHAR(64),
`brand` VARCHAR(64),
`bestselling` INT,
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` INT,
`name` VARCHAR(64),
`email` VARCHAR(64),
`email_verified_at` DATETIME,
`password` VARCHAR(64),
`logintype` VARCHAR(64),
`remember_token` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_399269_gamezone') AS relationships;
