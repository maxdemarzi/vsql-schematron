INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 315165_tables
#
CREATE DATABASE `db_315165_tables`;
USE `db_315165_tables`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`password` VARCHAR(50),
`role` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibitions` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`ticket_price` DECIMAL(10,2),
`opening_date` DATE,
`closing_date` DATE,
`status` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `exhibitions_halls` (
`hall_id` INT,
`exhibition_id` INT
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
`id` INT NOT NULL,
`user_id` INT,
`exhibition_id` INT,
`price` DECIMAL(10,2),
`purchase_time` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_315165_tables') AS relationships;
relationships
Database: db_315165_tables

Table Connections:
------------------
[Implied]  exhibitions_halls.exhibition_id -> exhibitions.id
[Implied]  tickets.exhibition_id -> exhibitions.id
[Implied]  tickets.user_id -> users.id

DROP DATABASE `db_315165_tables`;
UNINSTALL EXTENSION vsql_schematron;
