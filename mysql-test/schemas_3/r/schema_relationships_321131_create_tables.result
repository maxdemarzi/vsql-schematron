INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 321131_create_tables
#
CREATE DATABASE `db_321131_create_tables`;
USE `db_321131_create_tables`;
CREATE TABLE `USERS` (
`ID` INT NOT NULL,
`NAME` VARCHAR(50),
`EMAIL_ADDRESS` VARCHAR(50),
`USERNAME` VARCHAR(50),
`EMAIL_VERIFIED` BOOLEAN,
`PASSWORD` VARCHAR(50),
`VERIFICATION_EMAIL_SENT` BOOLEAN,
`NEW_ACCOUNT` BOOLEAN,
`AVATAR_COLOUR_CODE` VARCHAR(50),
`CREATED_AT` DATETIME,
`UPDATED_AT` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_PROFILES` (
`ID` INT NOT NULL,
`CURRENT_POSITION` VARCHAR(50),
`CURRENT_WORKING_PLACE_NAME` VARCHAR(50),
`WEBSITE_URL` VARCHAR(50),
`LOCATION` VARCHAR(50),
`SKILLS` TEXT,
`GITHUB_USERNAME` VARCHAR(50),
`BIO` TEXT,
`PROFILE_IMAGE_URL` VARCHAR(50),
`TWITTER_URL` VARCHAR(50),
`LINKEDIN_URL` VARCHAR(50),
`FACEBOOK_URL` VARCHAR(50),
`YOUTUBE_CHANNEL_URL` VARCHAR(50),
`INSTAGRAM_URL` VARCHAR(50),
`CREATED_AT` DATETIME,
`UPDATED_AT` DATETIME,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_EXPERIENCES` (
`ID` INT NOT NULL,
`JOB_TITLE` VARCHAR(50),
`COMPANY_NAME` VARCHAR(50),
`LOCATION` VARCHAR(50),
`STARTING_DATE` DATE,
`ENDING_DATE` DATE,
`JOB_DESCRIPTION` TEXT,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USER_EDUCATIONS` (
`ID` INT NOT NULL,
`SCHOOL_NAME` VARCHAR(50),
`DEGREE` VARCHAR(50),
`FIELD_OF_STUDY` VARCHAR(50),
`STARTING_DATE` DATE,
`ENDING_DATE` DATE,
`PROGRAM_DESCRIPTION` TEXT,
`USER_ID` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `POSTS` (
`ID` INT NOT NULL,
`BODY` TEXT,
`USER_ID` INT,
`CREATED_AT` DATETIME,
`UPDATED_AT` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `POST_COMMENTS` (
`ID` INT NOT NULL,
`BODY` TEXT,
`USER_ID` INT,
`POST_ID` INT,
`CREATED_AT` DATETIME,
`UPDATED_AT` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `POST_REACTIONS` (
`ID` INT NOT NULL,
`USER_ID` INT,
`POST_ID` INT,
`REACTION` BOOLEAN,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
