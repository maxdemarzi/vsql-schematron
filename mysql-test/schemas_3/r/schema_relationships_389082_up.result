INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 389082_up
#
CREATE DATABASE `db_389082_up`;
USE `db_389082_up`;
CREATE TABLE `wallets` (
`id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `accounts` (
`wallet_id` VARCHAR(64),
`id` VARCHAR(64),
`name` VARCHAR(64),
PRIMARY KEY (`wallet_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `positions` (
`wallet_id` VARCHAR(64),
`account_id` VARCHAR(64),
`id` VARCHAR(64),
`name` VARCHAR(64),
`units` VARCHAR(64),
`price` VARCHAR(64),
`value` VARCHAR(64),
PRIMARY KEY (`wallet_id`, `account_id`, `id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`wallet_id` VARCHAR(64),
`account_id` VARCHAR(64),
`id` VARCHAR(64),
`name` VARCHAR(64),
`time` VARCHAR(64),
`amount` VARCHAR(64),
PRIMARY KEY (`wallet_id`, `account_id`, `id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_389082_up') AS relationships;
relationships
