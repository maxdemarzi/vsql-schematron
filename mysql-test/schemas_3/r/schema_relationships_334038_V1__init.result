INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 334038_V1__init
#
CREATE DATABASE `db_334038_V1__init`;
USE `db_334038_V1__init`;
CREATE TABLE `level` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member` (
`id` BIGINT NOT NULL,
`username` VARCHAR(50),
`nickname` VARCHAR(50),
`role` VARCHAR(50),
`github_id` BIGINT,
`image_url` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `mission` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`level_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post` (
`id` BIGINT NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`member_id` BIGINT,
`mission_id` BIGINT,
`title` VARCHAR(50),
`content` TEXT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `post_tag` (
`id` BIGINT NOT NULL,
`tag_id` BIGINT,
`post_id` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tag` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_334038_V1__init') AS relationships;
relationships
Database: db_334038_V1__init

Table Connections:
------------------
[Implied]  mission.level_id -> level.id
[Implied]  post.member_id -> member.id
[Implied]  post.mission_id -> mission.id
[Implied]  post_tag.post_id -> post.id
[Implied]  post_tag.tag_id -> tag.id

DROP DATABASE `db_334038_V1__init`;
UNINSTALL EXTENSION vsql_schematron;
