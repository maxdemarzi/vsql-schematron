INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 364448_ddl
#
CREATE DATABASE `db_364448_ddl`;
USE `db_364448_ddl`;
CREATE TABLE `author` (
`id` INT,
`first_name` VARCHAR(255),
`last_name` VARCHAR(255),
`date_of_birth` DATETIME,
`year_of_birth` INT,
`distinguished` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_store` (
`name` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `language` (
`id` INT,
`cd` VARCHAR(255),
`description` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT,
`author_id` INT,
`title` VARCHAR(255),
`published_in` INT,
`language_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book_to_book_store` (
`name` VARCHAR(255),
`book_id` INT,
`stock` INT,
PRIMARY KEY (`name`, `book_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_364448_ddl') AS relationships;
relationships
Database: db_364448_ddl

Table Connections:
------------------
[Implied]  book.author_id -> author.id
[Implied]  book.language_id -> language.id
[Implied]  book_to_book_store.book_id -> book.id
[Implied]  book_to_book_store.name -> book_store.name

DROP DATABASE `db_364448_ddl`;
UNINSTALL EXTENSION vsql_schematron;
