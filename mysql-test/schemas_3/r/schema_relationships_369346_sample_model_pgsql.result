INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 369346_sample_model_pgsql
#
CREATE DATABASE `db_369346_sample_model_pgsql`;
USE `db_369346_sample_model_pgsql`;
CREATE TABLE `Customer` (
`Id` INT,
`FirstName` VARCHAR(64),
`LastName` VARCHAR(64),
`City` VARCHAR(64),
`Country` VARCHAR(64),
`Phone` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `OrderItem` (
`Id` INT,
`OrderId` INT,
`ProductId` INT,
`UnitPrice` DECIMAL(10,2),
`Quantity` INT,
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Product` (
`Id` INT,
`ProductName` VARCHAR(64),
`SupplierId` INT,
`UnitPrice` DECIMAL(10,2),
`Package` VARCHAR(64),
`IsDiscontinued` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
CREATE TABLE `Supplier` (
`Id` INT,
`CompanyName` VARCHAR(64),
`ContactName` VARCHAR(64),
`ContactTitle` VARCHAR(64),
`City` VARCHAR(64),
`Country` VARCHAR(64),
`Phone` VARCHAR(64),
`Fax` VARCHAR(64),
PRIMARY KEY (`Id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_369346_sample_model_pgsql') AS relationships;
relationships
Database: db_369346_sample_model_pgsql

Table Connections:
------------------
[Implied]  OrderItem.ProductId -> Product.Id
[Implied]  Product.SupplierId -> Supplier.Id

DROP DATABASE `db_369346_sample_model_pgsql`;
UNINSTALL EXTENSION vsql_schematron;
