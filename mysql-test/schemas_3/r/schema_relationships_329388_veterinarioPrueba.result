CREATE DATABASE `db_329388_veterinarioPrueba`;
USE `db_329388_veterinarioPrueba`;
CREATE TABLE `t_USUARIOS` (
`DNI` VARCHAR(64),
`password` VARCHAR(64),
`Nombre` VARCHAR(64),
`Apellidos` VARCHAR(64),
`Sexo` VARCHAR(64),
`Edad` INT,
`email` VARCHAR(64),
`mascota` VARCHAR(64),
PRIMARY KEY (`DNI`)
) CHARACTER SET latin1;
CREATE TABLE `t_VETERINARIOS` (
`DNI` VARCHAR(64),
`Nombre` VARCHAR(64),
`Apellidos` VARCHAR(64),
`email` VARCHAR(64),
`Movil` VARCHAR(64),
`Campo` VARCHAR(64),
PRIMARY KEY (`DNI`)
) CHARACTER SET latin1;
CREATE TABLE `t_MASCOTAS` (
`Chip` VARCHAR(64),
`Nombre` VARCHAR(64),
`Raza` VARCHAR(64),
`Edad` INT,
`Genero` VARCHAR(64),
`VeterinarioPersonal` VARCHAR(64),
PRIMARY KEY (`Chip`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_329388_veterinarioPrueba') AS relationships;
