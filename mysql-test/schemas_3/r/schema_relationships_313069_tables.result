INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 313069_tables
#
CREATE DATABASE `db_313069_tables`;
USE `db_313069_tables`;
CREATE TABLE `book_genre` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `book` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`author` VARCHAR(50),
`page_count` INT,
`book_genre` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `member` (
`id` INT NOT NULL,
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`email` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `borrowed_books` (
`id` INT NOT NULL,
`book_id` INT,
`member_id` INT,
`withdraw_date` DATETIME,
`due_date` DATETIME,
`is_overdue` TINYINT,
`is_returned` TINYINT,
`returned_date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_313069_tables') AS relationships;
relationships
Database: db_313069_tables

Table Connections:
------------------
[Implied]  book.book_genre -> book_genre.id
[Implied]  borrowed_books.book_id -> book.id
[Implied]  borrowed_books.member_id -> member.id

DROP DATABASE `db_313069_tables`;
UNINSTALL EXTENSION vsql_schematron;
