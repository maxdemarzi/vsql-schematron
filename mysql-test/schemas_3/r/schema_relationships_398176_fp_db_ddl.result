INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 398176_fp_db.ddl
#
CREATE DATABASE `db_398176_fp_db_ddl`;
USE `db_398176_fp_db_ddl`;
CREATE TABLE `user` (
`id` BIGINT NOT NULL,
`user_reference` VARCHAR(50),
`email` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
`username` VARCHAR(50),
`enabled` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallet_account` (
`id` BIGINT NOT NULL,
`user_id` BIGINT,
`created_at` DATETIME,
`enabled` BOOLEAN,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `wallet_credit_transaction` (
`id` BIGINT NOT NULL,
`transaction_reference` VARCHAR(50),
`wallet_account_id` BIGINT,
`amount` BIGINT,
`currency` VARCHAR(50),
`transaction_type` VARCHAR(50),
`method` VARCHAR(50),
`account_type` VARCHAR(50),
`description` VARCHAR(50),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_398176_fp_db_ddl') AS relationships;
relationships
