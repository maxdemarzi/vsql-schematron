INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 324116_photo_gallery.postgres
#
CREATE DATABASE `db_324116_photo_gallery_postgres`;
USE `db_324116_photo_gallery_postgres`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`email` TEXT,
`password_digest` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `albums` (
`id` INT NOT NULL,
`user_id` INT,
`name` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `photos` (
`id` INT NOT NULL,
`album_id` INT,
`filename` TEXT,
`created_at` TIMESTAMP NULL,
`updated_at` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_324116_photo_gallery_postgres') AS relationships;
relationships
