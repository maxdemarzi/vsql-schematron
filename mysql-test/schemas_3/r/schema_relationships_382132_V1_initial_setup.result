`edited` DATETIME,
`editor_uuid` VARCHAR(64),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `group` (
`uuid` VARCHAR(64),
`name` VARCHAR(64),
`meta` VARCHAR(64),
`created` DATETIME,
`creator_uuid` VARCHAR(64),
`edited` DATETIME,
`editor_uuid` VARCHAR(64),
PRIMARY KEY (`uuid`)
) CHARACTER SET latin1;
CREATE TABLE `user_group` (
`user_uuid` VARCHAR(64),
`group_uuid` VARCHAR(64),
PRIMARY KEY (`user_uuid`, `group_uuid`)
) CHARACTER SET latin1;
