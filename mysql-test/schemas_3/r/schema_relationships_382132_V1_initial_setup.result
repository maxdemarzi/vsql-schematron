`username` VARCHAR(64),
`firstname` VARCHAR(64),
`lastname` VARCHAR(64),
`passwordhash` VARCHAR(64),
`email` VARCHAR(64),
`enabled` BOOL,
`meta` VARCHAR(64),
`created` DATETIME,
