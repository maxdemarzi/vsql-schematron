INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 311975_price_inspector
#
CREATE DATABASE `db_311975_price_inspector`;
USE `db_311975_price_inspector`;
CREATE TABLE `backtests` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`company_id` VARCHAR(50),
`user_id` VARCHAR(50),
`strategy_id` VARCHAR(50),
`name` VARCHAR(50),
`number_oper` INT,
`initial_balance` DOUBLE,
`final_balance` DOUBLE,
`efectivity` DOUBLE,
`rentability` DOUBLE,
`param_0` DOUBLE,
`param_1` DOUBLE,
`param_2` DOUBLE,
`param_3` DOUBLE,
`param_4` DOUBLE,
`param_5` DOUBLE,
`param_6` DOUBLE,
`param_7` DOUBLE,
`param_8` DOUBLE,
`param_9` DOUBLE,
`initial_date` DATE,
`final_date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `strategies` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`id` VARCHAR(50) NOT NULL,
`created_at` DATETIME,
`updated_at` DATETIME,
`email` VARCHAR(50),
`password` VARCHAR(50),
`first_name` VARCHAR(50),
`last_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_311975_price_inspector') AS relationships;
