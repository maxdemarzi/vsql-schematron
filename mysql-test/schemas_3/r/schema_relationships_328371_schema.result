[Implied]  genome_variant_link.variant_id -> variant.variant_id
[Implied]  page.domain_id -> domain.domain_id
[Implied]  pageview.genome_id -> genome.genome_id
[Implied]  pageview.page_id -> page.page_id
[Implied]  pageview.referrer_id -> referrer.referrer_id
[Implied]  pageview.visitor_id -> visitor.visitor_id
[Implied]  stats_by_genome.genome_id -> genome.genome_id
[Implied]  stats_by_variant.variant_id -> variant.variant_id
[Implied]  variant.gene_id -> gene.gene_id

DROP DATABASE `db_328371_schema`;
UNINSTALL EXTENSION vsql_schematron;
