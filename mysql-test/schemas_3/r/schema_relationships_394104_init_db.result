INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 394104_init_db
#
CREATE DATABASE `db_394104_init_db`;
USE `db_394104_init_db`;
CREATE TABLE `products` (
`product_id` INT,
`name` VARCHAR(255),
`price` DECIMAL(10,2),
`category_id` INT,
PRIMARY KEY (`product_id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`category_id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`category_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`order_id` INT,
`user_id` INT,
`createdAt` DATETIME,
`status_id` INT,
PRIMARY KEY (`order_id`)
) CHARACTER SET latin1;
CREATE TABLE `status` (
`status_id` INT,
`name` VARCHAR(255),
PRIMARY KEY (`status_id`)
) CHARACTER SET latin1;
CREATE TABLE `order_products` (
`order_id` INT,
`product_id` INT
) CHARACTER SET latin1;
CREATE TABLE `users` (
`user_id` INT,
`login` VARCHAR(255),
`password` VARCHAR(255),
PRIMARY KEY (`user_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_394104_init_db') AS relationships;
relationships
Database: db_394104_init_db

