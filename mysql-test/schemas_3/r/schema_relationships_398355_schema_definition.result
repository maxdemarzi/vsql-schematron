CREATE DATABASE `db_398355_schema_definition`;
USE `db_398355_schema_definition`;
CREATE TABLE `customer` (
`customer_id` INT,
`name` VARCHAR(64),
`deadline` DATETIME,
`scheme` VARCHAR(64),
`status` VARCHAR(64),
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
CREATE TABLE `fine` (
`customer_id` INT,
`payment_date` DATETIME,
`amount` INT,
PRIMARY KEY (`customer_id`)
) CHARACTER SET latin1;
