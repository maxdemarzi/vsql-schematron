INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 303972_up
#
CREATE DATABASE `db_303972_up`;
USE `db_303972_up`;
CREATE TABLE `accounts` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`account_type` INT,
`initial_balance` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `transactions` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`source_account_id` INT,
`destination_account_id` INT,
`amount` BIGINT,
`date` DATE,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_303972_up') AS relationships;
