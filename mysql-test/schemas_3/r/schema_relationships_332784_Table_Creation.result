CREATE DATABASE `db_332784_Table_Creation`;
USE `db_332784_Table_Creation`;
CREATE TABLE `titles` (
`emp_title_id` VARCHAR(64),
`title` VARCHAR(64),
PRIMARY KEY (`emp_title_id`)
) CHARACTER SET latin1;
CREATE TABLE `department` (
`dept_no` VARCHAR(64),
`dept_name` VARCHAR(64),
PRIMARY KEY (`dept_no`)
) CHARACTER SET latin1;
CREATE TABLE `employees` (
`emp_no` INT,
`emp_title_id` VARCHAR(64),
`birth_date` DATETIME,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`sex` VARCHAR(64),
`hire_date` DATETIME,
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `salaries` (
`emp_no` INT,
`salary` VARCHAR(64),
PRIMARY KEY (`emp_no`)
) CHARACTER SET latin1;
CREATE TABLE `dept_emp` (
`emp_no` INT,
`dept_no` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `dept_manager` (
`dept_no` VARCHAR(64),
`emp_no` INT
) CHARACTER SET latin1;
