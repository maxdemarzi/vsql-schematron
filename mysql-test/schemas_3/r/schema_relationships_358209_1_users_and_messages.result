CREATE DATABASE `db_358209_1_users_and_messages`;
USE `db_358209_1_users_and_messages`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`name` VARCHAR(50),
`email` VARCHAR(50),
`passwordHash` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `messages` (
`id` INT NOT NULL,
`userId` INT,
`text` VARCHAR(50),
`date` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_358209_1_users_and_messages') AS relationships;
