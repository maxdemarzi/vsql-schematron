INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 324169_Musicdb_DDL
#
CREATE DATABASE `db_324169_Musicdb_DDL`;
USE `db_324169_Musicdb_DDL`;
CREATE TABLE `MUSIC_ALBUMS` (
`ALBUM_ID` INT,
`ALBUM_TITLE` VARCHAR(64),
`ALBUM_YEAR` INT,
`COMMENTS` VARCHAR(64),
PRIMARY KEY (`ALBUM_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSIC_ARTISTS` (
`AUTHOR_ID` INT,
`NAME` VARCHAR(64),
`NAME_2` VARCHAR(64),
`SURNAME` VARCHAR(64),
`BIRTH_YEAR` INT,
`DEATH_YEAR` INT,
`COMMENTS` VARCHAR(64),
`RATINGS` DECIMAL(10,2),
PRIMARY KEY (`AUTHOR_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSIC_AUTHORS` (
`AUTHOR_ID` INT,
`SONG_ID` INT,
PRIMARY KEY (`AUTHOR_ID`, `SONG_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSIC_FILES` (
`MUSIC_FILE_ID` INT,
`FILE_NAME` VARCHAR(64),
`FILE_SIZE` INT,
`EXTENSION` VARCHAR(64),
`CREATION_DATE` DATETIME,
`IS_PUBLIC` VARCHAR(64),
`FILE` VARCHAR(64),
PRIMARY KEY (`MUSIC_FILE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSIC_GENRES` (
`MUSIC_GENRE_ID` INT,
`NAME` VARCHAR(64),
`COMMENTS` VARCHAR(64),
PRIMARY KEY (`MUSIC_GENRE_ID`)
) CHARACTER SET latin1;
CREATE TABLE `MUSIC_PLAYLISTS` (
`PLAYLIST_ID` INT,
`USER_ID` INT,
`TITLE` VARCHAR(64),
`CREATION_DATE` DATETIME,
PRIMARY KEY (`PLAYLIST_ID`)
) CHARACTER SET latin1;
CREATE TABLE `PLAYLISTS_SONGS` (
`PLAYLIST_ID` INT,
`SONG_ID` INT,
`ORDER_NUMBER` INT,
PRIMARY KEY (`PLAYLIST_ID`, `SONG_ID`)
) CHARACTER SET latin1;
CREATE TABLE `SONGS` (
`SONG_ID` INT,
`TITLE` VARCHAR(64),
`FILE_ID` INT,
`RATING_TIMES` INT,
`ALBUM_ID` INT,
`MUSIC_GENRE_ID` INT,
`RATING` DECIMAL(10,2),
`PRODUCTION_YEAR` INT,
`OWNER_ID` INT,
PRIMARY KEY (`SONG_ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_324169_Musicdb_DDL') AS relationships;
