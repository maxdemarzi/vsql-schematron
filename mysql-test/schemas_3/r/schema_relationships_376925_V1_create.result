CREATE DATABASE `db_376925_V1_create`;
USE `db_376925_V1_create`;
CREATE TABLE `users` (
`id` INT,
`username` VARCHAR(64),
`password` VARCHAR(64),
`email` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `roles` (
`id` INT,
`name` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `users_roles` (
`user_id` INT,
`role_id` INT,
PRIMARY KEY (`user_id`, `role_id`)
) CHARACTER SET latin1;
CREATE TABLE `products` (
`id` INT,
`title` VARCHAR(64),
`price` DECIMAL(10,2),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `categories` (
`id` INT,
`title` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `products_categories` (
`product_id` INT,
`category_id` INT,
PRIMARY KEY (`product_id`, `category_id`)
) CHARACTER SET latin1;
CREATE TABLE `orders` (
`id` INT,
`owner_id` INT,
`total_price` DECIMAL(10,2),
`address` VARCHAR(64),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `orders_items` (
`id` INT,
`order_id` INT,
`product_id` INT,
`title` VARCHAR(64),
`quantity` INT,
`price_per_product` DECIMAL(10,2),
`created_at` DATETIME,
`updated_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
