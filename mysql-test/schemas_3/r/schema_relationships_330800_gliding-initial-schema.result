INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 330800_gliding-initial-schema
#
CREATE DATABASE `db_330800_gliding_initial_schema`;
USE `db_330800_gliding_initial_schema`;
CREATE TABLE `address` (
`id` INT NOT NULL,
`type` INT NOT NULL,
`addr1` VARCHAR(50),
`addr2` VARCHAR(50),
`addr3` VARCHAR(50),
`addr4` VARCHAR(50),
`city` VARCHAR(50),
`postcode` VARCHAR(50),
`country` VARCHAR(50),
PRIMARY KEY (`id`, `type`)
) CHARACTER SET latin1;
CREATE TABLE `address_type` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `diag` (
`id` INT NOT NULL,
`create_time` TIMESTAMP NULL,
`data` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_member` (
`gm_group_id` INT,
`gm_member_id` INT
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_330800_gliding_initial_schema') AS relationships;
