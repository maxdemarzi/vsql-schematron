INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 369177_database
#
CREATE DATABASE `db_369177_database`;
USE `db_369177_database`;
CREATE TABLE `usuario` (
`id_usuario` INT NOT NULL,
`senha` VARCHAR(50),
PRIMARY KEY (`id_usuario`)
) CHARACTER SET latin1;
CREATE TABLE `bueiro` (
`id_bueiro` INT NOT NULL,
`id_usuario` INT,
`nome` VARCHAR(50),
`latitude` DECIMAL(10,2),
`longitude` DECIMAL(10,2),
PRIMARY KEY (`id_bueiro`)
) CHARACTER SET latin1;
CREATE TABLE `sinais` (
`sin_id` INT NOT NULL,
`id_bueiro` INT,
`sin_dist` VARCHAR(50),
`sin_data` DATETIME,
PRIMARY KEY (`sin_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_369177_database') AS relationships;
relationships
Database: db_369177_database

Table Connections:
