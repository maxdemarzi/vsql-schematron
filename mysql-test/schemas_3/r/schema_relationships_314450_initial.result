INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 314450_initial
#
CREATE DATABASE `db_314450_initial`;
USE `db_314450_initial`;
CREATE TABLE `Activities` (
`id` INT,
`type` VARCHAR(64),
`data` VARCHAR(64),
`createdAt` DATETIME,
`CollectiveId` INT,
`UserId` INT,
`TransactionId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `ApplicationCollective` (
`createdAt` DATETIME,
`updatedAt` DATETIME,
`CollectiveId` INT,
`ApplicationId` INT,
PRIMARY KEY (`CollectiveId`, `ApplicationId`)
) CHARACTER SET latin1;
CREATE TABLE `Applications` (
`id` INT,
`api_key` VARCHAR(64),
`name` VARCHAR(64),
`href` VARCHAR(64),
`description` VARCHAR(64),
`disabled` VARCHAR(64),
`_access` DECIMAL(10,2),
`createdAt` DATETIME,
`updatedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Cards` (
`id` INT,
`number` VARCHAR(64),
`token` VARCHAR(64),
`serviceId` VARCHAR(64),
`service` VARCHAR(64),
`data` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`confirmedAt` DATETIME,
`deletedAt` DATETIME,
`UserId` INT,
`CollectiveId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Collectives` (
`id` INT,
`name` VARCHAR(64),
`description` VARCHAR(64),
`budget` DECIMAL(10,2),
`currency` VARCHAR(64),
`membership_type` VARCHAR(64),
`membershipfee` DECIMAL(10,2),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
`StripeManagedAccountId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Paykeys` (
`id` INT,
`trackingId` VARCHAR(64),
`paykey` VARCHAR(64),
`status` VARCHAR(64),
`payload` VARCHAR(64),
`data` VARCHAR(64),
`error` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
`TransactionId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `StripeManagedAccounts` (
`id` INT,
`stripeId` VARCHAR(64),
`stripeSecret` VARCHAR(64),
`stripeKey` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Transactions` (
`id` INT,
`type` VARCHAR(64),
`description` VARCHAR(64),
`amount` DECIMAL(10,2),
`currency` VARCHAR(64),
`vendor` VARCHAR(64),
`paidby` VARCHAR(64),
`tags` VARCHAR(64),
`status` VARCHAR(64),
`comment` VARCHAR(64),
`link` VARCHAR(64),
`approved` VARCHAR(64),
`createdAt` DATETIME,
`approvedAt` DATETIME,
`reimbursedAt` DATETIME,
`updatedAt` DATETIME,
`CollectiveId` INT,
`UserId` INT,
`CardId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Roles` (
`role` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`deletedAt` DATETIME,
`UserId` INT,
`CollectiveId` INT,
PRIMARY KEY (`UserId`, `CollectiveId`)
) CHARACTER SET latin1;
CREATE TABLE `Users` (
`id` INT,
`_access` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`username` VARCHAR(64),
`image` VARCHAR(64),
`email` VARCHAR(64),
`_salt` VARCHAR(64),
`refresh_token` VARCHAR(64),
`password_hash` VARCHAR(64),
`createdAt` DATETIME,
`updatedAt` DATETIME,
`seenAt` DATETIME,
`deletedAt` DATETIME,
`ApplicationId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_314450_initial') AS relationships;
relationships
