INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 305611_bolg
#
CREATE DATABASE `db_305611_bolg`;
USE `db_305611_bolg`;
CREATE TABLE `users` (
`id` INT NOT NULL,
`user_name` VARCHAR(50),
`passwd` VARCHAR(50),
`role_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `auth_roles` (
`id` INT NOT NULL,
`role_name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `blogs` (
`id` INT NOT NULL,
`title` VARCHAR(50),
`content` TEXT,
`create_time` DATE,
`comment_count` INT,
`upvote_count` INT,
`watch_count` INT,
`lable` VARCHAR(50),
`recommend` INT,
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `comments` (
`id` INT NOT NULL,
`content` VARCHAR(50),
`user_id` INT,
`blog_id` INT,
`create_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_305611_bolg') AS relationships;
relationships
Database: db_305611_bolg

Table Connections:
