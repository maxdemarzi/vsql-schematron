INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 308395_students
#
CREATE DATABASE `db_308395_students`;
USE `db_308395_students`;
CREATE TABLE `Modules` (
`code` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`code`)
) CHARACTER SET latin1;
CREATE TABLE `Programmes` (
`id` VARCHAR(50) NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Programme_Modules` (
`programme` VARCHAR(50),
`module` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Students` (
`id` INT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Student_Programme` (
`id` INT,
`programme` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_308395_students') AS relationships;
relationships
Database: db_308395_students

Table Connections:
------------------
[Implied]  Programme_Modules.module -> Modules.code
[Implied]  Programme_Modules.programme -> Programmes.id
[Implied]  Student_Programme.id -> Students.id
[Implied]  Student_Programme.programme -> Programmes.id

DROP DATABASE `db_308395_students`;
UNINSTALL EXTENSION vsql_schematron;
