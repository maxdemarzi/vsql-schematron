CREATE DATABASE `db_348491_schema_mysql`;
USE `db_348491_schema_mysql`;
CREATE TABLE `lucky_moneys` (
`id` INT,
`user_id` VARCHAR(64),
`system_wallet_id` INT,
`session_chat_id` VARCHAR(64),
`amount` INT,
`rest_money` INT,
`number_bag` INT,
`rest_bag` INT,
`type` VARCHAR(64),
`wish_message` VARCHAR(64),
`created_at` DATETIME,
`expired_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `received_lucky_moneys` (
`id` INT,
`lucky_money_id` INT,
`receiver_id` VARCHAR(64),
`amount` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
