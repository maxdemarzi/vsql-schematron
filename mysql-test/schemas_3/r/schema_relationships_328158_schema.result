INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 328158_schema
#
CREATE DATABASE `db_328158_schema`;
USE `db_328158_schema`;
CREATE TABLE `Matches` (
`id` VARCHAR(50) NOT NULL,
`player_id` TEXT,
`map` TEXT,
`mode` TEXT,
`date` DATETIME,
`duration_seconds` DECIMAL(10,2),
`rounds_won` DECIMAL(10,2),
`rounds_lost` DECIMAL(10,2),
`kills` DECIMAL(10,2),
`killshs` DECIMAL(10,2),
`deaths` DECIMAL(10,2),
`assists` DECIMAL(10,2),
`score` DECIMAL(10,2),
`mvps` DECIMAL(10,2),
`over` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Rounds` (
`id` VARCHAR(50) NOT NULL,
`match_id` TEXT,
`n_round` DECIMAL(10,2),
`team` TEXT,
`equip_value` DECIMAL(10,2),
`init_money` DECIMAL(10,2),
`init_armor` DECIMAL(10,2),
`helmet` DECIMAL(10,2),
`duration_seconds` DECIMAL(10,2),
`winner` TEXT,
`win_type` TEXT,
`died` DECIMAL(10,2),
`kills` DECIMAL(10,2),
`killshs` DECIMAL(10,2),
`assists` DECIMAL(10,2),
`score` DECIMAL(10,2),
`mvp` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_328158_schema') AS relationships;
relationships
