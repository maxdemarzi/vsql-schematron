CREATE DATABASE `db_340107_1495013854`;
USE `db_340107_1495013854`;
CREATE TABLE `action` (
`id` INT,
`strategy_id` INT,
`type` INT,
`file_path` VARCHAR(64),
`alarm_subject` VARCHAR(64),
`restore_subject` VARCHAR(64),
`alarm_template` VARCHAR(64),
`restore_template` VARCHAR(64),
`send_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action_result` (
`strategy_event_id` INT,
`action_id` INT,
`action_type` INT,
`action_send_type` INT,
`user_id` INT,
`username` VARCHAR(64),
`phone` VARCHAR(64),
`mail` VARCHAR(64),
`weixin` VARCHAR(64),
`subject` VARCHAR(64),
`content` VARCHAR(64),
`success` INT,
`response` VARCHAR(64),
`file_path` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `chart_element` (
`id` INT,
`chart_id` INT,
`name` VARCHAR(64),
`metric` VARCHAR(64),
`tags` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_plugin` (
`id` INT,
`group_id` INT,
`plugin_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
`id` INT,
`operation_time` DATETIME,
`ip` VARCHAR(64),
`operator` VARCHAR(64),
`content` VARCHAR(64),
`operation_result` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `strategy_event` (
`id` INT,
`strategy_id` INT,
`strategy_name` VARCHAR(64),
`priority` INT,
`cycle` INT,
`alarm_count` INT,
`expression` VARCHAR(64),
`create_time` DATETIME,
`update_time` DATETIME,
`count` INT,
`status` INT,
`host_id` VARCHAR(64),
`host_cname` VARCHAR(64),
`host_name` VARCHAR(64),
`ip` VARCHAR(64),
`sn` VARCHAR(64),
`process_user` VARCHAR(64),
`process_comments` VARCHAR(64),
`process_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
