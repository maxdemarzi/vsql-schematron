CREATE DATABASE `db_340107_1495013854`;
USE `db_340107_1495013854`;
CREATE TABLE `action` (
`id` INT,
`strategy_id` INT,
`type` INT,
`file_path` VARCHAR(255),
`alarm_subject` VARCHAR(255),
`restore_subject` VARCHAR(255),
`alarm_template` VARCHAR(255),
`restore_template` VARCHAR(255),
`send_type` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `action_result` (
`strategy_event_id` INT,
`action_id` INT,
`action_type` INT,
`action_send_type` INT,
`user_id` INT,
`username` VARCHAR(255),
`phone` VARCHAR(255),
`mail` VARCHAR(255),
`weixin` VARCHAR(255),
`subject` VARCHAR(255),
`content` VARCHAR(255),
`success` INT,
`response` VARCHAR(255),
`file_path` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `chart_element` (
`id` INT,
`chart_id` INT,
`name` VARCHAR(255),
`metric` VARCHAR(255),
`tags` VARCHAR(255),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `group_plugin` (
`id` INT,
`group_id` INT,
`plugin_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `operations` (
`id` INT,
`operation_time` DATETIME,
`ip` VARCHAR(255),
`operator` VARCHAR(255),
`content` VARCHAR(255),
`operation_result` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `strategy_event` (
`id` INT,
`strategy_id` INT,
`strategy_name` VARCHAR(255),
`priority` INT,
`cycle` INT,
`alarm_count` INT,
`expression` VARCHAR(255),
`create_time` DATETIME,
`update_time` DATETIME,
`count` INT,
`status` INT,
`host_id` VARCHAR(255),
`host_cname` VARCHAR(255),
`host_name` VARCHAR(255),
`ip` VARCHAR(255),
`sn` VARCHAR(255),
`process_user` VARCHAR(255),
`process_comments` VARCHAR(255),
`process_time` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
