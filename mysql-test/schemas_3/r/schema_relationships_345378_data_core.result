INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 345378_data_core
#
CREATE DATABASE `db_345378_data_core`;
USE `db_345378_data_core`;
CREATE TABLE `PAPERS` (
`ID` VARCHAR(50) NOT NULL,
`DOI` VARCHAR(50),
`TITLE` VARCHAR(50),
`ABSTRACT` VARCHAR(50),
`PUBLISHED_YEAR` INT,
`JOURNAL` VARCHAR(50),
`VOLUME` INT,
`ISSUE` INT,
`PAGES` VARCHAR(50),
`COVIDENCE` INT,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `PAPER_KEYWORDS` (
`KEYWORD` VARCHAR(50),
`PAPER_ID` VARCHAR(50),
`WEIGHT` INT
) CHARACTER SET latin1;
CREATE TABLE `AUTHORS` (
`AUTHOR` VARCHAR(50),
`PAPER_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `SECTORS` (
`SECTOR` VARCHAR(50),
`PAPER_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `COUNTRY` (
`COUNTRY_NAME` VARCHAR(50),
`PAPER_ID` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `THEME` (
`PRIMARY_THEME` VARCHAR(50),
`SECONDARY_THEME` VARCHAR(50),
`PAPER_ID` VARCHAR(50)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_345378_data_core') AS relationships;
relationships
