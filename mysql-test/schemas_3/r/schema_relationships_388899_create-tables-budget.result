CREATE DATABASE `db_388899_create_tables_budget`;
USE `db_388899_create_tables_budget`;
CREATE TABLE `entries` (
`id` INT NOT NULL,
`summary` VARCHAR(50),
`timeAdded` TIMESTAMP NULL,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `rules` (
`id` INT NOT NULL,
`ruleType` VARCHAR(50),
`amountModifier` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `conditions` (
`id` INT NOT NULL,
`sourceRule` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `funds` (
`id` INT NOT NULL,
`fundName` VARCHAR(50),
`ruleSet` INT,
`startEntry` INT,
`endEntry` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
