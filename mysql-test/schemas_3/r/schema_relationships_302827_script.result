INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 302827_script
#
CREATE DATABASE `db_302827_script`;
USE `db_302827_script`;
CREATE TABLE `categorias` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `personal` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`apellidos` VARCHAR(50),
`telefono` CHAR(50),
`direccion` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `tickets` (
`id` INT NOT NULL,
`nombre` VARCHAR(50),
`descripcion` VARCHAR(50),
`prioridad` CHAR(50),
`persona_id` INT,
`categoria_id` INT,
`estatus` CHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_302827_script') AS relationships;
relationships
Database: db_302827_script

