INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 374045_tables
#
CREATE DATABASE `db_374045_tables`;
USE `db_374045_tables`;
CREATE TABLE `app_user` (
`id` INT,
`email` VARCHAR(64),
`username` VARCHAR(64),
`password` VARCHAR(64),
`household` VARCHAR(64),
`is_parent` BOOL,
`balance` DECIMAL(10,2),
`active_goal` INT,
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `household` (
`name` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`name`)
) CHARACTER SET latin1;
CREATE TABLE `chore` (
`id` INT,
`created_by` INT,
`assigned_to` INT,
`household` VARCHAR(64),
`description` VARCHAR(64),
`created_at` DATETIME,
`completed_on` DATETIME,
`verified_on` DATETIME,
`reward` DECIMAL(10,2),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `goal` (
`id` INT,
`belongs_to` INT,
`description` VARCHAR(64),
`dollar_value` DECIMAL(10,2),
`image` VARCHAR(64),
`created_at` DATETIME,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `session` (
`ssid` VARCHAR(64),
`created_at` DATETIME,
`valid_until` DATETIME,
PRIMARY KEY (`ssid`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_374045_tables') AS relationships;
