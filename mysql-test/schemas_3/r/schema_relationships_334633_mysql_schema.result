[Implied]  ingredient.idcategory -> category.id
[Implied]  orderposition.idorder -> orders.id
[Implied]  orderposition.idpizza -> pizza.id
[Implied]  orders.iduser -> users.id
[Implied]  pizzaingredient.idingredient -> ingredient.id
[Implied]  pizzaingredient.idpizza -> pizza.id

DROP DATABASE `db_334633_mysql_schema`;
UNINSTALL EXTENSION vsql_schematron;
