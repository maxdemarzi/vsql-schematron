INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 356916_investigating_company
#
CREATE DATABASE `db_356916_investigating_company`;
USE `db_356916_investigating_company`;
CREATE TABLE `address` (
`address_id` INT,
`person_id` INT,
`description` VARCHAR(64),
`street` VARCHAR(64),
`city` VARCHAR(64),
`province` VARCHAR(64),
`postal_code` VARCHAR(64),
`country_code` VARCHAR(64)
) CHARACTER SET latin1;
CREATE TABLE `country` (
`country_code` VARCHAR(64),
`country_name` VARCHAR(64),
PRIMARY KEY (`country_code`)
) CHARACTER SET latin1;
CREATE TABLE `person` (
`person_id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`notes` VARCHAR(64),
PRIMARY KEY (`person_id`)
) CHARACTER SET latin1;
CREATE TABLE `picture` (
`picture_id` INT,
`person_id` INT,
`description` VARCHAR(64)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_356916_investigating_company') AS relationships;
relationships
Database: db_356916_investigating_company

Table Connections:
------------------
[Implied]  address.country_code -> country.country_code
[Implied]  address.person_id -> person.person_id
