INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 325070_mysql-seed
#
CREATE DATABASE `db_325070_mysql_seed`;
USE `db_325070_mysql_seed`;
CREATE TABLE `person` (
`id` VARCHAR(50) NOT NULL,
`tripId` VARCHAR(50),
`firstname` VARCHAR(50),
`lastname` VARCHAR(50),
`phone` VARCHAR(50),
`IDNumber` INT,
`email` VARCHAR(50),
`willTravel` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `trip` (
`id` VARCHAR(50) NOT NULL,
`departureDate` DATETIME,
`estimatedArrivalDate` DATETIME,
`agencyId` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_325070_mysql_seed') AS relationships;
