INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 331804_schema
#
CREATE DATABASE `db_331804_schema`;
USE `db_331804_schema`;
CREATE TABLE `department` (
`id` INT,
`department_name` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `role` (
`id` INT,
`title` VARCHAR(64),
`salary` DECIMAL(10,2),
`department_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `employee` (
`id` INT,
`first_name` VARCHAR(64),
`last_name` VARCHAR(64),
`role_id` INT,
`manager_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_331804_schema') AS relationships;
relationships
Database: db_331804_schema

Table Connections:
------------------
[Implied]  employee.manager_id -> employee.id
[Implied]  employee.role_id -> role.id
[Implied]  role.department_id -> department.id

DROP DATABASE `db_331804_schema`;
UNINSTALL EXTENSION vsql_schematron;
