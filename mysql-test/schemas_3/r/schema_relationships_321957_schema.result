CREATE DATABASE `db_321957_schema`;
USE `db_321957_schema`;
CREATE TABLE `MAIL2S` (
`ID` INT,
`SENDER` VARCHAR(64),
`DATA` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MAIL2_RECEIVERS` (
`ID` INT,
`MAIL2_ID` INT,
`RECEIVER` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `MAIL2_TOKENS` (
`ID` INT,
`ADDRESS` VARCHAR(64),
`TOKEN` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_321957_schema') AS relationships;
