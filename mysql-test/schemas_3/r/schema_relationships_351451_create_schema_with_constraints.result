`lo_quantity` INT,
`lo_extendedprice` INT,
`lo_ordtotalprice` INT,
`lo_discount` INT,
`lo_revenue` INT,
`lo_supplycost` INT,
`lo_tax` INT,
`lo_commitdate` INT,
`lo_shipmode` VARCHAR(64),
PRIMARY KEY (`lo_orderkey`, `lo_linenumber`)
) CHARACTER SET latin1;
