INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 337197_oracle_create_strict
#
CREATE DATABASE `db_337197_oracle_create_strict`;
USE `db_337197_oracle_create_strict`;
CREATE TABLE `cpa` (
`cpa_id` VARCHAR(255),
`cpa` VARCHAR(255),
PRIMARY KEY (`cpa_id`)
) CHARACTER SET latin1;
CREATE TABLE `url_mapping` (
`source` VARCHAR(255),
`destination` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `certificate_mapping` (
`id` VARCHAR(255),
`source` VARCHAR(255),
`destination` VARCHAR(255),
`cpa_id` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `ebms_message` (
`time_stamp` DATETIME,
`cpa_id` VARCHAR(255),
`conversation_id` VARCHAR(255),
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`ref_to_message_id` VARCHAR(255),
`time_to_live` DATETIME,
`persist_time` DATETIME,
`from_party_id` VARCHAR(255),
`from_role` VARCHAR(255),
`to_party_id` VARCHAR(255),
`to_role` VARCHAR(255),
`service` VARCHAR(255),
`action` VARCHAR(255),
`content` VARCHAR(255),
`status` DECIMAL(10,2),
`status_time` DATETIME,
PRIMARY KEY (`message_id`, `message_nr`)
) CHARACTER SET latin1;
CREATE TABLE `ebms_attachment` (
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`order_nr` DECIMAL(10,2),
`name` VARCHAR(255),
`content_id` VARCHAR(255),
`content_type` VARCHAR(255),
`content` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `delivery_task` (
`cpa_id` VARCHAR(255),
`send_channel_id` VARCHAR(255),
`receive_channel_id` VARCHAR(255),
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`time_to_live` DATETIME,
`time_stamp` DATETIME,
`is_confidential` DECIMAL(10,2),
`retries` DECIMAL(10,2),
`server_id` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `delivery_log` (
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`time_stamp` DATETIME,
`uri` VARCHAR(255),
`status` DECIMAL(10,2),
`error_message` VARCHAR(255)
) CHARACTER SET latin1;
CREATE TABLE `message_event` (
`message_id` VARCHAR(255),
`message_nr` DECIMAL(10,2),
`event_type` DECIMAL(10,2),
`time_stamp` DATETIME,
`processed` DECIMAL(10,2),
PRIMARY KEY (`message_id`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_337197_oracle_create_strict') AS relationships;
relationships
