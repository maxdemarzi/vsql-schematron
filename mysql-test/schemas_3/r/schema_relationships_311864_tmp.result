CREATE TABLE `micropubs` (
`id` INT,
`title` VARCHAR(64),
`summary` VARCHAR(64),
`timestamp` DATETIME,
`views` INT,
`author_id` INT,
`reference` VARCHAR(64),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
