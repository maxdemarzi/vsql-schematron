CREATE DATABASE `db_339462_1_MySQLCreateTables`;
USE `db_339462_1_MySQLCreateTables`;
CREATE TABLE `User` (
`id` BIGINT NOT NULL,
`userName` VARCHAR(50),
`password` VARCHAR(50),
`firstName` VARCHAR(50),
`lastName` VARCHAR(50),
`email` VARCHAR(50),
`role` TINYINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Province` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTestType` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `SportTest` (
`id` BIGINT NOT NULL,
`name` VARCHAR(50),
`description` VARCHAR(50),
`testStart` DATETIME,
`price` DECIMAL(10,2),
`maxParticipants` SMALLINT,
`location` VARCHAR(50),
`provinceId` BIGINT,
`sportTestTypeId` BIGINT,
`participants` SMALLINT,
`timesRated` SMALLINT,
`averageRating` BIGINT,
`version` BIGINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
CREATE TABLE `Inscription` (
`id` BIGINT NOT NULL,
`creditCardNumber` VARCHAR(50),
`dorsal` SMALLINT,
`dorsalPicked` VARCHAR(50),
`sportTestId` BIGINT,
`userId` BIGINT,
`score` SMALLINT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
