`SENHA` VARCHAR(64),
`FACEBOOK` VARCHAR(64),
`SINCRONIZAR` BOOL,
`LASTLOGIN` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `USUARIO_HAS_MEIODETRANSPORTE` (
`USUARIO_ID` INT,
`MEIODETRANSPORTE_ID` INT,
PRIMARY KEY (`USUARIO_ID`, `MEIODETRANSPORTE_ID`)
