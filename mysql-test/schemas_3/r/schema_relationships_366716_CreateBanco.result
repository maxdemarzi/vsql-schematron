PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `VIAGEM` (
`EVENTO_ID` INT,
`INICIO` DATETIME,
`FIM` DATETIME,
`DISTANCIA` DECIMAL(10,2),
PRIMARY KEY (`EVENTO_ID`)
) CHARACTER SET latin1;
CREATE TABLE `GASTO` (
