CREATE TABLE `MEIODETRANSPORTE` (
`ID` INT,
`DESCRICAO` VARCHAR(64),
`TIPO` VARCHAR(64),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `EVENTO` (
`ID` INT,
`MEIODETRANSPORTE_ID` INT,
