[Implied]  votes.choice_id -> choices.id
[Implied]  votes.poll_id -> polls.id
[Implied]  votes.user_id -> user_roles.user_id

DROP DATABASE `db_362615_V1_schema`;
UNINSTALL EXTENSION vsql_schematron;
