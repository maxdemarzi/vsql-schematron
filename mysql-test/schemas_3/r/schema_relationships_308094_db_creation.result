INSTALL EXTENSION vsql_schematron;
#
# Test relationships for schema 308094_db_creation
#
CREATE DATABASE `db_308094_db_creation`;
USE `db_308094_db_creation`;
CREATE TABLE `person` (
`IDUser` INT,
`Name` VARCHAR(64),
`Surname` VARCHAR(64),
`Gender` VARCHAR(64),
`DoB` DATETIME,
`Email` VARCHAR(64),
`Passwd` VARCHAR(64),
`Phone` VARCHAR(64),
`City` VARCHAR(64),
`Description` VARCHAR(64),
PRIMARY KEY (`IDUser`)
) CHARACTER SET latin1;
CREATE TABLE `feedback` (
`TeacherID` INT,
`StudentID` INT,
`Score` INT,
`Description` VARCHAR(64),
`ReviewDate` DATETIME,
PRIMARY KEY (`TeacherID`, `StudentID`)
) CHARACTER SET latin1;
CREATE TABLE `lesson` (
`IDLesson` INT,
`TeacherID` INT,
`StudentID` INT,
`LessonDate` DATETIME,
`LessonTime` DATETIME,
`LessonDuration` DATETIME,
`LessonTariff` INT,
`Payment` DATETIME,
PRIMARY KEY (`IDLesson`)
) CHARACTER SET latin1;
CREATE TABLE `chat` (
`TeacherID` INT,
`StudentID` INT,
`Confirmed` BOOL,
`Messages` VARCHAR(64),
`LastMessage` DATETIME,
PRIMARY KEY (`TeacherID`, `StudentID`)
) CHARACTER SET latin1;
CREATE TABLE `topic` (
`IDTopic` INT,
`Label` VARCHAR(64),
PRIMARY KEY (`IDTopic`)
) CHARACTER SET latin1;
CREATE TABLE `teacher_topic` (
`TeacherID` INT,
`TopicID` INT,
`Tariff` INT,
PRIMARY KEY (`TeacherID`, `TopicID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_308094_db_creation') AS relationships;
