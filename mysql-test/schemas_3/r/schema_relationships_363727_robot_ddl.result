CREATE DATABASE `db_363727_robot_ddl`;
USE `db_363727_robot_ddl`;
CREATE TABLE `URL_QUEUE` (
`ID` BIGINT NOT NULL,
`SESSION_ID` VARCHAR(50),
`METHOD` VARCHAR(50),
`URL` TEXT,
`META_DATA` TEXT,
`ENCODING` VARCHAR(50),
`PARENT_URL` TEXT,
`DEPTH` INT,
`LAST_MODIFIED` DATETIME,
`CREATE_TIME` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACCESS_RESULT` (
`ID` BIGINT NOT NULL,
`SESSION_ID` VARCHAR(50),
`RULE_ID` VARCHAR(50),
`URL` TEXT,
`PARENT_URL` TEXT,
`STATUS` INT,
`HTTP_STATUS_CODE` INT,
`METHOD` VARCHAR(50),
`MIME_TYPE` VARCHAR(50),
`CONTENT_LENGTH` BIGINT,
`EXECUTION_TIME` INT,
`LAST_MODIFIED` DATETIME,
`CREATE_TIME` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `ACCESS_RESULT_DATA` (
`ID` BIGINT NOT NULL,
`TRANSFORMER_NAME` VARCHAR(50),
`DATA` VARCHAR(50),
`ENCODING` VARCHAR(50),
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
CREATE TABLE `URL_FILTER` (
`ID` BIGINT NOT NULL,
`SESSION_ID` VARCHAR(50),
`URL` TEXT,
`FILTER_TYPE` VARCHAR(50),
`CREATE_TIME` DATETIME,
PRIMARY KEY (`ID`)
) CHARACTER SET latin1;
SELECT vsql_schema_relationships('db_363727_robot_ddl') AS relationships;
