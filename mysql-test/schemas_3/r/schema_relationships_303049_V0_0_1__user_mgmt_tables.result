CREATE TABLE `address_info` (
`id` INT NOT NULL,
`disabled` VARCHAR(50),
`uuid` VARCHAR(50),
`created_by` VARCHAR(50),
`created_date` VARCHAR(50),
`updated_date` VARCHAR(50),
`updated_by` VARCHAR(50),
`preferred` VARCHAR(50),
`address1` VARCHAR(50),
`address2` VARCHAR(50),
`address3` VARCHAR(50),
`city` VARCHAR(50),
`country` VARCHAR(50),
`state` VARCHAR(50),
`type` VARCHAR(50),
`zip` VARCHAR(50),
`user_id` INT,
PRIMARY KEY (`id`)
) CHARACTER SET latin1;
