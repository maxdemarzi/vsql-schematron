CREATE TABLE `DEPT` (
`DEPTNO` INT NOT NULL,
`DNAME` VARCHAR(50),
`LOCATION` VARCHAR(50),
PRIMARY KEY (`DEPTNO`)
) CHARACTER SET latin1;
CREATE TABLE `EMP` (
`EMPNO` INT NOT NULL,
`ENAME` VARCHAR(50),
`JOB` VARCHAR(50),
`HIREDATE` DATE,
`SALARY` DECIMAL(10,2),
`COMMISSION` DECIMAL(10,2),
`DEPTNO` INT,
`Version` INT,
PRIMARY KEY (`EMPNO`)
) CHARACTER SET latin1;
CREATE TABLE `users` (
`username` VARCHAR(50),
`password` VARCHAR(50)
) CHARACTER SET latin1;
CREATE TABLE `Accounts` (
`accountName` VARCHAR(50),
`balance` INT,
`version` INT
) CHARACTER SET latin1;
