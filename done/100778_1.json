          "UNIQUE": true,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": true,
          "IS_INDEX": false,
          "COMMENT": "The application id, e.g., application_1236543456321_1234567"
        },
        "name": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
