          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The user who started the application"
        },
        "queue_name": {
          "TYPE": "Varchar",
          "NULLABLE": null,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The queue the application was submitted to"
        },
        "start_time": {
          "TYPE": "UnsignedBigInt",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The time in which application started"
        },
        "finish_time": {
          "TYPE": "UnsignedBigInt",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
