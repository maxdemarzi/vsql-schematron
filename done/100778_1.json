        },
        "job_type": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The Job Type e.g, Pig, Hive, Spark, HadoopJava"
        },
        "severity": {
          "TYPE": "UnsignedTinyInt",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "Aggregate severity of all the heuristics. Ranges from 0(LOW) to 4(CRITICAL)"
        },
        "score": {
          "TYPE": "UnsignedMediumInt",
          "NULLABLE": null,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The application score which is the sum of heuristic scores"
        },
        "workflow_depth": {
          "TYPE": "UnsignedTinyInt",
          "NULLABLE": null,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The application depth in the scheduled flow. Depth starts from 0"
        },
        "scheduler": {
          "TYPE": "Varchar",
          "NULLABLE": null,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The scheduler which triggered the application"
        },
        "job_name": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The name of the job in the flow to which this app belongs"
        },
        "job_exec_id": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A unique reference to a specific execution of the job/action(job in the workflow). This should filter all applications (mapreduce/spark) triggered by the job for a particular execution."
        },
        "flow_exec_id": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A unique reference to a specific flow execution. This should filter all applications fired by a particular flow execution. Note that if the scheduler supports sub-workflows, then this ID should be the super parent flow execution id that triggered the the applications and sub-workflows."
        },
        "job_def_id": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A unique reference to the job in the entire flow independent of the execution. This should filter all the applications(mapreduce/spark) triggered by the job for all the historic executions of that job."
        },
        "flow_def_id": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A unique reference to the entire flow independent of any execution. This should filter all the historic mr jobs belonging to the flow. Note that if your scheduler supports sub-workflows, then this ID should reference the super parent flow that triggered the all the jobs and sub-workflows."
        },
        "job_exec_url": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A url to the job execution on the scheduler"
        },
        "flow_exec_url": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A url to the flow execution on the scheduler"
        },
        "job_def_url": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A url to the job definition on the scheduler"
        },
        "flow_def_url": {
          "TYPE": "Varchar",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": "",
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "A url to the flow definition on the scheduler"
        }
      },
      "PRIMARY_KEYS": [
        "id"
      ],
