        },
        "severity": {
          "TYPE": "UnsignedTinyInt",
          "NULLABLE": false,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The heuristic severity ranging from 0(LOW) to 4(CRITICAL)"
        },
        "score": {
          "TYPE": "UnsignedMediumInt",
          "NULLABLE": null,
          "UNIQUE": null,
          "DEFAULT": null,
          "CHECKS": [],
          "IS_PRIMARY": false,
          "IS_INDEX": false,
          "COMMENT": "The heuristic score for the application. score = severity * number_of_tasks(map/reduce) where severity not in [0,1], otherwise score = 0"
        }
