          "VALUES": [
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443.",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443.",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443.",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443.",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443.",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443",
            "\u0412\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u0433\u043e\u0440\u043e\u0436\u0430\u043d\u0435 \u0438 \u0445\u0438\u0442\u0440\u0430\u044f \u0432\u0435\u0434\u044c\u043c\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442 \u0413\u0435\u0440\u0430\u043b\u044c\u0442\u0430 \u0432 \u0411\u043b\u0430\u0432\u0438\u043a\u0435\u043d\u0435. \u0426\u0438\u0440\u0438 \u0432\u044b\u044f\u0441\u043d\u044f\u0435\u0442, \u0447\u0442\u043e \u0435\u0435 \u043a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u0442\u0432\u043e \u0440\u0443\u0448\u0438\u0442\u0441\u044f, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u041d\u0438\u043b\u044c\u0444\u0433\u0430\u0430\u0440\u0434 \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u0432\u043e\u0435\u0432\u0430\u0442\u044c \u0426\u0438\u043d\u0442\u0440\u0443",
